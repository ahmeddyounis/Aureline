  "downgrade_rules": [
    {
      "rule_id": "downgrade_rule:certified_archetype_unmanifested",
      "title": "Certified claim without a manifest entry",
      "trigger_reason": "certified_archetype_unmanifested",
      "applies_to_classes": [
        "certified"
      ],
      "default_action": "narrow_published_class",
      "blocks_publication": true,
      "rationale": "A subject put forward as Certified that does not reference a certified-archetype manifest entry narrows below Certified until a manifest entry is published."
    },
    {
      "rule_id": "downgrade_rule:certified_archetype_evidence_stale",
      "title": "Certified-archetype report no longer fresh",
      "trigger_reason": "certified_archetype_evidence_stale",
      "applies_to_classes": [
        "certified"
      ],
      "default_action": "refresh_certified_archetype",
      "blocks_publication": true,
      "rationale": "A Certified claim cannot ride a certified-archetype report that has aged out of its freshness window; the report must be refreshed before the claim publishes."
    },
    {
      "rule_id": "downgrade_rule:certified_archetype_decertified",
      "title": "Referenced archetype decertified",
      "trigger_reason": "certified_archetype_decertified",
      "applies_to_classes": [
        "certified"
      ],
      "default_action": "route_to_supported_mode",
      "blocks_publication": true,
      "rationale": "When the referenced certified-archetype manifest entry is decertified the subject narrows and routes users to a supported mode rather than claiming certification it no longer holds."
    },
    {
      "rule_id": "downgrade_rule:support_evidence_missing",
      "title": "Required support evidence absent",
      "trigger_reason": "support_evidence_missing",
      "applies_to_classes": [
        "certified",
        "supported",
        "community",
        "experimental"
      ],
      "default_action": "narrow_published_class",
      "blocks_publication": true,
      "rationale": "A positive support class with no evidence on its required evidence path narrows; an empty evidence set cannot back a published support claim."
    },
    {
      "rule_id": "downgrade_rule:support_evidence_stale",
      "title": "Support evidence no longer fresh",
      "trigger_reason": "support_evidence_stale",
      "applies_to_classes": [
        "certified",
        "supported",
        "community",
        "experimental"
      ],
      "default_action": "narrow_published_class",
      "blocks_publication": true,
      "rationale": "Support wording cannot ride evidence that has aged out of its freshness window; the published class narrows until the evidence is rerun."
    },
    {
      "rule_id": "downgrade_rule:backing_stable_claim_narrowed",
      "title": "Backing stable claim narrowed below cutline",
      "trigger_reason": "backing_stable_claim_narrowed",
      "applies_to_classes": [
        "certified",
        "supported",
        "community",
        "experimental"
      ],
      "default_action": "narrow_published_class",
      "blocks_publication": true,
      "rationale": "A support class that depends on a stable claim narrows automatically when that claim drops below the stable cutline, so published support never outruns the stable line it ingests."
    },
    {
      "rule_id": "downgrade_rule:waiver_expired",
      "title": "Provisional waiver expired",
      "trigger_reason": "waiver_expired",
      "applies_to_classes": [
        "certified",
        "supported",
        "community",
        "experimental"
      ],
      "default_action": "hold_publication",
      "blocks_publication": true,
      "rationale": "A class that only held because of a waiver narrows the moment the waiver expires; publication holds rather than silently widening."
    },
    {
      "rule_id": "downgrade_rule:owner_signoff_missing",
      "title": "Support claim lacks owner sign-off",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_classes": [
        "certified",
        "supported"
      ],
      "default_action": "request_owner_signoff",
      "blocks_publication": true,
      "rationale": "No certified or supported claim publishes without a named owner sign-off; an unsigned row holds publication until the owner signs."
    }
