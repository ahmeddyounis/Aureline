  "launch_cutline": {
    "cutline_level": "stable",
    "above_cutline_levels": [
      "lts",
      "stable"
    ],
    "below_cutline_levels": [
      "beta",
      "preview",
      "withdrawn"
    ],
    "description": "A maintenance lane (a hotfix lane, a supported-line backport lane, a correction-train lane, or a support-window commitment) governs a Stable (or LTS) maintenance promise only when its control packet is within its freshness SLO, any waiver it relies on is unexpired, its support window is complete and not past its end-of-support date, an owner has signed off, and the public claim it backs is itself at or above the cutline. A lane that loses any of those governs a label below the cutline (beta, preview, withdrawn) and never inherits an adjacent lane's governed label."
  },
  "release_blocking_lane_refs": [
    "lane:provider_hotfix",
    "lane:rollback_correction_train",
    "lane:rollback_support_window",
    "lane:provider_support_window",
    "lane:export_backport",
    "lane:localization_backport",
    "lane:regulated_support_window",
    "lane:repair_hotfix"
  ],
  "control_rules": [
    {
      "rule_id": "control_rule:claim_label_narrowed",
      "title": "Backing public claim narrowed below cutline",
      "trigger_reason": "claim_label_narrowed",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_control_label",
      "blocks_publication": false,
      "rationale": "A lane whose backing public claim is already below the stable cutline inherits that ceiling; the stable claim manifest already holds the claim upstream, so this is expected inheritance rather than a control defect and does not hold publication on its own."
    },
    {
      "rule_id": "control_rule:lane_capability_absent",
      "title": "Lane names an unimplemented maintenance capability",
      "trigger_reason": "lane_capability_absent",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_control_evidence",
      "blocks_publication": true,
      "rationale": "A lane that names a maintenance capability the build does not yet implement cannot govern a Stable maintenance promise; the lane narrows and publication holds until the capability lands and is re-evidenced."
    },
    {
      "rule_id": "control_rule:control_evidence_incomplete",
      "title": "Lane control evidence incomplete",
      "trigger_reason": "control_evidence_incomplete",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_control_evidence",
      "blocks_publication": true,
      "rationale": "A lane whose control packet does not cover the lane's drill, staffing, or rollback-target evidence narrows until the evidence is recaptured; the lane cannot govern Stable on partial evidence."
    },
    {
      "rule_id": "control_rule:support_window_incomplete",
      "title": "Support window incomplete",
      "trigger_reason": "support_window_incomplete",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "complete_support_window",
      "blocks_publication": true,
      "rationale": "A lane whose support window is missing an opened, review-through, or end-of-support date cannot govern a Stable maintenance promise; the lane narrows until the window is completed."
    },
    {
      "rule_id": "control_rule:support_window_expired",
      "title": "Support window expired",
      "trigger_reason": "support_window_expired",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "complete_support_window",
      "blocks_publication": true,
      "rationale": "A lane whose support window has passed its end-of-support date without being renewed or formally moved to end-of-life cannot govern a Stable maintenance promise; the window stays narrowed and publication holds until the window is renewed or its end-of-support is formally scheduled."
    },
    {
      "rule_id": "control_rule:control_packet_freshness_breached",
      "title": "Control packet breached its freshness SLO",
      "trigger_reason": "control_packet_freshness_breached",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_control_packet",
      "blocks_publication": true,
      "rationale": "A lane cannot govern a Stable maintenance promise on a control packet that has aged past its freshness SLO; the lane narrows and the packet must be refreshed before it backs the lane again."
    },
    {
      "rule_id": "control_rule:control_packet_missing",
      "title": "No control packet captured",
      "trigger_reason": "control_packet_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_control_packet",
      "blocks_publication": true,
      "rationale": "A lane with no captured control packet has nothing to govern against and narrows until a packet lands."
    },
    {
      "rule_id": "control_rule:waiver_expired",
      "title": "Provisional waiver expired",
      "trigger_reason": "waiver_expired",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "hold_publication",
      "blocks_publication": true,
      "rationale": "A lane that only governed a Stable maintenance promise because of a waiver narrows the moment the waiver expires; publication holds rather than silently keeping the promise."
    },
    {
      "rule_id": "control_rule:owner_signoff_missing",
      "title": "Governed lane lacks owner sign-off",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "request_owner_signoff",
      "blocks_publication": true,
      "rationale": "No lane governs a Stable or LTS maintenance promise without a named owner sign-off; an unsigned lane holds publication until the owner signs."
    }
  ],
