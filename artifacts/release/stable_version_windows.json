    "below_cutline_levels": [
      "beta",
      "preview",
      "withdrawn"
    ],
    "description": "An interface surface freezes a Stable (or LTS) version window only when its freeze packet is within its freshness SLO, any waiver it relies on is unexpired, its deprecation packet is complete with no overdue removal, its surface-level version evidence is complete, an owner has signed off, and the public claim it backs is itself at or above the cutline. A surface that loses any of those freezes a label below the cutline (beta, preview, withdrawn) and never inherits an adjacent surface's frozen label."
  },
  "release_blocking_surface_refs": [
    "api_surface:provider_routing",
    "cli_surface:repair_rollback_commands",
    "schema_surface:state_snapshot",
    "manifest_surface:update_manifest",
    "schema_surface:export_bundle",
    "cli_surface:localization_tooling",
    "manifest_surface:regulated_deploy",
    "api_surface:rollback_orchestration"
  ],
  "freeze_rules": [
    {
      "rule_id": "freeze_rule:claim_label_narrowed",
      "title": "Backing public claim narrowed below cutline",
      "trigger_reason": "claim_label_narrowed",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_window_label",
      "blocks_publication": false,
      "rationale": "A surface whose backing public claim is already below the stable cutline inherits that ceiling; the stable claim manifest already holds the claim upstream, so this is expected inheritance rather than a freeze defect and does not hold publication on its own."
    },
    {
      "rule_id": "freeze_rule:surface_capability_absent",
      "title": "Surface names an unimplemented version or capability",
      "trigger_reason": "surface_capability_absent",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_surface_evidence",
      "blocks_publication": true,
      "rationale": "A surface that names a version or capability the build does not yet implement cannot freeze a Stable window; the freeze narrows and publication holds until the capability lands and is re-evidenced."
    },
    {
      "rule_id": "freeze_rule:freeze_evidence_incomplete",
      "title": "Surface version evidence incomplete",
      "trigger_reason": "freeze_evidence_incomplete",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_surface_evidence",
      "blocks_publication": true,
      "rationale": "A surface whose freeze packet does not cover the surface-level version inventory narrows until the evidence is recaptured; the window cannot freeze Stable on partial evidence."
    },
    {
      "rule_id": "freeze_rule:deprecation_packet_incomplete",
      "title": "Deprecation packet incomplete",
      "trigger_reason": "deprecation_packet_incomplete",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "complete_deprecation_packet",
      "blocks_publication": true,
      "rationale": "A surface whose deprecation packet is missing a migration path, replacement, or removal target for a deprecated version cannot freeze a Stable window; the freeze narrows until the packet is completed."
    },
    {
      "rule_id": "freeze_rule:deprecation_removal_overdue",
      "title": "Deprecation removal overdue",
      "trigger_reason": "deprecation_removal_overdue",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "complete_deprecation_packet",
      "blocks_publication": true,
      "rationale": "A surface carrying a deprecation whose removal target date has passed without the removal landing cannot freeze a Stable window; the window stays narrowed and publication holds until the removal happens or the target is formally reset."
    },
    {
      "rule_id": "freeze_rule:freeze_packet_freshness_breached",
      "title": "Freeze packet breached its freshness SLO",
      "trigger_reason": "freeze_packet_freshness_breached",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_freeze_packet",
      "blocks_publication": true,
      "rationale": "A surface cannot freeze a Stable window on a freeze packet that has aged past its freshness SLO; the freeze narrows and the packet must be refreshed before it backs the window again."
    },
    {
      "rule_id": "freeze_rule:freeze_packet_missing",
      "title": "No freeze packet captured",
      "trigger_reason": "freeze_packet_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_freeze_packet",
      "blocks_publication": true,
      "rationale": "A surface with no captured freeze packet has nothing to freeze against and narrows until a packet lands."
    },
    {
      "rule_id": "freeze_rule:waiver_expired",
      "title": "Provisional waiver expired",
      "trigger_reason": "waiver_expired",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "hold_publication",
      "blocks_publication": true,
      "rationale": "A surface that only froze a Stable window because of a waiver narrows the moment the waiver expires; publication holds rather than silently keeping the freeze."
    },
    {
      "rule_id": "freeze_rule:owner_signoff_missing",
      "title": "Frozen surface lacks owner sign-off",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "request_owner_signoff",
      "blocks_publication": true,
      "rationale": "No surface freezes a Stable or LTS window without a named owner sign-off; an unsigned freeze holds publication until the owner signs."
    }
  ],
