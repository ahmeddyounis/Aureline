  "launch_cutline": {
    "cutline_level": "stable",
    "above_cutline_levels": [
      "lts",
      "stable"
    ],
    "below_cutline_levels": [
      "beta",
      "preview",
      "withdrawn"
    ],
    "description": "A publication (a known-limits, public benchmark, compatibility, or migration publication) carries a Stable (or LTS) public claim only when its proof packet is within its freshness SLO, any waiver it relies on is unexpired, its benchmark measurements (where it makes a performance claim) are within the published p50/p95 budget with corpus metadata and a benchmark-lab trace, an owner has signed off, and the public claim it backs is itself at or above the cutline. A publication that loses any of those carries a label below the cutline (beta, preview, withdrawn) and never inherits an adjacent publication's published label."
  },
  "release_blocking_surface_refs": [
    "surface:provider_aware_language_intelligence",
    "surface:repair_and_rollback_safety_known_limits",
    "surface:export_and_offboarding_known_limits",
