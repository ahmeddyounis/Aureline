    "surface:rollback_migration_guide"
  ],
  "publication_rules": [
    {
      "rule_id": "pub_rule:claim_label_narrowed",
      "title": "Backing public claim narrowed below cutline",
      "trigger_reason": "claim_label_narrowed",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_publication_label",
      "blocks_publication": false,
      "rationale": "A publication whose backing public claim is already below the stable cutline inherits that ceiling; the stable claim manifest already holds the claim upstream, so this is expected inheritance rather than a publication defect and does not hold publication on its own."
    },
    {
      "rule_id": "pub_rule:surface_capability_absent",
      "title": "Publication names an unimplemented surface capability",
      "trigger_reason": "surface_capability_absent",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_evidence",
      "blocks_publication": true,
      "rationale": "A publication that names a surface capability the build does not yet implement cannot carry a Stable public claim; the publication narrows and publication holds until the capability lands and is re-evidenced."
    },
    {
      "rule_id": "pub_rule:evidence_incomplete",
      "title": "Publication evidence incomplete",
      "trigger_reason": "evidence_incomplete",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_evidence",
      "blocks_publication": true,
      "rationale": "A publication whose proof packet does not cover the caveat set, report scope, or guide coverage it asserts narrows until the evidence is recaptured; the publication cannot carry Stable on partial evidence."
    },
    {
      "rule_id": "pub_rule:corpus_metadata_missing",
      "title": "Benchmark corpus metadata or lab trace missing",
      "trigger_reason": "corpus_metadata_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_proof_packet",
      "blocks_publication": true,
      "rationale": "A benchmark publication whose published numbers cannot be traced to a corpus manifest and a benchmark-lab trace narrows until both are attached; an untraceable benchmark cannot carry a Stable public claim."
    },
    {
      "rule_id": "pub_rule:budget_regressed",
      "title": "Benchmark measured p50/p95 regressed beyond published budget",
      "trigger_reason": "budget_regressed",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "retune_or_waive_budget",
      "blocks_publication": true,
      "rationale": "A benchmark publication whose measured p50/p95 exceeds the published budget narrows until the implementation re-meets the budget, the published numbers are re-published, or a waiver covers an intentionally tightened threshold; a Stable benchmark claim may not be wider than the measured numbers support."
    },
    {
      "rule_id": "pub_rule:proof_packet_freshness_breached",
      "title": "Proof packet breached its freshness SLO",
      "trigger_reason": "proof_packet_freshness_breached",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_proof_packet",
      "blocks_publication": true,
      "rationale": "A publication whose proof packet aged past its freshness SLO narrows until the packet is refreshed; a stale packet cannot carry a Stable public claim even when the claim it backs is still published Stable upstream."
    },
    {
      "rule_id": "pub_rule:proof_packet_missing",
      "title": "Proof packet missing",
      "trigger_reason": "proof_packet_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_proof_packet",
      "blocks_publication": true,
      "rationale": "A publication with no captured proof packet narrows until one is captured; an unproven publication cannot carry a Stable public claim."
    },
    {
      "rule_id": "pub_rule:waiver_expired",
      "title": "Publication waiver expired",
      "trigger_reason": "waiver_expired",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_publication_label",
      "blocks_publication": true,
      "rationale": "A publication that carried a Stable public claim only under a waiver narrows the moment that waiver expires; publication holds until the underlying gap is closed or a fresh waiver is granted."
    },
    {
      "rule_id": "pub_rule:owner_signoff_missing",
      "title": "Owner sign-off missing",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "request_owner_signoff",
      "blocks_publication": true,
      "rationale": "A publication carrying a Stable public claim requires an owner sign-off; without it the publication narrows and publication holds until the owner signs off."
    }
  ],
