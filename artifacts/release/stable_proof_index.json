  "launch_cutline": {
    "cutline_level": "stable",
    "above_cutline_levels": [
      "lts",
      "stable"
    ],
    "below_cutline_levels": [
      "beta",
      "preview",
      "withdrawn"
    ],
    "description": "A launch-blocking requirement backs a Stable (or LTS) public claim only when its proof packet is within its freshness SLO, any waiver it relies on is unexpired, its requirement-level evidence is complete, an owner has signed off, and the public claim it backs is itself at or above the cutline. A requirement that loses any of those backs a label below the cutline (beta, preview, withdrawn) and never inherits an adjacent requirement's proven label."
  },
  "launch_blocking_requirement_refs": [
    "launch_req:provider_routing_and_fallback",
    "launch_req:provider_completion_quality",
    "launch_req:rollback_live_hardware_drill",
    "launch_req:rollback_state_integrity",
    "launch_req:export_offboarding_fidelity",
    "launch_req:localization_locale_coverage",
    "launch_req:regulated_sovereign_evidence",
    "launch_req:enterprise_docs_matrices_known_limits"
  ],
  "proof_rules": [
    {
      "rule_id": "proof_index_rule:claim_label_narrowed",
      "title": "Backing public claim narrowed below cutline",
      "trigger_reason": "claim_label_narrowed",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_claim_label",
      "blocks_publication": false,
      "rationale": "A requirement whose backing public claim is already below the stable cutline inherits that ceiling; the stable claim manifest already holds the claim upstream, so this is expected inheritance rather than a proof-index defect and does not hold publication on its own."
    },
    {
      "rule_id": "proof_index_rule:requirement_capability_absent",
      "title": "Requirement names an unimplemented capability",
      "trigger_reason": "requirement_capability_absent",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_requirement_evidence",
      "blocks_publication": true,
      "rationale": "A launch-blocking requirement that names a capability the build does not yet implement cannot back a Stable public claim; the proof narrows and publication holds until the capability lands and is re-proven."
    },
    {
      "rule_id": "proof_index_rule:requirement_evidence_incomplete",
      "title": "Requirement-level evidence incomplete",
      "trigger_reason": "requirement_evidence_incomplete",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_requirement_evidence",
      "blocks_publication": true,
      "rationale": "A requirement whose proof packet does not cover the requirement-level evidence narrows until the evidence is recaptured; the public claim cannot publish Stable on partial proof."
    },
    {
      "rule_id": "proof_index_rule:proof_packet_freshness_breached",
      "title": "Proof packet breached its freshness SLO",
      "trigger_reason": "proof_packet_freshness_breached",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_proof_packet",
      "blocks_publication": true,
      "rationale": "A requirement cannot back a Stable public claim on a proof packet that has aged past its freshness SLO; the proof narrows and the packet must be refreshed before it backs the claim again."
    },
    {
      "rule_id": "proof_index_rule:proof_packet_missing",
      "title": "No proof packet captured",
      "trigger_reason": "proof_packet_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_proof_packet",
      "blocks_publication": true,
      "rationale": "A launch-blocking requirement with no captured proof packet has nothing to prove against and narrows until a packet lands."
    },
    {
      "rule_id": "proof_index_rule:waiver_expired",
      "title": "Provisional waiver expired",
      "trigger_reason": "waiver_expired",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "hold_publication",
      "blocks_publication": true,
      "rationale": "A requirement that only backed a Stable claim because of a waiver narrows the moment the waiver expires; publication holds rather than silently keeping the proof."
    },
    {
      "rule_id": "proof_index_rule:owner_signoff_missing",
      "title": "Proven requirement lacks owner sign-off",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "request_owner_signoff",
      "blocks_publication": true,
      "rationale": "No requirement backs a Stable or LTS public claim without a named owner sign-off; an unsigned proof holds publication until the owner signs."
    }
  ],
