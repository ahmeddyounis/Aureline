  "launch_cutline": {
    "cutline_level": "stable",
    "above_cutline_levels": [
      "lts",
      "stable"
    ],
    "below_cutline_levels": [
      "beta",
      "preview",
      "withdrawn"
    ],
    "description": "A value line publishes a Stable (or LTS) lifecycle label for a subject only when the subject's canonical manifest label is at or above the cutline, the line carries every capability the subject needs, the line's qualification evidence holds, its proof packet is within its freshness SLO, and an owner has signed off. A value line that loses any of those drops to a label below the cutline (beta, preview, withdrawn) and never publishes wider than the subject's canonical manifest label."
  },
  "boundary_rules": [
    {
      "rule_id": "boundary_rule:manifest_label_narrowed",
      "title": "Subject canonical label below cutline",
      "trigger_reason": "manifest_label_narrowed",
      "applies_to_labels": [
        "beta",
        "preview",
        "withdrawn"
      ],
      "default_action": "narrow_line_label",
      "blocks_publication": false,
      "rationale": "When the subject's canonical manifest label is already below the cutline, every value line inherits that ceiling and narrows. This is expected inheritance, not a boundary defect, so it narrows the line label without holding boundary publication; the stable claim manifest already holds that subject upstream."
    },
    {
      "rule_id": "boundary_rule:line_capability_absent",
      "title": "Value line lacks a required capability",
      "trigger_reason": "line_capability_absent",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "revalidate_line_support",
      "blocks_publication": true,
      "rationale": "A value line whose subject is canonically Stable but which lacks a capability the subject needs cannot publish Stable in that line; it narrows until the capability lands or the line is formally excluded."
    },
    {
      "rule_id": "boundary_rule:line_evidence_incomplete",
      "title": "Line-specific qualification incomplete",
      "trigger_reason": "line_evidence_incomplete",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "revalidate_line_support",
      "blocks_publication": true,
      "rationale": "A Stable subject whose line-specific qualification evidence is missing or narrowed cannot publish Stable in that line; it narrows until the line re-qualifies."
    },
    {
      "rule_id": "boundary_rule:boundary_packet_freshness_breached",
      "title": "Line proof packet breached its freshness SLO",
      "trigger_reason": "boundary_packet_freshness_breached",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_boundary_packet",
      "blocks_publication": true,
      "rationale": "A Stable line label cannot ride a proof packet that has aged past its freshness SLO; the line narrows and the packet must be refreshed before it publishes again."
    },
    {
      "rule_id": "boundary_rule:boundary_packet_missing",
      "title": "No line proof packet captured",
      "trigger_reason": "boundary_packet_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_boundary_packet",
      "blocks_publication": true,
      "rationale": "A Stable line label with no captured proof packet has nothing to publish against and narrows until a packet lands."
    },
    {
      "rule_id": "boundary_rule:waiver_expired",
      "title": "Line waiver expired",
      "trigger_reason": "waiver_expired",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "hold_publication",
      "blocks_publication": true,
      "rationale": "A line label that only held because of a waiver narrows the moment the waiver expires; boundary publication holds rather than silently keeping the label."
    },
    {
      "rule_id": "boundary_rule:owner_signoff_missing",
      "title": "Published line label lacks owner sign-off",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "request_owner_signoff",
      "blocks_publication": true,
      "rationale": "No Stable or LTS line label publishes without a named owner sign-off; an unsigned row holds publication until the owner signs."
    }
  ],
