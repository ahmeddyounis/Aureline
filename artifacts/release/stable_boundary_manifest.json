      "title": "Local OSS",
      "connectivity_posture": "no required outbound network; account-free local mode",
      "description": "The account-free open-source desktop product with no hosted dependency. A subject is carried here when it works against local sidecars, bring-your-own provider keys, or on-disk state without any vendor service."
    },
    {
      "value_line": "self_hosted",
      "title": "Self-hosted",
      "connectivity_posture": "customer-operated control plane and mirrors; egress to customer infra only",
      "description": "Customer-run control plane, identity, registry mirror, and relay infrastructure. A subject is carried here when its managed dependencies have a documented self-hosted form the customer can stand up."
    },
    {
      "value_line": "managed",
      "title": "Managed",
      "connectivity_posture": "vendor-hosted convenience services reachable over the network",
      "description": "Vendor-hosted convenience services (managed gateway, sync, marketplace hosting, collaboration brokering). A subject is carried here when its hosted dependencies are reachable and qualified."
    },
    {
      "value_line": "air_gapped",
      "title": "Air-gapped",
      "connectivity_posture": "no outbound connectivity; mirror-only, sovereign deployment",
      "description": "Offline / sovereign deployment with no outbound connectivity, fed only by mirrored updates, models, and policy bundles. A subject is carried here only when it has a fully offline, mirror-fed form that is qualified for the air-gapped line."
    }
  ],
  "boundary_states": [
    "available",
