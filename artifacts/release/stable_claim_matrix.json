    "description": "A row may publish as Stable (or LTS) only when its qualification state holds the claim with current, owner-signed proof. Any row that is not qualified, has stale evidence, or relied on an expired waiver drops below this cutline to beta, preview, or withdrawn and never inherits an adjacent green row."
  },
  "stop_rules": [
    {
      "rule_id": "stop_rule:qualification_gap",
      "title": "Stable claim lacks qualification proof",
      "trigger_reason": "qualification_evidence_missing",
      "applies_to_levels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_claim",
      "blocks_promotion": true,
      "rationale": "A surface put forward as Stable with no qualification proof is narrowed below the cutline and holds the stable train until proof lands."
    },
    {
      "rule_id": "stop_rule:stale_qualification_evidence",
      "title": "Stable claim evidence no longer current",
      "trigger_reason": "qualification_evidence_stale",
      "applies_to_levels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_evidence_packet",
      "blocks_promotion": true,
      "rationale": "Stable wording cannot ride evidence that has aged out of its freshness window; the packet must be refreshed before promotion proceeds."
    },
    {
      "rule_id": "stop_rule:freshness_window",
      "title": "Evidence freshness window exceeded",
      "trigger_reason": "freshness_window_exceeded",
      "applies_to_levels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_evidence_packet",
      "blocks_promotion": true,
      "rationale": "When the declared freshness window has elapsed the row stops being claim-bearing and promotion holds until a current packet is recorded."
    },
    {
      "rule_id": "stop_rule:waiver_expiry",
      "title": "Provisional waiver expired",
      "trigger_reason": "waiver_expired",
      "applies_to_levels": [
        "lts",
        "stable"
      ],
      "default_action": "hold_promotion",
      "blocks_promotion": true,
      "rationale": "A claim that only held because of a waiver must narrow the moment the waiver expires; the stable train holds rather than silently widening."
    },
    {
      "rule_id": "stop_rule:missing_owner_signoff",
      "title": "Stable claim lacks owner sign-off",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_levels": [
        "lts",
        "stable"
      ],
      "default_action": "hold_promotion",
      "blocks_promotion": true,
      "rationale": "No stable claim widens without a named owner sign-off; an unsigned row holds promotion until the owner signs."
    },
    {
      "rule_id": "stop_rule:compatibility_degraded",
      "title": "Backing compatibility row degraded",
      "trigger_reason": "compatibility_row_degraded",
      "applies_to_levels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_claim",
      "blocks_promotion": true,
      "rationale": "A stable claim that depends on a compatibility row narrows when that row degrades, so launch wording never outruns its compatibility evidence."
    },
    {
      "rule_id": "stop_rule:blocking_defect",
      "title": "Blocking defect open against claimed surface",
      "trigger_reason": "blocking_defect_open",
      "applies_to_levels": [
        "lts",
        "stable"
      ],
      "default_action": "staff_correction_lane",
      "blocks_promotion": true,
      "rationale": "An open blocking defect against a claimed surface staffs a correction lane and holds promotion until the defect is closed or the claim narrows."
    }
  ],
