    "below_cutline_levels": [
      "beta",
      "preview",
      "withdrawn"
    ],
    "description": "A subject publishes a Stable (or LTS) lifecycle label only when its backing stable claim still holds, every backing qualification lane holds, its support class still holds, its proof packet is within its freshness SLO, and an owner has signed off. A subject that loses any of those drops to a label below the cutline (beta, preview, withdrawn) and never inherits an adjacent subject's published label."
  },
  "publication_rules": [
    {
      "rule_id": "publication_rule:backing_claim_narrowed",
      "title": "Backing stable claim narrowed below cutline",
      "trigger_reason": "backing_claim_narrowed",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_label",
      "blocks_publication": true,
      "rationale": "A lifecycle label that depends on a stable claim narrows automatically when that claim drops below the stable cutline, so the published label never outruns the stable line it ingests."
    },
    {
      "rule_id": "publication_rule:qualification_incomplete",
      "title": "Backing qualification lane narrowed",
      "trigger_reason": "qualification_incomplete",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "revalidate_backing_claim",
      "blocks_publication": true,
      "rationale": "A label whose backing qualification lane is narrowed below the cutline cannot publish as Stable; it narrows until the lane re-qualifies."
    },
    {
      "rule_id": "publication_rule:support_class_thinned",
      "title": "Backing support class thinned",
      "trigger_reason": "support_class_thinned",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_label",
      "blocks_publication": true,
      "rationale": "When the backing support class narrows below the class it was put forward as, the lifecycle label narrows with it so published maturity never outruns published support."
    },
    {
      "rule_id": "publication_rule:proof_packet_freshness_breached",
      "title": "Proof packet breached its freshness SLO",
      "trigger_reason": "proof_packet_freshness_breached",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_proof_packet",
      "blocks_publication": true,
      "rationale": "A Stable label cannot ride a proof packet that has aged past its freshness SLO; the label narrows and the packet must be refreshed before it publishes again."
    },
    {
      "rule_id": "publication_rule:proof_packet_missing",
      "title": "No proof packet captured",
      "trigger_reason": "proof_packet_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_proof_packet",
      "blocks_publication": true,
      "rationale": "A Stable label with no captured proof packet has nothing to publish against and narrows until a packet lands."
    },
    {
      "rule_id": "publication_rule:waiver_expired",
      "title": "Provisional waiver expired",
      "trigger_reason": "waiver_expired",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "hold_publication",
      "blocks_publication": true,
      "rationale": "A label that only held because of a waiver narrows the moment the waiver expires; publication holds rather than silently keeping the label."
    },
    {
      "rule_id": "publication_rule:owner_signoff_missing",
      "title": "Published label lacks owner sign-off",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "request_owner_signoff",
      "blocks_publication": true,
      "rationale": "No Stable or LTS label publishes without a named owner sign-off; an unsigned entry holds publication until the owner signs."
    }
