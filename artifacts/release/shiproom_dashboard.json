  "stop_rules": [
    {
      "rule_id": "stop_rule:claim_label_narrowed",
      "title": "Backing public claim narrowed below cutline",
      "trigger_reason": "claim_label_narrowed",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_panel_label",
      "blocks_promotion": false,
      "rationale": "A panel whose backing public claim is already below the stable cutline inherits that ceiling; the stable claim manifest already holds the claim upstream, so this is expected inheritance rather than a dashboard defect and does not hold promotion on its own."
    },
    {
      "rule_id": "stop_rule:panel_capability_absent",
      "title": "Panel names an unimplemented dashboard capability",
      "trigger_reason": "panel_capability_absent",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_panel_evidence",
      "blocks_promotion": true,
      "rationale": "A panel that names a dashboard capability the build does not yet implement cannot render green for a Stable claim; the panel narrows and promotion holds until the capability lands and is re-evidenced."
    },
    {
      "rule_id": "stop_rule:qualification_row_regressed",
      "title": "Watched qualification row regressed below cutline",
      "trigger_reason": "qualification_row_regressed",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "hold_promotion",
      "blocks_promotion": true,
      "rationale": "A panel whose watched qualification row has fallen below the cutline in the stable qualification matrix cannot keep rendering Stable; the panel narrows and promotion holds until the qualification row is re-qualified or the public claim is formally narrowed."
    },
    {
      "rule_id": "stop_rule:fitness_function_failing",
      "title": "Fitness function failed or is unmeasured",
      "trigger_reason": "fitness_function_failing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "remediate_fitness_function",
      "blocks_promotion": true,
      "rationale": "A panel carrying a fitness function whose measurement does not clear its threshold cannot render green for a Stable claim; the panel narrows and promotion holds until the metric is remediated back above its threshold."
    },
    {
      "rule_id": "stop_rule:panel_evidence_incomplete",
      "title": "Panel source/fitness evidence incomplete",
      "trigger_reason": "panel_evidence_incomplete",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_panel_evidence",
      "blocks_promotion": true,
      "rationale": "A panel whose source or fitness evidence is incomplete \u2014 including an unmeasured fitness function \u2014 narrows until the evidence is recaptured; a panel cannot render Stable on partial evidence."
    },
    {
      "rule_id": "stop_rule:freshness_packet_breached",
      "title": "Freshness packet breached its SLO",
      "trigger_reason": "freshness_packet_breached",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_freshness_packet",
      "blocks_promotion": true,
      "rationale": "A panel cannot render green for a Stable claim on a freshness packet that has aged past its SLO; the panel narrows and the packet must be refreshed before it backs the panel again."
    },
    {
      "rule_id": "stop_rule:freshness_packet_missing",
      "title": "No freshness packet captured",
      "trigger_reason": "freshness_packet_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_freshness_packet",
      "blocks_promotion": true,
      "rationale": "A panel with no captured freshness packet has nothing to render against and narrows until a packet lands."
    },
    {
      "rule_id": "stop_rule:waiver_expired",
      "title": "Provisional waiver expired",
      "trigger_reason": "waiver_expired",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "hold_promotion",
      "blocks_promotion": true,
      "rationale": "A panel that only rendered green for a Stable claim because of a waiver narrows the moment the waiver expires; promotion holds rather than silently keeping the panel green."
    },
    {
      "rule_id": "stop_rule:owner_signoff_missing",
      "title": "Green panel lacks owner sign-off",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "request_owner_signoff",
      "blocks_promotion": true,
      "rationale": "No panel renders green for a Stable or LTS claim without a named owner sign-off; an unsigned panel holds promotion until the owner signs."
    }
  ],
