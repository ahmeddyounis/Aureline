    "shiproom_panel:provider_routing_truth",
    "shiproom_panel:desktop_qualification",
    "shiproom_panel:provider_proof_coverage",
    "shiproom_panel:rollback_maintenance_freshness",
    "shiproom_panel:state_schema_qualification",
    "shiproom_panel:provider_quality_fitness",
