%% M3 beta admission dependency graph.
%%
%% Mermaid source for the M3 beta scope, claimed-surface, and cohort dependency
%% map. Renderers and reviewers should treat this file as authoritative for
%% upstream blockers, downstream consumers, and the validator entry point.
%%
%% Canonical artifacts cited as graph nodes:
%%   - artifacts/milestones/m3/claimed_surface_register.json
%%   - artifacts/milestones/m3/cohort_guardrails.yaml
%%   - docs/milestones/m3/beta_admission_matrix.md
%%   - ci/check_beta_admission.py
%%
%% Upstream M2 artifacts the graph inherits:
%%   - artifacts/milestones/m2/alpha_wedge_matrix.yaml
%%   - artifacts/milestones/m2/exit_gate_scoreboard.yaml
%%   - artifacts/milestones/m2/dependency_graph.yaml
%%   - artifacts/certification/m2_archetype_seed_rows.yaml
%%   - artifacts/compat/reference_workspace_rows.yaml
%%   - artifacts/compat/archetype_rubric.yaml
%%   - artifacts/deployment/locality_matrix.yaml
%%   - docs/product/known_limits_contract.md
%%   - docs/governance/public_interface_versioning_policy.md
%%   - docs/release/certified_archetype_report_template.md

graph TD
    %% Upstream M2 contracts (inherited canonical truth)
    subgraph upstream_m2["Upstream M2 contracts (inherited)"]
        m2_matrix["alpha_wedge_matrix<br/>artifacts/milestones/m2/alpha_wedge_matrix.yaml"]
        m2_scoreboard["alpha_exit_gate_scoreboard<br/>artifacts/milestones/m2/exit_gate_scoreboard.yaml"]
        m2_graph["alpha_dependency_graph<br/>artifacts/milestones/m2/dependency_graph.yaml"]
        m2_archetype_seed["archetype_certification_seed_rows<br/>artifacts/certification/m2_archetype_seed_rows.yaml"]
        reference_workspace_rows["reference_workspace_rows<br/>artifacts/compat/reference_workspace_rows.yaml"]
        archetype_rubric["archetype_rubric<br/>artifacts/compat/archetype_rubric.yaml"]
        deployment_locality["deployment_locality_matrix<br/>artifacts/deployment/locality_matrix.yaml"]
        known_limits_contract["known_limits_contract<br/>docs/product/known_limits_contract.md"]
        public_interface_versioning["public_interface_versioning_policy<br/>docs/governance/public_interface_versioning_policy.md"]
        certified_archetype_template["certified_archetype_report_template<br/>docs/release/certified_archetype_report_template.md"]
    end

    %% M3 canonical artifacts (this task)
    subgraph m3_canonical["M3 beta canonical artifacts"]
        admission_doc["beta_admission_matrix<br/>docs/milestones/m3/beta_admission_matrix.md"]
        surface_register["claimed_surface_register<br/>artifacts/milestones/m3/claimed_surface_register.json"]
        cohort_guardrails["cohort_guardrails<br/>artifacts/milestones/m3/cohort_guardrails.yaml"]
    end

    %% First-consumer validator surface
    subgraph m3_consumers["M3 first consumers"]
        beta_admission_validator["beta_admission_validator<br/>ci/check_beta_admission.py"]
        validation_capture["beta_admission_validation_capture<br/>artifacts/milestones/m3/captures/beta_admission_validation_capture.json"]
    end

    %% Cohort and archetype scorecard lane
    subgraph m3_scorecards["M3 cohort and archetype scorecards"]
        cohort_scorecard_index["cohort_scorecard_index<br/>artifacts/milestones/m3/cohorts/scorecard_index.yaml"]
        archetype_scorecard_index["archetype_scorecard_index<br/>artifacts/compat/m3/archetype_scorecards/scorecard_index.yaml"]
        cohort_scorecards["cohort_scorecards<br/>artifacts/milestones/m3/cohorts/"]
        archetype_scorecards["archetype_scorecards<br/>artifacts/compat/m3/archetype_scorecards/"]
        scorecard_validator["scorecard_validator<br/>ci/check_cohort_archetype_scorecards.py"]
        scorecard_register["scorecard_register<br/>artifacts/milestones/m3/captures/cohort_archetype_scorecard_register.json"]
        scorecard_capture["scorecard_validation_capture<br/>artifacts/milestones/m3/captures/cohort_archetype_scorecard_validation_capture.json"]
    end

    %% Beta enablement starter-pack lane (extension authors, design
    %% partners / managed pilots, and community / issue routing).
    subgraph m3_starter_pack["M3 beta enablement starter pack"]
        starter_pack_yaml["beta_enablement_starter_pack<br/>artifacts/milestones/m3/beta_enablement_starter_pack.yaml"]
        starter_pack_extension_doc["beta_starter_pack_extension<br/>docs/extensions/m3/beta_starter_pack.md"]
        starter_pack_partner_doc["beta_starter_pack_partner<br/>docs/partners/m3/design_partner_beta_pack.md"]
        starter_pack_community_doc["beta_starter_pack_community<br/>docs/community/m3/issue_rfc_routing_beta.md"]
        starter_pack_validator["beta_enablement_starter_pack_validator<br/>ci/check_m3_beta_enablement_starter_pack.py"]
        starter_pack_capture["beta_enablement_starter_pack_capture<br/>artifacts/milestones/m3/captures/beta_enablement_starter_pack_validation_capture.json"]
        issue_routing_yaml["issue_routing<br/>artifacts/governance/issue_routing.yaml"]
    end

    %% Starter-pack lane edges (consumes the canonical truth set and
    %% renders the three audience entrypoint docs through the validator).
    surface_register -- "starter pack cites beta_surface ids" --> starter_pack_yaml
    cohort_guardrails -- "starter pack cites cohort_ids and downgrade rules" --> starter_pack_yaml
    cohort_scorecards -- "design-partner and extension lanes link the cohort scorecards" --> starter_pack_yaml
    issue_routing_yaml -- "starter pack admits issue_class ids by reference" --> starter_pack_yaml
    starter_pack_yaml -- "canonical source for the extension-author entrypoint" --> starter_pack_extension_doc
    starter_pack_yaml -- "canonical source for the design-partner entrypoint" --> starter_pack_partner_doc
    starter_pack_yaml -- "canonical source for the community / routing entrypoint" --> starter_pack_community_doc
    starter_pack_yaml -- "validator parses the pack and confirms refs" --> starter_pack_validator
    starter_pack_extension_doc -- "validator checks doc cross-refs" --> starter_pack_validator
    starter_pack_partner_doc -- "validator checks doc cross-refs" --> starter_pack_validator
    starter_pack_community_doc -- "validator checks doc cross-refs" --> starter_pack_validator
    starter_pack_validator -- "writes the checked-in validation capture" --> starter_pack_capture
    admission_doc -- "human entrypoint links to the starter pack lane" --> starter_pack_yaml

    %% Compatibility-report lane (matrix-derived, governs Help/About,
    %% docs, partner packets, and release evidence).
    subgraph m3_compat_report["M3 governed compatibility report"]
        compat_report_schema["compatibility_report_schema<br/>schemas/governance/compatibility_report.schema.json"]
        compat_report_matrix["m3_skew_window_matrix<br/>artifacts/compat/m3/skew_window_matrix.yaml"]
        compat_report_md["compatibility_report_md<br/>artifacts/compat/m3/compatibility_report.md"]
        compat_report_json["compatibility_report_json<br/>artifacts/compat/m3/compatibility_report.json"]
        compat_report_validator["compatibility_report_validator<br/>ci/check_m3_compatibility_report.py"]
        compat_report_capture["compatibility_report_validation_capture<br/>artifacts/compat/m3/captures/compatibility_report_validation_capture.json"]
    end

    %% Compatibility-report lane edges (derived from canonical seeds and
    %% the scorecard register; renders the matrix-derived report and capture).
    compat_report_matrix -- "names rows, scopes, cohorts, and surfaces" --> compat_report_validator
    surface_register -- "claimed beta surfaces ground client_scope" --> compat_report_validator
    cohort_guardrails -- "cohort_id vocabulary grounds primary_cohort_refs" --> compat_report_validator
    scorecard_register -- "scorecard derivations feed effective support class" --> compat_report_validator
    compat_report_validator -- "renders the JSON report" --> compat_report_json
    compat_report_validator -- "renders the markdown report" --> compat_report_md
    compat_report_validator -- "writes the validation capture" --> compat_report_capture
    compat_report_schema -- "constrains the JSON report" --> compat_report_validator
    admission_doc -- "human entrypoint links the matrix-derived report" --> compat_report_md

    %% Scorecard lane edges (scorecards consume the register / guardrails and
    %% feed the derived register that downstream packets cite).
    surface_register -- "claimed surfaces feed scorecard surface bindings" --> cohort_scorecard_index
    cohort_guardrails -- "cohort_id vocabulary feeds the cohort scorecard index" --> cohort_scorecard_index
    surface_register -- "claimed archetype rows feed the archetype scorecard index" --> archetype_scorecard_index
    cohort_scorecard_index -- "indexes the cohort scorecards" --> cohort_scorecards
    archetype_scorecard_index -- "indexes the archetype scorecards" --> archetype_scorecards
    cohort_scorecards -- "validator parses cohort scorecard front matter" --> scorecard_validator
    archetype_scorecards -- "validator parses archetype scorecard front matter" --> scorecard_validator
    cohort_scorecard_index -- "validator applies downgrade automation" --> scorecard_validator
    archetype_scorecard_index -- "validator applies downgrade automation" --> scorecard_validator
    scorecard_validator -- "writes the derived register downstream packets cite" --> scorecard_register
    scorecard_validator -- "writes the checked-in validation capture" --> scorecard_capture
    admission_doc -- "human entrypoint links to the scorecard lane" --> cohort_scorecard_index
    admission_doc -- "human entrypoint links to the scorecard lane" --> archetype_scorecard_index

    %% Cutline lane (consumes the beta scope; gates M4 stable planning)
    subgraph m3_cutline_lane["M3 cutline lane"]
        cutline_packet["cutline_packet<br/>docs/milestones/m3/cutline_packet.md"]
        unlock_map["unlock_map<br/>artifacts/milestones/m3/unlock_map.yaml"]
        stable_handoff["stable_planning_handoff_checklist<br/>artifacts/milestones/m3/stable_planning_handoff_checklist.md"]
        cutline_validator["m3_cutline_validator<br/>ci/check_m3_cutline_packet.py"]
        cutline_capture["cutline_packet_validation_capture<br/>artifacts/milestones/m3/captures/cutline_packet_validation_capture.json"]
    end

    %% M2 -> M3 inheritance edges
    m2_matrix -- "alpha wedge scope is the seed for the beta claimed surfaces" --> surface_register
    m2_scoreboard -- "downstream proof rows still resolve through the alpha scoreboard until beta-class scoreboard rows exist" --> surface_register
    m2_graph -- "beta admission inherits the alpha dependency model" --> surface_register
    m2_archetype_seed -- "TS/JS and Python archetype seeds carry into beta claimed archetype rows" --> surface_register
    reference_workspace_rows -- "Java/Kotlin, Rust, Go, and C/C++ archetype rows become first-time beta claims" --> surface_register
    archetype_rubric -- "support-class graduation rules are the canonical vocabulary" --> surface_register
    deployment_locality -- "deployment claims must resolve through the locality matrix" --> surface_register
    known_limits_contract -- "downgrade copy lands through the known-limits contract" --> surface_register
    public_interface_versioning -- "SDK and public interface downgrades route through the versioning policy" --> surface_register
    certified_archetype_template -- "certified-archetype publication template gates beta exit evidence" --> surface_register

    %% M2 cohort inheritance edges
    m2_matrix -- "external alpha / migration cohort persists into beta" --> cohort_guardrails
    archetype_rubric -- "support-class graduation drives cohort downgrade rules" --> cohort_guardrails
    deployment_locality -- "managed pilot cohort cites locality matrix profiles" --> cohort_guardrails
    known_limits_contract -- "cohort downgrade rules propagate through known-limits copy" --> cohort_guardrails
    certified_archetype_template -- "certified-archetype cohort cites the report template" --> cohort_guardrails

    %% Intra-M3 edges (one canonical truth, multiple lenses)
    surface_register -- "every claimed surface names one primary cohort" --> cohort_guardrails
    cohort_guardrails -- "cohort_id and downgrade vocabulary feed back into the surface register" --> surface_register
    surface_register -- "human entrypoint links the canonical truth set" --> admission_doc
    cohort_guardrails -- "human entrypoint links the canonical truth set" --> admission_doc

    %% Validator and capture edges
    surface_register -- "validator parses claimed surfaces" --> beta_admission_validator
    cohort_guardrails -- "validator parses cohort guardrails" --> beta_admission_validator
    admission_doc -- "validator checks entrypoint cross-refs" --> beta_admission_validator
    beta_admission_validator -- "writes the checked-in capture" --> validation_capture

    %% Cutline lane edges (beta scope feeds the cutline; cutline gates M4 unlocks)
    surface_register -- "claimed surfaces are the binding for cutline rows" --> unlock_map
    cohort_guardrails -- "cohort_id and downgrade vocabulary back the cutline" --> unlock_map
    admission_doc -- "beta entrypoint links to the cutline packet" --> cutline_packet
    cutline_packet -- "human entrypoint for the cutline lane" --> unlock_map
    cutline_packet -- "human entrypoint for the cutline lane" --> stable_handoff
    unlock_map -- "downstream M4 unlocks consume the handoff" --> stable_handoff
    unlock_map -- "cutline validator parses the unlock map" --> cutline_validator
    stable_handoff -- "cutline validator checks the handoff cross-refs" --> cutline_validator
    cutline_packet -- "cutline validator checks the doc cross-refs" --> cutline_validator
    cutline_validator -- "writes the checked-in cutline capture" --> cutline_capture

    %% Styling
    classDef m3 fill:#e7f3ff,stroke:#2a6fdb,stroke-width:1.5px;
    classDef m2 fill:#f1f1f1,stroke:#7a7a7a,stroke-width:1px;
    classDef consumer fill:#e8f7ec,stroke:#2f8a3f,stroke-width:1.5px;
    classDef cutline fill:#fff4e0,stroke:#b96b00,stroke-width:1.5px;
    classDef scorecard fill:#f3e8ff,stroke:#7a3cb8,stroke-width:1.5px;
    classDef compat fill:#e0fbf6,stroke:#2f8a86,stroke-width:1.5px;
    classDef starter fill:#fff0f6,stroke:#b8316c,stroke-width:1.5px;
    class admission_doc,surface_register,cohort_guardrails m3;
    class m2_matrix,m2_scoreboard,m2_graph,m2_archetype_seed,reference_workspace_rows,archetype_rubric,deployment_locality,known_limits_contract,public_interface_versioning,certified_archetype_template m2;
    class beta_admission_validator,validation_capture consumer;
    class cutline_packet,unlock_map,stable_handoff,cutline_validator,cutline_capture cutline;
    class cohort_scorecard_index,archetype_scorecard_index,cohort_scorecards,archetype_scorecards,scorecard_validator,scorecard_register,scorecard_capture scorecard;
    class compat_report_schema,compat_report_matrix,compat_report_md,compat_report_json,compat_report_validator,compat_report_capture compat;
    class starter_pack_yaml,starter_pack_extension_doc,starter_pack_partner_doc,starter_pack_community_doc,starter_pack_validator,starter_pack_capture,issue_routing_yaml starter;
