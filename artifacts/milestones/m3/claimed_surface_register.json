  "claimed_surfaces": [
    {
      "surface_id": "beta_surface:extension_runtime",
      "title": "Extension runtime, SDK, and publication path",
      "lifecycle_label": "beta",
      "claim_state": "beta_claim",
      "support_class": "supported",
      "primary_cohort_refs": [
        "cohort:extension_author"
      ],
      "secondary_cohort_refs": [
        "cohort:design_partner_managed_pilot"
      ],
      "rationale": "Extension runtime hardening, SDK stabilization, and publication mirror review are the hero proof for M3 beta.",
      "required_evidence_classes": [
        "sdk_diff_report",
        "sample_extension_pack",
        "extension_compatibility_report",
        "extension_rollback_drill"
      ],
      "downgrade_rules": [
        {
          "trigger": "sdk_breaking_change_without_migration",
          "downgrade_to": "retest_pending",
          "propagation_refs": [
            "docs/product/known_limits_contract.md",
            "docs/governance/public_interface_versioning_policy.md"
          ]
        },
        {
          "trigger": "publication_mirror_unavailable",
          "downgrade_to": "limited",
          "propagation_refs": [
            "docs/product/known_limits_contract.md"
          ]
        }
      ],
      "explicit_not_claimed": [
        "third_party_marketplace_listing_parity",
        "remote_extension_host_managed_parity"
      ]
    },
    {
