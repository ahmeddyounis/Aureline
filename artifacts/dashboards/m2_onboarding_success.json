{
  "schema_version": 1,
  "dashboard_id": "aureline.dashboard.onboarding_success_alpha",
  "title": "Onboarding success and first useful work",
  "owner_dri": "@ahmeddyounis",
  "source_schema_ref": "schemas/telemetry/onboarding_task_success.schema.json",
  "runtime_consumer_ref": "crates/aureline-telemetry/src/onboarding/mod.rs",
  "proof_fixture_ref": "fixtures/telemetry/onboarding_task_success/design_partner_expectations.json",
  "verification_command": "cargo test -p aureline-telemetry --test onboarding_task_success",
  "privacy_contract": {
    "default_posture": "off_by_default_no_emission_until_consent",
    "redaction_class": "metadata_safe_default",
    "allowed_capture_shape": "metadata_and_counts_only",
    "forbidden_content_classes": [
      "raw_project_content",
      "raw_repo_name",
      "file_path",
      "raw_url",
      "prompt_text",
      "terminal_text",
      "clipboard_content",
      "credential_or_secret"
    ]
  },
  "tiles": [
    {
      "tile_id": "onboarding.flow_completion_by_entry_flow",
      "title": "Flow completion by entry flow",
      "source_record_kind": "onboarding_task_success_event_record",
      "dimensions": [
        "entry.flow_kind",
        "entry.entry_verb",
        "entry.entry_route_id",
        "entry.measurement_surface",
        "completion_class",
        "outcome_class"
      ],
      "required_flow_kinds": [
        "first_run",
        "open",
        "clone",
        "import",
        "restore",
        "reconnect"
      ]
    },
    {
      "tile_id": "onboarding.first_useful_work_timing",
      "title": "First useful work timing",
      "source_record_kind": "onboarding_task_success_event_record",
      "metric": "first_useful_work.duration_ticks",
      "dimensions": [
        "entry.flow_kind",
        "entry.entry_route_id",
        "first_useful_work.target_surface",
        "first_useful_work.semantic_warmup_state"
      ],
      "guardrail": "Reject records with first_useful_work.raw_project_content_captured = true."
    },
    {
      "tile_id": "onboarding.migration_funnel",
      "title": "Migration funnel",
      "source_record_kind": "onboarding_task_success_event_record",
      "metric": "migration_funnel.outcome_counts.total_items",
      "dimensions": [
        "migration_funnel.source_kind",
        "migration_funnel.step",
        "migration_funnel.dry_run_state",
        "migration_funnel.rollback_state"
      ],
      "category_metrics": [
        "migration_funnel.outcome_counts.imported",
        "migration_funnel.outcome_counts.mapped",
        "migration_funnel.outcome_counts.skipped",
        "migration_funnel.outcome_counts.manual_review",
        "migration_funnel.outcome_counts.bridge_required",
        "migration_funnel.outcome_counts.unsupported"
      ]
    }
  ],
  "design_partner_proof": {
    "capture_record_kind": "onboarding_task_success_capture_record",
    "summary_fields": [
      "summary.observed_flow_kinds",
      "summary.distinct_entry_verbs",
      "summary.first_useful_work_timing_count",
      "summary.migration_funnel_event_count",
      "summary.design_partner_proof_ready"
    ],
    "ready_when": [
      "all required flow kinds are observed",
      "first-useful-work timing count is greater than zero",
      "migration funnel event count is greater than zero",
      "privacy envelope reports contains_raw_project_content = false"
    ]
  }
}
