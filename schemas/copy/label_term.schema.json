{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/copy/label_term.schema.json",
  "title": "Aureline naming, state label, client scope, and controlled glossary terms",
  "description": "Boundary schema for the controlled label glossary and worked review cases used by product UI, command palette, menus, CLI help, CLI summaries, documentation, exports, accessibility strings, telemetry dictionaries, and support packets. Records preserve label class, reserved meaning, allowed surfaces, alias review posture, and mechanical rejection rules so command names, state chips, reason chips, client-scope labels, and support terms cannot drift into ambiguous or decorative vocabulary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/controlled_glossary_record" },
    { "$ref": "#/$defs/label_review_case_record" }
  ],
  "$defs": {
    "label_term_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for the label-term family. Additive vocabulary growth bumps this const; repurposing a canonical term is breaking."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Stable id safe for support, docs, fixtures, and review artifacts. Raw source text, raw paths, raw URLs, secrets, and customer identifiers do not belong here."
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Redaction-aware human-facing label, phrase, or review note."
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "product_ui",
        "command_palette",
        "menu",
        "button",
        "panel",
        "settings",
        "cli_help",
        "cli_summary",
        "documentation",
        "export",
        "support_packet",
        "accessibility",
        "telemetry_dictionary",
        "automation_recipe",
        "browser_companion_handoff"
      ]
    },
    "label_class": {
      "type": "string",
      "enum": [
        "command_name",
        "setting_name",
        "panel_title",
        "view_title",
        "state_label",
        "reason_chip",
        "client_scope_label",
        "button_label",
        "glossary_term",
        "support_class_label"
      ]
    },
    "term_domain": {
      "type": "string",
      "enum": [
        "command_naming",
        "setting_naming",
        "panel_view_naming",
        "state",
        "reason",
        "client_scope",
        "trust",
        "policy",
        "recovery",
        "evidence",
        "support_class",
        "degraded_state"
      ]
    },
    "term_status": {
      "type": "string",
      "enum": [
        "canonical",
        "approved_alias",
        "deprecated_alias",
        "forbidden"
      ]
    },
    "review_decision": {
      "type": "string",
      "enum": [
        "accepted",
        "accepted_with_alias_review",
        "rejected"
      ]
    },
    "case_kind": {
      "type": "string",
      "enum": [
        "command_rename_review",
        "state_chip_surface_comparison",
        "client_scope_label_mapping",
        "rejected_whimsical_label"
      ]
    },
    "label_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "label_class",
        "rule_summary",
        "required_slots",
        "allowed_patterns",
        "rejection_tests"
      ],
      "properties": {
        "rule_id": { "$ref": "#/$defs/opaque_id" },
        "label_class": { "$ref": "#/$defs/label_class" },
        "rule_summary": { "$ref": "#/$defs/reviewable_label" },
        "required_slots": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_label" }
        },
        "allowed_patterns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_label" }
        },
        "rejection_tests": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_label" }
        }
      }
    },
    "controlled_term": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "term_id",
        "display_label",
        "label_class",
        "term_domain",
        "status",
        "definition",
        "reserved_meaning",
        "allowed_surface_classes",
        "required_context",
        "forbidden_uses",
        "owner_role"
      ],
      "properties": {
        "term_id": { "$ref": "#/$defs/opaque_id" },
        "display_label": { "$ref": "#/$defs/reviewable_label" },
        "label_class": { "$ref": "#/$defs/label_class" },
        "term_domain": { "$ref": "#/$defs/term_domain" },
        "status": { "$ref": "#/$defs/term_status" },
        "canonical_term_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "definition": { "$ref": "#/$defs/reviewable_label" },
        "reserved_meaning": { "$ref": "#/$defs/reviewable_label" },
        "allowed_surface_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_class" },
          "uniqueItems": true
        },
        "required_context": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_label" }
        },
        "forbidden_uses": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_label" }
        },
        "owner_role": { "$ref": "#/$defs/reviewable_label" },
        "surface_equivalence_key": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "alias_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alias_id",
        "canonical_term_id",
        "alias_label",
        "alias_status",
        "allowed_surface_classes",
        "rationale",
        "review_requirement"
      ],
      "properties": {
        "alias_id": { "$ref": "#/$defs/opaque_id" },
        "canonical_term_id": { "$ref": "#/$defs/opaque_id" },
        "alias_label": { "$ref": "#/$defs/reviewable_label" },
        "alias_status": { "$ref": "#/$defs/term_status" },
        "allowed_surface_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_class" },
          "uniqueItems": true
        },
        "rationale": { "$ref": "#/$defs/reviewable_label" },
        "review_requirement": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "governance_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_roles",
        "change_review_rules",
        "alias_review_rules",
        "localization_rules",
        "parity_rules"
      ],
      "properties": {
        "owner_roles": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_label" }
        },
        "change_review_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_label" }
        },
        "alias_review_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_label" }
        },
        "localization_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_label" }
        },
        "parity_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_label" }
        }
      }
    },
    "surface_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "label_class",
        "rendered_label",
        "meaning_statement"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "label_class": { "$ref": "#/$defs/label_class" },
        "rendered_label": { "$ref": "#/$defs/reviewable_label" },
        "term_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "meaning_statement": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "candidate_label": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "label",
        "label_class",
        "surface_class",
        "proposed_meaning"
      ],
      "properties": {
        "candidate_id": { "$ref": "#/$defs/opaque_id" },
        "label": { "$ref": "#/$defs/reviewable_label" },
        "label_class": { "$ref": "#/$defs/label_class" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "maps_to_term_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "proposed_meaning": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "expected_case_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "reasons",
        "required_follow_up"
      ],
      "properties": {
        "decision": { "$ref": "#/$defs/review_decision" },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_label" }
        },
        "required_follow_up": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_label" }
        }
      }
    },
    "controlled_glossary_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "label_term_schema_version",
        "glossary_id",
        "sources",
        "governance",
        "label_rules",
        "controlled_terms",
        "aliases",
        "denial_rules"
      ],
      "properties": {
        "record_kind": { "const": "controlled_glossary_record" },
        "label_term_schema_version": { "$ref": "#/$defs/label_term_schema_version" },
        "glossary_id": { "$ref": "#/$defs/opaque_id" },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "governance": { "$ref": "#/$defs/governance_policy" },
        "label_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/label_rule" }
        },
        "controlled_terms": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/controlled_term" }
        },
        "aliases": {
          "type": "array",
          "items": { "$ref": "#/$defs/alias_record" }
        },
        "denial_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_label" }
        }
      }
    },
    "label_review_case_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "label_term_schema_version",
        "case_id",
        "case_kind",
        "case_title",
        "scenario",
        "surfaces_under_review",
        "candidate_labels",
        "approved_labels",
        "forbidden_labels",
        "expected_decision",
        "conformance_expectations"
      ],
      "properties": {
        "record_kind": { "const": "label_review_case_record" },
        "label_term_schema_version": { "$ref": "#/$defs/label_term_schema_version" },
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "case_kind": { "$ref": "#/$defs/case_kind" },
        "case_title": { "$ref": "#/$defs/reviewable_label" },
        "scenario": { "$ref": "#/$defs/reviewable_label" },
        "surfaces_under_review": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_observation" }
        },
        "candidate_labels": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/candidate_label" }
        },
        "approved_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_label" }
        },
        "forbidden_labels": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_label" }
        },
        "expected_decision": { "$ref": "#/$defs/expected_case_result" },
        "conformance_expectations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_label" }
        }
      }
    }
  }
}
