{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/copy/late_copy_change.schema.json",
  "title": "Aureline translation-safe controlled late-copy change record",
  "description": "Boundary schema for the controlled_late_copy_change_record frozen in docs/copy/translation_safe_content_ops_contract.md. The record gates any after-freeze copy change that affects trust, legal, policy, recovery, support, evidence, screenshot/demo captions, source-language fallback, placeholder semantics, docs/help snippets, onboarding surfaces, export/report headings, CLI/help, public proof, or downstream support tooling. It complements schemas/docs/late_copy_change_packet.schema.json by adding translation, placeholder, caption, source-language fallback, and downstream-surface impact fields.",
  "type": "object",
  "$ref": "#/$defs/controlled_late_copy_change_record",
  "$defs": {
    "late_copy_change_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for the translation-safe late-copy gate family. Additive vocabulary growth bumps this const; repurposing an existing value is breaking."
    },
    "record_kind": {
      "type": "string",
      "const": "controlled_late_copy_change_record"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Stable opaque id safe for validation, support packets, and review artifacts."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_timestamp": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/timestamp" }
      ]
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "reviewable_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "bcp47_locale_tag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/non_empty_string" },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        }
      }
    },
    "packet_status": {
      "type": "string",
      "enum": [
        "proposed",
        "approved",
        "applied",
        "reversed",
        "superseded",
        "rejected"
      ]
    },
    "change_timing_class": {
      "type": "string",
      "enum": [
        "after_string_freeze_before_release",
        "post_release_hotfix",
        "out_of_band_service_notice"
      ]
    },
    "late_copy_reason_class": {
      "type": "string",
      "enum": [
        "legal_obligation_correction",
        "policy_requirement_correction",
        "trust_boundary_disclosure_correction",
        "recovery_instruction_correction",
        "support_path_correction",
        "evidence_source_alignment",
        "screenshot_demo_caption_alignment",
        "source_language_fallback_correction",
        "placeholder_semantics_correction",
        "export_report_heading_correction"
      ]
    },
    "review_role": {
      "type": "string",
      "enum": [
        "docs_public_truth_owner",
        "release_owner",
        "support_owner",
        "security_trust_owner",
        "legal_policy_owner",
        "recovery_owner",
        "localization_owner",
        "product_owner",
        "domain_owner"
      ]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "required",
        "approved",
        "acknowledged",
        "not_applicable"
      ]
    },
    "source_kind": {
      "type": "string",
      "enum": [
        "message_placeholder_record",
        "message_catalog_entry",
        "docs_pack",
        "claim_row",
        "compatibility_row",
        "policy_bundle",
        "late_copy_packet",
        "screenshot_caption_asset",
        "support_runbook",
        "export_heading_registry"
      ]
    },
    "delta_scope_class": {
      "type": "string",
      "enum": [
        "text_wording",
        "placeholder_semantics",
        "translator_note",
        "glossary_ref",
        "screenshot_caption",
        "source_language_fallback",
        "downstream_surface_alignment",
        "machine_identity_guard",
        "export_heading"
      ]
    },
    "semantic_change_class": {
      "type": "string",
      "enum": [
        "no_meaning_change",
        "narrows_claim",
        "corrects_false_or_stale_claim",
        "widens_claim_requires_source_update",
        "restores_source_language_access"
      ]
    },
    "downstream_surface_class": {
      "type": "string",
      "enum": [
        "product_ui",
        "docs_help",
        "onboarding",
        "screenshot_or_demo",
        "export_or_report",
        "support_tooling",
        "automation",
        "analytics",
        "locale_pack",
        "accessibility",
        "public_proof",
        "cli_help"
      ]
    },
    "surface_impact_class": {
      "type": "string",
      "enum": [
        "must_update_before_publish",
        "source_language_only_until_review",
        "no_runtime_change_validation_only",
        "blocked_until_retranslated",
        "screenshot_recapture_required",
        "support_export_relabel_required"
      ]
    },
    "verification_note_class": {
      "type": "string",
      "enum": [
        "claim_row_checked",
        "policy_owner_checked",
        "recovery_instruction_checked",
        "legal_signoff_checked",
        "translator_notes_checked",
        "placeholder_semantics_checked",
        "screenshot_caption_sync_checked",
        "source_language_fallback_checked",
        "support_export_preview_checked",
        "downstream_surface_inventory_checked",
        "string_freeze_exception_logged"
      ]
    },
    "translator_update_class": {
      "type": "string",
      "enum": [
        "no_translation_change",
        "translator_notes_only",
        "retranslation_required",
        "source_language_only_until_translation",
        "locale_pack_suppressed_until_review"
      ]
    },
    "reversal_class": {
      "type": "string",
      "enum": [
        "restore_prior_text",
        "supersede_with_reviewed_source",
        "withdraw_claim_and_route_to_known_limit",
        "rebind_surface_to_source_language",
        "no_reversal_needed"
      ]
    },
    "invariant_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "not_applicable"
      ]
    },
    "owner_assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_role",
        "owner_ref"
      ],
      "properties": {
        "owner_role": { "$ref": "#/$defs/review_role" },
        "owner_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "reviewer_assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "reviewer_ref",
        "status"
      ],
      "properties": {
        "role": { "$ref": "#/$defs/review_role" },
        "reviewer_ref": { "$ref": "#/$defs/non_empty_string" },
        "status": { "$ref": "#/$defs/review_status" },
        "reviewed_at": { "$ref": "#/$defs/nullable_timestamp" },
        "notes": { "$ref": "#/$defs/reviewable_text" }
      }
    },
    "text_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_kind",
        "source_ref",
        "text_locator"
      ],
      "properties": {
        "source_kind": { "$ref": "#/$defs/source_kind" },
        "source_ref": { "$ref": "#/$defs/opaque_id" },
        "source_revision_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "text_locator": { "$ref": "#/$defs/non_empty_string" },
        "text_digest_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "review_safe_preview": { "$ref": "#/$defs/reviewable_text" }
      }
    },
    "delta_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_class",
        "semantic_change_class",
        "prior_text_ref",
        "new_text_ref",
        "affected_placeholder_ids",
        "affected_translator_note_ids",
        "affected_glossary_term_refs"
      ],
      "properties": {
        "scope_class": { "$ref": "#/$defs/delta_scope_class" },
        "semantic_change_class": { "$ref": "#/$defs/semantic_change_class" },
        "prior_text_ref": { "$ref": "#/$defs/text_reference" },
        "new_text_ref": { "$ref": "#/$defs/text_reference" },
        "affected_placeholder_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true
        },
        "affected_translator_note_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "affected_glossary_term_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "meaning_delta_summary": { "$ref": "#/$defs/reviewable_text" }
      }
    },
    "downstream_surface_impact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "surface_ref",
        "impact_class",
        "requires_retranslation",
        "source_language_fallback_required",
        "support_export_impacted",
        "automation_or_analytics_identity_changed"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/downstream_surface_class" },
        "surface_ref": { "$ref": "#/$defs/opaque_id" },
        "impact_class": { "$ref": "#/$defs/surface_impact_class" },
        "requires_retranslation": { "type": "boolean" },
        "source_language_fallback_required": { "type": "boolean" },
        "support_export_impacted": { "type": "boolean" },
        "automation_or_analytics_identity_changed": { "const": false },
        "impact_summary": { "$ref": "#/$defs/reviewable_text" }
      }
    },
    "verification_note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "note_class",
        "summary",
        "verified_by",
        "recorded_at"
      ],
      "properties": {
        "note_class": { "$ref": "#/$defs/verification_note_class" },
        "summary": { "$ref": "#/$defs/reviewable_text" },
        "verified_by": { "$ref": "#/$defs/non_empty_string" },
        "recorded_at": { "$ref": "#/$defs/timestamp" },
        "evidence_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "source_language_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_language_locale",
        "fallback_chain",
        "fallback_active_until_retranslated",
        "escape_hatches",
        "disclosure_required"
      ],
      "properties": {
        "source_language_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "fallback_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bcp47_locale_tag" }
        },
        "fallback_active_until_retranslated": { "type": "boolean" },
        "escape_hatches": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "inline_source_language_toggle",
              "command_open_in_source_language",
              "docs_pane_source_language_route",
              "export_in_source_language_for_review",
              "support_packet_source_language_attachment"
            ]
          },
          "uniqueItems": true
        },
        "disclosure_required": { "type": "boolean" }
      }
    },
    "translator_update_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "update_class",
        "translator_note_refs",
        "affected_locale_pack_refs"
      ],
      "properties": {
        "update_class": { "$ref": "#/$defs/translator_update_class" },
        "translator_note_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "affected_locale_pack_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "translator_instruction_summary": { "$ref": "#/$defs/reviewable_text" }
      }
    },
    "rollback_or_reversal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reversal_class",
        "notes"
      ],
      "properties": {
        "reversal_class": { "$ref": "#/$defs/reversal_class" },
        "target_source_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "due_at": { "$ref": "#/$defs/nullable_timestamp" },
        "notes": { "$ref": "#/$defs/reviewable_text" }
      }
    },
    "invariant_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "localized_prose_never_controls_machine_identity",
        "placeholder_tokens_resolve_by_id_not_position",
        "literal_technical_tokens_preserve_spelling",
        "required_translator_notes_are_preserved",
        "glossary_terms_use_stable_refs",
        "screenshot_captions_bind_to_source_messages",
        "source_language_fallback_is_declared_and_disclosed",
        "late_copy_after_freeze_has_owner_verification_and_reversal",
        "downstream_surfaces_are_named_before_copy_changes_publish"
      ],
      "properties": {
        "localized_prose_never_controls_machine_identity": { "$ref": "#/$defs/invariant_status" },
        "placeholder_tokens_resolve_by_id_not_position": { "$ref": "#/$defs/invariant_status" },
        "literal_technical_tokens_preserve_spelling": { "$ref": "#/$defs/invariant_status" },
        "required_translator_notes_are_preserved": { "$ref": "#/$defs/invariant_status" },
        "glossary_terms_use_stable_refs": { "$ref": "#/$defs/invariant_status" },
        "screenshot_captions_bind_to_source_messages": { "$ref": "#/$defs/invariant_status" },
        "source_language_fallback_is_declared_and_disclosed": { "$ref": "#/$defs/invariant_status" },
        "late_copy_after_freeze_has_owner_verification_and_reversal": { "$ref": "#/$defs/invariant_status" },
        "downstream_surfaces_are_named_before_copy_changes_publish": { "$ref": "#/$defs/invariant_status" }
      }
    },
    "controlled_late_copy_change_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "late_copy_change_schema_version",
        "packet_id",
        "status",
        "opened_at",
        "applied_at",
        "change_timing_class",
        "string_freeze_baseline_ref",
        "owner",
        "reason_class",
        "summary",
        "required_reviewers",
        "affected_message_ids",
        "delta_scope",
        "downstream_surfaces",
        "verification_notes",
        "source_language_policy",
        "translator_update_policy",
        "linked_claim_row_refs",
        "linked_compatibility_row_refs",
        "linked_policy_refs",
        "linked_glossary_term_refs",
        "rollback_or_reversal",
        "invariant_checks"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "late_copy_change_schema_version": { "$ref": "#/$defs/late_copy_change_schema_version" },
        "packet_id": {
          "type": "string",
          "pattern": "^copy_late:[a-z0-9]+(?:[._:-][a-z0-9]+)*$"
        },
        "status": { "$ref": "#/$defs/packet_status" },
        "opened_at": { "$ref": "#/$defs/timestamp" },
        "applied_at": { "$ref": "#/$defs/nullable_timestamp" },
        "change_timing_class": { "$ref": "#/$defs/change_timing_class" },
        "string_freeze_baseline_ref": { "$ref": "#/$defs/opaque_id" },
        "owner": { "$ref": "#/$defs/owner_assignment" },
        "reason_class": { "$ref": "#/$defs/late_copy_reason_class" },
        "summary": { "$ref": "#/$defs/reviewable_text" },
        "required_reviewers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewer_assignment" }
        },
        "affected_message_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "delta_scope": { "$ref": "#/$defs/delta_scope" },
        "downstream_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downstream_surface_impact" }
        },
        "verification_notes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/verification_note" }
        },
        "source_language_policy": { "$ref": "#/$defs/source_language_policy" },
        "translator_update_policy": { "$ref": "#/$defs/translator_update_policy" },
        "linked_claim_row_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "linked_compatibility_row_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "linked_policy_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "linked_glossary_term_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "rollback_or_reversal": { "$ref": "#/$defs/rollback_or_reversal" },
        "invariant_checks": { "$ref": "#/$defs/invariant_checks" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "applied" } },
            "required": ["status"]
          },
          "then": {
            "required": ["applied_at"],
            "properties": {
              "applied_at": { "$ref": "#/$defs/timestamp" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "reason_class": {
                "enum": [
                  "legal_obligation_correction",
                  "policy_requirement_correction"
                ]
              }
            },
            "required": ["reason_class"]
          },
          "then": {
            "properties": {
              "required_reviewers": {
                "type": "array",
                "contains": {
                  "type": "object",
                  "properties": {
                    "role": { "const": "legal_policy_owner" }
                  },
                  "required": ["role"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "reason_class": { "const": "trust_boundary_disclosure_correction" }
            },
            "required": ["reason_class"]
          },
          "then": {
            "properties": {
              "required_reviewers": {
                "type": "array",
                "contains": {
                  "type": "object",
                  "properties": {
                    "role": { "const": "security_trust_owner" }
                  },
                  "required": ["role"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "reason_class": { "const": "recovery_instruction_correction" }
            },
            "required": ["reason_class"]
          },
          "then": {
            "properties": {
              "required_reviewers": {
                "type": "array",
                "allOf": [
                  {
                    "contains": {
                      "type": "object",
                      "properties": {
                        "role": { "const": "recovery_owner" }
                      },
                      "required": ["role"]
                    }
                  },
                  {
                    "contains": {
                      "type": "object",
                      "properties": {
                        "role": { "const": "support_owner" }
                      },
                      "required": ["role"]
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "delta_scope": {
                "type": "object",
                "properties": {
                  "semantic_change_class": { "const": "widens_claim_requires_source_update" }
                },
                "required": ["semantic_change_class"]
              }
            },
            "required": ["delta_scope"]
          },
          "then": {
            "properties": {
              "linked_claim_row_refs": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        },
        {
          "properties": {
            "required_reviewers": {
              "type": "array",
              "allOf": [
                {
                  "contains": {
                    "type": "object",
                    "properties": {
                      "role": { "const": "docs_public_truth_owner" }
                    },
                    "required": ["role"]
                  }
                },
                {
                  "contains": {
                    "type": "object",
                    "properties": {
                      "role": { "const": "release_owner" }
                    },
                    "required": ["role"]
                  }
                },
                {
                  "contains": {
                    "type": "object",
                    "properties": {
                      "role": { "const": "localization_owner" }
                    },
                    "required": ["role"]
                  }
                }
              ]
            },
            "verification_notes": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": {
                  "note_class": { "const": "string_freeze_exception_logged" }
                },
                "required": ["note_class"]
              }
            }
          }
        }
      ]
    }
  }
}
