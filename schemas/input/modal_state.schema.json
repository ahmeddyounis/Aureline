{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/input/modal_state.schema.json",
  "title": "Aureline modal editing state snapshot",
  "description": "Boundary schema for the focused modal editing state snapshot used by editor, help, migration, and support surfaces. The record exposes current mode, sequence guide state, register and clipboard route, operator-pending scope, narrowed surface fidelity, and keyboard recovery actions without carrying raw key history, clipboard contents, register contents, or edited text.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "state_id",
    "mode_strip",
    "register_route",
    "surface_fidelity",
    "recovery_actions",
    "diagnostics",
    "raw_key_history_present",
    "raw_clipboard_contents_present",
    "raw_register_contents_present",
    "redaction_class",
    "emitted_at"
  ],
  "properties": {
    "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
    "record_kind": { "const": "modal_state_snapshot_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "state_id": { "$ref": "#/$defs/opaque_id" },
    "mode_strip": { "$ref": "#/$defs/mode_strip_record" },
    "sequence_guide": { "$ref": "#/$defs/sequence_guide_record" },
    "register_route": { "$ref": "#/$defs/register_route_record" },
    "operator_pending": { "$ref": "#/$defs/operator_pending_record" },
    "surface_fidelity": { "$ref": "#/$defs/surface_fidelity_record" },
    "recovery_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/recovery_action_record" }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/reviewable_text" }
    },
    "raw_key_history_present": { "const": false },
    "raw_clipboard_contents_present": { "const": false },
    "raw_register_contents_present": { "const": false },
    "redaction_class": { "$ref": "#/$defs/non_empty_string" },
    "emitted_at": { "$ref": "#/$defs/non_empty_string" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/reviewable_text" }
      }
    },
    "modal_mode": {
      "type": "string",
      "enum": [
        "normal",
        "insert",
        "visual",
        "visual_line",
        "visual_block",
        "replace",
        "select",
        "command",
        "modeless",
        "unsupported"
      ]
    },
    "keymap_source_kind": {
      "type": "string",
      "enum": [
        "core_profile",
        "product_native_profile",
        "imported_bridge",
        "extension_profile",
        "workspace_override",
        "policy_narrowed"
      ]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "source_editor",
        "diff_editor",
        "commit_message",
        "notebook_code_cell",
        "terminal",
        "rendered_docs",
        "browser_companion",
        "large_file_editor",
        "restricted_mode_editor",
        "command_palette"
      ]
    },
    "recording_state": {
      "type": "string",
      "enum": ["not_recording", "recording", "paused"]
    },
    "sequence_state": {
      "type": "string",
      "enum": [
        "ready",
        "partial_waiting",
        "ambiguous_waiting",
        "conflict_requires_review",
        "blocked_by_host",
        "blocked_by_policy",
        "unsupported_surface",
        "timed_out",
        "cancelled",
        "resolved"
      ]
    },
    "next_key_availability": {
      "type": "string",
      "enum": [
        "available",
        "shadowed",
        "blocked_by_host",
        "blocked_by_policy",
        "unsupported_on_surface",
        "requires_review"
      ]
    },
    "register_scope_kind": {
      "type": "string",
      "enum": [
        "editor_local",
        "system_clipboard",
        "remote_clipboard_bridge",
        "named_register",
        "search_history",
        "macro",
        "special_register",
        "policy_blocked",
        "unknown"
      ]
    },
    "clipboard_route_kind": {
      "type": "string",
      "enum": [
        "local_editor_register",
        "local_system_clipboard",
        "remote_clipboard_bridge",
        "remote_bridge_suppressed",
        "admin_blocked",
        "unsupported_on_surface"
      ]
    },
    "register_policy_state": {
      "type": "string",
      "enum": [
        "allowed",
        "requires_review",
        "suppressed_by_remote_policy",
        "blocked_by_admin_policy",
        "unsupported_on_surface"
      ]
    },
    "surface_fidelity_class": {
      "type": "string",
      "enum": [
        "full_fidelity",
        "restricted_mode_narrowed",
        "browser_companion_limited",
        "large_file_limited",
        "remote_clipboard_limited",
        "unsupported_surface",
        "policy_blocked"
      ]
    },
    "operator_kind": {
      "type": "string",
      "enum": ["delete", "yank", "change", "format", "indent", "replace", "unknown"]
    },
    "operator_object_class": {
      "type": "string",
      "enum": ["motion", "text_object", "line_range", "selection", "search_result", "pending"]
    },
    "edit_target_scope": {
      "type": "string",
      "enum": ["current_buffer", "multiple_buffers", "workspace", "settings", "run_capable_command", "unknown"]
    },
    "recovery_action_class": {
      "type": "string",
      "enum": [
        "open_command_palette",
        "open_keymap_diagnostics",
        "open_migration_help",
        "switch_to_insert",
        "reset_keyboard_mode",
        "retry_on_supported_surface",
        "cancel_sequence",
        "review_register_route",
        "review_macro_replay"
      ]
    },
    "mode_strip_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_mode",
        "keymap_source_kind",
        "surface_kind",
        "surface_ref",
        "recording_state",
        "read_write_posture_label"
      ],
      "properties": {
        "current_mode": { "$ref": "#/$defs/modal_mode" },
        "keymap_source_kind": { "$ref": "#/$defs/keymap_source_kind" },
        "keymap_source_ref": { "type": "string" },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "surface_ref": { "$ref": "#/$defs/non_empty_string" },
        "recording_state": { "$ref": "#/$defs/recording_state" },
        "recording_register_name": { "type": "string" },
        "pending_count": { "type": "integer", "minimum": 1 },
        "pending_state_label": { "type": "string" },
        "read_write_posture_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "sequence_next_key_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_label", "group_label", "source_ref", "availability"],
      "properties": {
        "key_label": { "$ref": "#/$defs/non_empty_string" },
        "group_label": { "$ref": "#/$defs/non_empty_string" },
        "command_id": { "type": "string" },
        "command_title": { "type": "string" },
        "source_ref": { "$ref": "#/$defs/non_empty_string" },
        "availability": { "$ref": "#/$defs/next_key_availability" },
        "unavailable_reason_label": { "type": "string" }
      }
    },
    "sequence_guide_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["typed_prefix_display", "sequence_state", "next_keys"],
      "properties": {
        "typed_prefix_display": { "$ref": "#/$defs/non_empty_string" },
        "sequence_state": { "$ref": "#/$defs/sequence_state" },
        "timeout_ms": { "type": "integer", "minimum": 1 },
        "next_keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/sequence_next_key_record" }
        },
        "resolver_packet_ref": { "type": "string" },
        "conflict_review_ref": { "type": "string" },
        "diagnostic_label": { "type": "string" }
      }
    },
    "register_target_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_kind", "display_label"],
      "properties": {
        "scope_kind": { "$ref": "#/$defs/register_scope_kind" },
        "register_name": { "type": "string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "register_route_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_register",
        "clipboard_route",
        "policy_state",
        "is_default_route",
        "route_changes_result",
        "route_label",
        "diagnostics"
      ],
      "properties": {
        "active_register": { "$ref": "#/$defs/register_target_record" },
        "clipboard_route": { "$ref": "#/$defs/clipboard_route_kind" },
        "policy_state": { "$ref": "#/$defs/register_policy_state" },
        "is_default_route": { "type": "boolean" },
        "route_changes_result": { "type": "boolean" },
        "remote_boundary_ref": { "type": "string" },
        "policy_ref": { "type": "string" },
        "route_label": { "$ref": "#/$defs/non_empty_string" },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_text" }
        }
      }
    },
    "operator_pending_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator",
        "count",
        "object_class",
        "target_scope",
        "crosses_files",
        "replay_implication_label",
        "review_required"
      ],
      "properties": {
        "operator": { "$ref": "#/$defs/operator_kind" },
        "count": { "type": "integer", "minimum": 1 },
        "object_class": { "$ref": "#/$defs/operator_object_class" },
        "target_scope": { "$ref": "#/$defs/edit_target_scope" },
        "crosses_files": { "type": "boolean" },
        "replay_implication_label": { "$ref": "#/$defs/non_empty_string" },
        "review_required": { "type": "boolean" }
      }
    },
    "surface_fidelity_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fidelity_class", "narrowed_fidelity_labels", "support_matrix_refs"],
      "properties": {
        "fidelity_class": { "$ref": "#/$defs/surface_fidelity_class" },
        "narrowed_fidelity_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_text" }
        },
        "support_matrix_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "recovery_action_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_class", "label"],
      "properties": {
        "action_class": { "$ref": "#/$defs/recovery_action_class" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "target_ref": { "type": "string" }
      }
    }
  }
}
