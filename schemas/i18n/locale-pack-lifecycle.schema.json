{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/i18n/locale-pack-lifecycle.schema.json",
  "title": "Aureline stable locale-pack lifecycle and translated-surface parity packet",
  "description": "Canonical packet for stable localized claims. It binds locale-pack lifecycle windows, stable message ids, fallback-chain truth, translated docs/tour/auth/help/CLI parity, and release-gated proof rows into one inspectable contract. Raw translated bodies, raw docs bodies, raw URLs, signing keys, and credentials do not cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "source_contract_refs",
    "runtime_consumer_refs",
    "lifecycle_windows",
    "stable_message_id_rows",
    "fallback_truth_rows",
    "translated_surface_rows",
    "release_gate_rows",
    "summary"
  ],
  "properties": {
    "record_kind": { "const": "stable_locale_lifecycle_parity_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/stable_id" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_contract_refs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "runtime_consumer_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stable_id" },
      "uniqueItems": true
    },
    "lifecycle_windows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/lifecycle_window" }
    },
    "stable_message_id_rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stable_message_id_row" }
    },
    "fallback_truth_rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fallback_truth_row" }
    },
    "translated_surface_rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/translated_surface_row" }
    },
    "release_gate_rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/release_gate_row" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "stable_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:._@#/-]*$"
    },
    "locale": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "source_class": {
      "type": "string",
      "enum": [
        "first_party_source_language",
        "first_party_locale_pack",
        "reviewed_community_pack",
        "extension_owned_pack"
      ]
    },
    "distribution_class": {
      "type": "string",
      "enum": [
        "built_in_with_product",
        "mirrored_official_pack",
        "community_supplied_pack",
        "extension_overlay_pack",
        "air_gapped_offline_pack"
      ]
    },
    "signature_state": {
      "type": "string",
      "enum": [
        "signed_verified",
        "signed_unverified",
        "unsigned_explicit_acceptance",
        "signature_failed_blocked",
        "not_applicable_built_in"
      ]
    },
    "version_match_state": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "source_language_built_in_current",
        "first_party_signed_compatible",
        "mirror_signed_compatible",
        "reviewed_community_signed_compatible",
        "signature_failed_source_language_only",
        "version_skew_source_language_only",
        "missing_pack_source_language_only"
      ]
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "shell_chrome",
        "command_label",
        "settings_help_or_error",
        "docs_tour_or_auth_text",
        "extension_contributed_ui",
        "cli_help_text",
        "export_or_report_heading",
        "screenshot_or_demo_caption",
        "glossary_or_terminology_term",
        "policy_legal_or_recovery_text",
        "pseudoloc_only_test_string"
      ]
    },
    "claim_class": {
      "type": "string",
      "enum": ["stable_localized", "degraded_source_language_only", "not_claimed"]
    },
    "fallback_origin": {
      "type": "string",
      "enum": [
        "requested_locale_authoritative",
        "requested_locale_partial_with_base_fill",
        "base_locale_fallback",
        "source_language_fallback",
        "pack_signature_failed_source_language_only",
        "pack_missing_source_language_only",
        "policy_disabled_source_language_only"
      ]
    },
    "degraded_state": {
      "type": "string",
      "enum": [
        "fully_localized",
        "partial_translation_disclosed",
        "mixed_locale_strict_separation",
        "glossary_only_localized",
        "source_language_with_pseudoloc",
        "failed_pack_source_language_only"
      ]
    },
    "surface_kind": {
      "type": "string",
      "enum": ["docs", "guided_tour", "auth_recovery", "help_glossary_card", "cli_human_help"]
    },
    "machine_output_locale_class": {
      "type": "string",
      "enum": [
        "locale_neutral_canonical",
        "locale_neutral_with_translated_human_field",
        "locale_native_human_only",
        "forbidden_for_machine_output"
      ]
    },
    "parity_result": {
      "type": "string",
      "enum": ["passed", "source_language_fallback_passed", "blocked"]
    },
    "gate_state": {
      "type": "string",
      "enum": ["green", "narrowed", "blocked"]
    },
    "stable_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command_id_ref": { "$ref": "#/$defs/stable_id" },
        "semantic_action_id_ref": { "$ref": "#/$defs/stable_id" },
        "diagnostic_id_ref": { "$ref": "#/$defs/stable_id" },
        "docs_pack_key_ref": { "$ref": "#/$defs/stable_id" },
        "setting_id_ref": { "$ref": "#/$defs/stable_id" },
        "telemetry_key_ref": { "$ref": "#/$defs/stable_id" },
        "policy_name_ref": { "$ref": "#/$defs/stable_id" },
        "schema_id_ref": { "type": "string", "minLength": 1 }
      },
      "minProperties": 1
    },
    "lifecycle_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_id",
        "pack_ref",
        "source_class",
        "distribution_class",
        "requested_locale",
        "source_language_locale",
        "compatibility_min_build_ref",
        "compatibility_max_build_ref",
        "signature_state",
        "version_match_state",
        "lifecycle_state",
        "mirror_receipt_refs",
        "rollback_ref",
        "backs_claimed_localized_row"
      ],
      "properties": {
        "window_id": { "$ref": "#/$defs/stable_id" },
        "pack_ref": { "$ref": "#/$defs/stable_id" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "distribution_class": { "$ref": "#/$defs/distribution_class" },
        "requested_locale": { "$ref": "#/$defs/locale" },
        "source_language_locale": { "$ref": "#/$defs/locale" },
        "compatibility_min_build_ref": { "$ref": "#/$defs/stable_id" },
        "compatibility_max_build_ref": { "$ref": "#/$defs/stable_id" },
        "signature_state": { "$ref": "#/$defs/signature_state" },
        "version_match_state": { "$ref": "#/$defs/version_match_state" },
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
        "mirror_receipt_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" },
          "uniqueItems": true
        },
        "offline_bundle_ref": { "$ref": "#/$defs/stable_id" },
        "reviewed_community_decision_ref": { "$ref": "#/$defs/stable_id" },
        "rollback_ref": { "$ref": "#/$defs/stable_id" },
        "backs_claimed_localized_row": { "type": "boolean" }
      }
    },
    "stable_message_id_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "message_id",
        "surface_family",
        "stable_refs",
        "translation_pack_refs",
        "command_id_stable",
        "schema_or_diagnostic_id_stable",
        "semantic_action_id_stable",
        "machine_identifier_locale_neutral",
        "routed_by_localized_prose"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/stable_id" },
        "message_id": { "$ref": "#/$defs/stable_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "stable_refs": { "$ref": "#/$defs/stable_refs" },
        "translation_pack_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stable_id" },
          "uniqueItems": true
        },
        "command_id_stable": { "type": "boolean" },
        "schema_or_diagnostic_id_stable": { "type": "boolean" },
        "semantic_action_id_stable": { "type": "boolean" },
        "machine_identifier_locale_neutral": { "type": "boolean" },
        "routed_by_localized_prose": { "type": "boolean" }
      }
    },
    "fallback_truth_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "claim_class",
        "requested_locale",
        "effective_locale",
        "source_language_locale",
        "fallback_chain",
        "fallback_origin_class",
        "degraded_localization_state",
        "visible_in_settings",
        "visible_in_diagnostics",
        "visible_in_support_export",
        "open_in_source_language_route_ref",
        "non_blocking_core_use"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/stable_id" },
        "claim_class": { "$ref": "#/$defs/claim_class" },
        "requested_locale": { "$ref": "#/$defs/locale" },
        "effective_locale": { "$ref": "#/$defs/locale" },
        "source_language_locale": { "$ref": "#/$defs/locale" },
        "fallback_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/locale" }
        },
        "fallback_origin_class": { "$ref": "#/$defs/fallback_origin" },
        "degraded_localization_state": { "$ref": "#/$defs/degraded_state" },
        "visible_in_settings": { "type": "boolean" },
        "visible_in_diagnostics": { "type": "boolean" },
        "visible_in_support_export": { "type": "boolean" },
        "open_in_source_language_route_ref": { "$ref": "#/$defs/stable_id" },
        "non_blocking_core_use": { "type": "boolean" }
      }
    },
    "translated_surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "claim_class",
        "surface_kind",
        "message_id_refs",
        "command_id_refs",
        "citation_anchor_refs",
        "keyboard_path_refs",
        "screen_reader_label_refs",
        "recovery_route_refs",
        "source_language_route_ref",
        "cli_machine_keys_locale_neutral",
        "human_help_may_localize",
        "machine_output_locale_class",
        "fallback_state_refs",
        "accessibility_fixture_refs",
        "parity_result"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/stable_id" },
        "claim_class": { "$ref": "#/$defs/claim_class" },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "message_id_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "command_id_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "citation_anchor_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "keyboard_path_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "screen_reader_label_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "recovery_route_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "source_language_route_ref": { "$ref": "#/$defs/stable_id" },
        "cli_machine_keys_locale_neutral": { "type": "boolean" },
        "human_help_may_localize": { "type": "boolean" },
        "machine_output_locale_class": { "$ref": "#/$defs/machine_output_locale_class" },
        "fallback_state_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "accessibility_fixture_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "parity_result": { "$ref": "#/$defs/parity_result" }
      }
    },
    "release_gate_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "proof_kind",
        "command",
        "fixture_refs",
        "artifact_refs",
        "required_for_claimed_localized_rows",
        "gate_state"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/stable_id" },
        "proof_kind": { "$ref": "#/$defs/stable_id" },
        "command": { "type": "string", "minLength": 1 },
        "fixture_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "artifact_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "required_for_claimed_localized_rows": { "type": "boolean" },
        "gate_state": { "$ref": "#/$defs/gate_state" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claimed_localized_rows",
        "green_claimed_localized_rows",
        "degraded_source_language_rows",
        "blocked_rows",
        "promotion_state"
      ],
      "properties": {
        "claimed_localized_rows": { "type": "integer", "minimum": 0 },
        "green_claimed_localized_rows": { "type": "integer", "minimum": 0 },
        "degraded_source_language_rows": { "type": "integer", "minimum": 0 },
        "blocked_rows": { "type": "integer", "minimum": 0 },
        "promotion_state": { "$ref": "#/$defs/gate_state" }
      }
    }
  }
}
