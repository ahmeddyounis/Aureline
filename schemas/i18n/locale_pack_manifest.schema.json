{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/i18n/locale_pack_manifest.schema.json",
  "title": "Aureline beta locale-pack contract",
  "description": "Runtime and artifact-governance envelope for beta locale packs. This schema composes the UX message catalog, locale-pack manifest, and locale-fallback schemas into one product-facing contract that settings, Help/About, support exports, docs/help, and extension locale declarations can inspect. Raw translated bodies, raw docs bodies, raw URLs, signing keys, and credentials never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "contract_id",
    "contract_version_ref",
    "generated_at",
    "release_channel",
    "source_language_locale",
    "requested_locale",
    "active_locale_state",
    "source_contract_refs",
    "runtime_consumer_refs",
    "message_bindings",
    "locale_packs",
    "fallback_states",
    "extension_locale_declarations",
    "governance_actions",
    "compatibility_results",
    "compatibility_waivers",
    "machine_identifier_posture",
    "protected_proofs"
  ],
  "properties": {
    "record_kind": { "const": "locale_pack_beta_contract_record" },
    "schema_version": { "const": 1 },
    "contract_id": { "$ref": "#/$defs/stable_id" },
    "contract_version_ref": { "$ref": "#/$defs/stable_id" },
    "generated_at": { "type": "string", "format": "date-time" },
    "release_channel": { "const": "beta" },
    "source_language_locale": { "$ref": "#/$defs/locale" },
    "requested_locale": { "$ref": "#/$defs/locale" },
    "active_locale_state": { "$ref": "#/$defs/active_locale_state" },
    "source_contract_refs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "runtime_consumer_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stable_id" },
      "uniqueItems": true
    },
    "message_bindings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/message_binding" }
    },
    "locale_packs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/locale_pack" }
    },
    "fallback_states": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fallback_state" }
    },
    "extension_locale_declarations": {
      "type": "array",
      "items": { "$ref": "#/$defs/extension_locale_declaration" }
    },
    "governance_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/governance_action" }
    },
    "compatibility_results": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/compatibility_result" }
    },
    "compatibility_waivers": {
      "type": "array",
      "items": { "$ref": "#/$defs/compatibility_waiver" }
    },
    "machine_identifier_posture": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/machine_identifier_posture" }
    },
    "protected_proofs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/protected_proof" }
    }
  },
  "$defs": {
    "stable_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:._@#/-]*$"
    },
    "locale": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "shell_chrome",
        "command_label",
        "settings_help_or_error",
        "docs_tour_or_auth_text",
        "extension_contributed_ui",
        "cli_help_text",
        "export_or_report_heading",
        "screenshot_or_demo_caption",
        "glossary_or_terminology_term",
        "policy_legal_or_recovery_text",
        "pseudoloc_only_test_string"
      ]
    },
    "signature_state": {
      "type": "string",
      "enum": [
        "signed_verified",
        "signed_unverified",
        "unsigned_explicit_acceptance",
        "signature_failed_blocked",
        "not_applicable_built_in"
      ]
    },
    "version_match_state": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ]
    },
    "active_locale_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "state_id",
        "requested_locale",
        "effective_locale",
        "source_language_locale",
        "fallback_chain",
        "active_pack_refs",
        "active_fallback_state_refs",
        "source_language_fallback_active",
        "settings_projection_ref",
        "help_about_projection_ref",
        "support_export_ref",
        "signature_state_summary",
        "generated_at"
      ],
      "properties": {
        "record_kind": { "const": "active_locale_state_record" },
        "schema_version": { "const": 1 },
        "state_id": { "$ref": "#/$defs/stable_id" },
        "requested_locale": { "$ref": "#/$defs/locale" },
        "effective_locale": { "$ref": "#/$defs/locale" },
        "source_language_locale": { "$ref": "#/$defs/locale" },
        "fallback_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/locale" }
        },
        "active_pack_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "active_fallback_state_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "source_language_fallback_active": { "type": "boolean" },
        "settings_projection_ref": { "$ref": "#/$defs/stable_id" },
        "help_about_projection_ref": { "$ref": "#/$defs/stable_id" },
        "support_export_ref": { "$ref": "#/$defs/stable_id" },
        "signature_state_summary": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "format": "date-time" }
      }
    },
    "stable_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command_id_ref": { "$ref": "#/$defs/stable_id" },
        "semantic_action_id_ref": { "$ref": "#/$defs/stable_id" },
        "diagnostic_id_ref": { "$ref": "#/$defs/stable_id" },
        "docs_pack_key_ref": { "$ref": "#/$defs/stable_id" },
        "setting_id_ref": { "$ref": "#/$defs/stable_id" },
        "telemetry_key_ref": { "$ref": "#/$defs/stable_id" },
        "policy_name_ref": { "$ref": "#/$defs/stable_id" },
        "schema_id_ref": { "type": "string", "minLength": 1 }
      },
      "anyOf": [
        { "required": ["command_id_ref"] },
        { "required": ["semantic_action_id_ref"] },
        { "required": ["diagnostic_id_ref"] },
        { "required": ["docs_pack_key_ref"] },
        { "required": ["setting_id_ref"] },
        { "required": ["telemetry_key_ref"] },
        { "required": ["policy_name_ref"] },
        { "required": ["schema_id_ref"] }
      ]
    },
    "message_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "message_id",
        "message_id_class",
        "surface_family",
        "source_language_locale",
        "source_text",
        "stable_refs",
        "placeholders",
        "machine_output_locale_class",
        "source_language_escape_hatches",
        "localized_human_prose_allowed",
        "machine_identifier_fields_locale_neutral",
        "routed_by_localized_prose",
        "translation_review_refs",
        "minted_at"
      ],
      "properties": {
        "record_kind": { "const": "message_catalog_binding_record" },
        "schema_version": { "const": 1 },
        "message_id": { "$ref": "#/$defs/stable_id" },
        "message_id_class": {
          "type": "string",
          "enum": [
            "stable_canonical",
            "extension_overlay",
            "derived_with_upstream_id",
            "pseudoloc_test_only"
          ]
        },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "source_language_locale": { "$ref": "#/$defs/locale" },
        "source_text": { "type": "string", "minLength": 1 },
        "stable_refs": { "$ref": "#/$defs/stable_refs" },
        "placeholders": { "type": "array", "items": { "type": "object" } },
        "machine_output_locale_class": {
          "type": "string",
          "enum": [
            "locale_neutral_canonical",
            "locale_neutral_with_translated_human_field",
            "locale_native_human_only",
            "forbidden_for_machine_output"
          ]
        },
        "source_language_escape_hatches": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "localized_human_prose_allowed": { "type": "boolean" },
        "machine_identifier_fields_locale_neutral": { "const": true },
        "routed_by_localized_prose": { "const": false },
        "extension_namespace_ref": { "$ref": "#/$defs/stable_id" },
        "translation_review_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "minted_at": { "type": "string", "format": "date-time" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "surface_family": { "const": "command_label" } },
            "required": ["surface_family"]
          },
          "then": {
            "properties": {
              "stable_refs": {
                "required": ["command_id_ref", "semantic_action_id_ref"]
              }
            }
          }
        }
      ]
    },
    "locale_pack": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "record_kind",
        "schema_version",
        "pack_id",
        "pack_revision_ref",
        "locale",
        "coverage_locales",
        "source_language_locale",
        "base_locale_fallback_chain",
        "source_class",
        "distribution_class",
        "signature_state",
        "mirrorability_class",
        "compatibility_class",
        "compatibility_build_range",
        "covered_surface_families",
        "partially_translated_surface_families",
        "permitted_deployment_profiles",
        "source_artifact_ref",
        "mirror_receipt_refs",
        "rollback_ref",
        "policy_context",
        "redaction_class",
        "presentation_label",
        "minted_at"
      ],
      "properties": {
        "record_kind": { "const": "locale_pack_manifest_record" },
        "schema_version": { "const": 1 },
        "pack_id": { "$ref": "#/$defs/stable_id" },
        "pack_revision_ref": { "$ref": "#/$defs/stable_id" },
        "locale": { "$ref": "#/$defs/locale" },
        "coverage_locales": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/locale" }
        },
        "source_language_locale": { "$ref": "#/$defs/locale" },
        "base_locale_fallback_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/locale" }
        },
        "source_class": {
          "type": "string",
          "enum": [
            "first_party_source_language",
            "first_party_locale_pack",
            "reviewed_community_pack",
            "extension_owned_pack"
          ]
        },
        "distribution_class": {
          "type": "string",
          "enum": [
            "built_in_with_product",
            "mirrored_official_pack",
            "community_supplied_pack",
            "extension_overlay_pack",
            "air_gapped_offline_pack"
          ]
        },
        "signature_state": { "$ref": "#/$defs/signature_state" },
        "mirrorability_class": {
          "type": "string",
          "enum": [
            "mirror_allowed",
            "mirror_with_attribution_required",
            "mirror_forbidden",
            "air_gapped_only",
            "not_mirrorable_signed_blob"
          ]
        },
        "compatibility_class": { "$ref": "#/$defs/version_match_state" },
        "covered_surface_families": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_family" }
        },
        "partially_translated_surface_families": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_family" }
        }
      }
    },
    "fallback_state": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "record_kind",
        "schema_version",
        "state_id",
        "requested_locale",
        "effective_locale",
        "source_language_locale",
        "fallback_origin_class",
        "degraded_localization_state",
        "fallback_chain_walked",
        "packs_consulted",
        "disclosed_to_reviewer",
        "source_language_escape_hatches_active",
        "surface_family",
        "command_id_preservation_state",
        "machine_output_locale_class",
        "deployment_profile_refs",
        "policy_context",
        "redaction_class",
        "target_build_identity_ref",
        "presentation_label",
        "minted_at"
      ],
      "properties": {
        "record_kind": { "const": "locale_fallback_state_record" },
        "schema_version": { "const": 1 },
        "state_id": { "$ref": "#/$defs/stable_id" },
        "requested_locale": { "$ref": "#/$defs/locale" },
        "effective_locale": { "$ref": "#/$defs/locale" },
        "fallback_origin_class": {
          "type": "string",
          "enum": [
            "requested_locale_authoritative",
            "requested_locale_partial_with_base_fill",
            "base_locale_fallback",
            "source_language_fallback",
            "pack_signature_failed_source_language_only",
            "pack_missing_source_language_only",
            "policy_disabled_source_language_only"
          ]
        },
        "surface_family": { "$ref": "#/$defs/surface_family" }
      }
    },
    "extension_locale_declaration": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "extension_id",
        "extension_namespace_ref",
        "support_mode",
        "inherits_host_fallback_disclosure",
        "source_language_locale",
        "fallback_locale",
        "may_override_host_stable_ids",
        "compatibility_result_ref",
        "visible_disclosure_required"
      ],
      "properties": {
        "support_mode": {
          "type": "string",
          "enum": [
            "inherits_host_locale",
            "ships_own_locale_pack",
            "ships_companion_locale_pack",
            "source_language_only"
          ]
        },
        "may_override_host_stable_ids": { "const": false },
        "visible_disclosure_required": { "const": true }
      }
    },
    "governance_action": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action_id",
        "operation_class",
        "pack_ref",
        "review_required",
        "signature_verification_required",
        "compatibility_check_required",
        "mirror_metadata_preserved",
        "support_export_ref"
      ],
      "properties": {
        "operation_class": {
          "type": "string",
          "enum": ["install", "update", "rollback", "mirror_import", "offline_import"]
        },
        "review_required": { "const": true },
        "signature_verification_required": { "const": true },
        "compatibility_check_required": { "const": true }
      }
    },
    "compatibility_result": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "result_id",
        "pack_ref",
        "target_build_identity_ref",
        "outcome",
        "signature_state",
        "compatibility_class",
        "surface_families_checked",
        "fallback_state_refs"
      ],
      "properties": {
        "outcome": {
          "type": "string",
          "enum": [
            "compatible",
            "compatible_with_waiver",
            "blocked_signature_failure",
            "blocked_version_drift",
            "source_language_only_fallback"
          ]
        },
        "signature_state": { "$ref": "#/$defs/signature_state" },
        "compatibility_class": { "$ref": "#/$defs/version_match_state" }
      }
    },
    "compatibility_waiver": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "waiver_ref",
        "pack_ref",
        "bounded_to_surface_families",
        "reason",
        "expires_at",
        "fallback_required",
        "release_packet_ref"
      ],
      "properties": {
        "fallback_required": { "const": true }
      }
    },
    "machine_identifier_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_family",
        "stable_identifier_refs",
        "locale_neutral",
        "human_prose_overlay_allowed"
      ],
      "properties": {
        "field_family": { "type": "string", "minLength": 1 },
        "stable_identifier_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "locale_neutral": { "const": true },
        "human_prose_overlay_allowed": { "type": "boolean" }
      }
    },
    "protected_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_id", "fixture_ref", "exercised_axes"],
      "properties": {
        "proof_id": { "$ref": "#/$defs/stable_id" },
        "fixture_ref": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stable_id" }
        }
      }
    }
  }
}
