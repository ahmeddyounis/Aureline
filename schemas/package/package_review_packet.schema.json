{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/package/package_review_packet.schema.json",
  "title": "Aureline package-review packet boundary",
  "description": "Boundary schema for one package_review_packet_record frozen in docs/package/package_action_contract.md. The review packet is the gating object the desktop review surface, CLI dependency-review summary, AI tool review, hosted-review reader, support / export reader, and admin-audit reader read before any mutation-class package action proceeds (and after any apply for evidence). One pre-apply packet projects the typed lockfile-impact / transitive-impact / script-risk / registry-auth / rollback / mirror-or-offline truth that gates apply; one post-apply packet attributes the apply outcome; one rollback-preview packet materialises a restore-from-checkpoint plan; one audit-only packet projects read-only search / audit truth. Raw manifest bodies, raw lockfile bodies, raw post-install script bodies, raw native-toolchain command lines, raw registry URLs, raw OAuth tokens, raw .npmrc / .pypirc / .cargo / credentials token bytes, raw mTLS material, raw vendored-directory absolute paths, and raw author identity strings never cross this boundary; the packet carries opaque refs, integer-bucket counts, typed vocabulary, and reviewable sentences only. The package_action.schema.json companion schema vocabularies (package_action_class, manifest_scope_class, registry_source_class, registry_auth_mode_class, script_risk_class, lockfile_impact_class, transitive_impact_class, rollback_posture_class, mirror_or_offline_state_class, expected_validation_task_class, apply_outcome_class) are re-declared here by enum so this schema validates standalone. Adding a package_review_packet_class, package_review_outcome_class, or vocabulary value above is additive-minor and bumps package_review_packet_schema_version; repurposing an existing value is breaking and requires a new decision row co-signed by security_trust_review and product_scope_review.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "package_review_packet_id",
    "bound_package_action_id_ref",
    "package_review_packet_class",
    "package_review_outcome_class",
    "package_action_class",
    "decision_actor_ref",
    "decision_command_id_ref",
    "manifest_scope_class",
    "registry_source_class",
    "registry_auth_mode_class",
    "script_risk_class",
    "lockfile_impact_class",
    "lockfile_impact_envelope",
    "transitive_impact_class",
    "transitive_impact_envelope",
    "rollback_posture_class",
    "mirror_or_offline_state_class",
    "expected_validation_tasks",
    "workspace_trust_state",
    "redaction_class",
    "published_at",
    "narrative_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version. Additive-minor vocabulary additions bump this integer."
    },
    "record_kind": {
      "type": "string",
      "const": "package_review_packet_record"
    },
    "package_review_packet_id": { "$ref": "#/$defs/opaque_id" },
    "bound_package_action_id_ref": { "$ref": "#/$defs/opaque_id" },
    "package_review_packet_class": { "$ref": "#/$defs/package_review_packet_class" },
    "package_review_outcome_class": { "$ref": "#/$defs/package_review_outcome_class" },
    "decision_note": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/reviewable_sentence" }
      ]
    },
    "decision_actor_ref": { "$ref": "#/$defs/opaque_id" },
    "decision_command_id_ref": { "$ref": "#/$defs/opaque_id" },

    "package_action_class": { "$ref": "#/$defs/package_action_class" },

    "manifest_scope_class": { "$ref": "#/$defs/manifest_scope_class" },
    "manifest_locator_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },

    "registry_source_class": { "$ref": "#/$defs/registry_source_class" },
    "registry_endpoint_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "registry_auth_mode_class": { "$ref": "#/$defs/registry_auth_mode_class" },
    "registry_disclosure": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/reviewable_sentence" }
      ]
    },

    "script_risk_class": { "$ref": "#/$defs/script_risk_class" },
    "script_risk_disclosure": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/reviewable_sentence" }
      ]
    },
    "script_risk_consent_ticket_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },

    "lockfile_impact_class": { "$ref": "#/$defs/lockfile_impact_class" },
    "lockfile_impact_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "added_entry_count_bucket",
        "updated_entry_count_bucket",
        "removed_entry_count_bucket"
      ],
      "properties": {
        "prior_lockfile_snapshot_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "proposed_lockfile_snapshot_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "added_entry_count_bucket": { "type": "integer", "minimum": 0 },
        "updated_entry_count_bucket": { "type": "integer", "minimum": 0 },
        "removed_entry_count_bucket": { "type": "integer", "minimum": 0 },
        "lockfile_impact_disclosure": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      }
    },

    "transitive_impact_class": { "$ref": "#/$defs/transitive_impact_class" },
    "transitive_impact_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transitive_added_count_bucket",
        "transitive_removed_count_bucket",
        "transitive_major_boundary_count_bucket",
        "transitive_conflict_count_bucket"
      ],
      "properties": {
        "transitive_added_count_bucket": { "type": "integer", "minimum": 0 },
        "transitive_removed_count_bucket": { "type": "integer", "minimum": 0 },
        "transitive_major_boundary_count_bucket": { "type": "integer", "minimum": 0 },
        "transitive_conflict_count_bucket": { "type": "integer", "minimum": 0 },
        "transitive_impact_disclosure": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      }
    },

    "rollback_posture_class": { "$ref": "#/$defs/rollback_posture_class" },
    "rollback_checkpoint_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "rollback_posture_disclosure": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/reviewable_sentence" }
      ]
    },

    "mirror_or_offline_state_class": { "$ref": "#/$defs/mirror_or_offline_state_class" },
    "mirror_or_offline_state_disclosure": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/reviewable_sentence" }
      ]
    },

    "expected_validation_tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/expected_validation_task_class" },
      "uniqueItems": true
    },

    "workspace_trust_state": { "$ref": "#/$defs/workspace_trust_state_class" },
    "policy_epoch_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "linked_approval_ticket_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "linked_browser_handoff_packet_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "linked_authority_ticket_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "linked_post_apply_evidence_packet_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "linked_pre_apply_review_packet_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "apply_outcome_class": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/apply_outcome_class" }
      ]
    },

    "redaction_class": { "$ref": "#/$defs/redaction_class" },
    "export_safe": { "type": "boolean", "default": true },
    "published_at": { "$ref": "#/$defs/monotonic_timestamp" },
    "narrative_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "notes": { "type": "string" },
    "__fixture__": { "type": "object" }
  },
  "allOf": [
    {
      "description": "pre_apply_review_packet for a mutation-class action MUST NOT carry review_admitted_apply_proceeded; that outcome is admissible only on post_apply / audit_only packet classes.",
      "if": {
        "properties": {
          "package_review_packet_class": { "const": "pre_apply_review_packet" }
        },
        "required": [ "package_review_packet_class" ]
      },
      "then": {
        "properties": {
          "package_review_outcome_class": {
            "not": { "const": "review_admitted_apply_proceeded" }
          }
        }
      }
    },
    {
      "description": "post_apply_evidence_packet MUST cite a non-null apply_outcome_class mirrored from the bound action.",
      "if": {
        "properties": {
          "package_review_packet_class": { "const": "post_apply_evidence_packet" }
        },
        "required": [ "package_review_packet_class" ]
      },
      "then": {
        "required": [ "apply_outcome_class" ],
        "properties": {
          "apply_outcome_class": { "not": { "type": "null" } }
        }
      }
    },
    {
      "description": "rollback_preview_packet MUST resolve to package_action_class = restore_lockfile_to_checkpoint, a rollback_posture_class in the rollback-via-checkpoint set, and a non-null rollback_checkpoint_ref.",
      "if": {
        "properties": {
          "package_review_packet_class": { "const": "rollback_preview_packet" }
        },
        "required": [ "package_review_packet_class" ]
      },
      "then": {
        "required": [ "rollback_checkpoint_ref" ],
        "properties": {
          "package_action_class": { "const": "restore_lockfile_to_checkpoint" },
          "rollback_posture_class": {
            "enum": [
              "rollback_via_lockfile_checkpoint",
              "rollback_via_workspace_snapshot_checkpoint"
            ]
          },
          "rollback_checkpoint_ref": { "not": { "type": "null" } }
        }
      }
    },
    {
      "description": "audit_only_review_packet MUST mirror a read-only action class and resolve to read-only lockfile / transitive / rollback values.",
      "if": {
        "properties": {
          "package_review_packet_class": { "const": "audit_only_review_packet" }
        },
        "required": [ "package_review_packet_class" ]
      },
      "then": {
        "properties": {
          "package_action_class": {
            "enum": [
              "search_for_package_metadata",
              "audit_only_no_state_change"
            ]
          },
          "lockfile_impact_class": { "const": "no_lockfile_change_metadata_only" },
          "transitive_impact_class": { "const": "no_transitive_change" },
          "rollback_posture_class": { "const": "rollback_posture_not_applicable_read_only" }
        }
      }
    },
    {
      "description": "Mutation-class actions MUST NOT resolve to read-only lockfile / transitive / rollback values; the review packet preserves the per-record invariant from package_action.schema.json.",
      "if": {
        "properties": {
          "package_action_class": {
            "enum": [
              "install_new_dependency",
              "upgrade_existing_dependency",
              "downgrade_existing_dependency",
              "remove_existing_dependency",
              "pin_existing_dependency",
              "restore_lockfile_to_checkpoint"
            ]
          }
        },
        "required": [ "package_action_class" ]
      },
      "then": {
        "properties": {
          "rollback_posture_class": {
            "not": { "const": "rollback_posture_not_applicable_read_only" }
          }
        }
      }
    },
    {
      "description": "Lockfile-impact metadata-only paired with a script_risk_class outside the metadata-safe set is forbidden.",
      "if": {
        "properties": {
          "lockfile_impact_class": { "const": "no_lockfile_change_metadata_only" }
        },
        "required": [ "lockfile_impact_class" ]
      },
      "then": {
        "properties": {
          "script_risk_class": {
            "enum": [
              "no_script_no_native_build",
              "declarative_metadata_only"
            ]
          }
        }
      }
    },
    {
      "description": "rollback_unavailable_destructive_remove_with_no_checkpoint is admissible only when package_action_class is remove_existing_dependency.",
      "if": {
        "properties": {
          "rollback_posture_class": { "const": "rollback_unavailable_destructive_remove_with_no_checkpoint" }
        },
        "required": [ "rollback_posture_class" ]
      },
      "then": {
        "properties": {
          "package_action_class": { "const": "remove_existing_dependency" }
        }
      }
    }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$",
      "description": "Opaque, stable, snake_case-safe id. Raw URLs, raw host names, raw IPs, raw absolute paths, raw author identity strings, raw tokens, and raw secret bytes never appear here."
    },

    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Short, reviewable sentence safe for banners, admin exports, support packets, and diagnostics cards. Raw URLs, raw payloads, raw lockfile bodies, raw manifest bodies, raw script bodies, and raw secret material MUST NOT appear."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "workspace_trust_state_class": {
      "type": "string",
      "enum": [
        "workspace_trust_unset",
        "workspace_trust_restricted",
        "workspace_trust_session_only_temporary",
        "workspace_trust_trusted",
        "workspace_trust_revoked"
      ]
    },

    "package_action_class": {
      "type": "string",
      "enum": [
        "search_for_package_metadata",
        "install_new_dependency",
        "upgrade_existing_dependency",
        "downgrade_existing_dependency",
        "remove_existing_dependency",
        "pin_existing_dependency",
        "audit_only_no_state_change",
        "restore_lockfile_to_checkpoint"
      ]
    },

    "manifest_scope_class": {
      "type": "string",
      "enum": [
        "workspace_root_manifest",
        "workspace_member_manifest",
        "monorepo_root_manifest",
        "application_only_dev_dependency_manifest",
        "vendored_or_offline_manifest",
        "out_of_tree_global_manifest_admin_only",
        "manifest_scope_unknown_requires_review"
      ]
    },

    "registry_source_class": {
      "type": "string",
      "enum": [
        "public_default_registry",
        "public_alternate_registry",
        "vendor_published_mirror",
        "customer_operated_mirror",
        "private_internal_registry",
        "managed_org_curated_registry",
        "offline_bundle_registry",
        "vendored_directory_no_registry",
        "git_or_path_dependency_no_registry",
        "registry_source_unknown_requires_review"
      ]
    },

    "registry_auth_mode_class": {
      "type": "string",
      "enum": [
        "no_auth_public_registry",
        "secret_broker_handle_auth",
        "delegated_identity_auth",
        "policy_injected_credential_auth",
        "mirror_or_offline_no_auth_required",
        "managed_service_identity_auth",
        "mtls_client_certificate_auth",
        "device_flow_callback_auth",
        "registry_auth_unknown_requires_review",
        "registry_auth_unsupported_blocked"
      ]
    },

    "script_risk_class": {
      "type": "string",
      "enum": [
        "no_script_no_native_build",
        "declarative_metadata_only",
        "post_install_script_runs_in_sandbox",
        "post_install_script_runs_unsandboxed_user_consent_required",
        "native_compilation_required_local_toolchain",
        "prebuilt_binary_with_runtime_loader",
        "platform_specific_binary_unverified_origin",
        "script_risk_unknown_requires_review"
      ]
    },

    "lockfile_impact_class": {
      "type": "string",
      "enum": [
        "no_lockfile_change_metadata_only",
        "new_lockfile_entries_added",
        "existing_lockfile_entries_updated",
        "lockfile_entries_removed",
        "lockfile_resolver_strategy_changed",
        "lockfile_format_migration",
        "lockfile_locked_unchanged_pinned_query_only",
        "lockfile_absent_will_be_created",
        "lockfile_impact_unknown_requires_review"
      ]
    },

    "transitive_impact_class": {
      "type": "string",
      "enum": [
        "no_transitive_change",
        "transitive_added_within_minor_floor",
        "transitive_added_across_major_boundary",
        "transitive_removed",
        "transitive_pinned_pattern_changed",
        "transitive_resolver_conflict_user_review_required",
        "transitive_circular_dependency_detected",
        "transitive_impact_unknown_requires_review"
      ]
    },

    "rollback_posture_class": {
      "type": "string",
      "enum": [
        "rollback_via_lockfile_checkpoint",
        "rollback_via_workspace_snapshot_checkpoint",
        "rollback_requires_re_resolve_no_inline_checkpoint",
        "rollback_blocked_native_artifacts_must_be_recompiled",
        "rollback_blocked_post_install_script_was_unsandboxed",
        "rollback_unavailable_destructive_remove_with_no_checkpoint",
        "rollback_posture_not_applicable_read_only"
      ]
    },

    "mirror_or_offline_state_class": {
      "type": "string",
      "enum": [
        "online_default_origin_admissible",
        "online_mirror_pinned_no_direct_origin",
        "offline_grace_window_using_warm_cache",
        "offline_air_gapped_using_offline_bundle_only",
        "network_disabled_user_setting_or_policy",
        "mirror_or_offline_state_unknown_requires_review"
      ]
    },

    "expected_validation_task_class": {
      "type": "string",
      "enum": [
        "typecheck",
        "lint",
        "build",
        "unit_test",
        "integration_test",
        "license_audit",
        "security_audit",
        "dependency_audit",
        "format_check"
      ]
    },

    "apply_outcome_class": {
      "type": "string",
      "enum": [
        "apply_completed_clean",
        "apply_completed_with_warnings",
        "apply_partial_failure_user_review_required",
        "apply_failed_no_state_changed",
        "apply_failed_state_changed_rollback_executed",
        "apply_failed_state_changed_rollback_unavailable",
        "apply_blocked_by_policy",
        "apply_blocked_by_workspace_trust",
        "apply_in_flight",
        "apply_not_applicable_read_only"
      ]
    },

    "package_review_packet_class": {
      "type": "string",
      "enum": [
        "pre_apply_review_packet",
        "post_apply_evidence_packet",
        "rollback_preview_packet",
        "audit_only_review_packet",
        "packet_class_unknown_requires_review"
      ]
    },

    "package_review_outcome_class": {
      "type": "string",
      "enum": [
        "review_admitted_apply_proceeded",
        "review_admitted_apply_pending",
        "review_blocked_pending_user_decision",
        "review_blocked_pending_lockfile_resolution",
        "review_blocked_pending_native_build_consent",
        "review_blocked_pending_admin_policy",
        "review_blocked_pending_workspace_trust_elevation",
        "review_dismissed_no_apply"
      ]
    }
  }
}
