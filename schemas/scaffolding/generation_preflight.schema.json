{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/scaffolding/generation_preflight.schema.json",
  "title": "Aureline scaffold generation-preflight contract",
  "description": "Boundary schema for the generation-preflight record frozen in docs/scaffolding/template_health_and_preflight_contract.md. Every preflight sheet a user sees before pressing Generate publishes exactly one generation_preflight_record bound by ref to the template_card_record (schemas/scaffolding/template_card.schema.json) and to the template_manifest_record (schemas/scaffolding/template_manifest.schema.json) the card resolves against. The preflight enumerates parameter use, environment use, file-write impact, dependency impact, the ordered execution-step list, the immediate-vs-deferred partition, the rollback / vcs / lockfile checkpoints that will be planted, and the delete-generated-output recovery route — never collapsed into an opaque 'Create' action. Every preflight cites a non-empty create_without_starter_route_ids list so the open-without-starter route is preserved at every health state. Raw bearer tokens, raw API keys, raw passwords, raw signing keys, raw certificate / key material, raw absolute filesystem paths, raw repository URLs, raw author email addresses, raw container registry URLs, raw devcontainer image tags, raw lockfile bodies, raw extension marketplace urls, raw stdout / stderr, raw post-install script bodies, and raw user-supplied parameter values never cross this boundary; the schema carries opaque ids, closed vocabulary, content-addresses, integer-bucket counts, and short reviewable sentences only. Adding a new preflight_axis_class, file_write_disposition_class, dependency_impact_class, lockfile_mutation_class, execution_phase_class, immediate_or_deferred_action_class, checkpoint_kind_class, environment_use_kind_class, or denial_reason_class value is additive-minor and bumps generation_preflight_schema_version; repurposing an existing value is breaking and requires a new decision row in artifacts/governance/decision_index.yaml.",
  "type": "object",
  "$ref": "#/$defs/generation_preflight_record",
  "$defs": {
    "generation_preflight_schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "supported_ecosystem_class": {
      "type": "string",
      "enum": [
        "rust_cargo",
        "node_npm",
        "node_pnpm",
        "node_yarn",
        "node_bun",
        "python_pip",
        "python_poetry",
        "python_uv",
        "go_modules",
        "java_maven",
        "java_gradle",
        "dotnet_nuget",
        "ruby_bundler",
        "swift_package_manager",
        "multi_ecosystem_polyglot",
        "no_ecosystem_pure_files",
        "ecosystem_class_unknown_requires_review"
      ],
      "description": "Re-exported from schemas/scaffolding/template_manifest.schema.json without modification."
    },
    "required_parameter_kind_class": {
      "type": "string",
      "enum": [
        "typed_string_label",
        "typed_enum_choice_from_closed_set",
        "typed_boolean_choice",
        "typed_integer_value_with_bounds",
        "typed_directory_label_no_raw_path",
        "typed_identity_label_no_raw_email",
        "typed_secret_broker_handle_only",
        "typed_organization_provenance_handle_only",
        "parameter_kind_unknown_requires_review"
      ],
      "description": "Re-exported from schemas/scaffolding/template_manifest.schema.json without modification."
    },
    "generated_file_class": {
      "type": "string",
      "enum": [
        "source_file_text_human_authored",
        "configuration_json_human_edited",
        "configuration_jsonc_with_comments_preserved",
        "configuration_yaml_human_edited",
        "lockfile_or_manifest_paired_text_round_trip",
        "license_or_legal_text_immutable",
        "documentation_markdown_or_text",
        "static_asset_image_or_binary",
        "test_fixture_or_golden_artifact",
        "script_or_executable_file_no_post_create_invocation",
        "script_or_executable_file_invoked_under_declared_hook",
        "generated_only_artifact_back_linked_to_canonical_source",
        "lineage_metadata_file_for_generated_project",
        "generated_file_class_unknown_requires_review"
      ],
      "description": "Re-exported from schemas/scaffolding/template_manifest.schema.json without modification."
    },
    "delete_generated_output_recovery_route_class": {
      "type": "string",
      "enum": [
        "delete_with_lockfile_checkpoint_recovery",
        "delete_with_workspace_snapshot_recovery",
        "delete_with_local_history_recovery_only",
        "delete_with_regenerate_from_template_recovery",
        "delete_with_no_lineage_packet_local_history_only_review_required",
        "delete_unrecoverable_user_review_required"
      ],
      "description": "Re-exported from schemas/scaffolding/scaffold_run.schema.json without modification."
    },
    "scaffold_dry_run_posture_class": {
      "type": "string",
      "enum": [
        "dry_run_required_before_apply",
        "dry_run_offered_before_apply_user_may_skip",
        "dry_run_not_applicable_pure_files_no_side_effects",
        "dry_run_unavailable_irreversible_under_approval_only"
      ],
      "description": "Re-exported from schemas/scaffolding/scaffold_run.schema.json without modification."
    },
    "bypass_path_id": {
      "type": "string",
      "enum": [
        "bypass.open_folder_without_starter",
        "bypass.open_workspace_without_starter",
        "bypass.clone_repository_without_starter",
        "bypass.create_empty_workspace",
        "bypass.open_prebuild_minimal",
        "bypass.set_up_later",
        "bypass.continue_without_starter"
      ],
      "description": "Re-exported from docs/ux/template_and_prebuild_contract.md §3.9 without modification."
    },
    "template_health_state_class": {
      "type": "string",
      "enum": [
        "fresh",
        "validation_pending",
        "validation_stale",
        "validation_failed",
        "known_issue_active_workaround_documented",
        "known_issue_active_blocking_user_review_required",
        "deprecated",
        "unsupported",
        "preview_or_experimental",
        "ai_tool_proposed_pending_review",
        "health_state_unknown_requires_review"
      ],
      "description": "Re-exported from schemas/scaffolding/template_card.schema.json without modification."
    },
    "preflight_axis_class": {
      "type": "string",
      "enum": [
        "parameter_use_preview",
        "environment_use_preview",
        "file_write_preview",
        "dependency_impact_preview",
        "execution_step_preview",
        "immediate_vs_deferred_partition",
        "checkpoint_preview",
        "delete_generated_recovery_route_preview",
        "side_effect_summary_chip_set",
        "bypass_path_preview"
      ],
      "description": "Closed set of preflight axes the sheet renders. The first eight match the spec acceptance directly: parameter / environment use, file writes, dependency impact, execution steps, immediate-vs-deferred partition, checkpoints, and delete-generated recovery paths. Adding a value is additive-minor."
    },
    "file_write_disposition_class": {
      "type": "string",
      "enum": [
        "write_new_file_no_existing_target",
        "overwrite_existing_file_admitted",
        "skip_if_exists_preserve_existing",
        "refuse_overwrite_review_required",
        "merge_with_existing_round_trip",
        "rename_existing_then_write_new",
        "write_disposition_class_unknown_requires_review"
      ],
      "description": "Closed disposition for each generated file the preflight enumerates. Refuse_overwrite_review_required keeps a destructive overwrite from being silently approved."
    },
    "dependency_impact_class": {
      "type": "string",
      "enum": [
        "no_dependency_impact",
        "install_full_dependency_set",
        "install_added_dependencies_only",
        "restore_from_lockfile_only_no_resolution",
        "skip_install_local_lockfile_present",
        "network_unavailable_review_required",
        "managed_only_channel_install_required",
        "dependency_impact_class_unknown_requires_review"
      ]
    },
    "lockfile_mutation_class": {
      "type": "string",
      "enum": [
        "no_lockfile_mutation",
        "lockfile_created_new",
        "lockfile_updated_paired_text_round_trip",
        "lockfile_unchanged_restore_only",
        "lockfile_mutation_class_unknown_requires_review"
      ]
    },
    "execution_phase_class": {
      "type": "string",
      "enum": [
        "pre_fetch_phase",
        "pre_write_phase",
        "post_write_phase",
        "post_create_phase",
        "post_delete_phase"
      ]
    },
    "immediate_or_deferred_action_class": {
      "type": "string",
      "enum": [
        "immediate_action_runs_on_apply",
        "immediate_action_blocks_apply_until_done",
        "deferred_action_runs_after_open",
        "deferred_action_user_must_invoke",
        "deferred_action_set_up_later_path",
        "skipped_under_bypass_path",
        "immediate_or_deferred_class_unknown_requires_review"
      ]
    },
    "checkpoint_kind_class": {
      "type": "string",
      "enum": [
        "no_checkpoint_pure_files",
        "lockfile_checkpoint_planted",
        "workspace_snapshot_checkpoint_planted",
        "vcs_init_checkpoint_planted",
        "local_history_checkpoint_only",
        "managed_workspace_checkpoint_envelope",
        "checkpoint_kind_unknown_requires_review"
      ]
    },
    "environment_use_kind_class": {
      "type": "string",
      "enum": [
        "no_environment_use",
        "read_environment_variable_local_only",
        "read_workspace_setting_local_only",
        "read_profile_setting_local_only",
        "read_secret_broker_handle_only",
        "read_managed_workspace_envelope_only",
        "read_organization_provenance_handle_only",
        "environment_use_kind_unknown_requires_review"
      ]
    },
    "preflight_disposition_class": {
      "type": "string",
      "enum": [
        "preflight_admissible_apply_admitted",
        "preflight_dry_run_only_admitted",
        "preflight_blocked_workspace_trust_required",
        "preflight_blocked_policy_narrowed",
        "preflight_blocked_signature_review_required",
        "preflight_blocked_known_issue_blocking",
        "preflight_blocked_unsupported",
        "preflight_blocked_validation_failed",
        "preflight_blocked_target_runtime_unavailable",
        "preflight_blocked_template_revision_archived",
        "preflight_pending_ai_admission",
        "preflight_disposition_class_unknown_requires_review"
      ]
    },
    "denial_reason_class": {
      "type": "string",
      "enum": [
        "no_denial_preflight_admissible",
        "undeclared_hook_or_setup_task_must_not_run",
        "dry_run_required_before_apply_was_skipped",
        "raw_secret_in_template_manifest_forbidden",
        "raw_absolute_path_in_template_manifest_forbidden",
        "parameter_kind_must_resolve_to_typed_class",
        "template_egress_posture_must_resolve_to_typed_class",
        "template_trust_posture_must_match_declared_hooks_and_tasks",
        "workspace_trust_unset_or_restricted",
        "policy_epoch_expired_re_evaluation_required",
        "signature_review_required_user_review_required",
        "community_or_uncertified_template_pending_user_admit",
        "ai_tool_proposed_template_must_not_apply_pending_review",
        "ai_tool_proposed_run_must_not_apply_pending_admission",
        "manifest_content_address_unverifiable_user_review_required",
        "template_revision_archived_no_apply_path",
        "lineage_metadata_must_be_plain_reviewable_file",
        "create_without_starter_route_must_remain_at_equal_weight",
        "denial_reason_class_unknown_requires_review"
      ],
      "description": "Closed denial-reason vocabulary, re-exported from the scaffold-run contract and extended with create_without_starter_route_must_remain_at_equal_weight to enforce health-states acceptance bullet 3."
    },
    "parameter_use_preview_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameter_id_ref",
        "required_parameter_kind_class",
        "value_source_class"
      ],
      "properties": {
        "parameter_id_ref": { "$ref": "#/$defs/opaque_id" },
        "required_parameter_kind_class": {
          "$ref": "#/$defs/required_parameter_kind_class"
        },
        "value_source_class": {
          "type": "string",
          "enum": [
            "user_supplied_in_session",
            "default_from_manifest",
            "secret_broker_handle_only",
            "organization_provenance_handle_only",
            "imported_from_export_bundle",
            "ai_proposed_pending_review",
            "value_source_class_unknown_requires_review"
          ]
        },
        "value_handle_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      },
      "allOf": [
        {
          "description": "typed_secret_broker_handle_only requires a non-null value_handle_ref pointing at the secret-broker handle registry; raw secrets never cross the boundary.",
          "if": {
            "properties": {
              "required_parameter_kind_class": {
                "const": "typed_secret_broker_handle_only"
              }
            }
          },
          "then": {
            "required": ["value_handle_ref"],
            "properties": {
              "value_handle_ref": { "$ref": "#/$defs/opaque_id" },
              "value_source_class": {
                "const": "secret_broker_handle_only"
              }
            }
          }
        }
      ]
    },
    "environment_use_preview_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment_use_kind_class"],
      "properties": {
        "environment_use_kind_class": {
          "$ref": "#/$defs/environment_use_kind_class"
        },
        "environment_use_handle_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      }
    },
    "file_write_preview_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generated_file_id_ref",
        "generated_file_class",
        "file_write_disposition_class"
      ],
      "properties": {
        "generated_file_id_ref": { "$ref": "#/$defs/opaque_id" },
        "generated_file_class": { "$ref": "#/$defs/generated_file_class" },
        "file_write_disposition_class": {
          "$ref": "#/$defs/file_write_disposition_class"
        },
        "byte_size_bucket_class": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "string",
              "enum": [
                "size_bucket_under_1_kib",
                "size_bucket_1_kib_to_64_kib",
                "size_bucket_64_kib_to_1_mib",
                "size_bucket_1_mib_to_16_mib",
                "size_bucket_over_16_mib",
                "size_bucket_unknown_requires_review"
              ]
            }
          ]
        },
        "summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      }
    },
    "dependency_impact_preview_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bound_supported_ecosystem_class", "dependency_impact_class"],
      "properties": {
        "bound_supported_ecosystem_class": {
          "$ref": "#/$defs/supported_ecosystem_class"
        },
        "dependency_impact_class": {
          "$ref": "#/$defs/dependency_impact_class"
        },
        "lockfile_mutation_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/lockfile_mutation_class" }
          ]
        },
        "added_dependency_count_bucket": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "string",
              "enum": [
                "no_added_dependencies",
                "one_to_five_added",
                "six_to_twenty_added",
                "twenty_one_to_one_hundred_added",
                "over_one_hundred_added",
                "added_count_bucket_unknown_requires_review"
              ]
            }
          ]
        },
        "summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      }
    },
    "execution_step_preview_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_index",
        "execution_phase_class",
        "immediate_or_deferred_action_class",
        "step_kind"
      ],
      "properties": {
        "step_index": { "$ref": "#/$defs/non_negative_integer" },
        "execution_phase_class": {
          "$ref": "#/$defs/execution_phase_class"
        },
        "immediate_or_deferred_action_class": {
          "$ref": "#/$defs/immediate_or_deferred_action_class"
        },
        "step_kind": {
          "type": "string",
          "enum": [
            "declared_hook_invocation",
            "declared_setup_task_invocation",
            "checkpoint_plant",
            "rollback_breadcrumb_emit",
            "step_kind_unknown_requires_review"
          ]
        },
        "bound_declared_hook_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "bound_declared_setup_task_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "bound_checkpoint_kind_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/checkpoint_kind_class" }
          ]
        },
        "summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      },
      "allOf": [
        {
          "description": "declared_hook_invocation requires a non-null bound_declared_hook_id_ref so the step resolves through the manifest's declared_hooks list — never a free-form invocation.",
          "if": {
            "properties": { "step_kind": { "const": "declared_hook_invocation" } }
          },
          "then": {
            "required": ["bound_declared_hook_id_ref"],
            "properties": {
              "bound_declared_hook_id_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        },
        {
          "description": "declared_setup_task_invocation requires a non-null bound_declared_setup_task_id_ref.",
          "if": {
            "properties": {
              "step_kind": { "const": "declared_setup_task_invocation" }
            }
          },
          "then": {
            "required": ["bound_declared_setup_task_id_ref"],
            "properties": {
              "bound_declared_setup_task_id_ref": {
                "$ref": "#/$defs/opaque_id"
              }
            }
          }
        },
        {
          "description": "checkpoint_plant requires a non-null bound_checkpoint_kind_class.",
          "if": {
            "properties": { "step_kind": { "const": "checkpoint_plant" } }
          },
          "then": {
            "required": ["bound_checkpoint_kind_class"],
            "properties": {
              "bound_checkpoint_kind_class": {
                "$ref": "#/$defs/checkpoint_kind_class"
              }
            }
          }
        }
      ]
    },
    "checkpoint_preview_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkpoint_kind_class"],
      "properties": {
        "checkpoint_kind_class": {
          "$ref": "#/$defs/checkpoint_kind_class"
        },
        "checkpoint_handle_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      },
      "allOf": [
        {
          "description": "Non-no-checkpoint kinds require a non-null checkpoint_handle_ref pointing at the per-checkpoint registry.",
          "if": {
            "properties": {
              "checkpoint_kind_class": {
                "enum": [
                  "lockfile_checkpoint_planted",
                  "workspace_snapshot_checkpoint_planted",
                  "vcs_init_checkpoint_planted",
                  "managed_workspace_checkpoint_envelope"
                ]
              }
            }
          },
          "then": {
            "required": ["checkpoint_handle_ref"],
            "properties": {
              "checkpoint_handle_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        }
      ]
    },
    "generation_preflight_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "generation_preflight_schema_version",
        "preflight_id",
        "bound_template_card_record_ref",
        "bound_template_manifest_record_ref",
        "bound_template_id_ref",
        "bound_template_revision_ref",
        "preflight_axis_set_rendered",
        "parameter_use_preview",
        "environment_use_preview",
        "file_write_preview",
        "dependency_impact_preview",
        "execution_step_preview",
        "checkpoint_preview",
        "delete_generated_recovery_route_class",
        "scaffold_dry_run_posture_class",
        "preflight_disposition_class",
        "denial_reason_class",
        "template_health_state_class_carried",
        "create_without_starter_route_ids",
        "minted_at"
      ],
      "properties": {
        "record_kind": { "const": "generation_preflight_record" },
        "generation_preflight_schema_version": {
          "$ref": "#/$defs/generation_preflight_schema_version"
        },
        "preflight_id": { "$ref": "#/$defs/opaque_id" },
        "bound_template_card_record_ref": { "$ref": "#/$defs/opaque_id" },
        "bound_template_manifest_record_ref": { "$ref": "#/$defs/opaque_id" },
        "bound_template_id_ref": { "$ref": "#/$defs/opaque_id" },
        "bound_template_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "preflight_axis_set_rendered": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/preflight_axis_class" }
        },
        "parameter_use_preview": {
          "type": "array",
          "items": { "$ref": "#/$defs/parameter_use_preview_descriptor" }
        },
        "environment_use_preview": {
          "type": "array",
          "items": { "$ref": "#/$defs/environment_use_preview_descriptor" }
        },
        "file_write_preview": {
          "type": "array",
          "items": { "$ref": "#/$defs/file_write_preview_descriptor" }
        },
        "dependency_impact_preview": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependency_impact_preview_descriptor" }
        },
        "execution_step_preview": {
          "type": "array",
          "items": { "$ref": "#/$defs/execution_step_preview_descriptor" }
        },
        "checkpoint_preview": {
          "type": "array",
          "items": { "$ref": "#/$defs/checkpoint_preview_descriptor" }
        },
        "delete_generated_recovery_route_class": {
          "$ref": "#/$defs/delete_generated_output_recovery_route_class"
        },
        "delete_generated_recovery_route_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "scaffold_dry_run_posture_class": {
          "$ref": "#/$defs/scaffold_dry_run_posture_class"
        },
        "preflight_disposition_class": {
          "$ref": "#/$defs/preflight_disposition_class"
        },
        "denial_reason_class": { "$ref": "#/$defs/denial_reason_class" },
        "template_health_state_class_carried": {
          "$ref": "#/$defs/template_health_state_class"
        },
        "create_without_starter_route_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/bypass_path_id" }
        },
        "ai_tool_proposed_review_ticket_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        },
        "notes_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "preflight_axis_set_rendered MUST contain the four required axes named in the spec acceptance: file_write_preview, dependency_impact_preview, execution_step_preview, immediate_vs_deferred_partition. A preflight that hides any of these collapses execution into a generic Create action and is non-conforming.",
          "properties": {
            "preflight_axis_set_rendered": {
              "type": "array",
              "allOf": [
                { "contains": { "const": "file_write_preview" } },
                { "contains": { "const": "dependency_impact_preview" } },
                { "contains": { "const": "execution_step_preview" } },
                { "contains": { "const": "immediate_vs_deferred_partition" } },
                { "contains": { "const": "checkpoint_preview" } },
                {
                  "contains": {
                    "const": "delete_generated_recovery_route_preview"
                  }
                },
                { "contains": { "const": "bypass_path_preview" } }
              ]
            }
          }
        },
        {
          "description": "preflight_admissible_apply_admitted requires denial_reason_class no_denial_preflight_admissible.",
          "if": {
            "properties": {
              "preflight_disposition_class": {
                "const": "preflight_admissible_apply_admitted"
              }
            }
          },
          "then": {
            "properties": {
              "denial_reason_class": {
                "const": "no_denial_preflight_admissible"
              }
            }
          }
        },
        {
          "description": "Every preflight_blocked_* disposition MUST cite a denial_reason_class other than no_denial_preflight_admissible.",
          "if": {
            "properties": {
              "preflight_disposition_class": {
                "enum": [
                  "preflight_blocked_workspace_trust_required",
                  "preflight_blocked_policy_narrowed",
                  "preflight_blocked_signature_review_required",
                  "preflight_blocked_known_issue_blocking",
                  "preflight_blocked_unsupported",
                  "preflight_blocked_validation_failed",
                  "preflight_blocked_target_runtime_unavailable",
                  "preflight_blocked_template_revision_archived"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "denial_reason_class": {
                "not": { "const": "no_denial_preflight_admissible" }
              }
            }
          }
        },
        {
          "description": "preflight_pending_ai_admission MUST cite a non-null ai_tool_proposed_review_ticket_ref and ai_tool_proposed_run_must_not_apply_pending_admission denial.",
          "if": {
            "properties": {
              "preflight_disposition_class": {
                "const": "preflight_pending_ai_admission"
              }
            }
          },
          "then": {
            "required": ["ai_tool_proposed_review_ticket_ref"],
            "properties": {
              "ai_tool_proposed_review_ticket_ref": {
                "$ref": "#/$defs/opaque_id"
              },
              "denial_reason_class": {
                "const": "ai_tool_proposed_run_must_not_apply_pending_admission"
              },
              "template_health_state_class_carried": {
                "const": "ai_tool_proposed_pending_review"
              }
            }
          }
        },
        {
          "description": "scaffold_dry_run_posture_class dry_run_required_before_apply forbids preflight_admissible_apply_admitted unless the file_write_preview is non-empty (a meaningful preview was rendered).",
          "if": {
            "properties": {
              "scaffold_dry_run_posture_class": {
                "const": "dry_run_required_before_apply"
              },
              "preflight_disposition_class": {
                "const": "preflight_admissible_apply_admitted"
              }
            }
          },
          "then": {
            "properties": {
              "file_write_preview": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        },
        {
          "description": "delete_generated_recovery_route_class delete_unrecoverable_user_review_required forces preflight_disposition_class out of preflight_admissible_apply_admitted; an unrecoverable delete route cannot be silently approved.",
          "if": {
            "properties": {
              "delete_generated_recovery_route_class": {
                "const": "delete_unrecoverable_user_review_required"
              }
            }
          },
          "then": {
            "properties": {
              "preflight_disposition_class": {
                "not": { "const": "preflight_admissible_apply_admitted" }
              }
            }
          }
        },
        {
          "description": "Health-state classes that block generation force preflight_disposition_class into the matching preflight_blocked_* class or preflight_pending_ai_admission. The bypass list MUST remain non-empty regardless of the health state — health warnings never remove the open-without-starter route.",
          "if": {
            "properties": {
              "template_health_state_class_carried": {
                "enum": [
                  "known_issue_active_blocking_user_review_required",
                  "unsupported",
                  "validation_failed",
                  "ai_tool_proposed_pending_review"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "preflight_disposition_class": {
                "enum": [
                  "preflight_blocked_known_issue_blocking",
                  "preflight_blocked_unsupported",
                  "preflight_blocked_validation_failed",
                  "preflight_blocked_signature_review_required",
                  "preflight_blocked_policy_narrowed",
                  "preflight_blocked_target_runtime_unavailable",
                  "preflight_blocked_template_revision_archived",
                  "preflight_blocked_workspace_trust_required",
                  "preflight_pending_ai_admission"
                ]
              }
            }
          }
        }
      ],
      "description": "Per-preflight-sheet record. Every Generate sheet emits one of these; the record enumerates parameter / environment use, file writes, dependency impact, execution steps, immediate-vs-deferred partition, checkpoints, and the delete-generated recovery route — never collapsed into a single Create action."
    }
  }
}
