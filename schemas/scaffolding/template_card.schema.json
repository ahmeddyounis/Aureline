{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/scaffolding/template_card.schema.json",
  "title": "Aureline scaffold-template card contract",
  "description": "Boundary schema for the scaffold template card record frozen in docs/scaffolding/template_health_and_preflight_contract.md. The card is the per-template projection a user inspects before a generation preflight is opened: it names exactly one source class, exactly one support class, exactly one language / runtime / platform target set, exactly one host boundary class, exactly one signing-or-trust badge class, and an enumerated side-effect summary covering required network egress, required extension installs, required remote provisioning, and required managed-service / credential side effects. Every card cites a non-null bound_template_manifest_record_ref so the scaffold-runner contract (schemas/scaffolding/template_manifest.schema.json) remains the source of truth for declared hooks and setup tasks; this card MUST NOT mint parallel hook, setup-task, parameter, generated-file, or trust-posture vocabulary. Every card carries a non-empty create_without_starter_route_ids list so the open-without-starter route is preserved at every health state. Raw bearer tokens, raw API keys, raw passwords, raw signing keys, raw certificate / key material, raw absolute filesystem paths, raw repository URLs, raw author email addresses, raw container registry URLs, raw devcontainer image tags, raw lockfile bodies, raw extension marketplace urls, raw stdout / stderr, and raw post-install script bodies never cross this boundary; the schema carries opaque ids, closed vocabulary, content-addresses, and short reviewable sentences only. Adding a new host_boundary_class, signing_or_trust_badge_class, required_extension_install_class, required_remote_provisioning_class, required_managed_service_class, required_credential_provisioning_class, template_health_state_class, or card_disposition_class value is additive-minor and bumps template_card_schema_version; repurposing an existing value is breaking and requires a new decision row in artifacts/governance/decision_index.yaml.",
  "type": "object",
  "$ref": "#/$defs/template_card_record",
  "$defs": {
    "template_card_schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in support bundles, claim manifests, and release evidence. Raw paths, raw URLs, raw JSON payloads, raw secrets never appear here."
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "description": "Short reviewable sentence intended for gallery preview, preflight summary, and post-create handoff cards."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "semver_string": {
      "type": "string",
      "minLength": 1
    },
    "template_archetype_class": {
      "type": "string",
      "enum": [
        "web_application",
        "web_frontend_library",
        "backend_service",
        "cli_tool",
        "library_or_sdk",
        "data_or_ml_workbench",
        "mobile_application",
        "embedded_or_firmware",
        "monorepo_root_with_workspaces",
        "monorepo_member_workspace",
        "documentation_site",
        "infrastructure_or_pipeline",
        "extension_or_plugin",
        "archetype_class_unknown_requires_review"
      ],
      "description": "Re-exported from schemas/scaffolding/template_manifest.schema.json without modification."
    },
    "template_source_class": {
      "type": "string",
      "enum": [
        "first_party",
        "team_managed",
        "community",
        "local_only",
        "mirror_cached",
        "uncertified"
      ],
      "description": "Re-exported from docs/ux/template_and_prebuild_contract.md §3.2 without modification."
    },
    "support_class": {
      "type": "string",
      "enum": [
        "officially_supported",
        "community_supported",
        "experimental",
        "legacy_deprecated",
        "unsupported",
        "support_unknown"
      ],
      "description": "Re-exported from docs/ux/template_and_prebuild_contract.md §3.3 without modification."
    },
    "template_lifecycle_class": {
      "type": "string",
      "enum": [
        "resume_live_workspace",
        "start_from_snapshot",
        "clone_fresh_repository",
        "template_based_start",
        "prebuild_warm_start",
        "open_without_starter",
        "ai_tool_proposed_pending_review"
      ],
      "description": "Re-exported from docs/ux/template_and_prebuild_contract.md §3.5 without modification."
    },
    "runtime_and_toolchain_scope": {
      "type": "string",
      "enum": [
        "local_only",
        "local_with_devcontainer",
        "local_with_container",
        "remote_image_required",
        "managed_cloud_required",
        "mixed_local_and_remote",
        "not_declared"
      ],
      "description": "Re-exported from docs/ux/template_and_prebuild_contract.md §3.4 without modification."
    },
    "supported_ecosystem_class": {
      "type": "string",
      "enum": [
        "rust_cargo",
        "node_npm",
        "node_pnpm",
        "node_yarn",
        "node_bun",
        "python_pip",
        "python_poetry",
        "python_uv",
        "go_modules",
        "java_maven",
        "java_gradle",
        "dotnet_nuget",
        "ruby_bundler",
        "swift_package_manager",
        "multi_ecosystem_polyglot",
        "no_ecosystem_pure_files",
        "ecosystem_class_unknown_requires_review"
      ],
      "description": "Re-exported from schemas/scaffolding/template_manifest.schema.json without modification."
    },
    "supported_platform_class": {
      "type": "string",
      "enum": [
        "linux_x86_64",
        "linux_arm64",
        "macos_x86_64",
        "macos_arm64",
        "windows_x86_64",
        "windows_arm64",
        "web_browser_runtime",
        "container_runtime_target",
        "devcontainer_runtime_target",
        "managed_workspace_remote_target",
        "mobile_ios_target",
        "mobile_android_target",
        "embedded_target",
        "platform_class_unknown_requires_review"
      ],
      "description": "Re-exported from schemas/scaffolding/template_manifest.schema.json without modification."
    },
    "declared_freshness_class": {
      "type": "string",
      "enum": [
        "live_origin",
        "mirror_fresh",
        "mirror_lagged",
        "mirror_stale",
        "offline_snapshot",
        "signed_offline_bundle",
        "unknown_freshness"
      ],
      "description": "Re-exported from docs/ux/template_and_prebuild_contract.md §3.6 without modification."
    },
    "starter_setup_cost_class": {
      "type": "string",
      "enum": [
        "no_setup",
        "light_local_setup",
        "network_package_restore",
        "devcontainer_bootstrap",
        "container_bootstrap",
        "managed_remote_provisioning",
        "prebuild_attach_warm",
        "time_unknown_network_unknown"
      ],
      "description": "Re-exported from docs/ux/template_and_prebuild_contract.md §3.7 without modification."
    },
    "signer_continuity_class": {
      "type": "string",
      "enum": [
        "continuous_with_previous_acquisition",
        "first_acquisition_no_prior_signer",
        "signer_changed_review_required",
        "signer_unknown_user_review_required",
        "signer_continuity_not_applicable"
      ],
      "description": "Re-exported from the source-acquisition / bootstrap seed §1.5 without modification."
    },
    "signature_class": {
      "type": "string",
      "enum": [
        "unsigned",
        "author_signature",
        "author_and_organization_signature",
        "organization_signature_only",
        "managed_only_channel_signature",
        "quarantined_no_signature"
      ],
      "description": "Re-exported from the recipe / macro contract without modification."
    },
    "template_trust_posture_class": {
      "type": "string",
      "enum": [
        "workspace_trust_not_required_pure_local_files_only",
        "workspace_trust_required_before_post_create_actions",
        "workspace_trust_required_before_any_apply",
        "workspace_trust_revalidated_each_step",
        "restricted_mode_tolerated_read_only_only",
        "ai_tool_proposed_template_pending_review"
      ],
      "description": "Re-exported from schemas/scaffolding/template_manifest.schema.json without modification."
    },
    "template_egress_posture_class": {
      "type": "string",
      "enum": [
        "no_network_egress_required",
        "egress_to_first_party_origin_only",
        "egress_to_team_managed_mirror_only",
        "egress_to_community_origin_user_review_required",
        "egress_to_managed_workspace_envelope_only",
        "egress_envelope_unknown_requires_review"
      ],
      "description": "Re-exported from schemas/scaffolding/template_manifest.schema.json without modification."
    },
    "template_known_issue_class": {
      "type": "string",
      "enum": [
        "no_known_issue",
        "known_issue_active_workaround_documented",
        "known_issue_active_blocking_user_review_required",
        "known_issue_mitigated_by_workaround_in_template",
        "known_issue_resolved_in_revision",
        "known_issue_class_unknown_requires_review"
      ],
      "description": "Re-exported from schemas/scaffolding/template_manifest.schema.json without modification."
    },
    "bypass_path_id": {
      "type": "string",
      "enum": [
        "bypass.open_folder_without_starter",
        "bypass.open_workspace_without_starter",
        "bypass.clone_repository_without_starter",
        "bypass.create_empty_workspace",
        "bypass.open_prebuild_minimal",
        "bypass.set_up_later",
        "bypass.continue_without_starter"
      ],
      "description": "Re-exported from docs/ux/template_and_prebuild_contract.md §3.9 without modification."
    },
    "host_boundary_class": {
      "type": "string",
      "enum": [
        "host_local_device_only",
        "host_local_with_devcontainer_attached",
        "host_local_with_container_attached",
        "host_remote_image_required",
        "host_managed_workspace_required",
        "host_mixed_local_and_remote",
        "host_boundary_unknown_requires_review"
      ],
      "description": "Closed set declaring where the resulting workspace's host boundary actually lives. Composed with runtime_and_toolchain_scope but not redundant: runtime_and_toolchain_scope names which scope applies; host_boundary_class names whether the user's process/filesystem is on-device, attached to a container, or on a managed workspace. Adding a value bumps template_card_schema_version."
    },
    "signing_or_trust_badge_class": {
      "type": "string",
      "enum": [
        "first_party_signed_badge",
        "organization_signed_badge",
        "managed_only_channel_signed_badge",
        "author_signed_badge",
        "community_signer_continuity_review_required_badge",
        "uncertified_no_signature_badge",
        "ai_tool_proposed_pending_review_badge",
        "quarantined_no_signature_badge",
        "trust_badge_unknown_requires_review"
      ],
      "description": "Closed badge the card renders next to the title. Composes signature_class with template_trust_posture_class so the gallery row never has to compute the badge separately."
    },
    "required_network_egress_class": {
      "type": "string",
      "enum": [
        "no_network_egress_required",
        "egress_to_first_party_origin_only",
        "egress_to_team_managed_mirror_only",
        "egress_to_community_origin_user_review_required",
        "egress_to_managed_workspace_envelope_only",
        "egress_envelope_unknown_requires_review"
      ],
      "description": "Closed set re-exporting template_egress_posture_class verbatim. Surfaced on the card as the network egress chip."
    },
    "required_extension_install_class": {
      "type": "string",
      "enum": [
        "no_extension_install_required",
        "first_party_extension_install_required",
        "organization_curated_extension_install_required",
        "marketplace_extension_install_user_review_required",
        "managed_only_channel_extension_install_required",
        "extension_install_review_required_signature_unverified",
        "extension_install_class_unknown_requires_review"
      ],
      "description": "Closed set declaring whether the card's resulting workspace will require an IDE extension install before or during scaffold. The class is rendered as a chip; details (specific extension ids, publisher class, signature state, permission class) belong to the generation_preflight_record's extension_install_preview, not the card."
    },
    "required_remote_provisioning_class": {
      "type": "string",
      "enum": [
        "no_remote_provisioning_required",
        "devcontainer_attach_required",
        "container_attach_required",
        "remote_image_required",
        "managed_workspace_required",
        "mixed_local_and_remote_provisioning_required",
        "remote_provisioning_unknown_requires_review"
      ]
    },
    "required_managed_service_class": {
      "type": "string",
      "enum": [
        "no_managed_service_required",
        "managed_workspace_envelope_required",
        "managed_only_channel_invocation_required",
        "third_party_connected_provider_required",
        "first_party_managed_service_required",
        "managed_service_class_unknown_requires_review"
      ]
    },
    "required_credential_provisioning_class": {
      "type": "string",
      "enum": [
        "no_credential_provisioning_required",
        "secret_broker_handle_required",
        "credential_provisioning_step_required",
        "remote_attach_handshake_required",
        "credential_provisioning_class_unknown_requires_review"
      ]
    },
    "template_health_state_class": {
      "type": "string",
      "enum": [
        "fresh",
        "validation_pending",
        "validation_stale",
        "validation_failed",
        "known_issue_active_workaround_documented",
        "known_issue_active_blocking_user_review_required",
        "deprecated",
        "unsupported",
        "preview_or_experimental",
        "ai_tool_proposed_pending_review",
        "health_state_unknown_requires_review"
      ],
      "description": "Closed set of card-level health-state classes. Authoritative roll-up resolved against template_health_check_descriptors on the manifest; surfaces never invent intermediate states."
    },
    "card_disposition_class": {
      "type": "string",
      "enum": [
        "card_admissible_for_generation",
        "card_visible_disabled_signature_review_required",
        "card_visible_disabled_policy_narrowed",
        "card_visible_disabled_target_runtime_unavailable",
        "card_visible_disabled_template_revision_archived",
        "card_visible_disabled_known_issue_blocking",
        "card_visible_disabled_unsupported",
        "card_visible_disabled_validation_failed",
        "card_hidden_review_required",
        "ai_tool_proposed_pending_admission",
        "card_disposition_class_unknown_requires_review"
      ],
      "description": "Closed disposition for the card surface. Drives whether the card's primary action is enabled, visible-disabled with an inline notice, hidden, or pending AI admission. The bypass routes (create_without_starter_route_ids) MUST remain at equal weight in every disposition."
    },
    "side_effect_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_network_egress_class",
        "required_extension_install_class",
        "required_remote_provisioning_class",
        "required_managed_service_class",
        "required_credential_provisioning_class"
      ],
      "properties": {
        "required_network_egress_class": {
          "$ref": "#/$defs/required_network_egress_class"
        },
        "required_extension_install_class": {
          "$ref": "#/$defs/required_extension_install_class"
        },
        "required_remote_provisioning_class": {
          "$ref": "#/$defs/required_remote_provisioning_class"
        },
        "required_managed_service_class": {
          "$ref": "#/$defs/required_managed_service_class"
        },
        "required_credential_provisioning_class": {
          "$ref": "#/$defs/required_credential_provisioning_class"
        }
      }
    },
    "template_card_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "template_card_schema_version",
        "template_card_id",
        "bound_template_manifest_record_ref",
        "bound_template_id_ref",
        "bound_template_revision_ref",
        "title",
        "summary",
        "template_archetype_class",
        "template_source_class",
        "support_class",
        "template_lifecycle_class",
        "runtime_and_toolchain_scope",
        "supported_ecosystem_class_set",
        "supported_platform_class_set",
        "host_boundary_class",
        "signing_or_trust_badge_class",
        "template_trust_posture_class",
        "signature_class",
        "declared_freshness_class",
        "starter_setup_cost_class",
        "side_effect_summary",
        "template_health_state_class",
        "known_issue_disclosure_class",
        "card_disposition_class",
        "create_without_starter_route_ids",
        "minted_at"
      ],
      "properties": {
        "record_kind": { "const": "template_card_record" },
        "template_card_schema_version": {
          "$ref": "#/$defs/template_card_schema_version"
        },
        "template_card_id": { "$ref": "#/$defs/opaque_id" },
        "bound_template_manifest_record_ref": { "$ref": "#/$defs/opaque_id" },
        "bound_template_id_ref": { "$ref": "#/$defs/opaque_id" },
        "bound_template_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "bound_template_revision_semver": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/semver_string" }
          ]
        },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "template_archetype_class": {
          "$ref": "#/$defs/template_archetype_class"
        },
        "template_source_class": { "$ref": "#/$defs/template_source_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "template_lifecycle_class": {
          "$ref": "#/$defs/template_lifecycle_class"
        },
        "runtime_and_toolchain_scope": {
          "$ref": "#/$defs/runtime_and_toolchain_scope"
        },
        "supported_ecosystem_class_set": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/supported_ecosystem_class" }
        },
        "supported_platform_class_set": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/supported_platform_class" }
        },
        "host_boundary_class": { "$ref": "#/$defs/host_boundary_class" },
        "signing_or_trust_badge_class": {
          "$ref": "#/$defs/signing_or_trust_badge_class"
        },
        "template_trust_posture_class": {
          "$ref": "#/$defs/template_trust_posture_class"
        },
        "signature_class": { "$ref": "#/$defs/signature_class" },
        "signer_continuity_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/signer_continuity_class" }
          ]
        },
        "declared_freshness_class": {
          "$ref": "#/$defs/declared_freshness_class"
        },
        "starter_setup_cost_class": {
          "$ref": "#/$defs/starter_setup_cost_class"
        },
        "side_effect_summary": { "$ref": "#/$defs/side_effect_summary" },
        "template_health_state_class": {
          "$ref": "#/$defs/template_health_state_class"
        },
        "known_issue_disclosure_class": {
          "$ref": "#/$defs/template_known_issue_class"
        },
        "card_disposition_class": { "$ref": "#/$defs/card_disposition_class" },
        "create_without_starter_route_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/bypass_path_id" }
        },
        "ai_tool_proposed_review_ticket_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "notes_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Community / uncertified source MUST cite a non-null signer_continuity_class so the trust badge resolves honestly.",
          "if": {
            "properties": {
              "template_source_class": {
                "enum": ["community", "uncertified"]
              }
            }
          },
          "then": {
            "required": ["signer_continuity_class"],
            "properties": {
              "signer_continuity_class": {
                "$ref": "#/$defs/signer_continuity_class"
              }
            }
          }
        },
        {
          "description": "ai_tool_proposed_pending_review template_lifecycle_class MUST resolve template_trust_posture_class to ai_tool_proposed_template_pending_review, signing_or_trust_badge_class to ai_tool_proposed_pending_review_badge, template_health_state_class to ai_tool_proposed_pending_review, and card_disposition_class to ai_tool_proposed_pending_admission.",
          "if": {
            "properties": {
              "template_lifecycle_class": {
                "const": "ai_tool_proposed_pending_review"
              }
            }
          },
          "then": {
            "required": ["ai_tool_proposed_review_ticket_ref"],
            "properties": {
              "template_trust_posture_class": {
                "const": "ai_tool_proposed_template_pending_review"
              },
              "signing_or_trust_badge_class": {
                "const": "ai_tool_proposed_pending_review_badge"
              },
              "template_health_state_class": {
                "const": "ai_tool_proposed_pending_review"
              },
              "card_disposition_class": {
                "const": "ai_tool_proposed_pending_admission"
              },
              "ai_tool_proposed_review_ticket_ref": {
                "$ref": "#/$defs/opaque_id"
              }
            }
          }
        },
        {
          "description": "ai_tool_proposed_pending_admission card_disposition_class MUST cite a non-null ai_tool_proposed_review_ticket_ref.",
          "if": {
            "properties": {
              "card_disposition_class": {
                "const": "ai_tool_proposed_pending_admission"
              }
            }
          },
          "then": {
            "required": ["ai_tool_proposed_review_ticket_ref"],
            "properties": {
              "ai_tool_proposed_review_ticket_ref": {
                "$ref": "#/$defs/opaque_id"
              }
            }
          }
        },
        {
          "description": "host_boundary_class must agree with runtime_and_toolchain_scope.",
          "allOf": [
            {
              "if": {
                "properties": {
                  "runtime_and_toolchain_scope": { "const": "local_only" }
                }
              },
              "then": {
                "properties": {
                  "host_boundary_class": {
                    "enum": [
                      "host_local_device_only",
                      "host_boundary_unknown_requires_review"
                    ]
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "runtime_and_toolchain_scope": {
                    "const": "local_with_devcontainer"
                  }
                }
              },
              "then": {
                "properties": {
                  "host_boundary_class": {
                    "const": "host_local_with_devcontainer_attached"
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "runtime_and_toolchain_scope": {
                    "const": "local_with_container"
                  }
                }
              },
              "then": {
                "properties": {
                  "host_boundary_class": {
                    "const": "host_local_with_container_attached"
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "runtime_and_toolchain_scope": {
                    "const": "remote_image_required"
                  }
                }
              },
              "then": {
                "properties": {
                  "host_boundary_class": {
                    "const": "host_remote_image_required"
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "runtime_and_toolchain_scope": {
                    "const": "managed_cloud_required"
                  }
                }
              },
              "then": {
                "properties": {
                  "host_boundary_class": {
                    "const": "host_managed_workspace_required"
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "runtime_and_toolchain_scope": {
                    "const": "mixed_local_and_remote"
                  }
                }
              },
              "then": {
                "properties": {
                  "host_boundary_class": {
                    "const": "host_mixed_local_and_remote"
                  }
                }
              }
            }
          ]
        },
        {
          "description": "side_effect_summary.required_network_egress_class MUST agree with the underlying template_egress_posture_class shape; carrying egress while card claims no_network_egress_required is non-conforming.",
          "if": {
            "properties": {
              "side_effect_summary": {
                "properties": {
                  "required_network_egress_class": {
                    "const": "no_network_egress_required"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "side_effect_summary": {
                "properties": {
                  "required_remote_provisioning_class": {
                    "enum": [
                      "no_remote_provisioning_required",
                      "remote_provisioning_unknown_requires_review"
                    ]
                  },
                  "required_credential_provisioning_class": {
                    "enum": [
                      "no_credential_provisioning_required",
                      "credential_provisioning_class_unknown_requires_review"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "description": "managed_cloud_required runtime scope forces required_remote_provisioning_class to managed_workspace_required and required_managed_service_class to a non-null managed-service class.",
          "if": {
            "properties": {
              "runtime_and_toolchain_scope": {
                "const": "managed_cloud_required"
              }
            }
          },
          "then": {
            "properties": {
              "side_effect_summary": {
                "properties": {
                  "required_remote_provisioning_class": {
                    "const": "managed_workspace_required"
                  },
                  "required_managed_service_class": {
                    "enum": [
                      "managed_workspace_envelope_required",
                      "managed_only_channel_invocation_required",
                      "first_party_managed_service_required"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "description": "deprecated and unsupported card_disposition_class values must mirror template_health_state_class deprecated / unsupported (or known-issue blocking).",
          "if": {
            "properties": {
              "support_class": {
                "enum": ["legacy_deprecated", "unsupported"]
              }
            }
          },
          "then": {
            "properties": {
              "template_health_state_class": {
                "enum": [
                  "deprecated",
                  "unsupported",
                  "known_issue_active_blocking_user_review_required",
                  "validation_failed",
                  "validation_stale",
                  "validation_pending",
                  "health_state_unknown_requires_review",
                  "known_issue_active_workaround_documented"
                ]
              }
            }
          }
        },
        {
          "description": "known_issue_disclosure_class known_issue_active_blocking_user_review_required pairs with template_health_state_class known_issue_active_blocking_user_review_required.",
          "if": {
            "properties": {
              "known_issue_disclosure_class": {
                "const": "known_issue_active_blocking_user_review_required"
              }
            }
          },
          "then": {
            "properties": {
              "template_health_state_class": {
                "const": "known_issue_active_blocking_user_review_required"
              }
            }
          }
        },
        {
          "description": "Health-state classes that block generation must resolve card_disposition_class to a visible-disabled or pending class, never card_admissible_for_generation. The bypass list must remain non-empty regardless.",
          "if": {
            "properties": {
              "template_health_state_class": {
                "enum": [
                  "known_issue_active_blocking_user_review_required",
                  "unsupported",
                  "validation_failed",
                  "ai_tool_proposed_pending_review",
                  "health_state_unknown_requires_review"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "card_disposition_class": {
                "enum": [
                  "card_visible_disabled_known_issue_blocking",
                  "card_visible_disabled_unsupported",
                  "card_visible_disabled_validation_failed",
                  "card_visible_disabled_signature_review_required",
                  "card_visible_disabled_policy_narrowed",
                  "card_visible_disabled_target_runtime_unavailable",
                  "card_visible_disabled_template_revision_archived",
                  "card_hidden_review_required",
                  "ai_tool_proposed_pending_admission"
                ]
              }
            }
          }
        }
      ],
      "description": "Per-template card record. Every template revision that appears in a scaffold gallery emits one of these. The card is the per-template projection a user inspects before opening a generation_preflight_record. Nothing the scaffold runner does is admissible unless it resolves through the bound template_manifest_record."
    }
  }
}
