{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/harden_task_test_debug_and_terminal_event_normalization_truth.schema.json",
  "title": "Aureline harden-task-test-debug-and-terminal-event-normalization truth packet",
  "description": "Boundary schema for the stable event-normalization truth packet certifying task, test, debug, and terminal event-normalization lanes at the M4 launch-stable grade. Every launch_stable lane MUST publish an event_normalization_quality row plus the full four-wedge admission coverage (envelope_canonicalization, source_kind_negotiation, lifecycle_normalization, export_preservation), the full ten canonical envelope-field bindings (event_id, workspace_id, target_id, source_kind, confidence, timestamp, execution_context_id, payload_kind, raw_payload_ref, provenance), the full five source-kind bindings (native, bsp, bazel_bep, structured_output, heuristic_parser), the full nine canonical lifecycle-event bindings (task_queued, target_graph_ready, task_started, progress_updated, diagnostic_emitted, test_case_started, test_case_finished, artifact_published, task_finished), the full nine consumer-surface bindings (editor_run_surface, task_panel, test_runner_surface, debug_surface, terminal_pane, cli_headless, ai_tool_surface, review_surface, support_export), a raw_payload_retention_attestation row attesting preserved source_kind, confidence, and adapter raw payload retention, and a lineage_admission row binding execution_context_id. The packet is the single truth that the editor run surface, task panel, test runner surface, debug surface, terminal pane, CLI/headless inspector, AI tool surface, review surface, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies, paraphrase fields, or flatten the canonical envelope, lifecycle, or source-kind vocabularies.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "harden_task_test_debug_and_terminal_event_normalization_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/event_normalization_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/event_normalization_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 12,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "event_normalization_lane_class": {
      "enum": [
        "task_lane",
        "test_lane",
        "debug_lane",
        "terminal_lane"
      ]
    },
    "event_normalization_row_class": {
      "enum": [
        "event_normalization_quality",
        "wedge_admission",
        "envelope_field_binding",
        "source_kind_binding",
        "lifecycle_event_binding",
        "consumer_surface_binding",
        "raw_payload_retention_attestation",
        "lineage_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "wedge_class": {
      "enum": [
        "envelope_canonicalization",
        "source_kind_negotiation",
        "lifecycle_normalization",
        "export_preservation",
        "not_applicable"
      ]
    },
    "envelope_field_class": {
      "enum": [
        "event_id",
        "workspace_id",
        "target_id",
        "source_kind",
        "confidence",
        "timestamp",
        "execution_context_id",
        "payload_kind",
        "raw_payload_ref",
        "provenance",
        "not_applicable"
      ]
    },
    "source_kind_class": {
      "enum": [
        "native",
        "bsp",
        "bazel_bep",
        "structured_output",
        "heuristic_parser",
        "not_applicable"
      ]
    },
    "lifecycle_event_class": {
      "enum": [
        "task_queued",
        "target_graph_ready",
        "task_started",
        "progress_updated",
        "diagnostic_emitted",
        "test_case_started",
        "test_case_finished",
        "artifact_published",
        "task_finished",
        "not_applicable"
      ]
    },
    "consumer_surface_binding_class": {
      "enum": [
        "editor_run_surface",
        "task_panel",
        "test_runner_surface",
        "debug_surface",
        "terminal_pane",
        "cli_headless",
        "ai_tool_surface",
        "review_surface",
        "support_export",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "task_lane_subset_only",
        "test_lane_subset_only",
        "debug_lane_subset_only",
        "terminal_lane_subset_only",
        "wedge_admission_subset_only",
        "envelope_field_subset_only",
        "source_kind_subset_only",
        "lifecycle_event_subset_only",
        "consumer_surface_subset_only",
        "export_flattens_source_kind_or_confidence",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_wedge_admission_gap",
        "auto_narrow_on_envelope_field_gap",
        "auto_narrow_on_source_kind_gap",
        "auto_narrow_on_lifecycle_event_gap",
        "auto_narrow_on_consumer_surface_gap",
        "auto_narrow_on_export_flattening",
        "auto_narrow_on_lineage_break",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "event_normalization_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_lane_coverage",
        "missing_wedge_admission_coverage",
        "missing_envelope_field_coverage",
        "missing_source_kind_coverage",
        "missing_lifecycle_event_coverage",
        "missing_consumer_surface_coverage",
        "missing_raw_payload_retention_attestation",
        "raw_payload_retention_attestation_admits_flattening",
        "missing_lineage_admission",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "wedge_not_applicable",
        "wedge_not_permitted_on_row_class",
        "envelope_field_not_applicable",
        "envelope_field_not_permitted_on_row_class",
        "source_kind_not_applicable",
        "source_kind_not_permitted_on_row_class",
        "lifecycle_event_not_applicable",
        "lifecycle_event_not_permitted_on_row_class",
        "consumer_surface_not_applicable",
        "consumer_surface_not_permitted_on_row_class",
        "lineage_admission_missing_execution_context_id",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "wedge_vocabulary_collapsed",
        "envelope_field_vocabulary_collapsed",
        "source_kind_vocabulary_collapsed",
        "lifecycle_event_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "event_normalization_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "wedge_class",
        "envelope_field_class",
        "source_kind_class",
        "lifecycle_event_class",
        "consumer_surface_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/event_normalization_lane_class" },
        "row_class": { "$ref": "#/$defs/event_normalization_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "wedge_class": { "$ref": "#/$defs/wedge_class" },
        "envelope_field_class": { "$ref": "#/$defs/envelope_field_class" },
        "source_kind_class": { "$ref": "#/$defs/source_kind_class" },
        "lifecycle_event_class": { "$ref": "#/$defs/lifecycle_event_class" },
        "consumer_surface_class": { "$ref": "#/$defs/consumer_surface_binding_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/event_normalization_confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_id_binding": { "$ref": "#/$defs/non_empty_string" },
        "attests_raw_payload_retained": { "type": "boolean" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "event_normalization_truth_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_wedge_vocabulary",
        "preserves_envelope_field_vocabulary",
        "preserves_source_kind_vocabulary",
        "preserves_lifecycle_event_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "editor_run_surface",
            "task_panel",
            "test_runner_surface",
            "debug_surface",
            "terminal_pane",
            "cli_headless",
            "ai_tool_surface",
            "review_surface",
            "support_export",
            "release_proof_index",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "event_normalization_truth_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_wedge_vocabulary": { "type": "boolean" },
        "preserves_envelope_field_vocabulary": { "type": "boolean" },
        "preserves_source_kind_vocabulary": { "type": "boolean" },
        "preserves_lifecycle_event_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
