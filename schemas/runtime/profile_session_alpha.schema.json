{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/profile_session_alpha.schema.json",
  "title": "Aureline profile-session alpha descriptor",
  "description": "Boundary schema for one alpha profile-session descriptor. The descriptor binds capture mode/source, execution_context_id, exact build/runtime identity, target process or config, capture window, overhead class, mapping-quality state, data class, trace-bundle ref, comparison packet ref, and support/export posture into one attributable object. Raw trace payloads, command lines, environment bodies, memory snapshots, source bodies, paths, URLs, hostnames, credentials, and secrets never appear in this descriptor.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "profile_session_id",
    "capture",
    "execution_context_id",
    "exact_build_identity",
    "target",
    "capture_window",
    "overhead_class",
    "mapping_quality",
    "data_posture",
    "trace_bundle_ref",
    "comparison_packet_ref",
    "export_policy"
  ],
  "properties": {
    "record_kind": { "const": "profile_session_alpha_record" },
    "schema_version": { "$ref": "#/$defs/schema_version" },
    "profile_session_id": { "$ref": "#/$defs/opaque_ref" },
    "capture": { "$ref": "#/$defs/profile_capture_descriptor" },
    "execution_context_id": { "$ref": "#/$defs/opaque_ref" },
    "exact_build_identity": { "$ref": "#/$defs/build_runtime_identity" },
    "target": { "$ref": "#/$defs/profile_target_identity" },
    "capture_window": { "$ref": "#/$defs/capture_window" },
    "overhead_class": { "$ref": "#/$defs/overhead_class" },
    "mapping_quality": { "$ref": "#/$defs/mapping_quality_summary" },
    "data_posture": { "$ref": "#/$defs/runtime_evidence_data_posture" },
    "trace_bundle_ref": { "$ref": "#/$defs/opaque_ref" },
    "comparison_packet_ref": { "$ref": "#/$defs/opaque_ref" },
    "export_policy": { "$ref": "#/$defs/profile_export_policy" }
  },
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "opaque_ref": { "type": "string", "minLength": 1 },
    "date_time": { "type": "string", "format": "date-time" },
    "short_sentence": { "type": "string", "minLength": 1, "maxLength": 640 },
    "non_negative_integer": { "type": "integer", "minimum": 0 },
    "capture_mode": {
      "type": "string",
      "enum": [
        "cpu_sample",
        "instrumented_cpu_profile",
        "wall_time_trace",
        "memory_sample",
        "allocation_snapshot",
        "replay_recording",
        "imported_profile"
      ]
    },
    "capture_source": {
      "type": "string",
      "enum": [
        "local_capture",
        "remote_capture",
        "ci_artifact",
        "imported_bundle",
        "provider_supplied",
        "extension_supplied"
      ]
    },
    "overhead_class": {
      "type": "string",
      "enum": ["negligible", "low", "moderate", "high", "unknown"]
    },
    "mapping_quality_state": {
      "type": "string",
      "enum": [
        "exact_symbols_and_sources",
        "exact_symbols_partial_sources",
        "approximate_symbols",
        "symbolized_with_partial_source_maps",
        "raw_addresses_only",
        "stale_source_maps",
        "unresolved"
      ]
    },
    "runtime_evidence_data_class": {
      "type": "string",
      "enum": [
        "metadata_only",
        "redacted_summary",
        "environment_adjacent",
        "high_risk_raw_capture"
      ]
    },
    "trace_redaction_mode": {
      "type": "string",
      "enum": [
        "metadata_and_hashes_only",
        "redacted_summary",
        "local_only_raw_retained",
        "raw_payload_review_required",
        "withheld_by_policy"
      ]
    },
    "trace_retention_class": {
      "type": "string",
      "enum": [
        "local_rotation_7_days",
        "pinned_local_evidence",
        "support_bundle_manifest_only",
        "managed_archive",
        "not_retained_ephemeral"
      ]
    },
    "profile_capture_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capture_mode",
        "capture_source",
        "capture_source_ref",
        "evidence_state"
      ],
      "properties": {
        "capture_mode": { "$ref": "#/$defs/capture_mode" },
        "capture_source": { "$ref": "#/$defs/capture_source" },
        "capture_source_ref": { "$ref": "#/$defs/opaque_ref" },
        "evidence_state": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "build_runtime_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exact_build_identity_ref",
        "build_id",
        "commit_ref",
        "runtime_identity",
        "toolchain_identity_ref",
        "symbol_manifest_ref",
        "source_map_manifest_ref",
        "workspace_ref"
      ],
      "properties": {
        "exact_build_identity_ref": { "$ref": "#/$defs/opaque_ref" },
        "build_id": { "$ref": "#/$defs/opaque_ref" },
        "commit_ref": { "$ref": "#/$defs/opaque_ref" },
        "runtime_identity": { "$ref": "#/$defs/opaque_ref" },
        "toolchain_identity_ref": { "$ref": "#/$defs/opaque_ref" },
        "symbol_manifest_ref": { "$ref": "#/$defs/opaque_ref" },
        "source_map_manifest_ref": { "$ref": "#/$defs/opaque_ref" },
        "workspace_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "profile_target_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_kind", "target_ref", "target_label"],
      "properties": {
        "target_kind": { "$ref": "#/$defs/opaque_ref" },
        "target_ref": { "$ref": "#/$defs/opaque_ref" },
        "target_label": { "$ref": "#/$defs/short_sentence" },
        "process_ref": { "$ref": "#/$defs/opaque_ref" },
        "run_config_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "capture_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at", "ended_at", "duration_ms"],
      "properties": {
        "started_at": { "$ref": "#/$defs/date_time" },
        "ended_at": { "$ref": "#/$defs/date_time" },
        "duration_ms": { "$ref": "#/$defs/non_negative_integer" }
      }
    },
    "mapping_quality_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "symbol_manifest_ref",
        "source_map_manifest_ref",
        "exact_frame_count",
        "approximate_frame_count",
        "unresolved_frame_count",
        "note"
      ],
      "properties": {
        "state": { "$ref": "#/$defs/mapping_quality_state" },
        "symbol_manifest_ref": { "$ref": "#/$defs/opaque_ref" },
        "source_map_manifest_ref": { "$ref": "#/$defs/opaque_ref" },
        "exact_frame_count": { "$ref": "#/$defs/non_negative_integer" },
        "approximate_frame_count": { "$ref": "#/$defs/non_negative_integer" },
        "unresolved_frame_count": { "$ref": "#/$defs/non_negative_integer" },
        "note": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "runtime_evidence_data_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "data_class",
        "redaction_mode",
        "support_pack_item_id",
        "raw_payload_policy"
      ],
      "properties": {
        "data_class": { "$ref": "#/$defs/runtime_evidence_data_class" },
        "redaction_mode": { "$ref": "#/$defs/trace_redaction_mode" },
        "support_pack_item_id": { "$ref": "#/$defs/opaque_ref" },
        "raw_payload_policy": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "profile_export_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_scope",
        "raw_payload_export",
        "support_bundle_binding_ref",
        "retention_class"
      ],
      "properties": {
        "default_scope": { "$ref": "#/$defs/opaque_ref" },
        "raw_payload_export": { "$ref": "#/$defs/opaque_ref" },
        "support_bundle_binding_ref": { "$ref": "#/$defs/opaque_ref" },
        "retention_class": { "$ref": "#/$defs/trace_retention_class" }
      }
    }
  }
}
