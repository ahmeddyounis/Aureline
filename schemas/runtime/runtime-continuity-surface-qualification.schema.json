{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/runtime-continuity-surface-qualification.schema.json",
  "title": "Aureline runtime continuity surface qualification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "certification_label",
    "profile_rows",
    "evidence_index",
    "consumer_bindings",
    "source_contract_refs",
    "minted_at",
    "support_summary"
  ],
  "properties": {
    "record_kind": {
      "const": "runtime_continuity_surface_qualification"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "certification_label": {
      "type": "string",
      "minLength": 1
    },
    "profile_rows": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "profile",
          "claim_label",
          "displayed_label",
          "evidence_currency",
          "packet_refs",
          "required_proofs",
          "satisfied_proofs",
          "narrow_reasons",
          "scope_summary"
        ],
        "properties": {
          "profile": { "$ref": "#/$defs/profile" },
          "claim_label": { "$ref": "#/$defs/label" },
          "displayed_label": { "$ref": "#/$defs/label" },
          "evidence_currency": { "$ref": "#/$defs/evidence_currency" },
          "packet_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "required_proofs": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/proof_class" }
          },
          "satisfied_proofs": {
            "type": "array",
            "items": { "$ref": "#/$defs/proof_class" }
          },
          "narrow_reasons": {
            "type": "array",
            "items": { "$ref": "#/$defs/narrow_reason" }
          },
          "scope_summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "evidence_index": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entry_id",
          "profile",
          "schema_ref",
          "doc_ref",
          "artifact_ref",
          "drill_refs",
          "support_summary"
        ],
        "properties": {
          "entry_id": { "type": "string", "minLength": 1 },
          "profile": { "$ref": "#/$defs/profile" },
          "schema_ref": { "type": "string", "minLength": 1 },
          "doc_ref": { "type": "string", "minLength": 1 },
          "artifact_ref": { "type": "string", "minLength": 1 },
          "drill_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "support_summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "consumer_bindings": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "consumer",
          "consumer_ref",
          "profile_refs",
          "uses_shared_index",
          "shows_displayed_label"
        ],
        "properties": {
          "consumer": { "$ref": "#/$defs/consumer" },
          "consumer_ref": { "type": "string", "minLength": 1 },
          "profile_refs": {
            "type": "array",
            "minItems": 4,
            "items": { "$ref": "#/$defs/profile" }
          },
          "uses_shared_index": { "const": true },
          "shows_displayed_label": { "const": true }
        }
      }
    },
    "source_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "minted_at": {
      "type": "string",
      "minLength": 1
    },
    "support_summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "profile": {
      "enum": [
        "local_only",
        "mirrored",
        "managed",
        "browser_handoff"
      ]
    },
    "proof_class": {
      "enum": [
        "queue_fairness",
        "restore_no_hidden_rerun",
        "terminal_protocol_clipboard",
        "transcript_and_shared_control",
        "browser_handoff_continuity"
      ]
    },
    "label": {
      "enum": [
        "stable",
        "beta",
        "preview"
      ]
    },
    "evidence_currency": {
      "enum": [
        "current",
        "stale"
      ]
    },
    "narrow_reason": {
      "enum": [
        "proof_packet_stale",
        "browser_handoff_continuity_unqualified"
      ]
    },
    "consumer": {
      "enum": [
        "docs_help",
        "help_about",
        "support_playbook",
        "public_truth"
      ]
    }
  }
}
