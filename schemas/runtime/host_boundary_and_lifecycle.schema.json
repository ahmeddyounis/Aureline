{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/host_boundary_and_lifecycle.schema.json",
  "title": "Aureline host-boundary truth, wrong-target reapproval, and lifecycle export records",
  "description": "Boundary schema for the host-boundary truth records projected by crates/aureline-runtime/src/host_boundary/mod.rs. The record composes execution-context target identity, beta target-discovery source/freshness/confidence/capability decisions, host-boundary cue stack, action route identity, wrong-target correction posture, review-vs-commit reapproval evaluation, and managed-workspace lifecycle lineage. Task, terminal, debug, AI-tool, browser-handoff, transcript, CLI/headless, and support/export surfaces quote this object instead of inventing per-surface wording. Raw hostnames, paths, command lines, env bodies, provider payloads, and secrets do not cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/host_boundary_truth_record" },
    { "$ref": "#/$defs/host_boundary_surface_projection_record" },
    { "$ref": "#/$defs/host_boundary_reapproval_evaluation_record" },
    { "$ref": "#/$defs/host_boundary_support_export_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "task",
        "terminal",
        "debug",
        "ai_tool",
        "browser_handoff",
        "transcript",
        "cli_headless",
        "support_export"
      ]
    },
    "host_boundary_cue_class": {
      "type": "string",
      "enum": [
        "local_host_boundary",
        "user_mode_sandbox_boundary",
        "container_kernel_boundary",
        "devcontainer_boundary",
        "remote_ssh_boundary",
        "remote_agent_boundary",
        "managed_workspace_boundary",
        "notebook_kernel_boundary",
        "ai_sandbox_boundary",
        "browser_handoff_return_boundary",
        "bridged_host_boundary"
      ]
    },
    "action_origin_class": {
      "type": "string",
      "enum": [
        "user_keystroke_local",
        "cli_invocation_local",
        "ai_tool_call_local",
        "ai_tool_call_managed",
        "remote_agent_request",
        "managed_control_plane_request",
        "provider_callback_inbound",
        "import_or_restore_session"
      ]
    },
    "action_target_class": {
      "type": "string",
      "enum": [
        "local_host_target",
        "container_local_target",
        "devcontainer_target",
        "remote_ssh_target",
        "remote_agent_target",
        "managed_workspace_target",
        "notebook_kernel_local_target",
        "notebook_kernel_remote_target",
        "ai_sandbox_target",
        "system_browser_target",
        "unknown_target_class"
      ]
    },
    "action_route_class": {
      "type": "string",
      "enum": [
        "in_process_route",
        "local_rpc_route",
        "remote_rpc_route",
        "managed_control_plane_route",
        "remote_agent_attach_route",
        "approval_gated_route",
        "browser_handoff_route",
        "tunnel_exposed_route",
        "bridged_helper_route",
        "heuristic_unknown_route"
      ]
    },
    "action_exposure_class": {
      "type": "string",
      "enum": [
        "no_side_effect_local_read",
        "local_only_mutation",
        "workspace_visible_mutation",
        "browser_session_visible",
        "tunnel_exposed_public",
        "exposure_unknown_requires_review"
      ]
    },
    "route_change_reason_code": {
      "type": "string",
      "enum": [
        "canonical_no_route_change",
        "route_escalated_to_approval_required",
        "route_escalated_to_browser_handoff",
        "route_changed_target_unreachable",
        "route_changed_target_reassigned",
        "route_changed_policy_narrowed",
        "route_changed_wrong_target_detected",
        "route_changed_approval_withdrawn",
        "route_changed_freshness_floor_unmet",
        "route_changed_host_mismatch",
        "route_unknown_requires_review"
      ]
    },
    "authority_linkage_class": {
      "type": "string",
      "enum": [
        "no_authority_required_read_only",
        "local_user_keystroke_authority",
        "approval_ticket_linked",
        "browser_handoff_packet_linked",
        "remote_agent_attach_ticket_linked",
        "managed_control_plane_token_linked",
        "supervisor_repair_ticket_linked",
        "authority_missing_denied"
      ]
    },
    "boundary_freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unknown"
      ]
    },
    "boundary_reachability_class": {
      "type": "string",
      "enum": [
        "reachable",
        "warming",
        "degraded",
        "unreachable",
        "disabled_by_policy",
        "reachable_pending_reauth"
      ]
    },
    "managed_lifecycle_state": {
      "type": "string",
      "enum": [
        "undeclared",
        "provisioning",
        "warming",
        "ready",
        "idle_suspended",
        "snapshot_paused",
        "hibernated",
        "recovering",
        "quarantined",
        "retiring",
        "retired"
      ]
    },
    "managed_reviewer_label": {
      "type": "string",
      "enum": [
        "warming",
        "ready",
        "degraded",
        "paused",
        "suspended",
        "expired",
        "local_only_continuation"
      ]
    },
    "expiry_reason_class": {
      "type": "string",
      "enum": [
        "session_ticket_expired",
        "hibernation_window_elapsed",
        "retirement_drain_window_completed",
        "policy_epoch_rolled",
        "kill_switch_tripped",
        "successor_image_available"
      ]
    },
    "local_only_continuation_reason_class": {
      "type": "string",
      "enum": [
        "route_dependency_unreachable",
        "managed_control_plane_unreachable",
        "remote_agent_attach_unreachable",
        "browser_handoff_return_unavailable",
        "user_requested_local_fallback",
        "admin_requested_local_fallback"
      ]
    },
    "wrong_target_correction_class": {
      "type": "string",
      "enum": [
        "no_correction_needed",
        "corrected_before_commit",
        "corrected_after_partial_effect",
        "requires_user_confirmation",
        "blocked_pending_reapproval"
      ]
    },
    "reapproval_requirement_class": {
      "type": "string",
      "enum": [
        "no_reapproval_required",
        "session_ticket_refresh_required",
        "approval_ticket_reissue_required",
        "admin_confirmation_required",
        "policy_narrowing_required",
        "trust_reevaluation_required"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_and_hashes_only",
        "support_bundle_scoped",
        "broadened_capture"
      ]
    },
    "export_inclusion_posture": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "broadened_capture_opt_in"
      ]
    },
    "adapter_kind": {
      "type": "string",
      "enum": [
        "remote_agent_attach",
        "remote_ssh_adapter",
        "managed_workspace_adapter",
        "notebook_kernel_adapter",
        "bridged_helper_adapter",
        "ai_sandbox_adapter"
      ]
    },
    "adapter_confidence_class": {
      "type": "string",
      "enum": [
        "adapter_authoritative_match",
        "adapter_probed_consistent",
        "adapter_probed_divergent",
        "adapter_inferred_from_session",
        "adapter_unreachable"
      ]
    },
    "protected_action": {
      "type": "string",
      "enum": [
        "dispatch_run",
        "dispatch_test",
        "dispatch_debug_launch",
        "dispatch_debug_attach",
        "dispatch_build",
        "export_artifact"
      ]
    },
    "protected_action_decision": {
      "type": "string",
      "enum": [
        "allowed",
        "requires_review",
        "blocked_heuristic_target",
        "blocked_imported_target",
        "blocked_unsupported_capability",
        "blocked_resolver_unavailable",
        "blocked_freshness_stale"
      ]
    },
    "protected_action_decision_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "action_token", "decision", "decision_token", "summary"],
      "properties": {
        "action": { "$ref": "#/$defs/protected_action" },
        "action_token": { "$ref": "#/$defs/non_empty_string" },
        "decision": { "$ref": "#/$defs/protected_action_decision" },
        "decision_token": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "discovery_authority_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "discovery_source_token",
        "discovery_freshness_token",
        "target_discovery_confidence_token",
        "resolver_confidence_token",
        "advertised_capability_tokens",
        "authoritative_capability_subset_tokens",
        "protected_action_decisions",
        "any_protected_action_blocked",
        "narrowed_to_subset"
      ],
      "properties": {
        "discovery_source_token": { "$ref": "#/$defs/non_empty_string" },
        "discovery_freshness_token": { "$ref": "#/$defs/non_empty_string" },
        "target_discovery_confidence_token": { "$ref": "#/$defs/non_empty_string" },
        "resolver_confidence_token": { "$ref": "#/$defs/non_empty_string" },
        "advertised_capability_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "authoritative_capability_subset_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "protected_action_decisions": {
          "type": "array",
          "items": { "$ref": "#/$defs/protected_action_decision_row" }
        },
        "any_protected_action_blocked": { "type": "boolean" },
        "narrowed_to_subset": { "type": "boolean" }
      }
    },
    "identity_chips": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "host_identity_chip",
        "user_identity_chip",
        "workspace_identity_chip",
        "route_identity_chip"
      ],
      "properties": {
        "host_identity_chip": { "$ref": "#/$defs/non_empty_string" },
        "user_identity_chip": { "$ref": "#/$defs/non_empty_string" },
        "container_identity_chip": { "type": "string" },
        "workspace_identity_chip": { "$ref": "#/$defs/non_empty_string" },
        "route_identity_chip": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "adapter_confidence_placeholder": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter_kind",
        "adapter_kind_token",
        "adapter_confidence_class",
        "adapter_confidence_token",
        "adapter_authority_envelope_tag",
        "adapter_freshness_class",
        "adapter_freshness_token",
        "adapter_evidence_refs"
      ],
      "properties": {
        "adapter_kind": { "$ref": "#/$defs/adapter_kind" },
        "adapter_kind_token": { "$ref": "#/$defs/non_empty_string" },
        "adapter_confidence_class": { "$ref": "#/$defs/adapter_confidence_class" },
        "adapter_confidence_token": { "$ref": "#/$defs/non_empty_string" },
        "adapter_divergence_or_inference_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "adapter_authority_envelope_tag": { "$ref": "#/$defs/non_empty_string" },
        "adapter_freshness_class": { "$ref": "#/$defs/boundary_freshness_class" },
        "adapter_freshness_token": { "$ref": "#/$defs/non_empty_string" },
        "adapter_evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "managed_lifecycle_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "managed_workspace_lifecycle_state",
        "managed_workspace_lifecycle_state_token",
        "managed_workspace_reviewer_label",
        "managed_workspace_reviewer_label_token",
        "beta_lifecycle_state_token",
        "local_editing_continuity_token",
        "activation_budget_summary_ref",
        "lifecycle_lineage_tokens",
        "lifecycle_evidence_refs"
      ],
      "properties": {
        "managed_workspace_lifecycle_state": { "$ref": "#/$defs/managed_lifecycle_state" },
        "managed_workspace_lifecycle_state_token": { "$ref": "#/$defs/non_empty_string" },
        "managed_workspace_reviewer_label": { "$ref": "#/$defs/managed_reviewer_label" },
        "managed_workspace_reviewer_label_token": { "$ref": "#/$defs/non_empty_string" },
        "beta_lifecycle_state_token": { "$ref": "#/$defs/non_empty_string" },
        "local_editing_continuity_token": { "$ref": "#/$defs/non_empty_string" },
        "activation_budget_summary_ref": { "$ref": "#/$defs/non_empty_string" },
        "expiry_reason_class": { "$ref": "#/$defs/expiry_reason_class" },
        "expiry_reason_token": { "$ref": "#/$defs/non_empty_string" },
        "local_only_continuation_reason_class": {
          "$ref": "#/$defs/local_only_continuation_reason_class"
        },
        "local_only_continuation_reason_token": { "$ref": "#/$defs/non_empty_string" },
        "lifecycle_lineage_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "lifecycle_evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "host_boundary_truth_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "record_id",
        "invocation_session_id",
        "execution_context_ref",
        "workspace_ref",
        "generated_at",
        "source_surface",
        "source_surface_token",
        "target_ref",
        "target_class_token",
        "action_origin_class",
        "action_origin_token",
        "action_target_class",
        "action_target_token",
        "action_route_class",
        "action_route_token",
        "action_exposure_class",
        "action_exposure_token",
        "route_change_reason_code",
        "route_change_reason_token",
        "authority_linkage_class",
        "authority_linkage_token",
        "identity_chips",
        "host_boundary_cue_stack",
        "host_boundary_cue_stack_tokens",
        "host_boundary_visible",
        "discovery",
        "reachability_class",
        "reachability_token",
        "freshness_class",
        "freshness_token",
        "wrong_target_correction_class",
        "wrong_target_correction_token",
        "reapproval_requirement_class",
        "reapproval_requirement_token",
        "target_evidence_refs",
        "policy_epoch",
        "trust_state_token",
        "redaction_class",
        "redaction_token",
        "export_inclusion_posture",
        "export_inclusion_posture_token",
        "redaction_safe"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "host_boundary_truth_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "record_id": { "$ref": "#/$defs/non_empty_string" },
        "invocation_session_id": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_ref": { "$ref": "#/$defs/non_empty_string" },
        "workspace_ref": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "$ref": "#/$defs/non_empty_string" },
        "source_surface": { "$ref": "#/$defs/surface_class" },
        "source_surface_token": { "$ref": "#/$defs/non_empty_string" },
        "target_ref": { "$ref": "#/$defs/non_empty_string" },
        "target_class_token": { "$ref": "#/$defs/non_empty_string" },
        "action_origin_class": { "$ref": "#/$defs/action_origin_class" },
        "action_origin_token": { "$ref": "#/$defs/non_empty_string" },
        "action_target_class": { "$ref": "#/$defs/action_target_class" },
        "action_target_token": { "$ref": "#/$defs/non_empty_string" },
        "action_route_class": { "$ref": "#/$defs/action_route_class" },
        "action_route_token": { "$ref": "#/$defs/non_empty_string" },
        "action_exposure_class": { "$ref": "#/$defs/action_exposure_class" },
        "action_exposure_token": { "$ref": "#/$defs/non_empty_string" },
        "route_change_reason_code": { "$ref": "#/$defs/route_change_reason_code" },
        "route_change_reason_token": { "$ref": "#/$defs/non_empty_string" },
        "authority_linkage_class": { "$ref": "#/$defs/authority_linkage_class" },
        "authority_linkage_token": { "$ref": "#/$defs/non_empty_string" },
        "identity_chips": { "$ref": "#/$defs/identity_chips" },
        "host_boundary_cue_stack": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/host_boundary_cue_class" }
        },
        "host_boundary_cue_stack_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "host_boundary_visible": { "type": "boolean" },
        "discovery": { "$ref": "#/$defs/discovery_authority_block" },
        "adapter_confidence_placeholder": { "$ref": "#/$defs/adapter_confidence_placeholder" },
        "reachability_class": { "$ref": "#/$defs/boundary_reachability_class" },
        "reachability_token": { "$ref": "#/$defs/non_empty_string" },
        "freshness_class": { "$ref": "#/$defs/boundary_freshness_class" },
        "freshness_token": { "$ref": "#/$defs/non_empty_string" },
        "managed_lifecycle": { "$ref": "#/$defs/managed_lifecycle_truth" },
        "wrong_target_correction_class": { "$ref": "#/$defs/wrong_target_correction_class" },
        "wrong_target_correction_token": { "$ref": "#/$defs/non_empty_string" },
        "reapproval_requirement_class": { "$ref": "#/$defs/reapproval_requirement_class" },
        "reapproval_requirement_token": { "$ref": "#/$defs/non_empty_string" },
        "prior_target_ref": { "$ref": "#/$defs/non_empty_string" },
        "prior_route_token": { "$ref": "#/$defs/non_empty_string" },
        "repair_hook_ref": { "$ref": "#/$defs/non_empty_string" },
        "target_evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "policy_epoch": { "type": "integer", "minimum": 0 },
        "trust_state_token": { "$ref": "#/$defs/non_empty_string" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "redaction_token": { "$ref": "#/$defs/non_empty_string" },
        "export_inclusion_posture": { "$ref": "#/$defs/export_inclusion_posture" },
        "export_inclusion_posture_token": { "$ref": "#/$defs/non_empty_string" },
        "redaction_safe": { "type": "boolean", "const": true }
      }
    },
    "host_boundary_surface_projection_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "projection_id",
        "truth_record_ref",
        "surface",
        "surface_token",
        "target_ref",
        "action_route_token",
        "route_label",
        "host_boundary_cue_stack_tokens",
        "identity_chips",
        "discovery_source_token",
        "discovery_freshness_token",
        "resolver_confidence_token",
        "authoritative_capability_subset_tokens",
        "wrong_target_correction_token",
        "reapproval_requirement_token",
        "continue_action_enabled",
        "summary",
        "redaction_safe"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "host_boundary_surface_projection_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "projection_id": { "$ref": "#/$defs/non_empty_string" },
        "truth_record_ref": { "$ref": "#/$defs/non_empty_string" },
        "surface": { "$ref": "#/$defs/surface_class" },
        "surface_token": { "$ref": "#/$defs/non_empty_string" },
        "target_ref": { "$ref": "#/$defs/non_empty_string" },
        "action_route_token": { "$ref": "#/$defs/non_empty_string" },
        "route_label": { "$ref": "#/$defs/non_empty_string" },
        "host_boundary_cue_stack_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "identity_chips": { "$ref": "#/$defs/identity_chips" },
        "discovery_source_token": { "$ref": "#/$defs/non_empty_string" },
        "discovery_freshness_token": { "$ref": "#/$defs/non_empty_string" },
        "resolver_confidence_token": { "$ref": "#/$defs/non_empty_string" },
        "authoritative_capability_subset_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "lifecycle_label_token": { "$ref": "#/$defs/non_empty_string" },
        "lifecycle_label": { "$ref": "#/$defs/non_empty_string" },
        "wrong_target_correction_token": { "$ref": "#/$defs/non_empty_string" },
        "reapproval_requirement_token": { "$ref": "#/$defs/non_empty_string" },
        "continue_action_enabled": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/non_empty_string" },
        "redaction_safe": { "type": "boolean", "const": true }
      }
    },
    "host_boundary_drift_field": {
      "type": "string",
      "enum": [
        "target",
        "workspace",
        "action_target_class",
        "action_route_class",
        "host_boundary_cue_stack",
        "managed_lifecycle_state",
        "policy_epoch",
        "authority_linkage_class"
      ]
    },
    "host_boundary_drift_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "field_token", "review_value_token", "commit_value_token"],
      "properties": {
        "field": { "$ref": "#/$defs/host_boundary_drift_field" },
        "field_token": { "$ref": "#/$defs/non_empty_string" },
        "review_value_token": { "$ref": "#/$defs/non_empty_string" },
        "commit_value_token": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "host_boundary_review_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "truth_record_ref",
        "target_ref",
        "workspace_ref",
        "action_target_class",
        "action_route_class",
        "host_boundary_cue_stack",
        "policy_epoch",
        "authority_linkage_class"
      ],
      "properties": {
        "binding_id": { "$ref": "#/$defs/non_empty_string" },
        "truth_record_ref": { "$ref": "#/$defs/non_empty_string" },
        "target_ref": { "$ref": "#/$defs/non_empty_string" },
        "workspace_ref": { "$ref": "#/$defs/non_empty_string" },
        "action_target_class": { "$ref": "#/$defs/action_target_class" },
        "action_route_class": { "$ref": "#/$defs/action_route_class" },
        "host_boundary_cue_stack": {
          "type": "array",
          "items": { "$ref": "#/$defs/host_boundary_cue_class" }
        },
        "managed_lifecycle_state_token": { "$ref": "#/$defs/non_empty_string" },
        "policy_epoch": { "type": "integer", "minimum": 0 },
        "authority_linkage_class": { "$ref": "#/$defs/authority_linkage_class" }
      }
    },
    "host_boundary_reapproval_outcome": {
      "type": "object",
      "oneOf": [
        {
          "additionalProperties": false,
          "required": ["outcome"],
          "properties": {
            "outcome": { "type": "string", "const": "fresh" }
          }
        },
        {
          "additionalProperties": false,
          "required": ["outcome", "drift_rows"],
          "properties": {
            "outcome": { "type": "string", "const": "reapproval_required" },
            "drift_rows": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/host_boundary_drift_row" }
            }
          }
        }
      ]
    },
    "host_boundary_reapproval_evaluation_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "evaluation_id",
        "review_binding",
        "commit_truth_record_ref",
        "outcome",
        "reapproval_requirement_class",
        "reapproval_requirement_token"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "host_boundary_reapproval_evaluation_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "evaluation_id": { "$ref": "#/$defs/non_empty_string" },
        "review_binding": { "$ref": "#/$defs/host_boundary_review_binding" },
        "commit_truth_record_ref": { "$ref": "#/$defs/non_empty_string" },
        "outcome": { "$ref": "#/$defs/host_boundary_reapproval_outcome" },
        "reapproval_requirement_class": { "$ref": "#/$defs/reapproval_requirement_class" },
        "reapproval_requirement_token": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "host_boundary_support_export_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "support_export_id",
        "generated_at",
        "records",
        "support_projections",
        "reapproval_evaluations",
        "any_record_requires_reapproval_or_review",
        "redaction_safe"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "host_boundary_support_export_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "support_export_id": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "$ref": "#/$defs/non_empty_string" },
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/host_boundary_truth_record" }
        },
        "support_projections": {
          "type": "array",
          "items": { "$ref": "#/$defs/host_boundary_surface_projection_record" }
        },
        "reapproval_evaluations": {
          "type": "array",
          "items": { "$ref": "#/$defs/host_boundary_reapproval_evaluation_record" }
        },
        "any_record_requires_reapproval_or_review": { "type": "boolean" },
        "redaction_safe": { "type": "boolean", "const": true }
      }
    }
  }
}
