{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/storage_object_state.schema.json",
  "title": "Aureline browser storage object state record",
  "description": "Boundary schema for storage_object_state_record defined in docs/runtime/browser_inspection_contract.md. A storage object state binds browser-runtime session identity, preview route, preview snapshot, task channel, support bundle, exact-build identity, capture mode, live/imported/cached state, source-map state, storage area, origin/scope, storage-key posture, value posture, mutation admissibility, side-effect risk, redaction, export posture, and policy restrictions. Raw storage keys, raw cookie values, raw localStorage/sessionStorage values, raw IndexedDB records, raw Cache Storage payloads, raw service-worker scripts, raw URLs, raw hostnames, raw tokens, and raw provider data never cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/storage_object_state_record" }
  ],
  "$defs": {
    "storage_object_state_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "storage_object_state_record"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque identifier safe for evidence, support bundles, and export manifests. Raw keys, values, cookies, URLs, hostnames, tokens, and payloads never appear here."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_id" },
        { "type": "null" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 520,
      "description": "Short sentence safe for UI, support, and export review. Raw keys, values, cookies, URLs, hostnames, paths, tokens, and provider data are forbidden."
    },
    "capture_mode_class": {
      "type": "string",
      "enum": [
        "live_runtime_stream",
        "live_runtime_snapshot",
        "imported_browser_handoff",
        "imported_support_bundle",
        "replay_capture",
        "hosted_review_reader",
        "synthetic_fixture",
        "capture_mode_unknown_requires_review"
      ]
    },
    "liveness_class": {
      "type": "string",
      "enum": [
        "live_current",
        "live_drifted",
        "imported_read_only",
        "replayed_read_only",
        "cached_read_only",
        "blocked_inspect_only",
        "unavailable"
      ]
    },
    "evidence_origin_class": {
      "type": "string",
      "enum": [
        "live_capture_from_attached_runtime",
        "imported_from_browser_handoff_packet",
        "imported_from_support_export_bundle",
        "imported_from_replay_capture",
        "imported_from_hosted_review_reader",
        "evidence_origin_unverifiable_user_review_required"
      ]
    },
    "source_map_state_class": {
      "type": "string",
      "enum": [
        "source_map_in_sync_with_runtime",
        "source_map_in_sync_with_session_capture",
        "source_map_stale_runtime_advanced_since_capture",
        "source_map_inline_only_no_external_map",
        "source_map_missing_runtime_only",
        "source_map_redacted_for_export",
        "source_map_freshness_unknown_requires_review"
      ]
    },
    "mapping_fidelity_class": {
      "type": "string",
      "enum": [
        "exact_source_mapping",
        "approximate_source_mapping",
        "generated_only_mapping",
        "framework_only_mapping",
        "runtime_only_mapping",
        "unavailable_mapping",
        "mapping_fidelity_unknown_requires_review"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "headers_and_keys_redacted",
        "values_redacted",
        "payload_bodies_omitted",
        "local_only_sensitive",
        "blocked_sensitive_value",
        "provider_data_restricted"
      ]
    },
    "policy_restriction_class": {
      "type": "string",
      "enum": [
        "no_policy_restriction",
        "export_redacted_only",
        "export_metadata_only",
        "export_forbidden",
        "replay_requires_review",
        "mutation_requires_review",
        "reveal_requires_local_review",
        "blocked_by_policy",
        "blocked_by_workspace_trust",
        "partner_provider_data_do_not_export",
        "inspect_only_runtime_identity_weak"
      ]
    },
    "drift_disclosure_class": {
      "type": "string",
      "enum": [
        "no_drift_disclosure_required",
        "source_map_stale_disclosed",
        "live_dom_css_edit_uncommitted",
        "replayed_network_traffic_disclosed",
        "cached_service_worker_state_disclosed",
        "storage_mutation_side_effect_disclosed",
        "runtime_identity_weak_inspect_only_disclosed",
        "imported_evidence_disclosed",
        "preview_route_drift_disclosed",
        "policy_limited_evidence_disclosed"
      ]
    },
    "storage_area_class": {
      "type": "string",
      "enum": [
        "cookie_store",
        "local_storage",
        "session_storage",
        "indexeddb_database",
        "cache_storage_entry",
        "service_worker_registration",
        "service_worker_cache",
        "partitioned_storage_metadata",
        "storage_area_unknown_requires_review"
      ]
    },
    "origin_scope_class": {
      "type": "string",
      "enum": [
        "same_origin_scope",
        "same_site_partition_scope",
        "cross_origin_partition_scope",
        "opaque_origin_no_storage_mutation",
        "service_worker_scope",
        "origin_scope_unknown_requires_review"
      ]
    },
    "storage_key_class": {
      "type": "string",
      "enum": [
        "review_safe_key_label",
        "named_key_hash_only",
        "cookie_name_hash_only",
        "indexeddb_database_hash_only",
        "cache_request_key_hash_only",
        "service_worker_registration_scope_ref",
        "opaque_storage_bucket_ref",
        "storage_key_redacted",
        "storage_key_unknown_requires_review"
      ]
    },
    "value_presence_class": {
      "type": "string",
      "enum": [
        "present_metadata_only",
        "present_redacted_sensitive",
        "present_hash_only",
        "absent",
        "deleted_tombstone",
        "unknown_requires_review"
      ]
    },
    "value_size_class": {
      "type": "string",
      "enum": [
        "empty",
        "small",
        "medium",
        "large",
        "size_redacted",
        "size_unknown"
      ]
    },
    "storage_mutation_action_class": {
      "type": "string",
      "enum": [
        "clear_cookie_for_origin",
        "clear_local_storage_for_origin",
        "clear_session_storage_for_origin",
        "delete_indexeddb_database",
        "delete_cache_storage_entry",
        "unregister_service_worker",
        "clear_service_worker_cache",
        "no_mutation_inspect_only",
        "mutation_not_applicable"
      ]
    },
    "storage_mutation_admissibility_class": {
      "type": "string",
      "enum": [
        "mutation_admissible_after_review",
        "mutation_admissible_under_approval_ticket",
        "mutation_requires_local_review",
        "mutation_blocked_imported_or_replayed",
        "mutation_blocked_cached_state",
        "mutation_blocked_runtime_identity_weak",
        "mutation_blocked_policy",
        "mutation_not_applicable"
      ]
    },
    "side_effect_risk_class": {
      "type": "string",
      "enum": [
        "no_expected_side_effect",
        "sign_in_state_may_reset",
        "feature_flags_may_reset",
        "offline_cache_may_clear",
        "service_worker_scope_may_change",
        "provider_session_may_reset",
        "side_effect_unknown_requires_review"
      ]
    },
    "key_export_class": {
      "type": "string",
      "enum": [
        "key_export_review_safe_label",
        "key_export_hash_only",
        "key_export_redacted",
        "key_export_forbidden"
      ]
    },
    "value_export_class": {
      "type": "string",
      "enum": [
        "value_export_metadata_only",
        "value_export_hash_only",
        "value_export_local_only_after_review",
        "value_export_forbidden",
        "value_not_present"
      ]
    },
    "cookie_export_class": {
      "type": "string",
      "enum": [
        "not_cookie_storage",
        "cookie_name_hash_only_value_forbidden",
        "cookie_metadata_only_value_forbidden",
        "cookie_export_forbidden"
      ]
    },
    "viewer_linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_route_record_ref",
        "preview_snapshot_record_ref",
        "task_channel_ref",
        "support_bundle_ref",
        "exact_build_identity_ref",
        "evidence_packet_ref"
      ],
      "properties": {
        "preview_route_record_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "preview_snapshot_record_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "task_channel_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "support_bundle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "exact_build_identity_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "evidence_packet_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "hosted_review_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "companion_handoff_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "capture_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capture_mode_class",
        "liveness_class",
        "evidence_origin_class",
        "inspected_at"
      ],
      "properties": {
        "capture_mode_class": { "$ref": "#/$defs/capture_mode_class" },
        "liveness_class": { "$ref": "#/$defs/liveness_class" },
        "evidence_origin_class": { "$ref": "#/$defs/evidence_origin_class" },
        "inspected_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "capture_window_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "source_map_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_map_state_class",
        "mapping_fidelity_class",
        "source_map_handle_ref",
        "summary"
      ],
      "properties": {
        "source_map_state_class": { "$ref": "#/$defs/source_map_state_class" },
        "mapping_fidelity_class": { "$ref": "#/$defs/mapping_fidelity_class" },
        "source_map_handle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "storage_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "storage_area_class",
        "origin_scope_class",
        "origin_label_ref",
        "partition_label_ref"
      ],
      "properties": {
        "storage_area_class": { "$ref": "#/$defs/storage_area_class" },
        "origin_scope_class": { "$ref": "#/$defs/origin_scope_class" },
        "origin_label_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "partition_label_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "service_worker_registration_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "object_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "storage_key_class",
        "storage_key_ref",
        "provider_data_class"
      ],
      "properties": {
        "storage_key_class": { "$ref": "#/$defs/storage_key_class" },
        "storage_key_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "provider_data_class": {
          "type": "string",
          "enum": [
            "not_provider_data",
            "partner_provider_metadata_only",
            "partner_provider_data_restricted"
          ]
        },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "value_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value_presence_class",
        "value_size_class",
        "value_digest_ref",
        "sensitive_value_observed"
      ],
      "properties": {
        "value_presence_class": { "$ref": "#/$defs/value_presence_class" },
        "value_size_class": { "$ref": "#/$defs/value_size_class" },
        "value_digest_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "sensitive_value_observed": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "mutation_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "storage_mutation_action_class",
        "storage_mutation_admissibility_class",
        "side_effect_risk_class",
        "approval_ticket_ref",
        "summary"
      ],
      "properties": {
        "storage_mutation_action_class": { "$ref": "#/$defs/storage_mutation_action_class" },
        "storage_mutation_admissibility_class": { "$ref": "#/$defs/storage_mutation_admissibility_class" },
        "side_effect_risk_class": { "$ref": "#/$defs/side_effect_risk_class" },
        "approval_ticket_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "policy_restriction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_restriction_class",
        "enforced_by_ref",
        "summary"
      ],
      "properties": {
        "policy_restriction_class": { "$ref": "#/$defs/policy_restriction_class" },
        "enforced_by_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redaction_class",
        "raw_key_permitted",
        "raw_value_permitted",
        "raw_cookie_value_permitted",
        "summary"
      ],
      "properties": {
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "raw_key_permitted": { "type": "boolean" },
        "raw_value_permitted": { "type": "boolean" },
        "raw_cookie_value_permitted": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "export_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key_export_class",
        "value_export_class",
        "cookie_export_class",
        "support_bundle_inclusion_class",
        "summary"
      ],
      "properties": {
        "key_export_class": { "$ref": "#/$defs/key_export_class" },
        "value_export_class": { "$ref": "#/$defs/value_export_class" },
        "cookie_export_class": { "$ref": "#/$defs/cookie_export_class" },
        "support_bundle_inclusion_class": {
          "type": "string",
          "enum": [
            "included_redacted_by_default",
            "included_metadata_only",
            "local_only_reference",
            "excluded_by_default",
            "excluded_always"
          ]
        },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "storage_object_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "storage_object_state_schema_version",
        "storage_object_state_id",
        "captured_at",
        "browser_runtime_session_record_ref",
        "viewer_linkage",
        "capture_context",
        "source_map_state",
        "storage_scope",
        "object_identity",
        "value_state",
        "mutation_posture",
        "redaction",
        "policy_restrictions",
        "drift_disclosures",
        "export_review",
        "summary"
      ],
      "properties": {
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "storage_object_state_schema_version": { "$ref": "#/$defs/storage_object_state_schema_version" },
        "storage_object_state_id": { "$ref": "#/$defs/opaque_id" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "browser_runtime_session_record_ref": { "$ref": "#/$defs/opaque_id" },
        "viewer_linkage": { "$ref": "#/$defs/viewer_linkage" },
        "capture_context": { "$ref": "#/$defs/capture_context" },
        "source_map_state": { "$ref": "#/$defs/source_map_state" },
        "storage_scope": { "$ref": "#/$defs/storage_scope" },
        "object_identity": { "$ref": "#/$defs/object_identity" },
        "value_state": { "$ref": "#/$defs/value_state" },
        "mutation_posture": { "$ref": "#/$defs/mutation_posture" },
        "redaction": { "$ref": "#/$defs/redaction" },
        "policy_restrictions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/policy_restriction" }
        },
        "drift_disclosures": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/drift_disclosure_class" },
          "uniqueItems": true
        },
        "export_review": { "$ref": "#/$defs/export_review" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "description": "Imported, replayed, cached, hosted-review, synthetic, and unknown capture modes cannot claim live_current or admissible mutation.",
          "if": {
            "properties": {
              "capture_context": {
                "properties": {
                  "capture_mode_class": {
                    "enum": [
                      "imported_browser_handoff",
                      "imported_support_bundle",
                      "replay_capture",
                      "hosted_review_reader",
                      "synthetic_fixture",
                      "capture_mode_unknown_requires_review"
                    ]
                  }
                },
                "required": ["capture_mode_class"]
              }
            }
          },
          "then": {
            "properties": {
              "capture_context": {
                "properties": {
                  "liveness_class": {
                    "not": { "const": "live_current" }
                  }
                }
              },
              "mutation_posture": {
                "properties": {
                  "storage_mutation_admissibility_class": {
                    "not": {
                      "enum": [
                        "mutation_admissible_after_review",
                        "mutation_admissible_under_approval_ticket"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        {
          "description": "Weak runtime identity policy forces inspect-only mutation and disclosure.",
          "if": {
            "properties": {
              "policy_restrictions": {
                "contains": {
                  "properties": {
                    "policy_restriction_class": { "const": "inspect_only_runtime_identity_weak" }
                  },
                  "required": ["policy_restriction_class"]
                }
              }
            }
          },
          "then": {
            "properties": {
              "mutation_posture": {
                "properties": {
                  "storage_mutation_admissibility_class": {
                    "enum": [
                      "mutation_blocked_runtime_identity_weak",
                      "mutation_not_applicable"
                    ]
                  }
                }
              },
              "drift_disclosures": {
                "contains": { "const": "runtime_identity_weak_inspect_only_disclosed" }
              }
            }
          }
        },
        {
          "description": "Cookie storage forbids raw cookie value export.",
          "if": {
            "properties": {
              "storage_scope": {
                "properties": {
                  "storage_area_class": { "const": "cookie_store" }
                },
                "required": ["storage_area_class"]
              }
            }
          },
          "then": {
            "properties": {
              "redaction": {
                "properties": {
                  "raw_cookie_value_permitted": { "const": false }
                }
              },
              "export_review": {
                "properties": {
                  "cookie_export_class": {
                    "enum": [
                      "cookie_name_hash_only_value_forbidden",
                      "cookie_metadata_only_value_forbidden",
                      "cookie_export_forbidden"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "description": "Sensitive values cannot export raw keys, values, or cookie values.",
          "if": {
            "properties": {
              "value_state": {
                "properties": {
                  "sensitive_value_observed": { "const": true }
                },
                "required": ["sensitive_value_observed"]
              }
            }
          },
          "then": {
            "properties": {
              "redaction": {
                "properties": {
                  "raw_value_permitted": { "const": false },
                  "raw_cookie_value_permitted": { "const": false }
                }
              },
              "export_review": {
                "properties": {
                  "value_export_class": {
                    "enum": [
                      "value_export_metadata_only",
                      "value_export_hash_only",
                      "value_export_local_only_after_review",
                      "value_export_forbidden"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "description": "Service-worker storage mutations require service-worker disclosure and cannot be silently exported as ordinary storage.",
          "if": {
            "properties": {
              "storage_scope": {
                "properties": {
                  "storage_area_class": {
                    "enum": [
                      "service_worker_registration",
                      "service_worker_cache"
                    ]
                  }
                },
                "required": ["storage_area_class"]
              }
            }
          },
          "then": {
            "properties": {
              "drift_disclosures": {
                "contains": { "const": "cached_service_worker_state_disclosed" }
              }
            }
          }
        }
      ]
    }
  }
}
