{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/harden_coverage_flaky_test_snapshot_golden_and_baseline_truth.schema.json",
  "title": "Aureline harden coverage / flaky-test / snapshot-golden / baseline-truth packet",
  "description": "Boundary schema for the stable coverage / flaky-test / snapshot-golden / baseline-truth packet certifying the coverage, flaky_test, snapshot_golden, and baseline_truth lanes at the M4 launch-stable grade. Every launch_stable lane MUST publish a coverage_flaky_snapshot_baseline_quality row plus the full four-wedge admission coverage (stability_verdict_separation, quarantine_mute_renewal_truth, ai_candidate_source_attribution, coverage_impact_truth), the full six stability-verdict admissions (stable, flaky, failing, quarantined, muted, unknown), the full four quarantine-mute-state admissions (active, expiring_soon, expired_pending_renewal, removed), the full four test-source admissions (human_authored, candidate_ai_test, automated_baseline, imported_ci_evidence) each binding the required session/attempt + review-checkpoint lineage for candidate / automated / imported sources, the full four coverage-impact admissions (measured, estimated, stale, not_comparable), the full three candidate-lineage admissions (session_attempt_bound, review_checkpoint_bound, imported_ci_bound), the full five consumer-surface bindings (coverage_surface, flaky_triage_surface, snapshot_golden_surface, baseline_surface, release_packet_surface) each attesting the stability-verdict, quarantine-mute-state, test-source, coverage-impact, and candidate-lineage vocabularies it is required to preserve, and a lineage_admission row binding execution_context_id. The packet is the single truth that the coverage surface, flaky-triage surface, snapshot/golden surface, baseline surface, release packet surface, AI tool surface, CLI/headless inspector, evidence export, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies, hide muted / quarantined tests, or silently promote candidate AI tests into trusted coverage proof.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "harden_coverage_flaky_test_snapshot_golden_and_baseline_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/coverage_quality_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/coverage_quality_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 12,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "coverage_quality_lane_class": {
      "enum": [
        "coverage_lane",
        "flaky_test_lane",
        "snapshot_golden_lane",
        "baseline_truth_lane"
      ]
    },
    "coverage_quality_row_class": {
      "enum": [
        "coverage_flaky_snapshot_baseline_quality",
        "wedge_admission",
        "stability_verdict_admission",
        "quarantine_mute_state_admission",
        "test_source_admission",
        "coverage_impact_admission",
        "candidate_lineage_admission",
        "consumer_surface_binding",
        "lineage_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "wedge_class": {
      "enum": [
        "stability_verdict_separation",
        "quarantine_mute_renewal_truth",
        "ai_candidate_source_attribution",
        "coverage_impact_truth",
        "not_applicable"
      ]
    },
    "stability_verdict_class": {
      "enum": [
        "stable",
        "flaky",
        "failing",
        "quarantined",
        "muted",
        "unknown",
        "not_applicable"
      ]
    },
    "quarantine_mute_state_class": {
      "enum": [
        "active",
        "expiring_soon",
        "expired_pending_renewal",
        "removed",
        "not_applicable"
      ]
    },
    "test_source_class": {
      "enum": [
        "human_authored",
        "candidate_ai_test",
        "automated_baseline",
        "imported_ci_evidence",
        "not_applicable"
      ]
    },
    "coverage_impact_class": {
      "enum": [
        "measured",
        "estimated",
        "stale",
        "not_comparable",
        "not_applicable"
      ]
    },
    "candidate_lineage_class": {
      "enum": [
        "session_attempt_bound",
        "review_checkpoint_bound",
        "imported_ci_bound",
        "not_applicable"
      ]
    },
    "consumer_surface_class": {
      "enum": [
        "coverage_surface",
        "flaky_triage_surface",
        "snapshot_golden_surface",
        "baseline_surface",
        "release_packet_surface",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "coverage_lane_subset_only",
        "flaky_test_lane_subset_only",
        "snapshot_golden_lane_subset_only",
        "baseline_truth_lane_subset_only",
        "wedge_admission_subset_only",
        "stability_verdict_subset_only",
        "quarantine_mute_state_subset_only",
        "test_source_subset_only",
        "coverage_impact_subset_only",
        "candidate_lineage_subset_only",
        "consumer_surface_subset_only",
        "stability_verdict_attestation_skew_declared",
        "quarantine_mute_attestation_skew_declared",
        "test_source_attestation_skew_declared",
        "coverage_impact_attestation_skew_declared",
        "candidate_lineage_attestation_skew_declared",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_wedge_admission_gap",
        "auto_narrow_on_stability_verdict_gap",
        "auto_narrow_on_quarantine_mute_state_gap",
        "auto_narrow_on_test_source_gap",
        "auto_narrow_on_coverage_impact_gap",
        "auto_narrow_on_candidate_lineage_gap",
        "auto_narrow_on_consumer_surface_gap",
        "auto_narrow_on_stability_verdict_attestation_gap",
        "auto_narrow_on_quarantine_mute_attestation_gap",
        "auto_narrow_on_test_source_attestation_gap",
        "auto_narrow_on_coverage_impact_attestation_gap",
        "auto_narrow_on_candidate_lineage_attestation_gap",
        "auto_narrow_on_lineage_break",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": {
      "enum": ["info", "warning", "blocker"]
    },
    "consumer_surface": {
      "enum": [
        "coverage_surface",
        "flaky_triage_surface",
        "snapshot_golden_surface",
        "baseline_surface",
        "release_packet_surface",
        "ai_tool_surface",
        "cli_headless",
        "evidence_export",
        "support_export",
        "release_proof_index",
        "help_about",
        "conformance_dashboard"
      ]
    },
    "coverage_quality_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "wedge_class",
        "stability_verdict_class",
        "quarantine_mute_state_class",
        "test_source_class",
        "coverage_impact_class",
        "candidate_lineage_class",
        "consumer_surface_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/coverage_quality_lane_class" },
        "row_class": { "$ref": "#/$defs/coverage_quality_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "wedge_class": { "$ref": "#/$defs/wedge_class" },
        "stability_verdict_class": { "$ref": "#/$defs/stability_verdict_class" },
        "quarantine_mute_state_class": { "$ref": "#/$defs/quarantine_mute_state_class" },
        "test_source_class": { "$ref": "#/$defs/test_source_class" },
        "coverage_impact_class": { "$ref": "#/$defs/coverage_impact_class" },
        "candidate_lineage_class": { "$ref": "#/$defs/candidate_lineage_class" },
        "consumer_surface_class": { "$ref": "#/$defs/consumer_surface_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_id_binding": { "$ref": "#/$defs/non_empty_string" },
        "attests_candidate_lineage_bound": { "type": "boolean" },
        "attests_stability_verdict_preserved": { "type": "boolean" },
        "attests_quarantine_mute_state_preserved": { "type": "boolean" },
        "attests_test_source_preserved": { "type": "boolean" },
        "attests_coverage_impact_preserved": { "type": "boolean" },
        "attests_candidate_lineage_preserved": { "type": "boolean" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "coverage_quality_truth_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_wedge_vocabulary",
        "preserves_stability_verdict_vocabulary",
        "preserves_quarantine_mute_state_vocabulary",
        "preserves_test_source_vocabulary",
        "preserves_coverage_impact_vocabulary",
        "preserves_candidate_lineage_vocabulary",
        "preserves_consumer_surface_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "coverage_quality_truth_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_wedge_vocabulary": { "type": "boolean" },
        "preserves_stability_verdict_vocabulary": { "type": "boolean" },
        "preserves_quarantine_mute_state_vocabulary": { "type": "boolean" },
        "preserves_test_source_vocabulary": { "type": "boolean" },
        "preserves_coverage_impact_vocabulary": { "type": "boolean" },
        "preserves_candidate_lineage_vocabulary": { "type": "boolean" },
        "preserves_consumer_surface_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
