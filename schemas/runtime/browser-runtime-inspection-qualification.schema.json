{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/browser-runtime-inspection-qualification.schema.json",
  "title": "Aureline browser-runtime inspection qualification packet",
  "description": "Boundary schema for the browser-runtime inspection qualification packet. The packet proves browser-runtime target kind, origin scope, attach/protocol state, session freshness, source-map quality, object-class separation, console/network/storage state vocabulary, redaction defaults, mutation review lineage, downgrade rules, and consumer-surface bindings before any stable browser-runtime inspection surface can claim DOM/CSS/network/storage depth.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "rows",
    "source_contract_refs",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": {
      "const": "browser_runtime_inspection_qualification_packet"
    },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/qualification_row" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "target_kind": {
      "enum": [
        "embedded_preview",
        "external_browser_tab",
        "simulator_webview",
        "device_browser",
        "device_webview",
        "remote_preview_session",
        "captured_snapshot",
        "not_applicable"
      ]
    },
    "row_class": {
      "enum": [
        "target_kind_admission",
        "object_class_admission",
        "source_map_quality_admission",
        "inspection_state_admission",
        "mutation_action_review",
        "consumer_surface_binding",
        "downgrade_rule"
      ]
    },
    "support_class": {
      "enum": [
        "stable",
        "downgraded_below_stable",
        "inspect_only",
        "handoff_only",
        "blocked",
        "unbound"
      ]
    },
    "attach_protocol_state": {
      "enum": [
        "attached_live",
        "attach_required",
        "protocol_unavailable",
        "cross_origin_limited",
        "external_browser_only",
        "snapshot_only",
        "not_applicable"
      ]
    },
    "session_freshness_state": {
      "enum": [
        "live",
        "recent",
        "stale_requires_resync",
        "captured_snapshot",
        "unknown",
        "not_applicable"
      ]
    },
    "source_map_quality": {
      "enum": [
        "exact",
        "approximate",
        "framework_only",
        "runtime_only",
        "stale",
        "unavailable",
        "not_applicable"
      ]
    },
    "runtime_object_class": {
      "enum": [
        "dom_node",
        "framework_component",
        "source_file_symbol",
        "cross_origin_frame",
        "not_applicable"
      ]
    },
    "inspection_data_state": {
      "enum": [
        "data_available",
        "no_data",
        "cross_origin_limited",
        "protocol_unavailable",
        "attach_required",
        "external_browser_only",
        "not_applicable"
      ]
    },
    "mutation_action": {
      "enum": [
        "clear_storage",
        "cookie_override",
        "replay_request",
        "live_style_edit",
        "force_reload",
        "protocol_override",
        "not_applicable"
      ]
    },
    "consumer_surface": {
      "enum": [
        "product_surface_label",
        "docs_help",
        "support_export",
        "release_packet",
        "optional_surface_manifest",
        "not_applicable"
      ]
    },
    "downgrade_rule": {
      "enum": [
        "none",
        "target_identity_missing",
        "source_map_insufficient",
        "protocol_unavailable",
        "cross_origin_limited",
        "session_stale",
        "mutation_safety_missing",
        "redaction_unsafe",
        "consumer_surface_missing",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "fixture_evidence",
        "automated_functional_evidence",
        "design_accessibility_evidence",
        "security_privacy_evidence",
        "failure_recovery_drill_evidence",
        "release_evidence_review",
        "unbound"
      ]
    },
    "qualification_row": {
      "type": "object",
      "required": [
        "row_id",
        "row_class",
        "support_class",
        "target_kind",
        "attach_protocol_state",
        "session_freshness_state",
        "source_map_quality",
        "runtime_object_class",
        "inspection_data_state",
        "mutation_action",
        "consumer_surface",
        "downgrade_rule",
        "evidence_class",
        "evidence_refs",
        "target_identity_bound",
        "origin_scope_bound",
        "protocol_state_bound",
        "session_freshness_bound",
        "drift_resync_bound",
        "preview_runtime_separation_preserved",
        "object_class_distinction_preserved",
        "inspection_state_distinction_preserved",
        "target_identity_preserved_for_action",
        "redaction_safe_export",
        "hidden_side_effects_excluded",
        "consumes_packet_verbatim",
        "avoids_devtools_overclaim",
        "optional_labels_downgraded",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "row_class": { "$ref": "#/$defs/row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "target_kind": { "$ref": "#/$defs/target_kind" },
        "attach_protocol_state": { "$ref": "#/$defs/attach_protocol_state" },
        "session_freshness_state": { "$ref": "#/$defs/session_freshness_state" },
        "source_map_quality": { "$ref": "#/$defs/source_map_quality" },
        "runtime_object_class": { "$ref": "#/$defs/runtime_object_class" },
        "inspection_data_state": { "$ref": "#/$defs/inspection_data_state" },
        "mutation_action": { "$ref": "#/$defs/mutation_action" },
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "downgrade_rule": { "$ref": "#/$defs/downgrade_rule" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "type": ["string", "null"] },
        "approval_review_ref": { "type": ["string", "null"] },
        "rollback_or_export_ref": { "type": ["string", "null"] },
        "target_identity_bound": { "type": "boolean" },
        "origin_scope_bound": { "type": "boolean" },
        "protocol_state_bound": { "type": "boolean" },
        "session_freshness_bound": { "type": "boolean" },
        "drift_resync_bound": { "type": "boolean" },
        "preview_runtime_separation_preserved": { "type": "boolean" },
        "object_class_distinction_preserved": { "type": "boolean" },
        "inspection_state_distinction_preserved": { "type": "boolean" },
        "target_identity_preserved_for_action": { "type": "boolean" },
        "redaction_safe_export": { "type": "boolean" },
        "hidden_side_effects_excluded": { "type": "boolean" },
        "consumes_packet_verbatim": { "type": "boolean" },
        "avoids_devtools_overclaim": { "type": "boolean" },
        "optional_labels_downgraded": { "type": "boolean" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["severity", "finding_kind", "summary"],
      "properties": {
        "severity": { "enum": ["info", "warning", "blocker"] },
        "finding_kind": { "$ref": "#/$defs/non_empty_string" },
        "row_id": { "type": ["string", "null"] },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
