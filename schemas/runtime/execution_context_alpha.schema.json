{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/execution_context_alpha.schema.json",
  "title": "Aureline execution-context alpha export",
  "description": "Export schema for the alpha runtime object emitted by the shared execution-context resolver. The record keeps target, toolchain, scope, policy, trust, prebuild, mixed-version, and resolver-precedence explanations on one object for terminal, task, test, debug-prep, and AI-tool entry points. Raw environment bodies, raw command lines, and raw secrets are out of scope; records carry ids, class tokens, hashes, and structured reason codes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "execution_context_id",
    "invocation_subject",
    "target_identity",
    "target_confidence",
    "toolchain_identity",
    "environment_capsule_ref",
    "prebuild_metadata",
    "policy_and_trust",
    "workset_scope_class",
    "cache_disposition",
    "mixed_version_drift",
    "provenance",
    "reusable_surfaces",
    "explanations",
    "degraded_fields"
  ],
  "properties": {
    "record_kind": { "const": "execution_context_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "execution_context_id": { "type": "string", "minLength": 1 },
    "invocation_subject": { "$ref": "#/$defs/invocation_subject" },
    "target_identity": { "$ref": "#/$defs/target_identity" },
    "target_confidence": { "$ref": "#/$defs/target_confidence" },
    "toolchain_identity": { "$ref": "#/$defs/toolchain_identity" },
    "environment_capsule_ref": { "$ref": "#/$defs/environment_capsule_ref" },
    "prebuild_metadata": { "$ref": "#/$defs/prebuild_metadata" },
    "policy_and_trust": { "$ref": "#/$defs/policy_and_trust" },
    "workset_scope_class": { "$ref": "#/$defs/scope_class" },
    "cache_disposition": { "$ref": "#/$defs/cache_disposition" },
    "mixed_version_drift": { "$ref": "#/$defs/mixed_version_drift" },
    "provenance": { "$ref": "#/$defs/provenance" },
    "reusable_surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_class" },
      "minItems": 1
    },
    "explanations": {
      "type": "array",
      "items": { "$ref": "#/$defs/explanation" },
      "minItems": 1
    },
    "node_toolchain_detection": { "type": "object" },
    "python_environment_detection": { "type": "object" },
    "degraded_fields": {
      "type": "array",
      "items": { "$ref": "#/$defs/degraded_field" }
    }
  },
  "$defs": {
    "surface_class": {
      "type": "string",
      "enum": [
        "terminal",
        "task",
        "debug",
        "test",
        "notebook_kernel",
        "scaffolding",
        "ai_tool_call",
        "doctor_repair",
        "import_probe",
        "replay_probe"
      ]
    },
    "actor_class": {
      "type": "string",
      "enum": [
        "user_keystroke",
        "user_command",
        "session_override",
        "workspace_migration",
        "extension_api",
        "ai_apply",
        "scheduled_task",
        "imported_profile",
        "admin_policy_injector"
      ]
    },
    "target_class": {
      "type": "string",
      "enum": [
        "local_host",
        "ssh_remote",
        "container_local",
        "devcontainer",
        "remote_workspace_vm",
        "prebuild_runtime",
        "managed_workspace",
        "notebook_kernel_local",
        "notebook_kernel_remote",
        "ai_sandbox"
      ]
    },
    "reachability_state": {
      "type": "string",
      "enum": ["reachable", "warming", "degraded", "unreachable", "policy_blocked"]
    },
    "toolchain_class": {
      "type": "string",
      "enum": [
        "interpreter",
        "compiler_toolchain",
        "package_manager_runner",
        "containerised_runtime",
        "notebook_kernel_runtime",
        "language_server_process",
        "debug_adapter_runtime",
        "test_runner_runtime",
        "build_driver_runtime",
        "ai_tool_runtime",
        "login_shell"
      ]
    },
    "activation_strategy": {
      "type": "string",
      "enum": [
        "ambient_path",
        "env_manager_shim",
        "venv_activation",
        "nix_shell",
        "nix_flake",
        "direnv",
        "devcontainer_build",
        "oci_image_ref",
        "explicit_override",
        "fallback_resolution"
      ]
    },
    "confidence_level": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "target_confidence_reason": {
      "type": "string",
      "enum": [
        "exact_local_target",
        "surface_requested_target",
        "explicit_target_override",
        "workspace_default_target",
        "resolver_fallback_target",
        "conflicting_target_sources",
        "remote_or_managed_boundary",
        "trust_pending",
        "trust_restricted",
        "policy_blocked_reachability",
        "capsule_drift",
        "prebuild_runtime",
        "mixed_version_unchecked"
      ]
    },
    "capsule_drift_state": {
      "type": "string",
      "enum": [
        "in_sync",
        "stale_inputs",
        "generator_changed",
        "manually_diverged",
        "unknown_lineage"
      ]
    },
    "trust_state": {
      "type": "string",
      "enum": ["trusted", "restricted", "pending_evaluation"]
    },
    "identity_mode": {
      "type": "string",
      "enum": ["account_free_local", "self_hosted_org", "managed_convenience"]
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "current_root",
        "named_workset",
        "sparse_slice",
        "full_workspace",
        "policy_limited_view",
        "review_workspace",
        "companion_surface"
      ]
    },
    "cache_disposition": {
      "type": "string",
      "enum": [
        "cold",
        "warm",
        "prebuild_reused",
        "capsule_reused",
        "rejected_drift",
        "rejected_policy",
        "rejected_trust"
      ]
    },
    "prebuild_reuse_state": {
      "type": "string",
      "enum": [
        "not_applicable",
        "candidate",
        "reused",
        "rejected_drift",
        "rejected_policy",
        "rejected_trust"
      ]
    },
    "prebuild_invalidation_reason": {
      "type": "string",
      "enum": [
        "capsule_drift",
        "policy_epoch_advanced",
        "trust_state_restricted",
        "trust_state_pending",
        "target_class_changed"
      ]
    },
    "mixed_version_drift_state": {
      "type": "string",
      "enum": ["not_applicable", "aligned", "not_negotiated", "drift_detected"]
    },
    "mixed_version_reason": {
      "type": "string",
      "enum": [
        "local_only",
        "helper_boundary_not_negotiated",
        "protocols_aligned",
        "protocol_skew_detected"
      ]
    },
    "resolver_input_field": {
      "type": "string",
      "enum": ["target_class", "working_directory", "toolchain_class"]
    },
    "resolver_input_source": {
      "type": "string",
      "enum": [
        "explicit_override",
        "surface_requested",
        "workspace_default",
        "resolver_fallback"
      ]
    },
    "effect_class": {
      "type": "string",
      "enum": [
        "selected_by_precedence",
        "conflict_resolved",
        "target_boundary_visible",
        "target_boundary_local",
        "policy_allowed",
        "policy_narrowed",
        "policy_blocked",
        "trust_accepted",
        "trust_pending",
        "trust_restricted",
        "scope_selected",
        "prebuild_not_applicable",
        "prebuild_reused",
        "prebuild_rejected",
        "mixed_version_not_applicable",
        "mixed_version_unchecked",
        "reusable_across_surfaces"
      ]
    },
    "reason_code": {
      "type": "string",
      "enum": [
        "explicit_override_won",
        "surface_request_won",
        "workspace_default_won",
        "resolver_fallback_used",
        "lower_precedence_conflict",
        "local_target_no_boundary",
        "remote_or_managed_boundary",
        "policy_epoch_current",
        "policy_narrowed_by_trust",
        "policy_blocked_target_reachability",
        "trust_state_trusted",
        "trust_state_restricted",
        "trust_state_pending_evaluation",
        "workspace_scope_default",
        "prebuild_target_not_selected",
        "prebuild_snapshot_compatible",
        "prebuild_rejected_by_capsule_drift",
        "prebuild_rejected_by_trust",
        "local_only_no_helper_version",
        "helper_boundary_not_negotiated",
        "shared_context_contract"
      ]
    },
    "reason_source": {
      "type": "string",
      "enum": [
        "resolver",
        "explicit_override",
        "surface_request",
        "workspace_authority",
        "policy_authority",
        "trust_authority",
        "environment_capsule",
        "helper_boundary"
      ]
    },
    "degraded_reason": {
      "type": "string",
      "enum": [
        "toolchain_fallback",
        "activator_blocked_by_trust",
        "activator_blocked_by_policy",
        "activator_unsupported_on_target",
        "capsule_unresolved",
        "capsule_drift_detected",
        "target_unreachable",
        "policy_epoch_stale",
        "trust_state_unresolved",
        "workset_member_unavailable",
        "provenance_gap",
        "confidence_low",
        "remote_agent_scope_mismatch"
      ]
    },
    "invocation_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_id", "surface", "actor_class", "workspace_id"],
      "properties": {
        "command_id": { "type": "string", "minLength": 1 },
        "surface": { "$ref": "#/$defs/surface_class" },
        "actor_class": { "$ref": "#/$defs/actor_class" },
        "workspace_id": { "type": "string", "minLength": 1 },
        "profile_id": { "type": "string", "minLength": 1 }
      }
    },
    "target_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_class",
        "canonical_target_id",
        "reachability_state",
        "local_vs_managed_boundary_visible"
      ],
      "properties": {
        "target_class": { "$ref": "#/$defs/target_class" },
        "canonical_target_id": { "type": "string", "minLength": 1 },
        "working_directory": { "type": "string", "minLength": 1 },
        "reachability_state": { "$ref": "#/$defs/reachability_state" },
        "local_vs_managed_boundary_visible": { "type": "boolean" }
      }
    },
    "target_confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "reasons"],
      "properties": {
        "level": { "$ref": "#/$defs/confidence_level" },
        "reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/target_confidence_reason" },
          "minItems": 1
        }
      }
    },
    "toolchain_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "toolchain_class",
        "toolchain_id",
        "resolved_version",
        "activation_strategy",
        "degraded_fallback_flag"
      ],
      "properties": {
        "toolchain_class": { "$ref": "#/$defs/toolchain_class" },
        "toolchain_id": { "type": "string", "minLength": 1 },
        "resolved_version": { "type": "string", "minLength": 1 },
        "activation_strategy": { "$ref": "#/$defs/activation_strategy" },
        "degraded_fallback_flag": { "type": "boolean" }
      }
    },
    "environment_capsule_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capsule_id",
        "capsule_hash",
        "resolved_schema_version",
        "drift_state"
      ],
      "properties": {
        "capsule_id": { "type": "string", "minLength": 1 },
        "capsule_hash": { "type": "string", "minLength": 1 },
        "resolved_schema_version": { "type": "string", "minLength": 1 },
        "drift_state": { "$ref": "#/$defs/capsule_drift_state" }
      }
    },
    "prebuild_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reuse_state", "compatibility_fingerprint"],
      "properties": {
        "reuse_state": { "$ref": "#/$defs/prebuild_reuse_state" },
        "snapshot_ref": { "type": "string", "minLength": 1 },
        "compatibility_fingerprint": { "type": "string", "minLength": 1 },
        "invalidation_reason": { "$ref": "#/$defs/prebuild_invalidation_reason" }
      }
    },
    "policy_and_trust": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trust_state", "identity_mode", "policy_epoch"],
      "properties": {
        "trust_state": { "$ref": "#/$defs/trust_state" },
        "identity_mode": { "$ref": "#/$defs/identity_mode" },
        "policy_epoch": { "type": "integer", "minimum": 0 }
      }
    },
    "mixed_version_drift": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "client_protocol", "reason"],
      "properties": {
        "state": { "$ref": "#/$defs/mixed_version_drift_state" },
        "client_protocol": { "type": "string", "minLength": 1 },
        "helper_protocol": { "type": "string", "minLength": 1 },
        "reason": { "$ref": "#/$defs/mixed_version_reason" }
      }
    },
    "input_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "winning_source", "resolved_value_token"],
      "properties": {
        "field": { "$ref": "#/$defs/resolver_input_field" },
        "winning_source": { "$ref": "#/$defs/resolver_input_source" },
        "conflicting_sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/resolver_input_source" }
        },
        "resolved_value_token": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provenance_record_id",
        "recorded_at",
        "resolver_version",
        "confidence_level",
        "input_decisions"
      ],
      "properties": {
        "provenance_record_id": { "type": "string", "minLength": 1 },
        "recorded_at": { "type": "string", "minLength": 1 },
        "resolver_version": { "type": "string", "minLength": 1 },
        "confidence_level": { "$ref": "#/$defs/confidence_level" },
        "input_decisions": {
          "type": "array",
          "items": { "$ref": "#/$defs/input_decision" },
          "minItems": 1
        }
      }
    },
    "explanation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_path",
        "effect",
        "reason_code",
        "source",
        "resolved_value_token",
        "applicable_surfaces"
      ],
      "properties": {
        "field_path": { "type": "string", "minLength": 1 },
        "effect": { "$ref": "#/$defs/effect_class" },
        "reason_code": { "$ref": "#/$defs/reason_code" },
        "source": { "$ref": "#/$defs/reason_source" },
        "resolved_value_token": { "type": "string" },
        "related_input_sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/resolver_input_source" }
        },
        "applicable_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_class" },
          "minItems": 1
        }
      }
    },
    "degraded_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_path", "reason"],
      "properties": {
        "field_path": { "type": "string", "minLength": 1 },
        "reason": { "$ref": "#/$defs/degraded_reason" },
        "repair_hook_ref": { "type": "string", "minLength": 1 }
      }
    }
  }
}
