{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/lockfile_impact_alpha.schema.json",
  "title": "Aureline lockfile-impact alpha record",
  "description": "Boundary schema for lockfile_impact_alpha_record payloads used by package-mutation review. The record preserves resolver identity/version, affected lockfiles, transitive impact, regenerate-versus-edit mode, and operation audit lineage. Raw lockfile bodies and package-manager logs never appear.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "lockfile_impact_id",
    "resolver_identity",
    "affected_lockfiles",
    "lockfile_impact_class",
    "lockfile_impact_token",
    "mutation_mode",
    "mutation_mode_token",
    "added_entry_count_bucket",
    "updated_entry_count_bucket",
    "removed_entry_count_bucket",
    "transitive_impact_class",
    "transitive_impact_token",
    "transitive_added_count_bucket",
    "transitive_removed_count_bucket",
    "transitive_major_boundary_count_bucket",
    "transitive_conflict_count_bucket",
    "generated_artifact_posture_token",
    "disclosure"
  ],
  "properties": {
    "record_kind": { "const": "lockfile_impact_alpha_record" },
    "schema_version": { "const": 1 },
    "lockfile_impact_id": { "$ref": "#/$defs/non_empty_string" },
    "resolver_identity": { "$ref": "#/$defs/package_resolver_identity" },
    "affected_lockfiles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://aureline.dev/schemas/runtime/manifest_scope_alpha.schema.json#/$defs/lockfile_alpha_ref" }
    },
    "lockfile_impact_class": { "$ref": "#/$defs/lockfile_impact_class" },
    "lockfile_impact_token": { "$ref": "#/$defs/lockfile_impact_class" },
    "mutation_mode": { "$ref": "#/$defs/lockfile_mutation_mode" },
    "mutation_mode_token": { "$ref": "#/$defs/lockfile_mutation_mode" },
    "prior_lockfile_snapshot_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
    "proposed_lockfile_snapshot_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
    "lockfile_checkpoint_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
    "added_entry_count_bucket": { "type": "integer", "minimum": 0 },
    "updated_entry_count_bucket": { "type": "integer", "minimum": 0 },
    "removed_entry_count_bucket": { "type": "integer", "minimum": 0 },
    "transitive_impact_class": { "$ref": "#/$defs/transitive_impact_class" },
    "transitive_impact_token": { "$ref": "#/$defs/transitive_impact_class" },
    "transitive_added_count_bucket": { "type": "integer", "minimum": 0 },
    "transitive_removed_count_bucket": { "type": "integer", "minimum": 0 },
    "transitive_major_boundary_count_bucket": { "type": "integer", "minimum": 0 },
    "transitive_conflict_count_bucket": { "type": "integer", "minimum": 0 },
    "generated_artifact_posture_token": { "$ref": "#/$defs/non_empty_string" },
    "operation_audit_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "disclosure": { "$ref": "#/$defs/reviewable_sentence" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "nullable_non_empty_string": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/non_empty_string" }]
    },
    "reviewable_sentence": { "type": "string", "minLength": 1 },
    "package_manager_family": {
      "type": "string",
      "enum": ["npm", "pnpm", "package_manager_unknown_requires_review"]
    },
    "package_resolver_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolver_identity_ref",
        "package_manager_family",
        "package_manager_family_token",
        "resolver_version",
        "detector_version"
      ],
      "properties": {
        "resolver_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "package_manager_family": { "$ref": "#/$defs/package_manager_family" },
        "package_manager_family_token": { "$ref": "#/$defs/package_manager_family" },
        "resolver_version": { "$ref": "#/$defs/non_empty_string" },
        "detector_version": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "lockfile_impact_class": {
      "type": "string",
      "enum": [
        "no_lockfile_change_metadata_only",
        "new_lockfile_entries_added",
        "existing_lockfile_entries_updated",
        "lockfile_entries_removed",
        "lockfile_resolver_strategy_changed",
        "lockfile_format_migration",
        "lockfile_locked_unchanged_pinned_query_only",
        "lockfile_absent_will_be_created",
        "lockfile_impact_unknown_requires_review"
      ]
    },
    "lockfile_mutation_mode": {
      "type": "string",
      "enum": [
        "inline_edit_round_trip_safe",
        "regenerate_and_review",
        "compare_only_inspect",
        "blocked_unknown_requires_review"
      ]
    },
    "transitive_impact_class": {
      "type": "string",
      "enum": [
        "no_transitive_change",
        "transitive_added_within_minor_floor",
        "transitive_added_across_major_boundary",
        "transitive_removed",
        "transitive_pinned_pattern_changed",
        "transitive_resolver_conflict_user_review_required",
        "transitive_circular_dependency_detected",
        "transitive_impact_unknown_requires_review"
      ]
    }
  }
}
