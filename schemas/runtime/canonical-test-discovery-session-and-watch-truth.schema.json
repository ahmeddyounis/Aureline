{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aureline.dev/runtime/canonical-test-discovery-session-and-watch-truth.schema.json",
  "title": "Canonical test discovery, session, watch, quarantine, and imported-CI truth packet",
  "description": "Stable runtime boundary packet for durable test discovery identities, append-only session/attempt/watch truth, quarantine governance, triage, and imported-CI parity. The packet is metadata-only and must not rely on display labels as durable ids or let imported CI masquerade as current local runs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "stable_proof_index_refs",
    "discovery_snapshot_ref",
    "discovery_records",
    "session_plans",
    "attempts",
    "stability_verdicts",
    "quarantine_records",
    "triage_packets",
    "watch_states",
    "imported_ci_parity",
    "state_counts",
    "support_export_refs"
  ],
  "properties": {
    "record_kind": { "const": "canonical_test_discovery_session_and_watch_truth_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "stable_proof_index_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "discovery_snapshot_ref": { "$ref": "#/$defs/non_empty_string" },
    "discovery_records": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/discovery_record" }
    },
    "session_plans": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/session_plan" }
    },
    "attempts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/attempt" }
    },
    "stability_verdicts": {
      "type": "array",
      "items": { "$ref": "#/$defs/stability_verdict" }
    },
    "quarantine_records": {
      "type": "array",
      "items": { "$ref": "#/$defs/quarantine_record" }
    },
    "triage_packets": {
      "type": "array",
      "items": { "$ref": "#/$defs/triage_packet" }
    },
    "watch_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/watch_state" }
    },
    "imported_ci_parity": {
      "type": "array",
      "items": { "$ref": "#/$defs/imported_ci_parity" }
    },
    "state_counts": { "$ref": "#/$defs/state_counts" },
    "support_export_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "discovery_item_class": {
      "enum": [
        "suite_container",
        "concrete_case",
        "parameterized_template",
        "parameterized_invocation",
        "notebook_interactive",
        "partial_discovery"
      ]
    },
    "durable_identity_source_class": {
      "enum": [
        "adapter_stable_id",
        "framework_node_id",
        "notebook_cell_object_id",
        "imported_provider_stable_id"
      ]
    },
    "support_class": {
      "enum": ["live", "reduced", "polling", "unavailable"]
    },
    "omitted_scope_reason": {
      "enum": [
        "expands_at_runtime",
        "target_unavailable",
        "notebook_run_disabled",
        "imported_artifact_partial",
        "policy_blocked"
      ]
    },
    "discovery_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "discovery_record_id",
        "item_class",
        "item_class_token",
        "durable_test_id",
        "durable_identity_source_class",
        "durable_identity_source_token",
        "source_anchor_ref",
        "support_class",
        "support_class_token",
        "omitted_scope_reasons",
        "omitted_scope_reason_tokens",
        "export_safe_identity"
      ],
      "properties": {
        "discovery_record_id": { "$ref": "#/$defs/non_empty_string" },
        "item_class": { "$ref": "#/$defs/discovery_item_class" },
        "item_class_token": { "$ref": "#/$defs/discovery_item_class" },
        "durable_test_id": { "$ref": "#/$defs/non_empty_string" },
        "durable_identity_source_class": { "$ref": "#/$defs/durable_identity_source_class" },
        "durable_identity_source_token": { "$ref": "#/$defs/durable_identity_source_class" },
        "source_anchor_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "support_class_token": { "$ref": "#/$defs/support_class" },
        "omitted_scope_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/omitted_scope_reason" }
        },
        "omitted_scope_reason_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/omitted_scope_reason" }
        },
        "export_safe_identity": { "const": true }
      }
    },
    "session_mode": {
      "enum": [
        "run_selected",
        "watch_series",
        "rerun_failed",
        "debug_from_test",
        "imported_ci_read_only"
      ]
    },
    "session_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_plan_id",
        "test_session_id",
        "session_mode",
        "session_mode_token",
        "discovery_snapshot_ref",
        "selected_durable_test_ids",
        "target_ref",
        "environment_ref",
        "retry_policy_ref",
        "watch_policy_ref",
        "widening_review_required"
      ],
      "properties": {
        "session_plan_id": { "$ref": "#/$defs/non_empty_string" },
        "test_session_id": { "$ref": "#/$defs/non_empty_string" },
        "session_mode": { "$ref": "#/$defs/session_mode" },
        "session_mode_token": { "$ref": "#/$defs/session_mode" },
        "discovery_snapshot_ref": { "$ref": "#/$defs/non_empty_string" },
        "selected_durable_test_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "target_ref": { "$ref": "#/$defs/non_empty_string" },
        "environment_ref": { "$ref": "#/$defs/non_empty_string" },
        "retry_policy_ref": { "$ref": "#/$defs/non_empty_string" },
        "watch_policy_ref": { "$ref": "#/$defs/non_empty_string" },
        "imported_ci_session_ref": { "$ref": "#/$defs/non_empty_string" },
        "widening_review_required": { "type": "boolean" }
      }
    },
    "attempt_outcome": {
      "enum": ["passed", "failed", "blocked", "imported_failed", "unknown"]
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attempt_id",
        "test_session_ref",
        "attempt_index",
        "outcome_class",
        "outcome_token",
        "target_ref",
        "environment_ref",
        "runtime_build_refs",
        "artifact_refs",
        "covered_durable_test_ids"
      ],
      "properties": {
        "attempt_id": { "$ref": "#/$defs/non_empty_string" },
        "test_session_ref": { "$ref": "#/$defs/non_empty_string" },
        "attempt_index": { "type": "integer", "minimum": 1 },
        "outcome_class": { "$ref": "#/$defs/attempt_outcome" },
        "outcome_token": { "$ref": "#/$defs/attempt_outcome" },
        "target_ref": { "$ref": "#/$defs/non_empty_string" },
        "environment_ref": { "$ref": "#/$defs/non_empty_string" },
        "runtime_build_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "artifact_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "predecessor_attempt_ref": { "$ref": "#/$defs/non_empty_string" },
        "imported_attempt_ref": { "$ref": "#/$defs/non_empty_string" },
        "covered_durable_test_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "stability_verdict_class": {
      "enum": ["stable", "suspected_flaky", "reproduced_flaky", "muted", "unknown"]
    },
    "stability_verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stability_verdict_id",
        "verdict_class",
        "verdict_token",
        "evidence_attempt_refs",
        "evidence_window_ref",
        "confidence_ref"
      ],
      "properties": {
        "stability_verdict_id": { "$ref": "#/$defs/non_empty_string" },
        "verdict_class": { "$ref": "#/$defs/stability_verdict_class" },
        "verdict_token": { "$ref": "#/$defs/stability_verdict_class" },
        "evidence_attempt_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "evidence_window_ref": { "$ref": "#/$defs/non_empty_string" },
        "confidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "manual_override_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "governance_action": {
      "enum": ["quarantine", "mute"]
    },
    "release_visibility": {
      "enum": ["release_visible", "release_visible_blocks_readiness", "support_only"]
    },
    "quarantine_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quarantine_record_id",
        "action_class",
        "action_token",
        "scope_refs",
        "reason_ref",
        "owner_ref",
        "expires_at",
        "expired",
        "release_visibility_class",
        "release_visibility_token",
        "evidence_refs"
      ],
      "properties": {
        "quarantine_record_id": { "$ref": "#/$defs/non_empty_string" },
        "action_class": { "$ref": "#/$defs/governance_action" },
        "action_token": { "$ref": "#/$defs/governance_action" },
        "scope_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "reason_ref": { "$ref": "#/$defs/non_empty_string" },
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "expires_at": { "$ref": "#/$defs/non_empty_string" },
        "expired": { "type": "boolean" },
        "release_visibility_class": { "$ref": "#/$defs/release_visibility" },
        "release_visibility_token": { "$ref": "#/$defs/release_visibility" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "triage_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "triage_packet_id",
        "scope_refs",
        "attempt_refs",
        "assertion_summary_ref",
        "environment_drift_ref",
        "reproduce_action_ref",
        "debug_action_ref",
        "governance_review_ref"
      ],
      "properties": {
        "triage_packet_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "attempt_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "assertion_summary_ref": { "$ref": "#/$defs/non_empty_string" },
        "environment_drift_ref": { "$ref": "#/$defs/non_empty_string" },
        "reproduce_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "debug_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "governance_review_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "watch_state_class": {
      "enum": ["live", "reduced", "polling", "unavailable"]
    },
    "watch_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "watch_state_id",
        "test_session_ref",
        "session_series_ref",
        "watch_state_class",
        "watch_state_token",
        "support_class",
        "support_class_token",
        "grouped_attempt_refs",
        "backlog_count",
        "degradation_reason_refs",
        "claims_current_truth"
      ],
      "properties": {
        "watch_state_id": { "$ref": "#/$defs/non_empty_string" },
        "test_session_ref": { "$ref": "#/$defs/non_empty_string" },
        "session_series_ref": { "$ref": "#/$defs/non_empty_string" },
        "watch_state_class": { "$ref": "#/$defs/watch_state_class" },
        "watch_state_token": { "$ref": "#/$defs/watch_state_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "support_class_token": { "$ref": "#/$defs/support_class" },
        "grouped_attempt_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "last_successful_attempt_ref": { "$ref": "#/$defs/non_empty_string" },
        "backlog_count": { "type": "integer", "minimum": 0 },
        "degradation_reason_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "claims_current_truth": { "type": "boolean" }
      }
    },
    "imported_ci_parity_class": {
      "enum": [
        "not_imported",
        "read_only_linked",
        "linked_to_local_rerun_plan",
        "fresh_local_parity",
        "stale_or_partial"
      ]
    },
    "imported_ci_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "imported_ci_parity_id",
        "parity_class",
        "parity_token",
        "provider_session_refs",
        "current_discovery_snapshot_ref",
        "local_rerun_plan_refs",
        "imported_attempt_refs",
        "local_parity_attempt_refs",
        "read_only_imported_evidence",
        "claims_current_local_truth"
      ],
      "properties": {
        "imported_ci_parity_id": { "$ref": "#/$defs/non_empty_string" },
        "parity_class": { "$ref": "#/$defs/imported_ci_parity_class" },
        "parity_token": { "$ref": "#/$defs/imported_ci_parity_class" },
        "provider_session_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "current_discovery_snapshot_ref": { "$ref": "#/$defs/non_empty_string" },
        "local_rerun_plan_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "imported_attempt_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "local_parity_attempt_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "read_only_imported_evidence": { "type": "boolean" },
        "claims_current_local_truth": { "type": "boolean" }
      }
    },
    "state_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_count",
        "reduced_count",
        "polling_count",
        "unavailable_count",
        "quarantined_count",
        "muted_count",
        "imported_count"
      ],
      "properties": {
        "live_count": { "type": "integer", "minimum": 0 },
        "reduced_count": { "type": "integer", "minimum": 0 },
        "polling_count": { "type": "integer", "minimum": 0 },
        "unavailable_count": { "type": "integer", "minimum": 0 },
        "quarantined_count": { "type": "integer", "minimum": 0 },
        "muted_count": { "type": "integer", "minimum": 0 },
        "imported_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
