{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/finalize_environment_and_toolchain_manager_parity_across_ui_truth.schema.json",
  "title": "Aureline environment + toolchain manager and execution-context inspector parity truth packet",
  "description": "Boundary schema for the stable inspector-parity truth packet certifying that the local, remote/helper, container, and managed execution-context lanes return the same inspector fields (interpreter, sdk, shell, container_target, remote_target, activator, trust_state, policy_source) and the same recovery posture (reconnect, restore_no_rerun, blocked_target, degraded_helper, artifact_provenance) across the UI, CLI/headless, Help/About, and support/export parity surfaces. Every launch_stable lane MUST publish a toolchain_manager_admission row binding a manager id and a lineage_admission row binding execution_context_id. The packet is the single truth that the editor run surface, terminal pane, task panel, CLI/headless inspector, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies, fork their own runtime semantics, or paraphrase inspector posture.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": {
      "const": "finalize_environment_and_toolchain_manager_parity_across_ui_truth_stable_packet"
    },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/execution_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/inspector_parity_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "execution_lane_class": {
      "enum": [
        "local_lane",
        "remote_helper_lane",
        "container_lane",
        "managed_lane"
      ]
    },
    "inspector_parity_row_class": {
      "enum": [
        "inspector_parity_quality",
        "inspector_field_admission",
        "parity_surface_binding",
        "recovery_admission",
        "toolchain_manager_admission",
        "lineage_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "inspector_field_class": {
      "enum": [
        "interpreter",
        "sdk",
        "shell",
        "container_target",
        "remote_target",
        "activator",
        "trust_state",
        "policy_source",
        "not_applicable"
      ]
    },
    "parity_surface_class": {
      "enum": [
        "ui",
        "cli_headless",
        "help_about",
        "support_export",
        "not_applicable"
      ]
    },
    "recovery_state_class": {
      "enum": [
        "reconnect",
        "restore_no_rerun",
        "blocked_target",
        "degraded_helper",
        "artifact_provenance",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "local_lane_subset_only",
        "remote_helper_subset_only",
        "container_subset_only",
        "managed_subset_only",
        "inspector_field_subset_only",
        "parity_surface_subset_only",
        "recovery_state_subset_only",
        "unsupported_runtime_target",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_parity_surface_break",
        "auto_narrow_on_inspector_field_gap",
        "auto_narrow_on_recovery_state_gap",
        "auto_narrow_on_toolchain_manager_drift",
        "auto_narrow_on_lineage_break",
        "auto_narrow_on_silent_rerun",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "inspector_parity_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_execution_lane_coverage",
        "missing_inspector_field_coverage",
        "missing_parity_surface_binding_coverage",
        "missing_recovery_state_coverage",
        "missing_toolchain_manager_admission",
        "missing_lineage_admission",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "inspector_field_not_applicable",
        "inspector_field_not_permitted_on_row_class",
        "parity_surface_not_applicable",
        "parity_surface_not_permitted_on_row_class",
        "recovery_state_not_applicable",
        "recovery_state_not_permitted_on_row_class",
        "lineage_admission_missing_execution_context_id",
        "toolchain_manager_admission_missing_manager_id",
        "restore_recovery_admits_silent_rerun",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "inspector_field_vocabulary_collapsed",
        "parity_surface_vocabulary_collapsed",
        "recovery_state_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "inspector_parity_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "inspector_field_class",
        "parity_surface_class",
        "recovery_state_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/execution_lane_class" },
        "row_class": { "$ref": "#/$defs/inspector_parity_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "inspector_field_class": { "$ref": "#/$defs/inspector_field_class" },
        "parity_surface_class": { "$ref": "#/$defs/parity_surface_class" },
        "recovery_state_class": { "$ref": "#/$defs/recovery_state_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/inspector_parity_confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_id_binding": { "$ref": "#/$defs/non_empty_string" },
        "toolchain_manager_id_binding": { "$ref": "#/$defs/non_empty_string" },
        "restore_preserves_no_rerun": { "type": "boolean" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "inspector_parity_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_inspector_field_vocabulary",
        "preserves_parity_surface_vocabulary",
        "preserves_recovery_state_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "editor_run_surface",
            "terminal_pane",
            "task_panel",
            "cli_headless",
            "support_export",
            "release_proof_index",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "inspector_parity_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_inspector_field_vocabulary": { "type": "boolean" },
        "preserves_parity_surface_vocabulary": { "type": "boolean" },
        "preserves_recovery_state_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
