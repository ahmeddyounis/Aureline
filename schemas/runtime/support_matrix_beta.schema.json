{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/support_matrix_beta.schema.json",
  "title": "Aureline beta debugger and execution-context support matrix",
  "description": "Boundary schema for the beta debugger and execution-context support matrix per claimed launch-language wedge. One typed row per wedge covers launch, attach, test, and execution-context support with a closed support-class vocabulary and explicit downgrade semantics. Migration, partner, and release packets quote this contract verbatim instead of re-deriving wedge claims from prose.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/support_matrix_beta_manifest_record" },
    { "$ref": "#/$defs/support_matrix_beta_wedge_row_record" },
    { "$ref": "#/$defs/support_matrix_beta_wedge_input_record" },
    { "$ref": "#/$defs/support_matrix_beta_support_export_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "date_time": {
      "type": "string",
      "format": "date-time"
    },
    "support_matrix_class": {
      "type": "string",
      "enum": ["supported", "preview", "limited", "unsupported"]
    },
    "support_matrix_wedge_id": {
      "type": "string",
      "enum": ["python", "typescript_javascript"]
    },
    "support_matrix_context_lane": {
      "type": "string",
      "enum": [
        "local_host",
        "remote_attach",
        "container",
        "request_workspace"
      ]
    },
    "support_matrix_downgrade_rule": {
      "type": "string",
      "enum": [
        "narrow_launch_on_adapter_capability_drop",
        "narrow_attach_to_inspect_only_on_capability_drop",
        "block_on_unclaimed_test_framework",
        "block_on_unclaimed_target_class",
        "block_protected_dispatch_on_ticket_drift",
        "block_protected_dispatch_on_capsule_drift",
        "block_protected_dispatch_on_trust_state_regression",
        "block_protected_dispatch_on_policy_epoch_regression",
        "block_on_target_unreachable",
        "block_on_adapter_negotiation_refused"
      ]
    },
    "support_matrix_launch_support": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class",
        "class_token",
        "adapter_protocol_token",
        "summary"
      ],
      "properties": {
        "class": { "$ref": "#/$defs/support_matrix_class" },
        "class_token": { "$ref": "#/$defs/non_empty_string" },
        "adapter_protocol_token": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "support_matrix_attach_support": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class",
        "class_token",
        "adapter_protocol_token",
        "summary"
      ],
      "properties": {
        "class": { "$ref": "#/$defs/support_matrix_class" },
        "class_token": { "$ref": "#/$defs/non_empty_string" },
        "adapter_protocol_token": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "support_matrix_test_support": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class",
        "class_token",
        "claimed_framework_tokens",
        "previewed_framework_tokens",
        "summary"
      ],
      "properties": {
        "class": { "$ref": "#/$defs/support_matrix_class" },
        "class_token": { "$ref": "#/$defs/non_empty_string" },
        "claimed_framework_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "previewed_framework_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "support_matrix_context_lane_support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane", "lane_token", "class", "class_token", "summary"],
      "properties": {
        "lane": { "$ref": "#/$defs/support_matrix_context_lane" },
        "lane_token": { "$ref": "#/$defs/non_empty_string" },
        "class": { "$ref": "#/$defs/support_matrix_class" },
        "class_token": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "support_matrix_context_support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall_class", "overall_class_token", "lanes"],
      "properties": {
        "overall_class": { "$ref": "#/$defs/support_matrix_class" },
        "overall_class_token": { "$ref": "#/$defs/non_empty_string" },
        "lanes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/support_matrix_context_lane_support" }
        }
      }
    },
    "support_matrix_beta_wedge_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "wedge_id",
        "wedge_token",
        "wedge_label",
        "launch",
        "attach",
        "test",
        "execution_context",
        "downgrade_rules",
        "downgrade_rule_tokens"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "support_matrix_beta_wedge_row_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "wedge_id": { "$ref": "#/$defs/support_matrix_wedge_id" },
        "wedge_token": { "$ref": "#/$defs/non_empty_string" },
        "wedge_label": { "$ref": "#/$defs/non_empty_string" },
        "launch": { "$ref": "#/$defs/support_matrix_launch_support" },
        "attach": { "$ref": "#/$defs/support_matrix_attach_support" },
        "test": { "$ref": "#/$defs/support_matrix_test_support" },
        "execution_context": { "$ref": "#/$defs/support_matrix_context_support" },
        "downgrade_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/support_matrix_downgrade_rule" }
        },
        "downgrade_rule_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "support_matrix_beta_manifest_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "manifest_id",
        "generated_at",
        "rows"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "support_matrix_beta_manifest_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "manifest_id": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "$ref": "#/$defs/date_time" },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/support_matrix_beta_wedge_row_record" }
        }
      }
    },
    "support_matrix_context_lane_expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane_token", "expected_class"],
      "properties": {
        "lane_token": { "$ref": "#/$defs/non_empty_string" },
        "expected_class": { "$ref": "#/$defs/support_matrix_class" }
      }
    },
    "support_matrix_beta_wedge_input_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "wedge_id",
        "wedge_token",
        "expected_launch_class",
        "expected_attach_class",
        "expected_test_class",
        "expected_claimed_framework_tokens",
        "expected_context_lanes",
        "expected_downgrade_rule_tokens"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "support_matrix_beta_wedge_input_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "wedge_id": { "$ref": "#/$defs/support_matrix_wedge_id" },
        "wedge_token": { "$ref": "#/$defs/non_empty_string" },
        "expected_launch_class": { "$ref": "#/$defs/support_matrix_class" },
        "expected_attach_class": { "$ref": "#/$defs/support_matrix_class" },
        "expected_test_class": { "$ref": "#/$defs/support_matrix_class" },
        "expected_claimed_framework_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "expected_context_lanes": {
          "type": "array",
          "items": { "$ref": "#/$defs/support_matrix_context_lane_expectation" }
        },
        "expected_downgrade_rule_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "support_matrix_beta_support_export_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "support_export_id",
        "generated_at",
        "manifest",
        "inputs"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "support_matrix_beta_support_export_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "support_export_id": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "$ref": "#/$defs/date_time" },
        "manifest": { "$ref": "#/$defs/support_matrix_beta_manifest_record" },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/support_matrix_beta_wedge_input_record" }
        }
      }
    }
  }
}
