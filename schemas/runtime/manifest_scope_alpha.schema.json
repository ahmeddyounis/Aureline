{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/manifest_scope_alpha.schema.json",
  "title": "Aureline manifest-scope alpha descriptor",
  "description": "Boundary schema for manifest_scope_alpha_descriptor records used by package-mutation review. The descriptor makes root/member/module identity, active manifest path, inherited registry source, and lockfile coupling visible before dependency mutation. Raw manifest bodies, absolute paths, registry URLs, tokens, and lockfile bodies never appear.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "manifest_scope_id",
    "package_manager_family",
    "package_manager_family_token",
    "manifest_scope_class",
    "manifest_scope_token",
    "workspace_root_ref",
    "active_manifest_path",
    "active_manifest_ref",
    "inherited_registry_source_ref",
    "lockfile_refs"
  ],
  "properties": {
    "record_kind": { "const": "manifest_scope_alpha_descriptor" },
    "schema_version": { "const": 1 },
    "manifest_scope_id": { "$ref": "#/$defs/non_empty_string" },
    "package_manager_family": { "$ref": "#/$defs/package_manager_family" },
    "package_manager_family_token": { "$ref": "#/$defs/package_manager_family" },
    "manifest_scope_class": { "$ref": "#/$defs/manifest_scope_class" },
    "manifest_scope_token": { "$ref": "#/$defs/manifest_scope_class" },
    "workspace_root_ref": { "$ref": "#/$defs/non_empty_string" },
    "workspace_member_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
    "module_identity_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
    "active_manifest_path": {
      "type": "string",
      "minLength": 1,
      "description": "Workspace-relative manifest path visible in review and export."
    },
    "active_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "inherited_registry_source_ref": { "$ref": "#/$defs/non_empty_string" },
    "lockfile_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/lockfile_alpha_ref" }
    },
    "workspace_slice_ref": { "$ref": "#/$defs/nullable_non_empty_string" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "nullable_non_empty_string": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/non_empty_string" }]
    },
    "package_manager_family": {
      "type": "string",
      "enum": ["npm", "pnpm", "package_manager_unknown_requires_review"]
    },
    "manifest_scope_class": {
      "type": "string",
      "enum": [
        "workspace_root_manifest",
        "workspace_member_manifest",
        "monorepo_root_manifest",
        "application_only_dev_dependency_manifest",
        "vendored_or_offline_manifest",
        "out_of_tree_global_manifest_admin_only",
        "manifest_scope_unknown_requires_review"
      ]
    },
    "lockfile_coupling_class": {
      "type": "string",
      "enum": [
        "shared_workspace_lockfile",
        "manifest_local_lockfile",
        "lockfile_absent_will_be_created"
      ]
    },
    "lockfile_alpha_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lockfile_ref",
        "lockfile_path",
        "coupling_class",
        "coupling_token",
        "exists_before_apply"
      ],
      "properties": {
        "lockfile_ref": { "$ref": "#/$defs/non_empty_string" },
        "lockfile_path": {
          "type": "string",
          "minLength": 1,
          "description": "Workspace-relative lockfile path visible in review and export."
        },
        "coupling_class": { "$ref": "#/$defs/lockfile_coupling_class" },
        "coupling_token": { "$ref": "#/$defs/lockfile_coupling_class" },
        "exists_before_apply": { "type": "boolean" }
      }
    }
  }
}
