{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/queue-governor-and-admission-control.schema.json",
  "title": "Aureline stable queue-governor and admission-control packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "health",
    "jobs",
    "lane_rules",
    "lane_summaries",
    "labs",
    "consumer_projections",
    "raw_private_material_excluded"
  ],
  "properties": {
    "record_kind": {
      "const": "queue_governor_and_admission_control_stable_packet"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "raw_private_material_excluded": {
      "const": true
    },
    "health": {
      "type": "object",
      "required": [
        "state",
        "pause_reason",
        "resume_owner",
        "affected_lanes",
        "protected_foreground"
      ],
      "properties": {
        "state": {
          "enum": ["nominal", "constrained", "degraded", "protect_core", "recovery"]
        },
        "pause_reason": {
          "type": "string",
          "minLength": 1
        },
        "resume_owner": {
          "type": "string",
          "minLength": 1
        },
        "affected_lanes": {
          "type": "array",
          "items": { "$ref": "#/$defs/queue_lane" }
        },
        "protected_foreground": {
          "type": "array",
          "items": {
            "enum": ["editing", "save", "explicit_cancellation", "quick_open", "navigation"]
          }
        }
      }
    },
    "jobs": {
      "type": "array",
      "minItems": 1
    },
    "lane_rules": {
      "type": "array",
      "minItems": 5
    },
    "lane_summaries": {
      "type": "array",
      "minItems": 5
    },
    "labs": {
      "type": "array",
      "minItems": 6
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 5
    }
  },
  "$defs": {
    "queue_lane": {
      "enum": [
        "foreground",
        "interactive_background",
        "maintenance",
        "provider_overlay",
        "upload_replication"
      ]
    }
  }
}
