{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/runtime_evidence_comparison_alpha.schema.json",
  "title": "Aureline runtime-evidence comparison-class alpha packet",
  "description": "Boundary schema for one alpha comparison-class packet. The packet discloses workload id, corpus or archetype, local/remote/imported class, hardware and power profile, runtime/toolchain identity, capture mode, baseline/current refs, sample count, variance window, threshold state, comparison class, and confounders so unlike captures remain inspectable without being treated as equivalent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "comparison_packet_id",
    "workload_id",
    "corpus_archetype",
    "source_class",
    "hardware_power_profile",
    "runtime_toolchain",
    "baseline_ref",
    "current_profile_session_ref",
    "variance_window",
    "comparison_class",
    "confounders"
  ],
  "properties": {
    "record_kind": { "const": "runtime_evidence_comparison_alpha_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "comparison_packet_id": { "$ref": "#/$defs/opaque_ref" },
    "workload_id": { "$ref": "#/$defs/opaque_ref" },
    "corpus_archetype": { "$ref": "#/$defs/opaque_ref" },
    "source_class": { "$ref": "#/$defs/comparison_source_class" },
    "hardware_power_profile": { "$ref": "#/$defs/hardware_power_profile" },
    "runtime_toolchain": { "$ref": "#/$defs/comparison_runtime_toolchain" },
    "baseline_ref": { "$ref": "#/$defs/opaque_ref" },
    "current_profile_session_ref": { "$ref": "#/$defs/opaque_ref" },
    "variance_window": { "$ref": "#/$defs/variance_window" },
    "comparison_class": { "$ref": "#/$defs/comparison_class" },
    "confounders": {
      "type": "array",
      "items": { "$ref": "#/$defs/short_sentence" }
    }
  },
  "$defs": {
    "opaque_ref": { "type": "string", "minLength": 1 },
    "short_sentence": { "type": "string", "minLength": 1, "maxLength": 640 },
    "non_negative_integer": { "type": "integer", "minimum": 0 },
    "capture_mode": {
      "type": "string",
      "enum": [
        "cpu_sample",
        "instrumented_cpu_profile",
        "wall_time_trace",
        "memory_sample",
        "allocation_snapshot",
        "replay_recording",
        "imported_profile"
      ]
    },
    "comparison_source_class": {
      "type": "string",
      "enum": ["local", "remote", "container", "ci", "imported_read_only"]
    },
    "comparison_class": {
      "type": "string",
      "enum": [
        "like_for_like",
        "comparable_with_declared_confounders",
        "inspectable_not_equivalent",
        "import_view_only_not_comparable",
        "unknown_requires_review"
      ]
    },
    "hardware_power_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hardware_class",
        "cpu_arch_class",
        "power_state",
        "thermal_state"
      ],
      "properties": {
        "hardware_class": { "$ref": "#/$defs/opaque_ref" },
        "cpu_arch_class": { "$ref": "#/$defs/opaque_ref" },
        "power_state": { "$ref": "#/$defs/opaque_ref" },
        "thermal_state": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "comparison_runtime_toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_identity", "toolchain_identity_ref", "capture_mode"],
      "properties": {
        "runtime_identity": { "$ref": "#/$defs/opaque_ref" },
        "toolchain_identity_ref": { "$ref": "#/$defs/opaque_ref" },
        "capture_mode": { "$ref": "#/$defs/capture_mode" }
      }
    },
    "variance_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_count",
        "window_label",
        "relative_variance_bps",
        "threshold_state"
      ],
      "properties": {
        "sample_count": { "$ref": "#/$defs/non_negative_integer" },
        "window_label": { "$ref": "#/$defs/short_sentence" },
        "relative_variance_bps": { "$ref": "#/$defs/non_negative_integer" },
        "threshold_state": { "$ref": "#/$defs/opaque_ref" }
      }
    }
  }
}
