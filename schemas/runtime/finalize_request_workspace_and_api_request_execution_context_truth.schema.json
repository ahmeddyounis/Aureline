{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/finalize_request_workspace_and_api_request_execution_context_truth.schema.json",
  "title": "Aureline request-workspace and API-request execution-context reuse truth packet",
  "description": "Boundary schema for the stable request-workspace and API-request execution-context reuse truth packet covering the request_workspace_lane, api_request_lane, response_trust_lane, and data_action_lane. Every launch_stable lane MUST publish wedge_admission rows for route_target_truth, auth_source_truth, approval_review_truth, and execution_context_reuse_truth; auth_source_admission rows for os_keychain, enterprise_vault, delegated_identity, session_only, workspace_variable, and missing; connection_state_admission rows for connected, constrained, offline_local_safe, reauth_required, reconciliation_pending, and service_unavailable; streaming_response_state_admission rows for connecting, headers_received, streaming, truncated, complete, partial, timed_out, and policy_blocked; consumer_surface_binding rows for request_editor_surface, response_timeline_surface, mutation_review_sheet, replay_history_surface, cli_headless_inspect, support_export, help_about, and conformance_dashboard; and a lineage_admission row binding execution_context_id. The packet is the single truth that the request editor, response timeline, mutation-review sheet, replay/history, CLI/headless inspector, support export, release proof index, Help/About proof card, and conformance dashboard all read; surfaces MUST NOT fork local runtime semantics, paraphrase auth-source modes, collapse streaming-response states, or silently dispatch a deferred non-idempotent or destructive intent.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": {
      "const": "finalize_request_workspace_and_api_request_execution_context_truth_stable_packet"
    },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/request_execution_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/request_execution_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "request_execution_lane_class": {
      "enum": [
        "request_workspace_lane",
        "api_request_lane",
        "response_trust_lane",
        "data_action_lane"
      ]
    },
    "request_execution_row_class": {
      "enum": [
        "execution_context_reuse_quality",
        "wedge_admission",
        "auth_source_admission",
        "connection_state_admission",
        "streaming_response_state_admission",
        "consumer_surface_binding",
        "lineage_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "wedge_class": {
      "enum": [
        "route_target_truth",
        "auth_source_truth",
        "approval_review_truth",
        "execution_context_reuse_truth",
        "not_applicable"
      ]
    },
    "auth_source_mode": {
      "enum": [
        "os_keychain",
        "enterprise_vault",
        "delegated_identity",
        "session_only",
        "workspace_variable",
        "missing",
        "not_applicable"
      ]
    },
    "connection_state_class": {
      "enum": [
        "connected",
        "constrained",
        "offline_local_safe",
        "reauth_required",
        "reconciliation_pending",
        "service_unavailable",
        "not_applicable"
      ]
    },
    "streaming_response_state_class": {
      "enum": [
        "connecting",
        "headers_received",
        "streaming",
        "truncated",
        "complete",
        "partial",
        "timed_out",
        "policy_blocked",
        "not_applicable"
      ]
    },
    "consumer_surface_class": {
      "enum": [
        "request_editor_surface",
        "response_timeline_surface",
        "mutation_review_sheet",
        "replay_history_surface",
        "cli_headless_inspect",
        "support_export",
        "help_about",
        "conformance_dashboard",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "request_workspace_subset_only",
        "api_request_subset_only",
        "response_trust_subset_only",
        "data_action_subset_only",
        "wedge_subset_only",
        "auth_source_mode_subset_only",
        "connection_state_subset_only",
        "streaming_response_state_subset_only",
        "consumer_surface_subset_only",
        "unsupported_request_route",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_route_target_gap",
        "auto_narrow_on_auth_source_gap",
        "auto_narrow_on_connection_state_gap",
        "auto_narrow_on_streaming_state_gap",
        "auto_narrow_on_consumer_surface_gap",
        "auto_narrow_on_approval_review_drift",
        "auto_narrow_on_lineage_break",
        "auto_narrow_on_silent_queue_dispatch",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_execution_lane_coverage",
        "missing_wedge_coverage",
        "missing_auth_source_coverage",
        "missing_connection_state_coverage",
        "missing_streaming_response_state_coverage",
        "missing_consumer_surface_coverage",
        "missing_lineage_admission",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "wedge_not_applicable",
        "wedge_not_permitted_on_row_class",
        "auth_source_not_applicable",
        "auth_source_not_permitted_on_row_class",
        "connection_state_not_applicable",
        "connection_state_not_permitted_on_row_class",
        "streaming_state_not_applicable",
        "streaming_state_not_permitted_on_row_class",
        "consumer_surface_not_applicable",
        "consumer_surface_not_permitted_on_row_class",
        "lineage_admission_missing_execution_context_id",
        "mutation_review_binding_missing_approval",
        "silent_deferred_queue_admitted",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "wedge_vocabulary_collapsed",
        "auth_source_vocabulary_collapsed",
        "connection_state_vocabulary_collapsed",
        "streaming_response_state_vocabulary_collapsed",
        "consumer_surface_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "request_execution_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "wedge_class",
        "auth_source_mode",
        "connection_state_class",
        "streaming_response_state_class",
        "consumer_surface_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/request_execution_lane_class" },
        "row_class": { "$ref": "#/$defs/request_execution_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "wedge_class": { "$ref": "#/$defs/wedge_class" },
        "auth_source_mode": { "$ref": "#/$defs/auth_source_mode" },
        "connection_state_class": { "$ref": "#/$defs/connection_state_class" },
        "streaming_response_state_class": { "$ref": "#/$defs/streaming_response_state_class" },
        "consumer_surface_class": { "$ref": "#/$defs/consumer_surface_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_id_binding": { "$ref": "#/$defs/non_empty_string" },
        "approval_review_attested": { "type": "boolean" },
        "silent_deferred_queue_blocked": { "type": "boolean" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "request_execution_context_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_wedge_vocabulary",
        "preserves_auth_source_vocabulary",
        "preserves_connection_state_vocabulary",
        "preserves_streaming_response_state_vocabulary",
        "preserves_consumer_surface_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "request_editor_surface",
            "response_timeline_surface",
            "mutation_review_sheet",
            "replay_history_surface",
            "cli_headless_inspect",
            "support_export",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "request_execution_context_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_wedge_vocabulary": { "type": "boolean" },
        "preserves_auth_source_vocabulary": { "type": "boolean" },
        "preserves_connection_state_vocabulary": { "type": "boolean" },
        "preserves_streaming_response_state_vocabulary": { "type": "boolean" },
        "preserves_consumer_surface_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
