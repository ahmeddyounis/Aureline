{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/stabilize_integrated_terminal_boundaries_clipboard_posture_transcript_export_truth.schema.json",
  "title": "Aureline integrated-terminal stabilization truth packet",
  "description": "Boundary schema for the stable integrated-terminal stabilization truth packet certifying local, remote/helper, container, and restored terminal sessions at the M4 launch-stable grade. Every launch_stable lane MUST publish a terminal_stabilization_quality row plus the full four-wedge admission coverage (host_boundary_chip, clipboard_posture, transcript_export, restore_no_rerun), the full five host-boundary field bindings (host_or_session_identity, route_cue, trust_state, restore_state, target_or_cwd_hint), the full five clipboard-posture surface bindings (clipboard_route_local_vs_remote, bracketed_paste_state, multiline_paste_guardrail, admin_suppression, high_risk_paste_review), the full three transcript-export field bindings (transcript_versus_live_session, host_session_boundary_cue, redaction_state), a restore_no_rerun_attestation row attesting attests_no_silent_rerun=true, and a lineage_admission row binding execution_context_id. The packet is the single truth that the terminal pane, transcript export surface, browser handoff surface, restore surface, CLI/headless inspector, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies, fork their own host-boundary or clipboard semantics, or blur transcript-versus-live distinctions.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": {
      "const": "stabilize_integrated_terminal_boundaries_clipboard_posture_transcript_export_truth_stable_packet"
    },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/terminal_stabilization_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/terminal_stabilization_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 9,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "terminal_stabilization_lane_class": {
      "enum": ["local_lane", "remote_helper_lane", "container_lane", "restored_lane"]
    },
    "terminal_stabilization_row_class": {
      "enum": [
        "terminal_stabilization_quality",
        "wedge_admission",
        "host_boundary_field_binding",
        "clipboard_posture_binding",
        "transcript_export_field_binding",
        "restore_no_rerun_attestation",
        "lineage_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "wedge_class": {
      "enum": [
        "host_boundary_chip",
        "clipboard_posture",
        "transcript_export",
        "restore_no_rerun",
        "not_applicable"
      ]
    },
    "host_boundary_field_class": {
      "enum": [
        "host_or_session_identity",
        "route_cue",
        "trust_state",
        "restore_state",
        "target_or_cwd_hint",
        "not_applicable"
      ]
    },
    "clipboard_posture_class": {
      "enum": [
        "clipboard_route_local_vs_remote",
        "bracketed_paste_state",
        "multiline_paste_guardrail",
        "admin_suppression",
        "high_risk_paste_review",
        "not_applicable"
      ]
    },
    "transcript_export_field_class": {
      "enum": [
        "transcript_versus_live_session",
        "host_session_boundary_cue",
        "redaction_state",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "local_lane_subset_only",
        "remote_helper_subset_only",
        "container_subset_only",
        "restored_subset_only",
        "wedge_admission_subset_only",
        "host_boundary_field_subset_only",
        "clipboard_posture_subset_only",
        "transcript_export_field_subset_only",
        "restore_admits_silent_rerun",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_wedge_admission_gap",
        "auto_narrow_on_host_boundary_field_gap",
        "auto_narrow_on_clipboard_posture_gap",
        "auto_narrow_on_transcript_export_field_gap",
        "auto_narrow_on_restore_admits_silent_rerun",
        "auto_narrow_on_lineage_break",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "terminal_stabilization_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_lane_coverage",
        "missing_wedge_admission_coverage",
        "missing_host_boundary_field_coverage",
        "missing_clipboard_posture_coverage",
        "missing_transcript_export_field_coverage",
        "missing_restore_no_rerun_attestation",
        "restore_no_rerun_attestation_admits_silent_rerun",
        "missing_lineage_admission",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "wedge_not_applicable",
        "wedge_not_permitted_on_row_class",
        "host_boundary_field_not_applicable",
        "host_boundary_field_not_permitted_on_row_class",
        "clipboard_posture_not_applicable",
        "clipboard_posture_not_permitted_on_row_class",
        "transcript_export_field_not_applicable",
        "transcript_export_field_not_permitted_on_row_class",
        "lineage_admission_missing_execution_context_id",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "wedge_vocabulary_collapsed",
        "host_boundary_field_vocabulary_collapsed",
        "clipboard_posture_vocabulary_collapsed",
        "transcript_export_field_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "terminal_stabilization_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "wedge_class",
        "host_boundary_field_class",
        "clipboard_posture_class",
        "transcript_export_field_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/terminal_stabilization_lane_class" },
        "row_class": { "$ref": "#/$defs/terminal_stabilization_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "wedge_class": { "$ref": "#/$defs/wedge_class" },
        "host_boundary_field_class": { "$ref": "#/$defs/host_boundary_field_class" },
        "clipboard_posture_class": { "$ref": "#/$defs/clipboard_posture_class" },
        "transcript_export_field_class": { "$ref": "#/$defs/transcript_export_field_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/terminal_stabilization_confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_id_binding": { "$ref": "#/$defs/non_empty_string" },
        "attests_no_silent_rerun": { "type": "boolean" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "terminal_stabilization_truth_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_wedge_vocabulary",
        "preserves_host_boundary_field_vocabulary",
        "preserves_clipboard_posture_vocabulary",
        "preserves_transcript_export_field_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "terminal_pane",
            "transcript_export_surface",
            "browser_handoff_surface",
            "restore_surface",
            "cli_headless",
            "support_export",
            "release_proof_index",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "terminal_stabilization_truth_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_wedge_vocabulary": { "type": "boolean" },
        "preserves_host_boundary_field_vocabulary": { "type": "boolean" },
        "preserves_clipboard_posture_vocabulary": { "type": "boolean" },
        "preserves_transcript_export_field_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
