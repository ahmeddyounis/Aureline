{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/finalize_terminal_task_test_and_debug_support_export_parity_truth.schema.json",
  "title": "Aureline terminal/task/test/debug support-export parity truth packet",
  "description": "Boundary schema for the stable support-export parity truth packet certifying terminal, task, test, and debug surfaces at the M4 launch-stable grade. Every launch_stable lane MUST publish a support_export_parity_quality row plus the full four-wedge admission coverage (support_export_parity, diagnosis_packet, repair_hook, execution_context_lineage), the full five export-field bindings (export_class, redaction_state, provenance, support_summary, artifact_provenance), the full four diagnosis-packet bindings (finding_code, diagnosis_scope, redaction_class, chain_of_custody), the full four repair-hook bindings (repair_transaction_id, repair_hook_ref, repair_authority, repair_outcome), the full five recovery-posture admissions (reconnect, restore_no_rerun, blocked_target, degraded_helper, artifact_provenance), and a lineage_admission row binding execution_context_id. The packet is the single truth that the terminal pane, task panel, test explorer, debug surface, CLI/headless inspector, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies, fork their own export or diagnosis semantics, or blur recovery-posture distinctions.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": {
      "const": "finalize_terminal_task_test_and_debug_support_export_parity_truth_stable_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "workflow_or_surface_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "generated_at": {
      "$ref": "#/$defs/non_empty_string"
    },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/support_export_parity_lane_class"
      }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/support_export_parity_row"
      }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 9,
      "items": {
        "$ref": "#/$defs/consumer_projection"
      }
    },
    "source_contract_refs": {
      "$ref": "#/$defs/ref_array"
    },
    "promotion_state": {
      "$ref": "#/$defs/promotion_state"
    },
    "validation_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation_finding"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "ref_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "uniqueItems": true
    },
    "support_export_parity_lane_class": {
      "enum": [
        "terminal_lane",
        "task_lane",
        "test_lane",
        "debug_lane"
      ]
    },
    "support_export_parity_row_class": {
      "enum": [
        "support_export_parity_quality",
        "wedge_admission",
        "export_field_binding",
        "diagnosis_packet_binding",
        "repair_hook_binding",
        "recovery_posture_admission",
        "lineage_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "wedge_class": {
      "enum": [
        "support_export_parity",
        "diagnosis_packet",
        "repair_hook",
        "execution_context_lineage",
        "not_applicable"
      ]
    },
    "export_field_class": {
      "enum": [
        "export_class",
        "redaction_state",
        "provenance",
        "support_summary",
        "artifact_provenance",
        "not_applicable"
      ]
    },
    "diagnosis_packet_field_class": {
      "enum": [
        "finding_code",
        "diagnosis_scope",
        "redaction_class",
        "chain_of_custody",
        "not_applicable"
      ]
    },
    "repair_hook_field_class": {
      "enum": [
        "repair_transaction_id",
        "repair_hook_ref",
        "repair_authority",
        "repair_outcome",
        "not_applicable"
      ]
    },
    "recovery_posture_class": {
      "enum": [
        "reconnect",
        "restore_no_rerun",
        "blocked_target",
        "degraded_helper",
        "artifact_provenance",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "terminal_lane_subset_only",
        "task_lane_subset_only",
        "test_lane_subset_only",
        "debug_lane_subset_only",
        "export_field_subset_only",
        "diagnosis_packet_subset_only",
        "repair_hook_subset_only",
        "recovery_posture_subset_only",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_export_field_gap",
        "auto_narrow_on_diagnosis_packet_gap",
        "auto_narrow_on_repair_hook_gap",
        "auto_narrow_on_recovery_posture_gap",
        "auto_narrow_on_wedge_admission_gap",
        "auto_narrow_on_lineage_break",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "confidence_class": {
      "enum": [
        "high_confidence",
        "medium_confidence",
        "low_confidence"
      ]
    },
    "promotion_state": {
      "enum": [
        "stable",
        "narrowed_below_stable",
        "blocks_stable"
      ]
    },
    "finding_severity": {
      "enum": [
        "info",
        "warning",
        "blocker"
      ]
    },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_lane_coverage",
        "missing_wedge_admission_coverage",
        "missing_export_field_coverage",
        "missing_diagnosis_packet_coverage",
        "missing_repair_hook_coverage",
        "missing_recovery_posture_coverage",
        "missing_lineage_admission",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "wedge_not_applicable",
        "wedge_not_permitted_on_row_class",
        "export_field_not_applicable",
        "export_field_not_permitted_on_row_class",
        "diagnosis_packet_not_applicable",
        "diagnosis_packet_not_permitted_on_row_class",
        "repair_hook_not_applicable",
        "repair_hook_not_permitted_on_row_class",
        "recovery_posture_not_applicable",
        "recovery_posture_not_permitted_on_row_class",
        "lineage_admission_missing_execution_context_id",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "wedge_vocabulary_collapsed",
        "export_field_vocabulary_collapsed",
        "diagnosis_packet_vocabulary_collapsed",
        "repair_hook_vocabulary_collapsed",
        "recovery_posture_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "consumer_surface": {
      "enum": [
        "terminal_pane",
        "task_panel",
        "test_explorer",
        "debug_surface",
        "cli_headless",
        "support_export",
        "release_proof_index",
        "help_about",
        "conformance_dashboard"
      ]
    },
    "support_export_parity_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "wedge_class",
        "export_field_class",
        "diagnosis_packet_field_class",
        "repair_hook_field_class",
        "recovery_posture_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "lane_class": {
          "$ref": "#/$defs/support_export_parity_lane_class"
        },
        "row_class": {
          "$ref": "#/$defs/support_export_parity_row_class"
        },
        "support_class": {
          "$ref": "#/$defs/support_class"
        },
        "wedge_class": {
          "$ref": "#/$defs/wedge_class"
        },
        "export_field_class": {
          "$ref": "#/$defs/export_field_class"
        },
        "diagnosis_packet_field_class": {
          "$ref": "#/$defs/diagnosis_packet_field_class"
        },
        "repair_hook_field_class": {
          "$ref": "#/$defs/repair_hook_field_class"
        },
        "recovery_posture_class": {
          "$ref": "#/$defs/recovery_posture_class"
        },
        "evidence_class": {
          "$ref": "#/$defs/evidence_class"
        },
        "known_limit_class": {
          "$ref": "#/$defs/known_limit_class"
        },
        "downgrade_automation_class": {
          "$ref": "#/$defs/downgrade_automation_class"
        },
        "confidence_class": {
          "$ref": "#/$defs/confidence_class"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "disclosure_ref": {
          "type": "string"
        },
        "execution_context_id_binding": {
          "type": "string"
        },
        "raw_source_material_excluded": {
          "type": "boolean"
        },
        "secrets_excluded": {
          "type": "boolean"
        },
        "ambient_authority_excluded": {
          "type": "boolean"
        },
        "captured_at": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "support_export_parity_truth_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_wedge_vocabulary",
        "preserves_export_field_vocabulary",
        "preserves_diagnosis_packet_vocabulary",
        "preserves_repair_hook_vocabulary",
        "preserves_recovery_posture_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "$ref": "#/$defs/consumer_surface"
        },
        "projection_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "support_export_parity_truth_packet_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rendered_at": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preserves_same_packet": {
          "type": "boolean"
        },
        "preserves_lane_vocabulary": {
          "type": "boolean"
        },
        "preserves_row_class_vocabulary": {
          "type": "boolean"
        },
        "preserves_support_class_vocabulary": {
          "type": "boolean"
        },
        "preserves_wedge_vocabulary": {
          "type": "boolean"
        },
        "preserves_export_field_vocabulary": {
          "type": "boolean"
        },
        "preserves_diagnosis_packet_vocabulary": {
          "type": "boolean"
        },
        "preserves_repair_hook_vocabulary": {
          "type": "boolean"
        },
        "preserves_recovery_posture_vocabulary": {
          "type": "boolean"
        },
        "preserves_known_limit_vocabulary": {
          "type": "boolean"
        },
        "preserves_downgrade_automation_vocabulary": {
          "type": "boolean"
        },
        "preserves_evidence_class_vocabulary": {
          "type": "boolean"
        },
        "supports_json_export": {
          "type": "boolean"
        },
        "raw_private_material_excluded": {
          "type": "boolean"
        },
        "ambient_authority_excluded": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": [
        "finding_kind",
        "severity",
        "summary"
      ],
      "properties": {
        "finding_kind": {
          "$ref": "#/$defs/finding_kind"
        },
        "severity": {
          "$ref": "#/$defs/finding_severity"
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}