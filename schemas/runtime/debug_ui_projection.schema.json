{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/debug_ui_projection.schema.json",
  "title": "DebugUiProjection",
  "description": "Beta debugger daily-use surfaces (breakpoints, call stack, variables, watch, evaluate, debug console). The shell projection is a literal view onto the canonical aureline_runtime::DebugSessionSnapshot plus shell-owned content rows. The closed vocabularies in this schema mirror the Rust types under crates/aureline-shell/src/debug_ui/.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "projection_id",
    "captured_at",
    "active_binding",
    "surfaces",
    "breakpoints",
    "call_stack_frames",
    "variable_scopes",
    "watch_expressions",
    "evaluate_requests",
    "console_lines",
    "honesty_marker_present",
    "export_safe_summary"
  ],
  "additionalProperties": false,
  "properties": {
    "record_kind": { "const": "shell_debug_ui_beta_projection_record" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "shared_contract_ref": { "const": "shell:debug_ui_beta:v1" },
    "projection_id": { "type": "string", "minLength": 1 },
    "captured_at": { "type": "string", "minLength": 1 },
    "active_binding": { "$ref": "#/$defs/ActiveBinding" },
    "surfaces": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": { "$ref": "#/$defs/SurfaceRow" }
    },
    "breakpoints": {
      "type": "array",
      "items": { "$ref": "#/$defs/BreakpointRow" }
    },
    "call_stack_frames": {
      "type": "array",
      "items": { "$ref": "#/$defs/CallStackFrameRow" }
    },
    "variable_scopes": {
      "type": "array",
      "items": { "$ref": "#/$defs/VariableScopeRow" }
    },
    "watch_expressions": {
      "type": "array",
      "items": { "$ref": "#/$defs/WatchExpressionRow" }
    },
    "evaluate_requests": {
      "type": "array",
      "items": { "$ref": "#/$defs/EvaluateRequestRow" }
    },
    "console_lines": {
      "type": "array",
      "items": { "$ref": "#/$defs/ConsoleLineRow" }
    },
    "honesty_marker_present": { "type": "boolean" },
    "export_safe_summary": { "type": "string" }
  },
  "$defs": {
    "SurfaceClassToken": {
      "type": "string",
      "enum": [
        "breakpoints",
        "call_stack",
        "variables",
        "watch",
        "evaluate",
        "debug_console"
      ]
    },
    "AvailabilityClassToken": {
      "type": "string",
      "enum": [
        "available",
        "narrowed_by_dropped_capability",
        "unavailable_missing_required_capability",
        "unavailable_during_reconnect",
        "unavailable_during_quarantine",
        "unavailable_no_active_session"
      ]
    },
    "FocusReturnClassToken": {
      "type": "string",
      "enum": ["invoking_surface", "session_card", "quarantine_card"]
    },
    "SourceJumpStabilityClassToken": {
      "type": "string",
      "enum": [
        "stable",
        "degraded_no_mapping",
        "unstable_during_reconnect",
        "unstable_during_quarantine",
        "not_offered_no_session"
      ]
    },
    "BreakpointKindToken": {
      "type": "string",
      "enum": [
        "line",
        "function",
        "conditional",
        "hit_count",
        "log_point",
        "data",
        "exception"
      ]
    },
    "DefectKindToken": {
      "type": "string",
      "enum": [
        "missing_required_surface",
        "duplicate_surface_class",
        "content_row_not_bound_to_active_session",
        "content_kept_on_unavailable_surface",
        "hidden_capability_downgrade",
        "hidden_missing_required_capability",
        "unsafe_source_jump_during_non_steady_state",
        "unsafe_focus_return_during_non_steady_state",
        "missing_honesty_marker",
        "unsupported_honesty_marker",
        "missing_keyboard_route"
      ]
    },
    "ActiveBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "workspace_id",
        "canonical_target_id",
        "target_class_token",
        "target_label",
        "adapter_id",
        "adapter_label",
        "state_class_token",
        "mode_token"
      ],
      "properties": {
        "session_id": { "type": "string" },
        "workspace_id": { "type": "string", "minLength": 1 },
        "canonical_target_id": { "type": "string" },
        "target_class_token": { "type": "string" },
        "target_label": { "type": "string" },
        "adapter_id": { "type": "string" },
        "adapter_label": { "type": "string" },
        "state_class_token": { "type": "string" },
        "mode_token": { "type": "string" }
      }
    },
    "SurfaceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "surface_class",
        "surface_class_token",
        "display_label",
        "availability_class",
        "availability_class_token",
        "focus_return_class",
        "focus_return_class_token",
        "source_jump_stability_class",
        "source_jump_stability_class_token",
        "keyboard_route_ref",
        "dependent_capability_tokens",
        "dropped_capability_tokens",
        "missing_required_capability_tokens",
        "content_row_count",
        "summary"
      ],
      "properties": {
        "record_kind": { "const": "shell_debug_ui_beta_surface_row_record" },
        "schema_version": { "type": "integer", "minimum": 1 },
        "surface_class": { "$ref": "#/$defs/SurfaceClassToken" },
        "surface_class_token": { "$ref": "#/$defs/SurfaceClassToken" },
        "display_label": { "type": "string", "minLength": 1 },
        "availability_class": { "$ref": "#/$defs/AvailabilityClassToken" },
        "availability_class_token": { "$ref": "#/$defs/AvailabilityClassToken" },
        "focus_return_class": { "$ref": "#/$defs/FocusReturnClassToken" },
        "focus_return_class_token": { "$ref": "#/$defs/FocusReturnClassToken" },
        "source_jump_stability_class": { "$ref": "#/$defs/SourceJumpStabilityClassToken" },
        "source_jump_stability_class_token": { "$ref": "#/$defs/SourceJumpStabilityClassToken" },
        "keyboard_route_ref": { "type": "string", "minLength": 1 },
        "dependent_capability_tokens": { "type": "array", "items": { "type": "string" } },
        "dropped_capability_tokens": { "type": "array", "items": { "type": "string" } },
        "missing_required_capability_tokens": { "type": "array", "items": { "type": "string" } },
        "content_row_count": { "type": "integer", "minimum": 0 },
        "summary": { "type": "string" }
      }
    },
    "BoundContentRowProps": {
      "type": "object",
      "required": ["session_id", "canonical_target_id"],
      "properties": {
        "session_id": { "type": "string", "minLength": 1 },
        "canonical_target_id": { "type": "string", "minLength": 1 }
      }
    },
    "BreakpointRow": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [{ "$ref": "#/$defs/BoundContentRowProps" }],
      "required": [
        "breakpoint_id",
        "session_id",
        "canonical_target_id",
        "kind",
        "kind_token",
        "label",
        "verified",
        "enabled"
      ],
      "properties": {
        "breakpoint_id": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "canonical_target_id": { "type": "string", "minLength": 1 },
        "kind": { "$ref": "#/$defs/BreakpointKindToken" },
        "kind_token": { "$ref": "#/$defs/BreakpointKindToken" },
        "source_ref": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "label": { "type": "string", "minLength": 1 },
        "verified": { "type": "boolean" },
        "enabled": { "type": "boolean" }
      }
    },
    "CallStackFrameRow": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [{ "$ref": "#/$defs/BoundContentRowProps" }],
      "required": [
        "frame_id",
        "session_id",
        "canonical_target_id",
        "thread_id",
        "frame_index",
        "function_label",
        "is_focused_frame"
      ],
      "properties": {
        "frame_id": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "canonical_target_id": { "type": "string", "minLength": 1 },
        "thread_id": { "type": "string", "minLength": 1 },
        "frame_index": { "type": "integer", "minimum": 0 },
        "function_label": { "type": "string", "minLength": 1 },
        "source_ref": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "is_focused_frame": { "type": "boolean" }
      }
    },
    "VariableScopeRow": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [{ "$ref": "#/$defs/BoundContentRowProps" }],
      "required": [
        "scope_id",
        "session_id",
        "canonical_target_id",
        "frame_id",
        "scope_name",
        "variable_count",
        "expanded"
      ],
      "properties": {
        "scope_id": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "canonical_target_id": { "type": "string", "minLength": 1 },
        "frame_id": { "type": "string", "minLength": 1 },
        "scope_name": { "type": "string", "minLength": 1 },
        "variable_count": { "type": "integer", "minimum": 0 },
        "expanded": { "type": "boolean" }
      }
    },
    "WatchExpressionRow": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [{ "$ref": "#/$defs/BoundContentRowProps" }],
      "required": [
        "watch_id",
        "session_id",
        "canonical_target_id",
        "expression",
        "last_value_summary",
        "last_evaluation_failed"
      ],
      "properties": {
        "watch_id": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "canonical_target_id": { "type": "string", "minLength": 1 },
        "expression": { "type": "string", "minLength": 1 },
        "last_value_summary": { "type": "string" },
        "last_evaluation_failed": { "type": "boolean" }
      }
    },
    "EvaluateRequestRow": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [{ "$ref": "#/$defs/BoundContentRowProps" }],
      "required": [
        "request_id",
        "session_id",
        "canonical_target_id",
        "expression",
        "result_summary",
        "errored",
        "issued_at"
      ],
      "properties": {
        "request_id": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "canonical_target_id": { "type": "string", "minLength": 1 },
        "expression": { "type": "string", "minLength": 1 },
        "result_summary": { "type": "string" },
        "errored": { "type": "boolean" },
        "issued_at": { "type": "string", "minLength": 1 }
      }
    },
    "ConsoleLineRow": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [{ "$ref": "#/$defs/BoundContentRowProps" }],
      "required": [
        "line_id",
        "session_id",
        "canonical_target_id",
        "stream_class_token",
        "body",
        "observed_at"
      ],
      "properties": {
        "line_id": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "canonical_target_id": { "type": "string", "minLength": 1 },
        "stream_class_token": {
          "type": "string",
          "enum": ["stdout", "stderr", "log_point", "adapter_note"]
        },
        "body": { "type": "string" },
        "observed_at": { "type": "string", "minLength": 1 }
      }
    }
  }
}
