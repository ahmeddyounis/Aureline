{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/discovery_diff.schema.json",
  "title": "Aureline build-intelligence discovery-diff review",
  "description": "Boundary schema for discovery-diff reviews produced after adapter or config refresh. The review separates added, removed, renamed, downgraded-confidence, newly-heuristic, newly-exact, and now-unresolved targets so refresh review, support export, and replay cannot collapse material target changes into a generic changed state. Raw paths, raw command lines, environment bodies, and secrets do not cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/discovery_diff_review_record" }
  ],
  "$defs": {
    "build_intelligence_schema_version": {
      "type": "integer",
      "const": 1
    },
    "discovery_diff_change": {
      "type": "string",
      "enum": [
        "added",
        "removed",
        "renamed",
        "downgraded_confidence",
        "newly_heuristic",
        "newly_exact",
        "now_unresolved"
      ]
    },
    "discovery_diff_item": {
      "type": "object",
      "required": ["change_class", "change_token", "action_ref", "summary"],
      "additionalProperties": false,
      "properties": {
        "change_class": { "$ref": "#/$defs/discovery_diff_change" },
        "change_token": { "type": "string" },
        "previous_target_id": { "type": "string" },
        "current_target_id": { "type": "string" },
        "previous_name": { "type": "string" },
        "current_name": { "type": "string" },
        "previous_lane_type_token": { "type": "string" },
        "current_lane_type_token": { "type": "string" },
        "previous_exactness_status_token": { "type": "string" },
        "current_exactness_status_token": { "type": "string" },
        "action_ref": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "discovery_diff_review_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "diff_id",
        "workspace_id",
        "previous_refresh_id",
        "current_refresh_id",
        "reviewed_at",
        "added",
        "removed",
        "renamed",
        "downgraded_confidence",
        "newly_heuristic",
        "newly_exact",
        "now_unresolved",
        "summary",
        "redaction_safe"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "discovery_diff_review_record" },
        "schema_version": { "$ref": "#/$defs/build_intelligence_schema_version" },
        "diff_id": { "type": "string" },
        "workspace_id": { "type": "string" },
        "previous_refresh_id": { "type": "string" },
        "current_refresh_id": { "type": "string" },
        "reviewed_at": { "type": "string" },
        "added": {
          "type": "array",
          "items": { "$ref": "#/$defs/discovery_diff_item" }
        },
        "removed": {
          "type": "array",
          "items": { "$ref": "#/$defs/discovery_diff_item" }
        },
        "renamed": {
          "type": "array",
          "items": { "$ref": "#/$defs/discovery_diff_item" }
        },
        "downgraded_confidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/discovery_diff_item" }
        },
        "newly_heuristic": {
          "type": "array",
          "items": { "$ref": "#/$defs/discovery_diff_item" }
        },
        "newly_exact": {
          "type": "array",
          "items": { "$ref": "#/$defs/discovery_diff_item" }
        },
        "now_unresolved": {
          "type": "array",
          "items": { "$ref": "#/$defs/discovery_diff_item" }
        },
        "summary": { "type": "string" },
        "redaction_safe": { "type": "boolean", "const": true }
      }
    }
  }
}
