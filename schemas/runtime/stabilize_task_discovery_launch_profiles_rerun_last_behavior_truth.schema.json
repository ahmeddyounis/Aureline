{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/stabilize_task_discovery_launch_profiles_rerun_last_behavior_truth.schema.json",
  "title": "Aureline stabilize-task-discovery / launch-profiles / rerun-last / task-event truth packet",
  "description": "Boundary schema for the stable task-event truth packet certifying local, remote/helper, notebook, and imported-provider task-event lanes at the M4 launch-stable grade. Every launch_stable lane MUST publish a task_event_truth_quality row plus the full four-wedge admission coverage (task_discovery, launch_profile, rerun_last, task_event), the full six envelope-field bindings (event_id, execution_context_ref, adapter_identity, provider_identity, confidence_flag, fallback_flag), the full four downstream surface bindings (problems, output_channel, evidence_export, rerun_surface), an additive_detail_preservation row attesting preserved additive detail, and a lineage_admission row binding execution_context_id. The packet is the single truth that the editor run surface, task panel, problems panel, output channel, evidence export, rerun surface, CLI/headless inspector, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies, fork their own task-event semantics, or flatten additive detail into display text.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "stabilize_task_discovery_launch_profiles_rerun_last_behavior_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/task_event_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/task_event_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 11,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "task_event_lane_class": {
      "enum": [
        "local_lane",
        "remote_helper_lane",
        "notebook_lane",
        "imported_provider_lane"
      ]
    },
    "task_event_row_class": {
      "enum": [
        "task_event_truth_quality",
        "wedge_admission",
        "envelope_field_binding",
        "surface_binding",
        "additive_detail_preservation",
        "lineage_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "wedge_class": {
      "enum": [
        "task_discovery",
        "launch_profile",
        "rerun_last",
        "task_event",
        "not_applicable"
      ]
    },
    "envelope_field_class": {
      "enum": [
        "event_id",
        "execution_context_ref",
        "adapter_identity",
        "provider_identity",
        "confidence_flag",
        "fallback_flag",
        "not_applicable"
      ]
    },
    "downstream_surface_class": {
      "enum": [
        "problems",
        "output_channel",
        "evidence_export",
        "rerun_surface",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "local_lane_subset_only",
        "remote_helper_subset_only",
        "notebook_subset_only",
        "imported_provider_subset_only",
        "wedge_admission_subset_only",
        "envelope_field_subset_only",
        "downstream_surface_subset_only",
        "additive_detail_dropped",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_wedge_admission_gap",
        "auto_narrow_on_envelope_field_gap",
        "auto_narrow_on_downstream_surface_gap",
        "auto_narrow_on_additive_detail_dropped",
        "auto_narrow_on_lineage_break",
        "auto_narrow_on_adapter_identity_drift",
        "auto_narrow_on_confidence_flag_absent",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "task_event_truth_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_lane_coverage",
        "missing_wedge_admission_coverage",
        "missing_envelope_field_coverage",
        "missing_downstream_surface_coverage",
        "missing_additive_detail_preservation",
        "missing_lineage_admission",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "wedge_not_applicable",
        "wedge_not_permitted_on_row_class",
        "envelope_field_not_applicable",
        "envelope_field_not_permitted_on_row_class",
        "downstream_surface_not_applicable",
        "downstream_surface_not_permitted_on_row_class",
        "lineage_admission_missing_execution_context_id",
        "additive_detail_row_admits_flattening",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "wedge_vocabulary_collapsed",
        "envelope_field_vocabulary_collapsed",
        "downstream_surface_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "task_event_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "wedge_class",
        "envelope_field_class",
        "downstream_surface_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/task_event_lane_class" },
        "row_class": { "$ref": "#/$defs/task_event_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "wedge_class": { "$ref": "#/$defs/wedge_class" },
        "envelope_field_class": { "$ref": "#/$defs/envelope_field_class" },
        "downstream_surface_class": { "$ref": "#/$defs/downstream_surface_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/task_event_truth_confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_id_binding": { "$ref": "#/$defs/non_empty_string" },
        "additive_detail_preserved": { "type": "boolean" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "task_event_truth_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_wedge_vocabulary",
        "preserves_envelope_field_vocabulary",
        "preserves_downstream_surface_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "editor_run_surface",
            "task_panel",
            "problems_panel",
            "output_channel",
            "evidence_export",
            "rerun_surface",
            "cli_headless",
            "support_export",
            "release_proof_index",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "task_event_truth_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_wedge_vocabulary": { "type": "boolean" },
        "preserves_envelope_field_vocabulary": { "type": "boolean" },
        "preserves_downstream_surface_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
