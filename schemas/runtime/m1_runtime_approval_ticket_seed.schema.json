{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/m1_runtime_approval_ticket_seed.schema.json",
  "title": "Aureline M1 runtime approval-ticket seed envelope",
  "description": "Boundary schema for artifacts/runtime/m1_runtime_approval_ticket_seed.yaml. The envelope pins the canonical row vocabulary at approval_ticket.schema.json, the reviewer-facing landing page at docs/runtime/m1_authority_model.md, the upstream governance authority-ticket contract, the upstream integration approval-ticket contract, the build-identity record the validation lane embeds, the validation-lane registry ref, the closed authority_class / side_effect_class / issuer_class / request_origin_class / use_posture / revocation_posture_class / failure-drill vocabularies, the required coverage lists (authority classes, side-effect classes, request origins, revocation postures), the named-runtime-consumer set, and the named failure-drill ids that the per-row drills must draw from. Approval-ticket example fixtures conform to the row schema; the envelope cannot relax that contract.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "status",
    "matrix_id",
    "owner_dri",
    "overview_page",
    "upstream_authority_contract_ref",
    "upstream_integration_approval_ticket_schema_ref",
    "row_schema_ref",
    "build_identity_ref",
    "validation_lane_ref",
    "authority_class_vocabulary",
    "side_effect_class_vocabulary",
    "issuer_class_vocabulary",
    "request_origin_class_vocabulary",
    "actor_class_vocabulary",
    "use_posture_class_vocabulary",
    "revocation_posture_class_vocabulary",
    "redaction_class_vocabulary",
    "high_risk_flag_vocabulary",
    "denial_reason_vocabulary",
    "invalidation_reason_vocabulary",
    "audit_event_id_vocabulary",
    "failure_drill_id_vocabulary",
    "required_authority_class_coverage",
    "required_side_effect_class_coverage",
    "required_request_origin_class_coverage",
    "required_revocation_posture_class_coverage",
    "named_runtime_consumers",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": ["seeded", "stabilising", "stable"]
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "matrix_id": {
      "type": "string",
      "const": "m1_runtime_approval_ticket_seed"
    },
    "owner_dri": {
      "type": "string",
      "pattern": "^@[a-zA-Z0-9_-]+$"
    },
    "overview_page": {
      "type": "string",
      "const": "docs/runtime/m1_authority_model.md"
    },
    "upstream_authority_contract_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Upstream governance authority-ticket contract the runtime seed projects against. Must resolve on disk."
    },
    "upstream_integration_approval_ticket_schema_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Upstream provider-plane approval-ticket schema admitted under external_mutation tickets. Must resolve on disk."
    },
    "row_schema_ref": {
      "type": "string",
      "const": "schemas/runtime/approval_ticket.schema.json"
    },
    "build_identity_ref": {
      "type": "string",
      "minLength": 1
    },
    "validation_lane_ref": {
      "type": "string",
      "minLength": 1
    },
    "authority_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "local_mutation",
          "external_mutation",
          "credential_projection",
          "privileged_attach"
        ]
      },
      "description": "Closed M1 authority-class vocabulary. MUST agree exactly with the row schema's authority_class $defs enum."
    },
    "side_effect_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 6,
      "items": { "type": "string", "minLength": 1 }
    },
    "issuer_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": ["shell", "policy_service", "supervisor"]
      }
    },
    "request_origin_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 10,
      "items": { "type": "string", "minLength": 1 }
    },
    "actor_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 6,
      "items": { "type": "string", "minLength": 1 }
    },
    "use_posture_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": ["single_use", "bounded_reuse", "session_scoped"]
      }
    },
    "revocation_posture_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": { "type": "string", "minLength": 1 }
    },
    "high_risk_flag_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": { "type": "string", "minLength": 1 }
    },
    "denial_reason_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 8,
      "items": { "type": "string", "minLength": 1 }
    },
    "invalidation_reason_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": { "type": "string", "minLength": 1 }
    },
    "audit_event_id_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 6,
      "items": { "type": "string", "minLength": 1 }
    },
    "failure_drill_id_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "description": "Closed vocabulary of named failure drills the per-row failure_drill blocks must draw from."
    },
    "required_authority_class_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "local_mutation",
          "external_mutation",
          "credential_projection",
          "privileged_attach"
        ]
      },
      "description": "Every M1 protected authority class MUST appear at least once across the seed entries."
    },
    "required_side_effect_class_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_request_origin_class_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 2,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_revocation_posture_class_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 2,
      "items": { "type": "string", "minLength": 1 }
    },
    "named_runtime_consumers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "consumer_id",
          "consumer_class",
          "consumer_ref",
          "consumed_fields"
        ],
        "properties": {
          "consumer_id": { "type": "string", "minLength": 1 },
          "consumer_class": {
            "type": "string",
            "enum": [
              "review_docs_landing_page",
              "rust_runtime_validator",
              "ci_schema_validator",
              "support_or_release_surface",
              "docs_or_help_surface",
              "design_packet"
            ]
          },
          "consumer_ref": { "type": "string", "minLength": 1 },
          "consumed_fields": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "notes": { "type": "string" }
        }
      },
      "description": "Named live consumers that read the runtime approval-ticket seed. The lane resolves consumer_ref on disk and asserts consumed_fields is non-empty so a consumer cannot regress to mentioned-but-unread."
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "approval_ticket_profile_id",
          "authority_class",
          "side_effect_class",
          "issuer_class",
          "request_origin_class",
          "use_posture",
          "revocation_posture_class",
          "example_payload_ref",
          "owner_dri",
          "failure_drill"
        ],
        "properties": {
          "approval_ticket_profile_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
          },
          "authority_class": {
            "type": "string",
            "enum": [
              "local_mutation",
              "external_mutation",
              "credential_projection",
              "privileged_attach"
            ]
          },
          "side_effect_class": { "type": "string", "minLength": 1 },
          "issuer_class": {
            "type": "string",
            "enum": ["shell", "policy_service", "supervisor"]
          },
          "request_origin_class": { "type": "string", "minLength": 1 },
          "use_posture": {
            "type": "string",
            "enum": ["single_use", "bounded_reuse", "session_scoped"]
          },
          "revocation_posture_class": {
            "type": "string",
            "minLength": 1
          },
          "example_payload_ref": {
            "type": "string",
            "minLength": 1,
            "description": "Path to the JSON fixture under fixtures/runtime/approval_ticket_examples/ that validates against the row schema."
          },
          "owner_dri": {
            "type": "string",
            "pattern": "^@[a-zA-Z0-9_-]+$"
          },
          "notes": { "type": "string" },
          "failure_drill": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "drill_id",
              "forced_input",
              "expected_check_id",
              "actionable_next_action"
            ],
            "properties": {
              "drill_id": { "type": "string", "minLength": 1 },
              "forced_input": {
                "type": "object",
                "additionalProperties": true,
                "minProperties": 1
              },
              "expected_check_id": { "type": "string", "minLength": 1 },
              "actionable_next_action": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
