{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/stabilize_the_artifact_manager_preview_runtime_inspectors_and_truth.schema.json",
  "title": "Aureline artifact-manager / preview-runtime-inspector / evidence-export truth packet",
  "description": "Boundary schema for the stable artifact-manager, preview/runtime inspector, and evidence-export truth packet covering the artifact_manager_lane, preview_runtime_inspector_lane, signal_slice_lane, and evidence_export_lane. Every launch_stable lane MUST publish wedge_admission rows for artifact_chronology_replay_truth, signal_slice_identity_truth, evidence_export_review_truth, and cross_surface_evidence_lineage_truth; signal_slice_kind_admission rows for logs_slice, metrics_slice, traces_slice, and test_artifact_slice; slice_freshness_admission rows for live_stream, buffered_replay, cached_snapshot, imported_evidence, truncated_view, and exported_copy; replay_chronology_admission rows for recorded, not_recorded, unsupported, restart_with_recording_available, and partially_recorded; retention_class_admission rows for session_only_retention, session_plus_window_retention, policy_bounded_retention, archived_retention, and imported_external_retention; consumer_surface_binding rows for artifact_manager_surface, preview_runtime_inspector_surface, evidence_export_sheet_surface, cli_headless_inspect, support_export, help_about, and conformance_dashboard; and a lineage_admission row binding execution_context_id. The packet is the single truth that the artifact manager, preview/runtime inspectors, evidence-export sheet, CLI/headless inspector, support export, Help/About proof card, and conformance dashboard all read; surfaces MUST NOT fork local runtime semantics, paraphrase slice freshness, collapse replay/chronology into a single recorded/not-recorded bit, mistake exported copies for live runtime truth, or treat logs/traces/test artifacts as pane-local blobs.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": {
      "const": "stabilize_the_artifact_manager_preview_runtime_inspectors_and_truth_stable_packet"
    },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/evidence_export_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence_export_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "evidence_export_lane_class": {
      "enum": [
        "artifact_manager_lane",
        "preview_runtime_inspector_lane",
        "signal_slice_lane",
        "evidence_export_lane"
      ]
    },
    "evidence_export_row_class": {
      "enum": [
        "evidence_export_quality",
        "wedge_admission",
        "signal_slice_kind_admission",
        "slice_freshness_admission",
        "replay_chronology_admission",
        "retention_class_admission",
        "consumer_surface_binding",
        "lineage_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "wedge_class": {
      "enum": [
        "artifact_chronology_replay_truth",
        "signal_slice_identity_truth",
        "evidence_export_review_truth",
        "cross_surface_evidence_lineage_truth",
        "not_applicable"
      ]
    },
    "signal_slice_kind_class": {
      "enum": [
        "logs_slice",
        "metrics_slice",
        "traces_slice",
        "test_artifact_slice",
        "not_applicable"
      ]
    },
    "slice_freshness_class": {
      "enum": [
        "live_stream",
        "buffered_replay",
        "cached_snapshot",
        "imported_evidence",
        "truncated_view",
        "exported_copy",
        "not_applicable"
      ]
    },
    "replay_chronology_state_class": {
      "enum": [
        "recorded",
        "not_recorded",
        "unsupported",
        "restart_with_recording_available",
        "partially_recorded",
        "not_applicable"
      ]
    },
    "retention_class": {
      "enum": [
        "session_only_retention",
        "session_plus_window_retention",
        "policy_bounded_retention",
        "archived_retention",
        "imported_external_retention",
        "not_applicable"
      ]
    },
    "consumer_surface_class": {
      "enum": [
        "artifact_manager_surface",
        "preview_runtime_inspector_surface",
        "evidence_export_sheet_surface",
        "cli_headless_inspect",
        "support_export",
        "help_about",
        "conformance_dashboard",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "artifact_manager_subset_only",
        "preview_runtime_inspector_subset_only",
        "signal_slice_subset_only",
        "evidence_export_subset_only",
        "wedge_subset_only",
        "signal_slice_kind_subset_only",
        "slice_freshness_subset_only",
        "replay_chronology_state_subset_only",
        "retention_class_subset_only",
        "consumer_surface_subset_only",
        "imported_provider_only",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_signal_slice_kind_gap",
        "auto_narrow_on_slice_freshness_gap",
        "auto_narrow_on_replay_chronology_gap",
        "auto_narrow_on_retention_class_gap",
        "auto_narrow_on_signal_slice_identity_gap",
        "auto_narrow_on_evidence_export_review_gap",
        "auto_narrow_on_consumer_surface_gap",
        "auto_narrow_on_cross_surface_evidence_lineage_drift",
        "auto_narrow_on_lineage_break",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_evidence_export_lane_coverage",
        "missing_wedge_coverage",
        "missing_signal_slice_kind_coverage",
        "missing_slice_freshness_coverage",
        "missing_replay_chronology_state_coverage",
        "missing_retention_class_coverage",
        "missing_consumer_surface_coverage",
        "missing_lineage_admission",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "wedge_not_applicable",
        "wedge_not_permitted_on_row_class",
        "signal_slice_kind_not_applicable",
        "signal_slice_kind_not_permitted_on_row_class",
        "slice_freshness_not_applicable",
        "slice_freshness_not_permitted_on_row_class",
        "replay_chronology_state_not_applicable",
        "replay_chronology_state_not_permitted_on_row_class",
        "retention_class_not_applicable",
        "retention_class_not_permitted_on_row_class",
        "consumer_surface_not_applicable",
        "consumer_surface_not_permitted_on_row_class",
        "lineage_admission_missing_execution_context_id",
        "cross_surface_evidence_lineage_not_attested",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "wedge_vocabulary_collapsed",
        "signal_slice_kind_vocabulary_collapsed",
        "slice_freshness_vocabulary_collapsed",
        "replay_chronology_state_vocabulary_collapsed",
        "retention_class_vocabulary_collapsed",
        "consumer_surface_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "evidence_export_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "wedge_class",
        "signal_slice_kind_class",
        "slice_freshness_class",
        "replay_chronology_state_class",
        "retention_class",
        "consumer_surface_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/evidence_export_lane_class" },
        "row_class": { "$ref": "#/$defs/evidence_export_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "wedge_class": { "$ref": "#/$defs/wedge_class" },
        "signal_slice_kind_class": { "$ref": "#/$defs/signal_slice_kind_class" },
        "slice_freshness_class": { "$ref": "#/$defs/slice_freshness_class" },
        "replay_chronology_state_class": { "$ref": "#/$defs/replay_chronology_state_class" },
        "retention_class": { "$ref": "#/$defs/retention_class" },
        "consumer_surface_class": { "$ref": "#/$defs/consumer_surface_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_id_binding": { "$ref": "#/$defs/non_empty_string" },
        "cross_surface_evidence_lineage_attested": { "type": "boolean" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "evidence_export_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_wedge_vocabulary",
        "preserves_signal_slice_kind_vocabulary",
        "preserves_slice_freshness_vocabulary",
        "preserves_replay_chronology_state_vocabulary",
        "preserves_retention_class_vocabulary",
        "preserves_consumer_surface_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "artifact_manager_surface",
            "preview_runtime_inspector_surface",
            "evidence_export_sheet_surface",
            "cli_headless_inspect",
            "support_export",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_export_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_wedge_vocabulary": { "type": "boolean" },
        "preserves_signal_slice_kind_vocabulary": { "type": "boolean" },
        "preserves_slice_freshness_vocabulary": { "type": "boolean" },
        "preserves_replay_chronology_state_vocabulary": { "type": "boolean" },
        "preserves_retention_class_vocabulary": { "type": "boolean" },
        "preserves_consumer_surface_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
