{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/publish_execution_plane_certification_packets_for_local_remote.schema.json",
  "title": "Aureline execution-plane certification truth packet",
  "description": "Boundary schema for the stable execution-plane certification truth packet certifying local, remote/helper, and enterprise-network execution-plane lanes at the M4 launch-stable grade with surface-binding coverage (terminal, task, test, debug, artifact, request_workspace, preview, cli_headless, docs_help, support_export, conformance_dashboard), route-state admission coverage (local_route, remote_helper_route, enterprise_network_route, route_drift, blocked_target), reconnect-state admission coverage (reconnect_required, reconnect_honest, restore_no_rerun), degraded-helper-state admission coverage (capability_degraded, helper_offline, helper_skew), artifact-provenance-state admission coverage (provenance_tracked, provenance_missing), target admission, restore-rerun honesty, lineage admission rows binding execution_context_id, known limits, downgrade automation, and evidence binding. The packet is the single truth that the editor run surface, terminal pane, task panel, test explorer, debug session, artifact viewer, request editor, preview surface, CLI/headless inspector, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies, fork their own runtime semantics, or paraphrase execution-plane posture.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "publish_execution_plane_certification_packets_for_local_remote_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/execution_plane_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/execution_plane_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "execution_plane_lane_class": {
      "enum": [
        "local_lane",
        "remote_helper_lane",
        "enterprise_network_lane"
      ]
    },
    "execution_plane_row_class": {
      "enum": [
        "execution_plane_certification_quality",
        "surface_binding",
        "target_admission",
        "route_admission",
        "restore_rerun_honesty",
        "reconnect_admission",
        "degraded_helper_admission",
        "artifact_provenance_admission",
        "lineage_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "surface_binding_class": {
      "enum": [
        "terminal",
        "task",
        "test",
        "debug",
        "artifact",
        "request_workspace",
        "preview",
        "cli_headless",
        "docs_help",
        "support_export",
        "conformance_dashboard",
        "not_applicable"
      ]
    },
    "route_state_class": {
      "enum": [
        "local_route",
        "remote_helper_route",
        "enterprise_network_route",
        "route_drift",
        "blocked_target",
        "not_applicable"
      ]
    },
    "reconnect_state_class": {
      "enum": [
        "reconnect_required",
        "reconnect_honest",
        "restore_no_rerun",
        "not_applicable"
      ]
    },
    "degraded_helper_state_class": {
      "enum": [
        "capability_degraded",
        "helper_offline",
        "helper_skew",
        "not_applicable"
      ]
    },
    "artifact_provenance_state_class": {
      "enum": [
        "provenance_tracked",
        "provenance_missing",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "local_lane_subset_only",
        "remote_helper_subset_only",
        "enterprise_network_subset_only",
        "route_admission_subset_only",
        "reconnect_admission_subset_only",
        "degraded_helper_subset_only",
        "artifact_provenance_subset_only",
        "surface_binding_subset_only",
        "unsupported_runtime_target",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_target_unreachable",
        "auto_narrow_on_helper_skew",
        "auto_narrow_on_route_drift",
        "auto_narrow_on_blocked_target",
        "auto_narrow_on_reconnect_gap",
        "auto_narrow_on_silent_rerun",
        "auto_narrow_on_degraded_helper",
        "auto_narrow_on_artifact_provenance_gap",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "confidence_class": {
      "enum": [
        "high_confidence",
        "medium_confidence",
        "low_confidence"
      ]
    },
    "promotion_state": {
      "enum": [
        "stable",
        "narrowed_below_stable",
        "blocks_stable"
      ]
    },
    "finding_severity": {
      "enum": [
        "info",
        "warning",
        "blocker"
      ]
    },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_execution_lane_coverage",
        "missing_surface_binding_coverage",
        "missing_target_admission",
        "missing_route_admission",
        "missing_restore_rerun_honesty",
        "missing_reconnect_admission",
        "missing_degraded_helper_admission",
        "missing_artifact_provenance_admission",
        "missing_lineage_admission",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "surface_binding_not_applicable",
        "surface_binding_not_permitted_on_row_class",
        "route_state_not_applicable",
        "route_state_not_permitted_on_row_class",
        "reconnect_state_not_applicable",
        "reconnect_state_not_permitted_on_row_class",
        "degraded_helper_state_not_applicable",
        "degraded_helper_state_not_permitted_on_row_class",
        "artifact_provenance_state_not_applicable",
        "artifact_provenance_state_not_permitted_on_row_class",
        "lineage_admission_missing_execution_context_id",
        "restore_rerun_honesty_admits_silent_rerun",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "surface_binding_vocabulary_collapsed",
        "route_state_vocabulary_collapsed",
        "reconnect_state_vocabulary_collapsed",
        "degraded_helper_state_vocabulary_collapsed",
        "artifact_provenance_state_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "consumer_surface": {
      "enum": [
        "editor_run_surface",
        "terminal_pane",
        "task_panel",
        "cli_headless",
        "support_export",
        "release_proof_index",
        "help_about",
        "conformance_dashboard"
      ]
    },
    "execution_plane_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "surface_binding_class",
        "route_state_class",
        "reconnect_state_class",
        "degraded_helper_state_class",
        "artifact_provenance_state_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/execution_plane_lane_class" },
        "row_class": { "$ref": "#/$defs/execution_plane_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "surface_binding_class": { "$ref": "#/$defs/surface_binding_class" },
        "route_state_class": { "$ref": "#/$defs/route_state_class" },
        "reconnect_state_class": { "$ref": "#/$defs/reconnect_state_class" },
        "degraded_helper_state_class": { "$ref": "#/$defs/degraded_helper_state_class" },
        "artifact_provenance_state_class": { "$ref": "#/$defs/artifact_provenance_state_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "type": ["string", "null"] },
        "execution_context_id_binding": { "type": ["string", "null"] },
        "restore_preserves_no_rerun": { "type": "boolean" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "execution_plane_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_surface_binding_vocabulary",
        "preserves_route_state_vocabulary",
        "preserves_reconnect_state_vocabulary",
        "preserves_degraded_helper_state_vocabulary",
        "preserves_artifact_provenance_state_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "execution_plane_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_surface_binding_vocabulary": { "type": "boolean" },
        "preserves_route_state_vocabulary": { "type": "boolean" },
        "preserves_reconnect_state_vocabulary": { "type": "boolean" },
        "preserves_degraded_helper_state_vocabulary": { "type": "boolean" },
        "preserves_artifact_provenance_state_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
