{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/prebuild_descriptor_alpha.schema.json",
  "title": "Aureline prebuild descriptor alpha seed contract",
  "description": "Alpha seed contract for prebuild metadata and warm-start descriptors. This schema consumes the environment-capsule and execution-context vocabulary by token, and describes source identity, freshness, target boundary, reuse posture, and resume capability without claiming that a full prebuild materializer exists. Raw secrets, raw environment bodies, and raw command lines are excluded by construction.",
  "oneOf": [
    { "$ref": "#/$defs/prebuild_descriptor_alpha_record" },
    { "$ref": "#/$defs/warm_start_descriptor_seed_manifest" }
  ],
  "$defs": {
    "prebuild_descriptor_alpha_schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "record_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_./:#@-]*$"
    },
    "dotted_lower_snake_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "content_digest": {
      "type": "string",
      "pattern": "^(sha256|sha384|sha512|blake3):[0-9a-f]{32,128}$"
    },
    "path_ref": {
      "type": "string",
      "minLength": 1
    },
    "target_class": {
      "type": "string",
      "enum": [
        "local_host",
        "ssh_remote",
        "container_local",
        "devcontainer",
        "remote_workspace_vm",
        "prebuild_runtime",
        "managed_workspace",
        "notebook_kernel_local",
        "notebook_kernel_remote",
        "ai_sandbox"
      ],
      "description": "Re-export of the execution-context target-class vocabulary."
    },
    "boundary_class": {
      "type": "string",
      "enum": [
        "local_host_boundary",
        "container_kernel_boundary",
        "devcontainer_boundary",
        "remote_ssh_boundary",
        "remote_agent_boundary",
        "managed_workspace_boundary",
        "notebook_kernel_boundary",
        "ai_sandbox_boundary"
      ]
    },
    "capsule_location_class": {
      "type": "string",
      "enum": [
        "workspace_local",
        "prebuild_snapshot",
        "devcontainer_image",
        "container_local_ephemeral",
        "remote_ssh_host",
        "remote_workspace_vm",
        "managed_workspace_control_plane",
        "notebook_kernel_local",
        "notebook_kernel_remote",
        "ai_sandbox_ephemeral",
        "hosted_review_replay"
      ]
    },
    "trust_state": {
      "type": "string",
      "enum": ["trusted", "restricted", "pending_evaluation"]
    },
    "identity_mode": {
      "type": "string",
      "enum": ["account_free_local", "self_hosted_org", "managed_convenience"]
    },
    "policy_epoch": {
      "type": "integer",
      "minimum": 0
    },
    "platform_arch": {
      "type": "string",
      "enum": [
        "darwin_arm64",
        "darwin_x86_64",
        "linux_arm64",
        "linux_x86_64",
        "windows_x86_64",
        "platform_pending"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "workspace_template_seed",
        "environment_capsule",
        "prebuild_snapshot",
        "devcontainer_image",
        "managed_workspace_snapshot",
        "cache_index",
        "launch_bundle",
        "project_entry_restore"
      ]
    },
    "producer_class": {
      "type": "string",
      "enum": [
        "first_party_seed",
        "user_local_cache",
        "team_managed",
        "managed_control_plane",
        "mirror_imported",
        "unknown"
      ]
    },
    "freshness_state": {
      "type": "string",
      "enum": ["current", "warming", "cached", "stale", "partial", "offline", "unknown"]
    },
    "age_class": {
      "type": "string",
      "enum": [
        "within_window",
        "near_expiry",
        "expired",
        "not_observed",
        "not_applicable"
      ]
    },
    "prebuild_reuse_state": {
      "type": "string",
      "enum": [
        "not_applicable",
        "candidate",
        "reused",
        "rejected_drift",
        "rejected_policy",
        "rejected_trust"
      ],
      "description": "Re-export of the execution-context prebuild reuse-state vocabulary."
    },
    "prebuild_invalidation_reason": {
      "type": "string",
      "enum": [
        "capsule_drift",
        "policy_epoch_advanced",
        "trust_state_restricted",
        "trust_state_pending",
        "target_class_changed"
      ],
      "description": "Re-export of the execution-context prebuild invalidation vocabulary."
    },
    "cache_disposition": {
      "type": "string",
      "enum": [
        "cold",
        "warm",
        "prebuild_reused",
        "capsule_reused",
        "rejected_drift",
        "rejected_policy",
        "rejected_trust"
      ],
      "description": "Re-export of the execution-context cache-disposition vocabulary."
    },
    "warm_start_state": {
      "type": "string",
      "enum": [
        "cold_required",
        "warm_candidate",
        "partial_warm_candidate",
        "live_resume_candidate",
        "stale_warm_candidate",
        "blocked_until_review",
        "unavailable"
      ]
    },
    "resume_capability": {
      "type": "string",
      "enum": [
        "not_resume_capable",
        "resume_metadata_only",
        "resume_requires_reauth",
        "resume_ready_after_revalidation",
        "resume_blocked_stale_target"
      ]
    },
    "cache_class": {
      "type": "string",
      "enum": [
        "container_layer",
        "toolchain_cache",
        "dependency_cache",
        "index_shard",
        "artifact_mirror",
        "extension_lock",
        "workspace_snapshot",
        "restore_journal"
      ]
    },
    "descriptor_stage": {
      "type": "string",
      "enum": ["seed_metadata_only", "resolver_candidate", "runtime_observed"]
    },
    "materializer_claim": {
      "type": "string",
      "enum": [
        "metadata_only_no_materializer_claim",
        "observed_materializer_record",
        "runtime_owned_materializer"
      ]
    },
    "live_runtime_claim": {
      "type": "string",
      "enum": ["none", "resume_candidate_metadata_only", "live_attached_observed"]
    },
    "support_export_class": {
      "type": "string",
      "enum": ["metadata_only", "redacted_metadata_with_evidence_refs", "not_exportable"]
    },
    "review_surface": {
      "type": "string",
      "enum": [
        "start_center",
        "launch_bundle_review",
        "project_entry_review",
        "support_export",
        "environment_inspector",
        "project_doctor"
      ]
    },
    "drift_class": {
      "type": "string",
      "enum": [
        "capsule_drift",
        "policy_epoch_advanced",
        "target_class_changed",
        "missing_cached_artifact",
        "helper_version_unknown",
        "secret_revalidation_required"
      ]
    },
    "source_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "producer_class",
        "source_ref",
        "source_digest",
        "source_revision_ref"
      ],
      "properties": {
        "source_class": { "$ref": "#/$defs/source_class" },
        "producer_class": { "$ref": "#/$defs/producer_class" },
        "source_ref": { "$ref": "#/$defs/path_ref" },
        "source_digest": { "$ref": "#/$defs/content_digest" },
        "source_revision_ref": { "$ref": "#/$defs/record_ref" }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness_state",
        "observed_at",
        "max_age_seconds",
        "age_class",
        "evidence_ref"
      ],
      "properties": {
        "freshness_state": { "$ref": "#/$defs/freshness_state" },
        "observed_at": { "$ref": "#/$defs/timestamp" },
        "max_age_seconds": { "type": "integer", "minimum": 0 },
        "age_class": { "$ref": "#/$defs/age_class" },
        "evidence_ref": { "$ref": "#/$defs/path_ref" }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_class",
        "boundary_class",
        "target_identity_ref",
        "capsule_location_class",
        "requested_source_artifact_ref",
        "materialized_runtime_ref"
      ],
      "properties": {
        "target_class": { "$ref": "#/$defs/target_class" },
        "boundary_class": { "$ref": "#/$defs/boundary_class" },
        "target_identity_ref": { "$ref": "#/$defs/record_ref" },
        "capsule_location_class": { "$ref": "#/$defs/capsule_location_class" },
        "requested_source_artifact_ref": { "type": ["string", "null"] },
        "materialized_runtime_ref": { "type": ["string", "null"] }
      }
    },
    "compatibility_fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fingerprint_ref",
        "capsule_ref",
        "capsule_hash",
        "commit_or_tree_ref",
        "source_digest_set_hash",
        "platform_arch",
        "policy_epoch",
        "extension_lock_digest",
        "critical_toolchain_digests"
      ],
      "properties": {
        "fingerprint_ref": { "$ref": "#/$defs/record_ref" },
        "capsule_ref": { "$ref": "#/$defs/dotted_lower_snake_id" },
        "capsule_hash": { "$ref": "#/$defs/content_digest" },
        "commit_or_tree_ref": { "$ref": "#/$defs/record_ref" },
        "source_digest_set_hash": { "$ref": "#/$defs/content_digest" },
        "platform_arch": { "$ref": "#/$defs/platform_arch" },
        "policy_epoch": { "$ref": "#/$defs/policy_epoch" },
        "extension_lock_digest": { "$ref": "#/$defs/content_digest" },
        "critical_toolchain_digests": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/content_digest" }
        }
      }
    },
    "warm_start_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "warm_start_state",
        "reuse_state",
        "invalidation_reason",
        "cache_disposition",
        "cache_classes",
        "warmed_artifact_refs",
        "resume_capability",
        "descriptor_stage",
        "materializer_claim",
        "live_runtime_claim",
        "fallback_action_id"
      ],
      "properties": {
        "warm_start_state": { "$ref": "#/$defs/warm_start_state" },
        "reuse_state": { "$ref": "#/$defs/prebuild_reuse_state" },
        "invalidation_reason": {
          "oneOf": [
            { "$ref": "#/$defs/prebuild_invalidation_reason" },
            { "type": "null" }
          ]
        },
        "cache_disposition": { "$ref": "#/$defs/cache_disposition" },
        "cache_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/cache_class" }
        },
        "warmed_artifact_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/record_ref" }
        },
        "resume_capability": { "$ref": "#/$defs/resume_capability" },
        "descriptor_stage": { "$ref": "#/$defs/descriptor_stage" },
        "materializer_claim": { "$ref": "#/$defs/materializer_claim" },
        "live_runtime_claim": { "$ref": "#/$defs/live_runtime_claim" },
        "fallback_action_id": { "$ref": "#/$defs/record_ref" }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust_state",
        "identity_mode",
        "policy_epoch",
        "raw_secret_values_included",
        "raw_command_lines_included",
        "secret_revalidation_required",
        "review_required_before_reuse",
        "support_export_class"
      ],
      "properties": {
        "trust_state": { "$ref": "#/$defs/trust_state" },
        "identity_mode": { "$ref": "#/$defs/identity_mode" },
        "policy_epoch": { "$ref": "#/$defs/policy_epoch" },
        "raw_secret_values_included": {
          "type": "boolean",
          "const": false
        },
        "raw_command_lines_included": {
          "type": "boolean",
          "const": false
        },
        "secret_revalidation_required": { "type": "boolean" },
        "review_required_before_reuse": { "type": "boolean" },
        "support_export_class": { "$ref": "#/$defs/support_export_class" }
      }
    },
    "drift_marker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["drift_class", "reason_ref", "recovery_action_id"],
      "properties": {
        "drift_class": { "$ref": "#/$defs/drift_class" },
        "reason_ref": { "$ref": "#/$defs/record_ref" },
        "recovery_action_id": { "$ref": "#/$defs/record_ref" }
      }
    },
    "prebuild_descriptor_alpha_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "prebuild_descriptor_alpha_schema_version",
        "descriptor_id",
        "descriptor_revision",
        "display_label",
        "source_identity",
        "freshness",
        "target",
        "compatibility_fingerprint",
        "warm_start_descriptor",
        "safety",
        "drift_markers",
        "review_surfaces",
        "launch_bundle_refs",
        "workspace_template_refs",
        "project_entry_review_refs",
        "review_summary"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "prebuild_descriptor_alpha_record" },
        "prebuild_descriptor_alpha_schema_version": {
          "$ref": "#/$defs/prebuild_descriptor_alpha_schema_version"
        },
        "descriptor_id": { "$ref": "#/$defs/dotted_lower_snake_id" },
        "descriptor_revision": { "type": "integer", "minimum": 1 },
        "display_label": { "$ref": "#/$defs/reviewable_sentence" },
        "source_identity": { "$ref": "#/$defs/source_identity" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "target": { "$ref": "#/$defs/target" },
        "compatibility_fingerprint": { "$ref": "#/$defs/compatibility_fingerprint" },
        "warm_start_descriptor": { "$ref": "#/$defs/warm_start_descriptor" },
        "safety": { "$ref": "#/$defs/safety" },
        "drift_markers": {
          "type": "array",
          "items": { "$ref": "#/$defs/drift_marker" }
        },
        "review_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/review_surface" }
        },
        "launch_bundle_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/record_ref" }
        },
        "workspace_template_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/dotted_lower_snake_id" }
        },
        "project_entry_review_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/record_ref" }
        },
        "review_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "warm_start_descriptor_seed_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "prebuild_descriptor_alpha_schema_version",
        "manifest_id",
        "as_of",
        "owner",
        "contract_refs",
        "prebuild_descriptors",
        "validation"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "warm_start_descriptor_seed_manifest" },
        "prebuild_descriptor_alpha_schema_version": {
          "$ref": "#/$defs/prebuild_descriptor_alpha_schema_version"
        },
        "manifest_id": { "$ref": "#/$defs/record_ref" },
        "as_of": { "$ref": "#/$defs/date" },
        "owner": { "$ref": "#/$defs/opaque_id" },
        "contract_refs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/path_ref" }
        },
        "prebuild_descriptors": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/prebuild_descriptor_alpha_record" }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["validator_ref", "protected_fixture_ref", "first_consumer_ref"],
          "properties": {
            "validator_ref": { "$ref": "#/$defs/path_ref" },
            "protected_fixture_ref": { "$ref": "#/$defs/path_ref" },
            "first_consumer_ref": { "$ref": "#/$defs/path_ref" }
          }
        }
      }
    }
  }
}
