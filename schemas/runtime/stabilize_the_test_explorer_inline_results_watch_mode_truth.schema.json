{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/stabilize_the_test_explorer_inline_results_watch_mode_truth.schema.json",
  "title": "Aureline stabilize-the-test-explorer / inline-results / watch-mode / rerun / debug-from-test truth packet",
  "description": "Boundary schema for the stable test-explorer / inline-results / watch-mode / rerun / debug-from-test truth packet certifying local, remote/helper, container, and notebook test-explorer lanes at the M4 launch-stable grade. Every launch_stable lane MUST publish a test_explorer_stabilization_quality row plus the full four-wedge admission coverage (test_explorer_identity_truth, inline_results_truth, watch_mode_truth, rerun_debug_from_test_parity), the full four test-identity admissions (suite_identity, case_identity, template_identity, invocation_identity), the full three discovery-posture admissions (partial_discovery_record, loaded_versus_known_counts, case_enumeration_at_runtime), the full four watch-mode-support admissions (live, reduced, polling, unavailable), the full three selector-durability admissions (durable_id_selector, trait_selector, snapshot_scoped_query_selector), the full five consumer-surface bindings (test_explorer_surface, inline_results_surface, watch_mode_surface, rerun_surface, debug_from_test_surface) each attesting the test-identity, watch-mode-support, and durable-selector vocabularies it is required to preserve, and a lineage_admission row binding execution_context_id. The packet is the single truth that the test-explorer surface, inline-results surface, watch-mode surface, rerun surface, debug-from-test surface, AI tool surface, CLI/headless inspector, evidence export, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies, flatten watch-mode posture into watch on/off, or paraphrase durable selectors into display labels.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "stabilize_the_test_explorer_inline_results_watch_mode_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/test_explorer_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/test_explorer_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 12,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "test_explorer_lane_class": {
      "enum": [
        "local_lane",
        "remote_helper_lane",
        "container_lane",
        "notebook_lane"
      ]
    },
    "test_explorer_row_class": {
      "enum": [
        "test_explorer_stabilization_quality",
        "wedge_admission",
        "test_identity_admission",
        "discovery_posture_admission",
        "watch_mode_support_admission",
        "selector_durability_admission",
        "consumer_surface_binding",
        "lineage_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "wedge_class": {
      "enum": [
        "test_explorer_identity_truth",
        "inline_results_truth",
        "watch_mode_truth",
        "rerun_debug_from_test_parity",
        "not_applicable"
      ]
    },
    "test_identity_class": {
      "enum": [
        "suite_identity",
        "case_identity",
        "template_identity",
        "invocation_identity",
        "not_applicable"
      ]
    },
    "discovery_posture_class": {
      "enum": [
        "partial_discovery_record",
        "loaded_versus_known_counts",
        "case_enumeration_at_runtime",
        "not_applicable"
      ]
    },
    "watch_mode_support_class": {
      "enum": [
        "live",
        "reduced",
        "polling",
        "unavailable",
        "not_applicable"
      ]
    },
    "selector_durability_class": {
      "enum": [
        "durable_id_selector",
        "trait_selector",
        "snapshot_scoped_query_selector",
        "not_applicable"
      ]
    },
    "consumer_surface_class": {
      "enum": [
        "test_explorer_surface",
        "inline_results_surface",
        "watch_mode_surface",
        "rerun_surface",
        "debug_from_test_surface",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "local_lane_subset_only",
        "remote_helper_subset_only",
        "container_subset_only",
        "notebook_subset_only",
        "wedge_admission_subset_only",
        "test_identity_subset_only",
        "discovery_posture_subset_only",
        "watch_mode_support_subset_only",
        "selector_durability_subset_only",
        "consumer_surface_subset_only",
        "test_identity_attestation_skew_declared",
        "watch_mode_support_attestation_skew_declared",
        "durable_selector_attestation_skew_declared",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_wedge_admission_gap",
        "auto_narrow_on_test_identity_gap",
        "auto_narrow_on_discovery_posture_gap",
        "auto_narrow_on_watch_mode_support_gap",
        "auto_narrow_on_selector_durability_gap",
        "auto_narrow_on_consumer_surface_gap",
        "auto_narrow_on_test_identity_attestation_gap",
        "auto_narrow_on_watch_mode_support_attestation_gap",
        "auto_narrow_on_durable_selector_attestation_gap",
        "auto_narrow_on_lineage_break",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": {
      "enum": ["info", "warning", "blocker"]
    },
    "consumer_surface": {
      "enum": [
        "test_explorer_surface",
        "inline_results_surface",
        "watch_mode_surface",
        "rerun_surface",
        "debug_from_test_surface",
        "ai_tool_surface",
        "cli_headless",
        "evidence_export",
        "support_export",
        "release_proof_index",
        "help_about",
        "conformance_dashboard"
      ]
    },
    "test_explorer_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "wedge_class",
        "test_identity_class",
        "discovery_posture_class",
        "watch_mode_support_class",
        "selector_durability_class",
        "consumer_surface_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/test_explorer_lane_class" },
        "row_class": { "$ref": "#/$defs/test_explorer_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "wedge_class": { "$ref": "#/$defs/wedge_class" },
        "test_identity_class": { "$ref": "#/$defs/test_identity_class" },
        "discovery_posture_class": { "$ref": "#/$defs/discovery_posture_class" },
        "watch_mode_support_class": { "$ref": "#/$defs/watch_mode_support_class" },
        "selector_durability_class": { "$ref": "#/$defs/selector_durability_class" },
        "consumer_surface_class": { "$ref": "#/$defs/consumer_surface_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_id_binding": { "$ref": "#/$defs/non_empty_string" },
        "attests_test_identity_preserved": { "type": "boolean" },
        "attests_watch_mode_support_preserved": { "type": "boolean" },
        "attests_durable_selector_preserved": { "type": "boolean" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "test_explorer_stabilization_truth_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_wedge_vocabulary",
        "preserves_test_identity_vocabulary",
        "preserves_discovery_posture_vocabulary",
        "preserves_watch_mode_support_vocabulary",
        "preserves_selector_durability_vocabulary",
        "preserves_consumer_surface_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "test_explorer_stabilization_truth_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_wedge_vocabulary": { "type": "boolean" },
        "preserves_test_identity_vocabulary": { "type": "boolean" },
        "preserves_discovery_posture_vocabulary": { "type": "boolean" },
        "preserves_watch_mode_support_vocabulary": { "type": "boolean" },
        "preserves_selector_durability_vocabulary": { "type": "boolean" },
        "preserves_consumer_surface_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
