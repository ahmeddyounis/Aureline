{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/target_graph_state.schema.json",
  "title": "Aureline target-graph state, host-boundary cue, and operator-truth projection record",
  "description": "Boundary schema for the target_graph_state_record projected by run/test/build/debug pickers, target-graph panels, command diagnostics, provider entry surfaces, support exports, and inspector drawers when they need one stable, export-safe answer to: which target was intended, which target is resolved as current, how the system classifies the truth (exact/imported/heuristic/hybrid), how confident it is, which host boundary the claim crossed, what route/exposure posture was used to obtain it, what availability/lifecycle state the target graph is in (current/warming/stale/partial/unavailable), which authority class is the canonical writer, and why the system believes this is the current target. This schema composes with (and MUST NOT mint alternatives to) the frozen host-boundary cue vocabulary (docs/runtime/target_discovery_and_install_review_taxonomy.md), the frozen route/exposure vocabulary (docs/runtime/origin_target_route_taxonomy.md), and the frozen authority-class matrix (docs/runtime/authority_class_matrix.md). Raw build files, raw absolute paths, raw command lines, raw stdout/stderr bytes, raw provider payloads, and raw secrets never cross this boundary; opaque ids/refs, class labels, counts, and short reviewable sentences do. Adding a new operator_truth_projection_class, target_graph_availability_state, confidence_chip_class, belief_basis_class, target_resolution_state_class, or confidence_reason_class is additive-minor and bumps target_graph_state_schema_version; repurposing an existing value is breaking and requires a governance decision.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/target_graph_state_record" }
  ],
  "$defs": {
    "target_graph_state_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this target-graph state record family. Current value is 1."
    },

    "record_kind": {
      "type": "string",
      "const": "target_graph_state_record",
      "description": "Discriminator for the concrete payload shape."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe to log and export. Raw secrets, raw absolute paths, raw URLs, and raw payload bytes never appear here."
    },

    "dotted_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$",
      "description": "Dotted stable identifier (for example: aureline.native.cargo_runner)."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 / RFC 3339 UTC timestamp captured from a monotonic clock source."
    },

    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 320,
      "description": "Short reviewer-facing sentence safe to show in headers, chips, drawers, CLI diagnostics, and support exports. Raw command lines, raw provider payloads, raw absolute paths, and raw secrets MUST NOT appear."
    },

    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },

    "authority_class": {
      "type": "string",
      "enum": [
        "workspace_vfs",
        "buffer_editor",
        "derived_knowledge",
        "execution",
        "policy_entitlement",
        "provider_overlay"
      ],
      "description": "Re-export of the ADR-0005 authority-class matrix. This schema does not mint new authority classes."
    },

    "operator_truth_projection_class": {
      "type": "string",
      "enum": ["exact", "imported", "heuristic", "hybrid"],
      "description": "Frozen operator-truth projection class for the resolved target claim."
    },

    "target_graph_availability_state": {
      "type": "string",
      "enum": ["current", "warming", "stale", "partial", "unavailable"],
      "description": "Frozen availability/lifecycle state for the target graph claim as projected to user-facing surfaces."
    },

    "confidence_chip_class": {
      "type": "string",
      "enum": ["high", "medium_high", "medium", "low"],
      "description": "Frozen confidence chip class. Surfaces render these as High / Medium-high / Medium / Low using artifacts/runtime/target_graph_badge_projection.yaml."
    },

    "confidence_class": {
      "type": "string",
      "enum": [
        "authoritative_from_source",
        "structured_parse_match",
        "heuristic_best_effort",
        "degraded_partial",
        "unknown"
      ],
      "description": "Re-export of schemas/tooling/task_event_envelope.schema.json#/$defs/confidence_class."
    },

    "workspace_scope_class": {
      "type": "string",
      "enum": [
        "current_root",
        "named_workset",
        "sparse_slice",
        "full_workspace",
        "policy_limited_view",
        "review_workspace",
        "companion_surface"
      ],
      "description": "Re-export of the frozen workset scope_class vocabulary."
    },

    "target_kind": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "string",
          "enum": [
            "library",
            "executable_binary",
            "shared_library",
            "static_library",
            "test_suite",
            "integration_test_suite",
            "benchmark_suite",
            "fuzz_target",
            "documentation_bundle",
            "package_artifact",
            "container_image",
            "notebook_runnable",
            "language_server_runnable",
            "debug_runnable",
            "ai_proposed_pending_review",
            "opaque_preserved_unsupported"
          ]
        }
      ],
      "description": "Optional re-export of schemas/tooling/target_descriptor.schema.json#/$defs/target_kind."
    },

    "host_boundary_cue_class": {
      "type": "string",
      "enum": [
        "local_host_boundary",
        "user_mode_sandbox_boundary",
        "container_kernel_boundary",
        "devcontainer_boundary",
        "remote_ssh_boundary",
        "remote_agent_boundary",
        "managed_workspace_boundary",
        "notebook_kernel_boundary",
        "ai_sandbox_boundary",
        "browser_handoff_return_boundary",
        "bridged_host_boundary"
      ],
      "description": "Frozen host-boundary cue vocabulary. Ordered cue stacks are outermost-to-innermost."
    },

    "host_boundary_cue_stack": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/host_boundary_cue_class" },
      "description": "Optional ordered host-boundary cue stack, outermost-to-innermost."
    },

    "action_route_class": {
      "type": "string",
      "enum": [
        "in_process_route",
        "local_rpc_route",
        "remote_rpc_route",
        "managed_control_plane_route",
        "remote_agent_attach_route",
        "approval_gated_route",
        "browser_handoff_route",
        "embedded_webview_route",
        "native_callback_route",
        "provider_webhook_return_route",
        "publish_pipeline_route",
        "tunnel_exposed_route",
        "mirror_or_private_registry_route",
        "bridged_helper_route",
        "heuristic_unknown_route"
      ],
      "description": "Frozen action_route_class vocabulary (docs/runtime/origin_target_route_taxonomy.md)."
    },

    "action_exposure_class": {
      "type": "string",
      "enum": [
        "no_side_effect_local_read",
        "local_only_mutation",
        "workspace_visible_mutation",
        "provider_visible_mutation",
        "publicly_visible_publish",
        "cross_tenant_visible",
        "third_party_callback_visible",
        "browser_session_visible",
        "tunnel_exposed_public",
        "exposure_unknown_requires_review"
      ],
      "description": "Frozen action_exposure_class vocabulary (docs/runtime/origin_target_route_taxonomy.md)."
    },

    "authority_linkage_class": {
      "type": "string",
      "enum": [
        "no_authority_required_read_only",
        "local_user_keystroke_authority",
        "approval_ticket_linked",
        "browser_handoff_packet_linked",
        "publish_evidence_packet_linked",
        "remote_agent_attach_ticket_linked",
        "managed_control_plane_token_linked",
        "policy_injected_service_identity_linked",
        "supervisor_repair_ticket_linked",
        "authority_missing_denied"
      ],
      "description": "Frozen authority_linkage_class vocabulary (docs/runtime/origin_target_route_taxonomy.md)."
    },

    "wrong_target_correction_class": {
      "type": "string",
      "enum": [
        "no_correction_needed",
        "corrected_before_commit",
        "corrected_after_partial_effect",
        "requires_user_confirmation",
        "blocked_pending_reapproval"
      ],
      "description": "Frozen wrong-target correction vocabulary. Silent swaps are non-conforming."
    },

    "reapproval_requirement_class": {
      "type": "string",
      "enum": [
        "no_reapproval_required",
        "session_ticket_refresh_required",
        "approval_ticket_reissue_required",
        "admin_confirmation_required",
        "policy_narrowing_required",
        "trust_reevaluation_required"
      ],
      "description": "Frozen reapproval requirement vocabulary used when wrong-target correction or boundary changes require renewed admission."
    },

    "target_selection_source_class": {
      "type": "string",
      "enum": [
        "user_selected",
        "run_configuration_declared",
        "single_target_defaulted",
        "restored_from_session_cache",
        "imported_from_support_bundle",
        "imported_from_provider_overlay",
        "inferred_from_context",
        "unknown_requires_review"
      ],
      "description": "Where the intended target ref came from. Used to keep imported and inferred targets explicit."
    },

    "target_resolution_state_class": {
      "type": "string",
      "enum": [
        "resolved_exact",
        "resolved_remapped_by_lineage",
        "resolved_ambiguous_requires_user",
        "target_missing_in_graph",
        "target_outside_workset_scope",
        "graph_unavailable",
        "blocked_by_policy",
        "unresolvable"
      ],
      "description": "Resolution result for mapping intended target to resolved target. States that require user input or deny remain typed; generic failure copy is non-conforming."
    },

    "confidence_reason_class": {
      "type": "string",
      "enum": [
        "authoritative_adapter_current_graph",
        "authoritative_adapter_warming",
        "cached_graph_within_floor",
        "stale_graph_outside_floor",
        "partial_graph_coverage",
        "imported_replay_only_graph",
        "heuristic_target_inference",
        "hybrid_merge_mixed_provenance",
        "adapter_degraded_or_unavailable",
        "provider_unreachable_or_unavailable",
        "policy_narrowed_visibility"
      ],
      "description": "Closed confidence-reason vocabulary. Surfaces MUST NOT invent per-surface reason strings."
    },

    "belief_basis_class": {
      "type": "string",
      "enum": [
        "target_id_selected_by_user",
        "target_id_declared_by_run_configuration",
        "target_id_defaulted_single_candidate",
        "target_id_restored_from_session_cache",
        "target_id_imported_from_support_bundle",
        "target_id_inferred_from_context",
        "target_id_remapped_by_lineage",
        "target_id_changed_by_wrong_target_correction",
        "target_id_fell_back_after_provider_loss",
        "target_id_unavailable_partial_graph_blocks_resolution"
      ],
      "description": "Closed belief-basis vocabulary explaining why the system believes the resolved target is current."
    },

    "target_ref_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_id_ref", "display_label", "target_kind"],
      "properties": {
        "target_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Opaque ref/id of the target descriptor (or stable target id). Null when resolution is ambiguous/unavailable."
        },
        "display_label": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/short_sentence" }
          ],
          "description": "Reviewer-facing label safe for headers and exports. Null is admissible only when target_id_ref is null."
        },
        "target_kind": { "$ref": "#/$defs/target_kind" }
      }
    },

    "belief_basis_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["belief_basis_class", "summary", "evidence_ref"],
      "properties": {
        "belief_basis_class": { "$ref": "#/$defs/belief_basis_class" },
        "summary": { "$ref": "#/$defs/short_sentence" },
        "evidence_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Optional opaque ref to supporting evidence (graph snapshot id, lineage event id, support bundle entry id)."
        }
      }
    },

    "confidence_reason_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confidence_reason_class", "summary"],
      "properties": {
        "confidence_reason_class": { "$ref": "#/$defs/confidence_reason_class" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },

    "route_truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_route_class",
        "action_exposure_class",
        "authority_linkage_class",
        "authority_linkage_ref"
      ],
      "properties": {
        "action_route_class": { "$ref": "#/$defs/action_route_class" },
        "action_exposure_class": { "$ref": "#/$defs/action_exposure_class" },
        "authority_linkage_class": { "$ref": "#/$defs/authority_linkage_class" },
        "authority_linkage_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Opaque ref to the authority object (ticket, handoff packet, control-plane token). Null is admissible only when authority_linkage_class is no_authority_required_read_only."
        }
      },
      "allOf": [
        {
          "description": "authority_linkage_ref MUST be null only when authority_linkage_class is no_authority_required_read_only.",
          "if": {
            "properties": { "authority_linkage_class": { "const": "no_authority_required_read_only" } },
            "required": ["authority_linkage_class"]
          },
          "then": {
            "properties": { "authority_linkage_ref": { "type": "null" } },
            "required": ["authority_linkage_ref"]
          }
        }
      ]
    },

    "target_graph_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "graph_id",
        "source_adapter_id_ref",
        "source_adapter_confidence_class",
        "captured_at",
        "graph_freshness_class",
        "partial_truth_class",
        "workset_scope_class",
        "workset_scope_ref",
        "target_count_reported"
      ],
      "properties": {
        "graph_id": { "$ref": "#/$defs/opaque_id" },
        "source_adapter_id_ref": { "$ref": "#/$defs/dotted_id" },
        "source_adapter_confidence_class": { "$ref": "#/$defs/confidence_class" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "graph_freshness_class": {
          "type": "string",
          "enum": [
            "live_streaming",
            "warm_cached",
            "cold_cached",
            "stale_pending_refresh",
            "unknown_freshness",
            "support_bundle_replay_only"
          ],
          "description": "Re-export of schemas/tooling/target_graph_snapshot.schema.json#/$defs/freshness_class."
        },
        "partial_truth_class": {
          "type": "string",
          "enum": [
            "complete_for_workset_scope",
            "partial_workset_subset_of_full_graph",
            "partial_initial_load_pending_full_resolution",
            "partial_streamed_pending_completion_event",
            "partial_policy_limited_view",
            "partial_outside_current_slice_omitted",
            "partial_adapter_degraded_pending_recovery",
            "partial_unsupported_subgraph_preserved_opaquely"
          ],
          "description": "Re-export of schemas/tooling/target_graph_snapshot.schema.json#/$defs/partial_truth_class."
        },
        "workset_scope_class": { "$ref": "#/$defs/workspace_scope_class" },
        "workset_scope_ref": { "$ref": "#/$defs/opaque_id" },
        "target_count_reported": { "$ref": "#/$defs/non_negative_integer" },
        "execution_context_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Optional ref to an execution_context_record id that was active when the graph was captured."
        }
      }
    },

    "wrong_target_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wrong_target_correction_class",
        "reapproval_requirement_class",
        "prior_resolved_target"
      ],
      "properties": {
        "wrong_target_correction_class": { "$ref": "#/$defs/wrong_target_correction_class" },
        "reapproval_requirement_class": { "$ref": "#/$defs/reapproval_requirement_class" },
        "prior_resolved_target": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/target_ref_summary" }
          ],
          "description": "Prior resolved target when correction was applied. Null is admissible only when wrong_target_correction_class is no_correction_needed."
        }
      },
      "allOf": [
        {
          "description": "no_correction_needed implies no reapproval and null prior target.",
          "if": {
            "properties": { "wrong_target_correction_class": { "const": "no_correction_needed" } },
            "required": ["wrong_target_correction_class"]
          },
          "then": {
            "properties": {
              "reapproval_requirement_class": { "const": "no_reapproval_required" },
              "prior_resolved_target": { "type": "null" }
            },
            "required": ["reapproval_requirement_class", "prior_resolved_target"]
          }
        }
      ]
    },

    "import_source_class": {
      "type": "string",
      "enum": [
        "support_bundle",
        "provider_api_snapshot",
        "session_cache",
        "review_pack",
        "release_packet",
        "local_file_import",
        "not_imported"
      ],
      "description": "Closed import-source vocabulary for imported target-graph state. not_imported is required when operator_truth_projection_class is not imported."
    },

    "target_graph_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "target_graph_state_schema_version",
        "state_id",
        "captured_at",
        "workspace_id",
        "authority_class",
        "target_graph_availability_state",
        "operator_truth_projection_class",
        "confidence_chip_class",
        "host_boundary_cue_class",
        "host_boundary_cue_stack",
        "route_truth",
        "graph_summary",
        "intended_target",
        "intended_target_source",
        "resolved_target",
        "resolution_state",
        "wrong_target_state",
        "import_source_class",
        "belief_basis",
        "confidence_reasons",
        "summary"
      ],
      "properties": {
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "target_graph_state_schema_version": { "$ref": "#/$defs/target_graph_state_schema_version" },
        "state_id": { "$ref": "#/$defs/opaque_id" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "workspace_id": { "$ref": "#/$defs/opaque_id" },
        "authority_class": { "$ref": "#/$defs/authority_class" },
        "target_graph_availability_state": { "$ref": "#/$defs/target_graph_availability_state" },
        "operator_truth_projection_class": { "$ref": "#/$defs/operator_truth_projection_class" },
        "confidence_chip_class": { "$ref": "#/$defs/confidence_chip_class" },
        "host_boundary_cue_class": { "$ref": "#/$defs/host_boundary_cue_class" },
        "host_boundary_cue_stack": { "$ref": "#/$defs/host_boundary_cue_stack" },
        "route_truth": { "$ref": "#/$defs/route_truth_summary" },
        "graph_summary": { "$ref": "#/$defs/target_graph_summary" },
        "intended_target": { "$ref": "#/$defs/target_ref_summary" },
        "intended_target_source": { "$ref": "#/$defs/target_selection_source_class" },
        "resolved_target": { "$ref": "#/$defs/target_ref_summary" },
        "resolution_state": { "$ref": "#/$defs/target_resolution_state_class" },
        "wrong_target_state": { "$ref": "#/$defs/wrong_target_state" },
        "import_source_class": { "$ref": "#/$defs/import_source_class" },
        "belief_basis": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/belief_basis_entry" }
        },
        "confidence_reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/confidence_reason_entry" }
        },
        "summary": { "$ref": "#/$defs/short_sentence" },
        "$schema": { "type": "string" },
        "__fixture__": { "type": "object" }
      },
      "allOf": [
        {
          "description": "Imported truth requires a non-not_imported import_source_class; non-imported truth requires not_imported.",
          "if": {
            "properties": { "operator_truth_projection_class": { "const": "imported" } },
            "required": ["operator_truth_projection_class"]
          },
          "then": {
            "properties": { "import_source_class": { "not": { "const": "not_imported" } } },
            "required": ["import_source_class"]
          },
          "else": {
            "properties": { "import_source_class": { "const": "not_imported" } },
            "required": ["import_source_class"]
          }
        },
        {
          "description": "Resolution states that yield no current target require resolved_target.target_id_ref = null.",
          "if": {
            "properties": {
              "resolution_state": {
                "enum": [
                  "resolved_ambiguous_requires_user",
                  "target_missing_in_graph",
                  "target_outside_workset_scope",
                  "graph_unavailable",
                  "blocked_by_policy",
                  "unresolvable"
                ]
              }
            },
            "required": ["resolution_state"]
          },
          "then": {
            "properties": {
              "resolved_target": {
                "properties": { "target_id_ref": { "type": "null" } },
                "required": ["target_id_ref"]
              }
            }
          }
        }
      ],
      "description": "One target-graph state record. Consumers project badges, inspectors, and exports from this record rather than mint per-surface target truth objects."
    }
  }
}

