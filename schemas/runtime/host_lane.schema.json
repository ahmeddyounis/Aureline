{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/host_lane.schema.json",
  "title": "Aureline host-lane topology records",
  "description": "Boundary schema for runtime topology-inspector host lanes, inline badge groups, and visible result bindings. Host families remain plain-language while low-level process and transport identifiers stay in detail-only refs.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/host_lane_record" },
    { "$ref": "#/$defs/host_badge_group_record" },
    { "$ref": "#/$defs/topology_inspector_record" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "non_empty_string": { "type": "string", "minLength": 1 },
    "host_family": {
      "type": "string",
      "enum": [
        "local_shell_service",
        "language_analysis_host",
        "extension_sandbox_host",
        "debug_task_adapter_host",
        "notebook_kernel",
        "remote_workspace_agent",
        "managed_service_lane"
      ]
    },
    "health": {
      "type": "string",
      "enum": [
        "healthy",
        "starting",
        "reconnecting",
        "degraded",
        "stale_snapshot",
        "disconnected",
        "quarantined",
        "crash_loop",
        "disabled"
      ]
    },
    "surface": {
      "type": "string",
      "enum": [
        "logs",
        "run",
        "debug_view",
        "notebook_output",
        "preview",
        "profiler_replay",
        "data_api_session",
        "ai_tool_action",
        "provider_runtime_summary",
        "pipeline_viewer",
        "docs_browser_bridge",
        "runtime_diagnostic",
        "support_export"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": [
        "current",
        "stale",
        "partial_truth",
        "rebuilding",
        "disconnected_snapshot",
        "awaiting_refresh"
      ]
    },
    "visible_truth_label": {
      "type": "string",
      "enum": [
        "current",
        "stale",
        "rebuilding",
        "provider_unavailable",
        "reconnecting",
        "local_fallback",
        "captured_snapshot"
      ]
    },
    "badge": {
      "type": "object",
      "required": ["class", "token", "label"],
      "properties": {
        "class": { "type": "string" },
        "token": { "type": "string" },
        "label": { "type": "string" }
      },
      "additionalProperties": false
    },
    "detail_action": {
      "type": "object",
      "required": ["label", "action_ref", "open_target", "open_target_token"],
      "properties": {
        "label": { "$ref": "#/$defs/non_empty_string" },
        "action_ref": { "$ref": "#/$defs/non_empty_string" },
        "open_target": { "type": "string" },
        "open_target_token": { "type": "string" }
      },
      "additionalProperties": false
    },
    "host_lane_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "lane_id",
        "family",
        "family_token",
        "family_label",
        "health_class",
        "health_token",
        "fault_domain_id",
        "restart_budget_ref",
        "detail_action"
      ],
      "properties": {
        "record_kind": { "const": "host_lane_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "lane_id": { "$ref": "#/$defs/non_empty_string" },
        "family": { "$ref": "#/$defs/host_family" },
        "family_token": { "$ref": "#/$defs/host_family" },
        "family_label": { "$ref": "#/$defs/non_empty_string" },
        "role_label": { "type": "string" },
        "host_label": { "type": "string" },
        "target_ref": { "type": "string" },
        "locality_label": { "type": "string" },
        "boundary_badges": { "type": "array", "items": { "$ref": "#/$defs/badge" } },
        "health_class": { "$ref": "#/$defs/health" },
        "health_token": { "$ref": "#/$defs/health" },
        "health_label": { "type": "string" },
        "fault_domain_id": { "$ref": "#/$defs/non_empty_string" },
        "restart_budget_ref": { "$ref": "#/$defs/non_empty_string" },
        "restart_strike_count": { "type": "integer", "minimum": 0 },
        "restart_budget_in_window": { "type": "integer", "minimum": 0 },
        "restart_window_minutes": { "type": "integer", "minimum": 0 },
        "affected_capability_tokens": { "type": "array", "items": { "type": "string" } },
        "preserved_checkpoint_refs": { "type": "array", "items": { "type": "string" } },
        "stale_result_refs": { "type": "array", "items": { "type": "string" } },
        "quarantine_ref": { "type": "string" },
        "current_host_confirmed": { "type": "boolean" },
        "detail_action": { "$ref": "#/$defs/detail_action" }
      },
      "additionalProperties": true
    },
    "host_badge_group_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "result_ref",
        "surface",
        "surface_token",
        "host_lane_ref",
        "primary_badge_label",
        "state_badge_label",
        "detail_action"
      ],
      "properties": {
        "record_kind": { "const": "host_badge_group_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "result_ref": { "$ref": "#/$defs/non_empty_string" },
        "surface": { "$ref": "#/$defs/surface" },
        "surface_token": { "$ref": "#/$defs/surface" },
        "host_lane_ref": { "$ref": "#/$defs/non_empty_string" },
        "primary_badge_label": { "$ref": "#/$defs/non_empty_string" },
        "state_badge_label": { "$ref": "#/$defs/non_empty_string" },
        "restart_note": { "type": "string" },
        "boundary_badges": { "type": "array", "items": { "$ref": "#/$defs/badge" } },
        "detail_action": { "$ref": "#/$defs/detail_action" }
      },
      "additionalProperties": false
    },
    "topology_inspector_record": {
      "type": "object",
      "required": ["record_kind", "schema_version", "inspector_id", "workspace_id", "lanes", "results"],
      "properties": {
        "record_kind": { "const": "topology_inspector_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "inspector_id": { "$ref": "#/$defs/non_empty_string" },
        "workspace_id": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "type": "string" },
        "lanes": { "type": "array", "items": { "$ref": "#/$defs/host_lane_record" } },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "result_id",
              "surface",
              "surface_token",
              "result_summary",
              "host_lane_ids",
              "host_badge_groups",
              "freshness_class",
              "freshness_token",
              "visible_truth_label_token"
            ],
            "properties": {
              "result_id": { "$ref": "#/$defs/non_empty_string" },
              "surface": { "$ref": "#/$defs/surface" },
              "surface_token": { "$ref": "#/$defs/surface" },
              "result_summary": { "$ref": "#/$defs/non_empty_string" },
              "host_lane_ids": {
                "type": "array",
                "items": { "$ref": "#/$defs/non_empty_string" }
              },
              "host_badge_groups": {
                "type": "array",
                "items": { "$ref": "#/$defs/host_badge_group_record" }
              },
              "freshness_class": { "$ref": "#/$defs/freshness" },
              "freshness_token": { "$ref": "#/$defs/freshness" },
              "freshness_label": { "type": "string" },
              "visible_truth_label_class": { "$ref": "#/$defs/visible_truth_label" },
              "visible_truth_label_token": { "$ref": "#/$defs/visible_truth_label" },
              "visible_truth_label_label": { "type": "string" },
              "provenance_ref": { "type": "string" },
              "current_host_confirmed": { "type": "boolean" },
              "requires_reattach_review": { "type": "boolean" }
            },
            "additionalProperties": true
          }
        },
        "healthy_lane_count": { "type": "integer", "minimum": 0 },
        "degraded_lane_count": { "type": "integer", "minimum": 0 },
        "partial_truth_result_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    }
  }
}
