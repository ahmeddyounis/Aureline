{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/stabilize_debugger_host_and_adapter_negotiation_truth.schema.json",
  "title": "Aureline stabilize-debugger-host / adapter-negotiation / attach-launch / crash-isolation truth packet",
  "description": "Boundary schema for the stable debugger-host / adapter-negotiation / attach-launch / crash-isolation truth packet certifying local, remote/helper, container, and notebook-bridge debugger lanes at the M4 launch-stable grade. Every launch_stable lane MUST publish a debugger_stabilization_quality row plus the full four-wedge admission coverage (debugger_host, adapter_negotiation, attach_launch_flow, crash_isolation), the full six adapter-descriptor field bindings (adapter_identity, transport_class, launch_attach_scope, local_vs_remote_support_class, chronology_replay_capability_class, notebook_bridge_or_replay_only_limitation), the full four attach/launch parity-surface bindings (ui_surface, cli_headless, support_export, docs_help) all carrying the same attach/launch posture (supported, limited, view_only, unsupported, or policy_blocked) without drift, the full five crash-isolation assertion bindings (bounded_restart_budget, session_quarantine_admission, unrelated_language_host_unaffected, unrelated_terminal_lane_unaffected, unrelated_debug_session_unaffected) attesting their assertion, and a lineage_admission row binding execution_context_id. The packet is the single truth that the editor debug surface, debug session panel, breakpoint surface, watch/locals surface, crash-loop quarantine banner, CLI/headless inspector, evidence export, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies or fork their own debugger semantics.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "stabilize_debugger_host_and_adapter_negotiation_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/debugger_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/debugger_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 11,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "debugger_lane_class": {
      "enum": [
        "local_lane",
        "remote_helper_lane",
        "container_lane",
        "notebook_bridge_lane"
      ]
    },
    "debugger_row_class": {
      "enum": [
        "debugger_stabilization_quality",
        "wedge_admission",
        "adapter_descriptor_field_binding",
        "attach_launch_parity_surface_binding",
        "crash_isolation_assertion_binding",
        "lineage_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "wedge_class": {
      "enum": [
        "debugger_host",
        "adapter_negotiation",
        "attach_launch_flow",
        "crash_isolation",
        "not_applicable"
      ]
    },
    "adapter_descriptor_field_class": {
      "enum": [
        "adapter_identity",
        "transport_class",
        "launch_attach_scope",
        "local_vs_remote_support_class",
        "chronology_replay_capability_class",
        "notebook_bridge_or_replay_only_limitation",
        "not_applicable"
      ]
    },
    "attach_launch_parity_surface_class": {
      "enum": [
        "ui_surface",
        "cli_headless",
        "support_export",
        "docs_help",
        "not_applicable"
      ]
    },
    "attach_launch_posture_class": {
      "enum": [
        "supported",
        "limited",
        "view_only",
        "unsupported",
        "policy_blocked",
        "not_applicable"
      ]
    },
    "crash_isolation_assertion_class": {
      "enum": [
        "bounded_restart_budget",
        "session_quarantine_admission",
        "unrelated_language_host_unaffected",
        "unrelated_terminal_lane_unaffected",
        "unrelated_debug_session_unaffected",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "local_lane_subset_only",
        "remote_helper_subset_only",
        "container_subset_only",
        "notebook_bridge_subset_only",
        "wedge_admission_subset_only",
        "adapter_descriptor_field_subset_only",
        "attach_launch_parity_surface_subset_only",
        "crash_isolation_assertion_subset_only",
        "attach_launch_posture_drift_declared",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_wedge_admission_gap",
        "auto_narrow_on_adapter_descriptor_field_gap",
        "auto_narrow_on_attach_launch_parity_surface_gap",
        "auto_narrow_on_attach_launch_posture_drift",
        "auto_narrow_on_crash_isolation_assertion_gap",
        "auto_narrow_on_lineage_break",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "debugger_stabilization_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_lane_coverage",
        "missing_wedge_admission_coverage",
        "missing_adapter_descriptor_field_coverage",
        "missing_attach_launch_parity_surface_coverage",
        "missing_crash_isolation_assertion_coverage",
        "missing_lineage_admission",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "wedge_not_applicable",
        "wedge_not_permitted_on_row_class",
        "adapter_descriptor_field_not_applicable",
        "adapter_descriptor_field_not_permitted_on_row_class",
        "attach_launch_parity_surface_not_applicable",
        "attach_launch_parity_surface_not_permitted_on_row_class",
        "attach_launch_posture_not_applicable",
        "attach_launch_posture_not_permitted_on_row_class",
        "attach_launch_posture_missing_disclosure_ref",
        "attach_launch_posture_drift",
        "crash_isolation_assertion_not_applicable",
        "crash_isolation_assertion_not_permitted_on_row_class",
        "crash_isolation_assertion_not_attested",
        "lineage_admission_missing_execution_context_id",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "wedge_vocabulary_collapsed",
        "adapter_descriptor_field_vocabulary_collapsed",
        "attach_launch_parity_surface_vocabulary_collapsed",
        "attach_launch_posture_vocabulary_collapsed",
        "crash_isolation_assertion_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "debugger_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "wedge_class",
        "adapter_descriptor_field_class",
        "attach_launch_parity_surface_class",
        "attach_launch_posture_class",
        "crash_isolation_assertion_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/debugger_lane_class" },
        "row_class": { "$ref": "#/$defs/debugger_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "wedge_class": { "$ref": "#/$defs/wedge_class" },
        "adapter_descriptor_field_class": { "$ref": "#/$defs/adapter_descriptor_field_class" },
        "attach_launch_parity_surface_class": { "$ref": "#/$defs/attach_launch_parity_surface_class" },
        "attach_launch_posture_class": { "$ref": "#/$defs/attach_launch_posture_class" },
        "crash_isolation_assertion_class": { "$ref": "#/$defs/crash_isolation_assertion_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/debugger_stabilization_confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_id_binding": { "$ref": "#/$defs/non_empty_string" },
        "attests_crash_isolation_assertion": { "type": "boolean" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "debugger_stabilization_truth_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_wedge_vocabulary",
        "preserves_adapter_descriptor_field_vocabulary",
        "preserves_attach_launch_parity_surface_vocabulary",
        "preserves_attach_launch_posture_vocabulary",
        "preserves_crash_isolation_assertion_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "editor_debug_surface",
            "debug_session_panel",
            "breakpoint_surface",
            "watch_locals_surface",
            "crash_loop_quarantine_banner",
            "cli_headless",
            "evidence_export",
            "support_export",
            "release_proof_index",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "debugger_stabilization_truth_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_wedge_vocabulary": { "type": "boolean" },
        "preserves_adapter_descriptor_field_vocabulary": { "type": "boolean" },
        "preserves_attach_launch_parity_surface_vocabulary": { "type": "boolean" },
        "preserves_attach_launch_posture_vocabulary": { "type": "boolean" },
        "preserves_crash_isolation_assertion_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
