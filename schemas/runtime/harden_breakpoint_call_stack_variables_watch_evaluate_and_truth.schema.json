{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/harden_breakpoint_call_stack_variables_watch_evaluate_and_truth.schema.json",
  "title": "Aureline harden-breakpoint / call-stack / variables / watch / evaluate / debug-console fidelity truth packet",
  "description": "Boundary schema for the stable debug-fidelity truth packet certifying local, remote/helper, container, and notebook-bridge debug lanes at the M4 launch-stable grade. Every launch_stable lane MUST publish a debug_fidelity_quality row plus the full six-wedge admission coverage (breakpoint_fidelity, call_stack_fidelity, variables_fidelity, watch_fidelity, evaluate_fidelity, debug_console_fidelity), the full six inspector-state admissions (live, snapshot, stale, limited, unavailable, policy_blocked), the full six mapping-fidelity badge admissions (exact, approximate, partial, unavailable, stale, mismatched), the full six inspector-surface bindings (breakpoint_surface, call_stack_surface, variables_surface, watch_surface, evaluate_surface, debug_console_surface) each attesting the inspector-state and mapping-fidelity vocabularies it is required to preserve, and a lineage_admission row binding execution_context_id. The packet is the single truth that the breakpoint surface, call-stack surface, variables surface, watch surface, evaluate surface, debug-console surface, CLI/headless inspector, evidence export, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies, flatten inspector-state into generic error copy, or paraphrase mapping-fidelity badges.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "harden_breakpoint_call_stack_variables_watch_evaluate_and_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/debug_fidelity_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/debug_fidelity_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 12,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "debug_fidelity_lane_class": {
      "enum": [
        "local_lane",
        "remote_helper_lane",
        "container_lane",
        "notebook_bridge_lane"
      ]
    },
    "debug_fidelity_row_class": {
      "enum": [
        "debug_fidelity_quality",
        "wedge_admission",
        "inspector_state_admission",
        "mapping_fidelity_badge_admission",
        "inspector_surface_binding",
        "lineage_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "wedge_class": {
      "enum": [
        "breakpoint_fidelity",
        "call_stack_fidelity",
        "variables_fidelity",
        "watch_fidelity",
        "evaluate_fidelity",
        "debug_console_fidelity",
        "not_applicable"
      ]
    },
    "inspector_state_class": {
      "enum": [
        "live",
        "snapshot",
        "stale",
        "limited",
        "unavailable",
        "policy_blocked",
        "not_applicable"
      ]
    },
    "mapping_fidelity_badge_class": {
      "enum": [
        "exact",
        "approximate",
        "partial",
        "unavailable",
        "stale",
        "mismatched",
        "not_applicable"
      ]
    },
    "inspector_surface_class": {
      "enum": [
        "breakpoint_surface",
        "call_stack_surface",
        "variables_surface",
        "watch_surface",
        "evaluate_surface",
        "debug_console_surface",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "local_lane_subset_only",
        "remote_helper_subset_only",
        "container_subset_only",
        "notebook_bridge_subset_only",
        "wedge_admission_subset_only",
        "inspector_state_subset_only",
        "mapping_fidelity_badge_subset_only",
        "inspector_surface_subset_only",
        "inspector_state_attestation_skew_declared",
        "mapping_fidelity_attestation_skew_declared",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_wedge_admission_gap",
        "auto_narrow_on_inspector_state_gap",
        "auto_narrow_on_mapping_fidelity_badge_gap",
        "auto_narrow_on_inspector_surface_gap",
        "auto_narrow_on_inspector_state_attestation_gap",
        "auto_narrow_on_mapping_fidelity_attestation_gap",
        "auto_narrow_on_lineage_break",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "debug_fidelity_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_lane_coverage",
        "missing_wedge_admission_coverage",
        "missing_inspector_state_coverage",
        "missing_mapping_fidelity_badge_coverage",
        "missing_inspector_surface_coverage",
        "missing_lineage_admission",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "wedge_not_applicable",
        "wedge_not_permitted_on_row_class",
        "inspector_state_not_applicable",
        "inspector_state_not_permitted_on_row_class",
        "mapping_fidelity_badge_not_applicable",
        "mapping_fidelity_badge_not_permitted_on_row_class",
        "inspector_surface_not_applicable",
        "inspector_surface_not_permitted_on_row_class",
        "inspector_surface_missing_inspector_state_attestation",
        "inspector_surface_missing_mapping_fidelity_attestation",
        "lineage_admission_missing_execution_context_id",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "wedge_vocabulary_collapsed",
        "inspector_state_vocabulary_collapsed",
        "mapping_fidelity_badge_vocabulary_collapsed",
        "inspector_surface_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "debug_fidelity_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "wedge_class",
        "inspector_state_class",
        "mapping_fidelity_badge_class",
        "inspector_surface_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/debug_fidelity_lane_class" },
        "row_class": { "$ref": "#/$defs/debug_fidelity_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "wedge_class": { "$ref": "#/$defs/wedge_class" },
        "inspector_state_class": { "$ref": "#/$defs/inspector_state_class" },
        "mapping_fidelity_badge_class": { "$ref": "#/$defs/mapping_fidelity_badge_class" },
        "inspector_surface_class": { "$ref": "#/$defs/inspector_surface_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/debug_fidelity_confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_id_binding": { "$ref": "#/$defs/non_empty_string" },
        "attests_inspector_state_preserved": { "type": "boolean" },
        "attests_mapping_fidelity_preserved": { "type": "boolean" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "debug_fidelity_truth_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_wedge_vocabulary",
        "preserves_inspector_state_vocabulary",
        "preserves_mapping_fidelity_badge_vocabulary",
        "preserves_inspector_surface_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "breakpoint_surface",
            "call_stack_surface",
            "variables_surface",
            "watch_surface",
            "evaluate_surface",
            "debug_console_surface",
            "cli_headless",
            "evidence_export",
            "support_export",
            "release_proof_index",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "debug_fidelity_truth_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_wedge_vocabulary": { "type": "boolean" },
        "preserves_inspector_state_vocabulary": { "type": "boolean" },
        "preserves_mapping_fidelity_badge_vocabulary": { "type": "boolean" },
        "preserves_inspector_surface_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
