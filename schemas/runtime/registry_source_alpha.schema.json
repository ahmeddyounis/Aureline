{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/registry_source_alpha.schema.json",
  "title": "Aureline registry-source alpha descriptor",
  "description": "Boundary schema for registry_source_alpha_descriptor records used by package-mutation review. The descriptor preserves package source class, auth mode, policy owner, freshness, mirror/offline state, and revocation truth before write or network attempts. Raw registry URLs, hostnames, tokens, certificate material, and package-manager config bodies never appear.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "registry_source_id",
    "package_manager_family",
    "package_manager_family_token",
    "registry_source_class",
    "registry_source_token",
    "source_family_token",
    "auth_mode_class",
    "auth_mode_token",
    "raw_secret_observed",
    "freshness_class",
    "freshness_token",
    "revocation_state_class",
    "revocation_state_token",
    "mirror_or_offline_state_class",
    "mirror_or_offline_state_token",
    "disclosure",
    "visible_before_write",
    "visible_before_network"
  ],
  "properties": {
    "record_kind": { "const": "registry_source_alpha_descriptor" },
    "schema_version": { "const": 1 },
    "registry_source_id": { "$ref": "#/$defs/non_empty_string" },
    "package_manager_family": { "$ref": "#/$defs/package_manager_family" },
    "package_manager_family_token": { "$ref": "#/$defs/package_manager_family" },
    "registry_source_class": { "$ref": "#/$defs/registry_source_class" },
    "registry_source_token": { "$ref": "#/$defs/registry_source_class" },
    "source_family_token": {
      "type": "string",
      "enum": ["public", "private", "mirror", "offline", "workspace_or_vendored", "unknown"]
    },
    "auth_mode_class": { "$ref": "#/$defs/registry_auth_mode_class" },
    "auth_mode_token": { "$ref": "#/$defs/registry_auth_mode_class" },
    "policy_owner_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
    "secret_broker_handle_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
    "delegated_identity_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
    "raw_secret_observed": { "type": "boolean" },
    "freshness_class": { "$ref": "#/$defs/freshness_class" },
    "freshness_token": { "$ref": "#/$defs/freshness_class" },
    "revocation_state_class": { "$ref": "#/$defs/revocation_state_class" },
    "revocation_state_token": { "$ref": "#/$defs/revocation_state_class" },
    "mirror_or_offline_state_class": { "$ref": "#/$defs/mirror_or_offline_state_class" },
    "mirror_or_offline_state_token": { "$ref": "#/$defs/mirror_or_offline_state_class" },
    "disclosure": {
      "type": "string",
      "minLength": 1,
      "description": "Short review-safe sentence. Raw URLs and secrets are forbidden."
    },
    "visible_before_write": { "type": "boolean", "const": true },
    "visible_before_network": { "type": "boolean", "const": true }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "nullable_non_empty_string": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/non_empty_string" }]
    },
    "package_manager_family": {
      "type": "string",
      "enum": ["npm", "pnpm", "package_manager_unknown_requires_review"]
    },
    "registry_source_class": {
      "type": "string",
      "enum": [
        "public_default_registry",
        "public_alternate_registry",
        "vendor_published_mirror",
        "customer_operated_mirror",
        "private_internal_registry",
        "managed_org_curated_registry",
        "offline_bundle_registry",
        "vendored_directory_no_registry",
        "git_or_path_dependency_no_registry",
        "registry_source_unknown_requires_review"
      ]
    },
    "registry_auth_mode_class": {
      "type": "string",
      "enum": [
        "no_auth_public_registry",
        "secret_broker_handle_auth",
        "delegated_identity_auth",
        "policy_injected_credential_auth",
        "mirror_or_offline_no_auth_required",
        "managed_service_identity_auth",
        "mtls_client_certificate_auth",
        "device_flow_callback_auth",
        "registry_auth_unknown_requires_review",
        "registry_auth_unsupported_blocked"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "cached_within_freshness_window",
        "mirror_snapshot_within_policy_window",
        "stale_requires_review",
        "offline_bundle_pinned",
        "freshness_unknown_requires_review"
      ]
    },
    "revocation_state_class": {
      "type": "string",
      "enum": [
        "revocation_checked_current",
        "revocation_checked_from_mirror",
        "revocation_check_unavailable_stale",
        "revocation_blocked_by_policy",
        "revocation_status_unknown_requires_review"
      ]
    },
    "mirror_or_offline_state_class": {
      "type": "string",
      "enum": [
        "online_default_origin_admissible",
        "online_mirror_pinned_no_direct_origin",
        "offline_grace_window_using_warm_cache",
        "offline_air_gapped_using_offline_bundle_only",
        "network_disabled_user_setting_or_policy",
        "mirror_or_offline_state_unknown_requires_review"
      ]
    }
  }
}
