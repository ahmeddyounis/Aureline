{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/network_event_ref.schema.json",
  "title": "Aureline browser network event reference record",
  "description": "Boundary schema for network_event_ref_record defined in docs/runtime/browser_inspection_contract.md. A network event reference binds browser-runtime session identity, preview route, preview snapshot, task channel, support bundle, exact-build identity, capture mode, live/imported/replayed state, source-map state, request class, initiator, result posture, cache/service-worker posture, copy/export policy, and replay admissibility without carrying raw URLs, raw hostnames, raw query strings, raw request or response headers, raw cookies, raw request bodies, raw response bodies, raw bearer tokens, raw client certificates, raw provider payloads, or raw HAR bodies.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/network_event_ref_record" }
  ],
  "$defs": {
    "network_event_ref_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "network_event_ref_record"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque identifier safe for support bundles and exported evidence. Raw URLs, hosts, paths, query strings, headers, cookies, tokens, and payloads never appear here."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_id" },
        { "type": "null" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 520,
      "description": "Short sentence safe for row labels, export review, and support. Raw URLs, headers, cookies, tokens, payloads, paths, hostnames, and provider payloads are forbidden."
    },
    "capture_mode_class": {
      "type": "string",
      "enum": [
        "live_runtime_stream",
        "live_runtime_snapshot",
        "imported_browser_handoff",
        "imported_support_bundle",
        "replay_capture",
        "hosted_review_reader",
        "synthetic_fixture",
        "capture_mode_unknown_requires_review"
      ]
    },
    "liveness_class": {
      "type": "string",
      "enum": [
        "live_current",
        "live_drifted",
        "imported_read_only",
        "replayed_read_only",
        "cached_read_only",
        "blocked_inspect_only",
        "unavailable"
      ]
    },
    "evidence_origin_class": {
      "type": "string",
      "enum": [
        "live_capture_from_attached_runtime",
        "imported_from_browser_handoff_packet",
        "imported_from_support_export_bundle",
        "imported_from_replay_capture",
        "imported_from_hosted_review_reader",
        "evidence_origin_unverifiable_user_review_required"
      ]
    },
    "source_map_state_class": {
      "type": "string",
      "enum": [
        "source_map_in_sync_with_runtime",
        "source_map_in_sync_with_session_capture",
        "source_map_stale_runtime_advanced_since_capture",
        "source_map_inline_only_no_external_map",
        "source_map_missing_runtime_only",
        "source_map_redacted_for_export",
        "source_map_freshness_unknown_requires_review"
      ]
    },
    "mapping_fidelity_class": {
      "type": "string",
      "enum": [
        "exact_source_mapping",
        "approximate_source_mapping",
        "generated_only_mapping",
        "framework_only_mapping",
        "runtime_only_mapping",
        "unavailable_mapping",
        "mapping_fidelity_unknown_requires_review"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "headers_and_keys_redacted",
        "values_redacted",
        "payload_bodies_omitted",
        "local_only_sensitive",
        "blocked_sensitive_value",
        "provider_data_restricted"
      ]
    },
    "policy_restriction_class": {
      "type": "string",
      "enum": [
        "no_policy_restriction",
        "export_redacted_only",
        "export_metadata_only",
        "export_forbidden",
        "replay_requires_review",
        "mutation_requires_review",
        "reveal_requires_local_review",
        "blocked_by_policy",
        "blocked_by_workspace_trust",
        "partner_provider_data_do_not_export",
        "inspect_only_runtime_identity_weak"
      ]
    },
    "drift_disclosure_class": {
      "type": "string",
      "enum": [
        "no_drift_disclosure_required",
        "source_map_stale_disclosed",
        "live_dom_css_edit_uncommitted",
        "replayed_network_traffic_disclosed",
        "cached_service_worker_state_disclosed",
        "storage_mutation_side_effect_disclosed",
        "runtime_identity_weak_inspect_only_disclosed",
        "imported_evidence_disclosed",
        "preview_route_drift_disclosed",
        "policy_limited_evidence_disclosed"
      ]
    },
    "http_method_class": {
      "type": "string",
      "enum": [
        "get",
        "post",
        "put",
        "patch",
        "delete",
        "options",
        "head",
        "other_method",
        "method_unknown_redacted"
      ]
    },
    "request_target_class": {
      "type": "string",
      "enum": [
        "same_origin_api",
        "same_site_cross_origin_api",
        "cross_site_cors_api",
        "static_asset",
        "hmr_or_dev_server",
        "browser_extension_request",
        "preview_gateway_request",
        "service_worker_internal_request",
        "partner_provider_data_request",
        "request_target_unknown_requires_review"
      ]
    },
    "initiator_class": {
      "type": "string",
      "enum": [
        "app_code",
        "framework_runtime",
        "service_worker",
        "hmr_runtime",
        "browser_extension",
        "preview_gateway",
        "user_replay_review",
        "imported_evidence_reader",
        "initiator_unknown_requires_review"
      ]
    },
    "status_class": {
      "type": "string",
      "enum": [
        "status_1xx",
        "status_2xx",
        "status_3xx",
        "status_4xx",
        "status_5xx",
        "blocked_by_browser",
        "blocked_by_policy",
        "network_error",
        "cancelled",
        "status_not_captured"
      ]
    },
    "timing_class": {
      "type": "string",
      "enum": [
        "timing_exact_live",
        "timing_approximate",
        "timing_redacted",
        "timing_unavailable"
      ]
    },
    "cache_state_class": {
      "type": "string",
      "enum": [
        "not_cached",
        "browser_http_cache",
        "service_worker_cache_live",
        "service_worker_cache_stale",
        "cache_storage_replay",
        "imported_cache_metadata",
        "cache_state_unknown_requires_review"
      ]
    },
    "payload_component_class": {
      "type": "string",
      "enum": [
        "not_present",
        "metadata_only",
        "redacted_present",
        "hash_only",
        "local_only_available_after_review",
        "blocked_sensitive_value",
        "unknown_requires_review"
      ]
    },
    "copy_request_class": {
      "type": "string",
      "enum": [
        "copy_redacted_summary",
        "copy_headers_and_keys_redacted",
        "copy_metadata_only",
        "copy_local_only_after_review",
        "copy_forbidden"
      ]
    },
    "har_evidence_class": {
      "type": "string",
      "enum": [
        "har_metadata_only",
        "har_redacted_headers_and_bodies",
        "har_local_only_after_review",
        "har_by_reference_only",
        "har_forbidden"
      ]
    },
    "replay_admissibility_class": {
      "type": "string",
      "enum": [
        "replay_allowed_unchanged_reviewed",
        "replay_allowed_modified_payload_reviewed",
        "replay_requires_new_review",
        "replay_blocked_imported_or_replayed",
        "replay_blocked_stale_source_map",
        "replay_blocked_service_worker_cache_state",
        "replay_blocked_sensitive_values",
        "replay_blocked_target_identity_weak",
        "replay_forbidden_by_policy",
        "replay_not_applicable"
      ]
    },
    "viewer_linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_route_record_ref",
        "preview_snapshot_record_ref",
        "task_channel_ref",
        "support_bundle_ref",
        "exact_build_identity_ref",
        "evidence_packet_ref"
      ],
      "properties": {
        "preview_route_record_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "preview_snapshot_record_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "task_channel_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "support_bundle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "exact_build_identity_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "evidence_packet_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "hosted_review_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "companion_handoff_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "capture_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capture_mode_class",
        "liveness_class",
        "evidence_origin_class",
        "inspected_at"
      ],
      "properties": {
        "capture_mode_class": { "$ref": "#/$defs/capture_mode_class" },
        "liveness_class": { "$ref": "#/$defs/liveness_class" },
        "evidence_origin_class": { "$ref": "#/$defs/evidence_origin_class" },
        "inspected_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "capture_window_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "source_map_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_map_state_class",
        "mapping_fidelity_class",
        "source_map_handle_ref",
        "summary"
      ],
      "properties": {
        "source_map_state_class": { "$ref": "#/$defs/source_map_state_class" },
        "mapping_fidelity_class": { "$ref": "#/$defs/mapping_fidelity_class" },
        "source_map_handle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "request_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method_class",
        "request_target_class",
        "target_origin_label_ref",
        "route_handle_ref",
        "request_digest_ref"
      ],
      "properties": {
        "method_class": { "$ref": "#/$defs/http_method_class" },
        "request_target_class": { "$ref": "#/$defs/request_target_class" },
        "target_origin_label_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "route_handle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "request_digest_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "result_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status_class",
        "timing_class",
        "duration_ms",
        "bytes_sent_estimate",
        "bytes_received_estimate"
      ],
      "properties": {
        "status_class": { "$ref": "#/$defs/status_class" },
        "timing_class": { "$ref": "#/$defs/timing_class" },
        "duration_ms": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "bytes_sent_estimate": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "bytes_received_estimate": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        }
      }
    },
    "payload_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_headers_class",
        "request_body_class",
        "response_headers_class",
        "response_body_class",
        "cookie_header_class"
      ],
      "properties": {
        "request_headers_class": { "$ref": "#/$defs/payload_component_class" },
        "request_body_class": { "$ref": "#/$defs/payload_component_class" },
        "response_headers_class": { "$ref": "#/$defs/payload_component_class" },
        "response_body_class": { "$ref": "#/$defs/payload_component_class" },
        "cookie_header_class": { "$ref": "#/$defs/payload_component_class" },
        "payload_digest_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "cache_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cache_state_class",
        "service_worker_registration_ref",
        "summary"
      ],
      "properties": {
        "cache_state_class": { "$ref": "#/$defs/cache_state_class" },
        "service_worker_registration_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "copy_export_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "copy_request_class",
        "har_evidence_class",
        "support_bundle_inclusion_class",
        "summary"
      ],
      "properties": {
        "copy_request_class": { "$ref": "#/$defs/copy_request_class" },
        "har_evidence_class": { "$ref": "#/$defs/har_evidence_class" },
        "support_bundle_inclusion_class": {
          "type": "string",
          "enum": [
            "included_redacted_by_default",
            "included_metadata_only",
            "local_only_reference",
            "excluded_by_default",
            "excluded_always"
          ]
        },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "policy_restriction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_restriction_class",
        "enforced_by_ref",
        "summary"
      ],
      "properties": {
        "policy_restriction_class": { "$ref": "#/$defs/policy_restriction_class" },
        "enforced_by_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redaction_class",
        "raw_headers_permitted",
        "raw_bodies_permitted",
        "raw_cookies_permitted",
        "summary"
      ],
      "properties": {
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "raw_headers_permitted": { "type": "boolean" },
        "raw_bodies_permitted": { "type": "boolean" },
        "raw_cookies_permitted": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "network_event_ref_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "network_event_ref_schema_version",
        "network_event_ref_id",
        "captured_at",
        "browser_runtime_session_record_ref",
        "viewer_linkage",
        "capture_context",
        "source_map_state",
        "request_identity",
        "initiator_class",
        "result_summary",
        "payload_posture",
        "cache_state",
        "redaction",
        "policy_restrictions",
        "copy_export_policy",
        "replay_admissibility_class",
        "drift_disclosures",
        "summary"
      ],
      "properties": {
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "network_event_ref_schema_version": { "$ref": "#/$defs/network_event_ref_schema_version" },
        "network_event_ref_id": { "$ref": "#/$defs/opaque_id" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "browser_runtime_session_record_ref": { "$ref": "#/$defs/opaque_id" },
        "viewer_linkage": { "$ref": "#/$defs/viewer_linkage" },
        "capture_context": { "$ref": "#/$defs/capture_context" },
        "source_map_state": { "$ref": "#/$defs/source_map_state" },
        "request_identity": { "$ref": "#/$defs/request_identity" },
        "initiator_class": { "$ref": "#/$defs/initiator_class" },
        "result_summary": { "$ref": "#/$defs/result_summary" },
        "payload_posture": { "$ref": "#/$defs/payload_posture" },
        "cache_state": { "$ref": "#/$defs/cache_state" },
        "redaction": { "$ref": "#/$defs/redaction" },
        "policy_restrictions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/policy_restriction" }
        },
        "copy_export_policy": { "$ref": "#/$defs/copy_export_policy" },
        "replay_admissibility_class": { "$ref": "#/$defs/replay_admissibility_class" },
        "drift_disclosures": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/drift_disclosure_class" },
          "uniqueItems": true
        },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "description": "Imported, replayed, hosted-review, synthetic, and unknown captures cannot claim live_current liveness or replay without a new review.",
          "if": {
            "properties": {
              "capture_context": {
                "properties": {
                  "capture_mode_class": {
                    "enum": [
                      "imported_browser_handoff",
                      "imported_support_bundle",
                      "replay_capture",
                      "hosted_review_reader",
                      "synthetic_fixture",
                      "capture_mode_unknown_requires_review"
                    ]
                  }
                },
                "required": ["capture_mode_class"]
              }
            }
          },
          "then": {
            "properties": {
              "capture_context": {
                "properties": {
                  "liveness_class": {
                    "not": { "const": "live_current" }
                  }
                }
              },
              "replay_admissibility_class": {
                "not": {
                  "enum": [
                    "replay_allowed_unchanged_reviewed",
                    "replay_allowed_modified_payload_reviewed"
                  ]
                }
              }
            }
          }
        },
        {
          "description": "Stale, missing, redacted, or unknown source maps block modified-payload replay and require stale-source disclosure.",
          "if": {
            "properties": {
              "source_map_state": {
                "properties": {
                  "source_map_state_class": {
                    "enum": [
                      "source_map_stale_runtime_advanced_since_capture",
                      "source_map_missing_runtime_only",
                      "source_map_redacted_for_export",
                      "source_map_freshness_unknown_requires_review"
                    ]
                  }
                },
                "required": ["source_map_state_class"]
              }
            }
          },
          "then": {
            "properties": {
              "replay_admissibility_class": {
                "not": { "const": "replay_allowed_modified_payload_reviewed" }
              },
              "drift_disclosures": {
                "contains": { "const": "source_map_stale_disclosed" }
              }
            }
          }
        },
        {
          "description": "Stale or unknown service-worker cache state blocks replay and requires a service-worker cache disclosure.",
          "if": {
            "properties": {
              "cache_state": {
                "properties": {
                  "cache_state_class": {
                    "enum": [
                      "service_worker_cache_stale",
                      "cache_state_unknown_requires_review"
                    ]
                  }
                },
                "required": ["cache_state_class"]
              }
            }
          },
          "then": {
            "properties": {
              "replay_admissibility_class": {
                "enum": [
                  "replay_blocked_service_worker_cache_state",
                  "replay_forbidden_by_policy",
                  "replay_not_applicable"
                ]
              },
              "drift_disclosures": {
                "contains": { "const": "cached_service_worker_state_disclosed" }
              }
            }
          }
        },
        {
          "description": "Sensitive redaction classes forbid raw headers, bodies, and cookies.",
          "if": {
            "properties": {
              "redaction": {
                "properties": {
                  "redaction_class": {
                    "enum": [
                      "local_only_sensitive",
                      "blocked_sensitive_value",
                      "provider_data_restricted"
                    ]
                  }
                },
                "required": ["redaction_class"]
              }
            }
          },
          "then": {
            "properties": {
              "redaction": {
                "properties": {
                  "raw_headers_permitted": { "const": false },
                  "raw_bodies_permitted": { "const": false },
                  "raw_cookies_permitted": { "const": false }
                }
              }
            }
          }
        },
        {
          "description": "Partner/provider data requests cannot produce raw copied requests or raw HAR evidence by default.",
          "if": {
            "properties": {
              "request_identity": {
                "properties": {
                  "request_target_class": { "const": "partner_provider_data_request" }
                },
                "required": ["request_target_class"]
              }
            }
          },
          "then": {
            "properties": {
              "copy_export_policy": {
                "properties": {
                  "copy_request_class": {
                    "enum": [
                      "copy_redacted_summary",
                      "copy_metadata_only",
                      "copy_forbidden"
                    ]
                  },
                  "har_evidence_class": {
                    "enum": [
                      "har_metadata_only",
                      "har_by_reference_only",
                      "har_forbidden"
                    ]
                  }
                }
              },
              "policy_restrictions": {
                "contains": {
                  "properties": {
                    "policy_restriction_class": { "const": "partner_provider_data_do_not_export" }
                  },
                  "required": ["policy_restriction_class"]
                }
              }
            }
          }
        }
      ]
    }
  }
}
