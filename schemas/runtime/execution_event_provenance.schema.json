{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/execution_event_provenance.schema.json",
  "title": "Aureline execution-event provenance",
  "description": "Redaction-safe projection of a canonical execution context for downstream task, test, debug-prep, review, and support-export events. The projection carries ids, class tokens, resolver decisions, digests, policy/trust state, prebuild state, and degraded markers only; it must not carry raw command lines, raw environment bodies, secrets, or raw working-directory paths.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/execution_event_provenance_record" },
    { "$ref": "#/$defs/execution_provenance_event_record" },
    { "$ref": "#/$defs/execution_provenance_alpha_case" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "opaque_id": { "type": "string", "minLength": 1 },
    "date_time": { "type": "string", "format": "date-time" },
    "surface_class": {
      "type": "string",
      "enum": [
        "terminal",
        "task",
        "debug",
        "test",
        "notebook_kernel",
        "scaffolding",
        "ai_tool_call",
        "doctor_repair",
        "import_probe",
        "replay_probe"
      ]
    },
    "actor_class": {
      "type": "string",
      "enum": [
        "user_keystroke",
        "user_command",
        "session_override",
        "workspace_migration",
        "extension_api",
        "ai_apply",
        "scheduled_task",
        "imported_profile",
        "admin_policy_injector"
      ]
    },
    "target_class": {
      "type": "string",
      "enum": [
        "local_host",
        "ssh_remote",
        "container_local",
        "devcontainer",
        "remote_workspace_vm",
        "prebuild_runtime",
        "managed_workspace",
        "notebook_kernel_local",
        "notebook_kernel_remote",
        "ai_sandbox"
      ]
    },
    "reachability_state": {
      "type": "string",
      "enum": [
        "reachable",
        "warming",
        "degraded",
        "unreachable",
        "policy_blocked"
      ]
    },
    "confidence_level": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "toolchain_class": {
      "type": "string",
      "enum": [
        "interpreter",
        "compiler_toolchain",
        "package_manager_runner",
        "containerised_runtime",
        "notebook_kernel_runtime",
        "language_server_process",
        "debug_adapter_runtime",
        "test_runner_runtime",
        "build_driver_runtime",
        "ai_tool_runtime",
        "login_shell"
      ]
    },
    "prebuild_reuse_state": {
      "type": "string",
      "enum": [
        "not_applicable",
        "candidate",
        "reused",
        "rejected_drift",
        "rejected_policy",
        "rejected_trust"
      ]
    },
    "trust_state": {
      "type": "string",
      "enum": ["trusted", "restricted", "pending_evaluation"]
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "current_root",
        "named_workset",
        "sparse_slice",
        "full_workspace",
        "policy_limited_view",
        "review_workspace",
        "companion_surface"
      ]
    },
    "cache_disposition": {
      "type": "string",
      "enum": [
        "cold",
        "warm",
        "prebuild_reused",
        "capsule_reused",
        "rejected_drift",
        "rejected_policy",
        "rejected_trust"
      ]
    },
    "resolver_input_field": {
      "type": "string",
      "enum": ["target_class", "working_directory", "toolchain_class"]
    },
    "resolver_input_source": {
      "type": "string",
      "enum": [
        "explicit_override",
        "surface_requested",
        "workspace_default",
        "resolver_fallback"
      ]
    },
    "event_class": {
      "type": "string",
      "enum": ["task", "test", "debug_prep", "review", "support_export"]
    },
    "string_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_id" }
    },
    "input_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "field_token",
        "winning_source",
        "winning_source_token",
        "resolved_value_token"
      ],
      "properties": {
        "field": { "$ref": "#/$defs/resolver_input_field" },
        "field_token": { "$ref": "#/$defs/resolver_input_field" },
        "winning_source": { "$ref": "#/$defs/resolver_input_source" },
        "winning_source_token": { "$ref": "#/$defs/resolver_input_source" },
        "resolved_value_token": { "$ref": "#/$defs/opaque_id" },
        "conflicting_source_tokens": { "$ref": "#/$defs/string_array" }
      }
    },
    "execution_event_provenance_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "context_provenance_id",
        "execution_context_ref",
        "provenance_record_ref",
        "recorded_at",
        "resolver_version",
        "workspace_id",
        "command_id",
        "surface",
        "surface_token",
        "actor_class",
        "actor_class_token",
        "target_id",
        "target_class",
        "target_class_token",
        "reachability_state",
        "reachability_state_token",
        "boundary_cue_visible",
        "target_confidence_level",
        "target_confidence_level_token",
        "toolchain_class",
        "toolchain_class_token",
        "toolchain_id",
        "resolved_version",
        "environment_capsule_ref",
        "environment_capsule_hash",
        "environment_capsule_drift_token",
        "working_directory_present",
        "prebuild_reuse_state",
        "prebuild_reuse_state_token",
        "prebuild_compatibility_fingerprint",
        "trust_state",
        "trust_state_token",
        "identity_mode_token",
        "policy_epoch",
        "scope_class",
        "scope_class_token",
        "cache_disposition",
        "cache_disposition_token",
        "mixed_version_state_token",
        "mixed_version_reason_token",
        "client_protocol",
        "input_decisions",
        "degraded_field_count",
        "redaction_class",
        "redaction_safe",
        "reconstruction_fields"
      ],
      "properties": {
        "record_kind": { "const": "execution_event_provenance_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "context_provenance_id": { "$ref": "#/$defs/opaque_id" },
        "execution_context_ref": { "$ref": "#/$defs/opaque_id" },
        "provenance_record_ref": { "$ref": "#/$defs/opaque_id" },
        "recorded_at": { "$ref": "#/$defs/date_time" },
        "resolver_version": { "$ref": "#/$defs/opaque_id" },
        "workspace_id": { "$ref": "#/$defs/opaque_id" },
        "command_id": { "$ref": "#/$defs/opaque_id" },
        "surface": { "$ref": "#/$defs/surface_class" },
        "surface_token": { "$ref": "#/$defs/surface_class" },
        "actor_class": { "$ref": "#/$defs/actor_class" },
        "actor_class_token": { "$ref": "#/$defs/actor_class" },
        "target_id": { "$ref": "#/$defs/opaque_id" },
        "target_class": { "$ref": "#/$defs/target_class" },
        "target_class_token": { "$ref": "#/$defs/target_class" },
        "reachability_state": { "$ref": "#/$defs/reachability_state" },
        "reachability_state_token": { "$ref": "#/$defs/reachability_state" },
        "boundary_cue_visible": { "type": "boolean" },
        "target_confidence_level": { "$ref": "#/$defs/confidence_level" },
        "target_confidence_level_token": { "$ref": "#/$defs/confidence_level" },
        "target_confidence_reason_tokens": { "$ref": "#/$defs/string_array" },
        "toolchain_class": { "$ref": "#/$defs/toolchain_class" },
        "toolchain_class_token": { "$ref": "#/$defs/toolchain_class" },
        "toolchain_id": { "$ref": "#/$defs/opaque_id" },
        "resolved_version": { "$ref": "#/$defs/opaque_id" },
        "environment_capsule_ref": { "$ref": "#/$defs/opaque_id" },
        "environment_capsule_hash": { "$ref": "#/$defs/opaque_id" },
        "environment_capsule_drift_token": { "$ref": "#/$defs/opaque_id" },
        "working_directory_present": { "type": "boolean" },
        "working_directory_digest": { "$ref": "#/$defs/opaque_id" },
        "prebuild_reuse_state": { "$ref": "#/$defs/prebuild_reuse_state" },
        "prebuild_reuse_state_token": { "$ref": "#/$defs/prebuild_reuse_state" },
        "prebuild_snapshot_ref": { "$ref": "#/$defs/opaque_id" },
        "prebuild_compatibility_fingerprint": { "$ref": "#/$defs/opaque_id" },
        "prebuild_invalidation_reason_token": { "$ref": "#/$defs/opaque_id" },
        "trust_state": { "$ref": "#/$defs/trust_state" },
        "trust_state_token": { "$ref": "#/$defs/trust_state" },
        "identity_mode_token": { "$ref": "#/$defs/opaque_id" },
        "policy_epoch": { "type": "integer", "minimum": 0 },
        "scope_class": { "$ref": "#/$defs/scope_class" },
        "scope_class_token": { "$ref": "#/$defs/scope_class" },
        "cache_disposition": { "$ref": "#/$defs/cache_disposition" },
        "cache_disposition_token": { "$ref": "#/$defs/cache_disposition" },
        "mixed_version_state_token": { "$ref": "#/$defs/opaque_id" },
        "mixed_version_reason_token": { "$ref": "#/$defs/opaque_id" },
        "client_protocol": { "$ref": "#/$defs/opaque_id" },
        "helper_protocol": { "$ref": "#/$defs/opaque_id" },
        "input_decisions": {
          "type": "array",
          "items": { "$ref": "#/$defs/input_decision" }
        },
        "degraded_field_count": { "type": "integer", "minimum": 0 },
        "degraded_field_tokens": { "$ref": "#/$defs/string_array" },
        "explanation_reason_code_tokens": { "$ref": "#/$defs/string_array" },
        "redaction_class": { "const": "metadata_safe_default" },
        "redaction_safe": { "const": true },
        "reconstruction_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      }
    },
    "execution_provenance_event_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "event_id",
        "event_class",
        "event_class_token",
        "subject_ref",
        "occurred_at",
        "context_provenance"
      ],
      "properties": {
        "record_kind": { "const": "execution_provenance_event_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "event_id": { "$ref": "#/$defs/opaque_id" },
        "event_class": { "$ref": "#/$defs/event_class" },
        "event_class_token": { "$ref": "#/$defs/event_class" },
        "subject_ref": { "$ref": "#/$defs/opaque_id" },
        "occurred_at": { "$ref": "#/$defs/date_time" },
        "context_provenance": {
          "$ref": "#/$defs/execution_event_provenance_record"
        }
      }
    },
    "execution_provenance_alpha_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "case_id",
        "context_provenance",
        "events",
        "expect"
      ],
      "properties": {
        "record_kind": { "const": "execution_provenance_alpha_case" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "context_provenance": {
          "$ref": "#/$defs/execution_event_provenance_record"
        },
        "events": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/execution_provenance_event_record" }
        },
        "expect": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "all_events_share_context_provenance_id",
            "raw_working_directory_exported",
            "redaction_safe"
          ],
          "properties": {
            "all_events_share_context_provenance_id": { "$ref": "#/$defs/opaque_id" },
            "raw_working_directory_exported": { "const": false },
            "redaction_safe": { "const": true }
          }
        }
      }
    }
  }
}
