{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/resource_target.schema.json",
  "title": "Aureline resource-target record",
  "description": "Boundary schema for a deployable unit, service, job, config, queue, provider object, or other live resource that may be shown in source, rendered, planned, live, cached, provider-overlay, or imported-snapshot form. The record keeps authored source refs, rendered artifact refs, live handles, owner bindings, route bindings, connector bindings, target context, freshness, and authority posture separate so runtime snapshots never become the implicit source of truth.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/resource_target_record" },
    { "$ref": "#/$defs/resource_target_audit_event_record" }
  ],
  "$defs": {
    "resource_target_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this resource-target family. Additive optional fields or enum values bump this const; repurposing an existing value is breaking and requires a new governance decision."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "resource_target_record",
        "resource_target_audit_event_record"
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe to log and export. Raw credentials, private endpoint URLs, and raw provider payload bodies are forbidden."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_timestamp": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/monotonic_timestamp" }
      ]
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 360,
      "description": "Short operator-facing sentence safe for action sheets, support bundles, runbook packets, and CLI JSON. Secret material and raw provider payloads MUST NOT appear."
    },
    "target_truth_layer": {
      "type": "string",
      "enum": [
        "desired",
        "rendered",
        "planned",
        "live",
        "provider_overlay",
        "cached_live",
        "imported_snapshot",
        "unknown"
      ],
      "description": "Truth layer represented by a ref or handle. Desired source, rendered artifact, planned result, live object, overlay, cache, and imported snapshot are never interchangeable."
    },
    "resource_kind": {
      "type": "string",
      "enum": [
        "deployable_unit",
        "service",
        "job",
        "config",
        "queue",
        "database",
        "endpoint",
        "secret_reference",
        "storage",
        "topic",
        "stream",
        "runtime_host",
        "provider_overlay",
        "other_live_resource"
      ],
      "description": "Resource family. Specific providers may map their native kinds into one of these cross-surface classes while preserving native kind in handles."
    },
    "resource_target_state_class": {
      "type": "string",
      "enum": [
        "desired_only",
        "rendered_only",
        "planned_only",
        "live_only",
        "linked_desired_rendered_live",
        "drifted",
        "cached",
        "permission_limited",
        "unavailable",
        "imported_snapshot",
        "unknown"
      ],
      "description": "Current resource-target posture. Mutating surfaces must not collapse cached, permission-limited, imported, unavailable, or unknown states into live authority."
    },
    "source_ref_class": {
      "type": "string",
      "enum": [
        "workspace_file",
        "repository_object",
        "generated_source",
        "policy_manifest",
        "template",
        "imported_source",
        "unknown"
      ]
    },
    "rendered_artifact_class": {
      "type": "string",
      "enum": [
        "kustomize_output",
        "helm_output",
        "terraform_plan",
        "terraform_state_projection",
        "compose_model",
        "devcontainer_model",
        "ci_environment_model",
        "policy_expansion",
        "custom_rendered_artifact",
        "unknown"
      ]
    },
    "owner_kind": {
      "type": "string",
      "enum": [
        "team",
        "service",
        "repository",
        "component",
        "runbook",
        "incident",
        "provider_owner",
        "manual",
        "unknown"
      ]
    },
    "binding_posture": {
      "type": "string",
      "enum": [
        "read_only",
        "inspect_only",
        "dry_run_only",
        "mutation_pending_approval",
        "mutation_approved",
        "mutation_blocked",
        "handoff_only",
        "unknown"
      ],
      "description": "Effective authority posture for the route or connector binding."
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "live",
        "current_snapshot",
        "cached_within_floor",
        "stale",
        "partial",
        "offline",
        "imported_read_only",
        "unknown"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_only",
        "metadata_and_hashes",
        "redacted_summary",
        "operator_restricted",
        "support_restricted"
      ]
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truth_layer",
        "source_ref_class",
        "source_ref",
        "repository_ref",
        "revision_ref",
        "path",
        "selector",
        "digest",
        "source_authority_ref"
      ],
      "properties": {
        "truth_layer": { "const": "desired" },
        "source_ref_class": { "$ref": "#/$defs/source_ref_class" },
        "source_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "repository_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "revision_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "path": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "selector": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "digest": { "$ref": "#/$defs/nullable_opaque_id" },
        "source_authority_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      },
      "description": "Authored or desired source identity. A live object may omit this only by carrying an explicit live-only, imported, or unknown state."
    },
    "rendered_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truth_layer",
        "rendered_artifact_class",
        "rendered_ref",
        "renderer_identity_ref",
        "renderer_version",
        "input_set_ref",
        "artifact_digest",
        "freshness_class"
      ],
      "properties": {
        "truth_layer": { "const": "rendered" },
        "rendered_artifact_class": { "$ref": "#/$defs/rendered_artifact_class" },
        "rendered_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "renderer_identity_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "renderer_version": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "input_set_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "artifact_digest": { "$ref": "#/$defs/nullable_opaque_id" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" }
      },
      "description": "Rendered or expanded artifact identity derived from source and tool identity."
    },
    "live_handle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truth_layer",
        "live_handle_ref",
        "provider_class",
        "target_context_ref",
        "connector_session_ref",
        "group_version_kind",
        "provider_native_kind",
        "name",
        "namespace_or_scope",
        "stable_live_uid",
        "live_generation",
        "observed_at",
        "freshness_class",
        "raw_response_ref"
      ],
      "properties": {
        "truth_layer": {
          "type": "string",
          "enum": [
            "live",
            "cached_live",
            "provider_overlay",
            "imported_snapshot",
            "unknown"
          ]
        },
        "live_handle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "provider_class": {
          "$ref": "target_context.schema.json#/$defs/provider_class"
        },
        "target_context_ref": { "$ref": "#/$defs/opaque_id" },
        "connector_session_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "group_version_kind": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "provider_native_kind": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "name": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "namespace_or_scope": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "stable_live_uid": { "$ref": "#/$defs/nullable_opaque_id" },
        "live_generation": { "$ref": "#/$defs/nullable_opaque_id" },
        "observed_at": { "$ref": "#/$defs/nullable_timestamp" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "raw_response_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      },
      "description": "Live, cached-live, provider-overlay, or imported-snapshot handle. Raw provider payloads stay behind raw_response_ref."
    },
    "owner_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_kind",
        "owner_ref",
        "owner_source_ref",
        "ownership_confidence",
        "summary"
      ],
      "properties": {
        "owner_kind": { "$ref": "#/$defs/owner_kind" },
        "owner_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "owner_source_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "ownership_confidence": {
          "type": "string",
          "enum": [
            "exact",
            "inferred",
            "partial",
            "unknown"
          ]
        },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "description": "Owner or service binding used by support, incident, and export packets."
    },
    "route_or_connector_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_context_ref",
        "connector_session_ref",
        "route_truth_ref",
        "action_review_ref",
        "browser_handoff_packet_ref",
        "authority_linkage_ref",
        "binding_posture"
      ],
      "properties": {
        "target_context_ref": { "$ref": "#/$defs/opaque_id" },
        "connector_session_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "route_truth_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "action_review_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "browser_handoff_packet_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "authority_linkage_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "binding_posture": { "$ref": "#/$defs/binding_posture" }
      },
      "description": "Route and connector join keys. Static source parsing alone never grants mutation authority."
    },
    "resource_target_record": {
      "type": "object",
      "unevaluatedProperties": false,
      "required": [
        "record_kind",
        "resource_target_schema_version",
        "resource_target_id",
        "display_label",
        "resource_kind",
        "stable_identity",
        "state_class",
        "target_context_ref",
        "source_refs",
        "rendered_refs",
        "live_handles",
        "owner_binding",
        "route_or_connector_bindings",
        "freshness_class",
        "redaction_class",
        "created_at",
        "audit_refs"
      ],
      "properties": {
        "record_kind": { "const": "resource_target_record" },
        "resource_target_schema_version": {
          "$ref": "#/$defs/resource_target_schema_version"
        },
        "resource_target_id": { "$ref": "#/$defs/opaque_id" },
        "display_label": { "$ref": "#/$defs/reviewable_sentence" },
        "resource_kind": { "$ref": "#/$defs/resource_kind" },
        "stable_identity": { "$ref": "#/$defs/opaque_id" },
        "state_class": { "$ref": "#/$defs/resource_target_state_class" },
        "target_context_ref": { "$ref": "#/$defs/opaque_id" },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_ref" }
        },
        "rendered_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/rendered_ref" }
        },
        "live_handles": {
          "type": "array",
          "items": { "$ref": "#/$defs/live_handle" }
        },
        "owner_binding": { "$ref": "#/$defs/owner_binding" },
        "route_or_connector_bindings": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/route_or_connector_binding" }
        },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "created_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "updated_at": { "$ref": "#/$defs/nullable_timestamp" },
        "audit_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "notes": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      },
      "allOf": [
        {
          "description": "Linked desired/rendered/live targets carry at least one source ref, one rendered ref, and one live handle.",
          "if": {
            "properties": {
              "state_class": { "const": "linked_desired_rendered_live" }
            },
            "required": ["state_class"]
          },
          "then": {
            "properties": {
              "source_refs": { "minItems": 1 },
              "rendered_refs": { "minItems": 1 },
              "live_handles": { "minItems": 1 }
            }
          }
        },
        {
          "description": "Live-only and imported snapshots still require a live handle so support and export packets can reconstruct the observed object.",
          "if": {
            "properties": {
              "state_class": {
                "enum": [
                  "live_only",
                  "cached",
                  "permission_limited",
                  "imported_snapshot"
                ]
              }
            },
            "required": ["state_class"]
          },
          "then": {
            "properties": {
              "live_handles": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "resource_target_audit_event_class": {
      "type": "string",
      "enum": [
        "resource_target_linked",
        "resource_target_drifted",
        "resource_target_downgraded",
        "resource_target_imported",
        "resource_target_unavailable",
        "resource_target_schema_version_bumped"
      ]
    },
    "resource_target_audit_event_record": {
      "type": "object",
      "unevaluatedProperties": false,
      "required": [
        "record_kind",
        "resource_target_schema_version",
        "event_id",
        "event_class",
        "resource_target_ref",
        "occurred_at",
        "summary"
      ],
      "properties": {
        "record_kind": { "const": "resource_target_audit_event_record" },
        "resource_target_schema_version": {
          "$ref": "#/$defs/resource_target_schema_version"
        },
        "event_id": { "$ref": "#/$defs/opaque_id" },
        "event_class": { "$ref": "#/$defs/resource_target_audit_event_class" },
        "resource_target_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "occurred_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "audit_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      }
    }
  }
}
