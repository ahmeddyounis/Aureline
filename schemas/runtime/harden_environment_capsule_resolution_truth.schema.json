{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/harden_environment_capsule_resolution_truth.schema.json",
  "title": "Aureline harden-environment-capsule-resolution truth packet",
  "description": "Boundary schema for the stable capsule-resolution truth packet certifying that the devcontainer, Nix, Compose, shell/SDK, and template/prebuild lanes resolve declarative inputs into one typed environment-capsule object with the nine typed capsule fields (host_or_base_image_identity, target_plan, resolved_toolchain_locks, projected_environment_variables, secret_references, writable_mount_model, service_startup_ordering, trust_network_posture, provenance), the six prebuild-fingerprint components (commit_or_tree_identity, capsule_hash, platform_arch, policy_epoch, extension_lock_digest, critical_toolchain_digest), the six visible invalidation reasons (cold_path, partially_warm_path, fingerprint_mismatch, untrusted_template_metadata, blocked_hook, stale_prebuild), the five Project Doctor finding codes (wrong_interpreter, stale_prebuild, blocked_activator, drifted_toolchain, untrusted_template_metadata), and a materialized_identity_admission row that binds the requested template/capsule/prebuild artifact identity, the materialized runtime instance identity, and attests no_silent_prebuild_reuse. The packet is the single truth that the editor run surface, terminal pane, task panel, CLI/headless inspector, Project Doctor, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies, fork their own capsule semantics, or paraphrase capsule posture.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": {
      "const": "harden_environment_capsule_resolution_truth_stable_packet"
    },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/capsule_resolution_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capsule_resolution_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 9,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "capsule_resolution_lane_class": {
      "enum": [
        "devcontainer_lane",
        "nix_lane",
        "compose_lane",
        "shell_sdk_lane",
        "template_prebuild_lane"
      ]
    },
    "capsule_resolution_row_class": {
      "enum": [
        "capsule_resolution_quality",
        "capsule_field_admission",
        "prebuild_fingerprint_admission",
        "invalidation_reason_admission",
        "materialized_identity_admission",
        "project_doctor_finding_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "capsule_field_class": {
      "enum": [
        "host_or_base_image_identity",
        "target_plan",
        "resolved_toolchain_locks",
        "projected_environment_variables",
        "secret_references",
        "writable_mount_model",
        "service_startup_ordering",
        "trust_network_posture",
        "provenance",
        "not_applicable"
      ]
    },
    "prebuild_fingerprint_component_class": {
      "enum": [
        "commit_or_tree_identity",
        "capsule_hash",
        "platform_arch",
        "policy_epoch",
        "extension_lock_digest",
        "critical_toolchain_digest",
        "not_applicable"
      ]
    },
    "invalidation_reason_class": {
      "enum": [
        "cold_path",
        "partially_warm_path",
        "fingerprint_mismatch",
        "untrusted_template_metadata",
        "blocked_hook",
        "stale_prebuild",
        "not_applicable"
      ]
    },
    "project_doctor_finding_class": {
      "enum": [
        "wrong_interpreter",
        "stale_prebuild",
        "blocked_activator",
        "drifted_toolchain",
        "untrusted_template_metadata",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "devcontainer_subset_only",
        "nix_subset_only",
        "compose_subset_only",
        "shell_sdk_subset_only",
        "template_prebuild_subset_only",
        "capsule_field_subset_only",
        "prebuild_fingerprint_subset_only",
        "invalidation_reason_subset_only",
        "project_doctor_finding_subset_only",
        "unsupported_declarative_input",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_capsule_field_gap",
        "auto_narrow_on_fingerprint_gap",
        "auto_narrow_on_invalidation_reason_gap",
        "auto_narrow_on_project_doctor_finding_gap",
        "auto_narrow_on_materialized_identity_drift",
        "auto_narrow_on_silent_prebuild_reuse",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "capsule_resolution_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_lane_coverage",
        "missing_capsule_field_coverage",
        "missing_prebuild_fingerprint_coverage",
        "missing_invalidation_reason_coverage",
        "missing_project_doctor_finding_coverage",
        "missing_materialized_identity_admission",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "capsule_field_not_applicable",
        "capsule_field_not_permitted_on_row_class",
        "prebuild_fingerprint_not_applicable",
        "prebuild_fingerprint_not_permitted_on_row_class",
        "invalidation_reason_not_applicable",
        "invalidation_reason_not_permitted_on_row_class",
        "project_doctor_finding_not_applicable",
        "project_doctor_finding_not_permitted_on_row_class",
        "materialized_identity_admission_missing_requested_artifact",
        "materialized_identity_admission_missing_materialized_runtime",
        "materialized_identity_admission_equates_identities_without_attestation",
        "materialized_identity_admission_admits_silent_prebuild_reuse",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "capsule_field_vocabulary_collapsed",
        "prebuild_fingerprint_vocabulary_collapsed",
        "invalidation_reason_vocabulary_collapsed",
        "project_doctor_finding_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "capsule_resolution_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "capsule_field_class",
        "prebuild_fingerprint_component_class",
        "invalidation_reason_class",
        "project_doctor_finding_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/capsule_resolution_lane_class" },
        "row_class": { "$ref": "#/$defs/capsule_resolution_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "capsule_field_class": { "$ref": "#/$defs/capsule_field_class" },
        "prebuild_fingerprint_component_class": {
          "$ref": "#/$defs/prebuild_fingerprint_component_class"
        },
        "invalidation_reason_class": { "$ref": "#/$defs/invalidation_reason_class" },
        "project_doctor_finding_class": { "$ref": "#/$defs/project_doctor_finding_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/capsule_resolution_confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "requested_artifact_identity_binding": { "$ref": "#/$defs/non_empty_string" },
        "materialized_runtime_identity_binding": { "$ref": "#/$defs/non_empty_string" },
        "no_silent_prebuild_reuse": { "type": "boolean" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "capsule_resolution_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_capsule_field_vocabulary",
        "preserves_prebuild_fingerprint_vocabulary",
        "preserves_invalidation_reason_vocabulary",
        "preserves_project_doctor_finding_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "editor_run_surface",
            "terminal_pane",
            "task_panel",
            "cli_headless",
            "project_doctor",
            "support_export",
            "release_proof_index",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "capsule_resolution_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_capsule_field_vocabulary": { "type": "boolean" },
        "preserves_prebuild_fingerprint_vocabulary": { "type": "boolean" },
        "preserves_invalidation_reason_vocabulary": { "type": "boolean" },
        "preserves_project_doctor_finding_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
