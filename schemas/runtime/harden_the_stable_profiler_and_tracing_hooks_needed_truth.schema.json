        },
        "replay_state_class": {
          "$ref": "#/$defs/replay_state_class"
        },
        "profiler_surface_class": {
          "$ref": "#/$defs/profiler_surface_class"
        },
        "evidence_class": {
          "$ref": "#/$defs/evidence_class"
        },
        "known_limit_class": {
          "$ref": "#/$defs/known_limit_class"
        },
        "downgrade_automation_class": {
          "$ref": "#/$defs/downgrade_automation_class"
        },
        "confidence_class": {
          "$ref": "#/$defs/confidence_class"
        },
        "evidence_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "disclosure_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "execution_context_id_binding": {
          "type": [
            "string",
            "null"
          ]
        },
        "attests_capture_state_preserved": {
          "type": "boolean"
        },
        "attests_replay_state_preserved": {
          "type": "boolean"
        },
        "raw_source_material_excluded": {
          "type": "boolean"
        },
        "secrets_excluded": {
          "type": "boolean"
        },
        "ambient_authority_excluded": {
          "type": "boolean"
        },
        "captured_at": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "consumer_projection_surface": {
      "enum": [
        "flamegraph_surface",
        "timeline_surface",
        "call_tree_surface",
        "regression_summary_surface",
        "replay_controls_surface",
        "profile_session_surface",
        "cli_headless",
        "evidence_export",
        "support_export",
        "release_proof_index",
        "help_about",
        "conformance_dashboard"
      ]
