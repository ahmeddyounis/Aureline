          "type": "boolean"
        },
        "ambient_authority_excluded": {
          "type": "boolean"
        }
      }
    },
    "validation_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_kind",
        "severity",
        "summary"
      ],
      "properties": {
        "finding_kind": {
          "$ref": "#/$defs/finding_kind"
        },
