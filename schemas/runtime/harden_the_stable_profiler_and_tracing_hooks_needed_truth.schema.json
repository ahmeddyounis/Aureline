        },
        "row_class": {
          "$ref": "#/$defs/profiler_row_class"
        },
        "support_class": {
          "$ref": "#/$defs/support_class"
        },
        "wedge_class": {
          "$ref": "#/$defs/wedge_class"
        },
        "capture_state_class": {
          "$ref": "#/$defs/capture_state_class"
        },
        "origin_class": {
          "$ref": "#/$defs/origin_class"
        },
        "build_mode_class": {
          "$ref": "#/$defs/build_mode_class"
        },
        "run_class_class": {
          "$ref": "#/$defs/run_class_class"
        },
        "confounder_class": {
