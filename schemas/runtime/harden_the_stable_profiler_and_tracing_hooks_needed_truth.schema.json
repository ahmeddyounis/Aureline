        "preserves_run_class_vocabulary",
        "preserves_confounder_vocabulary",
        "preserves_replay_state_vocabulary",
        "preserves_profiler_surface_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "$ref": "#/$defs/consumer_projection_surface"
        },
        "projection_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "profiler_truth_packet_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rendered_at": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preserves_same_packet": {
          "type": "boolean"
        },
        "preserves_lane_vocabulary": {
          "type": "boolean"
        },
        "preserves_row_class_vocabulary": {
          "type": "boolean"
        },
        "preserves_support_class_vocabulary": {
          "type": "boolean"
        },
        "preserves_wedge_vocabulary": {
          "type": "boolean"
        },
        "preserves_capture_state_vocabulary": {
          "type": "boolean"
        },
        "preserves_origin_class_vocabulary": {
          "type": "boolean"
        },
        "preserves_build_mode_vocabulary": {
          "type": "boolean"
        },
        "preserves_run_class_vocabulary": {
          "type": "boolean"
        },
        "preserves_confounder_vocabulary": {
          "type": "boolean"
        },
        "preserves_replay_state_vocabulary": {
          "type": "boolean"
        },
        "preserves_profiler_surface_vocabulary": {
          "type": "boolean"
        },
        "preserves_known_limit_vocabulary": {
