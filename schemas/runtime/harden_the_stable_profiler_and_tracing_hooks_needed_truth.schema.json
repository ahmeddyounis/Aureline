        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "local_lane_subset_only",
        "remote_helper_subset_only",
        "container_subset_only",
        "ci_import_subset_only",
        "wedge_subset_only",
        "capture_state_subset_only",
        "origin_class_subset_only",
        "build_mode_subset_only",
        "run_class_subset_only",
        "confounder_subset_only",
        "replay_state_subset_only",
        "profiler_surface_subset_only",
        "richer_replay_outside_m4",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_wedge_admission_gap",
        "auto_narrow_on_capture_state_gap",
        "auto_narrow_on_origin_class_gap",
        "auto_narrow_on_build_mode_gap",
        "auto_narrow_on_run_class_gap",
        "auto_narrow_on_confounder_gap",
        "auto_narrow_on_replay_state_gap",
        "auto_narrow_on_profiler_surface_gap",
        "auto_narrow_on_lineage_break",
        "auto_block_on_missing_evidence",
