{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/harden_the_stable_profiler_and_tracing_hooks_needed_truth.schema.json",
  "title": "Aureline stable profiler and tracing-hooks hardening truth packet",
  "description": "Boundary schema for the stable profiler/tracing truth packet certifying local, remote/helper, container, and CI-import profiler lanes at the M4 launch-stable grade. Every launch_stable lane MUST publish a profiler_quality row plus the full eight-wedge admission coverage (profile_session_descriptor, trace_bundle_manifest, capture_mode_label, mapping_quality_state, baseline_comparison_key, replay_capability_descriptor, reverse_step_disabled_reason, export_redaction_summary), the full six capture-state admissions (live, cached, imported, stale, not_recorded, disabled_with_reason), the full four origin-class admissions (local_origin, remote_origin, ci_artifact_origin, imported_bundle_origin), the full two build-mode admissions (debug_mode, release_mode), the full two run-class admissions (warm_run, cold_run), the full three confounder admissions (hardware_class, power_state, thermal_state), the full five replay-state admissions (supported, limited, record_only, profile_only, import_view_only), the full six surface bindings (flamegraph_surface, timeline_surface, call_tree_surface, regression_summary_surface, replay_controls_surface, profile_session_surface) each attesting the capture-state and replay-state vocabularies they are required to preserve, and a lineage_admission row binding execution_context_id. Surfaces MUST NOT imply M5-class capture, replay, or regression depth on M4.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": {
      "const": "harden_the_stable_profiler_and_tracing_hooks_needed_truth_stable_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "workflow_or_surface_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "generated_at": {
      "$ref": "#/$defs/non_empty_string"
    },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/profiler_lane_class"
      }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/profiler_row"
      }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 12,
      "items": {
        "$ref": "#/$defs/consumer_projection"
      }
    },
    "source_contract_refs": {
      "$ref": "#/$defs/ref_array"
    },
    "promotion_state": {
      "$ref": "#/$defs/promotion_state"
    },
    "validation_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation_finding"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "ref_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "uniqueItems": true
    },
    "profiler_lane_class": {
      "enum": [
        "local_lane",
        "remote_helper_lane",
        "container_lane",
        "ci_import_lane"
      ]
    },
    "profiler_row_class": {
      "enum": [
        "profiler_quality",
        "wedge_admission",
        "capture_state_admission",
        "origin_class_admission",
        "build_mode_admission",
        "run_class_admission",
        "confounder_admission",
        "replay_state_admission",
        "surface_binding",
        "lineage_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "wedge_class": {
      "enum": [
        "profile_session_descriptor",
        "trace_bundle_manifest",
        "capture_mode_label",
        "mapping_quality_state",
        "baseline_comparison_key",
        "replay_capability_descriptor",
        "reverse_step_disabled_reason",
        "export_redaction_summary",
        "not_applicable"
      ]
    },
    "capture_state_class": {
      "enum": [
        "live",
        "cached",
        "imported",
        "stale",
        "not_recorded",
        "disabled_with_reason",
        "not_applicable"
