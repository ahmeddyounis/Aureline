        "remote_origin",
        "ci_artifact_origin",
        "imported_bundle_origin",
        "not_applicable"
      ]
    },
    "build_mode_class": {
      "enum": [
        "debug_mode",
        "release_mode",
        "not_applicable"
      ]
    },
    "run_class_class": {
      "enum": [
        "warm_run",
        "cold_run",
        "not_applicable"
      ]
    },
    "confounder_class": {
