        "hardware_class",
        "power_state",
        "thermal_state",
        "not_applicable"
      ]
    },
    "replay_state_class": {
      "enum": [
        "supported",
        "limited",
        "record_only",
        "profile_only",
        "import_view_only",
        "not_applicable"
