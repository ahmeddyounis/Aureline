{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/queue-session-terminal-governance.schema.json",
  "title": "Aureline queue, restore, and terminal governance packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_workloads",
    "rows",
    "activity_job_rows",
    "scheduler_lane_rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": {
      "const": "queue_session_terminal_governance_packet"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_or_surface_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "covered_workloads": {
      "type": "array",
      "minItems": 10,
      "items": {
        "$ref": "#/$defs/workload"
      }
    },
    "rows": {
      "type": "array",
      "minItems": 40,
      "items": {
        "type": "object",
        "required": [
          "row_id",
          "workload_class",
          "row_class",
          "support_class",
          "known_limit_class",
          "downgrade_rule_class",
          "evidence_class",
          "confidence_class",
          "evidence_refs",
          "captured_at",
          "raw_private_material_excluded",
          "secrets_excluded",
          "ambient_authority_excluded"
        ],
        "properties": {
          "row_id": { "type": "string", "minLength": 1 },
          "workload_class": { "$ref": "#/$defs/workload" },
          "row_class": { "$ref": "#/$defs/row_class" },
          "support_class": { "$ref": "#/$defs/support_class" },
          "queue_lane_class": { "$ref": "#/$defs/queue_lane" },
          "job_identities": {
            "type": "array",
            "items": { "$ref": "#/$defs/job_identity" }
          },
          "restore_fidelity_class": { "$ref": "#/$defs/restore_fidelity" },
          "terminal_boundary_class": { "$ref": "#/$defs/terminal_boundary" },
          "clipboard_posture_class": { "$ref": "#/$defs/clipboard_posture" },
          "known_limit_class": { "$ref": "#/$defs/known_limit" },
          "downgrade_rule_class": { "$ref": "#/$defs/downgrade_rule" },
          "evidence_class": { "$ref": "#/$defs/evidence_class" },
          "confidence_class": {
            "enum": ["high", "medium", "low"]
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "captured_at": { "type": "string", "minLength": 1 },
          "raw_private_material_excluded": { "const": true },
          "secrets_excluded": { "const": true },
          "ambient_authority_excluded": { "const": true }
        }
      }
    },
    "activity_job_rows": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "required": [
          "record_kind",
          "row_id",
          "workload_class",
          "primary_job_kind",
          "job_identity_refs",
          "queue_lane_class",
          "state_class",
          "state_token",
          "state_reason",
          "queue_age_seconds",
          "queue_age_label",
          "retry_class",
          "next_action_class",
          "next_action_ref",
          "exact_target_reopen_ref",
          "exact_target_identity_ref",
          "inspect_ref"
        ],
        "properties": {
          "record_kind": {
            "const": "queue_session_terminal_activity_job_row"
          },
          "row_id": { "type": "string", "minLength": 1 },
          "workload_class": { "$ref": "#/$defs/workload" },
          "primary_job_kind": { "$ref": "#/$defs/job_kind" },
          "job_identity_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "queue_lane_class": { "$ref": "#/$defs/queue_lane" },
          "state_class": { "$ref": "#/$defs/activity_state" },
          "state_token": { "type": "string", "minLength": 1 },
          "state_reason": { "type": "string", "minLength": 1 },
          "queue_age_seconds": { "type": "integer", "minimum": 0 },
          "queue_age_label": { "type": "string", "minLength": 1 },
          "retry_class": { "$ref": "#/$defs/retry_class" },
          "next_action_class": { "$ref": "#/$defs/activity_next_action" },
          "next_action_ref": { "type": "string", "minLength": 1 },
          "exact_target_reopen_ref": { "type": "string", "minLength": 1 },
          "exact_target_identity_ref": { "type": "string", "minLength": 1 },
          "inspect_ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    "scheduler_lane_rows": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": [
          "record_kind",
          "queue_lane_class",
          "queue_lane_token",
          "queue_depth",
          "oldest_age_label",
          "collapse_count",
          "retry_state_class",
          "retry_state_token",
          "activity_row_refs",
          "workload_classes",
          "inspect_ref"
        ],
        "properties": {
          "record_kind": {
            "const": "queue_session_terminal_scheduler_lane_row"
          },
          "queue_lane_class": { "$ref": "#/$defs/queue_lane" },
          "queue_lane_token": { "type": "string", "minLength": 1 },
          "queue_depth": { "type": "integer", "minimum": 0 },
          "oldest_age_seconds": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "oldest_age_label": { "type": "string", "minLength": 1 },
          "collapse_count": { "type": "integer", "minimum": 0 },
          "retry_state_class": { "$ref": "#/$defs/scheduler_retry_state" },
          "retry_state_token": { "type": "string", "minLength": 1 },
          "activity_row_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "workload_classes": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/workload" }
          },
          "inspect_ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 8
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "validation_findings": {
      "type": "array"
    }
  },
  "$defs": {
    "workload": {
      "enum": [
        "notebook_session",
        "data_query_console",
        "pipeline_run",
        "preview_route",
        "profiler_capture",
        "docs_recall",
        "sync_offboarding_flow",
        "companion_handoff",
        "incident_workspace",
        "infrastructure_session"
      ]
    },
    "row_class": {
      "enum": [
        "continuity_quality",
        "queue_identity_admission",
        "restore_continuity_admission",
        "terminal_boundary_admission",
        "downgrade_rule"
      ]
    },
    "support_class": {
      "enum": [
        "stable",
        "stable_below",
        "beta_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "activity_state": {
      "enum": [
        "queued",
        "running",
        "paused_by_user",
        "paused_by_policy",
        "paused_by_power_thermal",
        "stalled_error",
        "resumed",
        "cancelled",
        "superseded"
      ]
    },
    "activity_next_action": {
      "enum": [
        "inspect_queue",
        "resume_job",
        "review_policy",
        "wait_for_power_thermal_recovery",
        "retry_from_checkpoint",
        "reopen_target",
        "open_replacement",
        "open_evidence"
      ]
    },
    "queue_lane": {
      "enum": [
        "foreground",
        "interactive_background",
        "maintenance",
        "provider_overlay",
        "upload_replication",
        "not_applicable"
      ]
    },
    "job_kind": {
      "enum": [
        "notebook.cell_execution",
        "docs.pack_refresh",
        "docs.retrieval_index_refresh",
        "data.request_collection_run",
        "profiler.capture",
        "pipeline.log_pull",
        "pipeline.artifact_pull",
        "preview.dev_server",
        "preview.route_refresh",
        "sync.profile_replication",
        "sync.offboarding_export",
        "companion.handoff_package",
        "incident.recovery_workspace_refresh",
        "infrastructure.overlay_probe"
      ]
    },
    "retry_class": {
      "enum": [
        "none_declared",
        "local_retry_budget",
        "provider_retry_budget",
        "reconnect_after_reauth",
        "manual_requeue_only",
        "not_applicable"
      ]
    },
    "scheduler_retry_state": {
      "enum": [
        "no_retry_pending",
        "local_retry_budget_tracked",
        "provider_retry_budget_tracked",
        "reauthorize_before_retry",
        "manual_review_before_retry"
      ]
    },
    "initiating_source": {
      "enum": [
        "user_action",
        "session_startup",
        "workspace_open",
        "profile_change",
        "policy_change",
        "focus_change",
        "file_change_notification",
        "remote_reconnect",
        "scheduler_timer",
        "extension_request",
        "ai_tool_call",
        "support_export_request",
        "sync_trigger",
        "recovery_resume"
      ]
    },
    "collapse_policy": {
      "enum": [
        "coalesce_stale_duplicates",
        "replace_superseded",
        "restart_after_supersede",
        "serialize_exact_duplicates"
      ]
    },
    "staleness_policy": {
      "enum": [
        "drop_if_stale",
        "refresh_on_resume",
        "re_queue_if_still_relevant"
      ]
    },
    "budget_domain_ref": {
      "enum": [
        "foreground_task_budget",
        "knowledge_refresh_budget",
        "maintenance_budget",
        "provider_overlay_budget",
        "replication_budget",
        "hot_path_interactive_budget"
      ]
    },
    "job_identity": {
      "type": "object",
      "required": [
        "job_kind",
        "job_identity_ref",
        "workspace_id_ref",
        "scope",
        "initiating_source",
        "collapse_key",
        "collapse_policy",
        "staleness_policy",
        "budget_domain_refs",
        "workspace_revision_ref"
      ],
      "properties": {
        "job_kind": { "$ref": "#/$defs/job_kind" },
        "job_identity_ref": { "type": "string", "minLength": 1 },
        "workspace_id_ref": { "type": "string", "minLength": 1 },
        "slice_id_ref": { "type": ["string", "null"], "minLength": 1 },
        "scope": {
          "type": "object",
          "required": ["scope_class", "scope_ref"],
          "properties": {
            "scope_class": { "type": "string", "minLength": 1 },
            "scope_ref": { "type": "string", "minLength": 1 }
          }
        },
        "initiating_source": { "$ref": "#/$defs/initiating_source" },
        "collapse_key": { "type": "string", "minLength": 1 },
        "collapse_policy": { "$ref": "#/$defs/collapse_policy" },
        "staleness_policy": { "$ref": "#/$defs/staleness_policy" },
        "budget_domain_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/budget_domain_ref" }
        },
        "workspace_revision_ref": { "type": "string", "minLength": 1 },
        "manifest_hash_ref": { "type": ["string", "null"], "minLength": 1 },
        "execution_context_hash_ref": { "type": ["string", "null"], "minLength": 1 },
        "policy_epoch_ref": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "restore_fidelity": {
      "enum": [
        "exact_restore",
        "compatible_restore",
        "layout_only",
        "transcript_only",
        "evidence_only",
        "placeholder_only",
        "not_applicable"
      ]
    },
    "terminal_boundary": {
      "enum": [
        "local",
        "remote",
        "container",
        "managed",
        "shared_control",
        "policy_blocked",
        "not_applicable"
      ]
    },
    "clipboard_posture": {
      "enum": [
        "local_direct",
        "bracketed_paste_review",
        "remote_bridge_review",
        "shared_control_grant_required",
        "metadata_only_export",
        "policy_denied_safe_alternative",
        "not_applicable"
      ]
    },
    "known_limit": {
      "enum": [
        "none_declared",
        "queue_metadata_subset_only",
        "restore_placeholder_only",
        "terminal_boundary_subset_only",
        "policy_review_pending",
        "imported_evidence_only",
        "limit_unbound"
      ]
    },
    "downgrade_rule": {
      "enum": [
        "none",
        "auto_narrow_on_queue_metadata_stale",
        "auto_narrow_on_restore_fidelity_stale",
        "auto_narrow_on_terminal_boundary_stale",
        "auto_narrow_on_missing_checkpoint_proof",
        "auto_narrow_on_retry_budget_exhausted",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "design_qa_evidence",
        "failure_recovery_drill_evidence",
        "security_privacy_review_evidence",
        "release_evidence_review",
        "schema_fixture_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    }
  }
}
