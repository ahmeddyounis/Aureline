{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/queue-session-terminal-governance.schema.json",
  "title": "Aureline queue, restore, and terminal governance packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_workloads",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": {
      "const": "queue_session_terminal_governance_packet"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_or_surface_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "covered_workloads": {
      "type": "array",
      "minItems": 10,
      "items": {
        "$ref": "#/$defs/workload"
      }
    },
    "rows": {
      "type": "array",
      "minItems": 40,
      "items": {
        "type": "object",
        "required": [
          "row_id",
          "workload_class",
          "row_class",
          "support_class",
          "known_limit_class",
          "downgrade_rule_class",
          "evidence_class",
          "confidence_class",
          "evidence_refs",
          "captured_at",
          "raw_private_material_excluded",
          "secrets_excluded",
          "ambient_authority_excluded"
        ],
        "properties": {
          "row_id": { "type": "string", "minLength": 1 },
          "workload_class": { "$ref": "#/$defs/workload" },
          "row_class": { "$ref": "#/$defs/row_class" },
          "support_class": { "$ref": "#/$defs/support_class" },
          "queue_lane_class": { "$ref": "#/$defs/queue_lane" },
          "restore_fidelity_class": { "$ref": "#/$defs/restore_fidelity" },
          "terminal_boundary_class": { "$ref": "#/$defs/terminal_boundary" },
          "clipboard_posture_class": { "$ref": "#/$defs/clipboard_posture" },
          "known_limit_class": { "$ref": "#/$defs/known_limit" },
          "downgrade_rule_class": { "$ref": "#/$defs/downgrade_rule" },
          "evidence_class": { "$ref": "#/$defs/evidence_class" },
          "confidence_class": {
            "enum": ["high", "medium", "low"]
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "captured_at": { "type": "string", "minLength": 1 },
          "raw_private_material_excluded": { "const": true },
          "secrets_excluded": { "const": true },
          "ambient_authority_excluded": { "const": true }
        }
      }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 8
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "validation_findings": {
      "type": "array"
    }
  },
  "$defs": {
    "workload": {
      "enum": [
        "notebook_session",
        "data_query_console",
        "pipeline_run",
        "preview_route",
        "profiler_capture",
        "docs_recall",
        "sync_offboarding_flow",
        "companion_handoff",
        "incident_workspace",
        "infrastructure_session"
      ]
    },
    "row_class": {
      "enum": [
        "continuity_quality",
        "queue_identity_admission",
        "restore_continuity_admission",
        "terminal_boundary_admission",
        "downgrade_rule"
      ]
    },
    "support_class": {
      "enum": [
        "stable",
        "stable_below",
        "beta_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "queue_lane": {
      "enum": [
        "foreground",
        "interactive_background",
        "maintenance",
        "provider_overlay",
        "upload_replication",
        "not_applicable"
      ]
    },
    "restore_fidelity": {
      "enum": [
        "exact_restore",
        "compatible_restore",
        "layout_only",
        "transcript_only",
        "evidence_only",
        "placeholder_only",
        "not_applicable"
      ]
    },
    "terminal_boundary": {
      "enum": [
        "local",
        "remote",
        "container",
        "managed",
        "shared_control",
        "policy_blocked",
        "not_applicable"
      ]
    },
    "clipboard_posture": {
      "enum": [
        "local_direct",
        "bracketed_paste_review",
        "remote_bridge_review",
        "shared_control_grant_required",
        "metadata_only_export",
        "policy_denied_safe_alternative",
        "not_applicable"
      ]
    },
    "known_limit": {
      "enum": [
        "none_declared",
        "queue_metadata_subset_only",
        "restore_placeholder_only",
        "terminal_boundary_subset_only",
        "policy_review_pending",
        "imported_evidence_only",
        "limit_unbound"
      ]
    },
    "downgrade_rule": {
      "enum": [
        "none",
        "auto_narrow_on_queue_metadata_stale",
        "auto_narrow_on_restore_fidelity_stale",
        "auto_narrow_on_terminal_boundary_stale",
        "auto_narrow_on_missing_checkpoint_proof",
        "auto_narrow_on_retry_budget_exhausted",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "design_qa_evidence",
        "failure_recovery_drill_evidence",
        "security_privacy_review_evidence",
        "release_evidence_review",
        "schema_fixture_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    }
  }
}
