{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/runtime/harden_build_target_discovery_adapter_confidence_labels_and_truth.schema.json",
  "title": "Aureline build-target hardening truth packet",
  "description": "Boundary schema for the stable build-target discovery, adapter-confidence label, and target-graph snapshot hardening truth packet covering the run_lane, test_lane, debug_lane, and target_graph_snapshot_lane. Every launch_stable lane MUST publish wedge_admission rows for build_target_discovery_truth, adapter_confidence_label_truth, target_graph_snapshot_truth, and cross_surface_target_parity_truth; discovery_source_admission rows for native_protocol, structured_adapter, heuristic_parser, imported_metadata, user_declared, and resolver_unavailable; discovery_freshness_admission rows for fresh_probe, recent_within_session, imported_authoritative, stale_imported, and unknown; adapter_confidence_label_admission rows for adapter_authoritative_match, adapter_probed_consistent, adapter_probed_divergent, adapter_inferred_from_session, and adapter_unreachable; target_graph_snapshot_admission rows for live_snapshot, session_cached_snapshot, imported_snapshot, archived_snapshot, and snapshot_unavailable; consumer_surface_binding rows for run_surface, test_surface, debug_surface, cli_headless_inspect, support_export, help_about, and conformance_dashboard; and a lineage_admission row binding execution_context_id. The packet is the single truth that the run surface, the test surface, the debug surface, the CLI/headless inspector, the support export, the Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT fork local runtime semantics, paraphrase adapter-confidence labels, collapse discovery source / freshness into a single ok/unknown bit, or silently widen target identity on rerun.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": {
      "const": "harden_build_target_discovery_adapter_confidence_labels_and_truth_stable_packet"
    },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/build_target_hardening_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/build_target_hardening_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "build_target_hardening_lane_class": {
      "enum": [
        "run_lane",
        "test_lane",
        "debug_lane",
        "target_graph_snapshot_lane"
      ]
    },
    "build_target_hardening_row_class": {
      "enum": [
        "build_target_hardening_quality",
        "wedge_admission",
        "discovery_source_admission",
        "discovery_freshness_admission",
        "adapter_confidence_label_admission",
        "target_graph_snapshot_admission",
        "consumer_surface_binding",
        "lineage_admission",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "wedge_class": {
      "enum": [
        "build_target_discovery_truth",
        "adapter_confidence_label_truth",
        "target_graph_snapshot_truth",
        "cross_surface_target_parity_truth",
        "not_applicable"
      ]
    },
    "discovery_source_class": {
      "enum": [
        "native_protocol",
        "structured_adapter",
        "heuristic_parser",
        "imported_metadata",
        "user_declared",
        "resolver_unavailable",
        "not_applicable"
      ]
    },
    "discovery_freshness_class": {
      "enum": [
        "fresh_probe",
        "recent_within_session",
        "imported_authoritative",
        "stale_imported",
        "unknown",
        "not_applicable"
      ]
    },
    "adapter_confidence_label_class": {
      "enum": [
        "adapter_authoritative_match",
        "adapter_probed_consistent",
        "adapter_probed_divergent",
        "adapter_inferred_from_session",
        "adapter_unreachable",
        "not_applicable"
      ]
    },
    "target_graph_snapshot_class": {
      "enum": [
        "live_snapshot",
        "session_cached_snapshot",
        "imported_snapshot",
        "archived_snapshot",
        "snapshot_unavailable",
        "not_applicable"
      ]
    },
    "consumer_surface_class": {
      "enum": [
        "run_surface",
        "test_surface",
        "debug_surface",
        "cli_headless_inspect",
        "support_export",
        "help_about",
        "conformance_dashboard",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "automated_functional_evidence",
        "conformance_suite_evidence",
        "failure_recovery_drill_evidence",
        "design_qa_evidence",
        "release_evidence_review",
        "fixture_repo_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "run_subset_only",
        "test_subset_only",
        "debug_subset_only",
        "target_graph_snapshot_subset_only",
        "wedge_subset_only",
        "discovery_source_subset_only",
        "discovery_freshness_subset_only",
        "adapter_confidence_label_subset_only",
        "target_graph_snapshot_class_subset_only",
        "consumer_surface_subset_only",
        "unsupported_discovery_or_adapter",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_discovery_source_gap",
        "auto_narrow_on_discovery_freshness_gap",
        "auto_narrow_on_adapter_confidence_label_gap",
        "auto_narrow_on_target_graph_snapshot_gap",
        "auto_narrow_on_consumer_surface_gap",
        "auto_narrow_on_cross_surface_target_drift",
        "auto_narrow_on_lineage_break",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_hardening_lane_coverage",
        "missing_wedge_coverage",
        "missing_discovery_source_coverage",
        "missing_discovery_freshness_coverage",
        "missing_adapter_confidence_label_coverage",
        "missing_target_graph_snapshot_coverage",
        "missing_consumer_surface_coverage",
        "missing_lineage_admission",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "wedge_not_applicable",
        "wedge_not_permitted_on_row_class",
        "discovery_source_not_applicable",
        "discovery_source_not_permitted_on_row_class",
        "discovery_freshness_not_applicable",
        "discovery_freshness_not_permitted_on_row_class",
        "adapter_confidence_label_not_applicable",
        "adapter_confidence_label_not_permitted_on_row_class",
        "target_graph_snapshot_not_applicable",
        "target_graph_snapshot_not_permitted_on_row_class",
        "consumer_surface_not_applicable",
        "consumer_surface_not_permitted_on_row_class",
        "lineage_admission_missing_execution_context_id",
        "cross_surface_target_parity_not_attested",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "wedge_vocabulary_collapsed",
        "discovery_source_vocabulary_collapsed",
        "discovery_freshness_vocabulary_collapsed",
        "adapter_confidence_label_vocabulary_collapsed",
        "target_graph_snapshot_vocabulary_collapsed",
        "consumer_surface_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "build_target_hardening_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "wedge_class",
        "discovery_source_class",
        "discovery_freshness_class",
        "adapter_confidence_label_class",
        "target_graph_snapshot_class",
        "consumer_surface_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/build_target_hardening_lane_class" },
        "row_class": { "$ref": "#/$defs/build_target_hardening_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "wedge_class": { "$ref": "#/$defs/wedge_class" },
        "discovery_source_class": { "$ref": "#/$defs/discovery_source_class" },
        "discovery_freshness_class": { "$ref": "#/$defs/discovery_freshness_class" },
        "adapter_confidence_label_class": { "$ref": "#/$defs/adapter_confidence_label_class" },
        "target_graph_snapshot_class": { "$ref": "#/$defs/target_graph_snapshot_class" },
        "consumer_surface_class": { "$ref": "#/$defs/consumer_surface_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_id_binding": { "$ref": "#/$defs/non_empty_string" },
        "cross_surface_target_parity_attested": { "type": "boolean" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "build_target_hardening_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_wedge_vocabulary",
        "preserves_discovery_source_vocabulary",
        "preserves_discovery_freshness_vocabulary",
        "preserves_adapter_confidence_label_vocabulary",
        "preserves_target_graph_snapshot_vocabulary",
        "preserves_consumer_surface_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "run_surface",
            "test_surface",
            "debug_surface",
            "cli_headless_inspect",
            "support_export",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "build_target_hardening_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_wedge_vocabulary": { "type": "boolean" },
        "preserves_discovery_source_vocabulary": { "type": "boolean" },
        "preserves_discovery_freshness_vocabulary": { "type": "boolean" },
        "preserves_adapter_confidence_label_vocabulary": { "type": "boolean" },
        "preserves_target_graph_snapshot_vocabulary": { "type": "boolean" },
        "preserves_consumer_surface_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
