{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/request_workspace/request_environment_fingerprint.schema.json",
  "title": "Aureline request-workspace environment fingerprint",
  "description": "Structured environment fingerprint value object used by request-workspace alpha records. It carries endpoint identity, layer refs, digest class, and resolution state so UI, CLI, and support exports can explain the environment used without exporting raw credentials or endpoint internals.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fingerprint_ref",
    "digest_class",
    "digest_class_token",
    "environment_id",
    "endpoint_identity_ref",
    "layer_refs",
    "state",
    "state_token",
    "captured_at"
  ],
  "properties": {
    "fingerprint_ref": { "type": "string" },
    "digest_class": {
      "type": "string",
      "enum": ["sha256", "blake3", "opaque_stable"]
    },
    "digest_class_token": { "type": "string" },
    "environment_id": { "type": "string" },
    "endpoint_identity_ref": { "type": "string" },
    "layer_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "state": {
      "type": "string",
      "enum": [
        "current_local_resolution",
        "imported_from_export",
        "stale_requires_review",
        "blocked_unresolved_variable"
      ]
    },
    "state_token": { "type": "string" },
    "captured_at": { "type": "string" }
  }
}
