{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/request_workspace/request_response_preview.schema.json",
  "title": "Aureline request-workspace response preview and export posture",
  "description": "Safe-preview, representation-label, and portable-export value-object boundary for request-workspace alpha response artifacts. It keeps body, headers, cookies, token-like values, and large payloads on explicit preview/copy/export classes so support exports preserve labels and omit raw sensitive material by default.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/response_preview_rule" },
    { "$ref": "#/$defs/portable_export_contract" }
  ],
  "$defs": {
    "response_preview_component_class": {
      "type": "string",
      "enum": ["body", "headers", "cookies", "tokens", "large_payload"]
    },
    "response_safe_preview_class": {
      "type": "string",
      "enum": [
        "json_tree",
        "raw_text",
        "sanitized_rich",
        "metadata_only",
        "digest_only",
        "large_payload_summary",
        "redacted"
      ]
    },
    "response_copy_export_class": {
      "type": "string",
      "enum": [
        "redacted_with_label",
        "structured_summary_with_label",
        "digest_only_with_label",
        "local_only_raw_opt_in",
        "blocked_sensitive"
      ]
    },
    "portable_export_class": {
      "type": "string",
      "enum": [
        "metadata_aliases_and_evidence",
        "redacted_response_summary",
        "imported_stale_evidence_only",
        "local_only_raw_opt_in_blocked"
      ]
    },
    "response_preview_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component",
        "component_token",
        "safe_preview_class",
        "safe_preview_class_token",
        "representation_label",
        "copy_export_class",
        "copy_export_class_token"
      ],
      "properties": {
        "component": { "$ref": "#/$defs/response_preview_component_class" },
        "component_token": { "type": "string" },
        "safe_preview_class": { "$ref": "#/$defs/response_safe_preview_class" },
        "safe_preview_class_token": { "type": "string" },
        "representation_label": { "type": "string" },
        "copy_export_class": { "$ref": "#/$defs/response_copy_export_class" },
        "copy_export_class_token": { "type": "string" }
      }
    },
    "portable_export_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_class",
        "export_class_token",
        "alias_bundle_ref",
        "redaction_profile",
        "evidence_refs",
        "includes_raw_credentials",
        "includes_raw_cookies",
        "includes_raw_tokens"
      ],
      "properties": {
        "export_class": { "$ref": "#/$defs/portable_export_class" },
        "export_class_token": { "type": "string" },
        "alias_bundle_ref": { "type": "string" },
        "redaction_profile": { "type": "string" },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "includes_raw_credentials": { "type": "boolean", "const": false },
        "includes_raw_cookies": { "type": "boolean", "const": false },
        "includes_raw_tokens": { "type": "boolean", "const": false }
      }
    }
  }
}
