{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/request_workspace/request_assertion_suite.schema.json",
  "title": "Aureline request-workspace assertion suite",
  "description": "Assertion-suite and result value-object boundary for request-workspace alpha records. Suites carry lineage and descriptors; results carry outcome, evidence state, evidence refs, and bound environment fingerprints so current local runs, imported runs, stale artifacts, skipped rows, and failed assertions remain explicit.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/assertion_suite" },
    { "$ref": "#/$defs/assertion_result_row" }
  ],
  "$defs": {
    "assertion_kind": {
      "type": "string",
      "enum": [
        "status_match",
        "header_match",
        "body_json_path",
        "body_text_contains",
        "schema_validation",
        "latency_ceiling",
        "custom_script"
      ]
    },
    "assertion_outcome_class": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "skipped_no_response",
        "errored_during_evaluation",
        "not_executed"
      ]
    },
    "assertion_suite_lineage_class": {
      "type": "string",
      "enum": [
        "current_local",
        "imported_artifact",
        "stale_artifact",
        "mirrored_schema"
      ]
    },
    "assertion_evidence_state": {
      "type": "string",
      "enum": [
        "current_local_run",
        "imported_run",
        "stale_imported_artifact",
        "not_executed"
      ]
    },
    "assertion_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assertion_id",
        "kind",
        "kind_token",
        "target_pointer",
        "expected_token"
      ],
      "properties": {
        "assertion_id": { "type": "string" },
        "kind": { "$ref": "#/$defs/assertion_kind" },
        "kind_token": { "type": "string" },
        "target_pointer": { "type": "string" },
        "expected_token": { "type": "string" }
      }
    },
    "assertion_suite": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suite_id",
        "suite_alias",
        "lineage_class",
        "lineage_class_token",
        "assertions"
      ],
      "properties": {
        "suite_id": { "type": "string" },
        "suite_alias": { "type": "string" },
        "lineage_class": { "$ref": "#/$defs/assertion_suite_lineage_class" },
        "lineage_class_token": { "type": "string" },
        "assertions": {
          "type": "array",
          "items": { "$ref": "#/$defs/assertion_descriptor" }
        }
      }
    },
    "assertion_result_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_id",
        "suite_id",
        "assertion_ref",
        "outcome",
        "outcome_token",
        "expected_token",
        "evidence_state",
        "evidence_state_token",
        "evidence_ref",
        "bound_environment_fingerprint_ref"
      ],
      "properties": {
        "result_id": { "type": "string" },
        "suite_id": { "type": "string" },
        "assertion_ref": { "type": "string" },
        "outcome": { "$ref": "#/$defs/assertion_outcome_class" },
        "outcome_token": { "type": "string" },
        "observed_token": { "type": "string" },
        "expected_token": { "type": "string" },
        "evidence_state": { "$ref": "#/$defs/assertion_evidence_state" },
        "evidence_state_token": { "type": "string" },
        "evidence_ref": { "type": "string" },
        "bound_environment_fingerprint_ref": { "type": "string" }
      }
    }
  }
}
