{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/scaffold/template-manifest-and-run.schema.json",
  "title": "Aureline stable scaffold manifest, run, health, and lineage packet",
  "description": "Stable scaffold-capable lanes publish one packet that binds a versioned template manifest, reviewable scaffold plan, optional run record, template health report, and optional generated-project lineage record. Raw secrets, raw absolute paths, raw remote URLs, generated file bodies, hook bodies, stdout, and stderr are excluded; records carry opaque refs, closed vocabulary, counts, and reviewable guidance only.",
  "type": "object",
  "additionalProperties": false,
  "required": ["record_kind", "manifest", "plan", "health_report"],
  "properties": {
    "record_kind": { "const": "stable_scaffold_packet" },
    "manifest": { "$ref": "#/$defs/template_manifest" },
    "plan": { "$ref": "#/$defs/scaffold_plan" },
    "run": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/scaffold_run_record" }]
    },
    "health_report": { "$ref": "#/$defs/template_health_report" },
    "lineage": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/generated_project_lineage_record" }
      ]
    }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "^/" },
          { "pattern": "^[A-Za-z]:[\\\\/]" },
          { "pattern": "https?://" }
        ]
      }
    },
    "reviewable_sentence": { "type": "string", "minLength": 1, "maxLength": 512 },
    "support_class": {
      "enum": [
        "officially_supported",
        "team_managed",
        "community_supported",
        "experimental",
        "unsupported",
        "narrowed_below_stable"
      ]
    },
    "template_source_class": {
      "enum": [
        "first_party",
        "team_managed",
        "community",
        "extension_provided",
        "local_only",
        "ai_proposed_pending_review"
      ]
    },
    "template_archetype": {
      "enum": [
        "web_application",
        "backend_service",
        "cli_tool",
        "library_or_sdk",
        "extension_or_plugin",
        "monorepo_root",
        "module_or_feature_slice"
      ]
    },
    "supported_ecosystem": {
      "enum": [
        "rust_cargo",
        "node_pnpm",
        "node_npm",
        "python_uv",
        "python_pip",
        "go_modules",
        "java_gradle",
        "dotnet_nuget",
        "polyglot",
        "pure_files"
      ]
    },
    "supported_platform": {
      "enum": [
        "macos_arm64",
        "macos_x86_64",
        "linux_x86_64",
        "linux_arm64",
        "windows_x86_64",
        "web_browser_runtime",
        "devcontainer",
        "managed_workspace"
      ]
    },
    "parameter_kind": {
      "enum": ["text", "identifier", "relative_path", "boolean", "enum", "number", "secret_handle"]
    },
    "parameter_source": {
      "enum": ["template_default", "user_input", "workspace_value", "policy_value", "secret_broker_handle"]
    },
    "secret_resolution": {
      "enum": ["not_secret", "broker_handle_only", "missing_broker_handle", "raw_secret_rejected"]
    },
    "declared_file_class": {
      "enum": [
        "source_file",
        "test_file",
        "config_file",
        "dependency_manifest",
        "lockfile",
        "documentation",
        "ci_workflow",
        "lineage_metadata"
      ]
    },
    "hook_class": {
      "enum": ["pre_generate", "post_generate", "post_create", "health_check", "reopen_preflight"]
    },
    "task_class": {
      "enum": [
        "package_restore",
        "build",
        "test",
        "lint",
        "format",
        "devcontainer_build",
        "extension_recommendation",
        "managed_provisioning"
      ]
    },
    "trust_egress_posture": {
      "enum": [
        "local_no_egress",
        "package_registry_egress",
        "remote_image_pull",
        "managed_service_provisioning",
        "credential_broker_handshake"
      ]
    },
    "scaffold_scope": {
      "enum": ["new_project", "new_service", "new_module", "feature_slice", "repair_existing", "create_empty"]
    },
    "rollback_boundary": {
      "enum": ["workspace_checkpoint", "local_history_checkpoint", "delete_generated_outputs", "manual_review_only"]
    },
    "scaffold_outcome": {
      "enum": [
        "preflight_only_no_writes",
        "applied",
        "applied_with_warnings",
        "blocked_before_write",
        "rolled_back_after_partial_apply",
        "failed_partial_apply_left_for_review"
      ]
    },
    "scaffold_actor": {
      "enum": ["user", "cli", "workflow_bundle", "extension", "ai_proposed_pending_admission"]
    },
    "health_freshness_state": {
      "enum": ["live", "cached", "policy-evaluated", "unchecked"]
    },
    "health_severity": {
      "enum": ["blocked_prerequisite", "warning", "optional_optimization"]
    },
    "divergence_state": {
      "enum": [
        "in_sync",
        "local_overrides",
        "diverged_review_required",
        "unlinked_by_user",
        "unknown_imported_without_lineage"
      ]
    },
    "update_rebase_compatibility": {
      "enum": [
        "in_sync",
        "three_way_update_available",
        "three_way_rebase_required",
        "blocked_by_policy",
        "blocked_by_workspace_trust",
        "no_update_path"
      ]
    },
    "publisher_signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publisher_ref", "signature_ref", "verified"],
      "properties": {
        "publisher_ref": { "$ref": "#/$defs/opaque_id" },
        "signature_ref": { "$ref": "#/$defs/opaque_id" },
        "verified": { "type": "boolean" }
      }
    },
    "template_parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parameter_id", "kind", "required", "secret_bearing"],
      "properties": {
        "parameter_id": { "$ref": "#/$defs/opaque_id" },
        "kind": { "$ref": "#/$defs/parameter_kind" },
        "required": { "type": "boolean" },
        "secret_bearing": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "secret_bearing": { "const": true } }, "required": ["secret_bearing"] },
          "then": { "properties": { "kind": { "const": "secret_handle" } } }
        }
      ]
    },
    "declared_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "posture"],
      "properties": {
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "hook_class": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/hook_class" }] },
        "task_class": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/task_class" }] },
        "posture": { "$ref": "#/$defs/trust_egress_posture" }
      },
      "anyOf": [{ "required": ["hook_class"] }, { "required": ["task_class"] }]
    },
    "template_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "template_id",
        "template_version",
        "source_class",
        "publisher_signature",
        "archetype",
        "supported_ecosystems",
        "supported_platforms",
        "required_parameters",
        "declared_file_classes",
        "declared_actions",
        "trust_egress_notes",
        "support_class"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "template_id": { "$ref": "#/$defs/opaque_id" },
        "template_version": { "$ref": "#/$defs/opaque_id" },
        "source_class": { "$ref": "#/$defs/template_source_class" },
        "publisher_signature": { "$ref": "#/$defs/publisher_signature" },
        "archetype": { "$ref": "#/$defs/template_archetype" },
        "supported_ecosystems": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/supported_ecosystem" }
        },
        "supported_platforms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/supported_platform" }
        },
        "required_parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/template_parameter" }
        },
        "declared_file_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/declared_file_class" }
        },
        "declared_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/declared_action" }
        },
        "trust_egress_notes": { "$ref": "#/$defs/reviewable_sentence" },
        "support_class": { "$ref": "#/$defs/support_class" }
      }
    },
    "resolved_parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parameter_id", "source", "secret_resolution"],
      "properties": {
        "parameter_id": { "$ref": "#/$defs/opaque_id" },
        "source": { "$ref": "#/$defs/parameter_source" },
        "secret_resolution": { "$ref": "#/$defs/secret_resolution" }
      }
    },
    "file_impact_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create_count", "modify_count", "delete_count", "directory_create_count"],
      "properties": {
        "create_count": { "type": "integer", "minimum": 0 },
        "modify_count": { "type": "integer", "minimum": 0 },
        "delete_count": { "type": "integer", "minimum": 0 },
        "directory_create_count": { "type": "integer", "minimum": 0 }
      }
    },
    "scaffold_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "plan_id",
        "manifest_template_id_ref",
        "manifest_version_ref",
        "target_ref",
        "scope",
        "resolved_parameters",
        "file_impact",
        "planned_action_ids",
        "rollback_boundary",
        "create_empty_alternative",
        "reviewed_or_exported_before_write"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "plan_id": { "$ref": "#/$defs/opaque_id" },
        "manifest_template_id_ref": { "$ref": "#/$defs/opaque_id" },
        "manifest_version_ref": { "$ref": "#/$defs/opaque_id" },
        "target_ref": { "$ref": "#/$defs/opaque_id" },
        "scope": { "$ref": "#/$defs/scaffold_scope" },
        "resolved_parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/resolved_parameter" }
        },
        "file_impact": { "$ref": "#/$defs/file_impact_summary" },
        "planned_action_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "rollback_boundary": { "$ref": "#/$defs/rollback_boundary" },
        "create_empty_alternative": { "const": true },
        "reviewed_or_exported_before_write": { "const": true }
      }
    },
    "scaffold_run_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "run_id",
        "plan_id_ref",
        "manifest_template_id_ref",
        "manifest_version_ref",
        "workspace_workset_ref",
        "created_artifact_refs",
        "modified_artifact_refs",
        "invoked_action_ids",
        "outcome",
        "actor"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "run_id": { "$ref": "#/$defs/opaque_id" },
        "plan_id_ref": { "$ref": "#/$defs/opaque_id" },
        "manifest_template_id_ref": { "$ref": "#/$defs/opaque_id" },
        "manifest_version_ref": { "$ref": "#/$defs/opaque_id" },
        "workspace_workset_ref": { "$ref": "#/$defs/opaque_id" },
        "created_artifact_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "modified_artifact_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "invoked_action_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "checkpoint_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_id" }] },
        "outcome": { "$ref": "#/$defs/scaffold_outcome" },
        "actor": { "$ref": "#/$defs/scaffold_actor" }
      }
    },
    "template_health_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "label", "severity", "freshness_state", "scope", "skipped", "fix_guidance"],
      "properties": {
        "check_id": { "$ref": "#/$defs/opaque_id" },
        "label": { "$ref": "#/$defs/reviewable_sentence" },
        "severity": { "$ref": "#/$defs/health_severity" },
        "freshness_state": { "$ref": "#/$defs/health_freshness_state" },
        "scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/supported_platform" }
        },
        "skipped": { "type": "boolean" },
        "fix_guidance": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "template_health_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "report_id", "manifest_template_id_ref", "manifest_version_ref", "rows"],
      "properties": {
        "schema_version": { "const": 1 },
        "report_id": { "$ref": "#/$defs/opaque_id" },
        "manifest_template_id_ref": { "$ref": "#/$defs/opaque_id" },
        "manifest_version_ref": { "$ref": "#/$defs/opaque_id" },
        "rows": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/template_health_row" }
        }
      }
    },
    "generated_project_lineage_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "lineage_id",
        "generated_root_ref",
        "originating_run_id_ref",
        "manifest_template_id_ref",
        "manifest_version_ref",
        "workspace_workset_ref",
        "divergence_state",
        "update_rebase_compatibility",
        "latest_health_report_ref",
        "plain_reviewable_metadata"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "lineage_id": { "$ref": "#/$defs/opaque_id" },
        "generated_root_ref": { "$ref": "#/$defs/opaque_id" },
        "originating_run_id_ref": { "$ref": "#/$defs/opaque_id" },
        "manifest_template_id_ref": { "$ref": "#/$defs/opaque_id" },
        "manifest_version_ref": { "$ref": "#/$defs/opaque_id" },
        "workspace_workset_ref": { "$ref": "#/$defs/opaque_id" },
        "divergence_state": { "$ref": "#/$defs/divergence_state" },
        "update_rebase_compatibility": { "$ref": "#/$defs/update_rebase_compatibility" },
        "latest_health_report_ref": { "$ref": "#/$defs/opaque_id" },
        "plain_reviewable_metadata": { "const": true }
      }
    }
  }
}
