{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aureline.dev/continuity/deferred-intent-and-reconciliation.schema.json",
  "title": "Connectivity state, deferred intent, and reconciliation page",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "contract_refs",
    "local_safe_promises",
    "connectivity_badges",
    "connectivity_cards",
    "command_declarations",
    "deferred_intents",
    "idempotency_receipts",
    "reconciliation_reviews",
    "reconciliation_packets",
    "support_export"
  ],
  "properties": {
    "record_kind": { "const": "connectivity_continuity_page_record" },
    "schema_version": { "const": 1 },
    "contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "local_safe_promises": {
      "type": "array",
      "items": { "$ref": "#/$defs/local_safe_promise" },
      "minItems": 6
    },
    "connectivity_badges": {
      "type": "array",
      "items": { "$ref": "#/$defs/connectivity_badge" },
      "minItems": 6
    },
    "connectivity_cards": {
      "type": "array",
      "items": { "$ref": "#/$defs/connectivity_card" },
      "minItems": 6
    },
    "command_declarations": {
      "type": "array",
      "items": { "$ref": "#/$defs/network_command_declaration" },
      "minItems": 1
    },
    "deferred_intents": {
      "type": "array",
      "items": { "$ref": "#/$defs/deferred_intent" },
      "minItems": 1
    },
    "idempotency_receipts": {
      "type": "array",
      "items": { "$ref": "#/$defs/idempotency_receipt" },
      "minItems": 1
    },
    "reconciliation_reviews": {
      "type": "array",
      "items": { "$ref": "#/$defs/reconciliation_review_sheet" }
    },
    "reconciliation_packets": {
      "type": "array",
      "items": { "$ref": "#/$defs/reconciliation_packet" },
      "minItems": 1
    },
    "support_export": { "$ref": "#/$defs/support_export" }
  },
  "$defs": {
    "connectivity_state": {
      "type": "string",
      "enum": [
        "Connected",
        "Constrained",
        "OfflineLocalSafe",
        "ReauthRequired",
        "ReconciliationPending",
        "ServiceUnavailable"
      ]
    },
    "service_family": {
      "type": "string",
      "enum": [
        "provider",
        "managed_workspace",
        "request_workspace",
        "remote",
        "collaboration",
        "service_health",
        "ai",
        "support"
      ]
    },
    "stale_label_semantics": {
      "type": "string",
      "enum": [
        "current",
        "last_known_good_timestamp",
        "cached_inspect_only",
        "auth_or_policy_stale",
        "service_family_unavailable"
      ]
    },
    "local_safe_promise": {
      "type": "object",
      "required": [
        "state",
        "service_family",
        "local_editing_available",
        "local_search_available",
        "local_git_available",
        "local_tasks_available",
        "cached_inspection_available",
        "stale_label_semantics"
      ],
      "properties": {
        "state": { "$ref": "#/$defs/connectivity_state" },
        "service_family": { "$ref": "#/$defs/service_family" },
        "local_editing_available": { "type": "boolean" },
        "local_search_available": { "type": "boolean" },
        "local_git_available": { "type": "boolean" },
        "local_tasks_available": { "type": "boolean" },
        "cached_inspection_available": { "type": "boolean" },
        "stale_label_semantics": { "$ref": "#/$defs/stale_label_semantics" },
        "deployment_policy_ref": { "type": "string", "minLength": 1 }
      }
    },
    "connectivity_badge": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "badge_id",
        "service_family",
        "state",
        "affected_family_label",
        "promise_summary",
        "action_label",
        "action_ref"
      ],
      "properties": {
        "record_kind": { "const": "connectivity_badge_record" },
        "schema_version": { "const": 1 },
        "badge_id": { "type": "string", "minLength": 1 },
        "service_family": { "$ref": "#/$defs/service_family" },
        "state": { "$ref": "#/$defs/connectivity_state" },
        "affected_family_label": { "type": "string", "minLength": 1 },
        "promise_summary": { "type": "string", "minLength": 1 },
        "action_label": { "type": "string", "minLength": 1 },
        "action_ref": { "type": "string", "minLength": 1 }
      }
    },
    "card_action": {
      "type": "object",
      "required": ["action_id", "label", "action_ref"],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "action_ref": { "type": "string", "minLength": 1 }
      }
    },
    "connectivity_card": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "card_id",
        "service_family",
        "state",
        "title_label",
        "summary_label",
        "promise_label",
        "what_still_works",
        "suggested_actions"
      ],
      "properties": {
        "record_kind": { "const": "connectivity_state_card_record" },
        "schema_version": { "const": 1 },
        "card_id": { "type": "string", "minLength": 1 },
        "service_family": { "$ref": "#/$defs/service_family" },
        "state": { "$ref": "#/$defs/connectivity_state" },
        "title_label": { "type": "string", "minLength": 1 },
        "summary_label": { "type": "string", "minLength": 1 },
        "promise_label": { "type": "string", "minLength": 1 },
        "what_still_works": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "suggested_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/card_action" },
          "minItems": 1
        }
      }
    },
    "offline_read_class": {
      "type": "string",
      "enum": ["pure_local_core", "cached_read_inspect", "live_required"]
    },
    "queueability_class": {
      "type": "string",
      "enum": [
        "not_needed_local",
        "explicit_idempotent_reviewable",
        "read_only_refresh",
        "policy_bound_background",
        "never_queue"
      ]
    },
    "replay_safety_class": {
      "type": "string",
      "enum": [
        "idempotent_bounded",
        "read_only_refresh",
        "local_only",
        "manual_rerun_required"
      ]
    },
    "reconciliation_owner": {
      "type": "string",
      "enum": [
        "provider",
        "managed_workspace",
        "request_workspace",
        "remote",
        "service_health",
        "support"
      ]
    },
    "idempotency_key_shape": {
      "type": "object",
      "required": [
        "includes_command_id",
        "includes_target_identity",
        "includes_actor_identity",
        "includes_policy_epoch",
        "includes_context_hash",
        "support_summary"
      ],
      "properties": {
        "includes_command_id": { "type": "boolean" },
        "includes_target_identity": { "type": "boolean" },
        "includes_actor_identity": { "type": "boolean" },
        "includes_policy_epoch": { "type": "boolean" },
        "includes_context_hash": { "type": "boolean" },
        "support_summary": { "type": "string", "minLength": 1 }
      }
    },
    "expiry_policy": {
      "type": "object",
      "required": ["expires_after", "blocks_replay_after_expiry", "rationale_summary"],
      "properties": {
        "expires_after": { "type": "string", "minLength": 1 },
        "blocks_replay_after_expiry": { "type": "boolean" },
        "rationale_summary": { "type": "string", "minLength": 1 }
      }
    },
    "queueability_declaration": {
      "type": "object",
      "required": [
        "offline_read_class",
        "queueability",
        "replay_safety",
        "stale_label_semantics"
      ],
      "properties": {
        "offline_read_class": { "$ref": "#/$defs/offline_read_class" },
        "queueability": { "$ref": "#/$defs/queueability_class" },
        "replay_safety": { "$ref": "#/$defs/replay_safety_class" },
        "idempotency_key_shape": { "$ref": "#/$defs/idempotency_key_shape" },
        "expiry_policy": { "$ref": "#/$defs/expiry_policy" },
        "stale_label_semantics": { "$ref": "#/$defs/stale_label_semantics" },
        "reconciliation_owner": { "$ref": "#/$defs/reconciliation_owner" }
      }
    },
    "network_command_declaration": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "command_id",
        "service_family",
        "action_family",
        "queueability",
        "missing_metadata_block_reason"
      ],
      "properties": {
        "record_kind": { "const": "network_command_declaration_record" },
        "schema_version": { "const": 1 },
        "command_id": { "type": "string", "minLength": 1 },
        "service_family": { "$ref": "#/$defs/service_family" },
        "action_family": { "type": "string", "minLength": 1 },
        "queueability": { "$ref": "#/$defs/queueability_declaration" },
        "missing_metadata_block_reason": { "type": "string", "minLength": 1 }
      }
    },
    "actor_identity": {
      "type": "object",
      "required": ["actor_ref", "actor_class", "display_label"],
      "properties": {
        "actor_ref": { "type": "string", "minLength": 1 },
        "actor_class": { "type": "string", "minLength": 1 },
        "display_label": { "type": "string", "minLength": 1 }
      }
    },
    "target_identity": {
      "type": "object",
      "required": [
        "target_ref",
        "target_class",
        "tenant_ref",
        "region_ref",
        "endpoint_ref",
        "version_ref"
      ],
      "properties": {
        "target_ref": { "type": "string", "minLength": 1 },
        "target_class": { "type": "string", "minLength": 1 },
        "tenant_ref": { "type": "string", "minLength": 1 },
        "region_ref": { "type": "string", "minLength": 1 },
        "endpoint_ref": { "type": "string", "minLength": 1 },
        "version_ref": { "type": "string", "minLength": 1 }
      }
    },
    "auth_scope": {
      "type": "object",
      "required": ["subject_ref", "scope_refs", "auth_epoch"],
      "properties": {
        "subject_ref": { "type": "string", "minLength": 1 },
        "scope_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "auth_epoch": { "type": "string", "minLength": 1 }
      }
    },
    "deferred_intent_state": {
      "type": "string",
      "enum": ["queued", "replayed", "cancelled", "expired", "dropped", "conflict_review"]
    },
    "deferred_intent_action": {
      "type": "string",
      "enum": ["replay", "cancel", "export", "open_review"]
    },
    "sensitive_payload_posture": {
      "type": "string",
      "enum": [
        "no_raw_payload",
        "raw_payload_withheld_by_default",
        "redacted_preview_only"
      ]
    },
    "replay_prerequisite_class": {
      "type": "string",
      "enum": [
        "connectivity_restored",
        "service_family_healthy",
        "target_identity_current",
        "auth_scope_current",
        "policy_epoch_current",
        "context_hash_current",
        "data_fingerprint_current"
      ]
    },
    "replay_prerequisite_state": {
      "type": "string",
      "enum": ["pending_revalidation", "satisfied", "failed_requires_review"]
    },
    "replay_prerequisite": {
      "type": "object",
      "required": [
        "prerequisite_class",
        "state",
        "requirement_summary",
        "exact_match_required"
      ],
      "properties": {
        "prerequisite_class": { "$ref": "#/$defs/replay_prerequisite_class" },
        "state": { "$ref": "#/$defs/replay_prerequisite_state" },
        "requirement_summary": { "type": "string", "minLength": 1 },
        "exact_match_required": { "type": "boolean" }
      }
    },
    "deferred_intent": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "intent_id",
        "command_id",
        "service_family",
        "target_identity",
        "actor",
        "queued_at",
        "expires_at",
        "policy_epoch",
        "auth_scope",
        "context_hash",
        "data_fingerprint",
        "idempotency_key_ref",
        "previewed_effect_summary",
        "replay_prerequisites",
        "state",
        "available_actions",
        "sensitive_payload_posture"
      ],
      "properties": {
        "record_kind": { "const": "deferred_intent_record" },
        "schema_version": { "const": 1 },
        "intent_id": { "type": "string", "minLength": 1 },
        "command_id": { "type": "string", "minLength": 1 },
        "service_family": { "$ref": "#/$defs/service_family" },
        "target_identity": { "$ref": "#/$defs/target_identity" },
        "actor": { "$ref": "#/$defs/actor_identity" },
        "queued_at": { "type": "string", "minLength": 1 },
        "expires_at": { "type": "string", "minLength": 1 },
        "policy_epoch": { "type": "string", "minLength": 1 },
        "auth_scope": { "$ref": "#/$defs/auth_scope" },
        "context_hash": { "type": "string", "minLength": 1 },
        "data_fingerprint": { "type": "string", "minLength": 1 },
        "idempotency_key_ref": { "type": "string", "minLength": 1 },
        "previewed_effect_summary": { "type": "string", "minLength": 1 },
        "replay_prerequisites": {
          "type": "array",
          "items": { "$ref": "#/$defs/replay_prerequisite" },
          "minItems": 1
        },
        "state": { "$ref": "#/$defs/deferred_intent_state" },
        "available_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/deferred_intent_action" },
          "minItems": 1
        },
        "sensitive_payload_posture": { "$ref": "#/$defs/sensitive_payload_posture" }
      }
    },
    "idempotency_receipt_outcome": {
      "type": "string",
      "enum": [
        "queued_for_outbox",
        "replayed_under_same_key",
        "deduped_as_already_applied",
        "blocked_pending_review",
        "discarded_without_replay"
      ]
    },
    "idempotency_receipt": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "receipt_id",
        "intent_id",
        "idempotency_key_ref",
        "dedupe_scope_ref",
        "outcome",
        "recorded_at",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "idempotency_key_receipt_record" },
        "schema_version": { "const": 1 },
        "receipt_id": { "type": "string", "minLength": 1 },
        "intent_id": { "type": "string", "minLength": 1 },
        "idempotency_key_ref": { "type": "string", "minLength": 1 },
        "dedupe_scope_ref": { "type": "string", "minLength": 1 },
        "outcome": { "$ref": "#/$defs/idempotency_receipt_outcome" },
        "recorded_at": { "type": "string", "minLength": 1 },
        "summary_label": { "type": "string", "minLength": 1 }
      }
    },
    "drift_dimension": {
      "type": "string",
      "enum": [
        "route",
        "policy",
        "auth",
        "tenant",
        "region",
        "endpoint",
        "target",
        "version",
        "entitlement",
        "context",
        "data",
        "command_metadata",
        "expiry"
      ]
    },
    "drift_snapshot": {
      "type": "object",
      "required": ["dimension", "queued_value_summary", "current_value_summary"],
      "properties": {
        "dimension": { "$ref": "#/$defs/drift_dimension" },
        "queued_value_summary": { "type": "string", "minLength": 1 },
        "current_value_summary": { "type": "string", "minLength": 1 }
      }
    },
    "reconciliation_review_sheet": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "review_id",
        "intent_id",
        "connectivity_state",
        "drift_dimensions",
        "previewed_effect_summary",
        "current_drift_summary",
        "policy_or_auth_delta_summary",
        "available_actions",
        "replay_blocked_until_review"
      ],
      "properties": {
        "record_kind": { "const": "reconciliation_review_sheet_record" },
        "schema_version": { "const": 1 },
        "review_id": { "type": "string", "minLength": 1 },
        "intent_id": { "type": "string", "minLength": 1 },
        "connectivity_state": { "$ref": "#/$defs/connectivity_state" },
        "drift_dimensions": {
          "type": "array",
          "items": { "$ref": "#/$defs/drift_dimension" },
          "minItems": 1
        },
        "previewed_effect_summary": { "type": "string", "minLength": 1 },
        "current_drift_summary": { "type": "string", "minLength": 1 },
        "policy_or_auth_delta_summary": { "type": "string", "minLength": 1 },
        "available_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/deferred_intent_action" },
          "minItems": 1
        },
        "replay_blocked_until_review": { "const": true }
      }
    },
    "reconciliation_disposition": {
      "type": "string",
      "enum": ["replayed", "blocked", "narrowed", "discarded"]
    },
    "reconciliation_packet": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "intent_id",
        "service_family",
        "connectivity_state",
        "disposition",
        "drift_dimensions",
        "drift_snapshots",
        "summary_label",
        "support_manifest_ref",
        "outcome_disclosed_to_user"
      ],
      "properties": {
        "record_kind": { "const": "reconciliation_packet_record" },
        "schema_version": { "const": 1 },
        "packet_id": { "type": "string", "minLength": 1 },
        "intent_id": { "type": "string", "minLength": 1 },
        "service_family": { "$ref": "#/$defs/service_family" },
        "connectivity_state": { "$ref": "#/$defs/connectivity_state" },
        "disposition": { "$ref": "#/$defs/reconciliation_disposition" },
        "drift_dimensions": {
          "type": "array",
          "items": { "$ref": "#/$defs/drift_dimension" }
        },
        "drift_snapshots": {
          "type": "array",
          "items": { "$ref": "#/$defs/drift_snapshot" }
        },
        "summary_label": { "type": "string", "minLength": 1 },
        "idempotency_receipt_ref": { "type": "string", "minLength": 1 },
        "reconciliation_review_ref": { "type": "string", "minLength": 1 },
        "support_manifest_ref": { "type": "string", "minLength": 1 },
        "outcome_disclosed_to_user": { "const": true }
      }
    },
    "support_export_outcome_row": {
      "type": "object",
      "required": [
        "row_id",
        "intent_id",
        "service_family",
        "intent_state",
        "summary_label",
        "actor_label",
        "target_ref"
      ],
      "properties": {
        "row_id": { "type": "string", "minLength": 1 },
        "intent_id": { "type": "string", "minLength": 1 },
        "service_family": { "$ref": "#/$defs/service_family" },
        "intent_state": { "$ref": "#/$defs/deferred_intent_state" },
        "reconciliation_disposition": { "$ref": "#/$defs/reconciliation_disposition" },
        "summary_label": { "type": "string", "minLength": 1 },
        "actor_label": { "type": "string", "minLength": 1 },
        "target_ref": { "type": "string", "minLength": 1 },
        "idempotency_receipt_ref": { "type": "string", "minLength": 1 },
        "reconciliation_packet_ref": { "type": "string", "minLength": 1 }
      }
    },
    "support_export": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "state_vocabulary",
        "badge_refs",
        "deferred_intent_refs",
        "reconciliation_review_refs",
        "reconciliation_packet_refs",
        "idempotency_receipt_refs",
        "outcome_rows",
        "raw_sensitive_payloads_excluded"
      ],
      "properties": {
        "record_kind": { "const": "connectivity_support_export_packet_record" },
        "schema_version": { "const": 1 },
        "state_vocabulary": {
          "type": "array",
          "items": { "$ref": "#/$defs/connectivity_state" },
          "minItems": 6
        },
        "badge_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "deferred_intent_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "reconciliation_review_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "reconciliation_packet_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "idempotency_receipt_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "outcome_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/support_export_outcome_row" },
          "minItems": 1
        },
        "raw_sensitive_payloads_excluded": { "const": true }
      }
    }
  }
}
