{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/framework/framework_support_strip.schema.json",
  "title": "Aureline framework support / status strip record",
  "description": "Boundary schema for the framework_support_strip_record. The strip is the cross-surface header that every framework-aware surface (route explorer, component / service tree, convention-diagnostics lane, generator-preview review, notebook framework-context inspector, AI-assist context lane, support export) renders before a framework claim becomes actionable. It carries the detected framework identity and version (or version range), the support class (core native / framework pack / bridge / heuristic convention / unsupported), the pack or bridge source identity, runtime / pack health, freshness, local vs remote scope, version-compatibility posture, and the closed list of fallback-open actions the user may take. The strip composes with the framework_certainty_row and source_sync_chip contracts: it does NOT re-derive certainty, primary source, fallback-inference reasons, or runtime alignment; it carries the header-level orientation truth those records cite. Raw URLs, raw absolute paths, raw hostnames, raw IP addresses, raw secret material, and exact version strings the project would consider private never cross this boundary; only opaque ids, typed vocabulary, and export-safe labels and summaries do. Adding a new surface_class, framework_family_class, support_class, pack_source_class, bridge_kind_class, health_class, freshness_class, locality_class, version_compatibility_class, or framework_support_action_class value is additive-minor and bumps framework_support_strip_schema_version; repurposing an existing field is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [{ "$ref": "#/$defs/framework_support_strip_record" }],
  "$defs": {
    "framework_support_strip_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "framework_support_strip_record"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe to log, export, or persist. Raw URLs, raw absolute paths, raw hostnames, raw IPs, raw bearer tokens, and raw secret values never appear here."
    },
    "redacted_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "short_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "route_explorer_surface",
        "component_tree_surface",
        "service_graph_surface",
        "convention_diagnostics_surface",
        "generator_preview_surface",
        "notebook_framework_context_surface",
        "ai_assist_context_surface",
        "support_export_surface"
      ],
      "description": "Closed surface vocabulary every framework support strip may project to."
    },
    "framework_family_class": {
      "type": "string",
      "enum": [
        "react_or_jsx_family",
        "vue_or_template_family",
        "svelte_or_compile_family",
        "angular_or_decorator_family",
        "solid_or_signal_family",
        "web_components_family",
        "flutter_widget_family",
        "swiftui_widget_family",
        "compose_widget_family",
        "html_dom_passthrough",
        "static_markdown_renderer",
        "design_token_only_adapter",
        "unsupported_or_unclaimed_family"
      ],
      "description": "Re-export of framework_adapter_class from schemas/preview/preview_snapshot.schema.json (renamed for the strip context). unsupported_or_unclaimed_family forbids support_class in {core_native, framework_pack}."
    },
    "framework_identity_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["framework_family_class", "framework_name_label"],
      "properties": {
        "framework_family_class": { "$ref": "#/$defs/framework_family_class" },
        "framework_name_label": { "$ref": "#/$defs/redacted_label" },
        "framework_version_label": {
          "anyOf": [
            { "$ref": "#/$defs/redacted_label" },
            { "type": "null" }
          ],
          "description": "Reviewer-facing version label as detected. Null when no version was detected."
        },
        "framework_version_range_label": {
          "anyOf": [
            { "$ref": "#/$defs/redacted_label" },
            { "type": "null" }
          ],
          "description": "Reviewer-facing version range the support class covers. Null when no range was declared (e.g. heuristic mode)."
        }
      }
    },
    "support_class": {
      "type": "string",
      "enum": [
        "core_native",
        "framework_pack",
        "bridge_compatibility_layer",
        "heuristic_convention_mode",
        "unsupported_or_unclaimed"
      ],
      "description": "Closed support-class vocabulary. core_native: first-party / certified pack provides exact project-model support. framework_pack: governed pack provides structured support on shared contracts. bridge_compatibility_layer: capability is translated from another ecosystem or tool model. heuristic_convention_mode: routes / components / services / entities are inferred from naming or layout only. unsupported_or_unclaimed: nothing claims this framework."
    },
    "pack_source_class": {
      "type": "string",
      "enum": [
        "first_party_native",
        "governed_framework_pack",
        "community_framework_pack",
        "bridge_compatibility_layer",
        "heuristic_convention_only",
        "imported_snapshot_only",
        "no_pack_or_bridge"
      ],
      "description": "Closed pack / bridge source vocabulary. heuristic_convention_only and no_pack_or_bridge forbid support_class in {core_native, framework_pack}. governed_framework_pack and first_party_native are the only sources that may pair with support_class = core_native. bridge_compatibility_layer is admissible only with support_class = bridge_compatibility_layer."
    },
    "pack_or_bridge_source_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pack_source_class"],
      "properties": {
        "pack_source_class": { "$ref": "#/$defs/pack_source_class" },
        "pack_ref": {
          "anyOf": [{ "$ref": "#/$defs/opaque_id" }, { "type": "null" }]
        },
        "pack_version_label": {
          "anyOf": [{ "$ref": "#/$defs/redacted_label" }, { "type": "null" }]
        },
        "bridge_ref": {
          "anyOf": [{ "$ref": "#/$defs/opaque_id" }, { "type": "null" }]
        },
        "bridge_label": {
          "anyOf": [{ "$ref": "#/$defs/redacted_label" }, { "type": "null" }]
        }
      }
    },
    "health_class": {
      "type": "string",
      "enum": [
        "healthy_live",
        "degraded_partial",
        "stale_cache",
        "unreachable_runtime",
        "pack_capability_missing",
        "unknown_health"
      ],
      "description": "Closed pack / runtime health vocabulary. healthy_live forbids freshness_class in {stale, unverified}. unreachable_runtime forbids freshness_class = authoritative_live."
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ],
      "description": "Re-export of freshness_class from schemas/language/result_provenance.schema.json. Shared freshness ladder."
    },
    "health_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["health_class", "freshness_class"],
      "properties": {
        "health_class": { "$ref": "#/$defs/health_class" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "last_refresh_at": {
          "anyOf": [
            { "$ref": "#/$defs/monotonic_timestamp" },
            { "type": "null" }
          ]
        }
      }
    },
    "locality_class": {
      "type": "string",
      "enum": [
        "local_workspace",
        "remote_workspace",
        "managed_workspace",
        "mixed_local_and_remote",
        "notebook_kernel_only",
        "extension_host_only",
        "unknown_scope"
      ],
      "description": "Closed locality vocabulary describing where the framework is being evaluated."
    },
    "scope_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locality_class"],
      "properties": {
        "locality_class": { "$ref": "#/$defs/locality_class" },
        "workspace_scope_label": {
          "anyOf": [{ "$ref": "#/$defs/redacted_label" }, { "type": "null" }]
        },
        "workspace_scope_ref": {
          "anyOf": [{ "$ref": "#/$defs/opaque_id" }, { "type": "null" }]
        }
      }
    },
    "version_compatibility_class": {
      "type": "string",
      "enum": [
        "within_supported_range",
        "below_supported_range",
        "above_supported_range",
        "between_versions",
        "unsupported_version",
        "unknown_version",
        "version_not_applicable"
      ],
      "description": "Closed version-compatibility vocabulary. unsupported_version and unknown_version forbid support_class = core_native."
    },
    "compatibility_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version_compatibility_class"],
      "properties": {
        "version_compatibility_class": {
          "$ref": "#/$defs/version_compatibility_class"
        },
        "supported_version_range_label": {
          "anyOf": [{ "$ref": "#/$defs/redacted_label" }, { "type": "null" }]
        },
        "downgraded_behavior_summary": {
          "anyOf": [{ "$ref": "#/$defs/short_summary" }, { "type": "null" }]
        }
      }
    },
    "framework_support_action_class": {
      "type": "string",
      "enum": [
        "open_compatibility_details",
        "open_pack_status",
        "open_pack_docs",
        "open_migration_path",
        "open_raw_source_fallback",
        "request_pack_install",
        "request_pack_update",
        "request_policy_review",
        "open_runtime_inspector"
      ],
      "description": "Closed action vocabulary the strip may offer. Every strip MUST offer at least one action so the user is never given a dead-end label."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "framework_support_strip_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "framework_support_strip_schema_version",
        "framework_support_strip_id",
        "captured_at",
        "surface_class",
        "framework_identity_block",
        "support_class",
        "pack_or_bridge_source_block",
        "health_block",
        "scope_block",
        "compatibility_block",
        "actions",
        "summary"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "framework_support_strip_schema_version": {
          "$ref": "#/$defs/framework_support_strip_schema_version"
        },
        "framework_support_strip_id": { "$ref": "#/$defs/opaque_id" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },

        "surface_class": { "$ref": "#/$defs/surface_class" },

        "framework_identity_block": {
          "$ref": "#/$defs/framework_identity_block"
        },
        "support_class": { "$ref": "#/$defs/support_class" },
        "pack_or_bridge_source_block": {
          "$ref": "#/$defs/pack_or_bridge_source_block"
        },
        "health_block": { "$ref": "#/$defs/health_block" },
        "scope_block": { "$ref": "#/$defs/scope_block" },
        "compatibility_block": { "$ref": "#/$defs/compatibility_block" },

        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/framework_support_action_class" },
          "uniqueItems": true,
          "minItems": 1
        },

        "framework_certainty_row_record_ref": {
          "anyOf": [{ "$ref": "#/$defs/opaque_id" }, { "type": "null" }]
        },
        "source_sync_chip_record_ref": {
          "anyOf": [{ "$ref": "#/$defs/opaque_id" }, { "type": "null" }]
        },

        "summary": { "$ref": "#/$defs/short_summary" },
        "notes": {
          "anyOf": [{ "$ref": "#/$defs/short_summary" }, { "type": "null" }]
        }
      },
      "allOf": [
        {
          "description": "support_class = core_native requires pack_source_class in {first_party_native, governed_framework_pack} and version_compatibility_class != unsupported_version AND != unknown_version.",
          "if": {
            "properties": { "support_class": { "const": "core_native" } },
            "required": ["support_class"]
          },
          "then": {
            "properties": {
              "pack_or_bridge_source_block": {
                "properties": {
                  "pack_source_class": {
                    "enum": ["first_party_native", "governed_framework_pack"]
                  }
                },
                "required": ["pack_source_class"]
              },
              "compatibility_block": {
                "properties": {
                  "version_compatibility_class": {
                    "not": {
                      "enum": ["unsupported_version", "unknown_version"]
                    }
                  }
                }
              }
            }
          }
        },
        {
          "description": "support_class = framework_pack requires pack_source_class in {first_party_native, governed_framework_pack, community_framework_pack}.",
          "if": {
            "properties": { "support_class": { "const": "framework_pack" } },
            "required": ["support_class"]
          },
          "then": {
            "properties": {
              "pack_or_bridge_source_block": {
                "properties": {
                  "pack_source_class": {
                    "enum": [
                      "first_party_native",
                      "governed_framework_pack",
                      "community_framework_pack"
                    ]
                  }
                },
                "required": ["pack_source_class"]
              }
            }
          }
        },
        {
          "description": "support_class = bridge_compatibility_layer requires pack_source_class = bridge_compatibility_layer.",
          "if": {
            "properties": {
              "support_class": { "const": "bridge_compatibility_layer" }
            },
            "required": ["support_class"]
          },
          "then": {
            "properties": {
              "pack_or_bridge_source_block": {
                "properties": {
                  "pack_source_class": {
                    "const": "bridge_compatibility_layer"
                  }
                },
                "required": ["pack_source_class"]
              }
            }
          }
        },
        {
          "description": "support_class = heuristic_convention_mode requires pack_source_class in {heuristic_convention_only, imported_snapshot_only, no_pack_or_bridge} and forbids version_compatibility_class = within_supported_range.",
          "if": {
            "properties": {
              "support_class": { "const": "heuristic_convention_mode" }
            },
            "required": ["support_class"]
          },
          "then": {
            "properties": {
              "pack_or_bridge_source_block": {
                "properties": {
                  "pack_source_class": {
                    "enum": [
                      "heuristic_convention_only",
                      "imported_snapshot_only",
                      "no_pack_or_bridge"
                    ]
                  }
                },
                "required": ["pack_source_class"]
              },
              "compatibility_block": {
                "properties": {
                  "version_compatibility_class": {
                    "not": { "const": "within_supported_range" }
                  }
                }
              }
            }
          }
        },
        {
          "description": "support_class = unsupported_or_unclaimed requires pack_source_class = no_pack_or_bridge.",
          "if": {
            "properties": {
              "support_class": { "const": "unsupported_or_unclaimed" }
            },
            "required": ["support_class"]
          },
          "then": {
            "properties": {
              "pack_or_bridge_source_block": {
                "properties": {
                  "pack_source_class": { "const": "no_pack_or_bridge" }
                },
                "required": ["pack_source_class"]
              }
            }
          }
        },
        {
          "description": "framework_family_class = unsupported_or_unclaimed_family forbids support_class in {core_native, framework_pack}.",
          "if": {
            "properties": {
              "framework_identity_block": {
                "properties": {
                  "framework_family_class": {
                    "const": "unsupported_or_unclaimed_family"
                  }
                },
                "required": ["framework_family_class"]
              }
            },
            "required": ["framework_identity_block"]
          },
          "then": {
            "properties": {
              "support_class": {
                "not": { "enum": ["core_native", "framework_pack"] }
              }
            }
          }
        },
        {
          "description": "health_class = healthy_live forbids freshness_class in {stale, unverified}.",
          "if": {
            "properties": {
              "health_block": {
                "properties": { "health_class": { "const": "healthy_live" } },
                "required": ["health_class"]
              }
            },
            "required": ["health_block"]
          },
          "then": {
            "properties": {
              "health_block": {
                "properties": {
                  "freshness_class": {
                    "not": { "enum": ["stale", "unverified"] }
                  }
                }
              }
            }
          }
        },
        {
          "description": "health_class = unreachable_runtime forbids freshness_class = authoritative_live.",
          "if": {
            "properties": {
              "health_block": {
                "properties": {
                  "health_class": { "const": "unreachable_runtime" }
                },
                "required": ["health_class"]
              }
            },
            "required": ["health_block"]
          },
          "then": {
            "properties": {
              "health_block": {
                "properties": {
                  "freshness_class": {
                    "not": { "const": "authoritative_live" }
                  }
                }
              }
            }
          }
        },
        {
          "description": "Every non-unsupported strip MUST offer open_compatibility_details in its action set so users can drill into pack / bridge / heuristic posture.",
          "if": {
            "properties": {
              "support_class": {
                "enum": [
                  "core_native",
                  "framework_pack",
                  "bridge_compatibility_layer",
                  "heuristic_convention_mode"
                ]
              }
            },
            "required": ["support_class"]
          },
          "then": {
            "properties": {
              "actions": {
                "contains": { "const": "open_compatibility_details" }
              }
            }
          }
        },
        {
          "description": "request_pack_install / request_pack_update / open_pack_docs / open_pack_status / open_migration_path are admissible only when pack_or_bridge_source_block.pack_source_class is in {first_party_native, governed_framework_pack, community_framework_pack, bridge_compatibility_layer}.",
          "if": {
            "properties": {
              "pack_or_bridge_source_block": {
                "properties": {
                  "pack_source_class": {
                    "enum": [
                      "heuristic_convention_only",
                      "imported_snapshot_only",
                      "no_pack_or_bridge"
                    ]
                  }
                },
                "required": ["pack_source_class"]
              }
            },
            "required": ["pack_or_bridge_source_block"]
          },
          "then": {
            "properties": {
              "actions": {
                "not": {
                  "anyOf": [
                    { "contains": { "const": "request_pack_update" } },
                    { "contains": { "const": "open_pack_status" } }
                  ]
                }
              }
            }
          }
        }
      ],
      "description": "One framework support / status strip record emitted by a route explorer, component / service tree, convention-diagnostics lane, generator-preview review, notebook framework-context inspector, AI-assist context lane, or support export."
    }
  }
}
