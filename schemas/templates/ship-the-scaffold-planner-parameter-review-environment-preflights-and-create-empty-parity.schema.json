{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/templates/ship-the-scaffold-planner-parameter-review-environment-preflights-and-create-empty-parity.schema.json",
  "title": "Aureline scaffold planner, parameter review, environment preflights, and create-empty parity rows",
  "description": "Export-safe packet for the scaffold planner. Each row binds one prepared scaffold plan — a templated starter or a create-empty workspace — to its parameter-review state, environment-preflight state, previewed write impact and rollback boundary, create-empty parity posture, and readiness, so the gallery, scaffold preflight, parameter-review, run, recovery, diagnostics, and support surfaces project the same plan, preflight, and parity truth instead of writing before review or presenting a create-empty workspace as if it skipped the safety pipeline. Raw parameter values, secrets, absolute paths, repository URLs, manifest bodies, hook bodies, command output, and user-authored content never cross this boundary; rows carry opaque refs, closed-vocabulary class tokens, and short reviewable summaries only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "planner_label",
    "rows",
    "safety_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "scaffold_planner_parameter_review_and_create_empty_parity_rows"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "planner_label": { "$ref": "#/$defs/non_empty_string" },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/plan_row" }
    },
    "safety_review": { "$ref": "#/$defs/safety_review" },
    "consumer_projection": { "$ref": "#/$defs/consumer_projection" },
    "proof_freshness": { "$ref": "#/$defs/proof_freshness" },
    "source_contract_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "redaction_class_token": { "$ref": "#/$defs/non_empty_string" },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_non_empty_string": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/non_empty_string" }
      ]
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "string_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "plan_kind": {
      "type": "string",
      "enum": [
        "template_scaffold",
        "create_empty_workspace",
        "create_empty_parity_bridge"
      ]
    },
    "parameter_review_class": {
      "type": "string",
      "enum": [
        "all_resolved_reviewed",
        "defaults_accepted_reviewed",
        "awaiting_required_input",
        "invalid_parameters_blocked",
        "no_parameters_required",
        "review_required"
      ]
    },
    "environment_preflight_class": {
      "type": "string",
      "enum": [
        "all_preflights_passed",
        "passed_with_warnings",
        "missing_optional_tooling",
        "blocking_prerequisite_missing",
        "preflight_failed_blocked",
        "preflight_skipped_review_required"
      ]
    },
    "create_empty_parity_class": {
      "type": "string",
      "enum": [
        "full_parity_with_template_flow",
        "parity_with_documented_differences",
        "reduced_parity_review_required",
        "parity_broken_blocked"
      ]
    },
    "rollback_posture_class": {
      "type": "string",
      "enum": [
        "full_rollback_boundary_recorded",
        "partial_rollback_with_manual_steps",
        "no_writes_yet_fully_reversible",
        "rollback_unavailable_review_required"
      ]
    },
    "readiness_state": {
      "type": "string",
      "enum": [
        "ready_for_apply",
        "preview_only_awaiting_confirmation",
        "blocked_awaiting_input",
        "blocked_failed_preflight",
        "blocked_parity_broken",
        "review_required"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "required_parameter_unresolved",
        "parameter_validation_failed",
        "environment_prerequisite_missing",
        "preflight_failed",
        "write_impact_preview_unavailable",
        "rollback_boundary_unavailable",
        "create_empty_parity_broken",
        "template_revision_unavailable",
        "upstream_dependency_narrowed"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "gallery",
        "preflight",
        "parameter_review",
        "run_surface",
        "recovery",
        "cli_headless",
        "support_export",
        "diagnostics"
      ]
    },
    "parameter_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_class",
        "total_parameters",
        "resolved_parameters",
        "required_parameters",
        "unresolved_required_parameters",
        "invalid_parameters",
        "parameter_review_refs",
        "no_mutation_during_review"
      ],
      "properties": {
        "review_class": { "$ref": "#/$defs/parameter_review_class" },
        "total_parameters": { "$ref": "#/$defs/non_negative_integer" },
        "resolved_parameters": { "$ref": "#/$defs/non_negative_integer" },
        "required_parameters": { "$ref": "#/$defs/non_negative_integer" },
        "unresolved_required_parameters": { "$ref": "#/$defs/non_negative_integer" },
        "invalid_parameters": { "$ref": "#/$defs/non_negative_integer" },
        "parameter_review_refs": { "$ref": "#/$defs/string_array" },
        "no_mutation_during_review": { "type": "boolean" }
      }
    },
    "environment_preflight": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preflight_class",
        "total_checks",
        "passed_checks",
        "warning_checks",
        "blocking_failures",
        "preflight_check_refs"
      ],
      "properties": {
        "preflight_class": { "$ref": "#/$defs/environment_preflight_class" },
        "total_checks": { "$ref": "#/$defs/non_negative_integer" },
        "passed_checks": { "$ref": "#/$defs/non_negative_integer" },
        "warning_checks": { "$ref": "#/$defs/non_negative_integer" },
        "blocking_failures": { "$ref": "#/$defs/non_negative_integer" },
        "preflight_check_refs": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "create_empty_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parity_class",
        "shares_preflight_pipeline",
        "shares_parameter_review",
        "shares_rollback_boundary",
        "parity_note_refs"
      ],
      "properties": {
        "parity_class": { "$ref": "#/$defs/create_empty_parity_class" },
        "shares_preflight_pipeline": { "type": "boolean" },
        "shares_parameter_review": { "type": "boolean" },
        "shares_rollback_boundary": { "type": "boolean" },
        "parity_note_refs": { "$ref": "#/$defs/string_array" }
      }
    },
    "write_impact_preview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files_created",
        "files_modified",
        "directories_created",
        "no_writes_before_confirmation",
        "write_impact_preview_ref",
        "rollback_posture"
      ],
      "properties": {
        "files_created": { "$ref": "#/$defs/non_negative_integer" },
        "files_modified": { "$ref": "#/$defs/non_negative_integer" },
        "directories_created": { "$ref": "#/$defs/non_negative_integer" },
        "no_writes_before_confirmation": { "const": true },
        "write_impact_preview_ref": { "$ref": "#/$defs/non_empty_string" },
        "rollback_posture": { "$ref": "#/$defs/rollback_posture_class" }
      }
    },
    "plan_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_id",
        "plan_kind",
        "template_id",
        "plan_revision_semver",
        "manifest_ref",
        "scaffold_run_ref",
        "scope_summary",
        "parameter_review",
        "environment_preflight",
        "create_empty_parity",
        "write_impact_preview",
        "readiness_state",
        "admitted_for_apply",
        "known_blocker_refs",
        "downgrade_triggers",
        "consumer_surfaces"
      ],
      "properties": {
        "plan_id": { "$ref": "#/$defs/non_empty_string" },
        "plan_kind": { "$ref": "#/$defs/plan_kind" },
        "template_id": { "$ref": "#/$defs/nullable_non_empty_string" },
        "plan_revision_semver": { "$ref": "#/$defs/non_empty_string" },
        "manifest_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
        "scaffold_run_ref": { "$ref": "#/$defs/non_empty_string" },
        "scope_summary": { "$ref": "#/$defs/non_empty_string" },
        "parameter_review": { "$ref": "#/$defs/parameter_review" },
        "environment_preflight": { "$ref": "#/$defs/environment_preflight" },
        "create_empty_parity": { "$ref": "#/$defs/create_empty_parity" },
        "write_impact_preview": { "$ref": "#/$defs/write_impact_preview" },
        "readiness_state": { "$ref": "#/$defs/readiness_state" },
        "admitted_for_apply": { "type": "boolean" },
        "known_blocker_refs": { "$ref": "#/$defs/string_array" },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_trigger" },
          "uniqueItems": true
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/consumer_surface" },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "description": "Template-backed plans cite both a template id and a manifest ref.",
          "if": {
            "properties": {
              "plan_kind": {
                "enum": ["template_scaffold", "create_empty_parity_bridge"]
              }
            }
          },
          "then": {
            "properties": {
              "template_id": { "$ref": "#/$defs/non_empty_string" },
              "manifest_ref": { "$ref": "#/$defs/non_empty_string" }
            }
          }
        },
        {
          "description": "Plans admitted for apply must be ready, reviewed, preflighted, and reversible.",
          "if": {
            "properties": {
              "admitted_for_apply": { "const": true }
            }
          },
          "then": {
            "properties": {
              "readiness_state": { "const": "ready_for_apply" },
              "parameter_review": {
                "properties": {
                  "review_class": {
                    "not": {
                      "enum": [
                        "awaiting_required_input",
                        "invalid_parameters_blocked",
                        "review_required"
                      ]
                    }
                  }
                }
              },
              "environment_preflight": {
                "properties": {
                  "preflight_class": {
                    "not": {
                      "enum": [
                        "blocking_prerequisite_missing",
                        "preflight_failed_blocked",
                        "preflight_skipped_review_required"
                      ]
                    }
                  }
                }
              },
              "create_empty_parity": {
                "properties": {
                  "parity_class": {
                    "not": {
                      "enum": [
                        "reduced_parity_review_required",
                        "parity_broken_blocked"
                      ]
                    }
                  }
                }
              },
              "write_impact_preview": {
                "properties": {
                  "rollback_posture": {
                    "not": { "const": "rollback_unavailable_review_required" }
                  }
                }
              }
            }
          }
        },
        {
          "description": "Create-empty plans claiming full parity share the preflight pipeline and rollback boundary.",
          "if": {
            "properties": {
              "plan_kind": {
                "enum": ["create_empty_workspace", "create_empty_parity_bridge"]
              },
              "create_empty_parity": {
                "properties": {
                  "parity_class": { "const": "full_parity_with_template_flow" }
                }
              }
            }
          },
          "then": {
            "properties": {
              "create_empty_parity": {
                "properties": {
                  "shares_preflight_pipeline": { "const": true },
                  "shares_rollback_boundary": { "const": true }
                }
              }
            }
          }
        }
      ]
    },
    "safety_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_writes_before_review",
        "parameters_reviewed_before_apply",
        "environment_preflighted_before_apply",
        "write_impact_previewed_before_apply",
        "rollback_boundary_recorded",
        "create_empty_reaches_preflight_parity",
        "create_empty_reaches_rollback_parity",
        "blocking_preflight_blocks_apply",
        "unresolved_parameters_block_apply",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion",
        "no_credential_or_raw_payload_in_export"
      ],
      "properties": {
        "no_writes_before_review": { "const": true },
        "parameters_reviewed_before_apply": { "const": true },
        "environment_preflighted_before_apply": { "const": true },
        "write_impact_previewed_before_apply": { "const": true },
        "rollback_boundary_recorded": { "const": true },
        "create_empty_reaches_preflight_parity": { "const": true },
        "create_empty_reaches_rollback_parity": { "const": true },
        "blocking_preflight_blocks_apply": { "const": true },
        "unresolved_parameters_block_apply": { "const": true },
        "downgrade_narrows_instead_of_hides": { "const": true },
        "stale_or_underqualified_blocks_promotion": { "const": true },
        "no_credential_or_raw_payload_in_export": { "const": true }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gallery_shows_plan_kind_and_readiness",
        "preflight_shows_environment_checks",
        "parameter_review_shows_resolution_state",
        "run_surface_shows_write_impact_and_rollback",
        "recovery_shows_rollback_boundary",
        "cli_headless_shows_plan_rows",
        "support_export_shows_plan_rows",
        "diagnostics_shows_readiness_state",
        "blocked_plans_labeled_not_hidden"
      ],
      "properties": {
        "gallery_shows_plan_kind_and_readiness": { "const": true },
        "preflight_shows_environment_checks": { "const": true },
        "parameter_review_shows_resolution_state": { "const": true },
        "run_surface_shows_write_impact_and_rollback": { "const": true },
        "recovery_shows_rollback_boundary": { "const": true },
        "cli_headless_shows_plan_rows": { "const": true },
        "support_export_shows_plan_rows": { "const": true },
        "diagnostics_shows_readiness_state": { "const": true },
        "blocked_plans_labeled_not_hidden": { "const": true }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": { "type": "boolean" }
      }
    }
  }
}
