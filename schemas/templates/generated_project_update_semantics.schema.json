{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/templates/generated_project_update_semantics.schema.json",
  "title": "Aureline generated-project update semantics contract",
  "description": "Boundary schema for one generated_project_update_semantics_record as frozen in docs/templates/template_registry_and_scaffold_contract.md. Every inspect, template reapply, template update, template rebase, relink, unlink, or open-without-starter evaluation for a generated project MUST make drift detection, local divergence, lineage state, update/rebase state, reopen preflight, overwrite guard, migration-note status, preview diff, validation status, health/known issue refs, freshness explanation, recovery choices, bypass paths, and no-silent-overwrite posture inspectable before any write. Raw file bodies, raw diffs, raw paths, raw repository URLs, raw hook bodies, raw secrets, raw logs, and raw user-authored content never cross this boundary; records carry opaque refs, closed vocabulary, and short reviewable summaries only. Adding a new update operation, drift detection, local divergence, overwrite guard, migration note, validation status, or recovery choice value is additive-minor and requires a schema-version bump plus fixtures; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "$ref": "#/$defs/generated_project_update_semantics_record",
  "$defs": {
    "generated_project_update_semantics_schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for logs, support bundles, update records, and review packets. Raw paths, URLs, payloads, secrets, file bodies, diffs, and user content never appear here."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "generated_project_update_operation_class": {
      "type": "string",
      "enum": [
        "inspect_only",
        "template_reapply",
        "template_update",
        "template_rebase",
        "relink_to_template_revision",
        "unlink_from_template",
        "open_without_starter"
      ]
    },
    "template_drift_detection_class": {
      "type": "string",
      "enum": [
        "in_sync_no_drift",
        "template_revision_advanced",
        "template_revision_archived",
        "local_divergence_detected",
        "local_divergence_and_template_advanced",
        "lineage_unknown",
        "drift_detection_unavailable"
      ]
    },
    "local_divergence_class": {
      "type": "string",
      "enum": [
        "no_local_divergence",
        "comments_or_formatting_only",
        "safe_user_owned_files_only",
        "generated_files_modified",
        "conflicting_generated_and_user_files",
        "untracked_local_files_in_generated_scope",
        "divergence_unknown_review_required"
      ]
    },
    "overwrite_guard_class": {
      "type": "string",
      "enum": [
        "no_overwrite_needed",
        "overwrite_forbidden_without_preview",
        "overwrite_requires_three_way_review",
        "overwrite_requires_user_selected_files",
        "overwrite_blocked_policy_or_trust",
        "overwrite_blocked_lineage_unknown"
      ]
    },
    "migration_note_class": {
      "type": "string",
      "enum": [
        "migration_note_not_required",
        "migration_note_available_required_for_review",
        "migration_note_missing_blocks_breaking_update",
        "migration_note_not_applicable_unlinked"
      ]
    },
    "update_validation_status_class": {
      "type": "string",
      "enum": [
        "validation_not_run",
        "validation_passed_current",
        "validation_warning_non_blocking",
        "validation_failed_blocks_apply",
        "validation_unavailable_stale"
      ]
    },
    "update_recovery_choice_class": {
      "type": "string",
      "enum": [
        "keep_local_project",
        "open_without_starter",
        "preview_reapply",
        "preview_three_way_update",
        "export_local_patch",
        "unlink_from_template",
        "rollback_to_last_scaffold_checkpoint",
        "open_template_migration_note",
        "report_template_issue"
      ]
    },
    "generated_project_lineage_state_class": {
      "type": "string",
      "enum": [
        "linked_to_template_revision",
        "linked_to_template_revision_with_local_overrides",
        "unlinked_user_disclaimed_link",
        "unlinked_template_revision_archived",
        "drifted_from_template_revision_user_review_required",
        "rebased_to_newer_template_revision",
        "forked_to_local_template_revision",
        "lineage_unknown_imported_without_lineage_packet",
        "ai_tool_proposed_relink_pending_review",
        "lineage_state_class_unknown_requires_review"
      ]
    },
    "generated_project_update_or_rebase_state_class": {
      "type": "string",
      "enum": [
        "in_sync_with_bound_template_revision",
        "update_available_minor_no_breaking_change",
        "update_available_major_breaking_change_review_required",
        "rebase_required_breaking_change_pending_user_review",
        "rebase_blocked_pending_user_admit",
        "rebase_blocked_pending_policy_review",
        "rebase_blocked_pending_workspace_trust",
        "no_update_path_template_revision_archived",
        "no_update_path_unlinked_or_lineage_unknown",
        "update_state_class_unknown_requires_review"
      ]
    },
    "template_reopen_preflight_class": {
      "type": "string",
      "enum": [
        "reopen_preflight_in_sync_admissible",
        "reopen_preflight_template_revision_unchanged_admissible",
        "reopen_preflight_template_revision_advanced_update_available",
        "reopen_preflight_template_revision_advanced_breaking_rebase_required",
        "reopen_preflight_template_revision_archived_no_update_path",
        "reopen_preflight_template_revision_unverifiable_user_review_required",
        "reopen_preflight_lineage_unknown_imported_without_lineage_packet"
      ]
    },
    "bypass_path_id": {
      "type": "string",
      "enum": [
        "bypass.open_folder_without_starter",
        "bypass.open_workspace_without_starter",
        "bypass.clone_repository_without_starter",
        "bypass.create_empty_workspace",
        "bypass.open_prebuild_minimal",
        "bypass.set_up_later",
        "bypass.continue_without_starter"
      ]
    },
    "generated_project_update_semantics_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "generated_project_update_semantics_schema_version",
        "update_semantics_id",
        "generated_project_lineage_ref",
        "generated_project_lineage_state_class",
        "current_template_revision_ref",
        "target_template_revision_ref",
        "operation_class",
        "template_drift_detection_class",
        "local_divergence_class",
        "generated_project_update_or_rebase_state_class",
        "template_reopen_preflight_class",
        "overwrite_guard_class",
        "migration_note_class",
        "migration_note_ref",
        "preview_diff_ref",
        "validation_status_class",
        "health_check_refs",
        "known_issue_refs",
        "freshness_explanation_ref",
        "no_silent_overwrite",
        "recovery_choice_classes",
        "post_create_handoff_ref",
        "bypass_path_ids",
        "admitted_for_apply",
        "minted_at"
      ],
      "properties": {
        "record_kind": {
          "const": "generated_project_update_semantics_record"
        },
        "generated_project_update_semantics_schema_version": {
          "$ref": "#/$defs/generated_project_update_semantics_schema_version"
        },
        "update_semantics_id": { "$ref": "#/$defs/opaque_id" },
        "generated_project_lineage_ref": { "$ref": "#/$defs/opaque_id" },
        "generated_project_lineage_state_class": {
          "$ref": "#/$defs/generated_project_lineage_state_class"
        },
        "current_template_revision_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        },
        "target_template_revision_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        },
        "operation_class": {
          "$ref": "#/$defs/generated_project_update_operation_class"
        },
        "template_drift_detection_class": {
          "$ref": "#/$defs/template_drift_detection_class"
        },
        "local_divergence_class": {
          "$ref": "#/$defs/local_divergence_class"
        },
        "generated_project_update_or_rebase_state_class": {
          "$ref": "#/$defs/generated_project_update_or_rebase_state_class"
        },
        "template_reopen_preflight_class": {
          "$ref": "#/$defs/template_reopen_preflight_class"
        },
        "overwrite_guard_class": { "$ref": "#/$defs/overwrite_guard_class" },
        "migration_note_class": { "$ref": "#/$defs/migration_note_class" },
        "migration_note_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "preview_diff_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "validation_status_class": {
          "$ref": "#/$defs/update_validation_status_class"
        },
        "health_check_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "known_issue_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "freshness_explanation_ref": { "$ref": "#/$defs/opaque_id" },
        "no_silent_overwrite": { "const": true },
        "recovery_choice_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/update_recovery_choice_class" },
          "uniqueItems": true
        },
        "post_create_handoff_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "bypass_path_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bypass_path_id" },
          "uniqueItems": true
        },
        "admitted_for_apply": { "type": "boolean" },
        "summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        },
        "notes_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Local divergence requires preview review and a non-trivial overwrite guard.",
          "if": {
            "properties": {
              "local_divergence_class": {
                "not": { "const": "no_local_divergence" }
              }
            }
          },
          "then": {
            "required": ["preview_diff_ref"],
            "properties": {
              "preview_diff_ref": { "$ref": "#/$defs/opaque_id" },
              "overwrite_guard_class": {
                "enum": [
                  "overwrite_forbidden_without_preview",
                  "overwrite_requires_three_way_review",
                  "overwrite_requires_user_selected_files",
                  "overwrite_blocked_policy_or_trust",
                  "overwrite_blocked_lineage_unknown"
                ]
              },
              "no_silent_overwrite": { "const": true }
            }
          }
        },
        {
          "description": "Mutating operations with drift require a preview diff before apply.",
          "if": {
            "properties": {
              "operation_class": {
                "enum": [
                  "template_reapply",
                  "template_update",
                  "template_rebase",
                  "relink_to_template_revision"
                ]
              },
              "template_drift_detection_class": {
                "not": { "const": "in_sync_no_drift" }
              }
            }
          },
          "then": {
            "required": ["preview_diff_ref"],
            "properties": {
              "preview_diff_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        },
        {
          "description": "Breaking update movement without a migration note blocks apply.",
          "if": {
            "properties": {
              "migration_note_class": {
                "const": "migration_note_missing_blocks_breaking_update"
              }
            }
          },
          "then": {
            "properties": {
              "admitted_for_apply": { "const": false }
            }
          }
        },
        {
          "description": "Migration notes required for review cite a migration note ref.",
          "if": {
            "properties": {
              "migration_note_class": {
                "const": "migration_note_available_required_for_review"
              }
            }
          },
          "then": {
            "required": ["migration_note_ref"],
            "properties": {
              "migration_note_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        },
        {
          "description": "Blocked overwrite guards cannot be admitted for apply.",
          "if": {
            "properties": {
              "overwrite_guard_class": {
                "enum": [
                  "overwrite_blocked_policy_or_trust",
                  "overwrite_blocked_lineage_unknown"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "admitted_for_apply": { "const": false }
            }
          }
        },
        {
          "description": "Lineage unknown update records use the lineage-unknown reopen preflight and no update path state.",
          "if": {
            "properties": {
              "template_drift_detection_class": { "const": "lineage_unknown" }
            }
          },
          "then": {
            "properties": {
              "generated_project_update_or_rebase_state_class": {
                "const": "no_update_path_unlinked_or_lineage_unknown"
              },
              "template_reopen_preflight_class": {
                "const": "reopen_preflight_lineage_unknown_imported_without_lineage_packet"
              }
            }
          }
        },
        {
          "description": "Open-without-starter and inspect-only evaluations do not apply template writes.",
          "if": {
            "properties": {
              "operation_class": {
                "enum": ["inspect_only", "open_without_starter"]
              }
            }
          },
          "then": {
            "properties": {
              "admitted_for_apply": { "const": false }
            }
          }
        },
        {
          "description": "Failed or stale validation blocks apply until reviewed.",
          "if": {
            "properties": {
              "validation_status_class": {
                "enum": [
                  "validation_failed_blocks_apply",
                  "validation_unavailable_stale"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "admitted_for_apply": { "const": false }
            }
          }
        }
      ]
    }
  }
}
