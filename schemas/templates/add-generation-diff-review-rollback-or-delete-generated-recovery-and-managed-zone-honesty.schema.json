{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/templates/add-generation-diff-review-rollback-or-delete-generated-recovery-and-managed-zone-honesty.schema.json",
  "title": "Aureline generation diff review, rollback/delete-generated recovery, and managed-zone honesty rows",
  "description": "Export-safe packet for the generation review and recovery lane. Each row binds one generated project tree to its managed-zone classification (authored/generated/runtime-only), its generation-diff review state and overwrite guard, its rollback or delete-generated recovery action, its support class, and its admission decision, so the diff-review, run, recovery, diagnostics, and support surfaces project the same truth about what is authored, what is generated, what may be overwritten, and how the tree can be recovered, instead of overwriting silently or deleting authored work. Raw file bodies, raw diffs, raw paths, repository URLs, hook bodies, secrets, and user-authored content never cross this boundary; rows carry opaque refs, closed-vocabulary class tokens, and short reviewable summaries only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "packet_label",
    "rows",
    "review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "generation_diff_review_and_managed_zone_recovery_rows"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "packet_label": { "$ref": "#/$defs/non_empty_string" },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/recovery_row" }
    },
    "review": { "$ref": "#/$defs/review" },
    "consumer_projection": { "$ref": "#/$defs/consumer_projection" },
    "proof_freshness": { "$ref": "#/$defs/proof_freshness" },
    "source_contract_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "redaction_class_token": { "$ref": "#/$defs/non_empty_string" },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_non_empty_string": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/non_empty_string" }
      ]
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "managed_zone_class": {
      "type": "string",
      "enum": [
        "authored_only",
        "generated_only",
        "generated_then_user_edited",
        "runtime_only",
        "mixed_authored_and_generated",
        "zone_unknown_review_required"
      ]
    },
    "diff_review_class": {
      "type": "string",
      "enum": [
        "preview_ready",
        "preview_required_before_write",
        "no_diff_no_op",
        "diff_unavailable_review_required"
      ]
    },
    "overwrite_guard_class": {
      "type": "string",
      "enum": [
        "no_overwrite_needed",
        "overwrite_forbidden_without_preview",
        "overwrite_requires_three_way_review",
        "overwrite_requires_user_selected_files",
        "overwrite_blocked_policy_or_trust",
        "overwrite_blocked_lineage_unknown"
      ]
    },
    "recovery_action_class": {
      "type": "string",
      "enum": [
        "rollback_to_checkpoint",
        "delete_generated_only",
        "restore_authored_and_delete_generated",
        "quarantine_generated",
        "no_recovery_available",
        "recovery_blocked_lineage_unknown"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "officially_supported",
        "community_supported",
        "experimental",
        "bridge_behavior",
        "heuristic_mapping",
        "unsupported",
        "support_unknown"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "lineage_unknown",
        "checkpoint_unavailable",
        "diff_preview_unavailable",
        "authored_protection_unverified",
        "managed_zone_unknown",
        "bridge_behavior_disclosed",
        "known_issue_blocking",
        "validation_failed",
        "upstream_dependency_narrowed"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "diff_review",
        "run_surface",
        "recovery",
        "gallery",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "recovery_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "generated_root_ref",
        "scaffold_run_ref",
        "lineage_ref",
        "template_id",
        "template_revision_semver",
        "scope_summary",
        "managed_zone_class",
        "diff_review_class",
        "diff_preview_ref",
        "overwrite_guard_class",
        "recovery_action_class",
        "checkpoint_ref",
        "authored_content_protected",
        "support_class",
        "known_issue_refs",
        "admitted_for_recovery",
        "downgrade_triggers",
        "consumer_surfaces"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "generated_root_ref": { "$ref": "#/$defs/non_empty_string" },
        "scaffold_run_ref": { "$ref": "#/$defs/non_empty_string" },
        "lineage_ref": { "$ref": "#/$defs/non_empty_string" },
        "template_id": { "$ref": "#/$defs/non_empty_string" },
        "template_revision_semver": { "$ref": "#/$defs/non_empty_string" },
        "scope_summary": { "$ref": "#/$defs/non_empty_string" },
        "managed_zone_class": { "$ref": "#/$defs/managed_zone_class" },
        "diff_review_class": { "$ref": "#/$defs/diff_review_class" },
        "diff_preview_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
        "overwrite_guard_class": { "$ref": "#/$defs/overwrite_guard_class" },
        "recovery_action_class": { "$ref": "#/$defs/recovery_action_class" },
        "checkpoint_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
        "authored_content_protected": { "type": "boolean" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "known_issue_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "admitted_for_recovery": { "type": "boolean" },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_trigger" },
          "uniqueItems": true
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/consumer_surface" },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "description": "Rollback rows cite a checkpoint ref.",
          "if": {
            "properties": {
              "recovery_action_class": { "const": "rollback_to_checkpoint" }
            }
          },
          "then": {
            "properties": {
              "checkpoint_ref": { "$ref": "#/$defs/non_empty_string" }
            }
          }
        },
        {
          "description": "Preview-ready rows cite a diff-preview ref.",
          "if": {
            "properties": {
              "diff_review_class": { "const": "preview_ready" }
            }
          },
          "then": {
            "properties": {
              "diff_preview_ref": { "$ref": "#/$defs/non_empty_string" }
            }
          }
        },
        {
          "description": "Destructive recovery actions must protect authored content.",
          "if": {
            "properties": {
              "recovery_action_class": {
                "enum": [
                  "rollback_to_checkpoint",
                  "delete_generated_only",
                  "restore_authored_and_delete_generated"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "authored_content_protected": { "const": true }
            }
          }
        },
        {
          "description": "Delete-generated cannot be scoped over an authored-only zone.",
          "if": {
            "properties": {
              "recovery_action_class": { "const": "delete_generated_only" }
            }
          },
          "then": {
            "properties": {
              "managed_zone_class": {
                "not": { "const": "authored_only" }
              }
            }
          }
        },
        {
          "description": "Bridge and heuristic rows disclose a known issue and a disclosure trigger.",
          "if": {
            "properties": {
              "support_class": {
                "enum": ["bridge_behavior", "heuristic_mapping"]
              }
            }
          },
          "then": {
            "properties": {
              "known_issue_refs": {
                "type": "array",
                "minItems": 1
              },
              "downgrade_triggers": {
                "type": "array",
                "contains": { "const": "bridge_behavior_disclosed" }
              }
            }
          }
        },
        {
          "description": "Blocked rows cannot be admitted for recovery.",
          "if": {
            "anyOf": [
              {
                "properties": {
                  "diff_review_class": { "const": "diff_unavailable_review_required" }
                }
              },
              {
                "properties": {
                  "overwrite_guard_class": {
                    "enum": ["overwrite_blocked_policy_or_trust", "overwrite_blocked_lineage_unknown"]
                  }
                }
              },
              {
                "properties": {
                  "recovery_action_class": {
                    "enum": ["no_recovery_available", "recovery_blocked_lineage_unknown"]
                  }
                }
              },
              {
                "properties": {
                  "managed_zone_class": { "const": "zone_unknown_review_required" }
                }
              }
            ]
          },
          "then": {
            "properties": {
              "admitted_for_recovery": { "const": false }
            }
          }
        }
      ]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diff_preview_required_before_write",
        "no_silent_overwrite",
        "authored_content_never_deleted_by_recovery",
        "generated_zone_labeled_distinct_from_authored",
        "runtime_only_zone_labeled",
        "rollback_boundary_inspectable",
        "delete_generated_scoped_to_generated_zone",
        "managed_zone_not_presented_as_first_party_without_support_class",
        "known_issues_disclosed_before_recovery",
        "no_raw_file_bodies_or_diffs_in_export",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "diff_preview_required_before_write": { "const": true },
        "no_silent_overwrite": { "const": true },
        "authored_content_never_deleted_by_recovery": { "const": true },
        "generated_zone_labeled_distinct_from_authored": { "const": true },
        "runtime_only_zone_labeled": { "const": true },
        "rollback_boundary_inspectable": { "const": true },
        "delete_generated_scoped_to_generated_zone": { "const": true },
        "managed_zone_not_presented_as_first_party_without_support_class": { "const": true },
        "known_issues_disclosed_before_recovery": { "const": true },
        "no_raw_file_bodies_or_diffs_in_export": { "const": true },
        "downgrade_narrows_instead_of_hides": { "const": true },
        "stale_or_underqualified_blocks_promotion": { "const": true }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diff_review_shows_managed_zone_labels",
        "diff_review_shows_overwrite_guard",
        "recovery_shows_rollback_and_delete_scope",
        "recovery_shows_authored_protection",
        "run_surface_shows_diff_preview_state",
        "cli_headless_shows_recovery_rows",
        "support_export_shows_recovery_rows",
        "diagnostics_shows_managed_zone_state",
        "blocked_rows_labeled_not_hidden"
      ],
      "properties": {
        "diff_review_shows_managed_zone_labels": { "const": true },
        "diff_review_shows_overwrite_guard": { "const": true },
        "recovery_shows_rollback_and_delete_scope": { "const": true },
        "recovery_shows_authored_protection": { "const": true },
        "run_surface_shows_diff_preview_state": { "const": true },
        "cli_headless_shows_recovery_rows": { "const": true },
        "support_export_shows_recovery_rows": { "const": true },
        "diagnostics_shows_managed_zone_state": { "const": true },
        "blocked_rows_labeled_not_hidden": { "const": true }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": { "type": "boolean" }
      }
    }
  }
}
