{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/templates/generated_project_lineage_alpha.schema.json",
  "title": "Aureline generated project lineage alpha contract",
  "description": "Alpha boundary schema for the plain-file lineage record carried by a project created from a template. The record preserves manifest identity, template version, generated root identity, scaffold run reference, created and modified artifacts, checkpoint reference, divergence state, manual-edit detection, update/rebase compatibility, last health report, source/mirror posture, and the on-disk lineage metadata file reference. A hidden Aureline-only project database is never authoritative.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "generated_project_lineage_alpha_schema_version",
    "lineage_id",
    "manifest_ref",
    "template_id",
    "template_version",
    "generated_root_ref",
    "scaffold_run_ref",
    "created_artifact_refs",
    "modified_artifact_refs",
    "checkpoint_ref",
    "divergence_state",
    "manual_edit_detection",
    "update_rebase_compatibility",
    "last_health_report_ref",
    "lineage_metadata_path_ref",
    "source_class",
    "mirror_or_offline_source_class",
    "plain_file_authority",
    "no_hidden_project_database",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "generated_project_lineage_alpha_record" },
    "generated_project_lineage_alpha_schema_version": { "type": "integer", "const": 1 },
    "lineage_id": { "$ref": "#/$defs/opaque_id" },
    "manifest_ref": { "$ref": "#/$defs/opaque_id" },
    "template_id": { "$ref": "#/$defs/opaque_id" },
    "template_version": { "$ref": "#/$defs/non_empty_string" },
    "generated_root_ref": { "$ref": "#/$defs/opaque_id" },
    "scaffold_run_ref": { "$ref": "#/$defs/opaque_id" },
    "created_artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/opaque_id" },
      "uniqueItems": true
    },
    "modified_artifact_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_id" },
      "uniqueItems": true
    },
    "checkpoint_ref": { "$ref": "#/$defs/opaque_id" },
    "divergence_state": { "$ref": "#/$defs/divergence_state" },
    "manual_edit_detection": { "$ref": "#/$defs/manual_edit_detection" },
    "update_rebase_compatibility": { "$ref": "#/$defs/update_rebase_compatibility" },
    "last_health_report_ref": { "$ref": "#/$defs/opaque_id" },
    "lineage_metadata_path_ref": { "$ref": "#/$defs/opaque_id" },
    "source_class": { "$ref": "#/$defs/source_class" },
    "mirror_or_offline_source_class": { "$ref": "#/$defs/mirror_or_offline_source_class" },
    "plain_file_authority": { "const": true },
    "no_hidden_project_database": { "const": true },
    "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe for support export."
    },
    "non_empty_string": { "type": "string", "minLength": 1 },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "monotonic_timestamp": { "type": "string", "format": "date-time" },
    "source_class": {
      "type": "string",
      "enum": ["first_party", "team_managed", "community", "local_only", "mirror_cached", "imported", "uncertified"]
    },
    "mirror_or_offline_source_class": {
      "type": "string",
      "enum": ["public_origin", "approved_mirror", "signed_offline_bundle", "repo_local", "ad_hoc_local"]
    },
    "divergence_state": {
      "type": "string",
      "enum": [
        "in_sync",
        "local_overrides",
        "manual_edits_detected",
        "template_revision_advanced",
        "lineage_unknown",
        "unlinked"
      ]
    },
    "manual_edit_detection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "method", "last_checked_at", "summary"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["none_detected", "detected_in_generated_scope", "not_checked", "unknown_imported"]
        },
        "method": {
          "type": "string",
          "enum": ["content_digest_manifest", "vcs_status", "lineage_packet_only", "not_checked"]
        },
        "last_checked_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "update_rebase_compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "next_review_ref", "summary"],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "compatible_current_revision",
            "compatible_update_available",
            "rebase_review_required",
            "blocked_lineage_unknown",
            "no_update_path"
          ]
        },
        "next_review_ref": { "type": ["string", "null"], "minLength": 1 },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    }
  }
}
