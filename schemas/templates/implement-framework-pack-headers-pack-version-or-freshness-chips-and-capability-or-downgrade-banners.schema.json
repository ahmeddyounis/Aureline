{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/templates/implement-framework-pack-headers-pack-version-or-freshness-chips-and-capability-or-downgrade-banners.schema.json",
  "title": "Aureline framework-pack headers, pack version/freshness chips, and capability/downgrade banners",
  "description": "Export-safe packet for the framework-pack presentation lane. Each row binds one framework pack to its header provenance, its pinned pack version and freshness chip, its capability banner, its support class, and its downgrade banner, so the gallery, pack header, run, diff-review, diagnostics, and support surfaces project the same truth about where a pack came from, how fresh it is, what it can actually generate, and on what terms it may be offered, instead of presenting heuristic or bridge behavior as exact first-party truth. Raw pack bodies, raw manifests, repository URLs, hostnames, secrets, and user-authored content never cross this boundary; rows carry opaque refs, closed-vocabulary class tokens, short reviewable summaries, and export-safe chip labels only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "packet_label",
    "rows",
    "review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "framework_pack_header_and_capability_banner_rows"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "packet_label": { "$ref": "#/$defs/non_empty_string" },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/pack_row" }
    },
    "review": { "$ref": "#/$defs/review" },
    "consumer_projection": { "$ref": "#/$defs/consumer_projection" },
    "proof_freshness": { "$ref": "#/$defs/proof_freshness" },
    "source_contract_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "redaction_class_token": { "$ref": "#/$defs/non_empty_string" },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "provenance_class": {
      "type": "string",
      "enum": [
        "first_party",
        "partner_certified",
        "community",
        "mirror",
        "bridged_from_other_framework",
        "provenance_unknown"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "fresh",
        "update_available",
        "aging",
        "stale",
        "freshness_unknown"
      ]
    },
    "capability_class": {
      "type": "string",
      "enum": [
        "full_capability",
        "partial_capability",
        "bridged_capability",
        "heuristic_capability",
        "capability_degraded",
        "capability_unknown"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "officially_supported",
        "community_supported",
        "experimental",
        "bridge_behavior",
        "heuristic_mapping",
        "unsupported",
        "support_unknown"
      ]
    },
    "downgrade_banner_class": {
      "type": "string",
      "enum": [
        "no_banner",
        "freshness_banner",
        "capability_banner",
        "support_class_banner",
        "policy_block_banner",
        "provenance_unknown_banner"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "provenance_unknown",
        "pack_version_yanked",
        "freshness_stale",
        "capability_degraded",
        "bridge_behavior_disclosed",
        "heuristic_mapping_disclosed",
        "known_issue_blocking",
        "validation_failed",
        "upstream_dependency_narrowed"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "gallery",
        "pack_header",
        "run_surface",
        "diff_review",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "pack_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "pack_id",
        "pack_label",
        "framework_id",
        "framework_label",
        "pack_version_semver",
        "header_summary",
        "provenance_class",
        "freshness_class",
        "freshness_chip_label",
        "last_verified",
        "capability_class",
        "capability_summary",
        "support_class",
        "downgrade_banner_class",
        "known_issue_refs",
        "admitted_for_offer",
        "downgrade_triggers",
        "consumer_surfaces"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "pack_id": { "$ref": "#/$defs/non_empty_string" },
        "pack_label": { "$ref": "#/$defs/non_empty_string" },
        "framework_id": { "$ref": "#/$defs/non_empty_string" },
        "framework_label": { "$ref": "#/$defs/non_empty_string" },
        "pack_version_semver": { "$ref": "#/$defs/non_empty_string" },
        "header_summary": { "$ref": "#/$defs/non_empty_string" },
        "provenance_class": { "$ref": "#/$defs/provenance_class" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "freshness_chip_label": { "$ref": "#/$defs/non_empty_string" },
        "last_verified": {
          "type": "string",
          "format": "date-time"
        },
        "capability_class": { "$ref": "#/$defs/capability_class" },
        "capability_summary": { "$ref": "#/$defs/non_empty_string" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "downgrade_banner_class": { "$ref": "#/$defs/downgrade_banner_class" },
        "known_issue_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "admitted_for_offer": { "type": "boolean" },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_trigger" },
          "uniqueItems": true
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/consumer_surface" },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "description": "A non-full-capability pack must show a banner.",
          "if": {
            "properties": {
              "capability_class": {
                "not": { "const": "full_capability" }
              }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "Bridge and heuristic packs disclose a known issue and a present banner.",
          "if": {
            "properties": {
              "support_class": {
                "enum": ["bridge_behavior", "heuristic_mapping"]
              }
            }
          },
          "then": {
            "properties": {
              "known_issue_refs": {
                "type": "array",
                "minItems": 1
              },
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "Bridge packs carry the bridge-behavior disclosure trigger.",
          "if": {
            "properties": {
              "support_class": { "const": "bridge_behavior" }
            }
          },
          "then": {
            "properties": {
              "downgrade_triggers": {
                "type": "array",
                "contains": { "const": "bridge_behavior_disclosed" }
              }
            }
          }
        },
        {
          "description": "Heuristic packs carry the heuristic-mapping disclosure trigger.",
          "if": {
            "properties": {
              "support_class": { "const": "heuristic_mapping" }
            }
          },
          "then": {
            "properties": {
              "downgrade_triggers": {
                "type": "array",
                "contains": { "const": "heuristic_mapping_disclosed" }
              }
            }
          }
        },
        {
          "description": "A provenance-unknown pack carries the provenance-unknown banner.",
          "if": {
            "properties": {
              "provenance_class": { "const": "provenance_unknown" }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": { "const": "provenance_unknown_banner" }
            }
          }
        },
        {
          "description": "A stale or unknown-freshness pack shows a downgrade banner.",
          "if": {
            "properties": {
              "freshness_class": {
                "enum": ["stale", "freshness_unknown"]
              }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "Blocked packs cannot be admitted to be offered.",
          "if": {
            "anyOf": [
              {
                "properties": {
                  "freshness_class": {
                    "enum": ["stale", "freshness_unknown"]
                  }
                }
              },
              {
                "properties": {
                  "capability_class": {
                    "enum": ["capability_degraded", "capability_unknown"]
                  }
                }
              },
              {
                "properties": {
                  "provenance_class": { "const": "provenance_unknown" }
                }
              },
              {
                "properties": {
                  "downgrade_banner_class": {
                    "enum": ["policy_block_banner", "provenance_unknown_banner"]
                  }
                }
              }
            ]
          },
          "then": {
            "properties": {
              "admitted_for_offer": { "const": false }
            }
          }
        }
      ]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pack_header_shows_provenance_and_version",
        "freshness_chip_shown_for_every_pack",
        "capability_banner_shown_when_not_full",
        "downgrade_banner_shown_when_narrowed",
        "bridge_or_heuristic_never_presented_as_first_party",
        "stale_or_yanked_pack_not_offered_as_current",
        "provenance_unknown_pack_labeled_not_hidden",
        "support_class_visible_before_offer",
        "known_issues_disclosed_before_offer",
        "no_raw_pack_bodies_or_urls_in_export",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "pack_header_shows_provenance_and_version": { "const": true },
        "freshness_chip_shown_for_every_pack": { "const": true },
        "capability_banner_shown_when_not_full": { "const": true },
        "downgrade_banner_shown_when_narrowed": { "const": true },
        "bridge_or_heuristic_never_presented_as_first_party": { "const": true },
        "stale_or_yanked_pack_not_offered_as_current": { "const": true },
        "provenance_unknown_pack_labeled_not_hidden": { "const": true },
        "support_class_visible_before_offer": { "const": true },
        "known_issues_disclosed_before_offer": { "const": true },
        "no_raw_pack_bodies_or_urls_in_export": { "const": true },
        "downgrade_narrows_instead_of_hides": { "const": true },
        "stale_or_underqualified_blocks_promotion": { "const": true }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gallery_shows_pack_header",
        "gallery_shows_freshness_chip",
        "run_surface_shows_capability_banner",
        "diff_review_shows_downgrade_banner",
        "cli_headless_shows_pack_rows",
        "support_export_shows_pack_rows",
        "diagnostics_shows_freshness_and_capability_state",
        "blocked_rows_labeled_not_hidden"
      ],
      "properties": {
        "gallery_shows_pack_header": { "const": true },
        "gallery_shows_freshness_chip": { "const": true },
        "run_surface_shows_capability_banner": { "const": true },
        "diff_review_shows_downgrade_banner": { "const": true },
        "cli_headless_shows_pack_rows": { "const": true },
        "support_export_shows_pack_rows": { "const": true },
        "diagnostics_shows_freshness_and_capability_state": { "const": true },
        "blocked_rows_labeled_not_hidden": { "const": true }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": { "type": "boolean" }
      }
    }
  }
}
