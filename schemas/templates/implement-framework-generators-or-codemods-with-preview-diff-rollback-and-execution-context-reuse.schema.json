{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/templates/implement-framework-generators-or-codemods-with-preview-diff-rollback-and-execution-context-reuse.schema.json",
  "title": "Aureline framework generators and codemods with preview, diff, rollback, and execution-context reuse",
  "description": "Export-safe packet for the framework generator and codemod run lane. Each row binds one generator or codemod run to its pinned generator version, whether a preview was produced, whether the change diff was reviewed, whether the run can be rolled back, whether a warm execution context was reused, its run-record freshness, its support class, and its downgrade banner, so the generator gallery, preview pane, diff-review, run, rollback/recovery, diagnostics, and support surfaces project the same truth about whether a generator may be run and on what terms, instead of letting starter convenience outrun provenance, preview, or rollback. Raw source bodies, raw diffs, generated file contents, repository URLs, hostnames, secrets, and user-authored content never cross this boundary; rows carry opaque refs, closed-vocabulary class tokens, short reviewable summaries, structural locators, and export-safe chip labels only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "packet_label",
    "rows",
    "review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "framework_generator_run_preview_diff_rollback_rows"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "packet_label": { "$ref": "#/$defs/non_empty_string" },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/generator_run_row" }
    },
    "review": { "$ref": "#/$defs/review" },
    "consumer_projection": { "$ref": "#/$defs/consumer_projection" },
    "proof_freshness": { "$ref": "#/$defs/proof_freshness" },
    "source_contract_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "redaction_class_token": { "$ref": "#/$defs/non_empty_string" },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "generator_kind": {
      "type": "string",
      "enum": [
        "scaffold_generator",
        "codemod",
        "migration_codemod",
        "refactor_generator",
        "config_generator"
      ]
    },
    "preview_class": {
      "type": "string",
      "enum": ["preview_available", "preview_partial", "preview_unavailable"]
    },
    "diff_review_class": {
      "type": "string",
      "enum": ["diff_reviewed", "diff_pending", "diff_unavailable"]
    },
    "rollback_class": {
      "type": "string",
      "enum": [
        "rollback_available",
        "rollback_partial",
        "rollback_unavailable",
        "rolled_back"
      ]
    },
    "context_reuse_class": {
      "type": "string",
      "enum": [
        "context_reused",
        "context_fresh",
        "context_reuse_unavailable",
        "context_reuse_unknown"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "fresh",
        "rescan_available",
        "aging",
        "stale",
        "freshness_unknown"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "exactly_modeled",
        "experimental",
        "bridge_behavior",
        "heuristic_mapping",
        "unsupported",
        "support_unknown"
      ]
    },
    "downgrade_banner_class": {
      "type": "string",
      "enum": [
        "no_banner",
        "freshness_banner",
        "preview_unavailable_banner",
        "diff_unavailable_banner",
        "rollback_unavailable_banner",
        "support_class_banner",
        "context_reuse_banner",
        "policy_block_banner"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "preview_unavailable",
        "diff_unavailable",
        "rollback_unavailable",
        "context_reuse_unavailable",
        "generator_version_unverified",
        "run_record_stale",
        "heuristic_mapping_disclosed",
        "bridge_behavior_disclosed",
        "known_issue_blocking",
        "validation_failed",
        "upstream_dependency_narrowed"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "generator_gallery",
        "preview_pane",
        "diff_review",
        "run_surface",
        "rollback_recovery",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "generator_run_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "generator_kind",
        "generator_id",
        "generator_label",
        "generator_locator",
        "generator_version",
        "app_id",
        "framework_pack_ref",
        "target_summary",
        "preview_class",
        "preview_summary",
        "diff_review_class",
        "diff_summary",
        "diff_stat_label",
        "rollback_class",
        "rollback_summary",
        "rollback_handle_refs",
        "context_reuse_class",
        "context_reuse_summary",
        "execution_context_refs",
        "freshness_class",
        "freshness_chip_label",
        "last_run",
        "support_class",
        "downgrade_banner_class",
        "known_issue_refs",
        "admitted_for_display",
        "downgrade_triggers",
        "consumer_surfaces"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "generator_kind": { "$ref": "#/$defs/generator_kind" },
        "generator_id": { "$ref": "#/$defs/non_empty_string" },
        "generator_label": { "$ref": "#/$defs/non_empty_string" },
        "generator_locator": { "$ref": "#/$defs/non_empty_string" },
        "generator_version": { "$ref": "#/$defs/non_empty_string" },
        "app_id": { "$ref": "#/$defs/non_empty_string" },
        "framework_pack_ref": { "$ref": "#/$defs/non_empty_string" },
        "target_summary": { "$ref": "#/$defs/non_empty_string" },
        "preview_class": { "$ref": "#/$defs/preview_class" },
        "preview_summary": { "$ref": "#/$defs/non_empty_string" },
        "diff_review_class": { "$ref": "#/$defs/diff_review_class" },
        "diff_summary": { "$ref": "#/$defs/non_empty_string" },
        "diff_stat_label": { "$ref": "#/$defs/non_empty_string" },
        "rollback_class": { "$ref": "#/$defs/rollback_class" },
        "rollback_summary": { "$ref": "#/$defs/non_empty_string" },
        "rollback_handle_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "context_reuse_class": { "$ref": "#/$defs/context_reuse_class" },
        "context_reuse_summary": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "freshness_chip_label": { "$ref": "#/$defs/non_empty_string" },
        "last_run": {
          "type": "string",
          "format": "date-time"
        },
        "support_class": { "$ref": "#/$defs/support_class" },
        "downgrade_banner_class": { "$ref": "#/$defs/downgrade_banner_class" },
        "known_issue_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "admitted_for_display": { "type": "boolean" },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_trigger" },
          "uniqueItems": true
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/consumer_surface" },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "description": "An unavailable preview raises the preview-unavailable banner.",
          "if": {
            "properties": {
              "preview_class": { "const": "preview_unavailable" }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": { "const": "preview_unavailable_banner" }
            }
          }
        },
        {
          "description": "An unavailable diff shows a downgrade banner.",
          "if": {
            "properties": {
              "diff_review_class": { "const": "diff_unavailable" }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "An unavailable rollback raises the rollback-unavailable banner.",
          "if": {
            "properties": {
              "rollback_class": { "const": "rollback_unavailable" }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": { "const": "rollback_unavailable_banner" }
            }
          }
        },
        {
          "description": "A captured, partial, or rolled-back rollback carries at least one rollback-handle ref.",
          "if": {
            "properties": {
              "rollback_class": {
                "enum": ["rollback_available", "rollback_partial", "rolled_back"]
              }
            }
          },
          "then": {
            "properties": {
              "rollback_handle_refs": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        },
        {
          "description": "A context reuse that could not be honored or determined shows a banner.",
          "if": {
            "properties": {
              "context_reuse_class": {
                "enum": ["context_reuse_unavailable", "context_reuse_unknown"]
              }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "Bridge and heuristic runs disclose a known issue and a present banner.",
          "if": {
            "properties": {
              "support_class": {
                "enum": ["bridge_behavior", "heuristic_mapping"]
              }
            }
          },
          "then": {
            "properties": {
              "known_issue_refs": {
                "type": "array",
                "minItems": 1
              },
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "Bridge runs carry the bridge-behavior disclosure trigger.",
          "if": {
            "properties": {
              "support_class": { "const": "bridge_behavior" }
            }
          },
          "then": {
            "properties": {
              "downgrade_triggers": {
                "type": "array",
                "contains": { "const": "bridge_behavior_disclosed" }
              }
            }
          }
        },
        {
          "description": "Heuristic runs carry the heuristic-mapping disclosure trigger.",
          "if": {
            "properties": {
              "support_class": { "const": "heuristic_mapping" }
            }
          },
          "then": {
            "properties": {
              "downgrade_triggers": {
                "type": "array",
                "contains": { "const": "heuristic_mapping_disclosed" }
              }
            }
          }
        },
        {
          "description": "A stale or unknown-freshness run shows a downgrade banner.",
          "if": {
            "properties": {
              "freshness_class": {
                "enum": ["stale", "freshness_unknown"]
              }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "Blocked runs cannot be admitted for confident display.",
          "if": {
            "anyOf": [
              {
                "properties": {
                  "freshness_class": {
                    "enum": ["stale", "freshness_unknown"]
                  }
                }
              },
              {
                "properties": {
                  "preview_class": { "const": "preview_unavailable" }
                }
              },
              {
                "properties": {
                  "diff_review_class": { "const": "diff_unavailable" }
                }
              },
              {
                "properties": {
                  "rollback_class": { "const": "rollback_unavailable" }
                }
              },
              {
                "properties": {
                  "downgrade_banner_class": {
                    "enum": [
                      "preview_unavailable_banner",
                      "diff_unavailable_banner",
                      "rollback_unavailable_banner",
                      "policy_block_banner"
                    ]
                  }
                }
              }
            ]
          },
          "then": {
            "properties": {
              "admitted_for_display": { "const": false }
            }
          }
        }
      ]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generator_version_disclosed_for_every_run",
        "preview_state_shown_for_every_run",
        "diff_review_state_shown_for_every_run",
        "rollback_state_shown_for_every_run",
        "context_reuse_state_shown_for_every_run",
        "preview_unavailable_blocks_confident_apply",
        "diff_unavailable_blocks_confident_apply",
        "rollback_unavailable_blocks_confident_apply",
        "heuristic_or_bridge_never_presented_as_exact_truth",
        "context_reuse_failure_labeled_not_hidden",
        "stale_run_record_not_presented_as_current",
        "support_class_visible_before_display",
        "known_issues_disclosed_before_display",
        "no_raw_source_bodies_or_urls_in_export",
        "downgrade_narrows_instead_of_hides",
        "stale_or_unrunnable_blocks_promotion"
      ],
      "properties": {
        "generator_version_disclosed_for_every_run": { "const": true },
        "preview_state_shown_for_every_run": { "const": true },
        "diff_review_state_shown_for_every_run": { "const": true },
        "rollback_state_shown_for_every_run": { "const": true },
        "context_reuse_state_shown_for_every_run": { "const": true },
        "preview_unavailable_blocks_confident_apply": { "const": true },
        "diff_unavailable_blocks_confident_apply": { "const": true },
        "rollback_unavailable_blocks_confident_apply": { "const": true },
        "heuristic_or_bridge_never_presented_as_exact_truth": { "const": true },
        "context_reuse_failure_labeled_not_hidden": { "const": true },
        "stale_run_record_not_presented_as_current": { "const": true },
        "support_class_visible_before_display": { "const": true },
        "known_issues_disclosed_before_display": { "const": true },
        "no_raw_source_bodies_or_urls_in_export": { "const": true },
        "downgrade_narrows_instead_of_hides": { "const": true },
        "stale_or_unrunnable_blocks_promotion": { "const": true }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gallery_shows_generator_version",
        "preview_pane_shows_preview_state",
        "diff_review_shows_change_diff",
        "run_surface_shows_rollback_state",
        "run_surface_shows_context_reuse_state",
        "rollback_recovery_shows_rollback_handle",
        "cli_headless_shows_generator_rows",
        "support_export_shows_generator_rows",
        "diagnostics_shows_preview_diff_rollback_state",
        "blocked_runs_labeled_not_hidden"
      ],
      "properties": {
        "gallery_shows_generator_version": { "const": true },
        "preview_pane_shows_preview_state": { "const": true },
        "diff_review_shows_change_diff": { "const": true },
        "run_surface_shows_rollback_state": { "const": true },
        "run_surface_shows_context_reuse_state": { "const": true },
        "rollback_recovery_shows_rollback_handle": { "const": true },
        "cli_headless_shows_generator_rows": { "const": true },
        "support_export_shows_generator_rows": { "const": true },
        "diagnostics_shows_preview_diff_rollback_state": { "const": true },
        "blocked_runs_labeled_not_hidden": { "const": true }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": { "type": "boolean" }
      }
    }
  }
}
