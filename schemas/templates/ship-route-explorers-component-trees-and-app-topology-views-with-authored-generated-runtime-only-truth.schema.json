{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/templates/ship-route-explorers-component-trees-and-app-topology-views-with-authored-generated-runtime-only-truth.schema.json",
  "title": "Aureline route explorers, component trees, and app-topology views with authored/generated/runtime-only truth",
  "description": "Export-safe packet for the app-structure presentation lane. Each row binds one node of a route explorer, a component tree, or an app-topology view to its authored/generated/runtime-only origin, the generator version that produced any generated node, the view-scan freshness, how the node truth was derived, its support class, and its downgrade banner, so the route explorer, component tree, app-topology view, diff-review, run, diagnostics, and support surfaces project the same truth about whether a node was hand-authored, generated into a managed zone, or only exists at runtime, instead of presenting heuristic, bridged, or runtime-observed structure as exact authored or generated source truth. Raw source bodies, raw manifests, runtime payloads, repository URLs, hostnames, secrets, and user-authored content never cross this boundary; rows carry opaque refs, closed-vocabulary class tokens, short reviewable summaries, structural locators, and export-safe chip labels only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "packet_label",
    "rows",
    "review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "route_component_and_app_topology_view_rows"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "packet_label": { "$ref": "#/$defs/non_empty_string" },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/topology_row" }
    },
    "review": { "$ref": "#/$defs/review" },
    "consumer_projection": { "$ref": "#/$defs/consumer_projection" },
    "proof_freshness": { "$ref": "#/$defs/proof_freshness" },
    "source_contract_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "redaction_class_token": { "$ref": "#/$defs/non_empty_string" },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "view_kind": {
      "type": "string",
      "enum": ["route_explorer", "component_tree", "app_topology"]
    },
    "origin_class": {
      "type": "string",
      "enum": [
        "authored",
        "generated",
        "authored_in_generated_zone",
        "runtime_only",
        "origin_unknown"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "fresh",
        "rescan_available",
        "aging",
        "stale",
        "freshness_unknown"
      ]
    },
    "derivation_class": {
      "type": "string",
      "enum": [
        "generator_manifest",
        "static_analysis",
        "runtime_trace",
        "heuristic_inference",
        "bridged_from_external_tool",
        "derivation_degraded",
        "derivation_unknown"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "exactly_modeled",
        "runtime_observed",
        "experimental",
        "bridge_behavior",
        "heuristic_mapping",
        "unsupported",
        "support_unknown"
      ]
    },
    "downgrade_banner_class": {
      "type": "string",
      "enum": [
        "no_banner",
        "freshness_banner",
        "derivation_banner",
        "support_class_banner",
        "policy_block_banner",
        "origin_unknown_banner"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "origin_unknown",
        "generator_version_yanked",
        "scan_stale",
        "derivation_degraded",
        "bridge_behavior_disclosed",
        "heuristic_mapping_disclosed",
        "runtime_only_disclosed",
        "known_issue_blocking",
        "validation_failed",
        "upstream_dependency_narrowed"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "route_explorer",
        "component_tree",
        "app_topology_view",
        "diff_review",
        "run_surface",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "topology_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "view_kind",
        "node_id",
        "node_label",
        "node_path",
        "app_id",
        "generator_version",
        "origin_summary",
        "origin_class",
        "freshness_class",
        "freshness_chip_label",
        "last_scanned",
        "derivation_class",
        "derivation_summary",
        "support_class",
        "downgrade_banner_class",
        "known_issue_refs",
        "admitted_for_display",
        "downgrade_triggers",
        "consumer_surfaces"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "view_kind": { "$ref": "#/$defs/view_kind" },
        "node_id": { "$ref": "#/$defs/non_empty_string" },
        "node_label": { "$ref": "#/$defs/non_empty_string" },
        "node_path": { "$ref": "#/$defs/non_empty_string" },
        "app_id": { "$ref": "#/$defs/non_empty_string" },
        "generator_version": { "$ref": "#/$defs/non_empty_string" },
        "origin_summary": { "$ref": "#/$defs/non_empty_string" },
        "origin_class": { "$ref": "#/$defs/origin_class" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "freshness_chip_label": { "$ref": "#/$defs/non_empty_string" },
        "last_scanned": {
          "type": "string",
          "format": "date-time"
        },
        "derivation_class": { "$ref": "#/$defs/derivation_class" },
        "derivation_summary": { "$ref": "#/$defs/non_empty_string" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "downgrade_banner_class": { "$ref": "#/$defs/downgrade_banner_class" },
        "known_issue_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "admitted_for_display": { "type": "boolean" },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_trigger" },
          "uniqueItems": true
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/consumer_surface" },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "description": "A non-exact-derivation node must show a banner.",
          "if": {
            "properties": {
              "derivation_class": {
                "enum": [
                  "heuristic_inference",
                  "bridged_from_external_tool",
                  "derivation_degraded",
                  "derivation_unknown"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "Bridge and heuristic nodes disclose a known issue and a present banner.",
          "if": {
            "properties": {
              "support_class": {
                "enum": ["bridge_behavior", "heuristic_mapping"]
              }
            }
          },
          "then": {
            "properties": {
              "known_issue_refs": {
                "type": "array",
                "minItems": 1
              },
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "Bridge nodes carry the bridge-behavior disclosure trigger.",
          "if": {
            "properties": {
              "support_class": { "const": "bridge_behavior" }
            }
          },
          "then": {
            "properties": {
              "downgrade_triggers": {
                "type": "array",
                "contains": { "const": "bridge_behavior_disclosed" }
              }
            }
          }
        },
        {
          "description": "Heuristic nodes carry the heuristic-mapping disclosure trigger.",
          "if": {
            "properties": {
              "support_class": { "const": "heuristic_mapping" }
            }
          },
          "then": {
            "properties": {
              "downgrade_triggers": {
                "type": "array",
                "contains": { "const": "heuristic_mapping_disclosed" }
              }
            }
          }
        },
        {
          "description": "Runtime-only nodes carry the runtime-only disclosure trigger.",
          "if": {
            "properties": {
              "origin_class": { "const": "runtime_only" }
            }
          },
          "then": {
            "properties": {
              "downgrade_triggers": {
                "type": "array",
                "contains": { "const": "runtime_only_disclosed" }
              }
            }
          }
        },
        {
          "description": "An origin-unknown node carries the origin-unknown banner.",
          "if": {
            "properties": {
              "origin_class": { "const": "origin_unknown" }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": { "const": "origin_unknown_banner" }
            }
          }
        },
        {
          "description": "A stale or unknown-freshness node shows a downgrade banner.",
          "if": {
            "properties": {
              "freshness_class": {
                "enum": ["stale", "freshness_unknown"]
              }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "Blocked nodes cannot be admitted for confident display.",
          "if": {
            "anyOf": [
              {
                "properties": {
                  "freshness_class": {
                    "enum": ["stale", "freshness_unknown"]
                  }
                }
              },
              {
                "properties": {
                  "derivation_class": {
                    "enum": ["derivation_degraded", "derivation_unknown"]
                  }
                }
              },
              {
                "properties": {
                  "origin_class": { "const": "origin_unknown" }
                }
              },
              {
                "properties": {
                  "downgrade_banner_class": {
                    "enum": ["policy_block_banner", "origin_unknown_banner"]
                  }
                }
              }
            ]
          },
          "then": {
            "properties": {
              "admitted_for_display": { "const": false }
            }
          }
        }
      ]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "view_shows_origin_for_every_node",
        "generator_version_shown_for_generated_nodes",
        "freshness_chip_shown_for_every_view",
        "derivation_banner_shown_when_not_exact",
        "downgrade_banner_shown_when_narrowed",
        "runtime_only_never_presented_as_authored_or_generated",
        "bridge_or_heuristic_never_presented_as_exact_truth",
        "stale_view_not_presented_as_current",
        "origin_unknown_node_labeled_not_hidden",
        "support_class_visible_before_display",
        "known_issues_disclosed_before_display",
        "no_raw_source_bodies_or_urls_in_export",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "view_shows_origin_for_every_node": { "const": true },
        "generator_version_shown_for_generated_nodes": { "const": true },
        "freshness_chip_shown_for_every_view": { "const": true },
        "derivation_banner_shown_when_not_exact": { "const": true },
        "downgrade_banner_shown_when_narrowed": { "const": true },
        "runtime_only_never_presented_as_authored_or_generated": { "const": true },
        "bridge_or_heuristic_never_presented_as_exact_truth": { "const": true },
        "stale_view_not_presented_as_current": { "const": true },
        "origin_unknown_node_labeled_not_hidden": { "const": true },
        "support_class_visible_before_display": { "const": true },
        "known_issues_disclosed_before_display": { "const": true },
        "no_raw_source_bodies_or_urls_in_export": { "const": true },
        "downgrade_narrows_instead_of_hides": { "const": true },
        "stale_or_underqualified_blocks_promotion": { "const": true }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_explorer_shows_node_origin",
        "component_tree_shows_node_origin",
        "app_topology_shows_node_origin",
        "structure_view_shows_freshness_chip",
        "run_surface_shows_derivation_banner",
        "diff_review_shows_downgrade_banner",
        "cli_headless_shows_topology_rows",
        "support_export_shows_topology_rows",
        "diagnostics_shows_freshness_and_derivation_state",
        "blocked_nodes_labeled_not_hidden"
      ],
      "properties": {
        "route_explorer_shows_node_origin": { "const": true },
        "component_tree_shows_node_origin": { "const": true },
        "app_topology_shows_node_origin": { "const": true },
        "structure_view_shows_freshness_chip": { "const": true },
        "run_surface_shows_derivation_banner": { "const": true },
        "diff_review_shows_downgrade_banner": { "const": true },
        "cli_headless_shows_topology_rows": { "const": true },
        "support_export_shows_topology_rows": { "const": true },
        "diagnostics_shows_freshness_and_derivation_state": { "const": true },
        "blocked_nodes_labeled_not_hidden": { "const": true }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": { "type": "boolean" }
      }
    }
  }
}
