{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/templates/freeze-the-m5-template-registry-framework-pack-and-support-class-matrix.schema.json",
  "title": "Aureline template-registry, framework-pack, and support-class maturity matrix",
  "description": "Export-safe packet freezing the depth qualification for four template and framework lanes: a signed template registry with verified provenance, a scaffold planner that previews its write impact before any change, framework packs that keep authored-versus-generated-versus-runtime-only truth and support class explicit, and archetype health bundles that partition blockers from warnings and optimizations. The packet binds each lane to its qualification class, support class, generation-truth class, evidence requirements, downgrade triggers, rollback posture, source contracts, and consumer-surface parity. Template source bodies, raw generator output, raw provider payloads, credentials, and secret values never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "matrix_label",
    "lane_rows",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "freeze_template_registry_framework_pack_and_support_class_matrix"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "matrix_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "lane_rows": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/lane_row"
      }
    },
    "trust_review": {
      "$ref": "#/$defs/trust_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "lane": {
      "type": "string",
      "enum": [
        "signed_template_registry",
        "scaffold_planner",
        "framework_pack",
        "archetype_health_bundle"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "officially_supported",
        "team_managed",
        "community_supported",
        "experimental",
        "unsupported",
        "narrowed_below_stable"
      ]
    },
    "generation_truth": {
      "type": "string",
      "enum": [
        "authored",
        "generated",
        "runtime_only",
        "mixed_authored_generated"
      ]
    },
    "evidence_requirement": {
      "type": "string",
      "enum": [
        "required",
        "recommended",
        "optional",
        "not_applicable"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "signature_unverified",
        "template_revision_unavailable",
        "scaffold_preview_unavailable",
        "support_class_narrowed",
        "heuristic_presented_as_exact",
        "archetype_health_stale",
        "lineage_truth_missing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "rollback_posture": {
      "type": "string",
      "enum": [
        "read_only_no_mutation",
        "previewed_write_with_checkpoint",
        "delete_generated_outputs",
        "three_way_lineage_update",
        "evidence_preserved_no_revert",
        "not_applicable"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "gallery",
        "diff_preview",
        "run_surface",
        "recovery",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "lane_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane",
        "qualification",
        "support_class",
        "generation_truth",
        "scope_summary",
        "evidence_requirement",
        "required_evidence_packet_refs",
        "downgrade_triggers",
        "rollback_posture",
        "source_contract_refs",
        "consumer_surfaces"
      ],
      "properties": {
        "lane": {
          "$ref": "#/$defs/lane"
        },
        "qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "support_class": {
          "$ref": "#/$defs/support_class"
        },
        "generation_truth": {
          "$ref": "#/$defs/generation_truth"
        },
        "scope_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_requirement": {
          "$ref": "#/$defs/evidence_requirement"
        },
        "required_evidence_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "rollback_posture": {
          "$ref": "#/$defs/rollback_posture"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/consumer_surface"
          }
        }
      }
    },
    "trust_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_source_provenance_inspectable",
        "generator_and_pack_versions_inspectable",
        "signed_registry_signatures_verified",
        "scaffold_diff_preview_before_write",
        "rollback_boundary_visible",
        "authored_generated_runtime_truth_explicit",
        "support_class_and_downgrade_cues_current",
        "heuristic_never_presented_as_exact",
        "archetype_health_partitioned",
        "no_credential_bodies_in_export",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "template_source_provenance_inspectable": {
          "type": "boolean",
          "const": true
        },
        "generator_and_pack_versions_inspectable": {
          "type": "boolean",
          "const": true
        },
        "signed_registry_signatures_verified": {
          "type": "boolean",
          "const": true
        },
        "scaffold_diff_preview_before_write": {
          "type": "boolean",
          "const": true
        },
        "rollback_boundary_visible": {
          "type": "boolean",
          "const": true
        },
        "authored_generated_runtime_truth_explicit": {
          "type": "boolean",
          "const": true
        },
        "support_class_and_downgrade_cues_current": {
          "type": "boolean",
          "const": true
        },
        "heuristic_never_presented_as_exact": {
          "type": "boolean",
          "const": true
        },
        "archetype_health_partitioned": {
          "type": "boolean",
          "const": true
        },
        "no_credential_bodies_in_export": {
          "type": "boolean",
          "const": true
        },
        "downgrade_narrows_instead_of_hides": {
          "type": "boolean",
          "const": true
        },
        "stale_or_underqualified_blocks_promotion": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gallery_shows_source_and_support_class",
        "diff_preview_shows_authored_generated_truth",
        "run_surface_shows_pack_and_generator_versions",
        "recovery_shows_rollback_and_lineage",
        "cli_headless_shows_qualification",
        "support_export_shows_qualification",
        "diagnostics_shows_qualification",
        "help_about_shows_qualification",
        "preview_labs_label_for_unqualified_lanes"
      ],
      "properties": {
        "gallery_shows_source_and_support_class": {
          "type": "boolean",
          "const": true
        },
        "diff_preview_shows_authored_generated_truth": {
          "type": "boolean",
          "const": true
        },
        "run_surface_shows_pack_and_generator_versions": {
          "type": "boolean",
          "const": true
        },
        "recovery_shows_rollback_and_lineage": {
          "type": "boolean",
          "const": true
        },
        "cli_headless_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "support_export_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "diagnostics_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "help_about_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "preview_labs_label_for_unqualified_lanes": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
