{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/templates/add-convention-diagnostics-confidence-labels-suppressibility-and-proving-file-disclosure.schema.json",
  "title": "Aureline convention diagnostics with confidence labels, suppressibility, and proving-file disclosure",
  "description": "Export-safe packet for the framework-pack convention-diagnostic lane. Each row binds one convention diagnostic to its confidence label, the analysis freshness, whether and how it may be suppressed, the proving file or manifest that grounds it, its support class, and its downgrade banner, so the editor diagnostics, problems panel, diff-review, run, diagnostics, and support surfaces project the same truth about how confident a diagnostic is, whether it is suppressed, and what file proves it, instead of presenting a heuristic, bridged, or ungrounded convention as exact first-party truth. Raw source bodies, raw manifests, repository URLs, hostnames, secrets, and user-authored content never cross this boundary; rows carry opaque refs, closed-vocabulary class tokens, short reviewable summaries, structural locators, and export-safe chip labels only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "packet_label",
    "rows",
    "review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "convention_diagnostic_confidence_and_suppressibility_rows"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "packet_label": { "$ref": "#/$defs/non_empty_string" },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/diagnostic_row" }
    },
    "review": { "$ref": "#/$defs/review" },
    "consumer_projection": { "$ref": "#/$defs/consumer_projection" },
    "proof_freshness": { "$ref": "#/$defs/proof_freshness" },
    "source_contract_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "redaction_class_token": { "$ref": "#/$defs/non_empty_string" },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "diagnostic_kind": {
      "type": "string",
      "enum": [
        "naming_convention",
        "file_location",
        "required_registration",
        "config_convention",
        "api_usage_convention"
      ]
    },
    "severity": {
      "type": "string",
      "enum": ["error", "warning", "info", "hint"]
    },
    "confidence_label": {
      "type": "string",
      "enum": ["exact", "high", "heuristic", "low", "confidence_unknown"]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "fresh",
        "rescan_available",
        "aging",
        "stale",
        "freshness_unknown"
      ]
    },
    "suppression_class": {
      "type": "string",
      "enum": [
        "suppressible",
        "not_suppressible",
        "suppressed_by_user",
        "suppressed_by_scope",
        "suppression_unknown"
      ]
    },
    "proving_disclosure_class": {
      "type": "string",
      "enum": [
        "proving_file_disclosed",
        "proving_manifest_disclosed",
        "no_proving_file_needed",
        "proving_file_unavailable"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "exactly_modeled",
        "experimental",
        "bridge_behavior",
        "heuristic_mapping",
        "unsupported",
        "support_unknown"
      ]
    },
    "downgrade_banner_class": {
      "type": "string",
      "enum": [
        "no_banner",
        "freshness_banner",
        "confidence_banner",
        "support_class_banner",
        "proving_file_unavailable_banner",
        "policy_block_banner"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "proving_file_unavailable",
        "confidence_degraded",
        "analysis_stale",
        "heuristic_confidence_disclosed",
        "bridge_behavior_disclosed",
        "suppression_applied",
        "known_issue_blocking",
        "validation_failed",
        "upstream_dependency_narrowed"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "editor_diagnostics",
        "problems_panel",
        "diff_review",
        "run_surface",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "diagnostic_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "diagnostic_kind",
        "diagnostic_id",
        "diagnostic_label",
        "convention_locator",
        "app_id",
        "framework_pack_ref",
        "message_summary",
        "severity",
        "confidence_label",
        "confidence_summary",
        "freshness_class",
        "freshness_chip_label",
        "last_analyzed",
        "suppression_class",
        "suppression_summary",
        "proving_disclosure_class",
        "proving_file_refs",
        "proving_summary",
        "support_class",
        "downgrade_banner_class",
        "known_issue_refs",
        "admitted_for_display",
        "downgrade_triggers",
        "consumer_surfaces"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "diagnostic_kind": { "$ref": "#/$defs/diagnostic_kind" },
        "diagnostic_id": { "$ref": "#/$defs/non_empty_string" },
        "diagnostic_label": { "$ref": "#/$defs/non_empty_string" },
        "convention_locator": { "$ref": "#/$defs/non_empty_string" },
        "app_id": { "$ref": "#/$defs/non_empty_string" },
        "framework_pack_ref": { "$ref": "#/$defs/non_empty_string" },
        "message_summary": { "$ref": "#/$defs/non_empty_string" },
        "severity": { "$ref": "#/$defs/severity" },
        "confidence_label": { "$ref": "#/$defs/confidence_label" },
        "confidence_summary": { "$ref": "#/$defs/non_empty_string" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "freshness_chip_label": { "$ref": "#/$defs/non_empty_string" },
        "last_analyzed": {
          "type": "string",
          "format": "date-time"
        },
        "suppression_class": { "$ref": "#/$defs/suppression_class" },
        "suppression_summary": { "$ref": "#/$defs/non_empty_string" },
        "proving_disclosure_class": { "$ref": "#/$defs/proving_disclosure_class" },
        "proving_file_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "proving_summary": { "$ref": "#/$defs/non_empty_string" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "downgrade_banner_class": { "$ref": "#/$defs/downgrade_banner_class" },
        "known_issue_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "admitted_for_display": { "type": "boolean" },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_trigger" },
          "uniqueItems": true
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/consumer_surface" },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "description": "A non-confident confidence label shows a banner.",
          "if": {
            "properties": {
              "confidence_label": {
                "enum": ["heuristic", "low", "confidence_unknown"]
              }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "A confident (exact or high) claim discloses a proving file or manifest.",
          "if": {
            "properties": {
              "confidence_label": { "enum": ["exact", "high"] }
            }
          },
          "then": {
            "properties": {
              "proving_disclosure_class": {
                "enum": ["proving_file_disclosed", "proving_manifest_disclosed"]
              }
            }
          }
        },
        {
          "description": "A grounded proving disclosure carries at least one proving-file ref.",
          "if": {
            "properties": {
              "proving_disclosure_class": {
                "enum": ["proving_file_disclosed", "proving_manifest_disclosed"]
              }
            }
          },
          "then": {
            "properties": {
              "proving_file_refs": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        },
        {
          "description": "An unavailable proving file raises the proving-file banner and narrows confidence to unknown.",
          "if": {
            "properties": {
              "proving_disclosure_class": { "const": "proving_file_unavailable" }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": { "const": "proving_file_unavailable_banner" },
              "confidence_label": { "const": "confidence_unknown" }
            }
          }
        },
        {
          "description": "Bridge and heuristic diagnostics disclose a known issue and a present banner.",
          "if": {
            "properties": {
              "support_class": {
                "enum": ["bridge_behavior", "heuristic_mapping"]
              }
            }
          },
          "then": {
            "properties": {
              "known_issue_refs": {
                "type": "array",
                "minItems": 1
              },
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "Bridge diagnostics carry the bridge-behavior disclosure trigger.",
          "if": {
            "properties": {
              "support_class": { "const": "bridge_behavior" }
            }
          },
          "then": {
            "properties": {
              "downgrade_triggers": {
                "type": "array",
                "contains": { "const": "bridge_behavior_disclosed" }
              }
            }
          }
        },
        {
          "description": "Heuristic diagnostics carry the heuristic-confidence disclosure trigger.",
          "if": {
            "properties": {
              "support_class": { "const": "heuristic_mapping" }
            }
          },
          "then": {
            "properties": {
              "downgrade_triggers": {
                "type": "array",
                "contains": { "const": "heuristic_confidence_disclosed" }
              }
            }
          }
        },
        {
          "description": "Suppressed diagnostics carry the suppression-applied trigger and are not admitted.",
          "if": {
            "properties": {
              "suppression_class": {
                "enum": ["suppressed_by_user", "suppressed_by_scope"]
              }
            }
          },
          "then": {
            "properties": {
              "downgrade_triggers": {
                "type": "array",
                "contains": { "const": "suppression_applied" }
              },
              "admitted_for_display": { "const": false }
            }
          }
        },
        {
          "description": "A stale or unknown-freshness diagnostic shows a downgrade banner.",
          "if": {
            "properties": {
              "freshness_class": {
                "enum": ["stale", "freshness_unknown"]
              }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "Blocked diagnostics cannot be admitted for confident display.",
          "if": {
            "anyOf": [
              {
                "properties": {
                  "freshness_class": {
                    "enum": ["stale", "freshness_unknown"]
                  }
                }
              },
              {
                "properties": {
                  "confidence_label": { "const": "confidence_unknown" }
                }
              },
              {
                "properties": {
                  "proving_disclosure_class": { "const": "proving_file_unavailable" }
                }
              },
              {
                "properties": {
                  "downgrade_banner_class": {
                    "enum": ["proving_file_unavailable_banner", "policy_block_banner"]
                  }
                }
              }
            ]
          },
          "then": {
            "properties": {
              "admitted_for_display": { "const": false }
            }
          }
        }
      ]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confidence_label_shown_for_every_diagnostic",
        "proving_file_disclosed_or_marked_not_needed",
        "confident_claim_discloses_proving_file",
        "confidence_banner_shown_when_not_confident",
        "suppressibility_disclosed_for_every_diagnostic",
        "suppressed_diagnostic_labeled_not_hidden",
        "heuristic_or_bridge_never_presented_as_exact_truth",
        "proving_file_unavailable_blocks_confident_claim",
        "stale_analysis_not_presented_as_current",
        "support_class_visible_before_display",
        "known_issues_disclosed_before_display",
        "no_raw_source_bodies_or_urls_in_export",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "confidence_label_shown_for_every_diagnostic": { "const": true },
        "proving_file_disclosed_or_marked_not_needed": { "const": true },
        "confident_claim_discloses_proving_file": { "const": true },
        "confidence_banner_shown_when_not_confident": { "const": true },
        "suppressibility_disclosed_for_every_diagnostic": { "const": true },
        "suppressed_diagnostic_labeled_not_hidden": { "const": true },
        "heuristic_or_bridge_never_presented_as_exact_truth": { "const": true },
        "proving_file_unavailable_blocks_confident_claim": { "const": true },
        "stale_analysis_not_presented_as_current": { "const": true },
        "support_class_visible_before_display": { "const": true },
        "known_issues_disclosed_before_display": { "const": true },
        "no_raw_source_bodies_or_urls_in_export": { "const": true },
        "downgrade_narrows_instead_of_hides": { "const": true },
        "stale_or_underqualified_blocks_promotion": { "const": true }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "editor_shows_confidence_label",
        "problems_panel_shows_suppressibility",
        "diff_review_shows_proving_file",
        "run_surface_shows_confidence_banner",
        "cli_headless_shows_diagnostic_rows",
        "support_export_shows_diagnostic_rows",
        "diagnostics_shows_confidence_and_proving_state",
        "suppressed_diagnostics_labeled_not_hidden",
        "blocked_diagnostics_labeled_not_hidden"
      ],
      "properties": {
        "editor_shows_confidence_label": { "const": true },
        "problems_panel_shows_suppressibility": { "const": true },
        "diff_review_shows_proving_file": { "const": true },
        "run_surface_shows_confidence_banner": { "const": true },
        "cli_headless_shows_diagnostic_rows": { "const": true },
        "support_export_shows_diagnostic_rows": { "const": true },
        "diagnostics_shows_confidence_and_proving_state": { "const": true },
        "suppressed_diagnostics_labeled_not_hidden": { "const": true },
        "blocked_diagnostics_labeled_not_hidden": { "const": true }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": { "type": "boolean" }
      }
    }
  }
}
