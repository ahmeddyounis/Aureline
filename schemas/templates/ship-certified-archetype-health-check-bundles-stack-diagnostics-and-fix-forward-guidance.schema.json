{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/templates/ship-certified-archetype-health-check-bundles-stack-diagnostics-and-fix-forward-guidance.schema.json",
  "title": "Aureline certified-archetype health-check bundles, stack diagnostics, and fix-forward guidance",
  "description": "Export-safe packet for the certified-archetype health-check bundle lane. Each row binds one health-check bundle run to its archetype certification class, its pinned health-check bundle version, its overall health state, the worst stack-diagnostic severity it observed, whether and how fix-forward guidance is available, its scan-record freshness, its support class, and its downgrade banner, so the archetype gallery, health-check panel, stack-diagnostics, fix-forward guidance, run, diagnostics, and support surfaces project the same truth about whether a bundle's health verdict may be trusted and on what terms, instead of presenting an uncertified, heuristic, or bridged check as exact first-party certified truth. Raw source bodies, raw diagnostic logs, generated file contents, repository URLs, hostnames, secrets, and user-authored content never cross this boundary; rows carry opaque refs, closed-vocabulary class tokens, short reviewable summaries, structural locators, and export-safe chip labels only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "packet_label",
    "rows",
    "review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "certified_archetype_health_check_bundle_rows"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "packet_label": { "$ref": "#/$defs/non_empty_string" },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/archetype_health_row" }
    },
    "review": { "$ref": "#/$defs/review" },
    "consumer_projection": { "$ref": "#/$defs/consumer_projection" },
    "proof_freshness": { "$ref": "#/$defs/proof_freshness" },
    "source_contract_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "redaction_class_token": { "$ref": "#/$defs/non_empty_string" },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "archetype_kind": {
      "type": "string",
      "enum": [
        "service_archetype",
        "web_app_archetype",
        "full_stack_archetype",
        "cli_archetype",
        "library_archetype"
      ]
    },
    "certification_class": {
      "type": "string",
      "enum": [
        "certified_archetype",
        "provisional_archetype",
        "community_archetype",
        "uncertified_archetype",
        "certification_unknown"
      ]
    },
    "health_check_class": {
      "type": "string",
      "enum": [
        "healthy",
        "healthy_with_advisories",
        "degraded",
        "failing",
        "health_unknown"
      ]
    },
    "stack_diagnostic_class": {
      "type": "string",
      "enum": [
        "no_diagnostics",
        "advisory",
        "warning",
        "error",
        "blocking",
        "diagnostics_unavailable"
      ]
    },
    "fix_forward_class": {
      "type": "string",
      "enum": [
        "no_fix_needed",
        "fix_automatic",
        "fix_guided",
        "fix_advisory_only",
        "fix_unavailable"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "fresh",
        "rescan_available",
        "aging",
        "stale",
        "freshness_unknown"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "exactly_modeled",
        "experimental",
        "bridge_behavior",
        "heuristic_mapping",
        "unsupported",
        "support_unknown"
      ]
    },
    "downgrade_banner_class": {
      "type": "string",
      "enum": [
        "no_banner",
        "freshness_banner",
        "health_unknown_banner",
        "diagnostics_unavailable_banner",
        "fix_unavailable_banner",
        "certification_banner",
        "support_class_banner",
        "policy_block_banner"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "certification_unverified",
        "health_undeterminable",
        "diagnostics_unavailable",
        "fix_guidance_unavailable",
        "bundle_version_unverified",
        "bundle_record_stale",
        "uncertified_archetype_disclosed",
        "heuristic_mapping_disclosed",
        "bridge_behavior_disclosed",
        "known_issue_blocking",
        "upstream_dependency_narrowed"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "archetype_gallery",
        "health_check_panel",
        "stack_diagnostics",
        "fix_forward_guidance",
        "run_surface",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "archetype_health_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "archetype_kind",
        "archetype_id",
        "archetype_label",
        "archetype_locator",
        "archetype_version",
        "certification_class",
        "bundle_id",
        "bundle_version",
        "app_id",
        "framework_pack_ref",
        "health_check_class",
        "health_summary",
        "stack_diagnostic_class",
        "diagnostic_summary",
        "diagnostic_stat_label",
        "diagnostic_refs",
        "fix_forward_class",
        "fix_forward_summary",
        "fix_forward_refs",
        "freshness_class",
        "freshness_chip_label",
        "last_checked",
        "support_class",
        "downgrade_banner_class",
        "known_issue_refs",
        "admitted_for_display",
        "downgrade_triggers",
        "consumer_surfaces"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "archetype_kind": { "$ref": "#/$defs/archetype_kind" },
        "archetype_id": { "$ref": "#/$defs/non_empty_string" },
        "archetype_label": { "$ref": "#/$defs/non_empty_string" },
        "archetype_locator": { "$ref": "#/$defs/non_empty_string" },
        "archetype_version": { "$ref": "#/$defs/non_empty_string" },
        "certification_class": { "$ref": "#/$defs/certification_class" },
        "bundle_id": { "$ref": "#/$defs/non_empty_string" },
        "bundle_version": { "$ref": "#/$defs/non_empty_string" },
        "app_id": { "$ref": "#/$defs/non_empty_string" },
        "framework_pack_ref": { "$ref": "#/$defs/non_empty_string" },
        "health_check_class": { "$ref": "#/$defs/health_check_class" },
        "health_summary": { "$ref": "#/$defs/non_empty_string" },
        "stack_diagnostic_class": { "$ref": "#/$defs/stack_diagnostic_class" },
        "diagnostic_summary": { "$ref": "#/$defs/non_empty_string" },
        "diagnostic_stat_label": { "$ref": "#/$defs/non_empty_string" },
        "diagnostic_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "fix_forward_class": { "$ref": "#/$defs/fix_forward_class" },
        "fix_forward_summary": { "$ref": "#/$defs/non_empty_string" },
        "fix_forward_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "freshness_chip_label": { "$ref": "#/$defs/non_empty_string" },
        "last_checked": {
          "type": "string",
          "format": "date-time"
        },
        "support_class": { "$ref": "#/$defs/support_class" },
        "downgrade_banner_class": { "$ref": "#/$defs/downgrade_banner_class" },
        "known_issue_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "admitted_for_display": { "type": "boolean" },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_trigger" },
          "uniqueItems": true
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/consumer_surface" },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "description": "An unknown health verdict raises the health-unknown banner.",
          "if": {
            "properties": {
              "health_check_class": { "const": "health_unknown" }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": { "const": "health_unknown_banner" }
            }
          }
        },
        {
          "description": "Unavailable diagnostics show a downgrade banner.",
          "if": {
            "properties": {
              "stack_diagnostic_class": { "const": "diagnostics_unavailable" }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "An unavailable fix-forward path shows a downgrade banner.",
          "if": {
            "properties": {
              "fix_forward_class": { "const": "fix_unavailable" }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "A warning, error, or blocking diagnostic carries at least one diagnostic ref.",
          "if": {
            "properties": {
              "stack_diagnostic_class": {
                "enum": ["warning", "error", "blocking"]
              }
            }
          },
          "then": {
            "properties": {
              "diagnostic_refs": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        },
        {
          "description": "A bundle carrying fix-forward guidance carries at least one fix-forward ref.",
          "if": {
            "properties": {
              "fix_forward_class": {
                "enum": ["fix_automatic", "fix_guided", "fix_advisory_only"]
              }
            }
          },
          "then": {
            "properties": {
              "fix_forward_refs": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        },
        {
          "description": "A non-certified archetype shows a banner and carries the disclosure trigger.",
          "if": {
            "properties": {
              "certification_class": {
                "enum": [
                  "provisional_archetype",
                  "community_archetype",
                  "uncertified_archetype",
                  "certification_unknown"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              },
              "downgrade_triggers": {
                "type": "array",
                "contains": { "const": "uncertified_archetype_disclosed" }
              }
            }
          }
        },
        {
          "description": "Bridge and heuristic bundles disclose a known issue and a present banner.",
          "if": {
            "properties": {
              "support_class": {
                "enum": ["bridge_behavior", "heuristic_mapping"]
              }
            }
          },
          "then": {
            "properties": {
              "known_issue_refs": {
                "type": "array",
                "minItems": 1
              },
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "Bridge bundles carry the bridge-behavior disclosure trigger.",
          "if": {
            "properties": {
              "support_class": { "const": "bridge_behavior" }
            }
          },
          "then": {
            "properties": {
              "downgrade_triggers": {
                "type": "array",
                "contains": { "const": "bridge_behavior_disclosed" }
              }
            }
          }
        },
        {
          "description": "Heuristic bundles carry the heuristic-mapping disclosure trigger.",
          "if": {
            "properties": {
              "support_class": { "const": "heuristic_mapping" }
            }
          },
          "then": {
            "properties": {
              "downgrade_triggers": {
                "type": "array",
                "contains": { "const": "heuristic_mapping_disclosed" }
              }
            }
          }
        },
        {
          "description": "A stale or unknown-freshness bundle shows a downgrade banner.",
          "if": {
            "properties": {
              "freshness_class": {
                "enum": ["stale", "freshness_unknown"]
              }
            }
          },
          "then": {
            "properties": {
              "downgrade_banner_class": {
                "not": { "const": "no_banner" }
              }
            }
          }
        },
        {
          "description": "Blocked bundles cannot be admitted for a confident verdict.",
          "if": {
            "anyOf": [
              {
                "properties": {
                  "freshness_class": {
                    "enum": ["stale", "freshness_unknown"]
                  }
                }
              },
              {
                "properties": {
                  "health_check_class": { "const": "health_unknown" }
                }
              },
              {
                "properties": {
                  "stack_diagnostic_class": { "const": "diagnostics_unavailable" }
                }
              },
              {
                "properties": {
                  "downgrade_banner_class": {
                    "enum": [
                      "health_unknown_banner",
                      "diagnostics_unavailable_banner",
                      "policy_block_banner"
                    ]
                  }
                }
              }
            ]
          },
          "then": {
            "properties": {
              "admitted_for_display": { "const": false }
            }
          }
        }
      ]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "certification_disclosed_for_every_bundle",
        "health_state_shown_for_every_bundle",
        "stack_diagnostics_shown_for_every_bundle",
        "fix_forward_guidance_shown_when_available",
        "health_unknown_blocks_confident_verdict",
        "diagnostics_unavailable_blocks_confident_verdict",
        "uncertified_archetype_never_presented_as_certified",
        "heuristic_or_bridge_never_presented_as_exact_truth",
        "fix_guidance_unavailable_labeled_not_hidden",
        "stale_bundle_not_presented_as_current",
        "support_class_visible_before_display",
        "known_issues_disclosed_before_display",
        "no_raw_source_bodies_or_urls_in_export",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion",
        "certification_visible_before_display"
      ],
      "properties": {
        "certification_disclosed_for_every_bundle": { "const": true },
        "health_state_shown_for_every_bundle": { "const": true },
        "stack_diagnostics_shown_for_every_bundle": { "const": true },
        "fix_forward_guidance_shown_when_available": { "const": true },
        "health_unknown_blocks_confident_verdict": { "const": true },
        "diagnostics_unavailable_blocks_confident_verdict": { "const": true },
        "uncertified_archetype_never_presented_as_certified": { "const": true },
        "heuristic_or_bridge_never_presented_as_exact_truth": { "const": true },
        "fix_guidance_unavailable_labeled_not_hidden": { "const": true },
        "stale_bundle_not_presented_as_current": { "const": true },
        "support_class_visible_before_display": { "const": true },
        "known_issues_disclosed_before_display": { "const": true },
        "no_raw_source_bodies_or_urls_in_export": { "const": true },
        "downgrade_narrows_instead_of_hides": { "const": true },
        "stale_or_underqualified_blocks_promotion": { "const": true },
        "certification_visible_before_display": { "const": true }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gallery_shows_certification",
        "health_check_panel_shows_health_state",
        "stack_diagnostics_shows_diagnostics",
        "fix_forward_guidance_shows_remediation",
        "run_surface_shows_health_state",
        "cli_headless_shows_bundle_rows",
        "support_export_shows_bundle_rows",
        "diagnostics_shows_health_diagnostics_fix_state",
        "blocked_bundles_labeled_not_hidden",
        "uncertified_bundles_labeled_not_hidden"
      ],
      "properties": {
        "gallery_shows_certification": { "const": true },
        "health_check_panel_shows_health_state": { "const": true },
        "stack_diagnostics_shows_diagnostics": { "const": true },
        "fix_forward_guidance_shows_remediation": { "const": true },
        "run_surface_shows_health_state": { "const": true },
        "cli_headless_shows_bundle_rows": { "const": true },
        "support_export_shows_bundle_rows": { "const": true },
        "diagnostics_shows_health_diagnostics_fix_state": { "const": true },
        "blocked_bundles_labeled_not_hidden": { "const": true },
        "uncertified_bundles_labeled_not_hidden": { "const": true }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": { "type": "boolean" }
      }
    }
  }
}
