{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/templates/certify-the-template-registry-scaffold-planner-framework-packs-and-archetype-health-bundles-on-every-claimed-m5-profile.schema.json",
  "title": "Aureline M5 template-registry, scaffold-planner, framework-pack, and archetype-health certification",
  "description": "Export-safe packet certifying every claimed M5 template, scaffold, framework-pack, and archetype-health profile: the signed template registry, the generation diff-review and managed-zone recovery flow, framework generator/codemod runs, framework-pack headers, the richer framework-pack lane catalog, route/component/topology views, convention diagnostics, and certified archetype health bundles. Each profile binds a certification verdict to the upstream evidence packet (record kind, support-export artifact, schema, and contract doc), its downgrade triggers, rollback posture, and proof freshness. A compatibility report aggregates the per-profile verdicts into a promotion verdict. Raw template source bodies, raw generator output, raw provider payloads, repository URLs, credentials, and secret values never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "certification_label",
    "certified_profiles",
    "compatibility_report",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "certify_template_registry_scaffold_planner_framework_packs_and_archetype_health_bundles_on_every_claimed_m5_profile"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "certification_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "certified_profiles": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/certified_profile"
      }
    },
    "compatibility_report": {
      "$ref": "#/$defs/compatibility_report"
    },
    "trust_review": {
      "$ref": "#/$defs/trust_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "profile": {
      "type": "string",
      "enum": [
        "signed_template_registry",
        "generation_recovery",
        "framework_generator_run",
        "framework_pack_header",
        "richer_framework_packs",
        "app_topology_views",
        "convention_diagnostics",
        "archetype_health_bundle"
      ]
    },
    "lane": {
      "type": "string",
      "enum": [
        "template_registry",
        "scaffold_planner",
        "framework_pack",
        "archetype_health",
        "cross_cutting"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "certified",
        "narrowed_certified",
        "blocked",
        "not_certified"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "evidence_packet_invalid",
        "policy_blocked",
        "signature_unverified",
        "template_revision_unavailable",
        "scaffold_preview_unavailable",
        "support_class_narrowed",
        "heuristic_presented_as_exact",
        "archetype_health_stale",
        "lineage_truth_missing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "rollback_posture": {
      "type": "string",
      "enum": [
        "read_only_no_mutation",
        "scaffold_preview_before_write",
        "generation_rollback_or_delete_generated",
        "managed_zone_regenerate",
        "evidence_preserved_no_revert",
        "not_applicable"
      ]
    },
    "profile_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "proof_fresh"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "proof_fresh": {
          "type": "boolean"
        }
      }
    },
    "certified_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "lane",
        "claimed_qualification",
        "verdict",
        "upstream_record_kind",
        "evidence_artifact_ref",
        "evidence_schema_ref",
        "evidence_doc_ref",
        "downgrade_triggers",
        "rollback_posture",
        "proof_freshness"
      ],
      "properties": {
        "profile": {
          "$ref": "#/$defs/profile"
        },
        "lane": {
          "$ref": "#/$defs/lane"
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "verdict": {
          "$ref": "#/$defs/verdict"
        },
        "upstream_record_kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_artifact_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_schema_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_doc_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "rollback_posture": {
          "$ref": "#/$defs/rollback_posture"
        },
        "proof_freshness": {
          "$ref": "#/$defs/profile_freshness"
        }
      }
    },
    "compatibility_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_profiles",
        "certified_count",
        "narrowed_count",
        "blocked_count",
        "not_certified_count",
        "all_profiles_publishable",
        "promotion_note"
      ],
      "properties": {
        "total_profiles": {
          "type": "integer",
          "minimum": 0
        },
        "certified_count": {
          "type": "integer",
          "minimum": 0
        },
        "narrowed_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "not_certified_count": {
          "type": "integer",
          "minimum": 0
        },
        "all_profiles_publishable": {
          "type": "boolean"
        },
        "promotion_note": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "trust_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_source_provenance_inspectable",
        "generator_and_pack_versions_inspectable",
        "signed_registry_signatures_verified",
        "scaffold_diff_preview_before_write",
        "rollback_boundary_visible",
        "authored_generated_runtime_truth_explicit",
        "support_class_and_downgrade_cues_current",
        "heuristic_never_presented_as_exact",
        "archetype_health_partitioned",
        "no_credential_bodies_in_export",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "template_source_provenance_inspectable": {
          "type": "boolean",
          "const": true
        },
        "generator_and_pack_versions_inspectable": {
          "type": "boolean",
          "const": true
        },
        "signed_registry_signatures_verified": {
          "type": "boolean",
          "const": true
        },
        "scaffold_diff_preview_before_write": {
          "type": "boolean",
          "const": true
        },
        "rollback_boundary_visible": {
          "type": "boolean",
          "const": true
        },
        "authored_generated_runtime_truth_explicit": {
          "type": "boolean",
          "const": true
        },
        "support_class_and_downgrade_cues_current": {
          "type": "boolean",
          "const": true
        },
        "heuristic_never_presented_as_exact": {
          "type": "boolean",
          "const": true
        },
        "archetype_health_partitioned": {
          "type": "boolean",
          "const": true
        },
        "no_credential_bodies_in_export": {
          "type": "boolean",
          "const": true
        },
        "downgrade_narrows_instead_of_hides": {
          "type": "boolean",
          "const": true
        },
        "stale_or_underqualified_blocks_promotion": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gallery_shows_certification",
        "pack_header_shows_certification",
        "scaffold_run_shows_certification",
        "diff_review_shows_certification",
        "cli_headless_shows_certification",
        "support_export_shows_certification",
        "diagnostics_shows_certification",
        "help_about_shows_certification",
        "preview_labs_label_for_unqualified_profiles"
      ],
      "properties": {
        "gallery_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "pack_header_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "scaffold_run_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "diff_review_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "cli_headless_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "support_export_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "diagnostics_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "help_about_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "preview_labs_label_for_unqualified_profiles": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
