{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/templates/template_manifest_alpha.schema.json",
  "title": "Aureline template manifest alpha contract",
  "description": "Alpha boundary schema for one signed, reviewable template manifest projected into starter galleries, scaffold preflight, support export, and generated-project lineage. The manifest names template identity, version, signing/source posture, supported ecosystems and platforms, required parameters, generated artifacts, declared hooks and setup tasks, trust and egress notes, support class, and create-without-starter routes. Raw secrets, raw absolute paths, raw repository URLs, raw hook bodies, raw stdout/stderr, and raw user-authored content never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "template_manifest_alpha_schema_version",
    "manifest_id",
    "manifest_ref",
    "template_id",
    "template_version",
    "display_name",
    "signer",
    "support_class",
    "supported_ecosystems",
    "supported_platforms",
    "required_parameters",
    "generated_artifacts",
    "declared_hooks",
    "declared_setup_tasks",
    "trust_notes",
    "egress_notes",
    "create_without_starter_routes",
    "manifest_content_address",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "template_manifest_alpha_record" },
    "template_manifest_alpha_schema_version": { "type": "integer", "const": 1 },
    "manifest_id": { "$ref": "#/$defs/opaque_id" },
    "manifest_ref": { "$ref": "#/$defs/opaque_id" },
    "template_id": { "$ref": "#/$defs/opaque_id" },
    "template_version": { "$ref": "#/$defs/non_empty_string" },
    "display_name": { "$ref": "#/$defs/non_empty_string" },
    "summary": { "$ref": "#/$defs/reviewable_sentence" },
    "signer": { "$ref": "#/$defs/signer_source" },
    "support_class": { "$ref": "#/$defs/support_class" },
    "supported_ecosystems": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/supported_ecosystem" }
    },
    "supported_platforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/supported_platform" }
    },
    "required_parameters": {
      "type": "array",
      "items": { "$ref": "#/$defs/required_parameter" }
    },
    "generated_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/generated_artifact" }
    },
    "declared_hooks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/declared_hook" }
    },
    "declared_setup_tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/declared_setup_task" }
    },
    "trust_notes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/reviewable_sentence" }
    },
    "egress_notes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/reviewable_sentence" }
    },
    "create_without_starter_routes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/bypass_path_id" }
    },
    "manifest_content_address": { "$ref": "#/$defs/content_address" },
    "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe for support export. It is never a raw absolute path, raw URL, raw secret, or raw payload."
    },
    "non_empty_string": { "type": "string", "minLength": 1 },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "monotonic_timestamp": { "type": "string", "format": "date-time" },
    "digest_algorithm": {
      "type": "string",
      "enum": ["sha256", "sha384", "sha512", "blake3"]
    },
    "content_address": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest_algorithm", "digest_hex"],
      "properties": {
        "digest_algorithm": { "$ref": "#/$defs/digest_algorithm" },
        "digest_hex": {
          "type": "string",
          "pattern": "^[0-9a-f]+$",
          "minLength": 32
        },
        "digest_size_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "template_source_class": {
      "type": "string",
      "enum": [
        "first_party",
        "team_managed",
        "community",
        "local_only",
        "mirror_cached",
        "imported",
        "uncertified"
      ]
    },
    "source_distribution_class": {
      "type": "string",
      "enum": [
        "public_origin",
        "approved_mirror",
        "signed_offline_bundle",
        "repo_local",
        "ad_hoc_local"
      ]
    },
    "signature_state": {
      "type": "string",
      "enum": [
        "verified",
        "verified_via_mirror",
        "unsigned_review_required",
        "signature_failed_blocked",
        "unchecked"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "officially_supported",
        "community_supported",
        "experimental",
        "legacy_deprecated",
        "unsupported",
        "support_unknown"
      ]
    },
    "supported_ecosystem": {
      "type": "string",
      "enum": [
        "rust_cargo",
        "node_npm",
        "node_pnpm",
        "node_yarn",
        "node_bun",
        "python_pip",
        "python_poetry",
        "python_uv",
        "go_modules",
        "java_maven",
        "java_gradle",
        "multi_ecosystem_polyglot",
        "no_ecosystem_pure_files"
      ]
    },
    "supported_platform": {
      "type": "string",
      "enum": [
        "linux_x86_64",
        "linux_arm64",
        "macos_x86_64",
        "macos_arm64",
        "windows_x86_64",
        "windows_arm64",
        "container_runtime_target",
        "devcontainer_runtime_target",
        "managed_workspace_remote_target"
      ]
    },
    "parameter_kind": {
      "type": "string",
      "enum": [
        "typed_string_label",
        "typed_enum_choice",
        "typed_boolean_choice",
        "typed_directory_label_no_raw_path",
        "typed_secret_broker_handle_only"
      ]
    },
    "network_egress_class": {
      "type": "string",
      "enum": [
        "none",
        "declared_registry_after_review",
        "declared_mirror_after_review",
        "managed_service_after_review",
        "unknown_blocks_apply"
      ]
    },
    "signer_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "source_distribution_class",
        "signature_state",
        "signer_id_ref",
        "publisher_label",
        "trust_root_ref"
      ],
      "properties": {
        "source_class": { "$ref": "#/$defs/template_source_class" },
        "source_distribution_class": { "$ref": "#/$defs/source_distribution_class" },
        "signature_state": { "$ref": "#/$defs/signature_state" },
        "signer_id_ref": { "$ref": "#/$defs/opaque_id" },
        "publisher_label": { "$ref": "#/$defs/non_empty_string" },
        "trust_root_ref": { "$ref": "#/$defs/opaque_id" },
        "mirrored_from_ref": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "required_parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameter_id",
        "kind",
        "required",
        "source_class",
        "persists_raw_value"
      ],
      "properties": {
        "parameter_id": { "$ref": "#/$defs/opaque_id" },
        "kind": { "$ref": "#/$defs/parameter_kind" },
        "required": { "type": "boolean" },
        "source_class": {
          "type": "string",
          "enum": ["user_input", "manifest_default", "policy_default", "profile_default"]
        },
        "allowed_values_ref": { "type": ["string", "null"], "minLength": 1 },
        "persists_raw_value": { "const": false },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "generated_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "path_ref", "artifact_class", "disposition"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/opaque_id" },
        "path_ref": { "$ref": "#/$defs/opaque_id" },
        "artifact_class": {
          "type": "string",
          "enum": [
            "source_file",
            "configuration",
            "manifest",
            "lockfile",
            "documentation",
            "lineage_metadata",
            "test_fixture",
            "static_asset"
          ]
        },
        "disposition": {
          "type": "string",
          "enum": ["create", "modify", "skip_if_present", "review_required"]
        },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "declared_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hook_id",
        "hook_class",
        "execution_phase",
        "network_egress",
        "runs_before_review",
        "summary"
      ],
      "properties": {
        "hook_id": { "$ref": "#/$defs/opaque_id" },
        "hook_class": { "$ref": "#/$defs/opaque_id" },
        "execution_phase": { "$ref": "#/$defs/opaque_id" },
        "network_egress": { "$ref": "#/$defs/network_egress_class" },
        "runs_before_review": { "const": false },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "declared_setup_task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "task_class",
        "execution_phase",
        "immediate_or_deferred",
        "network_egress",
        "can_run_later",
        "summary"
      ],
      "properties": {
        "task_id": { "$ref": "#/$defs/opaque_id" },
        "task_class": { "$ref": "#/$defs/opaque_id" },
        "execution_phase": { "$ref": "#/$defs/opaque_id" },
        "immediate_or_deferred": {
          "type": "string",
          "enum": ["immediate_after_review", "deferred", "run_later_only"]
        },
        "network_egress": { "$ref": "#/$defs/network_egress_class" },
        "can_run_later": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "bypass_path_id": {
      "type": "string",
      "enum": [
        "bypass.open_folder_without_starter",
        "bypass.open_workspace_without_starter",
        "bypass.clone_repository_without_starter",
        "bypass.create_empty_workspace",
        "bypass.open_prebuild_minimal",
        "bypass.set_up_later",
        "bypass.continue_without_starter"
      ]
    }
  }
}
