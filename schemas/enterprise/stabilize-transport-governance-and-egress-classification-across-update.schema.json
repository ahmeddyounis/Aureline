{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/enterprise/stabilize-transport-governance-and-egress-classification-across-update.schema.json",
  "title": "Aureline stable transport governance and egress classification packet",
  "description": "Boundary schema for the stable TransportGovernancePage proof packet. The packet carries typed route class, egress decision, mirror route reference, offline posture, policy epoch, dependency class, control-plane status, and data-plane status for every named egress lane. Raw endpoint URLs, raw hostnames, raw credentials, raw private keys, raw PAC script bodies, and raw policy bundle content are excluded; only closed-vocabulary tokens, opaque refs, plain-language summary sentences, and schema-version integers cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "page_label",
    "generated_at",
    "summary",
    "rows",
    "defects",
    "policy_snapshot"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "record_kind": {
      "type": "string",
      "const": "remote_transport_governance_page_record"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "remote:transport_governance_stabilize:v1"
    },
    "page_id": { "$ref": "#/$defs/opaque_id" },
    "page_label": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
    "summary": { "$ref": "#/$defs/transport_governance_summary" },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/transport_governance_row" }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/transport_governance_defect" }
    },
    "policy_snapshot": { "$ref": "#/$defs/transport_policy_snapshot" }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 800
    },
    "egress_lane_token": {
      "type": "string",
      "enum": [
        "update",
        "marketplace",
        "ai",
        "docs",
        "provider",
        "remote",
        "mirror_offline"
      ]
    },
    "egress_decision_token": {
      "type": "string",
      "enum": [
        "allowed",
        "blocked_policy",
        "blocked_transport",
        "mirror_routed",
        "cached_offline",
        "last_known_good",
        "control_plane_impaired",
        "data_plane_impaired"
      ]
    },
    "egress_route_class_token": {
      "type": "string",
      "enum": [
        "direct",
        "proxied_system",
        "proxied_manual",
        "mirror_first",
        "offline",
        "last_known_good_fallback",
        "blocked_no_fallback"
      ]
    },
    "offline_posture_token": {
      "type": "string",
      "enum": [
        "online",
        "cached_content",
        "offline_grace",
        "mirror_served",
        "disconnected"
      ]
    },
    "dependency_class_token": {
      "type": "string",
      "enum": [
        "local_only",
        "network",
        "managed",
        "air_gapped"
      ]
    },
    "control_plane_status_token": {
      "type": "string",
      "enum": [
        "reachable",
        "unreachable",
        "policy_blocked",
        "mirror_routed",
        "not_applicable"
      ]
    },
    "data_plane_status_token": {
      "type": "string",
      "enum": [
        "reachable",
        "unreachable",
        "policy_blocked",
        "cached_served",
        "not_applicable"
      ]
    },
    "qualification_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "raw_private_material_exposed",
        "required_lane_missing",
        "local_core_continuity_undeclared",
        "dependency_class_undeclared",
        "policy_epoch_ref_missing",
        "egress_decision_typing_incomplete",
        "control_data_plane_distinction_missing"
      ]
    },
    "transport_policy_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "lane_token",
        "route_class_token",
        "egress_decision_token",
        "offline_posture_token",
        "policy_source_ref",
        "control_plane_status_token",
        "data_plane_status_token",
        "local_core_continuity_allowed",
        "dependency_class_token",
        "raw_private_material_excluded",
        "summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_transport_policy_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "remote:transport_governance_stabilize:v1" },
        "lane_token": { "$ref": "#/$defs/egress_lane_token" },
        "route_class_token": { "$ref": "#/$defs/egress_route_class_token" },
        "egress_decision_token": { "$ref": "#/$defs/egress_decision_token" },
        "mirror_route_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "offline_posture_token": { "$ref": "#/$defs/offline_posture_token" },
        "last_known_good_policy_epoch_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "tenant_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "region_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "policy_source_ref": { "$ref": "#/$defs/opaque_id" },
        "control_plane_status_token": { "$ref": "#/$defs/control_plane_status_token" },
        "data_plane_status_token": { "$ref": "#/$defs/data_plane_status_token" },
        "local_core_continuity_allowed": { "type": "boolean" },
        "dependency_class_token": { "$ref": "#/$defs/dependency_class_token" },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "transport_policy_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["records"],
      "properties": {
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/transport_policy_record" }
        }
      }
    },
    "transport_governance_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "lane_token",
        "route_class_token",
        "egress_decision_token",
        "offline_posture_token",
        "control_plane_status_token",
        "data_plane_status_token",
        "local_core_continuity_declared",
        "dependency_class_token",
        "policy_epoch_present",
        "raw_private_material_excluded",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "remote_transport_governance_row_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "remote:transport_governance_stabilize:v1" },
        "lane_token": { "$ref": "#/$defs/egress_lane_token" },
        "route_class_token": { "$ref": "#/$defs/egress_route_class_token" },
        "egress_decision_token": { "$ref": "#/$defs/egress_decision_token" },
        "offline_posture_token": { "$ref": "#/$defs/offline_posture_token" },
        "control_plane_status_token": { "$ref": "#/$defs/control_plane_status_token" },
        "data_plane_status_token": { "$ref": "#/$defs/data_plane_status_token" },
        "local_core_continuity_declared": { "type": "boolean" },
        "dependency_class_token": { "$ref": "#/$defs/dependency_class_token" },
        "policy_epoch_present": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "transport_governance_defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "remote_transport_governance_defect_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "remote:transport_governance_stabilize:v1" },
        "defect_id": { "$ref": "#/$defs/non_empty_string" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "transport_governance_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "lanes_covered",
        "local_core_continuity_declared_count",
        "policy_epoch_present_count",
        "overall_qualification_token"
      ],
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "lanes_covered": {
          "type": "array",
          "items": { "type": "string" }
        },
        "local_core_continuity_declared_count": { "type": "integer", "minimum": 0 },
        "policy_epoch_present_count": { "type": "integer", "minimum": 0 },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_token" }
      }
    }
  }
}
