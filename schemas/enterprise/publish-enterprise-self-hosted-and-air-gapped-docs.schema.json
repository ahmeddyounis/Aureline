{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/enterprise/publish-enterprise-self-hosted-and-air-gapped-docs.schema.json",
  "title": "Aureline enterprise, self-hosted, and air-gapped docs, matrices, and known-limits publish records",
  "description": "Boundary schema for the beta proof packet covering docs completeness, matrix completeness, known-limit disclosure, local-core continuity posture, and proof currency across claimed enterprise deployment profiles. Raw doc artefacts, raw hostnames, raw tenant identifiers, raw key bytes, and raw credentials never cross this boundary.",
  "oneOf": [
    { "$ref": "#/$defs/policy_enterprise_docs_matrices_known_limits_page_record" },
    { "$ref": "#/$defs/policy_enterprise_docs_matrices_known_limits_row_record" },
    { "$ref": "#/$defs/policy_enterprise_docs_matrices_known_limits_defect_record" },
    { "$ref": "#/$defs/policy_enterprise_docs_matrices_known_limits_summary_record" },
    { "$ref": "#/$defs/policy_enterprise_docs_matrices_known_limits_support_export_record" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "non_empty": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "shared_contract_ref": {
      "type": "string",
      "const": "policy:enterprise_docs_matrices_known_limits:v1"
    },
    "qualification_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "local_core_blocked_by_default",
        "aspirational_proof_on_sovereign_profile",
        "local_core_continuity_not_explicit",
        "docs_stale",
        "docs_missing",
        "matrix_partial",
        "matrix_missing",
        "known_limits_partially_disclosed",
        "known_limits_undisclosed",
        "tenant_region_ownership_not_declared",
        "policy_source_not_declared",
        "dependency_class_not_declared",
        "proof_stale",
        "profile_coverage_gap"
      ]
    },
    "enterprise_profile_token": {
      "type": "string",
      "enum": ["individual_local", "self_hosted", "enterprise_online", "air_gapped", "managed_cloud"]
    },
    "docs_state_token": {
      "type": "string",
      "enum": ["current", "stale", "missing", "not_applicable"]
    },
    "matrix_state_token": {
      "type": "string",
      "enum": ["complete", "partial", "missing", "not_applicable"]
    },
    "known_limits_state_token": {
      "type": "string",
      "enum": ["fully_disclosed", "partially_disclosed", "undisclosed", "not_applicable"]
    },
    "local_core_posture_token": {
      "type": "string",
      "enum": ["preserved", "impaired_managed_dependency", "blocked_by_default"]
    },
    "proof_currency_token": {
      "type": "string",
      "enum": ["current", "stale", "aspirational", "not_applicable"]
    },
    "docs_declaration": {
      "type": "object",
      "required": [
        "docs_state",
        "docs_state_token",
        "last_docs_build_ref",
        "last_docs_build_time",
        "freshness_window_token",
        "covered_doc_scope_labels",
        "missing_doc_scope_labels"
      ],
      "additionalProperties": false,
      "properties": {
        "docs_state": { "$ref": "#/$defs/docs_state_token" },
        "docs_state_token": { "$ref": "#/$defs/docs_state_token" },
        "last_docs_build_ref": { "type": "string" },
        "last_docs_build_time": { "type": "string" },
        "freshness_window_token": { "type": "string" },
        "covered_doc_scope_labels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missing_doc_scope_labels": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "matrix_declaration": {
      "type": "object",
      "required": [
        "matrix_state",
        "matrix_state_token",
        "matrix_ref",
        "last_published_time",
        "covered_capability_labels",
        "missing_capability_labels"
      ],
      "additionalProperties": false,
      "properties": {
        "matrix_state": { "$ref": "#/$defs/matrix_state_token" },
        "matrix_state_token": { "$ref": "#/$defs/matrix_state_token" },
        "matrix_ref": { "type": "string" },
        "last_published_time": { "type": "string" },
        "covered_capability_labels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missing_capability_labels": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "known_limits_declaration": {
      "type": "object",
      "required": [
        "known_limits_state",
        "known_limits_state_token",
        "disclosed_limit_count",
        "undisclosed_limit_count",
        "known_limit_index_ref",
        "disclosed_limitation_classes",
        "undisclosed_limitation_classes"
      ],
      "additionalProperties": false,
      "properties": {
        "known_limits_state": { "$ref": "#/$defs/known_limits_state_token" },
        "known_limits_state_token": { "$ref": "#/$defs/known_limits_state_token" },
        "disclosed_limit_count": { "type": "integer", "minimum": 0 },
        "undisclosed_limit_count": { "type": "integer", "minimum": 0 },
        "known_limit_index_ref": { "type": "string" },
        "disclosed_limitation_classes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "undisclosed_limitation_classes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "proof_currency_declaration": {
      "type": "object",
      "required": [
        "proof_currency",
        "proof_currency_token",
        "proof_packet_ref",
        "last_verified_time",
        "proof_validity_window_token"
      ],
      "additionalProperties": false,
      "properties": {
        "proof_currency": { "$ref": "#/$defs/proof_currency_token" },
        "proof_currency_token": { "$ref": "#/$defs/proof_currency_token" },
        "proof_packet_ref": { "type": "string" },
        "last_verified_time": { "type": "string" },
        "proof_validity_window_token": { "type": "string" }
      }
    },
    "policy_enterprise_docs_matrices_known_limits_row_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_id",
        "enterprise_profile",
        "enterprise_profile_token",
        "docs",
        "matrix",
        "known_limits",
        "proof_currency",
        "local_core_posture",
        "local_core_posture_token",
        "tenant_region_owner_ref",
        "policy_source_ref",
        "dependency_class_token",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_enterprise_docs_matrices_known_limits_row_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "row_id": { "$ref": "#/$defs/non_empty" },
        "enterprise_profile": { "$ref": "#/$defs/enterprise_profile_token" },
        "enterprise_profile_token": { "$ref": "#/$defs/enterprise_profile_token" },
        "docs": { "$ref": "#/$defs/docs_declaration" },
        "matrix": { "$ref": "#/$defs/matrix_declaration" },
        "known_limits": { "$ref": "#/$defs/known_limits_declaration" },
        "proof_currency": { "$ref": "#/$defs/proof_currency_declaration" },
        "local_core_posture": { "$ref": "#/$defs/local_core_posture_token" },
        "local_core_posture_token": { "$ref": "#/$defs/local_core_posture_token" },
        "tenant_region_owner_ref": { "type": "string" },
        "policy_source_ref": { "type": "string" },
        "dependency_class_token": { "type": "string" },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "type": "string" }
      }
    },
    "policy_enterprise_docs_matrices_known_limits_defect_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_enterprise_docs_matrices_known_limits_defect_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_id": { "$ref": "#/$defs/non_empty" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "$ref": "#/$defs/non_empty" },
        "note": { "type": "string" }
      }
    },
    "policy_enterprise_docs_matrices_known_limits_summary_record": {
      "type": "object",
      "required": [
        "row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "profiles_covered",
        "docs_current_row_count",
        "matrix_complete_row_count",
        "known_limits_fully_disclosed_row_count",
        "proof_current_row_count",
        "local_core_preserved_row_count",
        "overall_qualification_token"
      ],
      "additionalProperties": false,
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "profiles_covered": { "type": "array", "items": { "type": "string" } },
        "docs_current_row_count": { "type": "integer", "minimum": 0 },
        "matrix_complete_row_count": { "type": "integer", "minimum": 0 },
        "known_limits_fully_disclosed_row_count": { "type": "integer", "minimum": 0 },
        "proof_current_row_count": { "type": "integer", "minimum": 0 },
        "local_core_preserved_row_count": { "type": "integer", "minimum": 0 },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_token" }
      }
    },
    "policy_enterprise_docs_matrices_known_limits_page_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "page_id",
        "page_label",
        "generated_at",
        "summary",
        "rows",
        "defects"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_enterprise_docs_matrices_known_limits_page_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "page_id": { "$ref": "#/$defs/non_empty" },
        "page_label": { "type": "string" },
        "generated_at": { "$ref": "#/$defs/non_empty" },
        "summary": { "$ref": "#/$defs/policy_enterprise_docs_matrices_known_limits_summary_record" },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_enterprise_docs_matrices_known_limits_row_record" }
        },
        "defects": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_enterprise_docs_matrices_known_limits_defect_record" }
        }
      }
    },
    "policy_enterprise_docs_matrices_known_limits_support_export_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "export_id",
        "generated_at",
        "page",
        "narrow_reasons_present",
        "defect_counts_by_narrow_reason",
        "raw_private_material_excluded"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_enterprise_docs_matrices_known_limits_support_export_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "export_id": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "$ref": "#/$defs/non_empty" },
        "page": { "$ref": "#/$defs/policy_enterprise_docs_matrices_known_limits_page_record" },
        "narrow_reasons_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason_token" }
        },
        "defect_counts_by_narrow_reason": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "raw_private_material_excluded": { "type": "boolean", "const": true }
      }
    }
  }
}
