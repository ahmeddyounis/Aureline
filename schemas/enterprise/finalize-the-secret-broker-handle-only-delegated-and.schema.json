{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/enterprise/finalize-the-secret-broker-handle-only-delegated-and.schema.json",
  "title": "Aureline secret-broker finalize records",
  "description": "Boundary schema for the stable proof packet covering secret-broker handle-only, delegated, and session-only modes. Raw credentials, session tokens, vault entry bodies, raw handle ids, plaintext workspace-variable values, and secret material never cross this boundary.",
  "oneOf": [
    { "$ref": "#/$defs/policy_finalize_secret_broker_page_record" },
    { "$ref": "#/$defs/policy_finalize_secret_broker_row_record" },
    { "$ref": "#/$defs/policy_finalize_secret_broker_defect_record" },
    { "$ref": "#/$defs/policy_finalize_secret_broker_summary_record" },
    { "$ref": "#/$defs/policy_finalize_secret_broker_support_export_record" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "non_empty": { "type": "string", "minLength": 1 },
    "shared_contract_ref": {
      "type": "string",
      "const": "policy:finalize_secret_broker_handle_only_delegated:v1"
    },
    "qualification_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "beta_page_has_defects",
        "flow_class_coverage_gap",
        "handle_class_missing",
        "rotation_note_is_generic",
        "remembered_approval_not_narrow",
        "revocation_trigger_missing",
        "raw_secret_material_present",
        "literal_flattening_detected",
        "missing_handle_on_stable_claim"
      ]
    },
    "flow_class_token": {
      "type": "string",
      "enum": [
        "request_workspace",
        "database",
        "env_config",
        "provider",
        "managed_runtime"
      ]
    },
    "handle_class_token": {
      "type": "string",
      "enum": [
        "os_keychain",
        "enterprise_vault",
        "delegated_identity",
        "session_only",
        "workspace_variable",
        "missing"
      ]
    },
    "rotation_event_token": {
      "type": "string",
      "enum": [
        "rotated_by_issuer",
        "browser_device_code_renewal",
        "vault_keychain_loss",
        "handle_expired",
        "approval_revoked",
        "no_rotation_required"
      ]
    },
    "credential_rotation_state": {
      "type": "object",
      "required": [
        "rotation_event",
        "rotation_event_token",
        "rotation_note",
        "expires_at",
        "invalidates_remembered_decisions",
        "reapproval_path_available",
        "replay_posture_token"
      ],
      "additionalProperties": false,
      "properties": {
        "rotation_event": { "$ref": "#/$defs/rotation_event_token" },
        "rotation_event_token": { "$ref": "#/$defs/rotation_event_token" },
        "rotation_note": { "type": "string" },
        "expires_at": { "type": "string" },
        "invalidates_remembered_decisions": { "type": "boolean" },
        "reapproval_path_available": { "type": "boolean" },
        "replay_posture_token": {
          "type": "string",
          "enum": ["replay_safe", "replay_blocked", "replay_requires_reapproval"]
        }
      }
    },
    "remembered_approval_row": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "approval_row_id",
        "actor_ref",
        "target_ref",
        "action_family_token",
        "environment_token",
        "expiry_window",
        "bound_handle_class_token",
        "revocation_trigger_token",
        "is_valid",
        "reapproval_trigger_note",
        "raw_credential_excluded"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_finalize_secret_broker_remembered_approval_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "approval_row_id": { "$ref": "#/$defs/non_empty" },
        "actor_ref": { "type": "string" },
        "target_ref": { "type": "string" },
        "action_family_token": { "type": "string" },
        "environment_token": { "type": "string" },
        "expiry_window": { "type": "string" },
        "bound_handle_class_token": { "$ref": "#/$defs/handle_class_token" },
        "revocation_trigger_token": { "type": "string" },
        "is_valid": { "type": "boolean" },
        "reapproval_trigger_note": { "type": "string" },
        "raw_credential_excluded": { "type": "boolean", "const": true }
      }
    },
    "policy_finalize_secret_broker_row_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_id",
        "flow_class",
        "flow_class_token",
        "handle_class",
        "handle_class_token",
        "profile_token",
        "secret_class_token",
        "beta_row_ref",
        "rotation_state",
        "remembered_approvals",
        "raw_secret_material_excluded",
        "no_literal_flattening",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_finalize_secret_broker_row_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "row_id": { "$ref": "#/$defs/non_empty" },
        "flow_class": { "$ref": "#/$defs/flow_class_token" },
        "flow_class_token": { "$ref": "#/$defs/flow_class_token" },
        "handle_class": { "$ref": "#/$defs/handle_class_token" },
        "handle_class_token": { "$ref": "#/$defs/handle_class_token" },
        "profile_token": { "type": "string" },
        "secret_class_token": { "type": "string" },
        "beta_row_ref": { "type": "string" },
        "rotation_state": { "$ref": "#/$defs/credential_rotation_state" },
        "remembered_approvals": {
          "type": "array",
          "items": { "$ref": "#/$defs/remembered_approval_row" }
        },
        "raw_secret_material_excluded": { "type": "boolean", "const": true },
        "no_literal_flattening": { "type": "boolean", "const": true },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "type": "string" }
      }
    },
    "policy_finalize_secret_broker_defect_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source_row_id",
        "note"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_finalize_secret_broker_defect_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_id": { "$ref": "#/$defs/non_empty" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source_row_id": { "$ref": "#/$defs/non_empty" },
        "note": { "$ref": "#/$defs/non_empty" }
      }
    },
    "policy_finalize_secret_broker_summary_record": {
      "type": "object",
      "required": [
        "record_kind",
        "row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "flow_classes_covered",
        "handle_classes_present",
        "profiles_covered",
        "delegated_identity_row_count",
        "session_only_row_count",
        "remembered_approval_count",
        "defect_count",
        "defect_counts_by_narrow_reason",
        "beta_page_defect_count",
        "overall_qualification_token"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_finalize_secret_broker_summary_record"
        },
        "row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "flow_classes_covered": {
          "type": "array",
          "items": { "$ref": "#/$defs/flow_class_token" }
        },
        "handle_classes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/handle_class_token" }
        },
        "profiles_covered": {
          "type": "array",
          "items": { "type": "string" }
        },
        "delegated_identity_row_count": { "type": "integer", "minimum": 0 },
        "session_only_row_count": { "type": "integer", "minimum": 0 },
        "remembered_approval_count": { "type": "integer", "minimum": 0 },
        "defect_count": { "type": "integer", "minimum": 0 },
        "defect_counts_by_narrow_reason": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "beta_page_defect_count": { "type": "integer", "minimum": 0 },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_token" }
      }
    },
    "policy_finalize_secret_broker_page_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "page_id",
        "page_label",
        "generated_at",
        "summary",
        "rows",
        "defects",
        "beta_page"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_finalize_secret_broker_page_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "page_id": { "$ref": "#/$defs/non_empty" },
        "page_label": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "type": "string" },
        "summary": { "$ref": "#/$defs/policy_finalize_secret_broker_summary_record" },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_finalize_secret_broker_row_record" }
        },
        "defects": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_finalize_secret_broker_defect_record" }
        },
        "beta_page": { "type": "object" }
      }
    },
    "policy_finalize_secret_broker_support_export_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "export_id",
        "generated_at",
        "page",
        "narrow_reasons_present",
        "defect_counts_by_narrow_reason",
        "beta_support_export",
        "raw_secret_values_excluded",
        "raw_handle_ids_excluded",
        "remembered_approval_lineage_preserved"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_finalize_secret_broker_support_export_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "export_id": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "type": "string" },
        "page": { "$ref": "#/$defs/policy_finalize_secret_broker_page_record" },
        "narrow_reasons_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason_token" }
        },
        "defect_counts_by_narrow_reason": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "beta_support_export": { "type": "object" },
        "raw_secret_values_excluded": { "type": "boolean", "const": true },
        "raw_handle_ids_excluded": { "type": "boolean", "const": true },
        "remembered_approval_lineage_preserved": { "type": "boolean", "const": true }
      }
    }
  }
}
