{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/enterprise/stabilize-effective-policy-remembered-decision-waiver-expiry-and.schema.json",
  "title": "Aureline effective-policy stabilize records",
  "description": "Boundary schema for the stable proof packet that promotes the beta policy simulation page to a verified stable claim. Covers effective-policy simulation previews, remembered-decision drift, waiver/exception expiry, and exception-preview UX links. Raw policy bundle bodies, raw rule text, raw identities, raw credentials, and secret material never cross this boundary.",
  "oneOf": [
    { "$ref": "#/$defs/policy_effective_policy_stabilize_page_record" },
    { "$ref": "#/$defs/policy_effective_policy_stabilize_row_record" },
    { "$ref": "#/$defs/policy_effective_policy_stabilize_defect_record" },
    { "$ref": "#/$defs/policy_effective_policy_stabilize_support_export_record" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "non_empty": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "shared_contract_ref": {
      "type": "string",
      "const": "policy:effective_policy_stabilize:v1"
    },
    "qualification_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "policy_simulation_beta_page_has_defects",
        "required_change_class_missing",
        "exception_preview_links_missing",
        "exception_missing_bounded_expiry",
        "remembered_decision_drift_unexplained",
        "support_export_drops_historical_truth",
        "raw_private_material_exposed"
      ]
    },
    "policy_effective_policy_stabilize_row_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "simulation_id",
        "change_class_token",
        "scope_ref_id",
        "exception_preview_count",
        "expiring_exception_count",
        "remembered_decision_count",
        "drifted_remembered_decision_count",
        "action_time_policy_state_present",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "policy_effective_policy_stabilize_row_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "simulation_id": { "$ref": "#/$defs/non_empty" },
        "change_class_token": {
          "type": "string",
          "enum": ["policy_bundle_change", "settings_lock_change"]
        },
        "scope_ref_id": { "$ref": "#/$defs/non_empty" },
        "exception_preview_count": { "type": "integer", "minimum": 0 },
        "expiring_exception_count": { "type": "integer", "minimum": 0 },
        "remembered_decision_count": { "type": "integer", "minimum": 0 },
        "drifted_remembered_decision_count": { "type": "integer", "minimum": 0 },
        "action_time_policy_state_present": { "type": "boolean" },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "$ref": "#/$defs/non_empty" }
      },
      "additionalProperties": false
    },
    "policy_effective_policy_stabilize_defect_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "policy_effective_policy_stabilize_defect_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_id": { "$ref": "#/$defs/non_empty" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "$ref": "#/$defs/non_empty" },
        "note": { "$ref": "#/$defs/non_empty" }
      },
      "additionalProperties": false
    },
    "stabilize_summary": {
      "type": "object",
      "required": [
        "row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "simulation_beta_page_defect_count",
        "change_classes_covered",
        "expiring_exception_count",
        "drifted_remembered_decision_count",
        "overall_qualification_token"
      ],
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "simulation_beta_page_defect_count": { "type": "integer", "minimum": 0 },
        "change_classes_covered": { "type": "array", "items": { "type": "string" } },
        "expiring_exception_count": { "type": "integer", "minimum": 0 },
        "drifted_remembered_decision_count": { "type": "integer", "minimum": 0 },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_token" }
      },
      "additionalProperties": false
    },
    "policy_effective_policy_stabilize_page_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "page_id",
        "page_label",
        "generated_at",
        "summary",
        "rows",
        "defects",
        "simulation_beta_page"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "policy_effective_policy_stabilize_page_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "page_id": { "$ref": "#/$defs/non_empty" },
        "page_label": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "type": "string" },
        "summary": { "$ref": "#/$defs/stabilize_summary" },
        "rows": { "type": "array", "items": { "$ref": "#/$defs/policy_effective_policy_stabilize_row_record" } },
        "defects": { "type": "array", "items": { "$ref": "#/$defs/policy_effective_policy_stabilize_defect_record" } },
        "simulation_beta_page": { "type": "object" }
      },
      "additionalProperties": false
    },
    "policy_effective_policy_stabilize_support_export_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "export_id",
        "generated_at",
        "page",
        "narrow_reasons_present",
        "defect_counts_by_narrow_reason",
        "simulation_support_export",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "policy_effective_policy_stabilize_support_export_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "export_id": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "type": "string" },
        "page": { "$ref": "#/$defs/policy_effective_policy_stabilize_page_record" },
        "narrow_reasons_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason_token" }
        },
        "defect_counts_by_narrow_reason": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "simulation_support_export": { "type": "object" },
        "raw_private_material_excluded": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    }
  }
}
