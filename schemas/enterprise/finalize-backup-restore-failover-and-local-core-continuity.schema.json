{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/enterprise/finalize-backup-restore-failover-and-local-core-continuity.schema.json",
  "title": "Aureline backup, restore, failover, and local-core continuity finalize records",
  "description": "Boundary schema for the beta proof packet covering backup state, restore test posture, failover behavior, and local-core continuity across claimed enterprise deployment profiles. Raw backup artefacts, raw hostnames, raw tenant identifiers, raw key bytes, and raw credentials never cross this boundary.",
  "oneOf": [
    { "$ref": "#/$defs/policy_backup_restore_failover_continuity_page_record" },
    { "$ref": "#/$defs/policy_backup_restore_failover_continuity_row_record" },
    { "$ref": "#/$defs/policy_backup_restore_failover_continuity_defect_record" },
    { "$ref": "#/$defs/policy_backup_restore_failover_continuity_summary_record" },
    { "$ref": "#/$defs/policy_backup_restore_failover_continuity_support_export_record" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "non_empty": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "shared_contract_ref": {
      "type": "string",
      "const": "policy:backup_restore_failover_continuity:v1"
    },
    "qualification_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "local_core_blocked_by_failover",
        "local_core_continuity_not_explicit",
        "backup_state_unverified",
        "backup_state_overdue",
        "restore_never_drilled",
        "restore_drill_overdue",
        "failover_behavior_not_declared",
        "tenant_region_ownership_not_declared",
        "policy_source_not_declared",
        "dependency_class_not_declared",
        "profile_coverage_gap"
      ]
    },
    "enterprise_profile_token": {
      "type": "string",
      "enum": ["individual_local", "self_hosted", "enterprise_online", "air_gapped", "managed_cloud"]
    },
    "backup_state_token": {
      "type": "string",
      "enum": ["current", "pending", "overdue", "unverified", "not_applicable"]
    },
    "restore_test_posture_token": {
      "type": "string",
      "enum": ["tested_and_current", "tested_overdue", "never_tested", "not_applicable"]
    },
    "failover_behavior_token": {
      "type": "string",
      "enum": [
        "local_core_preserved",
        "degraded_managed_only",
        "local_core_may_be_impaired",
        "local_core_blocked",
        "not_applicable"
      ]
    },
    "local_core_posture_token": {
      "type": "string",
      "enum": ["preserved", "impaired_managed_dependency", "blocked_by_default"]
    },
    "backup_declaration": {
      "type": "object",
      "required": [
        "backup_state",
        "backup_state_token",
        "last_backup_ref",
        "last_backup_time",
        "retention_window_token",
        "backup_target_region_owner_ref",
        "included_data_scope_labels",
        "excluded_data_scope_labels"
      ],
      "additionalProperties": false,
      "properties": {
        "backup_state": { "$ref": "#/$defs/backup_state_token" },
        "backup_state_token": { "$ref": "#/$defs/backup_state_token" },
        "last_backup_ref": { "type": "string" },
        "last_backup_time": { "type": "string" },
        "retention_window_token": { "type": "string" },
        "backup_target_region_owner_ref": { "type": "string" },
        "included_data_scope_labels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excluded_data_scope_labels": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "restore_test_declaration": {
      "type": "object",
      "required": [
        "restore_test_posture",
        "restore_test_posture_token",
        "last_drill_time",
        "drill_valid_until",
        "rto_token",
        "rpo_token",
        "restore_scope_label"
      ],
      "additionalProperties": false,
      "properties": {
        "restore_test_posture": { "$ref": "#/$defs/restore_test_posture_token" },
        "restore_test_posture_token": { "$ref": "#/$defs/restore_test_posture_token" },
        "last_drill_time": { "type": "string" },
        "drill_valid_until": { "type": "string" },
        "rto_token": { "type": "string" },
        "rpo_token": { "type": "string" },
        "restore_scope_label": { "type": "string" }
      }
    },
    "failover_continuity_declaration": {
      "type": "object",
      "required": [
        "failover_behavior",
        "failover_behavior_token",
        "local_core_posture",
        "local_core_posture_token",
        "local_capabilities_during_failover",
        "degraded_managed_capabilities",
        "managed_dependency_ref",
        "downgrade_label"
      ],
      "additionalProperties": false,
      "properties": {
        "failover_behavior": { "$ref": "#/$defs/failover_behavior_token" },
        "failover_behavior_token": { "$ref": "#/$defs/failover_behavior_token" },
        "local_core_posture": { "$ref": "#/$defs/local_core_posture_token" },
        "local_core_posture_token": { "$ref": "#/$defs/local_core_posture_token" },
        "local_capabilities_during_failover": {
          "type": "array",
          "items": { "type": "string" }
        },
        "degraded_managed_capabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "managed_dependency_ref": { "type": "string" },
        "downgrade_label": { "type": "string" }
      }
    },
    "policy_backup_restore_failover_continuity_row_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_id",
        "enterprise_profile",
        "enterprise_profile_token",
        "backup",
        "restore",
        "failover_continuity",
        "tenant_region_owner_ref",
        "policy_source_ref",
        "dependency_class_token",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_backup_restore_failover_continuity_row_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "row_id": { "$ref": "#/$defs/non_empty" },
        "enterprise_profile": { "$ref": "#/$defs/enterprise_profile_token" },
        "enterprise_profile_token": { "$ref": "#/$defs/enterprise_profile_token" },
        "backup": { "$ref": "#/$defs/backup_declaration" },
        "restore": { "$ref": "#/$defs/restore_test_declaration" },
        "failover_continuity": { "$ref": "#/$defs/failover_continuity_declaration" },
        "tenant_region_owner_ref": { "type": "string" },
        "policy_source_ref": { "type": "string" },
        "dependency_class_token": { "type": "string" },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "type": "string" }
      }
    },
    "policy_backup_restore_failover_continuity_defect_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_backup_restore_failover_continuity_defect_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_id": { "$ref": "#/$defs/non_empty" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "$ref": "#/$defs/non_empty" },
        "note": { "type": "string" }
      }
    },
    "policy_backup_restore_failover_continuity_summary_record": {
      "type": "object",
      "required": [
        "row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "profiles_covered",
        "local_core_preserved_row_count",
        "backup_current_row_count",
        "restore_tested_row_count",
        "failover_non_blocking_row_count",
        "overall_qualification_token"
      ],
      "additionalProperties": false,
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "profiles_covered": { "type": "array", "items": { "type": "string" } },
        "local_core_preserved_row_count": { "type": "integer", "minimum": 0 },
        "backup_current_row_count": { "type": "integer", "minimum": 0 },
        "restore_tested_row_count": { "type": "integer", "minimum": 0 },
        "failover_non_blocking_row_count": { "type": "integer", "minimum": 0 },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_token" }
      }
    },
    "policy_backup_restore_failover_continuity_page_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "page_id",
        "page_label",
        "generated_at",
        "summary",
        "rows",
        "defects"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_backup_restore_failover_continuity_page_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "page_id": { "$ref": "#/$defs/non_empty" },
        "page_label": { "type": "string" },
        "generated_at": { "$ref": "#/$defs/non_empty" },
        "summary": { "$ref": "#/$defs/policy_backup_restore_failover_continuity_summary_record" },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_backup_restore_failover_continuity_row_record" }
        },
        "defects": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_backup_restore_failover_continuity_defect_record" }
        }
      }
    },
    "policy_backup_restore_failover_continuity_support_export_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "export_id",
        "generated_at",
        "page",
        "narrow_reasons_present",
        "defect_counts_by_narrow_reason",
        "raw_private_material_excluded"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_backup_restore_failover_continuity_support_export_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "export_id": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "$ref": "#/$defs/non_empty" },
        "page": { "$ref": "#/$defs/policy_backup_restore_failover_continuity_page_record" },
        "narrow_reasons_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason_token" }
        },
        "defect_counts_by_narrow_reason": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "raw_private_material_excluded": { "type": "boolean", "const": true }
      }
    }
  }
}
