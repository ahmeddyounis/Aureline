{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/enterprise/harden-os-keychain-and-trust-store-integration-trust.schema.json",
  "title": "Aureline hardened OS keychain and trust-store integration records",
  "description": "Boundary schema for the proof packet covering hardened OS keychain and trust-store integration, trust-store change detection, and repair-safe copy. Records a layered model distinguishing OS roots, custom CA bundles, pinned SSH host proofs, client-certificate material, and imported mirror trust roots. Trust-store changes emit attributable repair-safe events with layer attribution, affected-route declarations, local-continuity guarantees, and typed repair actions. Raw certificate bodies, private keys, raw fingerprints, and secret material never cross this boundary.",
  "oneOf": [
    { "$ref": "#/$defs/policy_harden_os_keychain_trust_store_page_record" },
    { "$ref": "#/$defs/policy_harden_os_keychain_trust_store_row_record" },
    { "$ref": "#/$defs/policy_harden_os_keychain_trust_store_change_event_record" },
    { "$ref": "#/$defs/policy_harden_os_keychain_trust_store_defect_record" },
    { "$ref": "#/$defs/policy_harden_os_keychain_trust_store_summary_record" },
    { "$ref": "#/$defs/policy_harden_os_keychain_trust_store_support_export_record" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "non_empty": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "shared_contract_ref": {
      "type": "string",
      "const": "policy:harden_os_keychain_trust_store:v1"
    },
    "qualification_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "trust_store_layer_token": {
      "type": "string",
      "enum": [
        "os_roots",
        "custom_ca_bundle",
        "pinned_ssh_host_proof",
        "client_certificate",
        "mirror_trust_root"
      ]
    },
    "trust_store_layer_health_token": {
      "type": "string",
      "enum": [
        "active",
        "pending_revalidation",
        "absent",
        "expired_or_revoked",
        "degraded",
        "inaccessible"
      ]
    },
    "trust_store_change_class_token": {
      "type": "string",
      "enum": ["added", "removed", "modified", "replaced", "revoked"]
    },
    "trust_store_change_attribution_token": {
      "type": "string",
      "enum": [
        "os_platform_update",
        "admin_policy_push",
        "manual_admin_import",
        "mirror_sync",
        "material_expiry",
        "revocation_signal",
        "keychain_relocked"
      ]
    },
    "session_impact_token": {
      "type": "string",
      "enum": [
        "no_impact",
        "revalidation_required",
        "session_must_pause",
        "route_blocked_local_continuity",
        "route_blocked_no_local_fallback"
      ]
    },
    "repair_action_token": {
      "type": "string",
      "enum": [
        "none_required",
        "revalidate_os_roots",
        "apply_and_revalidate_custom_ca_bundle",
        "reenroll_ssh_host_proof",
        "reenroll_client_certificate",
        "refresh_mirror_trust_root",
        "import_signed_mirror_root",
        "unlock_os_keychain",
        "contact_admin_for_updated_bundle",
        "wait_for_os_platform_update"
      ]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "missing_layer_coverage",
        "change_event_missing_attribution",
        "change_event_missing_repair_action",
        "change_event_missing_affected_routes",
        "change_event_missing_managed_policy_ref",
        "local_continuity_not_explicit",
        "repair_transaction_id_missing",
        "raw_trust_material_exposed"
      ]
    },
    "policy_harden_os_keychain_trust_store_change_event_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "repair_transaction_id",
        "layer",
        "layer_token",
        "change_class",
        "change_class_token",
        "attribution",
        "attribution_token",
        "attribution_label",
        "managed_policy_ref",
        "affected_route_refs",
        "affected_sessions_label",
        "session_impact",
        "session_impact_token",
        "local_continuity_explicit",
        "local_continuity_label",
        "repair_action",
        "repair_action_token",
        "repair_action_label",
        "raw_trust_material_excluded",
        "observed_at"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "policy_harden_os_keychain_trust_store_change_event_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "repair_transaction_id": { "$ref": "#/$defs/non_empty" },
        "layer": { "$ref": "#/$defs/trust_store_layer_token" },
        "layer_token": { "$ref": "#/$defs/trust_store_layer_token" },
        "change_class": { "$ref": "#/$defs/trust_store_change_class_token" },
        "change_class_token": { "$ref": "#/$defs/trust_store_change_class_token" },
        "attribution": { "$ref": "#/$defs/trust_store_change_attribution_token" },
        "attribution_token": { "$ref": "#/$defs/trust_store_change_attribution_token" },
        "attribution_label": { "type": "string" },
        "managed_policy_ref": { "type": "string" },
        "affected_route_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "affected_sessions_label": { "type": "string" },
        "session_impact": { "$ref": "#/$defs/session_impact_token" },
        "session_impact_token": { "$ref": "#/$defs/session_impact_token" },
        "local_continuity_explicit": { "type": "boolean" },
        "local_continuity_label": { "type": "string" },
        "repair_action": { "$ref": "#/$defs/repair_action_token" },
        "repair_action_token": { "$ref": "#/$defs/repair_action_token" },
        "repair_action_label": { "type": "string" },
        "raw_trust_material_excluded": { "type": "boolean", "const": true },
        "observed_at": { "type": "string" }
      }
    },
    "policy_harden_os_keychain_trust_store_row_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_id",
        "layer",
        "layer_token",
        "health",
        "health_token",
        "health_label",
        "governance_source_label",
        "managed_attribution_ref",
        "local_continuity_explicit",
        "local_continuity_label",
        "repair_action",
        "repair_action_token",
        "raw_trust_material_excluded",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "policy_harden_os_keychain_trust_store_row_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "row_id": { "$ref": "#/$defs/non_empty" },
        "layer": { "$ref": "#/$defs/trust_store_layer_token" },
        "layer_token": { "$ref": "#/$defs/trust_store_layer_token" },
        "health": { "$ref": "#/$defs/trust_store_layer_health_token" },
        "health_token": { "$ref": "#/$defs/trust_store_layer_health_token" },
        "health_label": { "type": "string" },
        "governance_source_label": { "type": "string" },
        "managed_attribution_ref": { "type": "string" },
        "local_continuity_explicit": { "type": "boolean" },
        "local_continuity_label": { "type": "string" },
        "repair_action": { "$ref": "#/$defs/repair_action_token" },
        "repair_action_token": { "$ref": "#/$defs/repair_action_token" },
        "raw_trust_material_excluded": { "type": "boolean", "const": true },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "type": "string" }
      }
    },
    "policy_harden_os_keychain_trust_store_defect_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "policy_harden_os_keychain_trust_store_defect_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_id": { "$ref": "#/$defs/non_empty" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "$ref": "#/$defs/non_empty" },
        "note": { "$ref": "#/$defs/non_empty" }
      }
    },
    "policy_harden_os_keychain_trust_store_summary_record": {
      "type": "object",
      "required": [
        "row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "layers_covered",
        "health_states_present",
        "change_event_count",
        "repair_transaction_ids_present",
        "local_continuity_explicit_row_count",
        "raw_material_excluded_row_count",
        "overall_qualification_token"
      ],
      "additionalProperties": false,
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "layers_covered": {
          "type": "array",
          "items": { "$ref": "#/$defs/trust_store_layer_token" }
        },
        "health_states_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/trust_store_layer_health_token" }
        },
        "change_event_count": { "type": "integer", "minimum": 0 },
        "repair_transaction_ids_present": {
          "type": "array",
          "items": { "type": "string" }
        },
        "local_continuity_explicit_row_count": { "type": "integer", "minimum": 0 },
        "raw_material_excluded_row_count": { "type": "integer", "minimum": 0 },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_token" }
      }
    },
    "policy_harden_os_keychain_trust_store_page_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "page_id",
        "page_label",
        "generated_at",
        "summary",
        "rows",
        "change_events",
        "defects"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "policy_harden_os_keychain_trust_store_page_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "page_id": { "$ref": "#/$defs/non_empty" },
        "page_label": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "type": "string" },
        "summary": { "$ref": "#/$defs/policy_harden_os_keychain_trust_store_summary_record" },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_harden_os_keychain_trust_store_row_record" }
        },
        "change_events": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_harden_os_keychain_trust_store_change_event_record" }
        },
        "defects": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_harden_os_keychain_trust_store_defect_record" }
        }
      }
    },
    "policy_harden_os_keychain_trust_store_support_export_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "export_id",
        "generated_at",
        "page",
        "narrow_reasons_present",
        "defect_counts_by_narrow_reason",
        "raw_trust_material_excluded"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "policy_harden_os_keychain_trust_store_support_export_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "export_id": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "type": "string" },
        "page": { "$ref": "#/$defs/policy_harden_os_keychain_trust_store_page_record" },
        "narrow_reasons_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason_token" }
        },
        "defect_counts_by_narrow_reason": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "raw_trust_material_excluded": { "type": "boolean", "const": true }
      }
    }
  }
}
