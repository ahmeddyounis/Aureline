{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/enterprise/harden-identity-and-admin-support-export-parity-audit.schema.json",
  "title": "Aureline identity and admin support-export parity harden records",
  "description": "Boundary schema for the proof packet covering hardened identity and admin support-export parity, audit-safe redaction, and no-vendor-control-plane local governance paths. Raw tenant data, raw user emails, raw provisioning payloads, raw policy bundles, raw credentials, and secret material never cross this boundary.",
  "oneOf": [
    { "$ref": "#/$defs/policy_harden_identity_admin_page_record" },
    { "$ref": "#/$defs/policy_harden_identity_admin_row_record" },
    { "$ref": "#/$defs/policy_harden_identity_admin_defect_record" },
    { "$ref": "#/$defs/policy_harden_identity_admin_summary_record" },
    { "$ref": "#/$defs/policy_harden_identity_admin_support_export_record" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "non_empty": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "shared_contract_ref": {
      "type": "string",
      "const": "policy:harden_identity_admin_support_export_parity:v1"
    },
    "qualification_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "row_class_token": {
      "type": "string",
      "enum": [
        "directory_provider_card",
        "user_seat_lifecycle",
        "provisioning_failure_log",
        "policy_target_dry_run",
        "local_governance_path"
      ]
    },
    "provisioning_class_token": {
      "type": "string",
      "enum": ["oidc", "scim", "signed_file_bundle", "manual"]
    },
    "sync_freshness_token": {
      "type": "string",
      "enum": ["live", "cached", "stale", "expired", "missing"]
    },
    "local_tenant_scope_token": {
      "type": "string",
      "enum": ["local_state_only", "tenant_scoped", "hybrid_local_tenant"]
    },
    "failure_kind_token": {
      "type": "string",
      "enum": [
        "provider_outage",
        "auth_drift",
        "scope_mismatch",
        "seat_loss",
        "deprovisioning_impact"
      ]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "missing_row_class_coverage",
        "missing_provisioning_class",
        "missing_sync_freshness",
        "missing_local_tenant_scope",
        "generic_failure_kind_used",
        "local_core_continuity_not_explicit",
        "missing_fallback_manual_path",
        "raw_secret_or_private_material_exposed",
        "missing_action_lineage"
      ]
    },
    "admin_action_lineage": {
      "type": "object",
      "required": [
        "action_token",
        "action_label",
        "result_token",
        "result_label",
        "actor_ref",
        "applied_at",
        "transaction_id"
      ],
      "additionalProperties": false,
      "properties": {
        "action_token": { "type": "string" },
        "action_label": { "type": "string" },
        "result_token": { "type": "string" },
        "result_label": { "type": "string" },
        "actor_ref": { "type": "string" },
        "applied_at": { "type": "string" },
        "transaction_id": { "type": "string" }
      }
    },
    "policy_harden_identity_admin_row_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_id",
        "row_class",
        "row_class_token",
        "provisioning_class",
        "provisioning_class_token",
        "sync_freshness",
        "sync_freshness_token",
        "fallback_manual_path_label",
        "local_artifact_safety_note",
        "local_tenant_scope",
        "local_tenant_scope_token",
        "local_core_continuity_explicit",
        "raw_secret_or_private_material_excluded",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "policy_harden_identity_admin_row_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "row_id": { "$ref": "#/$defs/non_empty" },
        "row_class": { "$ref": "#/$defs/row_class_token" },
        "row_class_token": { "$ref": "#/$defs/row_class_token" },
        "provisioning_class": { "$ref": "#/$defs/provisioning_class_token" },
        "provisioning_class_token": { "$ref": "#/$defs/provisioning_class_token" },
        "sync_freshness": { "$ref": "#/$defs/sync_freshness_token" },
        "sync_freshness_token": { "$ref": "#/$defs/sync_freshness_token" },
        "fallback_manual_path_label": { "type": "string" },
        "local_artifact_safety_note": { "type": "string" },
        "local_tenant_scope": { "$ref": "#/$defs/local_tenant_scope_token" },
        "local_tenant_scope_token": { "$ref": "#/$defs/local_tenant_scope_token" },
        "action_lineage": { "$ref": "#/$defs/admin_action_lineage" },
        "failure_kind": { "$ref": "#/$defs/failure_kind_token" },
        "failure_kind_token": { "type": "string" },
        "local_core_continuity_explicit": { "type": "boolean" },
        "raw_secret_or_private_material_excluded": { "type": "boolean" },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "type": "string" }
      }
    },
    "policy_harden_identity_admin_defect_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "policy_harden_identity_admin_defect_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_id": { "$ref": "#/$defs/non_empty" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "$ref": "#/$defs/non_empty" },
        "note": { "$ref": "#/$defs/non_empty" }
      }
    },
    "policy_harden_identity_admin_summary_record": {
      "type": "object",
      "required": [
        "row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "row_classes_covered",
        "provisioning_classes_present",
        "sync_freshness_present",
        "local_tenant_scopes_present",
        "failure_kinds_present",
        "local_core_continuity_explicit_row_count",
        "raw_secret_excluded_row_count",
        "action_lineage_row_count",
        "overall_qualification_token"
      ],
      "additionalProperties": false,
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "row_classes_covered": {
          "type": "array",
          "items": { "$ref": "#/$defs/row_class_token" }
        },
        "provisioning_classes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/provisioning_class_token" }
        },
        "sync_freshness_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/sync_freshness_token" }
        },
        "local_tenant_scopes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/local_tenant_scope_token" }
        },
        "failure_kinds_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/failure_kind_token" }
        },
        "local_core_continuity_explicit_row_count": { "type": "integer", "minimum": 0 },
        "raw_secret_excluded_row_count": { "type": "integer", "minimum": 0 },
        "action_lineage_row_count": { "type": "integer", "minimum": 0 },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_token" }
      }
    },
    "policy_harden_identity_admin_page_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "page_id",
        "page_label",
        "generated_at",
        "summary",
        "rows",
        "defects"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "policy_harden_identity_admin_page_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "page_id": { "$ref": "#/$defs/non_empty" },
        "page_label": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "type": "string" },
        "summary": { "$ref": "#/$defs/policy_harden_identity_admin_summary_record" },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_harden_identity_admin_row_record" }
        },
        "defects": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_harden_identity_admin_defect_record" }
        }
      }
    },
    "policy_harden_identity_admin_support_export_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "export_id",
        "generated_at",
        "page",
        "narrow_reasons_present",
        "defect_counts_by_narrow_reason",
        "raw_secret_or_private_material_excluded"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "policy_harden_identity_admin_support_export_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "export_id": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "type": "string" },
        "page": { "$ref": "#/$defs/policy_harden_identity_admin_page_record" },
        "narrow_reasons_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason_token" }
        },
        "defect_counts_by_narrow_reason": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "raw_secret_or_private_material_excluded": { "type": "boolean", "const": true }
      }
    }
  }
}
