{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/enterprise/harden-the-connected-provider-registry-capability-matrix-and.schema.json",
  "title": "Aureline connected-provider registry hardening proof packet",
  "description": "Boundary schema for the stable ProviderRegistryPage proof packet. The packet carries typed provider family, acting identity class, callback/ingress path, supported object kinds with inspect-vs-mutate posture, snapshot freshness, dependency class, and local-core continuity for every claimed (provider_family × actor_identity) pair. Raw provider URLs, raw tokens, raw callback bodies, raw private keys, and raw policy bundle content are excluded; only closed-vocabulary tokens, opaque refs, plain-language summary sentences, and schema-version integers cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "page_label",
    "generated_at",
    "summary",
    "rows",
    "defects",
    "descriptor_snapshot"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "record_kind": {
      "type": "string",
      "const": "remote_provider_registry_page_record"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "remote:provider_registry_harden:v1"
    },
    "page_id": { "$ref": "#/$defs/opaque_id" },
    "page_label": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
    "summary": { "$ref": "#/$defs/provider_registry_summary" },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/provider_registry_row" }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/provider_registry_defect" }
    },
    "descriptor_snapshot": { "$ref": "#/$defs/provider_descriptor_snapshot" }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 800
    },
    "provider_family_token": {
      "type": "string",
      "enum": ["code_host", "issue_tracker", "ci_checks"]
    },
    "actor_identity_token": {
      "type": "string",
      "enum": [
        "human_account",
        "installation_grant",
        "delegated_credential",
        "local_only_no_account"
      ]
    },
    "callback_path_token": {
      "type": "string",
      "enum": [
        "public_saas",
        "mirrored_ingress",
        "customer_controlled",
        "polling_or_import_only"
      ]
    },
    "object_kind_token": {
      "type": "string",
      "enum": [
        "pull_request",
        "branch",
        "issue_or_work_item",
        "check_run",
        "pipeline_run"
      ]
    },
    "mutation_posture_token": {
      "type": "string",
      "enum": [
        "inspect_only",
        "mutate_allowed",
        "browser_only_mutate",
        "publish_later_only"
      ]
    },
    "publish_mode_token": {
      "type": "string",
      "enum": [
        "local_draft",
        "publish_now",
        "open_in_provider",
        "publish_later_queue",
        "inspect_only"
      ]
    },
    "snapshot_freshness_token": {
      "type": "string",
      "enum": [
        "fresh",
        "stale_within_window",
        "expired_beyond_window",
        "revoked_or_disconnected"
      ]
    },
    "dependency_class_token": {
      "type": "string",
      "enum": ["local_only", "network", "managed", "air_gapped"]
    },
    "qualification_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "raw_private_material_exposed",
        "required_row_missing",
        "local_core_continuity_undeclared",
        "dependency_class_undeclared",
        "callback_path_undeclared",
        "object_support_undeclared"
      ]
    },
    "object_support_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_kind",
        "object_kind_token",
        "mutation_posture",
        "mutation_posture_token",
        "supported_publish_modes",
        "supported_publish_mode_tokens",
        "browser_handoff_required",
        "offline_publish_later_supported"
      ],
      "properties": {
        "object_kind": { "$ref": "#/$defs/object_kind_token" },
        "object_kind_token": { "$ref": "#/$defs/object_kind_token" },
        "mutation_posture": { "$ref": "#/$defs/mutation_posture_token" },
        "mutation_posture_token": { "$ref": "#/$defs/mutation_posture_token" },
        "supported_publish_modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/publish_mode_token" },
          "minItems": 1,
          "uniqueItems": true
        },
        "supported_publish_mode_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/publish_mode_token" },
          "minItems": 1
        },
        "browser_handoff_required": { "type": "boolean" },
        "offline_publish_later_supported": { "type": "boolean" }
      }
    },
    "provider_descriptor_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "provider_family",
        "provider_family_token",
        "actor_identity",
        "actor_identity_token",
        "canonical_host_ref",
        "callback_path",
        "callback_path_token",
        "object_support",
        "snapshot_freshness",
        "snapshot_freshness_token",
        "local_core_continuity_allowed",
        "dependency_class",
        "dependency_class_token",
        "raw_private_material_excluded",
        "summary"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "remote_provider_descriptor_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "remote:provider_registry_harden:v1" },
        "provider_family": { "$ref": "#/$defs/provider_family_token" },
        "provider_family_token": { "$ref": "#/$defs/provider_family_token" },
        "actor_identity": { "$ref": "#/$defs/actor_identity_token" },
        "actor_identity_token": { "$ref": "#/$defs/actor_identity_token" },
        "canonical_host_ref": { "$ref": "#/$defs/opaque_id" },
        "tenant_or_org_scope_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "callback_path": { "$ref": "#/$defs/callback_path_token" },
        "callback_path_token": { "$ref": "#/$defs/callback_path_token" },
        "object_support": {
          "type": "array",
          "items": { "$ref": "#/$defs/object_support_entry" }
        },
        "snapshot_freshness": { "$ref": "#/$defs/snapshot_freshness_token" },
        "snapshot_freshness_token": { "$ref": "#/$defs/snapshot_freshness_token" },
        "freshness_epoch_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "degraded_reason": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        },
        "local_core_continuity_allowed": { "type": "boolean" },
        "dependency_class": { "$ref": "#/$defs/dependency_class_token" },
        "dependency_class_token": { "$ref": "#/$defs/dependency_class_token" },
        "mirror_self_host_note": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        },
        "raw_private_material_excluded": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "provider_descriptor_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["records"],
      "properties": {
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/provider_descriptor_record" },
          "minItems": 1
        }
      }
    },
    "provider_registry_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "provider_family_token",
        "actor_identity_token",
        "callback_path_token",
        "dependency_class_token",
        "snapshot_freshness_token",
        "local_core_continuity_declared",
        "object_support_declared",
        "raw_private_material_excluded",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "remote_provider_registry_row_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "remote:provider_registry_harden:v1" },
        "provider_family_token": { "$ref": "#/$defs/provider_family_token" },
        "actor_identity_token": { "$ref": "#/$defs/actor_identity_token" },
        "callback_path_token": { "$ref": "#/$defs/callback_path_token" },
        "dependency_class_token": { "$ref": "#/$defs/dependency_class_token" },
        "snapshot_freshness_token": { "$ref": "#/$defs/snapshot_freshness_token" },
        "local_core_continuity_declared": { "type": "boolean" },
        "object_support_declared": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "provider_registry_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "pairs_covered",
        "local_core_continuity_declared_count",
        "object_support_declared_count",
        "overall_qualification_token"
      ],
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "pairs_covered": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 2,
            "maxItems": 2
          }
        },
        "local_core_continuity_declared_count": { "type": "integer", "minimum": 0 },
        "object_support_declared_count": { "type": "integer", "minimum": 0 },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_token" }
      }
    },
    "provider_registry_defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "remote_provider_registry_defect_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "remote:provider_registry_harden:v1" },
        "defect_id": { "$ref": "#/$defs/non_empty_string" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    }
  }
}
