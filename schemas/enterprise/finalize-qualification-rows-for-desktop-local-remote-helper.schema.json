{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/enterprise/finalize-qualification-rows-for-desktop-local-remote-helper.schema.json",
  "title": "Aureline qualification matrix — desktop local, remote/helper, provider-linked, state/schema, and accessibility",
  "description": "Boundary schema for the stable QualificationMatrixPage proof packet. The packet carries typed dependency class, local-core continuity, no-account compatibility, failure-mode downgrade, policy source, tenant/region, and qualification tier for every required surface × profile row and accessibility-feature row. Raw credentials, raw private keys, raw policy bundle bodies, and raw PII are excluded; only closed-vocabulary tokens, opaque refs, plain-language summary sentences, and schema-version integers cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "page_label",
    "generated_at",
    "summary",
    "rows",
    "defects",
    "snapshot"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "record_kind": {
      "type": "string",
      "const": "remote_qualification_matrix_page_record"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "remote:qualification_matrix:desktop:v1"
    },
    "page_id": { "$ref": "#/$defs/opaque_id" },
    "page_label": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
    "summary": { "$ref": "#/$defs/qualification_matrix_summary" },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/qualification_matrix_row" }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/qualification_matrix_defect" }
    },
    "snapshot": { "$ref": "#/$defs/qualification_snapshot" }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:/\\-][a-z0-9]+)*$"
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 800
    },
    "surface_token": {
      "type": "string",
      "enum": [
        "desktop_local",
        "remote_helper",
        "provider_linked",
        "state_schema",
        "accessibility"
      ]
    },
    "profile_token": {
      "type": "string",
      "enum": [
        "local_oss",
        "self_hosted",
        "managed",
        "air_gapped",
        ""
      ]
    },
    "accessibility_feature_token": {
      "type": "string",
      "enum": [
        "keyboard",
        "screen_reader",
        "ime_grapheme_bidi",
        "zoom",
        "high_contrast",
        "reduced_motion",
        ""
      ]
    },
    "dependency_class_token": {
      "type": "string",
      "enum": [
        "local_only",
        "network",
        "managed",
        "air_gapped"
      ]
    },
    "failure_downgrade_token": {
      "type": "string",
      "enum": [
        "local_core_unaffected",
        "degraded_features",
        "offline_grace",
        "mirror_fallback",
        "not_applicable"
      ]
    },
    "qualification_tier_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "raw_private_material_exposed",
        "required_row_missing",
        "local_core_continuity_undeclared",
        "dependency_class_undeclared",
        "no_account_compatibility_undeclared",
        "failure_downgrade_undeclared"
      ]
    },
    "qualification_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_key",
        "surface_token",
        "profile_token",
        "accessibility_feature_token",
        "dependency_class",
        "dependency_class_token",
        "local_core_continuity_allowed",
        "no_account_local_compatible",
        "failure_downgrade",
        "failure_downgrade_token",
        "policy_source_ref",
        "raw_private_material_excluded",
        "summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_qualification_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:qualification_matrix:desktop:v1"
        },
        "row_key": { "$ref": "#/$defs/non_empty_string" },
        "surface_token": { "$ref": "#/$defs/surface_token" },
        "profile_token": { "$ref": "#/$defs/profile_token" },
        "accessibility_feature_token": { "$ref": "#/$defs/accessibility_feature_token" },
        "dependency_class": { "$ref": "#/$defs/dependency_class_token" },
        "dependency_class_token": { "$ref": "#/$defs/dependency_class_token" },
        "local_core_continuity_allowed": { "type": "boolean" },
        "no_account_local_compatible": { "type": "boolean" },
        "failure_downgrade": { "$ref": "#/$defs/failure_downgrade_token" },
        "failure_downgrade_token": { "$ref": "#/$defs/failure_downgrade_token" },
        "policy_source_ref": { "$ref": "#/$defs/opaque_id" },
        "tenant_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "region_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "qualification_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["records"],
      "properties": {
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/qualification_record" }
        }
      }
    },
    "qualification_matrix_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_key",
        "surface_token",
        "profile_token",
        "accessibility_feature_token",
        "dependency_class_token",
        "local_core_continuity_declared",
        "no_account_compatibility_declared",
        "failure_downgrade_token",
        "raw_private_material_excluded",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_qualification_matrix_row_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:qualification_matrix:desktop:v1"
        },
        "row_key": { "$ref": "#/$defs/non_empty_string" },
        "surface_token": { "$ref": "#/$defs/surface_token" },
        "profile_token": { "$ref": "#/$defs/profile_token" },
        "accessibility_feature_token": { "$ref": "#/$defs/accessibility_feature_token" },
        "dependency_class_token": { "$ref": "#/$defs/dependency_class_token" },
        "local_core_continuity_declared": { "type": "boolean" },
        "no_account_compatibility_declared": { "type": "boolean" },
        "failure_downgrade_token": { "$ref": "#/$defs/failure_downgrade_token" },
        "raw_private_material_excluded": { "type": "boolean" },
        "qualification_token": { "$ref": "#/$defs/qualification_tier_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "qualification_matrix_defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_qualification_matrix_defect_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:qualification_matrix:desktop:v1"
        },
        "defect_id": { "$ref": "#/$defs/non_empty_string" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "qualification_matrix_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "rows_covered",
        "local_core_continuity_declared_count",
        "no_account_compatibility_declared_count",
        "overall_qualification_token"
      ],
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "rows_covered": {
          "type": "array",
          "items": { "type": "string" }
        },
        "local_core_continuity_declared_count": { "type": "integer", "minimum": 0 },
        "no_account_compatibility_declared_count": { "type": "integer", "minimum": 0 },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_tier_token" }
      }
    }
  }
}
