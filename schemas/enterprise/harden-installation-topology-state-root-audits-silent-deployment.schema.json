{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/enterprise/harden-installation-topology-state-root-audits-silent-deployment.schema.json",
  "title": "Aureline hardened installation topology records",
  "description": "Boundary schema for the proof packet covering managed-fleet install topology hardening: tenant identity, rollout ring, updater owner, binary root, state-root audits, policy source, fleet-rollout evidence, and silent-deployment posture. Raw tenant credentials, raw policy bodies, binary paths, and secret material never cross this boundary.",
  "oneOf": [
    { "$ref": "#/$defs/harden_install_topology_page_record" },
    { "$ref": "#/$defs/harden_install_topology_managed_fleet_row_record" },
    { "$ref": "#/$defs/harden_install_topology_silent_deployment_row_record" },
    { "$ref": "#/$defs/harden_install_topology_defect_record" },
    { "$ref": "#/$defs/harden_install_topology_summary_record" },
    { "$ref": "#/$defs/harden_install_topology_support_export_record" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "non_empty": { "type": "string", "minLength": 1 },
    "shared_contract_ref": {
      "type": "string",
      "const": "install:harden_installation_topology:v1"
    },
    "qualification_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "ring_not_named",
        "tenant_not_named",
        "updater_owner_not_named",
        "binary_root_not_named",
        "state_roots_not_audited",
        "policy_source_not_named",
        "fleet_evidence_incomplete",
        "admin_view_incomplete",
        "silent_limits_not_declared",
        "return_codes_not_named",
        "no_managed_rows"
      ]
    },
    "rollout_ring_class": {
      "type": "string",
      "enum": ["canary", "pilot", "broad", "lts"]
    },
    "updater_owner_class": {
      "type": "string",
      "enum": ["user", "admin", "external_package_manager", "managed_fleet", "none"]
    },
    "binary_root_class": {
      "type": "string",
      "enum": [
        "per_user_profile_program_area",
        "per_machine_program_area",
        "portable_directory",
        "offline_bundle_extracted_program_area",
        "admin_pinned_program_area",
        "external_package_manager_owned_area"
      ]
    },
    "state_root_isolation_class": {
      "type": "string",
      "enum": [
        "channel_owned",
        "portable_colocated",
        "admin_policy_owned",
        "mirror_metadata_owned",
        "shared_read_only"
      ]
    },
    "state_root_review_class": {
      "type": "string",
      "enum": [
        "no_review_needed",
        "explicit_import_review_required",
        "portable_no_os_ownership",
        "admin_policy_review_required",
        "mirror_verification_review_required"
      ]
    },
    "fleet_evidence_class": {
      "type": "string",
      "enum": [
        "ring_assignment",
        "exact_build_inventory",
        "managed_package_report",
        "policy_root",
        "rollback_target",
        "verification_status",
        "support_export"
      ]
    },
    "silent_install_support_class": {
      "type": "string",
      "enum": ["full", "partial", "unsupported", "managed_only"]
    },
    "state_root_audit_entry": {
      "type": "object",
      "required": [
        "state_root_ref",
        "isolation_class",
        "review_class",
        "exposed_in_admin_view",
        "contains_secret_material"
      ],
      "additionalProperties": false,
      "properties": {
        "state_root_ref": { "$ref": "#/$defs/non_empty" },
        "isolation_class": { "$ref": "#/$defs/state_root_isolation_class" },
        "review_class": { "$ref": "#/$defs/state_root_review_class" },
        "exposed_in_admin_view": { "type": "boolean" },
        "contains_secret_material": { "type": "boolean" }
      }
    },
    "harden_install_topology_managed_fleet_row_record": {
      "type": "object",
      "required": [
        "row_id",
        "topology_row_id",
        "platform_token",
        "tenant_ref",
        "rollout_ring_class",
        "updater_owner_class",
        "binary_root_class",
        "policy_source_ref",
        "state_root_audit",
        "fleet_evidence",
        "silent_deployment_class",
        "silent_deployment_limits_declared",
        "admin_view_complete",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty" },
        "topology_row_id": { "$ref": "#/$defs/non_empty" },
        "platform_token": { "type": "string" },
        "tenant_ref": { "type": "string" },
        "rollout_ring_class": { "$ref": "#/$defs/rollout_ring_class" },
        "updater_owner_class": { "$ref": "#/$defs/updater_owner_class" },
        "binary_root_class": { "$ref": "#/$defs/binary_root_class" },
        "policy_source_ref": { "type": "string" },
        "state_root_audit": {
          "type": "array",
          "items": { "$ref": "#/$defs/state_root_audit_entry" }
        },
        "fleet_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/fleet_evidence_class" }
        },
        "silent_deployment_class": { "$ref": "#/$defs/silent_install_support_class" },
        "silent_deployment_limits_declared": { "type": "boolean" },
        "admin_view_complete": { "type": "boolean" },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "type": "string" }
      }
    },
    "harden_install_topology_silent_deployment_row_record": {
      "type": "object",
      "required": [
        "row_id",
        "topology_row_id",
        "support_class",
        "limits_declared",
        "disclosed_limits",
        "return_code_families_named",
        "return_code_family_refs",
        "qualification_token",
        "narrow_reason_token"
      ],
      "additionalProperties": false,
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty" },
        "topology_row_id": { "$ref": "#/$defs/non_empty" },
        "support_class": { "$ref": "#/$defs/silent_install_support_class" },
        "limits_declared": { "type": "boolean" },
        "disclosed_limits": {
          "type": "array",
          "items": { "type": "string" }
        },
        "return_code_families_named": { "type": "boolean" },
        "return_code_family_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" }
      }
    },
    "harden_install_topology_defect_record": {
      "type": "object",
      "required": [
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "additionalProperties": false,
      "properties": {
        "defect_id": { "$ref": "#/$defs/non_empty" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "$ref": "#/$defs/non_empty" },
        "note": { "$ref": "#/$defs/non_empty" }
      }
    },
    "harden_install_topology_summary_record": {
      "type": "object",
      "required": [
        "managed_fleet_row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "rings_covered",
        "fleet_evidence_classes_present",
        "silent_deployment_limits_declared_count",
        "admin_view_complete_count",
        "overall_qualification_token"
      ],
      "additionalProperties": false,
      "properties": {
        "managed_fleet_row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "rings_covered": {
          "type": "array",
          "items": { "$ref": "#/$defs/rollout_ring_class" }
        },
        "fleet_evidence_classes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/fleet_evidence_class" }
        },
        "silent_deployment_limits_declared_count": { "type": "integer", "minimum": 0 },
        "admin_view_complete_count": { "type": "integer", "minimum": 0 },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_token" }
      }
    },
    "harden_install_topology_page_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "page_id",
        "page_label",
        "generated_at",
        "managed_fleet_rows",
        "silent_deployment_rows",
        "defects",
        "summary"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "harden_install_topology_page_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "page_id": { "$ref": "#/$defs/non_empty" },
        "page_label": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "type": "string" },
        "managed_fleet_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/harden_install_topology_managed_fleet_row_record" }
        },
        "silent_deployment_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/harden_install_topology_silent_deployment_row_record" }
        },
        "defects": {
          "type": "array",
          "items": { "$ref": "#/$defs/harden_install_topology_defect_record" }
        },
        "summary": { "$ref": "#/$defs/harden_install_topology_summary_record" }
      }
    },
    "harden_install_topology_support_export_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "export_id",
        "generated_at",
        "page",
        "narrow_reasons_present",
        "defect_counts_by_narrow_reason",
        "raw_private_material_excluded"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "harden_install_topology_support_export_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "export_id": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "type": "string" },
        "page": { "$ref": "#/$defs/harden_install_topology_page_record" },
        "narrow_reasons_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason_token" }
        },
        "defect_counts_by_narrow_reason": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "raw_private_material_excluded": { "type": "boolean", "const": true }
      }
    }
  }
}
