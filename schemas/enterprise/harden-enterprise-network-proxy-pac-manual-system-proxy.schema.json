{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/enterprise/harden-enterprise-network-proxy-pac-manual-system-proxy.schema.json",
  "title": "Aureline enterprise network proxy harden records",
  "description": "Boundary schema for the proof packet covering enterprise network proxy route hardening: PAC, manual, system proxy, policy-pinned, mirror-only, and offline routes with explicit selector reasons, trust material declarations, TLS/client-cert state, and local-only fallback documentation. Raw proxy hostnames, raw PAC script bodies, raw CA certificates, raw credentials, and secret material never cross this boundary.",
  "oneOf": [
    { "$ref": "#/$defs/policy_harden_enterprise_network_proxy_page_record" },
    { "$ref": "#/$defs/policy_harden_enterprise_network_proxy_row_record" },
    { "$ref": "#/$defs/policy_harden_enterprise_network_proxy_defect_record" },
    { "$ref": "#/$defs/policy_harden_enterprise_network_proxy_summary_record" },
    { "$ref": "#/$defs/policy_harden_enterprise_network_proxy_support_export_record" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "non_empty": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "shared_contract_ref": {
      "type": "string",
      "const": "policy:harden_enterprise_network_proxy:v1"
    },
    "qualification_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "proxy_route_token": {
      "type": "string",
      "enum": ["system", "pac", "manual", "policy_pinned", "mirror_only", "offline"]
    },
    "precedence_token": {
      "type": "string",
      "enum": [
        "policy_pinned",
        "manual",
        "process_environment",
        "pac",
        "system",
        "direct_no_proxy"
      ]
    },
    "selector_reason_token": {
      "type": "string",
      "enum": [
        "os_system_proxy_active",
        "pac_script_evaluated",
        "admin_manual_entry",
        "managed_policy_pinned",
        "mirror_only_profile_active",
        "offline_profile_active",
        "process_env_var_active",
        "direct_connection_forced"
      ]
    },
    "credential_kind_token": {
      "type": "string",
      "enum": [
        "none_required",
        "tls_system_ca",
        "custom_ca",
        "client_certificate",
        "ssh_host_key",
        "admin_signed_proxy_credential"
      ]
    },
    "tls_verification_posture_token": {
      "type": "string",
      "enum": [
        "full_verification",
        "custom_ca_verification",
        "not_applicable"
      ]
    },
    "client_cert_posture_token": {
      "type": "string",
      "enum": [
        "none_required",
        "present_valid",
        "missing_or_expired"
      ]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "upstream_network_trust_has_defects",
        "missing_route_coverage",
        "raw_secret_or_private_material_exposed",
        "empty_selector_reason",
        "missing_local_fallback_on_enterprise_route",
        "no_credential_declarations",
        "empty_tls_verification_posture",
        "local_core_continuity_not_explicit",
        "missing_managed_attribution_on_enterprise_route"
      ]
    },
    "bootstrap_credential_declaration": {
      "type": "object",
      "required": [
        "credential_kind",
        "credential_kind_token",
        "credential_ref",
        "source_label",
        "policy_locked"
      ],
      "additionalProperties": false,
      "properties": {
        "credential_kind": { "$ref": "#/$defs/credential_kind_token" },
        "credential_kind_token": { "$ref": "#/$defs/credential_kind_token" },
        "credential_ref": { "type": "string" },
        "source_label": { "type": "string" },
        "policy_locked": { "type": "boolean" }
      }
    },
    "policy_harden_enterprise_network_proxy_row_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_id",
        "proxy_route",
        "proxy_route_token",
        "precedence",
        "precedence_token",
        "precedence_rank",
        "precedence_rank_label",
        "selector_reason",
        "selector_reason_token",
        "selector_reason_label",
        "bootstrap_credentials",
        "tls_verification_posture",
        "tls_verification_posture_token",
        "client_cert_posture",
        "client_cert_posture_token",
        "ssh_host_key_posture_label",
        "local_only_fallback_route_token",
        "fallback_condition_label",
        "local_core_continuity_explicit",
        "raw_secret_or_private_material_excluded",
        "managed_attribution_ref",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "policy_harden_enterprise_network_proxy_row_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "row_id": { "$ref": "#/$defs/non_empty" },
        "proxy_route": { "$ref": "#/$defs/proxy_route_token" },
        "proxy_route_token": { "$ref": "#/$defs/proxy_route_token" },
        "precedence": { "$ref": "#/$defs/precedence_token" },
        "precedence_token": { "$ref": "#/$defs/precedence_token" },
        "precedence_rank": { "type": "integer", "minimum": 1, "maximum": 6 },
        "precedence_rank_label": { "type": "string" },
        "selector_reason": { "$ref": "#/$defs/selector_reason_token" },
        "selector_reason_token": { "$ref": "#/$defs/selector_reason_token" },
        "selector_reason_label": { "type": "string" },
        "bootstrap_credentials": {
          "type": "array",
          "items": { "$ref": "#/$defs/bootstrap_credential_declaration" },
          "minItems": 1
        },
        "tls_verification_posture": { "$ref": "#/$defs/tls_verification_posture_token" },
        "tls_verification_posture_token": { "$ref": "#/$defs/tls_verification_posture_token" },
        "client_cert_posture": { "$ref": "#/$defs/client_cert_posture_token" },
        "client_cert_posture_token": { "$ref": "#/$defs/client_cert_posture_token" },
        "ssh_host_key_posture_label": { "type": "string" },
        "local_only_fallback_route_token": { "type": "string" },
        "fallback_condition_label": { "type": "string" },
        "local_core_continuity_explicit": { "type": "boolean" },
        "raw_secret_or_private_material_excluded": { "type": "boolean" },
        "managed_attribution_ref": { "type": "string" },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "type": "string" }
      }
    },
    "policy_harden_enterprise_network_proxy_defect_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "policy_harden_enterprise_network_proxy_defect_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_id": { "$ref": "#/$defs/non_empty" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "$ref": "#/$defs/non_empty" },
        "note": { "$ref": "#/$defs/non_empty" }
      }
    },
    "policy_harden_enterprise_network_proxy_summary_record": {
      "type": "object",
      "required": [
        "row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "routes_covered",
        "selector_reasons_present",
        "bootstrap_credential_kinds_present",
        "local_core_continuity_explicit_row_count",
        "raw_secret_excluded_row_count",
        "upstream_network_trust_defect_count",
        "overall_qualification_token"
      ],
      "additionalProperties": false,
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "routes_covered": {
          "type": "array",
          "items": { "$ref": "#/$defs/proxy_route_token" }
        },
        "selector_reasons_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/selector_reason_token" }
        },
        "bootstrap_credential_kinds_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/credential_kind_token" }
        },
        "local_core_continuity_explicit_row_count": { "type": "integer", "minimum": 0 },
        "raw_secret_excluded_row_count": { "type": "integer", "minimum": 0 },
        "upstream_network_trust_defect_count": { "type": "integer", "minimum": 0 },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_token" }
      }
    },
    "policy_harden_enterprise_network_proxy_page_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "page_id",
        "page_label",
        "generated_at",
        "summary",
        "rows",
        "defects",
        "network_trust_beta_page"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "policy_harden_enterprise_network_proxy_page_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "page_id": { "$ref": "#/$defs/non_empty" },
        "page_label": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "type": "string" },
        "summary": { "$ref": "#/$defs/policy_harden_enterprise_network_proxy_summary_record" },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_harden_enterprise_network_proxy_row_record" }
        },
        "defects": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_harden_enterprise_network_proxy_defect_record" }
        },
        "network_trust_beta_page": { "type": "object" }
      }
    },
    "policy_harden_enterprise_network_proxy_support_export_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "export_id",
        "generated_at",
        "page",
        "narrow_reasons_present",
        "defect_counts_by_narrow_reason",
        "raw_private_material_excluded"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "policy_harden_enterprise_network_proxy_support_export_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "export_id": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "type": "string" },
        "page": { "$ref": "#/$defs/policy_harden_enterprise_network_proxy_page_record" },
        "narrow_reasons_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason_token" }
        },
        "defect_counts_by_narrow_reason": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "raw_private_material_excluded": { "type": "boolean", "const": true }
      }
    }
  }
}
