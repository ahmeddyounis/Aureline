{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/testing/test_quarantine_record.schema.json",
  "title": "Aureline governed test mute and quarantine record",
  "description": "Boundary schema for governed test mute/quarantine records included in support and release trust packets. The record preserves treatment kind, owner, reason, scope, expiry, evidence refs, reopen behavior, and release debt. Expired records reopen into release-visible debt until renewed or resolved. Raw runner logs, raw test names, raw paths, raw command lines, raw policy payloads, and raw provider payloads never cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/test_quarantine_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "treatment_kind_token": {
      "type": "string",
      "enum": ["mute", "quarantine"]
    },
    "status_token": {
      "type": "string",
      "enum": ["active", "expired_reopened", "resolved", "renewed"]
    },
    "reason_token": {
      "type": "string",
      "enum": [
        "suspected_flaky",
        "reproduced_flaky",
        "known_failing",
        "environment_dependent",
        "imported_incomparable",
        "manual_noise_reduction",
        "policy_restriction",
        "unknown_requires_review"
      ]
    },
    "scope_class_token": {
      "type": "string",
      "enum": [
        "exact_test_item",
        "parameterized_family",
        "suite_or_container",
        "selector_expression",
        "target_environment",
        "release_channel_scope",
        "unknown_requires_review"
      ]
    },
    "reopen_behavior_token": {
      "type": "string",
      "enum": [
        "reopen_failure",
        "stable_window_required",
        "manual_owner_review",
        "renewal_required",
        "unknown_requires_review"
      ]
    },
    "release_debt_token": {
      "type": "string",
      "enum": [
        "release_blocking",
        "claim_narrowing_required",
        "waiver_linked",
        "informational_recovered",
        "unknown_requires_review"
      ]
    },
    "test_quarantine_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "quarantine_record_id",
        "treatment_kind",
        "treatment_kind_token",
        "status",
        "status_token",
        "owner_ref",
        "reason",
        "reason_token",
        "scope_class",
        "scope_class_token",
        "scope_refs",
        "created_at",
        "expires_at",
        "evidence_refs",
        "reopen_behavior",
        "reopen_behavior_token",
        "release_debt_class",
        "release_debt_token",
        "release_visible",
        "summary"
      ],
      "properties": {
        "record_kind": { "const": "test_quarantine_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "quarantine_record_id": { "$ref": "#/$defs/opaque_id" },
        "treatment_kind": { "$ref": "#/$defs/treatment_kind_token" },
        "treatment_kind_token": { "$ref": "#/$defs/treatment_kind_token" },
        "status": { "$ref": "#/$defs/status_token" },
        "status_token": { "$ref": "#/$defs/status_token" },
        "owner_ref": { "$ref": "#/$defs/opaque_ref" },
        "reason": { "$ref": "#/$defs/reason_token" },
        "reason_token": { "$ref": "#/$defs/reason_token" },
        "scope_class": { "$ref": "#/$defs/scope_class_token" },
        "scope_class_token": { "$ref": "#/$defs/scope_class_token" },
        "scope_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "expires_at": { "$ref": "#/$defs/timestamp" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "reopen_behavior": { "$ref": "#/$defs/reopen_behavior_token" },
        "reopen_behavior_token": { "$ref": "#/$defs/reopen_behavior_token" },
        "release_debt_class": { "$ref": "#/$defs/release_debt_token" },
        "release_debt_token": { "$ref": "#/$defs/release_debt_token" },
        "release_visible": { "type": "boolean" },
        "reopened_attempt_ref": { "$ref": "#/$defs/opaque_ref" },
        "summary": { "type": "string", "minLength": 1 }
      }
    }
  }
}
