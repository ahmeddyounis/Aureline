{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/testing/test-generation-suggestion-cards-and-diff-first-apply.schema.json",
  "title": "Aureline M5 test-generation proposal packet",
  "description": "Export-safe packet that brings AI-assisted test generation into the governed M5 test-intelligence lane. A test-generation suggestion card ties a durable generated-test subject (addressed by a node kind and a non-display fingerprint distinct from its id, so a parameterized template never collapses into a concrete invocation) to the target symbols / files it exercises, the uncovered-path or bug source that motivated it, named assumptions, the files it would write, a sandbox-validation posture, and a preview / diff / apply / revert posture. A proposal is evidence-bound, not free-text: it carries one or more reopenable evidence references over the discovery / session / coverage / attempt / verdict / diagnostic / bug vocabulary, each addressable by a non-display fingerprint. A card may not expose an apply path before naming assumptions, evidence basis, affected files, and a determinate validation posture. An applied card must have been previewed, must carry an isolated sandbox pass, must not widen beyond its evidenced scope, and must carry a follow-on rerun ref; an imported proposal is held read-only and never reads as a local apply. Generated source bodies, raw model prompts / completions, sandbox stdout, diff bytes, raw provider payloads, provider cursors, credentials, and host names never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "label",
    "cards",
    "guardrails",
    "consumer_projection",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "test_generation_proposal_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/test_generation_suggestion_card"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "$ref": "#/$defs/non_empty_string"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "test_item_identity_class": {
      "type": "string",
      "enum": [
        "stable",
        "remap_review_required",
        "imported_read_only",
        "display_text_only_denied",
        "unknown_requires_review"
      ]
    },
    "durable_test_node_kind": {
      "type": "string",
      "enum": [
        "suite",
        "concrete_case",
        "parameterized_template",
        "concrete_invocation",
        "notebook_linked_test"
      ]
    },
    "generation_source_kind": {
      "type": "string",
      "enum": [
        "uncovered_coverage_path",
        "uncovered_branch_path",
        "bug_reproduction",
        "regression_guard",
        "changed_code_gap",
        "unknown_requires_review"
      ]
    },
    "evidence_object_kind": {
      "type": "string",
      "enum": [
        "coverage_overlay",
        "discovery_snapshot",
        "session_plan",
        "attempt_record",
        "stability_verdict",
        "diagnostic_record",
        "bug_report"
      ]
    },
    "validation_posture": {
      "type": "string",
      "enum": [
        "sandbox_validated_pass",
        "sandbox_validated_fail",
        "sandbox_validation_pending",
        "sandbox_validation_error",
        "not_validated",
        "imported_unvalidated"
      ]
    },
    "apply_state": {
      "type": "string",
      "enum": [
        "pending_preview",
        "previewed",
        "applied",
        "reverted",
        "rejected",
        "blocked_needs_validation"
      ]
    },
    "proposal_provenance": {
      "type": "string",
      "enum": [
        "locally_generated",
        "imported_proposal",
        "unknown_requires_review"
      ]
    },
    "generated_file_kind": {
      "type": "string",
      "enum": [
        "new_test_file",
        "appended_test_file",
        "new_fixture_file",
        "new_snapshot_baseline"
      ]
    },
    "target_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_id",
        "file_ref",
        "symbol_label",
        "target_fingerprint_token"
      ],
      "properties": {
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "file_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "symbol_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "evidence_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_kind",
        "evidence_ref",
        "evidence_fingerprint_token",
        "summary"
      ],
      "properties": {
        "evidence_kind": {
          "$ref": "#/$defs/evidence_object_kind"
        },
        "evidence_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "assumption_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "requires_confirmation"
      ],
      "properties": {
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "requires_confirmation": {
          "type": "boolean"
        }
      }
    },
    "generated_file_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file_ref",
        "change_kind",
        "diff_summary_ref"
      ],
      "properties": {
        "file_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "change_kind": {
          "$ref": "#/$defs/generated_file_kind"
        },
        "diff_summary_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "sandbox_validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "posture",
        "tests_executed",
        "tests_passed",
        "isolated",
        "summary"
      ],
      "properties": {
        "posture": {
          "$ref": "#/$defs/validation_posture"
        },
        "sandbox_run_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "tests_executed": {
          "type": "integer",
          "minimum": 0
        },
        "tests_passed": {
          "type": "integer",
          "minimum": 0
        },
        "isolated": {
          "type": "boolean"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "apply_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "preview_first",
        "diff_ref",
        "widens_beyond_evidence"
      ],
      "properties": {
        "state": {
          "$ref": "#/$defs/apply_state"
        },
        "preview_first": {
          "type": "boolean"
        },
        "diff_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "revert_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "widens_beyond_evidence": {
          "type": "boolean"
        }
      }
    },
    "generated_test_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_id",
        "node_kind",
        "subject_fingerprint_token",
        "identity_class"
      ],
      "properties": {
        "subject_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "node_kind": {
          "$ref": "#/$defs/durable_test_node_kind"
        },
        "subject_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "identity_class": {
          "$ref": "#/$defs/test_item_identity_class"
        }
      }
    },
    "test_generation_suggestion_card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id",
        "subject",
        "source_kind",
        "provenance",
        "targets",
        "evidence_basis",
        "assumptions",
        "generated_files",
        "sandbox_validation",
        "apply_posture",
        "captured_at",
        "support_summary"
      ],
      "properties": {
        "card_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "subject": {
          "$ref": "#/$defs/generated_test_subject"
        },
        "source_kind": {
          "$ref": "#/$defs/generation_source_kind"
        },
        "provenance": {
          "$ref": "#/$defs/proposal_provenance"
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/target_reference"
          }
        },
        "evidence_basis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_reference"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/assumption_entry"
          }
        },
        "generated_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/generated_file_entry"
          }
        },
        "sandbox_validation": {
          "$ref": "#/$defs/sandbox_validation"
        },
        "apply_posture": {
          "$ref": "#/$defs/apply_posture"
        },
        "origin_provider_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "follow_on_rerun_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "captured_at": {
          "$ref": "#/$defs/non_empty_string"
        },
        "support_summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disclosure_before_apply",
        "evidence_bound_not_free_text",
        "sandbox_validated_before_apply",
        "preview_diff_apply_revert_parity",
        "no_silent_scope_widening",
        "imported_never_reads_as_local",
        "template_invocation_distinct"
      ],
      "properties": {
        "disclosure_before_apply": {
          "type": "boolean"
        },
        "evidence_bound_not_free_text": {
          "type": "boolean"
        },
        "sandbox_validated_before_apply": {
          "type": "boolean"
        },
        "preview_diff_apply_revert_parity": {
          "type": "boolean"
        },
        "no_silent_scope_widening": {
          "type": "boolean"
        },
        "imported_never_reads_as_local": {
          "type": "boolean"
        },
        "template_invocation_distinct": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suggestion_card_ui_normalized",
        "diff_apply_pipeline_normalized",
        "evidence_reopen_normalized",
        "rerun_diagnose_normalized",
        "release_support_export_normalized"
      ],
      "properties": {
        "suggestion_card_ui_normalized": {
          "type": "boolean"
        },
        "diff_apply_pipeline_normalized": {
          "type": "boolean"
        },
        "evidence_reopen_normalized": {
          "type": "boolean"
        },
        "rerun_diagnose_normalized": {
          "type": "boolean"
        },
        "release_support_export_normalized": {
          "type": "boolean"
        }
      }
    }
  }
}
