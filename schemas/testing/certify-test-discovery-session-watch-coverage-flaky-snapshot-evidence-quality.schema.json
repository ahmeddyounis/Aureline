{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/testing/certify-test-discovery-session-watch-coverage-flaky-snapshot-evidence-quality.schema.json",
  "title": "Aureline M5 test discovery / session / watch / coverage / flaky / snapshot evidence-quality and selector-portability certification",
  "description": "Export-safe certification binding every claimed M5 test row (framework-pack, notebook, AI-test-generation, review-panel, imported-CI) to per-dimension evidence-quality proof over the discovery, session, watch, selector-portability, coverage, flaky, and snapshot dimensions. Each dimension certification names a proof currency and, unless the proof is missing, a reopenable proof ref keyed by a non-display fingerprint. A claimed row whose required-core dimension is uncertified, or whose certified dimension lacks current proof (stale, missing, requires-review, or imported proof standing in for a local claim), auto-narrows to an effective grade strictly below its claim, with a recorded narrow trigger and a precise narrowed label. Parameterized templates stay distinct from their concrete invocations; imported CI rows never read as a live local rerun; quarantine and stale coverage never hide behind a generic green grade; and snapshot, golden, and test-generation proposals use the shared preview/diff/apply rules. Raw test source, raw provider payloads, raw log bytes, provider cursors, credentials, and raw artifact bodies never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "label",
    "rows",
    "guardrails",
    "consumer_projection",
    "evidence_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "certify_test_discovery_session_watch_coverage_flaky_snapshot_evidence_quality_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/certified_test_row"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "evidence_freshness": {
      "$ref": "#/$defs/evidence_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "certified_row_kind": {
      "type": "string",
      "enum": [
        "framework_pack_row",
        "notebook_row",
        "ai_test_generation_row",
        "review_panel_row",
        "ci_import_row"
      ]
    },
    "evidence_dimension": {
      "type": "string",
      "enum": [
        "discovery_truth",
        "session_truth",
        "watch_truth",
        "selector_portability",
        "coverage_evidence",
        "flaky_evidence",
        "snapshot_evidence"
      ]
    },
    "proof_currency": {
      "type": "string",
      "enum": [
        "verified_current",
        "cached_within_window",
        "imported_current",
        "stale_expired",
        "missing_proof",
        "requires_review"
      ]
    },
    "certification_grade": {
      "type": "string",
      "enum": [
        "release_certified",
        "certified",
        "provisionally_certified",
        "uncertified",
        "not_applicable"
      ]
    },
    "narrow_trigger": {
      "type": "string",
      "enum": [
        "missing_dimension_proof",
        "stale_dimension_proof",
        "imported_proof_on_local_row",
        "verdict_requires_review",
        "partial_discovery_uncertified",
        "quarantine_debt_uncertified",
        "selector_portability_unproven",
        "upstream_dependency_narrowed"
      ]
    },
    "durable_test_node_kind": {
      "type": "string",
      "enum": [
        "suite",
        "concrete_case",
        "parameterized_template",
        "concrete_invocation",
        "notebook_linked_test"
      ]
    },
    "test_item_identity_class": {
      "type": "string",
      "enum": [
        "stable",
        "remap_review_required",
        "imported_read_only",
        "display_text_only_denied",
        "unknown_requires_review"
      ]
    },
    "certified_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_id",
        "node_kind",
        "subject_fingerprint_token",
        "identity_class"
      ],
      "properties": {
        "subject_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "node_kind": {
          "$ref": "#/$defs/durable_test_node_kind"
        },
        "subject_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "identity_class": {
          "$ref": "#/$defs/test_item_identity_class"
        }
      }
    },
    "dimension_certification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension",
        "proof_currency",
        "summary"
      ],
      "properties": {
        "dimension": {
          "$ref": "#/$defs/evidence_dimension"
        },
        "proof_currency": {
          "$ref": "#/$defs/proof_currency"
        },
        "proof_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "proof_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "certified_test_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "row_kind",
        "subject",
        "label_summary",
        "imported_row",
        "certifications",
        "template_distinct_from_invocation",
        "partial_discovery_visible",
        "quarantine_visible_and_exportable",
        "proposals_use_preview_apply",
        "claimed_grade",
        "effective_grade",
        "evidence_refs",
        "source_contract_refs"
      ],
      "properties": {
        "row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "row_kind": {
          "$ref": "#/$defs/certified_row_kind"
        },
        "subject": {
          "$ref": "#/$defs/certified_subject"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "imported_row": {
          "type": "boolean"
        },
        "certifications": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dimension_certification"
          }
        },
        "template_distinct_from_invocation": {
          "type": "boolean"
        },
        "partial_discovery_visible": {
          "type": "boolean"
        },
        "quarantine_visible_and_exportable": {
          "type": "boolean"
        },
        "proposals_use_preview_apply": {
          "type": "boolean"
        },
        "claimed_grade": {
          "$ref": "#/$defs/certification_grade"
        },
        "effective_grade": {
          "$ref": "#/$defs/certification_grade"
        },
        "narrow_trigger": {
          "$ref": "#/$defs/narrow_trigger"
        },
        "narrowed_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameterized_templates_distinct_from_invocations",
        "imported_ci_never_reads_as_local_rerun",
        "quarantines_and_stale_coverage_never_hidden",
        "proposals_use_preview_diff_apply",
        "rows_auto_narrow_without_current_proof"
      ],
      "properties": {
        "parameterized_templates_distinct_from_invocations": {
          "type": "boolean"
        },
        "imported_ci_never_reads_as_local_rerun": {
          "type": "boolean"
        },
        "quarantines_and_stale_coverage_never_hidden": {
          "type": "boolean"
        },
        "proposals_use_preview_diff_apply": {
          "type": "boolean"
        },
        "rows_auto_narrow_without_current_proof": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_certification",
        "docs_help_ingests_certification",
        "review_ingests_certification",
        "support_ingests_certification",
        "release_control_ingests_certification",
        "narrowed_rows_labeled_below_claim"
      ],
      "properties": {
        "product_ingests_certification": {
          "type": "boolean"
        },
        "docs_help_ingests_certification": {
          "type": "boolean"
        },
        "review_ingests_certification": {
          "type": "boolean"
        },
        "support_ingests_certification": {
          "type": "boolean"
        },
        "release_control_ingests_certification": {
          "type": "boolean"
        },
        "narrowed_rows_labeled_below_claim": {
          "type": "boolean"
        }
      }
    },
    "evidence_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_freshness_slo_hours",
        "last_evidence_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "evidence_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_evidence_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
