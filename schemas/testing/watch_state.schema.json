{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/testing/watch_state.schema.json",
  "title": "Aureline test watch-state packet",
  "description": "Boundary schema for the release-facing watch-state packet on claimed beta test rows. The record preserves the controlled watch vocabulary, exact downgrade reasons, source alpha watch-controller tokens, latest attempt refs, backlog count, and reconnect/export parity. Raw runner logs, raw paths, raw command lines, raw environment bodies, raw provider payloads, and raw test names never cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/test_watch_state_packet_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1
    },
    "framework_token": {
      "type": "string",
      "enum": ["pytest"]
    },
    "watch_state_token": {
      "type": "string",
      "enum": ["live", "reduced", "polling", "unavailable", "imported_only"]
    },
    "downgrade_reason_token": {
      "type": "string",
      "enum": [
        "none",
        "not_a_watch_session",
        "partial_discovery",
        "bounded_backlog",
        "native_watcher_unavailable_polling",
        "imported_read_only_evidence",
        "source_or_target_drift",
        "target_unavailable",
        "reconnect_required",
        "unknown_requires_review"
      ]
    },
    "triage_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_test_item_ref",
        "selector_ref",
        "test_session_ref",
        "framework",
        "framework_token",
        "tree_row_ref",
        "inline_row_ref"
      ],
      "properties": {
        "canonical_test_item_ref": { "$ref": "#/$defs/opaque_ref" },
        "selector_ref": { "$ref": "#/$defs/opaque_ref" },
        "test_session_ref": { "$ref": "#/$defs/opaque_ref" },
        "framework": { "$ref": "#/$defs/framework_token" },
        "framework_token": { "$ref": "#/$defs/framework_token" },
        "tree_row_ref": { "$ref": "#/$defs/opaque_ref" },
        "inline_row_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "test_watch_state_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "watch_state_packet_id",
        "identity",
        "watch_controller_ref",
        "watch_state",
        "watch_state_token",
        "downgrade_reasons",
        "downgrade_reason_tokens",
        "source_watch_state_token",
        "source_degradation_reason_token",
        "buffered_change_count",
        "current_truth_claim_allowed",
        "reconnect_preserves_state",
        "summary"
      ],
      "properties": {
        "record_kind": { "const": "test_watch_state_packet_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "watch_state_packet_id": { "$ref": "#/$defs/opaque_id" },
        "identity": { "$ref": "#/$defs/triage_identity" },
        "watch_controller_ref": { "$ref": "#/$defs/opaque_ref" },
        "watch_state": { "$ref": "#/$defs/watch_state_token" },
        "watch_state_token": { "$ref": "#/$defs/watch_state_token" },
        "downgrade_reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_reason_token" }
        },
        "downgrade_reason_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_reason_token" }
        },
        "source_watch_state_token": { "type": "string", "minLength": 1 },
        "source_degradation_reason_token": { "type": "string", "minLength": 1 },
        "latest_attempt_ref": { "$ref": "#/$defs/opaque_ref" },
        "last_successful_attempt_ref": { "$ref": "#/$defs/opaque_ref" },
        "buffered_change_count": { "type": "integer", "minimum": 0 },
        "current_truth_claim_allowed": { "type": "boolean" },
        "reconnect_preserves_state": { "type": "boolean" },
        "summary": { "type": "string", "minLength": 1 }
      }
    }
  }
}
