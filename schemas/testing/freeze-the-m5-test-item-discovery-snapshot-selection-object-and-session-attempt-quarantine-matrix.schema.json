{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/testing/freeze-the-m5-test-item-discovery-snapshot-selection-object-and-session-attempt-quarantine-matrix.schema.json",
  "title": "Aureline M5 test-item, discovery-snapshot, selection-object, session-attempt, verdict, quarantine, and triage-packet matrix",
  "description": "Export-safe matrix binding every claimed M5 test-intelligence surface (framework test explorer, notebook test cells, AI test generation, review test panel, CI import overlay, coverage surface, flaky/quarantine board, snapshot/golden review) to its test-item identity class, discovery-snapshot class, selection-object class, session-attempt class, verdict projection class, selection-object contract, triage-packet contract, and proposal descriptors. The matrix reuses the frozen test-item identity, imported-CI projection, and flaky/quarantine verdict vocabularies and adds the matrix-level discovery-snapshot, selection-object, session-attempt, and proposal-kind vocabularies it owns. A claimed row that cannot identify a durable test item, a discovery snapshot, a selection object, or a session-attempt class — or whose verdict still requires review — auto-downgrades to an effective qualification strictly below its claim, with a recorded downgrade trigger and a precise degraded label. Display labels never stand in for durable test identity; parameterized templates stay distinct from their concrete invocations; partial discovery stays visible; imported or provider-backed results never masquerade as live local truth; quarantine and mute states stay visible, filterable, and exportable; and snapshot, golden, and test-generation proposals use the shared preview/diff/apply rules. Raw test source, raw provider payloads, raw log bytes, provider cursors, credentials, and raw artifact bodies never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "matrix_label",
    "rows",
    "guardrails",
    "consumer_projection",
    "evidence_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "freeze_the_m5_test_item_discovery_snapshot_selection_object_and_session_attempt_quarantine_matrix"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "matrix_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/test_qualification_row"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "evidence_freshness": {
      "$ref": "#/$defs/evidence_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "test_intelligence_surface": {
      "type": "string",
      "enum": [
        "framework_test_explorer",
        "notebook_test_cells",
        "ai_test_generation",
        "review_test_panel",
        "ci_import_overlay",
        "coverage_surface",
        "flaky_quarantine_board",
        "snapshot_golden_review",
        "support_export_projection"
      ]
    },
    "test_item_identity_class": {
      "type": "string",
      "enum": [
        "stable",
        "remap_review_required",
        "imported_read_only",
        "display_text_only_denied",
        "unknown_requires_review"
      ]
    },
    "discovery_snapshot_class": {
      "type": "string",
      "enum": [
        "complete_discovery",
        "partial_visible_discovery",
        "streaming_discovery",
        "provider_imported_discovery",
        "stale_cached_discovery"
      ]
    },
    "selection_object_class": {
      "type": "string",
      "enum": [
        "durable_identity_selection",
        "visible_range_selection",
        "query_matched_selection",
        "provider_scoped_selection"
      ]
    },
    "session_attempt_class": {
      "type": "string",
      "enum": [
        "local_live_session",
        "rerun_attempt_lineage",
        "imported_ci_session",
        "mixed_local_imported_session"
      ]
    },
    "imported_ci_projection_class": {
      "type": "string",
      "enum": [
        "not_imported_ci",
        "authoritative_imported_read_only",
        "stale_imported_read_only",
        "fresh_local_reconfirmation",
        "imported_ci_projection_unknown_requires_review"
      ]
    },
    "flaky_verdict_state": {
      "type": "string",
      "enum": [
        "suspected_flaky",
        "reproduced_flaky",
        "stable_again",
        "muted",
        "unknown"
      ]
    },
    "proposal_kind": {
      "type": "string",
      "enum": [
        "generate_test",
        "accept_snapshot",
        "update_golden",
        "accept_baseline",
        "apply_codemod"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "held",
        "unavailable"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "unidentified_test_item",
        "display_only_test_identity",
        "unidentified_discovery_snapshot",
        "unidentified_selection_object",
        "unidentified_session_attempt",
        "imported_verdict_requires_review",
        "partial_discovery_limited",
        "quarantine_debt_unresolved",
        "provider_narrowed",
        "upstream_dependency_narrowed"
      ]
    },
    "proposal_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proposal_id",
        "proposal_kind",
        "mutates_source_or_artifact",
        "requires_preview_diff",
        "requires_explicit_apply"
      ],
      "properties": {
        "proposal_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "proposal_kind": {
          "$ref": "#/$defs/proposal_kind"
        },
        "mutates_source_or_artifact": {
          "type": "boolean"
        },
        "requires_preview_diff": {
          "type": "boolean"
        },
        "requires_explicit_apply": {
          "type": "boolean"
        }
      }
    },
    "selection_object_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selection_object_id",
        "basis_token",
        "portable_to_rerun",
        "portable_to_cli",
        "captures_display_name_only",
        "survives_rediscovery"
      ],
      "properties": {
        "selection_object_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "basis_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "portable_to_rerun": {
          "type": "boolean"
        },
        "portable_to_cli": {
          "type": "boolean"
        },
        "captures_display_name_only": {
          "type": "boolean"
        },
        "survives_rediscovery": {
          "type": "boolean"
        }
      }
    },
    "triage_packet_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "triage_packet_id",
        "quarantine_state",
        "quarantine_visible",
        "quarantine_exportable",
        "has_renewal_or_expiry",
        "evidence_backed"
      ],
      "properties": {
        "triage_packet_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "quarantine_state": {
          "$ref": "#/$defs/flaky_verdict_state"
        },
        "quarantine_visible": {
          "type": "boolean"
        },
        "quarantine_exportable": {
          "type": "boolean"
        },
        "has_renewal_or_expiry": {
          "type": "boolean"
        },
        "evidence_backed": {
          "type": "boolean"
        }
      }
    },
    "test_qualification_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "surface",
        "label_summary",
        "verdict_projection_class",
        "selection_object",
        "triage_packet",
        "proposal_descriptors",
        "identity_independent_of_display_name",
        "template_distinct_from_invocation",
        "partial_discovery_stays_visible",
        "imported_results_not_shown_as_local",
        "quarantine_visible_and_exportable",
        "proposals_use_preview_apply",
        "claimed_qualification",
        "effective_qualification",
        "evidence_refs",
        "source_contract_refs"
      ],
      "properties": {
        "row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface": {
          "$ref": "#/$defs/test_intelligence_surface"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "test_item_identity_class": {
          "$ref": "#/$defs/test_item_identity_class"
        },
        "discovery_snapshot_class": {
          "$ref": "#/$defs/discovery_snapshot_class"
        },
        "selection_object_class": {
          "$ref": "#/$defs/selection_object_class"
        },
        "session_attempt_class": {
          "$ref": "#/$defs/session_attempt_class"
        },
        "verdict_projection_class": {
          "$ref": "#/$defs/imported_ci_projection_class"
        },
        "selection_object": {
          "$ref": "#/$defs/selection_object_declaration"
        },
        "triage_packet": {
          "$ref": "#/$defs/triage_packet_declaration"
        },
        "proposal_descriptors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/proposal_descriptor"
          }
        },
        "identity_independent_of_display_name": {
          "type": "boolean"
        },
        "template_distinct_from_invocation": {
          "type": "boolean"
        },
        "partial_discovery_stays_visible": {
          "type": "boolean"
        },
        "imported_results_not_shown_as_local": {
          "type": "boolean"
        },
        "quarantine_visible_and_exportable": {
          "type": "boolean"
        },
        "proposals_use_preview_apply": {
          "type": "boolean"
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "effective_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "downgrade_trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "degraded_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_labels_never_substitute_test_identity",
        "parameterized_templates_distinct_from_invocations",
        "partial_discovery_stays_visible",
        "imported_results_never_masquerade_as_local",
        "quarantines_visible_filterable_exportable",
        "proposals_use_preview_diff_apply",
        "rows_auto_downgrade_on_unidentified_objects"
      ],
      "properties": {
        "display_labels_never_substitute_test_identity": {
          "type": "boolean"
        },
        "parameterized_templates_distinct_from_invocations": {
          "type": "boolean"
        },
        "partial_discovery_stays_visible": {
          "type": "boolean"
        },
        "imported_results_never_masquerade_as_local": {
          "type": "boolean"
        },
        "quarantines_visible_filterable_exportable": {
          "type": "boolean"
        },
        "proposals_use_preview_diff_apply": {
          "type": "boolean"
        },
        "rows_auto_downgrade_on_unidentified_objects": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_matrix",
        "docs_help_ingests_matrix",
        "diagnostics_ingests_matrix",
        "ai_review_ingests_matrix",
        "release_control_ingests_matrix",
        "downgraded_rows_labeled_below_current"
      ],
      "properties": {
        "product_ingests_matrix": {
          "type": "boolean"
        },
        "docs_help_ingests_matrix": {
          "type": "boolean"
        },
        "diagnostics_ingests_matrix": {
          "type": "boolean"
        },
        "ai_review_ingests_matrix": {
          "type": "boolean"
        },
        "release_control_ingests_matrix": {
          "type": "boolean"
        },
        "downgraded_rows_labeled_below_current": {
          "type": "boolean"
        }
      }
    },
    "evidence_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_freshness_slo_hours",
        "last_evidence_refresh",
        "auto_downgrade_on_stale"
      ],
      "properties": {
        "evidence_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_evidence_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_downgrade_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
