{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/testing/ai_test_generation_gate.schema.json",
  "title": "Aureline AI test-generation gate record",
  "description": "Boundary schema for the ai_test_generation_gate_record frozen in docs/testing/test_intelligence_and_acceptance_contract.md. The record preserves requested scope, cited evidence, selector truth, protected-path restrictions, preview requirement, sandbox/run plan, and no-automatic-land posture for AI-generated test proposals. Generated source and patch bodies remain outside this record; the gate carries refs, counts, class labels, bounded summaries, and timestamps only. Raw command lines, raw stdout or stderr bytes, raw environment bodies, raw absolute paths, raw URLs, raw secret values, raw test names, raw assertion bodies, raw source excerpts, raw generated test source, raw AI prompt text, raw provider payloads, and raw stack traces MUST NOT cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/ai_test_generation_gate_record" }
  ],
  "$defs": {
    "ai_test_generation_gate_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "enum": ["ai_test_generation_gate_record"]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for logs, RPC, support bundles, release packets, and review exports."
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque ref to another governed record."
    },
    "opaque_ref_nullable": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 520,
      "description": "Short reviewable sentence. Raw code, raw paths, raw secrets, raw tool arguments, raw test names, raw provider payloads, raw generated test source, raw prompt text, and raw runner payloads are forbidden."
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_and_hashes_only",
        "support_bundle_scoped",
        "broadened_capture"
      ]
    },
    "gate_decision_class": {
      "type": "string",
      "enum": [
        "ready_for_user_review",
        "preview_required_missing",
        "blocked_missing_evidence",
        "blocked_selector_unresolved",
        "blocked_protected_path",
        "blocked_policy_restriction",
        "blocked_sandbox_or_run_required",
        "gate_decision_unknown_requires_review"
      ],
      "description": "Closed gate-decision vocabulary. ready_for_user_review still forbids automatic landing; it only admits a human review path."
    },
    "requested_scope_class": {
      "type": "string",
      "enum": [
        "uncovered_path_scope",
        "changed_files_scope",
        "bug_regression_scope",
        "flaky_reproduction_scope",
        "snapshot_guard_scope",
        "explicit_selector_scope",
        "release_claim_gap_scope",
        "requested_scope_unknown_requires_review"
      ]
    },
    "evidence_source_class": {
      "type": "string",
      "enum": [
        "coverage_merge_result",
        "flaky_verdict",
        "bug_report",
        "diagnostic",
        "review_comment",
        "source_change",
        "user_request",
        "imported_provider_artifact",
        "test_failure_history",
        "vulnerability_or_policy",
        "evidence_source_unknown_requires_review"
      ]
    },
    "selector_resolution_class": {
      "type": "string",
      "enum": [
        "resolved_exact",
        "resolved_with_reviewed_widening",
        "unresolved",
        "display_label_only_denied",
        "stale_resolution_requires_refresh",
        "policy_limited",
        "selector_resolution_unknown_requires_review"
      ],
      "description": "Closed selector-truth vocabulary. Unresolved, display-label-only, stale, policy-limited, and unknown states block automatic action."
    },
    "selector_widening_class": {
      "type": "string",
      "enum": [
        "no_widening",
        "widening_reviewed_and_accepted",
        "widening_requires_review",
        "widening_denied",
        "widening_unknown_requires_review"
      ]
    },
    "protected_path_restriction_class": {
      "type": "string",
      "enum": [
        "no_protected_paths",
        "protected_path_review_required",
        "claimed_stable_path_review_required",
        "generated_source_boundary_review_required",
        "policy_owned_path_blocked",
        "protected_path_restriction_unknown_requires_review"
      ],
      "description": "Closed protected-path vocabulary. Any value outside no_protected_paths blocks automatic landing."
    },
    "preview_requirement_class": {
      "type": "string",
      "enum": [
        "preview_present",
        "preview_missing",
        "preview_stale",
        "preview_incomplete",
        "preview_requirement_unknown_requires_review"
      ]
    },
    "preview_completeness_class": {
      "type": "string",
      "enum": [
        "complete_for_requested_scope",
        "partial_due_to_unresolved_selector",
        "partial_due_to_protected_paths",
        "partial_due_to_policy",
        "preview_missing",
        "preview_stale",
        "preview_completeness_unknown_requires_review"
      ]
    },
    "sandbox_plan_class": {
      "type": "string",
      "enum": [
        "sandbox_plan_pending",
        "sandbox_executed_passed",
        "sandbox_executed_failed",
        "sandbox_blocked_by_policy",
        "sandbox_incompatible",
        "sandbox_not_applicable_review_only",
        "sandbox_plan_unknown_requires_review"
      ],
      "description": "Closed sandbox/run vocabulary. Pending, failed, blocked, incompatible, and unknown states cannot be summarized as validation success."
    },
    "side_effect_posture_class": {
      "type": "string",
      "enum": [
        "read_only_plan",
        "local_write_preview_only",
        "local_write_manual_apply",
        "remote_or_provider_write_denied",
        "side_effect_posture_unknown_requires_review"
      ]
    },
    "no_automatic_land_class": {
      "type": "string",
      "enum": [
        "proposal_only_no_apply",
        "manual_apply_after_review_only",
        "side_branch_only_pending_review",
        "automatic_land_forbidden",
        "no_automatic_land_unknown_requires_review"
      ],
      "description": "Mandatory no-automatic-land posture. There is no conforming value that lets generated tests land automatically."
    },
    "denial_reason_class": {
      "type": "string",
      "enum": [
        "ai_test_generation_gate_must_cite_requested_scope",
        "ai_test_generation_gate_must_cite_evidence",
        "ai_test_generation_gate_must_carry_selector_truth",
        "ai_test_generation_gate_must_block_unresolved_selector",
        "ai_test_generation_gate_must_block_display_label_only_selector",
        "ai_test_generation_gate_must_block_protected_path_without_review",
        "ai_test_generation_gate_must_carry_preview_ref",
        "ai_test_generation_gate_must_not_bypass_preview",
        "ai_test_generation_gate_must_carry_sandbox_or_run_plan",
        "ai_test_generation_gate_must_not_treat_pending_run_as_passed",
        "ai_test_generation_gate_must_carry_no_automatic_land_class",
        "ai_test_generation_gate_must_not_auto_land_generated_tests",
        "ai_test_generation_gate_unknown_requires_review"
      ]
    },
    "evidence_citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_citation_id",
        "evidence_source_class",
        "evidence_ref",
        "freshness_ref",
        "supports_requested_scope",
        "evidence_summary"
      ],
      "properties": {
        "evidence_citation_id": { "$ref": "#/$defs/opaque_id" },
        "evidence_source_class": { "$ref": "#/$defs/evidence_source_class" },
        "evidence_ref": { "$ref": "#/$defs/opaque_ref" },
        "freshness_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "supports_requested_scope": { "type": "boolean" },
        "evidence_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "requested_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_scope_class",
        "selector_refs",
        "canonical_test_item_refs",
        "source_object_refs",
        "coverage_merge_result_refs",
        "test_session_refs",
        "target_environment_refs",
        "scope_summary"
      ],
      "properties": {
        "requested_scope_class": { "$ref": "#/$defs/requested_scope_class" },
        "selector_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "canonical_test_item_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "source_object_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "coverage_merge_result_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "test_session_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "target_environment_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "scope_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "selector_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selector_resolution_class",
        "selector_widening_class",
        "matched_canonical_test_item_refs",
        "omitted_scope_refs",
        "unresolved_selector_refs",
        "selector_truth_summary"
      ],
      "properties": {
        "selector_resolution_class": { "$ref": "#/$defs/selector_resolution_class" },
        "selector_widening_class": { "$ref": "#/$defs/selector_widening_class" },
        "matched_canonical_test_item_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "omitted_scope_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "unresolved_selector_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "selector_truth_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "protected_path_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protected_path_restriction_class",
        "protected_path_refs",
        "claimed_stable_path_refs",
        "required_owner_or_reviewer_refs",
        "policy_refs",
        "restriction_summary"
      ],
      "properties": {
        "protected_path_restriction_class": { "$ref": "#/$defs/protected_path_restriction_class" },
        "protected_path_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "claimed_stable_path_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "required_owner_or_reviewer_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "policy_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "restriction_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "preview_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_requirement_class",
        "preview_completeness_class",
        "patch_preview_ref",
        "review_sheet_ref",
        "rollback_or_checkpoint_refs",
        "preview_summary"
      ],
      "properties": {
        "preview_requirement_class": { "$ref": "#/$defs/preview_requirement_class" },
        "preview_completeness_class": { "$ref": "#/$defs/preview_completeness_class" },
        "patch_preview_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "review_sheet_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "rollback_or_checkpoint_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "preview_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "sandbox_run_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sandbox_plan_class",
        "side_effect_posture_class",
        "planned_command_refs",
        "target_environment_refs",
        "result_attempt_refs",
        "sandbox_summary"
      ],
      "properties": {
        "sandbox_plan_class": { "$ref": "#/$defs/sandbox_plan_class" },
        "side_effect_posture_class": { "$ref": "#/$defs/side_effect_posture_class" },
        "planned_command_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "target_environment_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "result_attempt_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "sandbox_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "ai_test_generation_gate_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "ai_test_generation_gate_schema_version",
        "ai_test_generation_gate_record_id",
        "requested_scope",
        "cited_evidence",
        "selector_truth",
        "protected_path_review",
        "preview_gate",
        "sandbox_run_plan",
        "gate_decision_class",
        "no_automatic_land_class",
        "proposal_branch_or_worktree_ref",
        "audit_event_refs",
        "denial_reason_class",
        "captured_at",
        "redaction_class",
        "approval_ticket_ref"
      ],
      "properties": {
        "record_kind": { "const": "ai_test_generation_gate_record" },
        "ai_test_generation_gate_schema_version": { "$ref": "#/$defs/ai_test_generation_gate_schema_version" },
        "ai_test_generation_gate_record_id": { "$ref": "#/$defs/opaque_id" },
        "requested_scope": { "$ref": "#/$defs/requested_scope" },
        "cited_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence_citation" }
        },
        "selector_truth": { "$ref": "#/$defs/selector_truth" },
        "protected_path_review": { "$ref": "#/$defs/protected_path_review" },
        "preview_gate": { "$ref": "#/$defs/preview_gate" },
        "sandbox_run_plan": { "$ref": "#/$defs/sandbox_run_plan" },
        "gate_decision_class": { "$ref": "#/$defs/gate_decision_class" },
        "no_automatic_land_class": { "$ref": "#/$defs/no_automatic_land_class" },
        "proposal_branch_or_worktree_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "gate_summary": { "$ref": "#/$defs/short_sentence" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "denial_reason_class": {
          "oneOf": [
            { "$ref": "#/$defs/denial_reason_class" },
            { "type": "null" }
          ]
        },
        "captured_at": { "$ref": "#/$defs/timestamp" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "approval_ticket_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "notes": { "$ref": "#/$defs/short_sentence" }
      }
    }
  }
}
