{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/testing/coverage_merge_result.schema.json",
  "title": "Aureline coverage merge result record",
  "description": "Boundary schema for the coverage_merge_result_record frozen in docs/testing/test_intelligence_and_acceptance_contract.md. The record preserves which coverage artifacts, shards, platforms, commit/build identities, toolchain identities, and metric families were included or omitted by a coverage merge, plus partial/incompatible warnings and the resulting claim scope. Coverage bytes remain on the artifact rail; this record carries refs, counts, class labels, bounded summaries, and timestamps only. Raw command lines, raw stdout or stderr bytes, raw environment bodies, raw absolute paths, raw URLs, raw secret values, raw test names, raw assertion bodies, raw source excerpts, raw coverage payloads, raw provider payloads, and raw stack traces MUST NOT cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/coverage_merge_result_record" }
  ],
  "$defs": {
    "coverage_merge_result_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "enum": ["coverage_merge_result_record"]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for logs, RPC, support bundles, release packets, and review exports."
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque ref to another governed record."
    },
    "opaque_ref_nullable": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 520,
      "description": "Short reviewable sentence. Raw code, raw paths, raw secrets, raw tool arguments, raw test names, raw provider payloads, and raw runner payloads are forbidden."
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "non_negative_integer_nullable": {
      "oneOf": [
        { "$ref": "#/$defs/non_negative_integer" },
        { "type": "null" }
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_and_hashes_only",
        "support_bundle_scoped",
        "broadened_capture"
      ]
    },
    "merge_basis_class": {
      "type": "string",
      "enum": [
        "explicit_user_merge",
        "automatic_review_projection",
        "provider_import_reconstruction",
        "release_evidence_projection",
        "support_export_projection",
        "merge_basis_unknown_requires_review"
      ],
      "description": "Why this merge result was produced. Unknown fails closed and cannot be rendered as a complete coverage state."
    },
    "input_source_class": {
      "type": "string",
      "enum": [
        "local_test_attempt",
        "provider_imported_artifact",
        "mirrored_provider_artifact",
        "cached_local_artifact",
        "release_evidence_artifact",
        "support_bundle_artifact",
        "input_source_unknown_requires_review"
      ]
    },
    "coverage_format_class": {
      "type": "string",
      "enum": [
        "lcov",
        "gcov",
        "llvm_profdata",
        "cobertura_xml",
        "jacoco_xml",
        "coverage_json",
        "provider_native",
        "coverage_format_unknown_requires_review"
      ]
    },
    "metric_support_class": {
      "type": "string",
      "enum": [
        "line_only",
        "branch_only",
        "line_and_branch",
        "line_supported_branch_missing",
        "branch_supported_line_missing",
        "metric_unsupported",
        "metric_support_unknown_requires_review"
      ],
      "description": "Line and branch coverage support for an input artifact. Missing branch support is distinct from branch coverage zero."
    },
    "coverage_support_class": {
      "type": "string",
      "enum": [
        "supported_complete",
        "supported_partial",
        "unsupported_not_collected",
        "unsupported_format",
        "incompatible_excluded",
        "support_unknown_requires_review"
      ]
    },
    "merge_completeness_class": {
      "type": "string",
      "enum": [
        "complete_exact_scope",
        "partial_missing_shards",
        "partial_omitted_platforms",
        "partial_redaction_or_policy_limited",
        "incompatible_metrics_excluded",
        "incompatible_branch_coverage_excluded",
        "no_compatible_artifacts",
        "merge_completeness_unknown_requires_review"
      ],
      "description": "Closed completeness vocabulary. complete_exact_scope is allowed only when all expected shards, platforms, and metric families were included and no warnings are present."
    },
    "warning_class": {
      "type": "string",
      "enum": [
        "missing_shard",
        "omitted_platform",
        "stale_artifact",
        "source_revision_mismatch",
        "build_identity_mismatch",
        "toolchain_identity_mismatch",
        "incompatible_format",
        "incompatible_metric_family",
        "incompatible_branch_coverage",
        "line_only_degraded",
        "branch_only_degraded",
        "policy_limited_scope",
        "redaction_limited_scope",
        "partial_scope",
        "warning_unknown_requires_review"
      ]
    },
    "omission_reason_class": {
      "type": "string",
      "enum": [
        "missing_shard",
        "artifact_unreadable",
        "artifact_stale",
        "format_incompatible",
        "metric_family_incompatible",
        "branch_coverage_incompatible",
        "platform_not_requested",
        "platform_missing",
        "policy_redacted",
        "source_revision_mismatch",
        "build_identity_mismatch",
        "omission_reason_unknown_requires_review"
      ]
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "full_workspace_scope",
        "current_root_scope",
        "named_workset_scope",
        "sparse_slice_scope",
        "changed_files_only_scope",
        "explicit_test_item_set_scope",
        "release_packet_scope",
        "support_export_scope",
        "scope_unknown_requires_review"
      ]
    },
    "platform_class": {
      "type": "string",
      "enum": [
        "linux",
        "macos",
        "windows",
        "container",
        "remote",
        "managed_provider",
        "platform_mixed",
        "platform_unknown_requires_review"
      ]
    },
    "review_state_class": {
      "type": "string",
      "enum": [
        "complete_reviewed",
        "reviewable_with_warnings",
        "blocked_incompatible",
        "blocked_no_compatible_artifacts",
        "draft_pending_review",
        "review_state_unknown_requires_review"
      ]
    },
    "denial_reason_class": {
      "type": "string",
      "enum": [
        "coverage_merge_result_must_cite_included_artifacts",
        "coverage_merge_result_must_cite_commit_and_build_identity",
        "coverage_merge_result_must_carry_line_and_branch_support",
        "coverage_merge_result_must_disclose_missing_shards",
        "coverage_merge_result_must_disclose_omitted_platforms",
        "coverage_merge_result_must_disclose_incompatible_metrics",
        "coverage_merge_result_must_not_claim_complete_when_warnings_present",
        "coverage_merge_result_must_not_treat_missing_branch_as_zero",
        "coverage_merge_result_must_carry_resulting_scope",
        "coverage_merge_result_completeness_unknown_requires_review",
        "coverage_merge_result_scope_unknown_requires_review"
      ]
    },
    "coverage_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coverage_input_id",
        "source_class",
        "coverage_artifact_event_ref",
        "platform_class",
        "target_environment_ref",
        "commit_ref",
        "build_identity_ref",
        "toolchain_identity_ref",
        "coverage_format_class",
        "metric_support_class",
        "file_count",
        "line_count",
        "branch_count"
      ],
      "properties": {
        "coverage_input_id": { "$ref": "#/$defs/opaque_id" },
        "source_class": { "$ref": "#/$defs/input_source_class" },
        "coverage_artifact_event_ref": { "$ref": "#/$defs/opaque_ref" },
        "test_session_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "test_attempt_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "run_summary_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "coverage_handoff_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "shard_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "platform_class": { "$ref": "#/$defs/platform_class" },
        "target_environment_ref": { "$ref": "#/$defs/opaque_ref" },
        "commit_ref": { "$ref": "#/$defs/opaque_ref" },
        "build_identity_ref": { "$ref": "#/$defs/opaque_ref" },
        "toolchain_identity_ref": { "$ref": "#/$defs/opaque_ref" },
        "coverage_format_class": { "$ref": "#/$defs/coverage_format_class" },
        "metric_support_class": { "$ref": "#/$defs/metric_support_class" },
        "file_count": { "$ref": "#/$defs/non_negative_integer" },
        "line_count": { "$ref": "#/$defs/non_negative_integer" },
        "branch_count": { "$ref": "#/$defs/non_negative_integer_nullable" },
        "input_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "omitted_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "omitted_input_ref",
        "omission_reason_class",
        "platform_class",
        "commit_ref",
        "build_identity_ref",
        "omission_summary"
      ],
      "properties": {
        "omitted_input_ref": { "$ref": "#/$defs/opaque_ref" },
        "omission_reason_class": { "$ref": "#/$defs/omission_reason_class" },
        "platform_class": { "$ref": "#/$defs/platform_class" },
        "commit_ref": { "$ref": "#/$defs/opaque_ref" },
        "build_identity_ref": { "$ref": "#/$defs/opaque_ref" },
        "shard_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "coverage_artifact_event_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "omission_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "merge_warning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "warning_class",
        "warning_ref",
        "affected_input_refs",
        "warning_summary"
      ],
      "properties": {
        "warning_class": { "$ref": "#/$defs/warning_class" },
        "warning_ref": { "$ref": "#/$defs/opaque_ref" },
        "affected_input_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "warning_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "resulting_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_class",
        "included_root_refs",
        "omitted_root_refs",
        "canonical_test_item_refs",
        "target_environment_refs",
        "platform_classes",
        "file_count",
        "covered_line_count",
        "total_line_count",
        "covered_branch_count",
        "total_branch_count",
        "scope_summary"
      ],
      "properties": {
        "scope_class": { "$ref": "#/$defs/scope_class" },
        "included_root_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "omitted_root_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "canonical_test_item_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "target_environment_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "platform_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/platform_class" }
        },
        "file_count": { "$ref": "#/$defs/non_negative_integer" },
        "covered_line_count": { "$ref": "#/$defs/non_negative_integer" },
        "total_line_count": { "$ref": "#/$defs/non_negative_integer" },
        "covered_branch_count": { "$ref": "#/$defs/non_negative_integer_nullable" },
        "total_branch_count": { "$ref": "#/$defs/non_negative_integer_nullable" },
        "scope_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "coverage_merge_result_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "coverage_merge_result_schema_version",
        "coverage_merge_result_record_id",
        "merge_basis_class",
        "source_revision_ref",
        "merge_commit_ref",
        "merge_build_identity_ref",
        "merge_toolchain_identity_ref",
        "included_inputs",
        "omitted_inputs",
        "line_coverage_support_class",
        "branch_coverage_support_class",
        "merge_completeness_class",
        "warnings",
        "resulting_scope",
        "review_state_class",
        "audit_event_refs",
        "denial_reason_class",
        "captured_at",
        "redaction_class",
        "approval_ticket_ref"
      ],
      "properties": {
        "record_kind": { "const": "coverage_merge_result_record" },
        "coverage_merge_result_schema_version": { "$ref": "#/$defs/coverage_merge_result_schema_version" },
        "coverage_merge_result_record_id": { "$ref": "#/$defs/opaque_id" },
        "merge_basis_class": { "$ref": "#/$defs/merge_basis_class" },
        "source_revision_ref": { "$ref": "#/$defs/opaque_ref" },
        "merge_commit_ref": { "$ref": "#/$defs/opaque_ref" },
        "merge_build_identity_ref": { "$ref": "#/$defs/opaque_ref" },
        "merge_toolchain_identity_ref": { "$ref": "#/$defs/opaque_ref" },
        "test_session_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "test_attempt_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "run_summary_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "coverage_handoff_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "included_inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/coverage_input" }
        },
        "omitted_inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/omitted_input" }
        },
        "line_coverage_support_class": { "$ref": "#/$defs/coverage_support_class" },
        "branch_coverage_support_class": { "$ref": "#/$defs/coverage_support_class" },
        "merge_completeness_class": { "$ref": "#/$defs/merge_completeness_class" },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/merge_warning" }
        },
        "resulting_scope": { "$ref": "#/$defs/resulting_scope" },
        "review_state_class": { "$ref": "#/$defs/review_state_class" },
        "surface_summary": { "$ref": "#/$defs/short_sentence" },
        "release_use_allowed": {
          "type": "boolean",
          "description": "Whether this merge may be consumed by release evidence without additional waiver or claim narrowing."
        },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "denial_reason_class": {
          "oneOf": [
            { "$ref": "#/$defs/denial_reason_class" },
            { "type": "null" }
          ]
        },
        "captured_at": { "$ref": "#/$defs/timestamp" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "approval_ticket_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "notes": { "$ref": "#/$defs/short_sentence" }
      }
    }
  }
}
