{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/testing/flaky_verdict.schema.json",
  "title": "Aureline test flaky-verdict packet",
  "description": "Boundary schema for the release-facing flaky-verdict packet. The packet ties a verdict to concrete canonical attempt-ledger inputs: attempt refs, result tokens, target ids, execution-context refs, imported-CI class, source drift, watch state, predecessor, and origin. Raw logs, raw assertions, raw test names, raw paths, raw environment bodies, and raw provider payloads never cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/test_flaky_verdict_packet_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1
    },
    "framework_token": {
      "type": "string",
      "enum": ["pytest"]
    },
    "flaky_verdict_token": {
      "type": "string",
      "enum": [
        "suspected_flaky",
        "reproduced_flaky",
        "stable_again",
        "muted",
        "unknown"
      ]
    },
    "triage_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_test_item_ref",
        "selector_ref",
        "test_session_ref",
        "framework",
        "framework_token",
        "tree_row_ref",
        "inline_row_ref"
      ],
      "properties": {
        "canonical_test_item_ref": { "$ref": "#/$defs/opaque_ref" },
        "selector_ref": { "$ref": "#/$defs/opaque_ref" },
        "test_session_ref": { "$ref": "#/$defs/opaque_ref" },
        "framework": { "$ref": "#/$defs/framework_token" },
        "framework_token": { "$ref": "#/$defs/framework_token" },
        "tree_row_ref": { "$ref": "#/$defs/opaque_ref" },
        "inline_row_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "flaky_verdict_attempt_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attempt_ref",
        "attempt_index",
        "attempt_kind_token",
        "result_state_token",
        "execution_context_ref",
        "target_id",
        "target_class_token",
        "imported_ci_projection_token",
        "source_drift_state_token",
        "watch_state_at_attempt_token"
      ],
      "properties": {
        "attempt_ref": { "$ref": "#/$defs/opaque_ref" },
        "attempt_index": { "type": "integer", "minimum": 1 },
        "attempt_kind_token": { "type": "string", "minLength": 1 },
        "result_state_token": { "type": "string", "minLength": 1 },
        "execution_context_ref": { "$ref": "#/$defs/opaque_ref" },
        "target_id": { "$ref": "#/$defs/opaque_id" },
        "target_class_token": { "type": "string", "minLength": 1 },
        "imported_ci_projection_token": { "type": "string", "minLength": 1 },
        "source_drift_state_token": { "type": "string", "minLength": 1 },
        "watch_state_at_attempt_token": { "type": "string", "minLength": 1 },
        "predecessor_attempt_ref": { "$ref": "#/$defs/opaque_ref" },
        "origin_attempt_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "test_flaky_verdict_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "flaky_verdict_packet_id",
        "identity",
        "verdict_state",
        "verdict_token",
        "evidence_attempt_refs",
        "evidence_attempts",
        "observation_window_attempts",
        "release_visible",
        "summary"
      ],
      "properties": {
        "record_kind": { "const": "test_flaky_verdict_packet_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "flaky_verdict_packet_id": { "$ref": "#/$defs/opaque_id" },
        "identity": { "$ref": "#/$defs/triage_identity" },
        "verdict_state": { "$ref": "#/$defs/flaky_verdict_token" },
        "verdict_token": { "$ref": "#/$defs/flaky_verdict_token" },
        "producing_test_attempt_ref": { "$ref": "#/$defs/opaque_ref" },
        "evidence_attempt_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "evidence_attempts": {
          "type": "array",
          "items": { "$ref": "#/$defs/flaky_verdict_attempt_input" }
        },
        "observation_window_attempts": { "type": "integer", "minimum": 0 },
        "release_visible": { "type": "boolean" },
        "summary": { "type": "string", "minLength": 1 }
      }
    }
  }
}
