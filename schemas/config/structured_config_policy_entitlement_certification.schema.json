{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/config/structured_config_policy_entitlement_certification.schema.json",
  "title": "Structured Config Policy Entitlement Certification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "shared_contract_ref",
    "as_of",
    "notice",
    "upstream_packets",
    "artifact_rows",
    "profile_rows",
    "surface_rows",
    "downgrade_rules",
    "summary",
    "docs_ref",
    "help_doc_ref",
    "schema_ref"
  ],
  "properties": {
    "record_kind": {
      "const": "structured_config_policy_entitlement_certification"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "shared_contract_ref": {
      "const": "config:structured_config_policy_entitlement_certification:v1"
    },
    "as_of": {
      "type": "string",
      "minLength": 1
    },
    "notice": {
      "type": "string",
      "minLength": 1
    },
    "upstream_packets": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/source_packet_ref"
      }
    },
    "artifact_rows": {
      "type": "array",
      "minItems": 13,
      "items": {
        "$ref": "#/$defs/artifact_row"
      }
    },
    "profile_rows": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/profile_row"
      }
    },
    "surface_rows": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/surface_row"
      }
    },
    "downgrade_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/downgrade_rule"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "docs_ref": {
      "type": "string",
      "minLength": 1
    },
    "help_doc_ref": {
      "type": "string",
      "minLength": 1
    },
    "schema_ref": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "artifact_family": {
      "type": "string",
      "enum": [
        "request_workspace_environment",
        "database_profile",
        "api_profile",
        "notebook_runtime_manifest",
        "preview_runtime_config",
        "workflow_bundle_manifest",
        "ci_environment_descriptor",
        "infra_environment_descriptor",
        "managed_policy_overlay",
        "admin_policy_bundle_artifact",
        "offline_entitlement_snapshot_artifact",
        "emergency_disable_bundle_artifact",
        "trust_root_signer_update_artifact"
      ]
    },
    "bundle_class": {
      "type": "string",
      "enum": [
        "admin_policy_bundle",
        "offline_entitlement_snapshot",
        "emergency_disable_bundle",
        "trust_root_signer_update"
      ]
    },
    "claim_ceiling": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview"
      ]
    },
    "certification_state": {
      "type": "string",
      "enum": [
        "certified",
        "limited",
        "offline_only",
        "retest_pending"
      ]
    },
    "narrowing_reason": {
      "type": "string",
      "enum": [
        "preview_dependency",
        "depth_incomplete",
        "stale_policy_evidence",
        "reauth_required",
        "signer_rotation_pending",
        "mirror_offline_fallback",
        "reference_workspace_drill_missing",
        "admin_auditability_incomplete"
      ]
    },
    "deployment_profile": {
      "type": "string",
      "enum": [
        "local_only",
        "managed",
        "self_hosted",
        "mirrored",
        "fully_air_gapped"
      ]
    },
    "source_packet_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_ref",
        "shared_contract_ref"
      ],
      "properties": {
        "packet_ref": {
          "type": "string",
          "minLength": 1
        },
        "shared_contract_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifact_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "lane_class",
        "family_ref",
        "summary",
        "claim_ceiling",
        "published_state",
        "truth_planes_reviewable",
        "mode_layer_reviewable",
        "parameter_provenance_reviewable",
        "secret_reference_class_visible",
        "policy_lock_visible",
        "signed_path_reviewable",
        "admin_auditability",
        "supported_profiles",
        "evidence_as_of",
        "evidence_age_days",
        "upstream_packet_refs",
        "visible_labels",
        "narrowing_reasons"
      ],
      "properties": {
        "family": {
          "$ref": "#/$defs/artifact_family"
        },
        "lane_class": {
          "type": "string",
          "enum": [
            "structured_config",
            "signed_bundle_review"
          ]
        },
        "family_ref": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "claim_ceiling": {
          "$ref": "#/$defs/claim_ceiling"
        },
        "published_state": {
          "$ref": "#/$defs/certification_state"
        },
        "truth_planes_reviewable": {
          "type": "boolean"
        },
        "mode_layer_reviewable": {
          "type": "boolean"
        },
        "parameter_provenance_reviewable": {
          "type": "boolean"
        },
        "secret_reference_class_visible": {
          "type": "boolean"
        },
        "policy_lock_visible": {
          "type": "boolean"
        },
        "signed_path_reviewable": {
          "type": "boolean"
        },
        "admin_auditability": {
          "type": "string",
          "enum": [
            "explainable_export_ready",
            "explainable_local_safe_only",
            "incomplete"
          ]
        },
        "supported_profiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/deployment_profile"
          }
        },
        "evidence_as_of": {
          "type": "string",
          "minLength": 1
        },
        "evidence_age_days": {
          "type": "integer",
          "minimum": 0
        },
        "upstream_packet_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "visible_labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "narrowing_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/narrowing_reason"
          }
        }
      }
    },
    "profile_drill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drill_kind",
        "status",
        "executed_at",
        "evidence_ref",
        "summary"
      ],
      "properties": {
        "drill_kind": {
          "type": "string",
          "enum": [
            "reference_workspace",
            "mirror_offline",
            "managed_self_hosted",
            "stale_policy",
            "reauth_required",
            "signer_rotation"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "passed_current",
            "passed_narrowed",
            "not_applicable",
            "retest_pending"
          ]
        },
        "executed_at": {
          "type": "string",
          "minLength": 1
        },
        "evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "profile_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "claim_ceiling",
        "published_state",
        "required_bundle_classes",
        "distribution_paths",
        "managed_auth_dependency",
        "local_safe_label",
        "known_limits",
        "drills",
        "evidence_as_of",
        "evidence_age_days",
        "narrowing_reasons"
      ],
      "properties": {
        "profile": {
          "$ref": "#/$defs/deployment_profile"
        },
        "claim_ceiling": {
          "$ref": "#/$defs/claim_ceiling"
        },
        "published_state": {
          "$ref": "#/$defs/certification_state"
        },
        "required_bundle_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/bundle_class"
          }
        },
        "distribution_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "managed_auth_dependency": {
          "type": "string"
        },
        "local_safe_label": {
          "type": "string"
        },
        "known_limits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "drills": {
          "type": "array",
          "minItems": 6,
          "items": {
            "$ref": "#/$defs/profile_drill"
          }
        },
        "evidence_as_of": {
          "type": "string",
          "minLength": 1
        },
        "evidence_age_days": {
          "type": "integer",
          "minimum": 0
        },
        "narrowing_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/narrowing_reason"
          }
        }
      }
    },
    "surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "packet_ref",
        "shows_published_state",
        "shows_evidence_age",
        "shows_local_safe_floor",
        "shows_supported_profiles",
        "shows_narrowing_reasons"
      ],
      "properties": {
        "surface": {
          "type": "string",
          "enum": [
            "release_center",
            "help_about",
            "support_export",
            "docs_help",
            "shiproom"
          ]
        },
        "packet_ref": {
          "type": "string",
          "minLength": 1
        },
        "shows_published_state": {
          "type": "boolean"
        },
        "shows_evidence_age": {
          "type": "boolean"
        },
        "shows_local_safe_floor": {
          "type": "boolean"
        },
        "shows_supported_profiles": {
          "type": "boolean"
        },
        "shows_narrowing_reasons": {
          "type": "boolean"
        }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger",
        "narrow_to",
        "rationale"
      ],
      "properties": {
        "trigger": {
          "$ref": "#/$defs/narrowing_reason"
        },
        "narrow_to": {
          "$ref": "#/$defs/certification_state"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_family_count",
        "certified_artifact_family_count",
        "narrowed_artifact_family_count",
        "profile_count",
        "certified_profile_count",
        "publication_surface_count",
        "local_safe_floor_visible_everywhere",
        "publication_surfaces_aligned"
      ],
      "properties": {
        "artifact_family_count": {
          "type": "integer",
          "minimum": 0
        },
        "certified_artifact_family_count": {
          "type": "integer",
          "minimum": 0
        },
        "narrowed_artifact_family_count": {
          "type": "integer",
          "minimum": 0
        },
        "profile_count": {
          "type": "integer",
          "minimum": 0
        },
        "certified_profile_count": {
          "type": "integer",
          "minimum": 0
        },
        "publication_surface_count": {
          "type": "integer",
          "minimum": 0
        },
        "local_safe_floor_visible_everywhere": {
          "type": "boolean"
        },
        "publication_surfaces_aligned": {
          "type": "boolean"
        }
      }
    }
  }
}
