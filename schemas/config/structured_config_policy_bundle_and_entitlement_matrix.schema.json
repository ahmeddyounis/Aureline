{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/config/structured_config_policy_bundle_and_entitlement_matrix.schema.json",
  "title": "Aureline structured config, policy bundle, and offline entitlement matrix",
  "description": "Boundary schema for the canonical metadata-only packet that freezes config-bearing artifact families, signed-bundle taxonomy, and deployment-profile qualification rows. The packet keeps authored source, effective projection, and live or observed state distinct; names secret-handling and policy-lock posture; freezes envelope-field requirements for policy, entitlement, emergency-disable, and trust-root or signer-update bundles; and declares what local-only, managed, self-hosted, mirrored, and fully air-gapped profiles may honestly claim. Raw bundle bytes, trust-root material, endpoints, and secrets never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "matrix_id",
    "shared_contract_ref",
    "notice",
    "artifact_families",
    "bundle_taxonomy",
    "profile_qualifications",
    "summary",
    "docs_ref",
    "schema_ref"
  ],
  "properties": {
    "record_kind": {
      "const": "config_structured_config_policy_bundle_and_entitlement_matrix"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "matrix_id": {
      "type": "string",
      "minLength": 1
    },
    "shared_contract_ref": {
      "const": "config:structured_config_policy_bundle_and_entitlement_matrix:v1"
    },
    "notice": {
      "type": "string",
      "minLength": 1
    },
    "artifact_families": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_family_row" },
      "minItems": 13
    },
    "bundle_taxonomy": {
      "type": "array",
      "items": { "$ref": "#/$defs/bundle_taxonomy_row" },
      "minItems": 4
    },
    "profile_qualifications": {
      "type": "array",
      "items": { "$ref": "#/$defs/profile_qualification_row" },
      "minItems": 5
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "docs_ref": {
      "type": "string",
      "minLength": 1
    },
    "schema_ref": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "artifact_family_kind": {
      "type": "string",
      "enum": [
        "request_workspace_environment",
        "database_profile",
        "api_profile",
        "notebook_runtime_manifest",
        "preview_runtime_config",
        "workflow_bundle_manifest",
        "ci_environment_descriptor",
        "infra_environment_descriptor",
        "managed_policy_overlay",
        "admin_policy_bundle_artifact",
        "offline_entitlement_snapshot_artifact",
        "emergency_disable_bundle_artifact",
        "trust_root_signer_update_artifact"
      ]
    },
    "qualification_label": {
      "type": "string",
      "enum": ["stable", "beta", "preview"]
    },
    "live_state_posture": {
      "type": "string",
      "enum": [
        "not_supported",
        "deferred_by_runtime",
        "inspect_only_observed",
        "inspect_only_mirrored"
      ]
    },
    "source_layer": {
      "type": "string",
      "enum": [
        "embedded_default",
        "profile_import",
        "workspace_source",
        "user_override",
        "policy_bundle",
        "managed_override",
        "secret_reference",
        "runtime_discovery",
        "live_observation"
      ]
    },
    "secret_handling": {
      "type": "string",
      "enum": [
        "no_secrets_expected",
        "reference_or_handle_only",
        "redacted_placeholder_only",
        "key_path_locator_only"
      ]
    },
    "policy_lock_posture": {
      "type": "string",
      "enum": [
        "not_policy_owned",
        "narrowable_by_policy",
        "signed_bundle_owned",
        "emergency_disable_ratchet"
      ]
    },
    "distribution_path": {
      "type": "string",
      "enum": [
        "local_file",
        "signed_origin",
        "signed_mirror",
        "manual_import",
        "offline_bundle",
        "preseeded_cache"
      ]
    },
    "downgrade_label": {
      "type": "string",
      "enum": [
        "local_safe_only",
        "last_known_good",
        "stale_effective_projection",
        "stale_live_observation",
        "managed_actions_paused",
        "mirror_snapshot_in_use",
        "offline_snapshot_required",
        "preview_dependency_disclosed",
        "policy_locked"
      ]
    },
    "artifact_family_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "family_ref",
        "summary",
        "qualification_label",
        "authored_source",
        "effective_projection",
        "live_state_posture",
        "source_layers",
        "secret_handling",
        "policy_lock_posture",
        "distribution_paths",
        "downgrade_labels",
        "support_export_safe"
      ],
      "properties": {
        "family": { "$ref": "#/$defs/artifact_family_kind" },
        "family_ref": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "qualification_label": { "$ref": "#/$defs/qualification_label" },
        "authored_source": { "type": "boolean" },
        "effective_projection": { "type": "boolean" },
        "live_state_posture": { "$ref": "#/$defs/live_state_posture" },
        "source_layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_layer" },
          "minItems": 1
        },
        "secret_handling": { "$ref": "#/$defs/secret_handling" },
        "policy_lock_posture": { "$ref": "#/$defs/policy_lock_posture" },
        "distribution_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/distribution_path" },
          "minItems": 1
        },
        "downgrade_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_label" },
          "minItems": 1
        },
        "support_export_safe": { "type": "boolean" }
      }
    },
    "bundle_class": {
      "type": "string",
      "enum": [
        "admin_policy_bundle",
        "offline_entitlement_snapshot",
        "emergency_disable_bundle",
        "trust_root_signer_update"
      ]
    },
    "envelope_field": {
      "type": "string",
      "enum": [
        "bundle_id",
        "bundle_class",
        "schema_version",
        "issued_at",
        "valid_from",
        "valid_until",
        "signer_ref",
        "trust_root_ref",
        "scope_ref",
        "digest_ref",
        "payload_ref",
        "precedence_layer",
        "distribution_path",
        "grace_window",
        "supersedes_refs",
        "revokes_refs",
        "emergency_reason",
        "rotation_window"
      ]
    },
    "bundle_precedence": {
      "type": "string",
      "enum": [
        "signed_local_admin_bundle",
        "entitlement_gate",
        "emergency_disable",
        "trust_root_update_gate"
      ]
    },
    "expiry_guidance": {
      "type": "string",
      "enum": [
        "grace_window_required",
        "last_known_good_grace_allowed",
        "supersedes_or_expiry_required",
        "rotation_overlap_required"
      ]
    },
    "local_safe_label": {
      "type": "string",
      "enum": [
        "continue_local_only",
        "continue_with_last_known_good",
        "continue_with_mirror_snapshot",
        "continue_with_offline_snapshot",
        "continue_local_while_managed_actions_pause"
      ]
    },
    "bundle_taxonomy_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_class",
        "bundle_ref",
        "summary",
        "required_envelope_fields",
        "precedence_layer",
        "expiry_guidance",
        "supports_supersedes",
        "supports_revokes",
        "distribution_paths",
        "stale_label",
        "local_safe_label"
      ],
      "properties": {
        "bundle_class": { "$ref": "#/$defs/bundle_class" },
        "bundle_ref": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "required_envelope_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/envelope_field" },
          "minItems": 1
        },
        "precedence_layer": { "$ref": "#/$defs/bundle_precedence" },
        "expiry_guidance": { "$ref": "#/$defs/expiry_guidance" },
        "supports_supersedes": { "type": "boolean" },
        "supports_revokes": { "type": "boolean" },
        "distribution_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/distribution_path" },
          "minItems": 1
        },
        "stale_label": { "$ref": "#/$defs/downgrade_label" },
        "local_safe_label": { "$ref": "#/$defs/local_safe_label" }
      }
    },
    "deployment_profile": {
      "type": "string",
      "enum": [
        "local_only",
        "managed",
        "self_hosted",
        "mirrored",
        "fully_air_gapped"
      ]
    },
    "managed_auth_dependency": {
      "type": "string",
      "enum": [
        "none_local_only",
        "managed_live_or_last_known_good",
        "self_hosted_live_or_last_known_good",
        "mirror_snapshot_with_local_admin_cache",
        "offline_snapshot_and_local_admin_cache"
      ]
    },
    "known_limit": {
      "type": "string",
      "enum": [
        "no_managed_plane",
        "no_authoritative_live_observation",
        "manual_rotation_required",
        "mirror_freshness_may_stale",
        "hosted_capabilities_may_pause",
        "preview_rows_remain_narrowed"
      ]
    },
    "profile_qualification_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "qualification_label",
        "required_bundle_classes",
        "distribution_paths",
        "managed_auth_dependency",
        "local_safe_label",
        "downgrade_labels",
        "known_limits",
        "supports_authoritative_live_observation",
        "support_export_safe"
      ],
      "properties": {
        "profile": { "$ref": "#/$defs/deployment_profile" },
        "qualification_label": { "$ref": "#/$defs/qualification_label" },
        "required_bundle_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/bundle_class" }
        },
        "distribution_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/distribution_path" },
          "minItems": 1
        },
        "managed_auth_dependency": { "$ref": "#/$defs/managed_auth_dependency" },
        "local_safe_label": { "$ref": "#/$defs/local_safe_label" },
        "downgrade_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_label" },
          "minItems": 1
        },
        "known_limits": {
          "type": "array",
          "items": { "$ref": "#/$defs/known_limit" },
          "minItems": 1
        },
        "supports_authoritative_live_observation": { "type": "boolean" },
        "support_export_safe": { "type": "boolean" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_family_count",
        "bundle_class_count",
        "profile_count",
        "non_stable_artifact_family_count",
        "truth_planes_never_collapsed",
        "local_safe_continuation_preserved",
        "narrower_rows_explicit"
      ],
      "properties": {
        "artifact_family_count": { "type": "integer", "minimum": 1 },
        "bundle_class_count": { "type": "integer", "minimum": 1 },
        "profile_count": { "type": "integer", "minimum": 1 },
        "non_stable_artifact_family_count": { "type": "integer", "minimum": 0 },
        "truth_planes_never_collapsed": { "type": "boolean" },
        "local_safe_continuation_preserved": { "type": "boolean" },
        "narrower_rows_explicit": { "type": "boolean" }
      }
    }
  }
}
