{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/config/structured_config_artifact_modes_and_layers.schema.json",
  "title": "Aureline structured config artifact modes and layers",
  "description": "Boundary schema for the shared config-bearing artifact packet that freezes header disclosures, source/effective/live mode-switch semantics, and in-IDE environment-layer stacks across shell, CLI inspect, support export, and docs/help consumers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "shared_contract_ref",
    "notice",
    "upstream_family_matrix_ref",
    "header_vocabulary",
    "mode_vocabulary",
    "layer_vocabulary",
    "surface_vocabulary",
    "artifact_surfaces",
    "summary",
    "docs_ref",
    "schema_ref"
  ],
  "properties": {
    "record_kind": {
      "const": "structured_config_artifact_modes_and_layers"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "shared_contract_ref": {
      "const": "config:structured_config_artifact_modes_and_layers:v1"
    },
    "notice": {
      "type": "string",
      "minLength": 1
    },
    "upstream_family_matrix_ref": {
      "const": "config:structured_config_policy_bundle_and_entitlement_matrix:v1"
    },
    "header_vocabulary": {
      "type": "array",
      "items": { "$ref": "#/$defs/header_field_definition" },
      "minItems": 6
    },
    "mode_vocabulary": {
      "type": "array",
      "items": { "$ref": "#/$defs/mode_vocabulary_row" },
      "minItems": 3
    },
    "layer_vocabulary": {
      "type": "array",
      "items": { "$ref": "#/$defs/layer_vocabulary_row" },
      "minItems": 7
    },
    "surface_vocabulary": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_vocabulary_binding" },
      "minItems": 4
    },
    "artifact_surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_surface_row" },
      "minItems": 13
    },
    "summary": { "$ref": "#/$defs/packet_summary" },
    "docs_ref": {
      "type": "string",
      "minLength": 1
    },
    "schema_ref": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "artifact_family_kind": {
      "type": "string",
      "enum": [
        "request_workspace_environment",
        "database_profile",
        "api_profile",
        "notebook_runtime_manifest",
        "preview_runtime_config",
        "workflow_bundle_manifest",
        "ci_environment_descriptor",
        "infra_environment_descriptor",
        "managed_policy_overlay",
        "admin_policy_bundle_artifact",
        "offline_entitlement_snapshot_artifact",
        "emergency_disable_bundle_artifact",
        "trust_root_signer_update_artifact"
      ]
    },
    "qualification_label": {
      "type": "string",
      "enum": ["stable", "beta", "preview"]
    },
    "header_field_class": {
      "type": "string",
      "enum": [
        "file_identity",
        "artifact_class",
        "canonical_source_note",
        "target_context",
        "validator_state",
        "active_mode"
      ]
    },
    "mode_class": {
      "type": "string",
      "enum": ["source", "effective", "live"]
    },
    "validator_state_class": {
      "type": "string",
      "enum": [
        "current",
        "warning",
        "stale",
        "unresolved",
        "preview_narrowed",
        "policy_locked"
      ]
    },
    "mode_state_class": {
      "type": "string",
      "enum": ["current", "stale", "unresolved", "deferred", "unsupported"]
    },
    "target_boundary_class": {
      "type": "string",
      "enum": [
        "local_workspace",
        "request_runtime",
        "database_runtime",
        "api_runtime",
        "kernel_session",
        "preview_runtime",
        "workflow_runtime",
        "ci_mirror",
        "infra_mirror",
        "policy_cache",
        "offline_entitlement_cache",
        "trust_root_cache"
      ]
    },
    "write_eligibility_class": {
      "type": "string",
      "enum": [
        "writable_canonical_source",
        "inspect_only_projection",
        "inspect_only_live_observation",
        "deferred_until_runtime",
        "unresolved_target",
        "signed_bundle_review_only"
      ]
    },
    "layer_vocabulary_field": {
      "type": "string",
      "enum": [
        "layer_order",
        "source_class",
        "tracked_state",
        "policy_lock",
        "secret_bearing_note",
        "reset_action",
        "open_source_action"
      ]
    },
    "consumer_surface_class": {
      "type": "string",
      "enum": ["desktop_shell", "cli_inspect", "support_export", "docs_help"]
    },
    "source_layer_class": {
      "type": "string",
      "enum": [
        "embedded_default",
        "profile_import",
        "workspace_source",
        "user_override",
        "policy_bundle",
        "managed_override",
        "secret_reference",
        "runtime_discovery",
        "live_observation"
      ]
    },
    "layer_tracked_state": {
      "type": "string",
      "enum": ["tracked", "ignored", "derived_read_only"]
    },
    "layer_policy_lock_state": {
      "type": "string",
      "enum": ["none", "narrowed", "locked"]
    },
    "header_field_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "label", "description"],
      "properties": {
        "field": { "$ref": "#/$defs/header_field_class" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "mode_vocabulary_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "label", "description", "canonical_writable_truth"],
      "properties": {
        "mode": { "$ref": "#/$defs/mode_class" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "canonical_writable_truth": { "type": "boolean" }
      }
    },
    "layer_vocabulary_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "label", "description"],
      "properties": {
        "field": { "$ref": "#/$defs/layer_vocabulary_field" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "surface_vocabulary_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "shared_contract_ref",
        "header_fields",
        "mode_labels",
        "layer_fields"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/consumer_surface_class" },
        "shared_contract_ref": {
          "const": "config:structured_config_artifact_modes_and_layers:v1"
        },
        "header_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/header_field_class" },
          "minItems": 6
        },
        "mode_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/mode_class" },
          "minItems": 3
        },
        "layer_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/layer_vocabulary_field" },
          "minItems": 7
        }
      }
    },
    "artifact_header": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity_label",
        "identity_ref",
        "artifact_class_label",
        "canonical_source_note",
        "target_context_label",
        "validator_state",
        "validator_summary",
        "active_mode"
      ],
      "properties": {
        "identity_label": { "type": "string", "minLength": 1 },
        "identity_ref": { "type": "string", "minLength": 1 },
        "artifact_class_label": { "type": "string", "minLength": 1 },
        "canonical_source_note": { "type": "string", "minLength": 1 },
        "target_context_label": { "type": "string", "minLength": 1 },
        "validator_state": { "$ref": "#/$defs/validator_state_class" },
        "validator_summary": { "type": "string", "minLength": 1 },
        "active_mode": { "$ref": "#/$defs/mode_class" }
      }
    },
    "mode_switch_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "active",
        "resolution_time_label",
        "target_boundary",
        "write_eligibility",
        "state",
        "summary"
      ],
      "properties": {
        "mode": { "$ref": "#/$defs/mode_class" },
        "active": { "type": "boolean" },
        "resolution_time_label": { "type": "string", "minLength": 1 },
        "target_boundary": { "$ref": "#/$defs/target_boundary_class" },
        "write_eligibility": { "$ref": "#/$defs/write_eligibility_class" },
        "state": { "$ref": "#/$defs/mode_state_class" },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "layer_action_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "action_label", "action_ref"],
      "properties": {
        "available": { "type": "boolean" },
        "action_label": { "type": "string", "minLength": 1 },
        "action_ref": { "type": "string", "minLength": 1 }
      }
    },
    "environment_layer_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer_order",
        "layer_label",
        "source_class",
        "tracked_state",
        "policy_lock",
        "secret_bearing_note",
        "wins_effective_value",
        "reset_action",
        "open_source_action"
      ],
      "properties": {
        "layer_order": { "type": "integer", "minimum": 0 },
        "layer_label": { "type": "string", "minLength": 1 },
        "source_class": { "$ref": "#/$defs/source_layer_class" },
        "tracked_state": { "$ref": "#/$defs/layer_tracked_state" },
        "policy_lock": { "$ref": "#/$defs/layer_policy_lock_state" },
        "secret_bearing_note": { "type": "string", "minLength": 1 },
        "wins_effective_value": { "type": "boolean" },
        "reset_action": { "$ref": "#/$defs/layer_action_row" },
        "open_source_action": { "$ref": "#/$defs/layer_action_row" }
      }
    },
    "environment_layer_stack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visible_without_leaving_ide", "summary", "layers"],
      "properties": {
        "visible_without_leaving_ide": { "type": "boolean", "const": true },
        "summary": { "type": "string", "minLength": 1 },
        "layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/environment_layer_row" },
          "minItems": 1
        }
      }
    },
    "artifact_surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "qualification_label",
        "family_ref",
        "source_packet_ref",
        "evidence_refs",
        "header",
        "mode_switches",
        "environment_stack_required",
        "environment_layer_stack"
      ],
      "properties": {
        "family": { "$ref": "#/$defs/artifact_family_kind" },
        "qualification_label": { "$ref": "#/$defs/qualification_label" },
        "family_ref": { "type": "string", "minLength": 1 },
        "source_packet_ref": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "header": { "$ref": "#/$defs/artifact_header" },
        "mode_switches": {
          "type": "array",
          "items": { "$ref": "#/$defs/mode_switch_row" },
          "minItems": 3
        },
        "environment_stack_required": { "type": "boolean" },
        "environment_layer_stack": {
          "anyOf": [
            { "$ref": "#/$defs/environment_layer_stack" },
            { "type": "null" }
          ]
        }
      }
    },
    "packet_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_surface_count",
        "environment_stack_count",
        "shared_surface_count",
        "active_source_count",
        "active_effective_count",
        "active_live_count",
        "all_headers_complete",
        "effective_and_live_non_writable",
        "in_ide_layer_actions_available",
        "shared_surface_vocabulary_consistent"
      ],
      "properties": {
        "artifact_surface_count": { "type": "integer", "minimum": 0 },
        "environment_stack_count": { "type": "integer", "minimum": 0 },
        "shared_surface_count": { "type": "integer", "minimum": 0 },
        "active_source_count": { "type": "integer", "minimum": 0 },
        "active_effective_count": { "type": "integer", "minimum": 0 },
        "active_live_count": { "type": "integer", "minimum": 0 },
        "all_headers_complete": { "type": "boolean" },
        "effective_and_live_non_writable": { "type": "boolean" },
        "in_ide_layer_actions_available": { "type": "boolean" },
        "shared_surface_vocabulary_consistent": { "type": "boolean" }
      }
    }
  }
}
