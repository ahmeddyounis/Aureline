{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/config/structured_config_parameter_source_and_round_trip_review.schema.json",
  "title": "Aureline structured config parameter-source and round-trip review",
  "description": "Boundary schema for the canonical metadata-only packet that freezes M5 structured-config parameter-source rows, value-class chips, round-trip-risk banners, compare-before-save sheets, effective-value review sheets, and export/support disclosure summaries. Raw secret values, raw config bodies, raw bundle bytes, raw hostnames, raw URLs, raw tokens, and raw provider payloads never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "shared_contract_ref",
    "notice",
    "upstream_family_matrix_ref",
    "upstream_artifact_modes_ref",
    "parameter_row_vocabulary",
    "value_chip_vocabulary",
    "output_disclosure_vocabulary",
    "surface_vocabulary",
    "artifact_reviews",
    "summary",
    "docs_ref",
    "schema_ref"
  ],
  "properties": {
    "record_kind": { "const": "structured_config_parameter_source_and_round_trip_review" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "shared_contract_ref": { "const": "config:structured_config_parameter_source_and_round_trip_review:v1" },
    "notice": { "type": "string", "minLength": 1 },
    "upstream_family_matrix_ref": { "const": "config:structured_config_policy_bundle_and_entitlement_matrix:v1" },
    "upstream_artifact_modes_ref": { "const": "config:structured_config_artifact_modes_and_layers:v1" },
    "parameter_row_vocabulary": {
      "type": "array",
      "items": { "$ref": "#/$defs/parameter_row_field_definition" },
      "minItems": 7
    },
    "value_chip_vocabulary": {
      "type": "array",
      "items": { "$ref": "#/$defs/value_chip_vocabulary_row" },
      "minItems": 5
    },
    "output_disclosure_vocabulary": {
      "type": "array",
      "items": { "$ref": "#/$defs/output_disclosure_vocabulary_row" },
      "minItems": 4
    },
    "surface_vocabulary": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_vocabulary_binding" },
      "minItems": 4
    },
    "artifact_reviews": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_review_row" },
      "minItems": 9
    },
    "summary": { "$ref": "#/$defs/packet_summary" },
    "docs_ref": { "type": "string", "minLength": 1 },
    "schema_ref": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "artifact_family_kind": {
      "type": "string",
      "enum": [
        "request_workspace_environment",
        "database_profile",
        "api_profile",
        "notebook_runtime_manifest",
        "preview_runtime_config",
        "workflow_bundle_manifest",
        "ci_environment_descriptor",
        "infra_environment_descriptor",
        "managed_policy_overlay",
        "admin_policy_bundle_artifact",
        "offline_entitlement_snapshot_artifact",
        "emergency_disable_bundle_artifact",
        "trust_root_signer_update_artifact"
      ]
    },
    "qualification_label": {
      "type": "string",
      "enum": ["stable", "beta", "preview"]
    },
    "consumer_surface_class": {
      "type": "string",
      "enum": ["desktop_shell", "cli_inspect", "support_export", "docs_help"]
    },
    "parameter_row_field": {
      "type": "string",
      "enum": [
        "key_path",
        "display_value",
        "source_class",
        "resolution_time",
        "winner",
        "override_action",
        "copy_export_posture"
      ]
    },
    "value_chip_class": {
      "type": "string",
      "enum": [
        "literal_value",
        "env_reference",
        "secret_handle",
        "policy_injected",
        "runtime_discovered"
      ]
    },
    "output_disclosure_class": {
      "type": "string",
      "enum": [
        "literal_value",
        "reference_handle",
        "redacted_placeholder",
        "key_path_metadata_only"
      ]
    },
    "copy_export_posture": {
      "type": "string",
      "enum": [
        "local_literal_after_review",
        "reference_handle_only",
        "redacted_placeholder_only",
        "key_path_metadata_only",
        "metadata_summary_only"
      ]
    },
    "review_action_class": {
      "type": "string",
      "enum": [
        "reset_current_layer",
        "clear_override",
        "reveal_locally",
        "open_source",
        "view_policy_source",
        "compare_before_save",
        "compare_live"
      ]
    },
    "round_trip_risk_flag": {
      "type": "string",
      "enum": [
        "comments_may_rewrite",
        "unknown_keys_may_rewrite",
        "ordering_may_rewrite",
        "extension_namespaces_may_rewrite"
      ]
    },
    "parameter_row_field_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "label", "description"],
      "properties": {
        "field": { "$ref": "#/$defs/parameter_row_field" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "value_chip_vocabulary_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chip_class",
        "label",
        "description",
        "raw_secret_export_blocked_by_default"
      ],
      "properties": {
        "chip_class": { "$ref": "#/$defs/value_chip_class" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "raw_secret_export_blocked_by_default": { "type": "boolean" }
      }
    },
    "output_disclosure_vocabulary_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_class", "label", "description"],
      "properties": {
        "output_class": { "$ref": "#/$defs/output_disclosure_class" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "surface_vocabulary_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "shared_contract_ref",
        "renders_parameter_rows",
        "renders_value_chips",
        "renders_round_trip_banner",
        "renders_compare_before_save_sheet",
        "renders_effective_value_review_sheet",
        "renders_export_summary"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/consumer_surface_class" },
        "shared_contract_ref": { "type": "string", "minLength": 1 },
        "renders_parameter_rows": { "type": "boolean" },
        "renders_value_chips": { "type": "boolean" },
        "renders_round_trip_banner": { "type": "boolean" },
        "renders_compare_before_save_sheet": { "type": "boolean" },
        "renders_effective_value_review_sheet": { "type": "boolean" },
        "renders_export_summary": { "type": "boolean" }
      }
    },
    "review_action_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_class", "action_label"],
      "properties": {
        "action_class": { "$ref": "#/$defs/review_action_class" },
        "action_label": { "type": "string", "minLength": 1 }
      }
    },
    "parameter_source_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key_path",
        "display_value",
        "source_class",
        "resolution_time_label",
        "winner_label",
        "override_action",
        "copy_export_posture",
        "wins_effective_value"
      ],
      "properties": {
        "key_path": { "type": "string", "minLength": 1 },
        "display_value": { "type": "string", "minLength": 1 },
        "source_class": { "$ref": "#/$defs/value_chip_class" },
        "resolution_time_label": { "type": "string", "minLength": 1 },
        "winner_label": { "type": "string", "minLength": 1 },
        "override_action": { "$ref": "#/$defs/review_action_row" },
        "copy_export_posture": { "$ref": "#/$defs/copy_export_posture" },
        "wins_effective_value": { "type": "boolean" }
      }
    },
    "value_chip_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key_path",
        "chip_class",
        "label",
        "copy_export_posture",
        "reveal_posture_label",
        "raw_secret_export_blocked_by_default"
      ],
      "properties": {
        "key_path": { "type": "string", "minLength": 1 },
        "chip_class": { "$ref": "#/$defs/value_chip_class" },
        "label": { "type": "string", "minLength": 1 },
        "copy_export_posture": { "$ref": "#/$defs/copy_export_posture" },
        "reveal_posture_label": { "type": "string", "minLength": 1 },
        "raw_secret_export_blocked_by_default": { "type": "boolean" }
      }
    },
    "round_trip_risk_banner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "risk_summary",
        "affected_scope_label",
        "safe_path_label",
        "review_action",
        "risk_flags"
      ],
      "properties": {
        "risk_summary": { "type": "string", "minLength": 1 },
        "affected_scope_label": { "type": "string", "minLength": 1 },
        "safe_path_label": { "type": "string", "minLength": 1 },
        "review_action": { "$ref": "#/$defs/review_action_row" },
        "risk_flags": {
          "type": "array",
          "items": { "$ref": "#/$defs/round_trip_risk_flag" },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "compare_before_save_sheet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sheet_id",
        "artifact_scope_label",
        "selected_key_set",
        "risk_flags",
        "limitation_summary",
        "fallback_path_label",
        "review_action",
        "requires_explicit_acknowledgement",
        "compare_ref"
      ],
      "properties": {
        "sheet_id": { "type": "string", "minLength": 1 },
        "artifact_scope_label": { "type": "string", "minLength": 1 },
        "selected_key_set": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "risk_flags": {
          "type": "array",
          "items": { "$ref": "#/$defs/round_trip_risk_flag" },
          "minItems": 1,
          "uniqueItems": true
        },
        "limitation_summary": { "type": "string", "minLength": 1 },
        "fallback_path_label": { "type": "string", "minLength": 1 },
        "review_action": { "$ref": "#/$defs/review_action_row" },
        "requires_explicit_acknowledgement": { "type": "boolean" },
        "compare_ref": { "type": "string", "minLength": 1 }
      }
    },
    "effective_value_review_sheet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key_set",
        "winning_layers",
        "unresolved",
        "export_posture_label",
        "output_disclosure_classes",
        "actions"
      ],
      "properties": {
        "key_set": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "winning_layers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "unresolved": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "export_posture_label": { "type": "string", "minLength": 1 },
        "output_disclosure_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/output_disclosure_class" },
          "minItems": 1,
          "uniqueItems": true
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/review_action_row" },
          "minItems": 1
        }
      }
    },
    "export_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary_id",
        "posture_label",
        "output_disclosure_classes",
        "summary_lines"
      ],
      "properties": {
        "summary_id": { "type": "string", "minLength": 1 },
        "posture_label": { "type": "string", "minLength": 1 },
        "output_disclosure_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/output_disclosure_class" },
          "minItems": 1,
          "uniqueItems": true
        },
        "summary_lines": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      }
    },
    "artifact_review_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "qualification_label",
        "artifact_surface_ref",
        "parameter_source_rows",
        "value_chips",
        "effective_value_review_sheet",
        "export_summary",
        "support_export_reuses_export_summary"
      ],
      "properties": {
        "family": { "$ref": "#/$defs/artifact_family_kind" },
        "qualification_label": { "$ref": "#/$defs/qualification_label" },
        "artifact_surface_ref": { "type": "string", "minLength": 1 },
        "parameter_source_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/parameter_source_row" },
          "minItems": 1
        },
        "value_chips": {
          "type": "array",
          "items": { "$ref": "#/$defs/value_chip_row" },
          "minItems": 1
        },
        "round_trip_risk_banner": { "$ref": "#/$defs/round_trip_risk_banner" },
        "compare_before_save_sheet": { "$ref": "#/$defs/compare_before_save_sheet" },
        "effective_value_review_sheet": { "$ref": "#/$defs/effective_value_review_sheet" },
        "export_summary": { "$ref": "#/$defs/export_summary" },
        "support_export_reuses_export_summary": { "type": "boolean" }
      }
    },
    "packet_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_review_count",
        "parameter_source_row_count",
        "family_count_with_round_trip_banner",
        "family_count_with_compare_before_save",
        "family_count_with_effective_value_review",
        "family_count_reusing_export_summary",
        "chip_class_coverage_count",
        "output_disclosure_coverage_count",
        "shared_surface_count",
        "raw_secret_export_blocked_everywhere",
        "support_export_metadata_reused_everywhere"
      ],
      "properties": {
        "artifact_review_count": { "type": "integer", "minimum": 0 },
        "parameter_source_row_count": { "type": "integer", "minimum": 0 },
        "family_count_with_round_trip_banner": { "type": "integer", "minimum": 0 },
        "family_count_with_compare_before_save": { "type": "integer", "minimum": 0 },
        "family_count_with_effective_value_review": { "type": "integer", "minimum": 0 },
        "family_count_reusing_export_summary": { "type": "integer", "minimum": 0 },
        "chip_class_coverage_count": { "type": "integer", "minimum": 0 },
        "output_disclosure_coverage_count": { "type": "integer", "minimum": 0 },
        "shared_surface_count": { "type": "integer", "minimum": 0 },
        "raw_secret_export_blocked_everywhere": { "type": "boolean" },
        "support_export_metadata_reused_everywhere": { "type": "boolean" }
      }
    }
  }
}
