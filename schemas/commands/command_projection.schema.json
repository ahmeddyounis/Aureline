{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/command_projection.schema.json",
  "title": "Aureline canonical command surface-projection packets and fixture cases",
  "description": "Boundary schema for canonical command surface-projection packets consumed by shell and discoverability surfaces. A command_surface_projection_packet_record projects canonical command identity (command_id, revision, canonical verb), label/accessibility refs, docs/help anchor, lifecycle and capability cues, alias history, current shortcut display state, imported-keymap bridge anchors, and typed enablement/disabled-reason references into a single packet so command palette, menus, keybinding editor/help, help search, onboarding, migration bridges, and why-unavailable explainers stay aligned. Records carry ids and controlled vocabulary; raw URLs, raw hostnames, raw user content, and raw credential material never cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/command_surface_projection_packet_record" },
    { "$ref": "#/$defs/command_surface_projection_case_record" }
  ],
  "$defs": {
    "command_projection_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for command surface-projection packets."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe for logs, fixtures, and support export."
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "$ref": "command_descriptor.schema.json#/$defs/monotonic_timestamp"
    },
    "policy_context": {
      "$ref": "command_descriptor.schema.json#/$defs/policy_context"
    },
    "redaction_class": {
      "$ref": "command_descriptor.schema.json#/$defs/redaction_class"
    },
    "docs_help_anchor_ref": {
      "$ref": "command_descriptor.schema.json#/$defs/docs_help_anchor_ref"
    },
    "accessibility_label_path": {
      "$ref": "command_descriptor.schema.json#/$defs/accessibility_label_path"
    },
    "capability_scope_class": {
      "$ref": "command_descriptor.schema.json#/$defs/capability_scope_class"
    },
    "preview_class": {
      "$ref": "command_descriptor.schema.json#/$defs/preview_class"
    },
    "approval_posture_class": {
      "$ref": "command_descriptor.schema.json#/$defs/approval_posture_class"
    },
    "ai_tool_surfacing_class": {
      "$ref": "command_descriptor.schema.json#/$defs/ai_tool_surfacing_class"
    },
    "palette_visibility_class": {
      "$ref": "command_descriptor.schema.json#/$defs/palette_visibility_class"
    },
    "lifecycle_state": {
      "$ref": "command_descriptor.schema.json#/$defs/lifecycle_state"
    },
    "support_class": {
      "$ref": "command_descriptor.schema.json#/$defs/support_class"
    },
    "release_channel": {
      "$ref": "command_descriptor.schema.json#/$defs/release_channel"
    },
    "freshness_class": {
      "$ref": "command_descriptor.schema.json#/$defs/freshness_class"
    },
    "client_scope": {
      "$ref": "command_descriptor.schema.json#/$defs/client_scope"
    },
    "issuing_surface": {
      "$ref": "command_descriptor.schema.json#/$defs/issuing_surface"
    },
    "ui_slot_class": {
      "$ref": "command_descriptor.schema.json#/$defs/ui_slot_class"
    },
    "disabled_reason_code": {
      "$ref": "command_descriptor.schema.json#/$defs/disabled_reason_code"
    },
    "repair_hook_ref": {
      "$ref": "command_descriptor.schema.json#/$defs/repair_hook_ref"
    },
    "enablement_decision_class": {
      "$ref": "command_descriptor.schema.json#/$defs/enablement_decision_class"
    },
    "namespace_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/namespace_class"
    },
    "automation_label": {
      "$ref": "command_registry_entry.schema.json#/$defs/automation_label"
    },
    "dominant_side_effect_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/dominant_side_effect_class"
    },
    "platform_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/platform_class"
    },
    "current_keybinding_ref": {
      "$ref": "command_registry_entry.schema.json#/$defs/current_keybinding_ref"
    },
    "alias_record": {
      "$ref": "command_registry_entry.schema.json#/$defs/alias_record"
    },
    "disabled_reason_record": {
      "$ref": "command_registry_entry.schema.json#/$defs/disabled_reason_record"
    },
    "origin_badge_record": {
      "$ref": "command_registry_entry.schema.json#/$defs/origin_badge_record"
    },
    "target_badge_record": {
      "$ref": "command_registry_entry.schema.json#/$defs/target_badge_record"
    },
    "discoverability_record": {
      "$ref": "command_registry_entry.schema.json#/$defs/discoverability_record"
    },
    "surface_exposure_record": {
      "$ref": "command_registry_entry.schema.json#/$defs/surface_exposure_record"
    },
    "seed_enablement_snapshot": {
      "$ref": "command_registry_entry.schema.json#/$defs/seed_enablement_snapshot"
    },
    "projection_surface_class": {
      "type": "string",
      "enum": [
        "command_palette",
        "global_application_menu",
        "editor_context_menu",
        "explorer_context_menu",
        "review_context_menu",
        "source_control_context_menu",
        "terminal_context_menu",
        "search_context_menu",
        "primary_toolbar",
        "secondary_toolbar",
        "status_bar_control",
        "keybinding_help",
        "keybinding_editor",
        "cli_help",
        "ai_tool_surface",
        "help_search",
        "onboarding_hint",
        "migration_bridge_card",
        "diagnostics_view",
        "current_shortcut_display",
        "key_sequence_help"
      ],
      "description": "Surface projection targets. Superset of command_registry_entry.surface_exposure_class with an explicit keybinding_editor lane."
    },
    "command_identity_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "command_revision_ref",
        "canonical_verb",
        "primary_label_ref",
        "accessibility_label_path",
        "docs_help_anchor_ref"
      ],
      "properties": {
        "command_id": { "$ref": "#/$defs/opaque_id" },
        "command_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "canonical_verb": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
        },
        "primary_label_ref": { "$ref": "#/$defs/opaque_id" },
        "accessibility_label_path": { "$ref": "#/$defs/accessibility_label_path" },
        "docs_help_anchor_ref": { "$ref": "#/$defs/docs_help_anchor_ref" }
      }
    },
    "command_capability_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_scope_class",
        "preview_class",
        "approval_posture_class",
        "ai_tool_surfacing_class",
        "palette_visibility"
      ],
      "properties": {
        "capability_scope_class": { "$ref": "#/$defs/capability_scope_class" },
        "preview_class": { "$ref": "#/$defs/preview_class" },
        "approval_posture_class": { "$ref": "#/$defs/approval_posture_class" },
        "ai_tool_surfacing_class": { "$ref": "#/$defs/ai_tool_surfacing_class" },
        "palette_visibility": { "$ref": "#/$defs/palette_visibility_class" }
      }
    },
    "command_lifecycle_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lifecycle_state",
        "support_class",
        "release_channel",
        "declared_freshness_class",
        "client_scopes"
      ],
      "properties": {
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "release_channel": { "$ref": "#/$defs/release_channel" },
        "declared_freshness_class": { "$ref": "#/$defs/freshness_class" },
        "client_scopes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/client_scope" }
        }
      }
    },
    "surface_projection_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_class", "projection_ref", "enablement_snapshot"],
      "properties": {
        "surface_class": { "$ref": "#/$defs/projection_surface_class" },
        "projection_ref": { "$ref": "#/$defs/opaque_id" },
        "issuing_surface": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/issuing_surface" }]
        },
        "descriptor_ui_slot_class": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/ui_slot_class" }]
        },
        "menu_path_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "description": "Menu path refs when the projection is menu-backed; empty otherwise."
        },
        "enablement_snapshot": { "$ref": "#/$defs/seed_enablement_snapshot" }
      }
    },
    "imported_keymap_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keymap_bridge_ref"],
      "properties": {
        "keymap_bridge_ref": { "$ref": "#/$defs/opaque_id" },
        "bridge_record_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_id" }],
          "description": "Optional opaque ref to a keybinding_import_bridge_record for richer bridge details."
        }
      }
    },
    "command_surface_projection_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "command_projection_schema_version",
        "projection_packet_id",
        "registry_entry_id",
        "namespace_class",
        "identity",
        "capability",
        "lifecycle",
        "discoverability_record",
        "alias_records",
        "automation_labels",
        "dominant_side_effect_class",
        "current_keybinding_refs",
        "disabled_reason_records",
        "seed_enablement_snapshot",
        "surface_projections",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "record_kind": { "const": "command_surface_projection_packet_record" },
        "command_projection_schema_version": { "$ref": "#/$defs/command_projection_schema_version" },
        "projection_packet_id": { "$ref": "#/$defs/opaque_id" },
        "registry_entry_id": { "$ref": "#/$defs/opaque_id" },
        "namespace_class": { "$ref": "#/$defs/namespace_class" },
        "identity": { "$ref": "#/$defs/command_identity_record" },
        "capability": { "$ref": "#/$defs/command_capability_record" },
        "lifecycle": { "$ref": "#/$defs/command_lifecycle_record" },
        "discoverability_record": { "$ref": "#/$defs/discoverability_record" },
        "alias_records": {
          "type": "array",
          "items": { "$ref": "#/$defs/alias_record" }
        },
        "automation_labels": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/automation_label" }
        },
        "dominant_side_effect_class": { "$ref": "#/$defs/dominant_side_effect_class" },
        "origin_badge": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/origin_badge_record" }]
        },
        "target_badges": {
          "type": "array",
          "items": { "$ref": "#/$defs/target_badge_record" }
        },
        "current_keybinding_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/current_keybinding_ref" }
        },
        "disabled_reason_records": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/disabled_reason_record" }
        },
        "seed_enablement_snapshot": { "$ref": "#/$defs/seed_enablement_snapshot" },
        "imported_keymap_anchors": {
          "type": "array",
          "items": { "$ref": "#/$defs/imported_keymap_anchor" },
          "description": "Optional anchors to imported-keymap bridge records relevant to this command."
        },
        "surface_projections": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_projection_row" }
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    },
    "command_surface_projection_case_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "command_projection_schema_version",
        "case_id",
        "case_summary",
        "source_registry_entry_ref",
        "context",
        "expected_packet"
      ],
      "properties": {
        "record_kind": { "const": "command_surface_projection_case_record" },
        "command_projection_schema_version": { "$ref": "#/$defs/command_projection_schema_version" },
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "case_summary": { "$ref": "#/$defs/non_empty_string" },
        "source_registry_entry_ref": { "$ref": "#/$defs/non_empty_string" },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": ["platform_class", "client_scope"],
          "properties": {
            "platform_class": { "$ref": "#/$defs/platform_class" },
            "client_scope": { "$ref": "#/$defs/client_scope" },
            "execution_context_available": {
              "type": "boolean",
              "description": "Whether the current execution context needed by the command is available."
            },
            "provider_linked": {
              "oneOf": [{ "type": "null" }, { "type": "boolean" }],
              "description": "Optional provider-linkage axis when a command requires a provider."
            }
          }
        },
        "expected_packet": { "$ref": "#/$defs/command_surface_projection_packet_record" }
      }
    }
  }
}

