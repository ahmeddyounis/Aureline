{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/command_descriptor_alpha.schema.json",
  "title": "Aureline alpha command-descriptor registry publication",
  "description": "Alpha publication schema for the launch-wedge command registry packet. The packet references the canonical seeded command registry and freezes the alpha-only cross-surface parity, discoverability consumer, automation-label, browser/voice descriptor, and disabled-reason cause-family proofs required before live beta command SDK work exists. Raw argument values, paths, URLs, provider payloads, prompt text, and credentials never appear here.",
  "type": "object",
  "required": [
    "record_kind",
    "alpha_command_registry_schema_version",
    "registry_id",
    "source_registry_artifact_ref",
    "parity_report_ref",
    "claimed_commands"
  ],
  "properties": {
    "record_kind": { "const": "alpha_command_registry_record" },
    "alpha_command_registry_schema_version": { "type": "integer", "const": 1 },
    "registry_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "source_registry_artifact_ref": { "$ref": "#/$defs/non_empty_string" },
    "source_command_descriptor_schema_ref": { "$ref": "#/$defs/non_empty_string" },
    "descriptor_schema_ref": { "$ref": "#/$defs/non_empty_string" },
    "invocation_session_schema_ref": { "$ref": "#/$defs/non_empty_string" },
    "parity_report_ref": { "$ref": "#/$defs/non_empty_string" },
    "disabled_reason_vocabulary_ref": { "$ref": "#/$defs/non_empty_string" },
    "result_contract_baseline_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "surface_family_set": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_family" },
      "minItems": 1,
      "uniqueItems": true
    },
    "disabled_reason_cause_families": {
      "type": "array",
      "items": { "$ref": "#/$defs/disabled_reason_cause_family" }
    },
    "claimed_commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/alpha_command_claim" },
      "minItems": 1
    }
  },
  "additionalProperties": true,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "command_palette",
        "menu_or_button",
        "keybinding_help",
        "cli_headless",
        "ai_tool_surface",
        "recipe_or_onboarding_generated",
        "browser_or_voice_descriptor"
      ]
    },
    "coverage_status": {
      "type": "string",
      "enum": [
        "claimed",
        "explicitly_narrowed",
        "discoverable_only",
        "browser_handoff_only",
        "voice_addressable",
        "not_surfaced_on_this_client"
      ]
    },
    "automation_label": {
      "type": "string",
      "enum": [
        "macro_safe",
        "recipe_safe",
        "headless_safe",
        "ui_only",
        "approval_required",
        "unknown_automation_support"
      ]
    },
    "disabled_reason_cause_family": {
      "type": "object",
      "required": [
        "cause_family",
        "canonical_disabled_reason_code",
        "surface_copy_contract"
      ],
      "properties": {
        "cause_family": {
          "type": "string",
          "enum": [
            "focus",
            "selection",
            "lifecycle_state",
            "missing_dependency",
            "policy",
            "entitlement",
            "remote_or_host_mismatch"
          ]
        },
        "canonical_disabled_reason_code": { "$ref": "#/$defs/non_empty_string" },
        "surface_copy_contract": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": true
    },
    "discoverability_consumer": {
      "type": "object",
      "required": [
        "consumer_class",
        "consumer_ref",
        "command_id",
        "keyboard_route",
        "descriptor_anchor_ref",
        "preserves_preview_apply_semantics",
        "disabled_reason_mode"
      ],
      "properties": {
        "consumer_class": {
          "type": "string",
          "enum": [
            "start_center_card",
            "onboarding_hint",
            "keymap_bridge",
            "help_search_result",
            "migration_guidance",
            "voice_hint",
            "browser_handoff_row"
          ]
        },
        "consumer_ref": { "$ref": "#/$defs/non_empty_string" },
        "command_id": { "$ref": "#/$defs/non_empty_string" },
        "keyboard_route": { "$ref": "#/$defs/non_empty_string" },
        "descriptor_anchor_ref": { "$ref": "#/$defs/non_empty_string" },
        "invocation_packet_ref": { "type": ["string", "null"] },
        "preserves_preview_apply_semantics": { "type": "boolean" },
        "disabled_reason_mode": { "$ref": "#/$defs/non_empty_string" },
        "exact_reopen_ref": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "discoverability_record": {
      "type": "object",
      "required": [
        "primary_label_ref",
        "category_refs",
        "docs_help_anchor_ref",
        "consumer_refs"
      ],
      "properties": {
        "primary_label_ref": { "$ref": "#/$defs/non_empty_string" },
        "aliases": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "category_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "docs_help_anchor_ref": { "$ref": "#/$defs/non_empty_string" },
        "consumer_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/discoverability_consumer" }
        }
      },
      "additionalProperties": true
    },
    "surface_parity": {
      "type": "object",
      "required": [
        "surface_family",
        "surface_class",
        "coverage_status",
        "projected_command_id",
        "authority_class",
        "preview_class",
        "approval_posture_class",
        "disabled_reason_mode",
        "automation_support",
        "client_scope_disclosure",
        "result_contract_class"
      ],
      "properties": {
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "surface_class": { "$ref": "#/$defs/non_empty_string" },
        "coverage_status": { "$ref": "#/$defs/coverage_status" },
        "projected_command_id": { "$ref": "#/$defs/non_empty_string" },
        "authority_class": { "$ref": "#/$defs/non_empty_string" },
        "preview_class": { "$ref": "#/$defs/non_empty_string" },
        "approval_posture_class": { "$ref": "#/$defs/non_empty_string" },
        "disabled_reason_mode": { "$ref": "#/$defs/non_empty_string" },
        "automation_support": { "$ref": "#/$defs/non_empty_string" },
        "client_scope_disclosure": { "$ref": "#/$defs/non_empty_string" },
        "result_contract_class": { "$ref": "#/$defs/non_empty_string" },
        "narrowing_reason": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "alpha_command_claim": {
      "type": "object",
      "required": [
        "claim_id",
        "command_id",
        "command_revision_ref",
        "lifecycle_state",
        "authority_class",
        "capability_scope_class",
        "dominant_side_effect_class",
        "preview_class",
        "approval_posture_class",
        "result_contract_class",
        "automation_labels",
        "discoverability_record",
        "surface_parity"
      ],
      "properties": {
        "claim_id": { "$ref": "#/$defs/non_empty_string" },
        "command_id": { "$ref": "#/$defs/non_empty_string" },
        "command_revision_ref": { "$ref": "#/$defs/non_empty_string" },
        "lifecycle_state": { "$ref": "#/$defs/non_empty_string" },
        "authority_class": { "$ref": "#/$defs/non_empty_string" },
        "capability_scope_class": { "$ref": "#/$defs/non_empty_string" },
        "dominant_side_effect_class": { "$ref": "#/$defs/non_empty_string" },
        "preview_class": { "$ref": "#/$defs/non_empty_string" },
        "approval_posture_class": { "$ref": "#/$defs/non_empty_string" },
        "result_contract_class": { "$ref": "#/$defs/non_empty_string" },
        "evidence_ref_class_required": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "automation_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/automation_label" },
          "minItems": 1,
          "uniqueItems": true
        },
        "discoverability_record": { "$ref": "#/$defs/discoverability_record" },
        "surface_parity": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_parity" },
          "minItems": 1
        },
        "invocation_packet_fixture_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      },
      "additionalProperties": true
    }
  }
}
