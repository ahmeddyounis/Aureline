{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/m5_capability_state_truth.schema.json",
  "title": "M5 capability-state truth packet",
  "description": "Boundary schema for the canonical M5 capability-state truth packet. The packet projects command-owned lifecycle state and dependency-marker truth into settings, Help/About, docs packs, release rows, workflow bundles, profile exports, support packets, and desktop/CLI/extension/browser inspectors without widening stable wording beyond the current effective state. Raw workspace content, raw provider payloads, raw credentials, and raw policy bundles never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "schema_ref",
    "doc_ref",
    "source_packet_ref",
    "source_rollout_inventory_ref",
    "lifecycle_vocabulary_ref",
    "projection_matrix_ref",
    "state_definitions",
    "rows",
    "summary"
  ],
  "properties": {
    "record_kind": { "const": "m5_capability_state_truth_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty" },
    "generated_at": { "type": "string", "format": "date-time" },
    "schema_ref": { "$ref": "#/$defs/non_empty" },
    "doc_ref": { "$ref": "#/$defs/non_empty" },
    "source_packet_ref": { "$ref": "#/$defs/non_empty" },
    "source_rollout_inventory_ref": { "$ref": "#/$defs/non_empty" },
    "lifecycle_vocabulary_ref": { "$ref": "#/$defs/non_empty" },
    "projection_matrix_ref": { "$ref": "#/$defs/non_empty" },
    "state_definitions": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/state_definition_row" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability_state_row" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty": {
      "type": "string",
      "minLength": 1
    },
    "capability_state_class": {
      "type": "string",
      "enum": [
        "labs",
        "preview",
        "beta",
        "stable",
        "deprecated",
        "disabled_by_policy",
        "retest_pending",
        "removed"
      ]
    },
    "marker_class": {
      "type": "string",
      "enum": [
        "labs_dependency",
        "preview_dependency",
        "beta_dependency",
        "policy_disabled_dependency",
        "retest_pending_dependency",
        "deprecated_dependency",
        "removed_dependency",
        "stale_evidence_dependency"
      ]
    },
    "projection_surface_class": {
      "type": "string",
      "enum": [
        "settings_row",
        "help_about",
        "docs_pack",
        "release_row",
        "workflow_bundle",
        "profile_export",
        "support_packet",
        "desktop_inspector",
        "cli_inspect",
        "extension_metadata",
        "browser_companion"
      ]
    },
    "state_definition_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_class",
        "display_label",
        "detail_ref",
        "stable_wording_allowed",
        "full_support_badge_allowed",
        "dependency_markers_required_on_saved_artifacts",
        "tombstone_state"
      ],
      "properties": {
        "state_class": { "$ref": "#/$defs/capability_state_class" },
        "display_label": { "$ref": "#/$defs/non_empty" },
        "detail_ref": { "$ref": "#/$defs/non_empty" },
        "stable_wording_allowed": { "type": "boolean" },
        "full_support_badge_allowed": { "type": "boolean" },
        "dependency_markers_required_on_saved_artifacts": { "type": "boolean" },
        "tombstone_state": { "type": "boolean" }
      }
    },
    "dependency_marker_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "marker_ref",
        "marker_class",
        "dependency_ref",
        "disclosure_label",
        "detail_ref",
        "narrows_to_state_class",
        "affects_surfaces"
      ],
      "properties": {
        "marker_ref": { "$ref": "#/$defs/non_empty" },
        "marker_class": { "$ref": "#/$defs/marker_class" },
        "dependency_ref": { "$ref": "#/$defs/non_empty" },
        "disclosure_label": { "$ref": "#/$defs/non_empty" },
        "detail_ref": { "$ref": "#/$defs/non_empty" },
        "narrows_to_state_class": { "$ref": "#/$defs/capability_state_class" },
        "affects_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/projection_surface_class" }
        }
      }
    },
    "projection_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "projection_ref",
        "declared_state_class",
        "effective_state_class",
        "stable_wording_visible",
        "support_wording_visible",
        "dependency_marker_refs",
        "dependency_markers_visible",
        "badge_labels",
        "inspect_detail_ref",
        "route_or_metadata_ref",
        "evidence_freshness_class",
        "export_safe"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/projection_surface_class" },
        "projection_ref": { "$ref": "#/$defs/non_empty" },
        "declared_state_class": { "$ref": "#/$defs/capability_state_class" },
        "effective_state_class": { "$ref": "#/$defs/capability_state_class" },
        "stable_wording_visible": { "type": "boolean" },
        "support_wording_visible": { "type": "boolean" },
        "dependency_marker_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty" }
        },
        "dependency_markers_visible": { "type": "boolean" },
        "badge_labels": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty" }
        },
        "inspect_detail_ref": { "$ref": "#/$defs/non_empty" },
        "route_or_metadata_ref": { "$ref": "#/$defs/non_empty" },
        "evidence_freshness_class": { "$ref": "#/$defs/non_empty" },
        "export_safe": { "type": "boolean" }
      }
    },
    "capability_state_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_row_id",
        "command_id",
        "display_label",
        "canonical_verb",
        "declared_state_class",
        "effective_state_class",
        "support_class",
        "release_channel",
        "freshness_class",
        "origin_class",
        "owner_ref",
        "lifecycle_ref",
        "rollout_state_ref",
        "dependency_markers",
        "projection_rows",
        "finding_codes"
      ],
      "properties": {
        "capability_row_id": { "$ref": "#/$defs/non_empty" },
        "command_id": { "$ref": "#/$defs/non_empty" },
        "display_label": { "$ref": "#/$defs/non_empty" },
        "canonical_verb": { "$ref": "#/$defs/non_empty" },
        "declared_state_class": { "$ref": "#/$defs/capability_state_class" },
        "effective_state_class": { "$ref": "#/$defs/capability_state_class" },
        "support_class": { "$ref": "#/$defs/non_empty" },
        "release_channel": { "$ref": "#/$defs/non_empty" },
        "freshness_class": { "$ref": "#/$defs/non_empty" },
        "origin_class": { "$ref": "#/$defs/non_empty" },
        "owner_ref": { "$ref": "#/$defs/non_empty" },
        "lifecycle_ref": { "$ref": "#/$defs/non_empty" },
        "rollout_state_ref": { "$ref": "#/$defs/non_empty" },
        "dependency_markers": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependency_marker_record" }
        },
        "projection_rows": {
          "type": "array",
          "minItems": 11,
          "items": { "$ref": "#/$defs/projection_row" }
        },
        "finding_codes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty" }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_count",
        "state_definition_count",
        "dependency_marker_count",
        "projection_row_count",
        "claim_surface_projection_count",
        "saved_artifact_projection_count",
        "labs_row_count",
        "preview_row_count",
        "beta_row_count",
        "stable_row_count",
        "deprecated_row_count",
        "disabled_by_policy_row_count",
        "retest_pending_row_count",
        "removed_row_count",
        "stable_wording_projection_count",
        "finding_count"
      ],
      "properties": {
        "capability_count": { "type": "integer", "minimum": 0 },
        "state_definition_count": { "type": "integer", "minimum": 0 },
        "dependency_marker_count": { "type": "integer", "minimum": 0 },
        "projection_row_count": { "type": "integer", "minimum": 0 },
        "claim_surface_projection_count": { "type": "integer", "minimum": 0 },
        "saved_artifact_projection_count": { "type": "integer", "minimum": 0 },
        "labs_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "deprecated_row_count": { "type": "integer", "minimum": 0 },
        "disabled_by_policy_row_count": { "type": "integer", "minimum": 0 },
        "retest_pending_row_count": { "type": "integer", "minimum": 0 },
        "removed_row_count": { "type": "integer", "minimum": 0 },
        "stable_wording_projection_count": { "type": "integer", "minimum": 0 },
        "finding_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
