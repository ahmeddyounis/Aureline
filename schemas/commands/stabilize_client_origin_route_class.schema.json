{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/stabilize_client_origin_route_class.schema.json",
  "title": "Aureline client-origin route-class stabilization record",
  "$comment": "Rust owner: aureline_commands::stabilize_client_origin_route_class::ClientOriginRouteClassPacket.",
  "description": "Boundary schema for the metadata-only client-origin, target-context, route-class, capability-route inspection, and expiry ownership disclosure record. For one provider or remote flow on a claimed stable row, the packet binds the capability-route inspector (naming route class, target identity, capability boundary, approval scope, expiry, and revalidation triggers), the client-origin and target-context disclosure, the approval scope and ownership record with enforced expiry, and the cross-surface inspector parity rows that prove every claimed stable entry surface (menu/button, keybinding, palette, CLI/headless, AI tool, voice, recipe, deep link, browser companion) discloses the same route class, target identity, capability boundary, approval scope and expiry, and revalidation triggers without widening capability or claiming the Stable lane while narrowed below it. It does not re-derive the descriptor, registry, invocation, result, authority, or parity models; it binds them by their canonical schema refs. It carries refs, state tokens, and coarse classes only. Adding a new enum member or optional field is additive-minor; repurposing an existing member is breaking and bumps schema_version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "command_family_id",
    "display_label",
    "claimed_stable",
    "policy_epoch_ref",
    "contract_refs",
    "capability_route_inspector",
    "approval_scope",
    "surface_rows",
    "evidence_export",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "client_origin_route_class_stabilization_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "command_family_id": { "type": "string", "minLength": 1 },
    "display_label": { "type": "string", "minLength": 1 },
    "claimed_stable": { "type": "boolean" },
    "policy_epoch_ref": { "type": "string", "minLength": 1 },
    "contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "descriptor_schema_ref", "registry_entry_schema_ref", "registry_seed_ref",
        "invocation_session_schema_ref", "result_packet_schema_ref",
        "public_contract_schema_ref", "parity_expectation_schema_ref",
        "disabled_reason_vocabulary_ref"
      ],
      "properties": {
        "descriptor_schema_ref": { "type": "string", "minLength": 1 },
        "registry_entry_schema_ref": { "type": "string", "minLength": 1 },
        "registry_seed_ref": { "type": "string", "minLength": 1 },
        "invocation_session_schema_ref": { "type": "string", "minLength": 1 },
        "result_packet_schema_ref": { "type": "string", "minLength": 1 },
        "public_contract_schema_ref": { "type": "string", "minLength": 1 },
        "parity_expectation_schema_ref": { "type": "string", "minLength": 1 },
        "disabled_reason_vocabulary_ref": { "type": "string", "minLength": 1 }
      }
    },
    "capability_route_inspector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inspector_id", "client_origin", "target_context", "route_class",
        "capability_boundary", "target_identity_ref", "approval_scope_ref",
        "policy_epoch_ref", "expiry_token", "approval_owner_label",
        "revalidation_triggers", "drift_forces_reapproval",
        "reachable_without_debug_toggle", "spend_posture_token",
        "approval_disclosure_ref"
      ],
      "properties": {
        "inspector_id": { "type": "string", "minLength": 1 },
        "client_origin": {
          "type": "string",
          "enum": ["local_ui", "cli_headless", "deep_link", "browser_companion",
                   "ai_tool_call", "recipe_automation", "tunnel_endpoint", "provider_action"]
        },
        "target_context": {
          "type": "string",
          "enum": ["local_workspace", "remote_workspace", "managed_provider",
                   "external_provider", "tunnel_exposed_endpoint", "browser_handoff"]
        },
        "route_class": {
          "type": "string",
          "enum": ["local", "browser_handoff", "managed", "enterprise_gateway",
                   "tunnel_forwarded", "provider_action_callback", "byok"]
        },
        "capability_boundary": {
          "type": "string",
          "enum": ["local_device", "user_account", "org_enterprise", "managed_policy",
                   "external_provider", "browser_companion", "tunnel_boundary"]
        },
        "target_identity_ref": { "type": "string", "minLength": 1 },
        "approval_scope_ref": { "type": "string", "minLength": 1 },
        "policy_epoch_ref": { "type": "string", "minLength": 1 },
        "expiry_token": { "type": "string", "minLength": 1 },
        "approval_owner_label": { "type": "string", "minLength": 1 },
        "revalidation_triggers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["approval_epoch_drift", "route_or_provider_drift", "target_identity_drift",
                     "capability_boundary_drift", "policy_epoch_advanced", "approval_expired",
                     "explicit_revalidation_requested"]
          }
        },
        "drift_forces_reapproval": { "type": "boolean" },
        "reachable_without_debug_toggle": { "type": "boolean" },
        "spend_posture_token": { "type": "string", "minLength": 1 },
        "approval_disclosure_ref": { "type": "string", "minLength": 1 }
      }
    },
    "approval_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_ref", "owner_label", "expiry_token", "expiry_enforced",
        "disclosed_in_preview", "disclosed_in_support_export"
      ],
      "properties": {
        "scope_ref": { "type": "string", "minLength": 1 },
        "owner_label": { "type": "string", "minLength": 1 },
        "expiry_token": { "type": "string", "minLength": 1 },
        "expiry_enforced": { "type": "boolean" },
        "disclosed_in_preview": { "type": "boolean" },
        "disclosed_in_support_export": { "type": "boolean" }
      }
    },
    "surface_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface_class", "inspector_reachable", "discloses_route_class",
          "discloses_target_identity", "discloses_capability_boundary",
          "discloses_approval_scope_and_expiry", "discloses_revalidation_triggers",
          "policy_checked", "no_capability_widening", "qualification", "claimed_stable"
        ],
        "properties": {
          "surface_class": {
            "type": "string",
            "enum": ["menu_or_button", "keybinding", "command_palette", "cli_headless",
                     "ai_tool", "voice", "recipe", "deep_link", "browser_companion"]
          },
          "inspector_reachable": { "type": "boolean" },
          "discloses_route_class": { "type": "boolean" },
          "discloses_target_identity": { "type": "boolean" },
          "discloses_capability_boundary": { "type": "boolean" },
          "discloses_approval_scope_and_expiry": { "type": "boolean" },
          "discloses_revalidation_triggers": { "type": "boolean" },
          "policy_checked": { "type": "boolean" },
          "no_capability_widening": { "type": "boolean" },
          "qualification": {
            "type": "string",
            "enum": ["stable", "beta", "experimental", "not_applicable"]
          },
          "claimed_stable": { "type": "boolean" }
        }
      }
    },
    "evidence_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id", "json_export_ref", "markdown_summary_ref",
        "admin_inspector_ref", "support_export_ref", "rollback_lineage_refs",
        "export_lineage_refs"
      ],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "json_export_ref": { "type": "string", "minLength": 1 },
        "markdown_summary_ref": { "type": "string", "minLength": 1 },
        "admin_inspector_ref": { "type": "string", "minLength": 1 },
        "support_export_ref": { "type": "string", "minLength": 1 },
        "rollback_lineage_refs": { "type": "array", "items": { "type": "string" } },
        "export_lineage_refs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "source_contract_refs": { "type": "array", "items": { "type": "string" } },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  }
}
