{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/finalize_command_parity.schema.json",
  "title": "Aureline finalized command-parity record",
  "$comment": "Rust owner: aureline_commands::finalize_command_parity::CommandParityFinalizationPacket.",
  "description": "Boundary schema for the metadata-only finalized command-parity record. For one canonical command family on a claimed stable row, the packet binds the one canonical discoverability record (canonical command id, primary label, alias set, category refs, docs/help anchor, keyword refs) every projection surface reads from, the per-surface discoverability projection rows that prove palette, menus, tooltips, leader/help overlays, onboarding tips, voice hints, deep links, keybinding help, and docs/help pages project from the same record and alias set without copy-ID/CLI, add-to-recipe, modifier-footer, disabled-reason, or example drift, the modifier-action footer contract (default run, split/open-alt, open alternate target, copy command ID, copy CLI form, add to recipe, inspect why not automatable) with held-modifier intent surfaced, no debug-only requirement, and no-bypass guards, the palette query-session privacy posture (local-first, typed history policy, bounded retention, clear-or-disable controls, held-modifier intent, redaction posture, and no silent cross-device/cross-tenant widening without an explicit governing feature), and the disabled-with-reason chip rows resolved identically across surfaces, plus exportable evidence/rollback lineage. It does not re-derive the descriptor, registry, palette-row, query-session, or discoverability models; it binds them by their canonical schema refs. It carries refs, state tokens, coarse classes, counts, and review labels only. It never carries raw query text, raw command arguments, raw prompt bodies, source file bodies, endpoint URLs, credentials, or signing-key material. Adding a new enum member or a new optional field is additive-minor; repurposing an existing member is breaking and bumps schema_version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "command_family_id",
    "display_label",
    "claimed_stable",
    "policy_epoch_ref",
    "contract_refs",
    "discoverability_record",
    "projection_rows",
    "footer_contract",
    "query_session_privacy",
    "disabled_reason_chips",
    "evidence_export",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "command_parity_finalization_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "command_family_id": { "type": "string", "minLength": 1 },
    "display_label": { "type": "string", "minLength": 1 },
    "claimed_stable": { "type": "boolean" },
    "policy_epoch_ref": { "type": "string", "minLength": 1 },
    "contract_refs": { "$ref": "#/$defs/stable_contract_refs" },
    "discoverability_record": { "$ref": "#/$defs/discoverability_record" },
    "projection_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/discoverability_projection_row" }
    },
    "footer_contract": { "$ref": "#/$defs/modifier_action_footer_contract" },
    "query_session_privacy": { "$ref": "#/$defs/query_session_privacy_contract" },
    "disabled_reason_chips": {
      "type": "array",
      "items": { "$ref": "#/$defs/disabled_reason_chip_row" }
    },
    "evidence_export": { "$ref": "#/$defs/evidence_export_block" },
    "source_contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "discoverability_surface_class": {
      "type": "string",
      "enum": [
        "command_palette",
        "menu",
        "tooltip",
        "leader_overlay",
        "keybinding_help",
        "onboarding_tip",
        "voice_hint",
        "deep_link",
        "docs_help_page"
      ]
    },
    "modifier_action_class": {
      "type": "string",
      "enum": [
        "default_run",
        "split_or_open_alt",
        "open_alternate_target",
        "copy_command_id",
        "copy_cli_form",
        "add_to_recipe",
        "inspect_why_not_automatable"
      ]
    },
    "history_policy_class": {
      "type": "string",
      "enum": [
        "no_history",
        "session_only",
        "local_profile",
        "local_device",
        "managed_governed"
      ]
    },
    "clear_history_rule_class": {
      "type": "string",
      "enum": [
        "clear_current_session_only",
        "clear_palette_recent_queries",
        "clear_command_recents",
        "clear_profile_command_history",
        "admin_policy_purge",
        "erase_on_workspace_untrust"
      ]
    },
    "redaction_posture_class": {
      "type": "string",
      "enum": [
        "local_private",
        "metadata_safe",
        "support_redacted",
        "policy_review",
        "export_denied"
      ]
    },
    "disabled_reason_case_class": {
      "type": "string",
      "enum": [
        "disabled_by_policy",
        "wrong_focus",
        "missing_runtime",
        "degraded_provider",
        "preview_required",
        "approval_required",
        "ui_only"
      ]
    },
    "surface_qualification_class": {
      "type": "string",
      "enum": ["stable", "beta", "experimental", "not_applicable"]
    },
    "stable_contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "descriptor_schema_ref",
        "registry_entry_schema_ref",
        "registry_seed_ref",
        "invocation_session_schema_ref",
        "result_packet_schema_ref",
        "public_contract_schema_ref",
        "parity_expectation_schema_ref",
        "disabled_reason_vocabulary_ref"
      ],
      "properties": {
        "descriptor_schema_ref": { "type": "string", "minLength": 1 },
        "registry_entry_schema_ref": { "type": "string", "minLength": 1 },
        "registry_seed_ref": { "type": "string", "minLength": 1 },
        "invocation_session_schema_ref": { "type": "string", "minLength": 1 },
        "result_packet_schema_ref": { "type": "string", "minLength": 1 },
        "public_contract_schema_ref": { "type": "string", "minLength": 1 },
        "parity_expectation_schema_ref": { "type": "string", "minLength": 1 },
        "disabled_reason_vocabulary_ref": { "type": "string", "minLength": 1 }
      }
    },
    "discoverability_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_command_id",
        "primary_label_ref",
        "alias_set",
        "category_refs",
        "docs_help_anchor_ref",
        "keyword_refs"
      ],
      "properties": {
        "canonical_command_id": { "type": "string", "minLength": 1 },
        "primary_label_ref": { "type": "string", "minLength": 1 },
        "alias_set": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "category_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "docs_help_anchor_ref": { "type": "string", "minLength": 1 },
        "keyword_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "discoverability_projection_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "projects_from_canonical_record",
        "alias_set_matches",
        "resolves_to_canonical_command",
        "copy_id_consistent",
        "copy_cli_consistent",
        "add_to_recipe_consistent",
        "modifier_footer_consistent",
        "disabled_reason_consistent",
        "why_not_automatable_consistent",
        "example_drift_free",
        "qualification",
        "claimed_stable"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/discoverability_surface_class" },
        "projects_from_canonical_record": { "type": "boolean" },
        "alias_set_matches": { "type": "boolean" },
        "resolves_to_canonical_command": { "type": "boolean" },
        "copy_id_consistent": { "type": "boolean" },
        "copy_cli_consistent": { "type": "boolean" },
        "add_to_recipe_consistent": { "type": "boolean" },
        "modifier_footer_consistent": { "type": "boolean" },
        "disabled_reason_consistent": { "type": "boolean" },
        "why_not_automatable_consistent": { "type": "boolean" },
        "example_drift_free": { "type": "boolean" },
        "qualification": { "$ref": "#/$defs/surface_qualification_class" },
        "claimed_stable": { "type": "boolean" }
      }
    },
    "modifier_action_footer_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actions",
        "exposes_held_modifier_intent",
        "exposes_why_not_automatable",
        "requires_debug_mode",
        "copy_and_inspect_never_dispatch",
        "placement_and_target_never_widen_authority"
      ],
      "properties": {
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/modifier_action_class" }
        },
        "exposes_held_modifier_intent": { "type": "boolean" },
        "exposes_why_not_automatable": { "type": "boolean" },
        "requires_debug_mode": { "type": "boolean" },
        "copy_and_inspect_never_dispatch": { "type": "boolean" },
        "placement_and_target_never_widen_authority": { "type": "boolean" }
      }
    },
    "query_session_privacy_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_first",
        "history_policy",
        "retention_policy_ref",
        "max_history_entries",
        "clear_controls",
        "disable_control_available",
        "exposes_held_modifier_intent",
        "redaction_posture",
        "raw_query_export_allowed",
        "cross_device_memory_governed_by_explicit_feature"
      ],
      "properties": {
        "local_first": { "type": "boolean" },
        "history_policy": { "$ref": "#/$defs/history_policy_class" },
        "retention_policy_ref": { "type": "string", "minLength": 1 },
        "max_history_entries": { "type": "integer", "minimum": 0 },
        "clear_controls": {
          "type": "array",
          "items": { "$ref": "#/$defs/clear_history_rule_class" }
        },
        "disable_control_available": { "type": "boolean" },
        "exposes_held_modifier_intent": { "type": "boolean" },
        "redaction_posture": { "$ref": "#/$defs/redaction_posture_class" },
        "raw_query_export_allowed": { "type": "boolean" },
        "cross_device_memory_governed_by_explicit_feature": { "type": "boolean" },
        "governing_feature_ref": { "type": "string", "minLength": 1 }
      }
    },
    "disabled_reason_chip_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_class",
        "disabled_reason_code",
        "explanation_ref",
        "why_not_automatable_ref",
        "surfaces_resolve_identically"
      ],
      "properties": {
        "case_class": { "$ref": "#/$defs/disabled_reason_case_class" },
        "disabled_reason_code": { "type": "string", "minLength": 1 },
        "explanation_ref": { "type": "string", "minLength": 1 },
        "why_not_automatable_ref": { "type": "string", "minLength": 1 },
        "surfaces_resolve_identically": { "type": "boolean" }
      }
    },
    "evidence_export_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "json_export_ref",
        "markdown_summary_ref",
        "admin_inspector_ref",
        "support_export_ref",
        "rollback_lineage_refs",
        "export_lineage_refs"
      ],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "json_export_ref": { "type": "string", "minLength": 1 },
        "markdown_summary_ref": { "type": "string", "minLength": 1 },
        "admin_inspector_ref": { "type": "string", "minLength": 1 },
        "support_export_ref": { "type": "string", "minLength": 1 },
        "rollback_lineage_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "export_lineage_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
