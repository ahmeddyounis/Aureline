{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/stabilize_command_contract.schema.json",
  "title": "Aureline stabilized command-contract record",
  "$comment": "Rust owner: aureline_commands::stabilize_command_contract::CommandContractStabilizationPacket.",
  "description": "Boundary schema for the metadata-only stabilized command-contract record. For one canonical command family on a claimed stable row, the packet binds the finalized stable descriptor fields (command id, invocation schema, capability class, enablement rules, discoverability record, automation labels, result contract, lifecycle/origin metadata, alias/deprecation metadata, docs/help anchor, accessibility labels, shortcut narration), the stabilized invocation-session and result-packet contract (stable result codes, canonical identity, alias resolution, issuing surface, artifact refs, notification/activity joins, rollback/checkpoint handles, evidence refs, and strict no-bypass guards), the palette diagnostics contract (source badge, keybinding, dominant side-effect cue, disabled-with-reason state, preview/approval posture, and the Copy command ID / Copy CLI equivalent / Add to recipe / Why not automatable? actions), the structured disabled-reason cases every surface resolves identically, and the cross-surface authority parity over menu/button, keybinding, palette, CLI/headless, AI tool, voice, recipe, deep link, and browser companion, plus exportable evidence/rollback lineage, into one attributable artifact. It does not re-derive the descriptor, registry, invocation, result, or authority models; it binds them by their canonical schema refs. It carries refs, state tokens, coarse classes, counts, and review labels only. It never carries raw command arguments, raw prompt bodies, source file bodies, endpoint URLs, credentials, signing-key material, raw token counts, or exact prices. Adding a new enum member or a new optional field is additive-minor; repurposing an existing member is breaking and bumps schema_version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "command_family_id",
    "display_label",
    "claimed_stable",
    "policy_epoch_ref",
    "contract_refs",
    "stable_descriptor_fields",
    "result_contract",
    "palette_diagnostics",
    "disabled_reason_cases",
    "surface_parity_rows",
    "evidence_export",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "command_contract_stabilization_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "command_family_id": { "type": "string", "minLength": 1 },
    "display_label": { "type": "string", "minLength": 1 },
    "claimed_stable": { "type": "boolean" },
    "policy_epoch_ref": { "type": "string", "minLength": 1 },
    "contract_refs": { "$ref": "#/$defs/stable_contract_refs" },
    "stable_descriptor_fields": {
      "type": "array",
      "items": { "$ref": "#/$defs/stable_descriptor_field_row" }
    },
    "result_contract": { "$ref": "#/$defs/result_contract_stabilization" },
    "palette_diagnostics": { "$ref": "#/$defs/palette_diagnostics_contract" },
    "disabled_reason_cases": {
      "type": "array",
      "items": { "$ref": "#/$defs/disabled_reason_case_row" }
    },
    "surface_parity_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_parity_row" }
    },
    "evidence_export": { "$ref": "#/$defs/evidence_export_block" },
    "source_contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "stable_descriptor_field_class": {
      "type": "string",
      "enum": [
        "command_id",
        "invocation_schema",
        "capability_class",
        "enablement_rules",
        "discoverability_record",
        "automation_labels",
        "result_contract",
        "lifecycle_metadata",
        "origin_metadata",
        "alias_deprecation_metadata",
        "docs_help_anchor",
        "accessibility_labels",
        "shortcut_narration"
      ]
    },
    "command_result_code_class": {
      "type": "string",
      "enum": [
        "succeeded",
        "succeeded_with_warnings",
        "partially_applied",
        "cancelled",
        "blocked_by_policy",
        "disabled_with_reason",
        "preview_required",
        "approval_required",
        "failed"
      ]
    },
    "palette_action_class": {
      "type": "string",
      "enum": [
        "copy_command_id",
        "copy_cli_equivalent",
        "add_to_recipe",
        "why_not_automatable"
      ]
    },
    "disabled_reason_case_class": {
      "type": "string",
      "enum": [
        "disabled_by_policy",
        "wrong_focus",
        "missing_runtime",
        "degraded_provider",
        "preview_required",
        "approval_required",
        "ui_only"
      ]
    },
    "command_surface_class": {
      "type": "string",
      "enum": [
        "menu_or_button",
        "keybinding",
        "command_palette",
        "cli_headless",
        "ai_tool",
        "voice",
        "recipe",
        "deep_link",
        "browser_companion"
      ]
    },
    "surface_qualification_class": {
      "type": "string",
      "enum": ["stable", "beta", "experimental", "not_applicable"]
    },
    "stable_contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "descriptor_schema_ref",
        "registry_entry_schema_ref",
        "registry_seed_ref",
        "invocation_session_schema_ref",
        "result_packet_schema_ref",
        "public_contract_schema_ref",
        "parity_expectation_schema_ref",
        "disabled_reason_vocabulary_ref"
      ],
      "properties": {
        "descriptor_schema_ref": { "type": "string", "minLength": 1 },
        "registry_entry_schema_ref": { "type": "string", "minLength": 1 },
        "registry_seed_ref": { "type": "string", "minLength": 1 },
        "invocation_session_schema_ref": { "type": "string", "minLength": 1 },
        "result_packet_schema_ref": { "type": "string", "minLength": 1 },
        "public_contract_schema_ref": { "type": "string", "minLength": 1 },
        "parity_expectation_schema_ref": { "type": "string", "minLength": 1 },
        "disabled_reason_vocabulary_ref": { "type": "string", "minLength": 1 }
      }
    },
    "stable_descriptor_field_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_class",
        "field_label",
        "descriptor_pointer",
        "exported",
        "stable_interface"
      ],
      "properties": {
        "field_class": { "$ref": "#/$defs/stable_descriptor_field_class" },
        "field_label": { "type": "string", "minLength": 1 },
        "descriptor_pointer": { "type": "string", "minLength": 1 },
        "exported": { "type": "boolean" },
        "stable_interface": { "type": "boolean" }
      }
    },
    "result_contract_stabilization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_codes",
        "preserves_canonical_command_identity",
        "records_alias_resolution",
        "records_issuing_surface",
        "carries_artifact_refs",
        "joins_notification_or_activity",
        "requires_rollback_handle_for_durable",
        "supports_checkpoints",
        "carries_evidence_refs",
        "no_bypass_guards_strict"
      ],
      "properties": {
        "result_codes": {
          "type": "array",
          "items": { "$ref": "#/$defs/command_result_code_class" }
        },
        "preserves_canonical_command_identity": { "type": "boolean" },
        "records_alias_resolution": { "type": "boolean" },
        "records_issuing_surface": { "type": "boolean" },
        "carries_artifact_refs": { "type": "boolean" },
        "joins_notification_or_activity": { "type": "boolean" },
        "requires_rollback_handle_for_durable": { "type": "boolean" },
        "supports_checkpoints": { "type": "boolean" },
        "carries_evidence_refs": { "type": "boolean" },
        "no_bypass_guards_strict": { "type": "boolean" }
      }
    },
    "palette_diagnostics_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shows_source_badge",
        "shows_keybinding",
        "shows_dominant_side_effect_cue",
        "shows_disabled_with_reason",
        "shows_preview_posture",
        "shows_approval_posture",
        "actions"
      ],
      "properties": {
        "shows_source_badge": { "type": "boolean" },
        "shows_keybinding": { "type": "boolean" },
        "shows_dominant_side_effect_cue": { "type": "boolean" },
        "shows_disabled_with_reason": { "type": "boolean" },
        "shows_preview_posture": { "type": "boolean" },
        "shows_approval_posture": { "type": "boolean" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/palette_action_class" }
        }
      }
    },
    "disabled_reason_case_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_class",
        "disabled_reason_code",
        "explanation_ref",
        "repair_hook_ref",
        "surfaces_resolve_identically"
      ],
      "properties": {
        "case_class": { "$ref": "#/$defs/disabled_reason_case_class" },
        "disabled_reason_code": { "type": "string", "minLength": 1 },
        "explanation_ref": { "type": "string", "minLength": 1 },
        "repair_hook_ref": { "type": "string", "minLength": 1 },
        "surfaces_resolve_identically": { "type": "boolean" }
      }
    },
    "surface_parity_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "descriptor_ref",
        "reachable",
        "shares_command_descriptor",
        "shares_preview_model",
        "shares_approval_model",
        "shares_rollback_model",
        "shares_audit_model",
        "resolves_to_canonical",
        "route_disclosed",
        "policy_checked",
        "automation_label_honest",
        "qualification",
        "claimed_stable"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/command_surface_class" },
        "descriptor_ref": { "type": "string", "minLength": 1 },
        "reachable": { "type": "boolean" },
        "shares_command_descriptor": { "type": "boolean" },
        "shares_preview_model": { "type": "boolean" },
        "shares_approval_model": { "type": "boolean" },
        "shares_rollback_model": { "type": "boolean" },
        "shares_audit_model": { "type": "boolean" },
        "resolves_to_canonical": { "type": "boolean" },
        "route_disclosed": { "type": "boolean" },
        "policy_checked": { "type": "boolean" },
        "automation_label_honest": { "type": "boolean" },
        "qualification": { "$ref": "#/$defs/surface_qualification_class" },
        "claimed_stable": { "type": "boolean" }
      }
    },
    "evidence_export_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "json_export_ref",
        "markdown_summary_ref",
        "admin_inspector_ref",
        "support_export_ref",
        "rollback_lineage_refs",
        "export_lineage_refs"
      ],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "json_export_ref": { "type": "string", "minLength": 1 },
        "markdown_summary_ref": { "type": "string", "minLength": 1 },
        "admin_inspector_ref": { "type": "string", "minLength": 1 },
        "support_export_ref": { "type": "string", "minLength": 1 },
        "rollback_lineage_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "export_lineage_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
