{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/parity_expectation.schema.json",
  "title": "Aureline command invocation parity expectation",
  "description": "Boundary schema for command_parity_expectation_record. Each record freezes the result semantics a command must preserve across desktop menus/buttons/context menus, palette/keybinding/leader routes, CLI/recipe/AI/voice routes, and browser/mobile companion surfaces. It also pins alias, deprecation, and migration rules so stable command ids cannot be silently reassigned.",
  "type": "object",
  "$ref": "#/$defs/command_parity_expectation_record",
  "$defs": {
    "parity_expectation_schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "canonical_verb": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "menu_button_context_menu",
        "palette_keybinding_leader",
        "cli_recipe_ai_voice",
        "browser_mobile_companion"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "global_application_menu",
        "context_menu",
        "toolbar_button",
        "command_palette",
        "keybinding_chord",
        "leader_sequence",
        "cli_surface",
        "automation_recipe_surface",
        "ai_tool_surface",
        "voice_surface",
        "browser_companion_surface",
        "mobile_companion_surface"
      ]
    },
    "coverage_status": {
      "type": "string",
      "enum": [
        "claimed",
        "explicitly_narrowed",
        "read_only_mirror_only",
        "denied_by_client_scope",
        "unsupported_pending_surface_contract"
      ]
    },
    "authority_class": {
      "type": "string",
      "enum": [
        "user_initiated_local",
        "user_initiated_shared",
        "ai_initiated",
        "extension_initiated",
        "automation_recipe_initiated",
        "collaboration_remote_initiated",
        "admin_policy_initiated"
      ]
    },
    "result_outcome_code": {
      "type": "string",
      "enum": [
        "succeeded",
        "succeeded_with_warnings",
        "denied_by_enablement",
        "denied_by_preview",
        "denied_by_approval",
        "cancelled_by_user",
        "failed_with_typed_error",
        "rolled_back_after_apply",
        "partially_applied_and_halted",
        "scheduled_pending_background"
      ]
    },
    "warning_code": {
      "type": "string",
      "enum": [
        "deprecated_alias_used",
        "headless_prompt_elided_with_disclosure",
        "companion_freshness_degraded",
        "rollback_window_limited",
        "export_redacted_by_policy",
        "partial_evidence_retained",
        "notification_delivery_deferred",
        "activity_projection_delayed",
        "background_completion_pending"
      ]
    },
    "error_code": {
      "type": "string",
      "enum": [
        "workspace_trust_restricted",
        "policy_blocked_in_context",
        "preview_required_not_shown",
        "approval_denial_no_approval_path",
        "basis_snapshot_drifted",
        "required_argument_unresolved",
        "required_credential_missing",
        "execution_context_unavailable",
        "command_version_unknown",
        "alias_not_resolvable",
        "typed_runtime_failure",
        "companion_mutation_requires_desktop_handoff",
        "rollback_failed_typed_reason"
      ]
    },
    "result_contract_class": {
      "type": "string",
      "enum": [
        "no_result_emitted",
        "typed_value_returned",
        "artifact_created_ref",
        "artifact_modified_ref",
        "artifact_deleted_ref",
        "journal_entry_appended_ref",
        "audit_event_emitted_ref",
        "preview_record_emitted_ref",
        "approval_ticket_emitted_ref",
        "browser_handoff_packet_emitted_ref",
        "evidence_packet_emitted_ref",
        "rollback_ticket_emitted_ref"
      ]
    },
    "evidence_ref_class": {
      "type": "string",
      "enum": [
        "preview_record_ref",
        "approval_ticket_ref",
        "permission_prompt_ref",
        "interaction_safety_packet_ref",
        "mutation_journal_entry_ref",
        "audit_event_ref",
        "capability_lifecycle_audit_event_ref",
        "ai_evidence_packet_ref",
        "support_export_row_ref",
        "browser_handoff_packet_ref",
        "rollback_ticket_ref",
        "rollback_handle_ref",
        "checkpoint_ref",
        "command_result_packet_ref",
        "notification_event_ref",
        "activity_event_ref",
        "docs_citation_anchor_ref"
      ]
    },
    "rollback_handle_posture": {
      "type": "string",
      "enum": [
        "not_applicable_no_mutation",
        "handle_available",
        "handle_pending_background",
        "manual_recovery_only",
        "not_reversible_by_contract",
        "expired_or_invalidated"
      ]
    },
    "export_posture_class": {
      "type": "string",
      "enum": [
        "exportable_metadata_default",
        "exportable_with_redaction",
        "support_bundle_redacted_only",
        "organization_audit_log_only",
        "local_user_only",
        "signing_evidence_only",
        "export_denied_by_policy"
      ]
    },
    "alias_kind": {
      "type": "string",
      "enum": [
        "legacy_command_id",
        "alternate_palette_phrasing",
        "alternate_cli_verb",
        "ai_tool_handle",
        "keybinding_target",
        "voice_phrase",
        "companion_handoff_token",
        "imported_bridge_alias"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "$ref": "#/$defs/non_empty_string" },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted"]
        },
        "execution_context_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "no_bypass_guards": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust_revalidation_required",
        "policy_revalidation_required",
        "permission_prompt_revalidation_required",
        "preview_path_preserved",
        "approval_path_preserved",
        "credential_broker_revalidation_required",
        "execution_context_revalidation_required",
        "freshness_floor_revalidation_required",
        "capability_class_may_not_widen",
        "result_schema_may_not_be_replaced",
        "companion_must_handoff_mutation_to_desktop",
        "voice_must_confirm_resolved_command"
      ],
      "properties": {
        "trust_revalidation_required": { "const": true },
        "policy_revalidation_required": { "const": true },
        "permission_prompt_revalidation_required": { "const": true },
        "preview_path_preserved": { "const": true },
        "approval_path_preserved": { "const": true },
        "credential_broker_revalidation_required": { "const": true },
        "execution_context_revalidation_required": { "const": true },
        "freshness_floor_revalidation_required": { "const": true },
        "capability_class_may_not_widen": { "const": true },
        "result_schema_may_not_be_replaced": { "const": true },
        "companion_must_handoff_mutation_to_desktop": { "const": true },
        "voice_must_confirm_resolved_command": { "const": true }
      }
    },
    "expected_result_semantics_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_outcome_codes",
        "allowed_warning_codes",
        "allowed_error_codes",
        "result_contract_classes",
        "required_evidence_ref_classes",
        "rollback_handle_posture",
        "export_posture_class",
        "notification_or_activity_ref_required"
      ],
      "properties": {
        "allowed_outcome_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/result_outcome_code" }
        },
        "allowed_warning_codes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/warning_code" }
        },
        "allowed_error_codes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/error_code" }
        },
        "result_contract_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/result_contract_class" }
        },
        "required_evidence_ref_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidence_ref_class" }
        },
        "rollback_handle_posture": { "$ref": "#/$defs/rollback_handle_posture" },
        "export_posture_class": { "$ref": "#/$defs/export_posture_class" },
        "notification_or_activity_ref_required": { "type": "boolean" }
      }
    },
    "surface_parity_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_family",
        "surface_class",
        "coverage_status",
        "authority_class",
        "result_packet_required",
        "invocation_session_minimum_required",
        "expected_result_semantics",
        "no_bypass_guards",
        "narrowing_reason_ref"
      ],
      "properties": {
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "coverage_status": { "$ref": "#/$defs/coverage_status" },
        "authority_class": { "$ref": "#/$defs/authority_class" },
        "result_packet_required": { "const": true },
        "invocation_session_minimum_required": { "const": true },
        "expected_result_semantics": { "$ref": "#/$defs/expected_result_semantics_block" },
        "no_bypass_guards": { "$ref": "#/$defs/no_bypass_guards" },
        "narrowing_reason_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "alias_migration_rules_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_command_id_reassignment_forbidden",
        "silent_alias_reassignment_forbidden",
        "canonical_id_required_for_new_bindings",
        "deprecated_alias_invocations_record_alias_used",
        "deprecated_alias_support_window_ref_required",
        "migration_trace_required_for_imported_aliases",
        "release_notes_alone_are_not_sufficient",
        "alias_kinds_covered"
      ],
      "properties": {
        "stable_command_id_reassignment_forbidden": { "const": true },
        "silent_alias_reassignment_forbidden": { "const": true },
        "canonical_id_required_for_new_bindings": { "const": true },
        "deprecated_alias_invocations_record_alias_used": { "const": true },
        "deprecated_alias_support_window_ref_required": { "const": true },
        "migration_trace_required_for_imported_aliases": { "const": true },
        "release_notes_alone_are_not_sufficient": { "const": true },
        "alias_kinds_covered": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/alias_kind" }
        }
      }
    },
    "command_parity_expectation_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "parity_expectation_schema_version",
        "parity_expectation_id",
        "canonical_command_id",
        "command_revision_ref",
        "canonical_verb",
        "descriptor_ref",
        "result_packet_schema_ref",
        "rollback_handle_schema_ref",
        "surface_rows",
        "alias_migration_rules",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "command_parity_expectation_record" },
        "parity_expectation_schema_version": { "$ref": "#/$defs/parity_expectation_schema_version" },
        "parity_expectation_id": { "$ref": "#/$defs/opaque_id" },
        "canonical_command_id": { "$ref": "#/$defs/opaque_id" },
        "command_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "canonical_verb": { "$ref": "#/$defs/canonical_verb" },
        "descriptor_ref": { "$ref": "#/$defs/non_empty_string" },
        "result_packet_schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "rollback_handle_schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "surface_rows": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/surface_parity_row" }
        },
        "alias_migration_rules": { "$ref": "#/$defs/alias_migration_rules_block" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    }
  }
}
