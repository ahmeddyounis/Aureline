{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/palette_action_footer.schema.json",
  "title": "Aureline command palette selected-row action-footer contract",
  "description": "Boundary schema for palette_action_footer_record, frozen in docs/commands/palette_row_contract.md and docs/commands/palette_query_session_contract.md. The footer is a selected-row projection over command descriptor, command registry, keybinding resolver, query-session state, and shareability metadata. It defines default run/open, alternate invocation rows, copy/CLI/recipe/diagnostic actions, and a required action inventory without creating palette-private launch semantics.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/palette_action_footer_record" }
  ],
  "$defs": {
    "palette_action_footer_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "enum": ["palette_action_footer_record"]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "$ref": "command_descriptor.schema.json#/$defs/monotonic_timestamp"
    },
    "canonical_verb": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
    },
    "repair_hook_ref": {
      "$ref": "command_descriptor.schema.json#/$defs/repair_hook_ref"
    },
    "preview_class": {
      "$ref": "command_descriptor.schema.json#/$defs/preview_class"
    },
    "approval_posture_class": {
      "$ref": "command_descriptor.schema.json#/$defs/approval_posture_class"
    },
    "disabled_reason_code": {
      "$ref": "command_descriptor.schema.json#/$defs/disabled_reason_code"
    },
    "copy_form_class": {
      "$ref": "shareability_metadata.schema.json#/$defs/copy_form_class"
    },
    "cli_equivalent_presence_class": {
      "$ref": "shareability_metadata.schema.json#/$defs/cli_equivalent_presence_class"
    },
    "headless_mode_class": {
      "$ref": "shareability_metadata.schema.json#/$defs/headless_mode_class"
    },
    "shareability_why_unavailable_reason": {
      "$ref": "shareability_metadata.schema.json#/$defs/shareability_why_unavailable_reason"
    },
    "automation_safety_cue": {
      "$ref": "shareability_metadata.schema.json#/$defs/automation_safety_cue"
    },
    "unavailability_parity_surface": {
      "$ref": "shareability_metadata.schema.json#/$defs/unavailability_parity_surface"
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "scenario"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/non_empty_string" },
        "source_registry_fixture": { "$ref": "#/$defs/non_empty_string" },
        "exercised_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "footer_state_class": {
      "type": "string",
      "enum": [
        "hidden",
        "compact",
        "expanded",
        "disabled_reason_only",
        "automation_detail",
        "preview_required"
      ]
    },
    "footer_action_class": {
      "type": "string",
      "enum": [
        "primary_run_or_open",
        "open_in_split",
        "open_alternate_target",
        "open_new_tab_or_window",
        "copy_command_id",
        "copy_canonical_verb",
        "copy_cli_headless_form",
        "copy_deep_link_ref",
        "copy_docs_help_anchor",
        "add_to_recipe",
        "inspect_why_not_automatable",
        "inspect_arguments",
        "inspect_unavailability",
        "open_docs_help",
        "open_keybinding_settings"
      ]
    },
    "footer_action_enabled_state": {
      "type": "string",
      "enum": [
        "enabled",
        "disabled_with_reason",
        "hidden_with_reason"
      ]
    },
    "action_inventory_slot_class": {
      "type": "string",
      "enum": [
        "default_run",
        "split_or_open_alt",
        "open_alternate_target",
        "copy_command_id",
        "copy_cli_headless_form",
        "add_to_recipe",
        "inspect_why_not_automatable"
      ]
    },
    "keyboard_gesture_class": {
      "type": "string",
      "enum": [
        "enter",
        "alt_enter",
        "primary_modifier_enter",
        "secondary_modifier_enter",
        "tab_focus",
        "space_or_enter_on_footer",
        "copy_chord",
        "no_default_gesture"
      ]
    },
    "alternate_invocation_placement_class": {
      "type": "string",
      "enum": [
        "current_surface",
        "split_pane",
        "new_tab",
        "new_window",
        "external_browser_handoff",
        "headless_skeleton",
        "recipe_step",
        "detail_only"
      ]
    },
    "invocation_semantics_class": {
      "type": "string",
      "enum": [
        "dispatch_primary",
        "dispatch_with_placement_delta",
        "copy_only_no_dispatch",
        "recipe_insert_no_dispatch",
        "inspect_only_no_dispatch",
        "open_docs_only_no_dispatch"
      ]
    },
    "projection_target_class": {
      "type": "string",
      "enum": [
        "command_palette",
        "docs_help",
        "settings_command_detail",
        "keybinding_help",
        "migration_guidance",
        "command_docs",
        "automation_recipe_builder",
        "support_export"
      ]
    },
    "source_record_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "palette_row_ref",
        "registry_entry_id",
        "command_descriptor_ref",
        "shareability_metadata_ref",
        "projection_ref"
      ],
      "properties": {
        "palette_row_ref": { "$ref": "#/$defs/opaque_id" },
        "registry_entry_id": { "$ref": "#/$defs/opaque_id" },
        "command_descriptor_ref": { "$ref": "#/$defs/opaque_id" },
        "shareability_metadata_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "diagnostic_projection_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "projection_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "command_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "command_revision_ref",
        "canonical_verb"
      ],
      "properties": {
        "command_id": { "$ref": "#/$defs/opaque_id" },
        "command_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "canonical_verb": { "$ref": "#/$defs/canonical_verb" }
      }
    },
    "unavailable_reason_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason_code",
        "display_label_ref",
        "repair_hook_ref"
      ],
      "properties": {
        "reason_code": {
          "anyOf": [
            { "$ref": "#/$defs/disabled_reason_code" },
            { "$ref": "#/$defs/shareability_why_unavailable_reason" }
          ]
        },
        "display_label_ref": { "$ref": "#/$defs/opaque_id" },
        "repair_hook_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/repair_hook_ref" }
          ]
        }
      }
    },
    "revalidation_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust_revalidation_required",
        "policy_revalidation_required",
        "permission_prompt_revalidation_required",
        "preview_path_preserved",
        "approval_path_preserved",
        "copy_actions_do_not_dispatch"
      ],
      "properties": {
        "trust_revalidation_required": { "const": true },
        "policy_revalidation_required": { "const": true },
        "permission_prompt_revalidation_required": { "const": true },
        "preview_path_preserved": { "const": true },
        "approval_path_preserved": { "const": true },
        "copy_actions_do_not_dispatch": { "const": true }
      }
    },
    "shareability_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "copy_form_class",
        "copy_token_ref",
        "cli_equivalent_presence_class",
        "headless_mode_class"
      ],
      "properties": {
        "copy_form_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/copy_form_class" }
          ]
        },
        "copy_token_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "cli_equivalent_presence_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/cli_equivalent_presence_class" }
          ]
        },
        "headless_mode_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/headless_mode_class" }
          ]
        },
        "invocation_ref_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "typed_argv_shape_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      }
    },
    "footer_action_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "footer_action_id",
        "action_class",
        "enabled_state",
        "label_ref",
        "narration_ref",
        "keyboard_gesture_class",
        "semantics_class",
        "shareability",
        "unavailable_reason",
        "revalidation",
        "consistent_on_surfaces"
      ],
      "properties": {
        "footer_action_id": { "$ref": "#/$defs/opaque_id" },
        "action_class": { "$ref": "#/$defs/footer_action_class" },
        "enabled_state": { "$ref": "#/$defs/footer_action_enabled_state" },
        "label_ref": { "$ref": "#/$defs/opaque_id" },
        "narration_ref": { "$ref": "#/$defs/opaque_id" },
        "keyboard_gesture_class": { "$ref": "#/$defs/keyboard_gesture_class" },
        "semantics_class": { "$ref": "#/$defs/invocation_semantics_class" },
        "shareability": { "$ref": "#/$defs/shareability_projection" },
        "unavailable_reason": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/unavailable_reason_projection" }
          ]
        },
        "revalidation": { "$ref": "#/$defs/revalidation_contract" },
        "consistent_on_surfaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "anyOf": [
              { "$ref": "#/$defs/unavailability_parity_surface" },
              { "$ref": "#/$defs/projection_target_class" }
            ]
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled_state": {
                "enum": [
                  "disabled_with_reason",
                  "hidden_with_reason"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "unavailable_reason": { "$ref": "#/$defs/unavailable_reason_projection" }
            }
          }
        }
      ]
    },
    "alternate_invocation_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alternate_row_id",
        "action_class",
        "placement_class",
        "semantics_class",
        "argument_delta_refs",
        "preserves_command_identity",
        "preserves_enablement_decision",
        "revalidation",
        "label_ref",
        "narration_ref"
      ],
      "properties": {
        "alternate_row_id": { "$ref": "#/$defs/opaque_id" },
        "action_class": { "$ref": "#/$defs/footer_action_class" },
        "placement_class": { "$ref": "#/$defs/alternate_invocation_placement_class" },
        "semantics_class": { "$ref": "#/$defs/invocation_semantics_class" },
        "argument_delta_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "preserves_command_identity": { "const": true },
        "preserves_enablement_decision": { "const": true },
        "revalidation": { "$ref": "#/$defs/revalidation_contract" },
        "label_ref": { "$ref": "#/$defs/opaque_id" },
        "narration_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "automation_detail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "automation_safety_cues",
        "why_not_automatable_ref",
        "recipe_insert_allowed"
      ],
      "properties": {
        "automation_safety_cues": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/automation_safety_cue" }
        },
        "why_not_automatable_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "recipe_insert_allowed": { "type": "boolean" }
      }
    },
    "preview_approval_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_class",
        "approval_posture_class",
        "preview_required_before_dispatch",
        "approval_required_before_dispatch"
      ],
      "properties": {
        "preview_class": { "$ref": "#/$defs/preview_class" },
        "approval_posture_class": { "$ref": "#/$defs/approval_posture_class" },
        "preview_required_before_dispatch": { "type": "boolean" },
        "approval_required_before_dispatch": { "type": "boolean" }
      }
    },
    "projection_consistency_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "menus_use_same_action_classes",
        "docs_use_same_copy_forms",
        "settings_use_same_disabled_reasons",
        "keyboard_flows_use_same_modifier_semantics",
        "recipe_builder_uses_same_invocation_ref"
      ],
      "properties": {
        "menus_use_same_action_classes": { "const": true },
        "docs_use_same_copy_forms": { "const": true },
        "settings_use_same_disabled_reasons": { "const": true },
        "keyboard_flows_use_same_modifier_semantics": { "const": true },
        "recipe_builder_uses_same_invocation_ref": { "const": true }
      }
    },
    "action_inventory_slot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_class",
        "action_class",
        "action_ref",
        "enabled_state",
        "unavailable_reason_ref"
      ],
      "properties": {
        "slot_class": { "$ref": "#/$defs/action_inventory_slot_class" },
        "action_class": { "$ref": "#/$defs/footer_action_class" },
        "action_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "enabled_state": { "$ref": "#/$defs/footer_action_enabled_state" },
        "unavailable_reason_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled_state": {
                "enum": [
                  "disabled_with_reason",
                  "hidden_with_reason"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "unavailable_reason_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        }
      ]
    },
    "action_inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_run",
        "split_or_open_alt",
        "open_alternate_target",
        "copy_command_id",
        "copy_cli_headless_form",
        "add_to_recipe",
        "inspect_why_not_automatable",
        "keyboard_menu_docs_cli_consistency_required"
      ],
      "properties": {
        "default_run": { "$ref": "#/$defs/action_inventory_slot" },
        "split_or_open_alt": { "$ref": "#/$defs/action_inventory_slot" },
        "open_alternate_target": { "$ref": "#/$defs/action_inventory_slot" },
        "copy_command_id": { "$ref": "#/$defs/action_inventory_slot" },
        "copy_cli_headless_form": { "$ref": "#/$defs/action_inventory_slot" },
        "add_to_recipe": { "$ref": "#/$defs/action_inventory_slot" },
        "inspect_why_not_automatable": { "$ref": "#/$defs/action_inventory_slot" },
        "keyboard_menu_docs_cli_consistency_required": { "const": true }
      }
    },
    "palette_action_footer_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "palette_action_footer_schema_version",
        "footer_id",
        "footer_state",
        "source_record_refs",
        "command_identity",
        "preview_approval",
        "automation_detail",
        "primary_action_ref",
        "action_inventory",
        "actions",
        "alternate_invocation_rows",
        "projection_targets",
        "projection_consistency",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "palette_action_footer_record" },
        "palette_action_footer_schema_version": {
          "$ref": "#/$defs/palette_action_footer_schema_version"
        },
        "footer_id": { "$ref": "#/$defs/opaque_id" },
        "footer_state": { "$ref": "#/$defs/footer_state_class" },
        "source_record_refs": { "$ref": "#/$defs/source_record_refs" },
        "command_identity": { "$ref": "#/$defs/command_identity" },
        "preview_approval": { "$ref": "#/$defs/preview_approval_projection" },
        "automation_detail": { "$ref": "#/$defs/automation_detail" },
        "primary_action_ref": { "$ref": "#/$defs/opaque_id" },
        "action_inventory": { "$ref": "#/$defs/action_inventory" },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/footer_action_record" }
        },
        "alternate_invocation_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/alternate_invocation_row" }
        },
        "projection_targets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/projection_target_class" }
        },
        "projection_consistency": { "$ref": "#/$defs/projection_consistency_contract" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    }
  }
}
