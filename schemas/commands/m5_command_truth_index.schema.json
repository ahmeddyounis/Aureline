{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/m5_command_truth_index.schema.json",
  "title": "M5 command truth index packet",
  "description": "Boundary schema for the canonical M5 command-truth evidence index. The packet binds the M5 command-governance packet, capability-state truth packet, and rollout inventory into one downstream-facing source for Help/About, release-center, support-export, and public-truth consumers. It carries typed lifecycle state, truth posture, projection refs, and evidence refs only; raw payloads, credentials, and rendered packet bodies never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "schema_ref",
    "doc_ref",
    "source_command_governance_ref",
    "source_capability_state_ref",
    "source_rollout_inventory_ref",
    "rows",
    "summary"
  ],
  "properties": {
    "record_kind": { "const": "m5_command_truth_index_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "schema_ref": { "const": "schemas/commands/m5_command_truth_index.schema.json" },
    "doc_ref": { "const": "docs/commands/m5_command_truth_index.md" },
    "source_command_governance_ref": { "type": "string", "minLength": 1 },
    "source_capability_state_ref": { "type": "string", "minLength": 1 },
    "source_rollout_inventory_ref": { "type": "string", "minLength": 1 },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/row" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "capability_state_class": {
      "type": "string",
      "enum": [
        "labs",
        "preview",
        "beta",
        "stable",
        "deprecated",
        "disabled_by_policy",
        "retest_pending",
        "removed"
      ]
    },
    "truth_state_class": {
      "type": "string",
      "enum": [
        "certified",
        "narrowed",
        "policy_blocked",
        "retest_pending",
        "underqualified"
      ]
    },
    "truth_surface_class": {
      "type": "string",
      "enum": [
        "help_about",
        "release_center",
        "support_export",
        "public_truth"
      ]
    },
    "surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "surface_ref",
        "source_projection_ref",
        "effective_state_class",
        "stable_wording_visible",
        "support_wording_visible",
        "visible_narrowing_reason_codes"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/truth_surface_class" },
        "surface_ref": { "type": "string", "minLength": 1 },
        "source_projection_ref": { "type": "string", "minLength": 1 },
        "effective_state_class": { "$ref": "#/$defs/capability_state_class" },
        "stable_wording_visible": { "type": "boolean" },
        "support_wording_visible": { "type": "boolean" },
        "visible_narrowing_reason_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "capability_id",
        "display_label",
        "owner_ref",
        "rollout_ring",
        "cohort",
        "review_or_expiry_date",
        "lifecycle_label",
        "support_class",
        "effective_state_class",
        "truth_state_class",
        "authority_parity_complete",
        "result_packet_reuse_complete",
        "lifecycle_truth_visible",
        "stable_wording_allowed",
        "settings_projection_ref",
        "help_about_projection_ref",
        "diagnostics_projection_ref",
        "release_center_projection_ref",
        "support_export_projection_ref",
        "public_truth_projection_ref",
        "evidence_refs",
        "finding_codes",
        "surface_rows",
        "rationale"
      ],
      "properties": {
        "command_id": { "type": "string", "minLength": 1 },
        "capability_id": { "type": "string", "minLength": 1 },
        "display_label": { "type": "string", "minLength": 1 },
        "owner_ref": { "type": "string", "minLength": 1 },
        "rollout_ring": { "type": "string", "minLength": 1 },
        "cohort": { "type": "string", "minLength": 1 },
        "review_or_expiry_date": { "type": "string", "minLength": 1 },
        "lifecycle_label": { "type": "string", "minLength": 1 },
        "support_class": { "type": "string", "minLength": 1 },
        "effective_state_class": { "$ref": "#/$defs/capability_state_class" },
        "truth_state_class": { "$ref": "#/$defs/truth_state_class" },
        "authority_parity_complete": { "type": "boolean" },
        "result_packet_reuse_complete": { "type": "boolean" },
        "lifecycle_truth_visible": { "type": "boolean" },
        "stable_wording_allowed": { "type": "boolean" },
        "active_kill_switch_source": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "settings_projection_ref": { "type": "string", "minLength": 1 },
        "help_about_projection_ref": { "type": "string", "minLength": 1 },
        "diagnostics_projection_ref": { "type": "string", "minLength": 1 },
        "release_center_projection_ref": { "type": "string", "minLength": 1 },
        "support_export_projection_ref": { "type": "string", "minLength": 1 },
        "public_truth_projection_ref": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "finding_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "surface_rows": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/surface_row" }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_count",
        "truth_surface_row_count",
        "certified_command_count",
        "narrowed_command_count",
        "policy_blocked_command_count",
        "retest_pending_command_count",
        "underqualified_command_count",
        "active_kill_switch_command_count",
        "stable_wording_allowed_command_count",
        "finding_count"
      ],
      "properties": {
        "command_count": { "type": "integer", "minimum": 0 },
        "truth_surface_row_count": { "type": "integer", "minimum": 0 },
        "certified_command_count": { "type": "integer", "minimum": 0 },
        "narrowed_command_count": { "type": "integer", "minimum": 0 },
        "policy_blocked_command_count": { "type": "integer", "minimum": 0 },
        "retest_pending_command_count": { "type": "integer", "minimum": 0 },
        "underqualified_command_count": { "type": "integer", "minimum": 0 },
        "active_kill_switch_command_count": { "type": "integer", "minimum": 0 },
        "stable_wording_allowed_command_count": { "type": "integer", "minimum": 0 },
        "finding_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
