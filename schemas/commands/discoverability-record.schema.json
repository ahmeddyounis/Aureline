{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/discoverability-record.schema.json",
  "title": "Aureline stable command discoverability support packet",
  "description": "Boundary schema for the command_discoverability_support_packet. The packet binds one canonical discoverability record per protected command, one alias/deprecation map, one privacy-bounded query-session policy, and one per-surface parity row so palette, keybinding help, docs/help, onboarding, voice hints, CLI help, and support export consume the same discoverability truth instead of hand-authored copies.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "source_registry_ref",
    "source_descriptor_contract_ref",
    "source_discoverability_contract_ref",
    "source_palette_query_contract_ref",
    "published_doc_ref",
    "schema_ref",
    "query_session_schema_ref",
    "commands",
    "query_session_policy"
  ],
  "properties": {
    "record_kind": { "const": "command_discoverability_support_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_registry_ref": { "$ref": "#/$defs/non_empty_string" },
    "source_descriptor_contract_ref": { "$ref": "#/$defs/non_empty_string" },
    "source_discoverability_contract_ref": { "$ref": "#/$defs/non_empty_string" },
    "source_palette_query_contract_ref": { "$ref": "#/$defs/non_empty_string" },
    "published_doc_ref": { "$ref": "#/$defs/non_empty_string" },
    "schema_ref": { "$ref": "#/$defs/non_empty_string" },
    "query_session_schema_ref": { "$ref": "#/$defs/non_empty_string" },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/protected_command_discoverability_record" }
    },
    "query_session_policy": { "$ref": "#/$defs/query_session_policy_record" }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "string_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "nullable_string": {
      "type": ["string", "null"]
    },
    "automation_support_class": {
      "type": "string",
      "enum": [
        "macro_safe",
        "recipe_safe",
        "headless_safe",
        "ui_only",
        "approval_required",
        "unknown"
      ]
    },
    "discoverability_surface_class": {
      "type": "string",
      "enum": [
        "command_palette",
        "keybinding_help",
        "docs_help",
        "onboarding_hint",
        "voice_hint",
        "cli_help",
        "support_export"
      ]
    },
    "query_session_provider_class": {
      "type": "string",
      "enum": [
        "command_registry",
        "recent_history",
        "lexical_command_index",
        "semantic_command_index",
        "docs_help",
        "keybinding_resolver",
        "migration_bridge"
      ]
    },
    "query_session_text_material_class": {
      "type": "string",
      "enum": [
        "not_recorded",
        "raw_local_only",
        "redacted_text",
        "classification_only"
      ]
    },
    "query_session_sync_posture_class": {
      "type": "string",
      "enum": ["local_only", "governed_sync"]
    },
    "history_policy_class": {
      "type": "string",
      "enum": [
        "no_history",
        "session_only",
        "local_profile",
        "local_device",
        "managed_governed"
      ]
    },
    "clear_history_rule_class": {
      "type": "string",
      "enum": [
        "clear_current_session_only",
        "clear_palette_recent_queries",
        "clear_command_recents",
        "clear_profile_command_history",
        "admin_policy_purge",
        "erase_on_workspace_untrust"
      ]
    },
    "redaction_posture_class": {
      "type": "string",
      "enum": [
        "local_private",
        "metadata_safe",
        "support_redacted",
        "policy_review",
        "export_denied"
      ]
    },
    "discoverability_accessibility_record": {
      "type": "object",
      "required": [
        "primary_label_ref",
        "short_label_ref",
        "long_description_ref",
        "role_class",
        "keyboard_shortcut_narration_ref"
      ],
      "properties": {
        "primary_label_ref": { "$ref": "#/$defs/non_empty_string" },
        "short_label_ref": { "$ref": "#/$defs/non_empty_string" },
        "long_description_ref": { "$ref": "#/$defs/non_empty_string" },
        "role_class": { "$ref": "#/$defs/non_empty_string" },
        "keyboard_shortcut_narration_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "discoverability_alias_record": {
      "type": "object",
      "required": [
        "alias_id",
        "alias_kind",
        "alias_state",
        "source_system_ref",
        "eligible_for_new_bindings"
      ],
      "properties": {
        "alias_id": { "$ref": "#/$defs/non_empty_string" },
        "alias_kind": { "$ref": "#/$defs/non_empty_string" },
        "alias_state": { "$ref": "#/$defs/non_empty_string" },
        "source_system_ref": { "$ref": "#/$defs/non_empty_string" },
        "introduced_ref": { "$ref": "#/$defs/nullable_string" },
        "deprecated_ref": { "$ref": "#/$defs/nullable_string" },
        "retired_ref": { "$ref": "#/$defs/nullable_string" },
        "replacement_command_id": { "$ref": "#/$defs/nullable_string" },
        "notes_ref": { "$ref": "#/$defs/nullable_string" },
        "eligible_for_new_bindings": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "discoverability_current_keybinding_record": {
      "type": "object",
      "required": [
        "platform_class",
        "display_state",
        "keybinding_ref",
        "source_layer"
      ],
      "properties": {
        "platform_class": { "$ref": "#/$defs/non_empty_string" },
        "display_state": { "$ref": "#/$defs/non_empty_string" },
        "keybinding_ref": { "$ref": "#/$defs/non_empty_string" },
        "source_layer": { "$ref": "#/$defs/non_empty_string" },
        "imported_from_ref": { "$ref": "#/$defs/nullable_string" },
        "notes_ref": { "$ref": "#/$defs/nullable_string" }
      },
      "additionalProperties": false
    },
    "discoverability_projection_refs": {
      "type": "object",
      "required": [
        "palette_row_ref",
        "help_search_ref",
        "onboarding_hint_ref",
        "migration_bridge_card_ref",
        "current_shortcut_display_ref",
        "why_unavailable_explainer_ref",
        "key_sequence_discoverability_ref",
        "docs_help_page_ref",
        "voice_hint_ref",
        "cli_help_ref",
        "support_export_ref"
      ],
      "properties": {
        "palette_row_ref": { "$ref": "#/$defs/non_empty_string" },
        "help_search_ref": { "$ref": "#/$defs/non_empty_string" },
        "onboarding_hint_ref": { "$ref": "#/$defs/non_empty_string" },
        "migration_bridge_card_ref": { "$ref": "#/$defs/non_empty_string" },
        "current_shortcut_display_ref": { "$ref": "#/$defs/non_empty_string" },
        "why_unavailable_explainer_ref": { "$ref": "#/$defs/non_empty_string" },
        "key_sequence_discoverability_ref": { "$ref": "#/$defs/non_empty_string" },
        "docs_help_page_ref": { "$ref": "#/$defs/non_empty_string" },
        "voice_hint_ref": { "$ref": "#/$defs/non_empty_string" },
        "cli_help_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "discoverability_surface_projection_row": {
      "type": "object",
      "required": [
        "surface_class",
        "projection_ref",
        "examples_match",
        "alias_set_matches",
        "lifecycle_matches",
        "disabled_reason_matches",
        "automation_support_matches",
        "accessibility_labels_match",
        "help_anchor_matches"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/discoverability_surface_class" },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "examples_match": { "type": "boolean" },
        "alias_set_matches": { "type": "boolean" },
        "lifecycle_matches": { "type": "boolean" },
        "disabled_reason_matches": { "type": "boolean" },
        "automation_support_matches": { "type": "boolean" },
        "accessibility_labels_match": { "type": "boolean" },
        "help_anchor_matches": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "discoverability_typed_argument_record": {
      "type": "object",
      "required": [
        "argument_name",
        "argument_kind",
        "is_required",
        "narration_label_ref"
      ],
      "properties": {
        "argument_name": { "$ref": "#/$defs/non_empty_string" },
        "argument_kind": { "$ref": "#/$defs/non_empty_string" },
        "is_required": { "type": "boolean" },
        "narration_label_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "protected_command_discoverability_record": {
      "type": "object",
      "required": [
        "discoverability_record_id",
        "command_id",
        "command_revision_ref",
        "canonical_verb",
        "title",
        "summary",
        "lifecycle_state",
        "stable_line_required",
        "origin_class",
        "category_refs",
        "example_refs",
        "tag_refs",
        "searchability_axes",
        "promoted_alias_ids",
        "alias_records",
        "current_keybindings",
        "docs_help_anchor_ref",
        "accessibility",
        "shortcut_narration_hint",
        "typed_arguments",
        "capability_scope_class",
        "preview_class",
        "approval_posture_class",
        "ai_tool_surfacing_class",
        "automation_support",
        "disabled_reason_explanation_refs",
        "projection_refs",
        "surface_rows"
      ],
      "properties": {
        "discoverability_record_id": { "$ref": "#/$defs/non_empty_string" },
        "command_id": { "$ref": "#/$defs/non_empty_string" },
        "command_revision_ref": { "$ref": "#/$defs/non_empty_string" },
        "canonical_verb": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/non_empty_string" },
        "lifecycle_state": { "$ref": "#/$defs/non_empty_string" },
        "stable_line_required": { "type": "boolean" },
        "origin_class": { "$ref": "#/$defs/non_empty_string" },
        "origin_source_ref": { "$ref": "#/$defs/nullable_string" },
        "category_refs": { "$ref": "#/$defs/string_array" },
        "example_refs": { "$ref": "#/$defs/string_array" },
        "tag_refs": { "$ref": "#/$defs/string_array" },
        "searchability_axes": { "$ref": "#/$defs/string_array" },
        "promoted_alias_ids": { "$ref": "#/$defs/string_array" },
        "alias_records": {
          "type": "array",
          "items": { "$ref": "#/$defs/discoverability_alias_record" }
        },
        "current_keybindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/discoverability_current_keybinding_record" }
        },
        "replacement_command_id": { "$ref": "#/$defs/nullable_string" },
        "docs_help_anchor_ref": { "$ref": "#/$defs/non_empty_string" },
        "accessibility": { "$ref": "#/$defs/discoverability_accessibility_record" },
        "shortcut_narration_hint": {
          "type": "object",
          "required": [
            "when_bound_narration_ref",
            "when_unbound_narration_ref",
            "chord_class_hint"
          ],
          "properties": {
            "when_bound_narration_ref": { "$ref": "#/$defs/non_empty_string" },
            "when_unbound_narration_ref": { "$ref": "#/$defs/non_empty_string" },
            "chord_class_hint": { "$ref": "#/$defs/non_empty_string" }
          },
          "additionalProperties": false
        },
        "typed_arguments": {
          "type": "array",
          "items": { "$ref": "#/$defs/discoverability_typed_argument_record" }
        },
        "capability_scope_class": { "$ref": "#/$defs/non_empty_string" },
        "preview_class": { "$ref": "#/$defs/non_empty_string" },
        "approval_posture_class": { "$ref": "#/$defs/non_empty_string" },
        "ai_tool_surfacing_class": { "$ref": "#/$defs/non_empty_string" },
        "automation_support": {
          "type": "array",
          "items": { "$ref": "#/$defs/automation_support_class" }
        },
        "disabled_reason_explanation_refs": { "$ref": "#/$defs/string_array" },
        "projection_refs": { "$ref": "#/$defs/discoverability_projection_refs" },
        "surface_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/discoverability_surface_projection_row" }
        }
      },
      "additionalProperties": false
    },
    "query_session_policy_record": {
      "type": "object",
      "required": [
        "query_session_policy_id",
        "current_text_material_class",
        "provider_classes",
        "held_modifier_intent_class",
        "history_policy_class",
        "max_history_entries",
        "retention_policy_ref",
        "clear_controls",
        "disable_control_available",
        "sync_posture",
        "redaction_posture",
        "raw_query_export_allowed",
        "accessibility_disclosure_ref"
      ],
      "properties": {
        "query_session_policy_id": { "$ref": "#/$defs/non_empty_string" },
        "current_text_material_class": { "$ref": "#/$defs/query_session_text_material_class" },
        "provider_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/query_session_provider_class" }
        },
        "held_modifier_intent_class": { "$ref": "#/$defs/non_empty_string" },
        "history_policy_class": { "$ref": "#/$defs/history_policy_class" },
        "max_history_entries": { "type": "integer", "minimum": 0 },
        "retention_policy_ref": { "$ref": "#/$defs/non_empty_string" },
        "clear_controls": {
          "type": "array",
          "items": { "$ref": "#/$defs/clear_history_rule_class" }
        },
        "disable_control_available": { "type": "boolean" },
        "sync_posture": { "$ref": "#/$defs/query_session_sync_posture_class" },
        "redaction_posture": { "$ref": "#/$defs/redaction_posture_class" },
        "raw_query_export_allowed": { "type": "boolean" },
        "accessibility_disclosure_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
