{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/freeze_command_governance_contract.schema.json",
  "title": "Aureline command-governance contract packet",
  "$comment": "Rust owner: aureline_commands::freeze_command_governance_contract::CommandGovernanceContractPacket.",
  "description": "Boundary schema for the export-safe command-governance packet. The packet freezes the canonical descriptor-field vocabulary, invocation-session field vocabulary, result-packet field vocabulary, lifecycle-dependency vocabulary, downgrade rules, and per-feature-family surface matrix that determine whether a command family may keep Stable wording across desktop, CLI, AI, recipe, extension, and browser-companion routes. Rows carry refs, state tokens, and coarse governance posture only. They never carry raw arguments, prompts, provider payloads, credentials, URLs, or source bodies. Adding a new enum value or optional field is additive-minor; repurposing an existing value is breaking and bumps schema_version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "display_label",
    "policy_epoch_ref",
    "contract_refs",
    "descriptor_fields",
    "invocation_session_fields",
    "result_packet_fields",
    "lifecycle_dependency_vocabulary",
    "downgrade_rules",
    "feature_family_rows",
    "evidence_export",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "command_governance_contract_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "display_label": { "type": "string", "minLength": 1 },
    "policy_epoch_ref": { "type": "string", "minLength": 1 },
    "contract_refs": { "$ref": "#/$defs/governance_contract_refs" },
    "descriptor_fields": {
      "type": "array",
      "items": { "$ref": "#/$defs/descriptor_field_row" }
    },
    "invocation_session_fields": {
      "type": "array",
      "items": { "$ref": "#/$defs/invocation_session_field_row" }
    },
    "result_packet_fields": {
      "type": "array",
      "items": { "$ref": "#/$defs/result_packet_field_row" }
    },
    "lifecycle_dependency_vocabulary": {
      "type": "array",
      "items": { "$ref": "#/$defs/lifecycle_dependency_vocabulary_row" }
    },
    "downgrade_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/downgrade_rule_row" }
    },
    "feature_family_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/feature_family_governance_row" }
    },
    "evidence_export": { "$ref": "#/$defs/governance_evidence_export" },
    "source_contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "command_descriptor_field_class": {
      "type": "string",
      "enum": [
        "command_identity",
        "alias_deprecation_state",
        "capability_class",
        "preview_class",
        "automation_labels",
        "origin_metadata",
        "result_packet_references",
        "lifecycle_metadata"
      ]
    },
    "invocation_session_field_class": {
      "type": "string",
      "enum": [
        "issuing_surface",
        "argument_provenance",
        "context_snapshot",
        "enablement_decision",
        "execution_intent",
        "outcome",
        "artifacts",
        "timing_cost_bands"
      ]
    },
    "result_packet_field_class": {
      "type": "string",
      "enum": [
        "canonical_command_identity",
        "outcome_codes",
        "artifact_refs",
        "rollback_handle",
        "checkpoint_refs",
        "notification_activity_refs",
        "evidence_refs",
        "export_posture"
      ]
    },
    "lifecycle_dependency_class": {
      "type": "string",
      "enum": [
        "labs_dependency",
        "preview_dependency",
        "beta_dependency",
        "policy_gated_dependency",
        "underqualified_dependency"
      ]
    },
    "feature_family_class": {
      "type": "string",
      "enum": [
        "notebook",
        "data_api",
        "profiler",
        "docs_browser",
        "pipeline",
        "framework_pack",
        "companion",
        "sync",
        "incident",
        "infrastructure"
      ]
    },
    "command_governance_surface_class": {
      "type": "string",
      "enum": [
        "desktop",
        "cli",
        "ai",
        "recipe",
        "extension",
        "browser_companion"
      ]
    },
    "publication_consumer_surface_class": {
      "type": "string",
      "enum": ["help_about", "release", "support", "docs"]
    },
    "governance_claim_class": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "policy_blocked", "unsupported"]
    },
    "evidence_freshness_class": {
      "type": "string",
      "enum": ["current", "due_for_refresh", "stale", "missing"]
    },
    "downgrade_trigger_class": {
      "type": "string",
      "enum": [
        "descriptor_contract_missing",
        "invocation_session_contract_missing",
        "result_packet_contract_missing",
        "lifecycle_dependency_present",
        "stale_evidence",
        "missing_evidence",
        "authority_parity_broken",
        "preview_semantics_stale",
        "disabled_reason_vocabulary_missing"
      ]
    },
    "governance_contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "descriptor_contract_ref",
        "invocation_parity_contract_ref",
        "lifecycle_adr_ref",
        "disabled_reason_vocabulary_ref",
        "descriptor_schema_ref",
        "invocation_session_schema_ref",
        "result_packet_schema_ref",
        "claim_publication_manifest_ref",
        "capability_lifecycle_registry_ref"
      ],
      "properties": {
        "descriptor_contract_ref": { "type": "string", "minLength": 1 },
        "invocation_parity_contract_ref": { "type": "string", "minLength": 1 },
        "lifecycle_adr_ref": { "type": "string", "minLength": 1 },
        "disabled_reason_vocabulary_ref": { "type": "string", "minLength": 1 },
        "descriptor_schema_ref": { "type": "string", "minLength": 1 },
        "invocation_session_schema_ref": { "type": "string", "minLength": 1 },
        "result_packet_schema_ref": { "type": "string", "minLength": 1 },
        "claim_publication_manifest_ref": { "type": "string", "minLength": 1 },
        "capability_lifecycle_registry_ref": { "type": "string", "minLength": 1 }
      }
    },
    "descriptor_field_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_class", "field_label", "source_pointer", "exported"],
      "properties": {
        "field_class": { "$ref": "#/$defs/command_descriptor_field_class" },
        "field_label": { "type": "string", "minLength": 1 },
        "source_pointer": { "type": "string", "minLength": 1 },
        "exported": { "type": "boolean" }
      }
    },
    "invocation_session_field_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_class",
        "field_label",
        "source_pointer",
        "required_on_every_surface"
      ],
      "properties": {
        "field_class": { "$ref": "#/$defs/invocation_session_field_class" },
        "field_label": { "type": "string", "minLength": 1 },
        "source_pointer": { "type": "string", "minLength": 1 },
        "required_on_every_surface": { "type": "boolean" }
      }
    },
    "result_packet_field_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_class",
        "field_label",
        "source_pointer",
        "required_on_every_result"
      ],
      "properties": {
        "field_class": { "$ref": "#/$defs/result_packet_field_class" },
        "field_label": { "type": "string", "minLength": 1 },
        "source_pointer": { "type": "string", "minLength": 1 },
        "required_on_every_result": { "type": "boolean" }
      }
    },
    "lifecycle_dependency_vocabulary_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dependency_class",
        "disclosure_label",
        "source_pointer",
        "narrows_stable_claim"
      ],
      "properties": {
        "dependency_class": { "$ref": "#/$defs/lifecycle_dependency_class" },
        "disclosure_label": { "type": "string", "minLength": 1 },
        "source_pointer": { "type": "string", "minLength": 1 },
        "narrows_stable_claim": { "type": "boolean" }
      }
    },
    "downgrade_rule_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger",
        "narrowed_to",
        "consumer_surfaces",
        "stable_copy_forbidden",
        "summary"
      ],
      "properties": {
        "trigger": { "$ref": "#/$defs/downgrade_trigger_class" },
        "narrowed_to": { "$ref": "#/$defs/governance_claim_class" },
        "consumer_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/publication_consumer_surface_class" }
        },
        "stable_copy_forbidden": { "type": "boolean" },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "lifecycle_dependency_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "marker_ref",
        "dependency_class",
        "dependency_ref",
        "owner_ref",
        "disclosure_ref",
        "narrowing_required"
      ],
      "properties": {
        "marker_ref": { "type": "string", "minLength": 1 },
        "dependency_class": { "$ref": "#/$defs/lifecycle_dependency_class" },
        "dependency_ref": { "type": "string", "minLength": 1 },
        "owner_ref": { "type": "string", "minLength": 1 },
        "disclosure_ref": { "type": "string", "minLength": 1 },
        "narrowing_required": { "type": "boolean" }
      }
    },
    "surface_governance_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "claimed_stable",
        "effective_claim",
        "published_stable_copy_allowed",
        "descriptor_contract_current",
        "invocation_session_contract_current",
        "result_packet_contract_current",
        "lifecycle_dependency_disclosed",
        "dependency_marker_refs",
        "authority_parity_preserved",
        "preview_parity_preserved",
        "approval_parity_preserved",
        "disabled_reason_parity_preserved",
        "route_truth_disclosed",
        "evidence_freshness",
        "downgrade_reasons"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/command_governance_surface_class" },
        "claimed_stable": { "type": "boolean" },
        "effective_claim": { "$ref": "#/$defs/governance_claim_class" },
        "published_stable_copy_allowed": { "type": "boolean" },
        "descriptor_contract_current": { "type": "boolean" },
        "invocation_session_contract_current": { "type": "boolean" },
        "result_packet_contract_current": { "type": "boolean" },
        "lifecycle_dependency_disclosed": { "type": "boolean" },
        "dependency_marker_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "authority_parity_preserved": { "type": "boolean" },
        "preview_parity_preserved": { "type": "boolean" },
        "approval_parity_preserved": { "type": "boolean" },
        "disabled_reason_parity_preserved": { "type": "boolean" },
        "route_truth_disclosed": { "type": "boolean" },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness_class" },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_trigger_class" }
        }
      }
    },
    "feature_family_governance_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_class",
        "display_label",
        "claimed_stable",
        "effective_claim",
        "published_stable_copy_allowed",
        "descriptor_proof_ref",
        "descriptor_contract_current",
        "invocation_session_proof_ref",
        "invocation_session_contract_current",
        "result_packet_proof_ref",
        "result_packet_contract_current",
        "disabled_reason_vocabulary_current",
        "preview_semantics_current",
        "rollout_owner_ref",
        "evidence_packet_ref",
        "evidence_freshness",
        "lifecycle_dependencies",
        "downgrade_reasons",
        "surface_rows"
      ],
      "properties": {
        "family_class": { "$ref": "#/$defs/feature_family_class" },
        "display_label": { "type": "string", "minLength": 1 },
        "claimed_stable": { "type": "boolean" },
        "effective_claim": { "$ref": "#/$defs/governance_claim_class" },
        "published_stable_copy_allowed": { "type": "boolean" },
        "descriptor_proof_ref": { "type": "string", "minLength": 1 },
        "descriptor_contract_current": { "type": "boolean" },
        "invocation_session_proof_ref": { "type": "string", "minLength": 1 },
        "invocation_session_contract_current": { "type": "boolean" },
        "result_packet_proof_ref": { "type": "string", "minLength": 1 },
        "result_packet_contract_current": { "type": "boolean" },
        "disabled_reason_vocabulary_current": { "type": "boolean" },
        "preview_semantics_current": { "type": "boolean" },
        "rollout_owner_ref": { "type": "string", "minLength": 1 },
        "evidence_packet_ref": { "type": "string", "minLength": 1 },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness_class" },
        "lifecycle_dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_dependency_row" }
        },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_trigger_class" }
        },
        "surface_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_governance_row" }
        }
      }
    },
    "governance_evidence_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "json_export_ref",
        "markdown_summary_ref",
        "help_projection_ref",
        "release_projection_ref",
        "support_projection_ref"
      ],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "json_export_ref": { "type": "string", "minLength": 1 },
        "markdown_summary_ref": { "type": "string", "minLength": 1 },
        "help_projection_ref": { "type": "string", "minLength": 1 },
        "release_projection_ref": { "type": "string", "minLength": 1 },
        "support_projection_ref": { "type": "string", "minLength": 1 }
      }
    }
  }
}
