{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/m5_rollout_inventory.schema.json",
  "title": "M5 rollout inventory packet",
  "description": "Boundary schema for the canonical M5 rollout inventory packet. The packet binds owner, rollout ring, cohort, review or expiry date, declared and effective lifecycle state, promotion posture, kill-switch paths, affected capability families, and stable-facing disclosure coverage for the optional M5 command lanes. It carries refs and copy-safe labels only and never embeds raw credentials, raw provider payloads, or user content.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "schema_ref",
    "doc_ref",
    "rows",
    "summary"
  ],
  "properties": {
    "record_kind": { "const": "m5_rollout_inventory_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty" },
    "generated_at": { "type": "string", "format": "date-time" },
    "schema_ref": { "$ref": "#/$defs/non_empty" },
    "doc_ref": { "$ref": "#/$defs/non_empty" },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/inventory_row" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty": {
      "type": "string",
      "minLength": 1
    },
    "rollout_state_class": {
      "type": "string",
      "enum": [
        "labs",
        "preview",
        "beta",
        "stable",
        "deprecated",
        "disabled_by_policy",
        "retest_pending",
        "removed"
      ]
    },
    "promotion_state_class": {
      "type": "string",
      "enum": [
        "labs_opt_in",
        "preview_named_cohort",
        "beta_design_partner",
        "beta_broad",
        "stable_broad",
        "retest_required",
        "blocked_by_policy",
        "sunset_only"
      ]
    },
    "kill_switch_source_class": {
      "type": "string",
      "enum": [
        "emergency_security_response",
        "admin_policy_ceiling",
        "release_channel_or_rollout_override",
        "cohort_or_ring_assignment",
        "user_opt_in_or_local_preview_toggle"
      ]
    },
    "consumer_surface_class": {
      "type": "string",
      "enum": [
        "settings_inspector",
        "help_about",
        "diagnostics",
        "support_export",
        "docs_release"
      ]
    },
    "kill_switch_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "source_ref",
        "active",
        "reason",
        "preserve_user_data",
        "preserved_data_scope",
        "fallback_path"
      ],
      "properties": {
        "source_class": { "$ref": "#/$defs/kill_switch_source_class" },
        "source_ref": { "$ref": "#/$defs/non_empty" },
        "active": { "type": "boolean" },
        "reason": { "$ref": "#/$defs/non_empty" },
        "preserve_user_data": { "type": "boolean" },
        "preserved_data_scope": { "$ref": "#/$defs/non_empty" },
        "fallback_path": { "$ref": "#/$defs/non_empty" }
      }
    },
    "surface_disclosure_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "surface_ref",
        "behavior_change_visible"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/consumer_surface_class" },
        "surface_ref": { "$ref": "#/$defs/non_empty" },
        "behavior_change_visible": { "type": "boolean" }
      }
    },
    "inventory_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "capability_id",
        "display_label",
        "owner_ref",
        "rollout_ring",
        "cohort",
        "review_or_expiry_date",
        "declared_state_class",
        "effective_state_class",
        "promotion_state",
        "rollout_state_ref",
        "stable_claim_allowed",
        "no_hidden_flag_rule_satisfied",
        "affected_capability_ids",
        "kill_switches",
        "surfaced_in",
        "rationale"
      ],
      "properties": {
        "command_id": { "$ref": "#/$defs/non_empty" },
        "capability_id": { "$ref": "#/$defs/non_empty" },
        "display_label": { "$ref": "#/$defs/non_empty" },
        "owner_ref": { "$ref": "#/$defs/non_empty" },
        "rollout_ring": { "$ref": "#/$defs/non_empty" },
        "cohort": { "$ref": "#/$defs/non_empty" },
        "review_or_expiry_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "declared_state_class": { "$ref": "#/$defs/rollout_state_class" },
        "effective_state_class": { "$ref": "#/$defs/rollout_state_class" },
        "promotion_state": { "$ref": "#/$defs/promotion_state_class" },
        "rollout_state_ref": { "$ref": "#/$defs/non_empty" },
        "stable_claim_allowed": { "type": "boolean" },
        "no_hidden_flag_rule_satisfied": { "type": "boolean" },
        "affected_capability_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty" }
        },
        "kill_switches": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/kill_switch_record" }
        },
        "surfaced_in": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/surface_disclosure_record" }
        },
        "rationale": { "$ref": "#/$defs/non_empty" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_count",
        "labs_row_count",
        "preview_row_count",
        "beta_row_count",
        "stable_row_count",
        "deprecated_row_count",
        "disabled_by_policy_row_count",
        "retest_pending_row_count",
        "removed_row_count",
        "active_kill_switch_row_count",
        "narrowed_row_count",
        "stable_claim_allowed_row_count",
        "no_hidden_flag_row_count"
      ],
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "labs_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "deprecated_row_count": { "type": "integer", "minimum": 0 },
        "disabled_by_policy_row_count": { "type": "integer", "minimum": 0 },
        "retest_pending_row_count": { "type": "integer", "minimum": 0 },
        "removed_row_count": { "type": "integer", "minimum": 0 },
        "active_kill_switch_row_count": { "type": "integer", "minimum": 0 },
        "narrowed_row_count": { "type": "integer", "minimum": 0 },
        "stable_claim_allowed_row_count": { "type": "integer", "minimum": 0 },
        "no_hidden_flag_row_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
