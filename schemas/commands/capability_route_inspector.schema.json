{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schemas/commands/capability_route_inspector.schema.json",
  "title": "CapabilityRouteInspectorPacket",
  "description": "Export-safe capability-route inspector publication record across deep links, approvals, tunnels, remote targets, provider handoffs, and replay-safe command flows.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "command_family_id",
    "display_label",
    "claimed_stable",
    "policy_epoch_ref",
    "contract_refs",
    "capability_route_inspector",
    "flow_records",
    "reapproval_policy",
    "lineage_preservation",
    "keyboard_reachability",
    "surface_rows",
    "evidence_export",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "capability_route_inspector_packet"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "command_family_id": {
      "type": "string",
      "minLength": 1
    },
    "display_label": {
      "type": "string",
      "minLength": 1
    },
    "claimed_stable": {
      "type": "boolean"
    },
    "policy_epoch_ref": {
      "type": "string",
      "minLength": 1
    },
    "contract_refs": {
      "$ref": "#/definitions/StableContractRefs"
    },
    "capability_route_inspector": {
      "$ref": "#/definitions/CapabilityRouteInspector"
    },
    "flow_records": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/FlowPublicationRecord"
      }
    },
    "reapproval_policy": {
      "$ref": "#/definitions/ReapprovalPolicyRecord"
    },
    "lineage_preservation": {
      "$ref": "#/definitions/LineagePreservationRecord"
    },
    "keyboard_reachability": {
      "$ref": "#/definitions/KeyboardReachabilityRecord"
    },
    "surface_rows": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/PublicationSurfaceRow"
      }
    },
    "evidence_export": {
      "$ref": "#/definitions/CommandContractEvidenceExport"
    },
    "source_contract_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "redaction_class_token": {
      "type": "string",
      "minLength": 1
    },
    "minted_at": {
      "type": "string",
      "minLength": 1
    }
  },
  "definitions": {
    "StableContractRefs": {
      "type": "object",
      "required": [
        "descriptor_schema_ref",
        "registry_entry_schema_ref",
        "registry_seed_ref",
        "invocation_session_schema_ref",
        "result_packet_schema_ref",
        "public_contract_schema_ref",
        "parity_expectation_schema_ref",
        "disabled_reason_vocabulary_ref"
      ],
      "properties": {
        "descriptor_schema_ref": { "type": "string" },
        "registry_entry_schema_ref": { "type": "string" },
        "registry_seed_ref": { "type": "string" },
        "invocation_session_schema_ref": { "type": "string" },
        "result_packet_schema_ref": { "type": "string" },
        "public_contract_schema_ref": { "type": "string" },
        "parity_expectation_schema_ref": { "type": "string" },
        "disabled_reason_vocabulary_ref": { "type": "string" }
      }
    },
    "CapabilityRouteInspector": {
      "type": "object",
      "required": [
        "inspector_id",
        "client_origin",
        "target_context",
        "route_class",
        "capability_boundary",
        "target_identity_ref",
        "approval_scope_ref",
        "policy_epoch_ref",
        "expiry_token",
        "approval_owner_label",
        "revalidation_triggers",
        "drift_forces_reapproval",
        "reachable_without_debug_toggle",
        "spend_posture_token",
        "approval_disclosure_ref"
      ],
      "properties": {
        "inspector_id": { "type": "string", "minLength": 1 },
        "client_origin": {
          "type": "string",
          "enum": [
            "local_ui",
            "cli_headless",
            "deep_link",
            "browser_companion",
            "ai_tool_call",
            "recipe_automation",
            "tunnel_endpoint",
            "provider_action"
          ]
        },
        "target_context": {
          "type": "string",
          "enum": [
            "local_workspace",
            "remote_workspace",
            "managed_provider",
            "external_provider",
            "tunnel_exposed_endpoint",
            "browser_handoff"
          ]
        },
        "route_class": {
          "type": "string",
          "enum": [
            "local",
            "browser_handoff",
            "managed",
            "enterprise_gateway",
            "tunnel_forwarded",
            "provider_action_callback",
            "byok"
          ]
        },
        "capability_boundary": {
          "type": "string",
          "enum": [
            "local_device",
            "user_account",
            "org_enterprise",
            "managed_policy",
            "external_provider",
            "browser_companion",
            "tunnel_boundary"
          ]
        },
        "target_identity_ref": { "type": "string", "minLength": 1 },
        "approval_scope_ref": { "type": "string", "minLength": 1 },
        "policy_epoch_ref": { "type": "string", "minLength": 1 },
        "expiry_token": { "type": "string", "minLength": 1 },
        "approval_owner_label": { "type": "string", "minLength": 1 },
        "revalidation_triggers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "approval_epoch_drift",
              "route_or_provider_drift",
              "target_identity_drift",
              "capability_boundary_drift",
              "policy_epoch_advanced",
              "approval_expired",
              "explicit_revalidation_requested"
            ]
          }
        },
        "drift_forces_reapproval": { "type": "boolean" },
        "reachable_without_debug_toggle": { "type": "boolean" },
        "spend_posture_token": { "type": "string", "minLength": 1 },
        "approval_disclosure_ref": { "type": "string", "minLength": 1 }
      }
    },
    "FlowPublicationRecord": {
      "type": "object",
      "required": [
        "flow_class",
        "inspector_reachable",
        "discloses_route_class",
        "discloses_target_identity",
        "discloses_capability_boundary",
        "discloses_approval_scope_and_expiry",
        "discloses_revalidation_triggers",
        "lineage_preserved",
        "drift_forces_reapproval",
        "no_authority_widening",
        "reversible_when_external",
        "policy_checked"
      ],
      "properties": {
        "flow_class": {
          "type": "string",
          "enum": [
            "deep_link",
            "approval",
            "tunnel",
            "remote_target",
            "provider_handoff",
            "replay_safe_command"
          ]
        },
        "inspector_reachable": { "type": "boolean" },
        "discloses_route_class": { "type": "boolean" },
        "discloses_target_identity": { "type": "boolean" },
        "discloses_capability_boundary": { "type": "boolean" },
        "discloses_approval_scope_and_expiry": { "type": "boolean" },
        "discloses_revalidation_triggers": { "type": "boolean" },
        "lineage_preserved": { "type": "boolean" },
        "drift_forces_reapproval": { "type": "boolean" },
        "no_authority_widening": { "type": "boolean" },
        "reversible_when_external": { "type": "boolean" },
        "policy_checked": { "type": "boolean" }
      }
    },
    "ReapprovalPolicyRecord": {
      "type": "object",
      "required": [
        "required",
        "drift_classes",
        "route_drift_forces_reapproval",
        "target_drift_forces_reapproval",
        "policy_drift_forces_reapproval",
        "host_drift_forces_reapproval",
        "approval_expiry_forces_reapproval",
        "no_silent_replay_on_drift",
        "replay_review_surfaced"
      ],
      "properties": {
        "required": { "type": "boolean" },
        "drift_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "route_drift",
              "target_drift",
              "policy_drift",
              "host_drift",
              "approval_expiry"
            ]
          }
        },
        "route_drift_forces_reapproval": { "type": "boolean" },
        "target_drift_forces_reapproval": { "type": "boolean" },
        "policy_drift_forces_reapproval": { "type": "boolean" },
        "host_drift_forces_reapproval": { "type": "boolean" },
        "approval_expiry_forces_reapproval": { "type": "boolean" },
        "no_silent_replay_on_drift": { "type": "boolean" },
        "replay_review_surfaced": { "type": "boolean" }
      }
    },
    "LineagePreservationRecord": {
      "type": "object",
      "required": [
        "single_object_through_lifecycle",
        "preserved_in_preview",
        "preserved_in_execution",
        "preserved_in_audit",
        "preserved_in_support_export",
        "preserved_in_shiproom_proof",
        "no_private_team_reconstruction",
        "lineage_ref"
      ],
      "properties": {
        "single_object_through_lifecycle": { "type": "boolean" },
        "preserved_in_preview": { "type": "boolean" },
        "preserved_in_execution": { "type": "boolean" },
        "preserved_in_audit": { "type": "boolean" },
        "preserved_in_support_export": { "type": "boolean" },
        "preserved_in_shiproom_proof": { "type": "boolean" },
        "no_private_team_reconstruction": { "type": "boolean" },
        "lineage_ref": { "type": "string", "minLength": 1 }
      }
    },
    "KeyboardReachabilityRecord": {
      "type": "object",
      "required": [
        "keyboard_reachable",
        "reachable_from_review_sheet",
        "reachable_from_command_preview",
        "reachable_from_diagnostic_surface",
        "reachable_from_support_surface",
        "keyboard_shortcut_ref"
      ],
      "properties": {
        "keyboard_reachable": { "type": "boolean" },
        "reachable_from_review_sheet": { "type": "boolean" },
        "reachable_from_command_preview": { "type": "boolean" },
        "reachable_from_diagnostic_surface": { "type": "boolean" },
        "reachable_from_support_surface": { "type": "boolean" },
        "keyboard_shortcut_ref": { "type": "string", "minLength": 1 }
      }
    },
    "PublicationSurfaceRow": {
      "type": "object",
      "required": [
        "surface_class",
        "inspector_published",
        "discloses_route_class",
        "discloses_target_identity",
        "discloses_capability_boundary",
        "discloses_approval_scope_and_expiry",
        "discloses_revalidation_triggers",
        "policy_checked",
        "no_capability_widening",
        "qualification",
        "claimed_stable"
      ],
      "properties": {
        "surface_class": {
          "type": "string",
          "enum": [
            "menu_or_button",
            "keybinding",
            "command_palette",
            "cli_headless",
            "ai_tool",
            "voice",
            "recipe",
            "deep_link",
            "browser_companion"
          ]
        },
        "inspector_published": { "type": "boolean" },
        "discloses_route_class": { "type": "boolean" },
        "discloses_target_identity": { "type": "boolean" },
        "discloses_capability_boundary": { "type": "boolean" },
        "discloses_approval_scope_and_expiry": { "type": "boolean" },
        "discloses_revalidation_triggers": { "type": "boolean" },
        "policy_checked": { "type": "boolean" },
        "no_capability_widening": { "type": "boolean" },
        "qualification": {
          "type": "string",
          "enum": [
            "stable",
            "beta",
            "alpha",
            "not_applicable"
          ]
        },
        "claimed_stable": { "type": "boolean" }
      }
    },
    "CommandContractEvidenceExport": {
      "type": "object",
      "required": [
        "evidence_id",
        "json_export_ref",
        "markdown_summary_ref",
        "admin_inspector_ref",
        "support_export_ref",
        "rollback_lineage_refs",
        "export_lineage_refs"
      ],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "json_export_ref": { "type": "string", "minLength": 1 },
        "markdown_summary_ref": { "type": "string", "minLength": 1 },
        "admin_inspector_ref": { "type": "string", "minLength": 1 },
        "support_export_ref": { "type": "string", "minLength": 1 },
        "rollback_lineage_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "export_lineage_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
