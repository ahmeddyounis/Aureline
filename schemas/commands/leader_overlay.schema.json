{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/leader_overlay.schema.json",
  "title": "Aureline modal sequence help and leader overlay contract",
  "description": "Boundary schema for modal state cues, sequence-help rows, leader-overlay rows, shortcut-teaching rows, and command-language parity rows. These records make modal editing, leader sequences, operator-pending sequences, and colon-style command entry inspectable projections of the canonical command graph rather than separate command systems. See docs/commands/sequence_and_modal_discoverability_contract.md.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/modal_state_cue_record" },
    { "$ref": "#/$defs/sequence_help_row_record" },
    { "$ref": "#/$defs/leader_overlay_row_record" },
    { "$ref": "#/$defs/shortcut_teaching_row_record" },
    { "$ref": "#/$defs/command_language_parity_row_record" }
  ],
  "$defs": {
    "leader_overlay_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this modal and sequence discoverability boundary."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "modal_state_cue_record",
        "sequence_help_row_record",
        "leader_overlay_row_record",
        "shortcut_teaching_row_record",
        "command_language_parity_row_record"
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe for logs, support export, docs/help pivots, and cross-surface handoff."
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "redaction_aware_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Short human-readable text whose producer must apply the active redaction policy before export."
    },
    "monotonic_timestamp": {
      "$ref": "command_descriptor.schema.json#/$defs/monotonic_timestamp"
    },
    "policy_context": {
      "$ref": "command_descriptor.schema.json#/$defs/policy_context"
    },
    "redaction_class": {
      "$ref": "command_descriptor.schema.json#/$defs/redaction_class"
    },
    "docs_help_anchor_ref": {
      "$ref": "command_descriptor.schema.json#/$defs/docs_help_anchor_ref"
    },
    "disabled_reason_code": {
      "$ref": "command_descriptor.schema.json#/$defs/disabled_reason_code"
    },
    "repair_hook_ref": {
      "$ref": "command_descriptor.schema.json#/$defs/repair_hook_ref"
    },
    "preview_class": {
      "$ref": "command_descriptor.schema.json#/$defs/preview_class"
    },
    "approval_posture_class": {
      "$ref": "command_descriptor.schema.json#/$defs/approval_posture_class"
    },
    "capability_scope_class": {
      "$ref": "command_descriptor.schema.json#/$defs/capability_scope_class"
    },
    "canonical_verb": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
    },
    "resolver_layer_class": {
      "type": "string",
      "enum": [
        "platform_reserved",
        "emergency_security_hard_block",
        "admin_policy_lock",
        "temporary_mode_overlay",
        "user_profile_binding",
        "workspace_recommendation",
        "extension_binding",
        "core_default"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "core",
        "built_in_extension",
        "third_party_extension",
        "imported_bridge",
        "workspace_override",
        "policy_provided",
        "user_profile",
        "labs"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "source_editor",
        "diff_editor",
        "commit_message",
        "request_editor",
        "query_editor",
        "notebook_code_cell",
        "terminal",
        "rendered_docs",
        "webview",
        "property_grid",
        "command_palette",
        "settings",
        "migration_review",
        "support_export"
      ]
    },
    "surface_support_class": {
      "type": "string",
      "enum": [
        "fully_supported",
        "leader_limited",
        "operator_limited",
        "modeless_only",
        "unsupported_here",
        "blocked_by_policy"
      ]
    },
    "mode_class": {
      "type": "string",
      "enum": [
        "normal",
        "insert",
        "visual",
        "replace",
        "select",
        "command",
        "terminal_passthrough",
        "modeless",
        "unsupported"
      ]
    },
    "mode_source_class": {
      "type": "string",
      "enum": [
        "core_profile",
        "product_native_profile",
        "imported_bridge",
        "extension_profile",
        "workspace_override",
        "policy_narrowed"
      ]
    },
    "mode_visibility_cue_class": {
      "type": "string",
      "enum": [
        "text_label",
        "icon_shape",
        "screen_reader_announcement",
        "status_bar_segment",
        "mode_strip_label",
        "focus_region_label",
        "color_token"
      ]
    },
    "non_color_mode_cue_class": {
      "type": "string",
      "enum": [
        "text_label",
        "icon_shape",
        "screen_reader_announcement",
        "status_bar_segment",
        "mode_strip_label",
        "focus_region_label"
      ]
    },
    "sequence_shape_class": {
      "type": "string",
      "enum": [
        "single_stroke",
        "multi_stroke_chord",
        "leader_sequence",
        "operator_pending_sequence",
        "colon_command_entry"
      ]
    },
    "typed_key_kind": {
      "type": "string",
      "enum": [
        "leader_key",
        "literal_key",
        "modifier_chord",
        "operator",
        "count_digit",
        "motion",
        "text_object",
        "colon_command",
        "command_argument_marker"
      ]
    },
    "sequence_resolution_state": {
      "type": "string",
      "enum": [
        "ready",
        "partial_waiting",
        "ambiguous_waiting",
        "conflict_requires_review",
        "disabled_command",
        "blocked_by_policy",
        "blocked_by_host",
        "unsupported_surface",
        "timed_out",
        "cancelled",
        "resolved"
      ]
    },
    "next_key_availability_state": {
      "type": "string",
      "enum": [
        "available",
        "waiting_prefix",
        "ambiguous",
        "conflict",
        "disabled_command",
        "blocked_by_policy",
        "blocked_by_host",
        "unsupported_on_surface",
        "shadowed"
      ]
    },
    "next_key_result_kind": {
      "type": "string",
      "enum": [
        "command",
        "sequence_group",
        "conflict",
        "disabled_command",
        "unsupported_explanation",
        "unbound"
      ]
    },
    "timeout_outcome_class": {
      "type": "string",
      "enum": [
        "cancel_sequence",
        "resolve_exact_prefix_if_available",
        "keep_help_open_until_explicit_cancel",
        "open_conflict_review"
      ]
    },
    "pivot_action_class": {
      "type": "string",
      "enum": [
        "open_command_palette",
        "open_keybinding_settings",
        "open_command_docs",
        "open_migration_guidance",
        "open_conflict_review",
        "open_sequence_help",
        "copy_command_id",
        "reset_mode",
        "retry_on_supported_surface",
        "dismiss_overlay"
      ]
    },
    "register_class": {
      "type": "string",
      "enum": [
        "unnamed",
        "named",
        "system_clipboard",
        "remote_clipboard_bridge",
        "search_register",
        "macro_register",
        "blackhole",
        "policy_blocked"
      ]
    },
    "register_route_class": {
      "type": "string",
      "enum": [
        "local_profile_register",
        "system_clipboard",
        "remote_workspace_bridge",
        "search_state",
        "macro_storage",
        "discarded",
        "blocked_by_policy"
      ]
    },
    "macro_state_class": {
      "type": "string",
      "enum": [
        "none",
        "recording",
        "replaying",
        "replay_waiting_for_review",
        "blocked"
      ]
    },
    "macro_replay_scope_class": {
      "type": "string",
      "enum": [
        "editor_local_only",
        "cross_file",
        "cross_surface",
        "runs_commands",
        "external_side_effects"
      ]
    },
    "shortcut_display_state": {
      "type": "string",
      "enum": [
        "assigned",
        "unassigned",
        "conflict_requires_review",
        "platform_reserved",
        "shadowed",
        "policy_blocked",
        "unsupported_surface"
      ]
    },
    "frequency_bucket": {
      "type": "string",
      "enum": [
        "daily_driver",
        "high_frequency",
        "standard",
        "rare"
      ]
    },
    "binding_winner_state": {
      "type": "string",
      "enum": [
        "active_winner",
        "lost_shadowed",
        "blocked_higher_layer",
        "requires_review"
      ]
    },
    "parity_surface_class": {
      "type": "string",
      "enum": [
        "command_palette",
        "leader_overlay",
        "sequence_help",
        "modal_sequence",
        "colon_command_entry",
        "docs_help",
        "settings",
        "migration_guidance",
        "automation_recipe",
        "cli_help"
      ]
    },
    "mode_visibility_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "visible_cues",
        "non_color_cues",
        "screen_reader_announcement_ref"
      ],
      "properties": {
        "visible_cues": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/mode_visibility_cue_class" }
        },
        "non_color_cues": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/non_color_mode_cue_class" }
        },
        "color_token_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "screen_reader_announcement_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "typed_key": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "kind"
      ],
      "properties": {
        "key": { "$ref": "#/$defs/non_empty_string" },
        "kind": { "$ref": "#/$defs/typed_key_kind" },
        "display_label_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "typed_sequence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "literal_sequence",
        "shape_class",
        "typed_keys_so_far",
        "stroke_count"
      ],
      "properties": {
        "literal_sequence": { "$ref": "#/$defs/non_empty_string" },
        "shape_class": { "$ref": "#/$defs/sequence_shape_class" },
        "typed_keys_so_far": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/typed_key" }
        },
        "stroke_count": {
          "type": "integer",
          "minimum": 1
        },
        "leader_key_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "current_mode_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode_class",
        "mode_label",
        "mode_label_ref",
        "mode_source_class",
        "mode_visibility"
      ],
      "properties": {
        "mode_class": { "$ref": "#/$defs/mode_class" },
        "mode_label": { "$ref": "#/$defs/non_empty_string" },
        "mode_label_ref": { "$ref": "#/$defs/opaque_id" },
        "mode_source_class": { "$ref": "#/$defs/mode_source_class" },
        "source_profile_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "mode_visibility": { "$ref": "#/$defs/mode_visibility_contract" }
      }
    },
    "pending_operator_cue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator_key",
        "operator_label",
        "waiting_for"
      ],
      "properties": {
        "operator_key": { "$ref": "#/$defs/non_empty_string" },
        "operator_label": { "$ref": "#/$defs/non_empty_string" },
        "count_prefix": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 1 }
          ]
        },
        "waiting_for": { "$ref": "#/$defs/non_empty_string" },
        "resulting_command_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "scope_preview_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "count_cue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "literal_count",
        "applies_to"
      ],
      "properties": {
        "literal_count": {
          "type": "integer",
          "minimum": 1
        },
        "applies_to": { "$ref": "#/$defs/non_empty_string" },
        "display_label_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "macro_recording_cue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "macro_state",
        "register_ref",
        "visible_label",
        "replay_scope_class",
        "review_required"
      ],
      "properties": {
        "macro_state": { "$ref": "#/$defs/macro_state_class" },
        "register_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "visible_label": { "$ref": "#/$defs/non_empty_string" },
        "replay_scope_class": { "$ref": "#/$defs/macro_replay_scope_class" },
        "review_required": { "type": "boolean" }
      }
    },
    "register_boundary_cue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_register_ref",
        "register_class",
        "route_class",
        "visible_label",
        "preview_redaction_class"
      ],
      "properties": {
        "active_register_ref": { "$ref": "#/$defs/opaque_id" },
        "register_class": { "$ref": "#/$defs/register_class" },
        "route_class": { "$ref": "#/$defs/register_route_class" },
        "visible_label": { "$ref": "#/$defs/non_empty_string" },
        "preview_redaction_class": { "$ref": "#/$defs/redaction_class" },
        "policy_lock_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "leader_sequence_cue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_prefix",
        "sequence_state"
      ],
      "properties": {
        "active_prefix": { "$ref": "#/$defs/typed_sequence" },
        "sequence_state": { "$ref": "#/$defs/sequence_resolution_state" },
        "overlay_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "modal_state_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_mode",
        "surface_class",
        "surface_support_class",
        "pending_operator",
        "count_prefix",
        "macro_recording",
        "register_boundary",
        "leader_sequence"
      ],
      "properties": {
        "current_mode": { "$ref": "#/$defs/current_mode_context" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "surface_support_class": { "$ref": "#/$defs/surface_support_class" },
        "pending_operator": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/pending_operator_cue" }
          ]
        },
        "count_prefix": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/count_cue" }
          ]
        },
        "macro_recording": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/macro_recording_cue" }
          ]
        },
        "register_boundary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/register_boundary_cue" }
          ]
        },
        "leader_sequence": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/leader_sequence_cue" }
          ]
        },
        "support_note": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/redaction_aware_text" }
          ]
        }
      }
    },
    "command_identity_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "command_revision_ref",
        "command_label",
        "canonical_verb",
        "preview_class",
        "approval_posture_class",
        "capability_scope_class"
      ],
      "properties": {
        "command_id": { "$ref": "#/$defs/opaque_id" },
        "command_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "command_label": { "$ref": "#/$defs/non_empty_string" },
        "canonical_verb": { "$ref": "#/$defs/canonical_verb" },
        "preview_class": { "$ref": "#/$defs/preview_class" },
        "approval_posture_class": { "$ref": "#/$defs/approval_posture_class" },
        "capability_scope_class": { "$ref": "#/$defs/capability_scope_class" },
        "docs_help_anchor_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/docs_help_anchor_ref" }
          ]
        }
      }
    },
    "available_next_key": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "key_kind",
        "group_label",
        "availability_state",
        "result_kind",
        "resulting_command",
        "resolver_layer",
        "source_class",
        "scope_ref"
      ],
      "properties": {
        "key": { "$ref": "#/$defs/non_empty_string" },
        "key_kind": { "$ref": "#/$defs/typed_key_kind" },
        "group_label": { "$ref": "#/$defs/non_empty_string" },
        "availability_state": { "$ref": "#/$defs/next_key_availability_state" },
        "result_kind": { "$ref": "#/$defs/next_key_result_kind" },
        "resulting_command": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/command_identity_projection" }
          ]
        },
        "resolver_layer": { "$ref": "#/$defs/resolver_layer_class" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "scope_ref": { "$ref": "#/$defs/opaque_id" },
        "disabled_reason_code": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/disabled_reason_code" }
          ]
        },
        "conflict_review_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "summary_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "result_kind": {
                "enum": [
                  "command",
                  "conflict",
                  "disabled_command"
                ]
              }
            },
            "required": ["result_kind"]
          },
          "then": {
            "properties": {
              "resulting_command": { "$ref": "#/$defs/command_identity_projection" }
            }
          }
        }
      ]
    },
    "timeout_or_cancel_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timeout_ms",
        "cancel_gesture",
        "on_timeout_outcome",
        "hint_label"
      ],
      "properties": {
        "timeout_ms": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 0 }
          ]
        },
        "cancel_gesture": { "$ref": "#/$defs/non_empty_string" },
        "on_timeout_outcome": { "$ref": "#/$defs/timeout_outcome_class" },
        "hint_label": { "$ref": "#/$defs/non_empty_string" },
        "timeout_explanation_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "pivot_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_class",
        "label",
        "target_ref",
        "preserves_context"
      ],
      "properties": {
        "action_class": { "$ref": "#/$defs/pivot_action_class" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "target_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "preserves_context": { "type": "boolean" }
      }
    },
    "current_shortcut_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_state",
        "literal_sequence",
        "resolver_layer",
        "source_class",
        "scope_ref"
      ],
      "properties": {
        "display_state": { "$ref": "#/$defs/shortcut_display_state" },
        "literal_sequence": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/non_empty_string" }
          ]
        },
        "resolver_layer": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/resolver_layer_class" }
          ]
        },
        "source_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/source_class" }
          ]
        },
        "scope_ref": { "$ref": "#/$defs/opaque_id" },
        "narration_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "binding_conflict_party": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "scope_ref",
        "resolver_layer",
        "source_class",
        "winner_state"
      ],
      "properties": {
        "command": { "$ref": "#/$defs/command_identity_projection" },
        "scope_ref": { "$ref": "#/$defs/opaque_id" },
        "resolver_layer": { "$ref": "#/$defs/resolver_layer_class" },
        "source_class": { "$ref": "#/$defs/source_class" },
