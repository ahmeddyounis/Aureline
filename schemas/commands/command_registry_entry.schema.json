{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/command_registry_entry.schema.json",
  "title": "Aureline canonical command-registry entry and seed manifest",
  "description": "Boundary schema for the seeded canonical command registry. Each registry entry embeds the frozen command_descriptor_record from schemas/commands/command_descriptor.schema.json and adds the discoverability, alias-lifecycle, keybinding, badge, diagnostic, and machine-name metadata that palette, help search, onboarding, migration bridges, keybinding help, and diagnostics surfaces must share. The seed manifest freezes reserved namespace rules, alias and deprecation rules, and the required discoverability projection refs so command parity survives label churn, keymap import, and CLI or automation aliasing without inventing per-surface copies.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/command_registry_entry_record" },
    { "$ref": "#/$defs/command_registry_seed_record" }
  ],
  "$defs": {
    "command_registry_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "command_registry_entry_record",
        "command_registry_seed_record"
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "$ref": "command_descriptor.schema.json#/$defs/monotonic_timestamp"
    },
    "policy_context": {
      "$ref": "command_descriptor.schema.json#/$defs/policy_context"
    },
    "redaction_class": {
      "$ref": "command_descriptor.schema.json#/$defs/redaction_class"
    },
    "repair_hook_ref": {
      "$ref": "command_descriptor.schema.json#/$defs/repair_hook_ref"
    },
    "enablement_decision_class": {
      "$ref": "command_descriptor.schema.json#/$defs/enablement_decision_class"
    },
    "disabled_reason_code": {
      "$ref": "command_descriptor.schema.json#/$defs/disabled_reason_code"
    },
    "issuing_surface": {
      "$ref": "command_descriptor.schema.json#/$defs/issuing_surface"
    },
    "ui_slot_class": {
      "$ref": "command_descriptor.schema.json#/$defs/ui_slot_class"
    },
    "lifecycle_state": {
      "$ref": "command_descriptor.schema.json#/$defs/lifecycle_state"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "namespace_class": {
      "type": "string",
      "enum": [
        "core",
        "built_in_extension",
        "imported_bridge",
        "labs"
      ]
    },
    "registry_alias_kind": {
      "type": "string",
      "enum": [
        "legacy_command_id",
        "alternate_palette_phrasing",
        "alternate_cli_verb",
        "ai_tool_handle",
        "keybinding_target"
      ]
    },
    "alias_state": {
      "type": "string",
      "enum": [
        "active",
        "deprecated",
        "retired"
      ]
    },
    "searchability_axis": {
      "type": "string",
      "enum": [
        "primary_label",
        "stable_command_id",
        "alias",
        "literal_key_sequence"
      ]
    },
    "projection_class": {
      "type": "string",
      "enum": [
        "palette_row",
        "help_search",
        "onboarding_hint",
        "migration_bridge_card",
        "current_shortcut_display",
        "why_unavailable_explainer",
        "key_sequence_discoverability"
      ]
    },
    "automation_label": {
      "type": "string",
      "enum": [
        "macro_safe",
        "recipe_safe",
        "headless_safe",
        "ui_only",
        "approval_required",
        "unknown_automation_support"
      ]
    },
    "dominant_side_effect_class": {
      "type": "string",
      "enum": [
        "no_material_side_effect",
        "writes_files",
        "runs_process",
        "network_call",
        "remote_mutation"
      ]
    },
    "origin_badge_class": {
      "type": "string",
      "enum": [
        "core",
        "built_in_extension",
        "third_party_extension",
        "imported_bridge",
        "policy_provided",
        "labs"
      ]
    },
    "target_badge_class": {
      "type": "string",
      "enum": [
        "current_workspace",
        "focused_selection",
        "remote_repository",
        "profile_import_source",
        "restore_checkpoint",
        "external_browser_destination",
        "docs_reference",
        "diagnostics_surface",
        "managed_admin_surface"
      ]
    },
    "badge_priority_class": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "supporting"
      ]
    },
    "platform_class": {
      "type": "string",
      "enum": [
        "macos",
        "windows",
        "linux",
        "cross_platform"
      ]
    },
    "current_shortcut_display_state": {
      "type": "string",
      "enum": [
        "assigned",
        "unassigned",
        "conflict_requires_review",
        "platform_reserved",
        "shadowed",
        "blocked_by_policy",
        "blocked_by_security",
        "unsupported_on_surface"
      ],
      "description": "Current-shortcut display state projected from the frozen keybinding resolver. assigned or unassigned are not the only truthful states: shadowed, policy-blocked, security-blocked, host-reserved, and unsupported-on-surface remain first-class."
    },
    "keybinding_source_layer": {
      "type": "string",
      "enum": [
        "platform_reserved",
        "emergency_security_hard_block",
        "temporary_mode_overlay",
        "core_default",
        "imported_keymap_bridge",
        "user_profile_override",
        "workspace_recommendation",
        "admin_policy_lock",
        "extension_contributed",
        "not_bound"
      ],
      "description": "Snapshot source-layer vocabulary for current-shortcut display and diagnostics. Resolver precedence itself is frozen in schemas/commands/keybinding_resolver.schema.json; imported_keymap_bridge is an origin label, not a separate precedence tier."
    },
    "owner_boundary_class": {
      "type": "string",
      "enum": [
        "trust",
        "policy",
        "context",
        "dependency",
        "lifecycle",
        "client_scope",
        "platform",
        "migration_bridge"
      ]
    },
    "surface_exposure_class": {
      "type": "string",
      "enum": [
        "command_palette",
        "global_application_menu",
        "editor_context_menu",
        "explorer_context_menu",
        "review_context_menu",
        "source_control_context_menu",
        "terminal_context_menu",
        "search_context_menu",
        "primary_toolbar",
        "secondary_toolbar",
        "status_bar_control",
        "keybinding_help",
        "cli_help",
        "ai_tool_surface",
        "help_search",
        "onboarding_hint",
        "migration_bridge_card",
        "diagnostics_view",
        "current_shortcut_display",
        "key_sequence_help"
      ]
    },
    "surface_exposure_preference_class": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "contextual",
        "mirrored",
        "explain_only",
        "hidden_but_addressable"
      ]
    },
    "machine_name_kind": {
      "type": "string",
      "enum": [
        "canonical_cli_verb",
        "stable_cli_alias",
        "automation_handle",
        "ai_tool_handle",
        "recipe_step_handle"
      ]
    },
    "machine_name_state": {
      "type": "string",
      "enum": [
        "stable",
        "reserved",
        "deprecated",
        "retired"
      ]
    },
    "machine_name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9._:-]*$"
    },
    "projection_ref_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "palette_row_ref",
        "help_search_ref",
        "onboarding_hint_ref",
        "migration_bridge_card_ref",
        "current_shortcut_display_ref",
        "why_unavailable_explainer_ref",
        "key_sequence_discoverability_ref"
      ],
      "properties": {
        "palette_row_ref": { "$ref": "#/$defs/opaque_id" },
        "help_search_ref": { "$ref": "#/$defs/opaque_id" },
        "onboarding_hint_ref": { "$ref": "#/$defs/opaque_id" },
        "migration_bridge_card_ref": { "$ref": "#/$defs/opaque_id" },
        "current_shortcut_display_ref": { "$ref": "#/$defs/opaque_id" },
        "why_unavailable_explainer_ref": { "$ref": "#/$defs/opaque_id" },
        "key_sequence_discoverability_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "diagnostic_projection_ref_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "why_preview_required_ref",
        "why_ui_only_ref",
        "why_not_automatable_ref"
      ],
      "properties": {
        "why_preview_required_ref": { "$ref": "#/$defs/opaque_id" },
        "why_ui_only_ref": { "$ref": "#/$defs/opaque_id" },
        "why_not_automatable_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "discoverability_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "discoverability_record_id",
        "category_refs",
        "example_refs",
        "tag_refs",
        "searchability_axes",
        "promoted_alias_ids",
        "projection_refs"
      ],
      "properties": {
        "discoverability_record_id": { "$ref": "#/$defs/opaque_id" },
        "category_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "example_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "tag_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "searchability_axes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/searchability_axis" }
        },
        "promoted_alias_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "projection_refs": { "$ref": "#/$defs/projection_ref_block" }
      }
    },
    "alias_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alias_id",
        "alias_kind",
        "alias_state",
        "source_system_ref",
        "eligible_for_new_bindings"
      ],
      "properties": {
        "alias_id": { "$ref": "#/$defs/opaque_id" },
        "alias_kind": { "$ref": "#/$defs/registry_alias_kind" },
        "alias_state": { "$ref": "#/$defs/alias_state" },
        "source_system_ref": { "$ref": "#/$defs/non_empty_string" },
        "introduced_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "deprecated_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "retired_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "replacement_command_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "notes_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "eligible_for_new_bindings": {
          "type": "boolean"
        }
      }
    },
    "seed_enablement_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_class",
        "disabled_reason_code",
        "repair_hook_ref"
      ],
      "properties": {
        "decision_class": { "$ref": "#/$defs/enablement_decision_class" },
        "disabled_reason_code": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/disabled_reason_code" }
          ]
        },
        "repair_hook_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/repair_hook_ref" }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "decision_class": {
                "enum": [
                  "disabled_with_reason",
                  "hidden_with_reason"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "disabled_reason_code": { "$ref": "#/$defs/disabled_reason_code" },
              "repair_hook_ref": { "$ref": "#/$defs/repair_hook_ref" }
            },
            "required": [
              "disabled_reason_code",
              "repair_hook_ref"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "decision_class": { "const": "enabled" }
            }
          },
          "then": {
            "properties": {
              "disabled_reason_code": { "type": "null" },
              "repair_hook_ref": { "type": "null" }
            }
          }
        }
      ]
    },
    "current_keybinding_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform_class",
        "display_state",
        "keybinding_ref",
        "source_layer"
      ],
      "properties": {
        "platform_class": { "$ref": "#/$defs/platform_class" },
        "display_state": { "$ref": "#/$defs/current_shortcut_display_state" },
        "keybinding_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "source_layer": { "$ref": "#/$defs/keybinding_source_layer" },
        "imported_from_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/non_empty_string" }
          ]
        },
        "notes_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "origin_badge_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "badge_class",
        "label_ref",
        "priority",
        "projection_ref"
      ],
      "properties": {
        "badge_class": { "$ref": "#/$defs/origin_badge_class" },
        "label_ref": { "$ref": "#/$defs/opaque_id" },
        "priority": { "$ref": "#/$defs/badge_priority_class" },
        "projection_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "target_badge_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "badge_class",
        "label_ref",
        "priority",
        "projection_ref"
      ],
      "properties": {
        "badge_class": { "$ref": "#/$defs/target_badge_class" },
        "label_ref": { "$ref": "#/$defs/opaque_id" },
        "priority": { "$ref": "#/$defs/badge_priority_class" },
        "projection_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "disabled_reason_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disabled_reason_code",
        "owner_boundary_class",
        "explanation_ref",
        "repair_hook_ref"
      ],
      "properties": {
        "disabled_reason_code": { "$ref": "#/$defs/disabled_reason_code" },
        "owner_boundary_class": { "$ref": "#/$defs/owner_boundary_class" },
        "explanation_ref": { "$ref": "#/$defs/opaque_id" },
        "repair_hook_ref": { "$ref": "#/$defs/repair_hook_ref" },
        "fallback_command_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "surface_exposure_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "preference_class",
        "projection_ref",
        "issuing_surface"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/surface_exposure_class" },
        "preference_class": {
          "$ref": "#/$defs/surface_exposure_preference_class"
        },
        "projection_ref": { "$ref": "#/$defs/opaque_id" },
        "issuing_surface": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/issuing_surface" }
          ]
        },
        "descriptor_ui_slot_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/ui_slot_class" }
          ]
        }
      }
    },
    "machine_name_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name_kind",
        "machine_name",
        "machine_name_state",
        "eligible_for_new_automation"
      ],
      "properties": {
        "name_kind": { "$ref": "#/$defs/machine_name_kind" },
        "machine_name": { "$ref": "#/$defs/machine_name" },
        "machine_name_state": { "$ref": "#/$defs/machine_name_state" },
        "eligible_for_new_automation": {
          "type": "boolean"
        },
        "notes_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "preview_gate_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "gate_class",
        "requirement_class",
        "review_surface_refs",
        "apply_guard_ref",
        "revert_posture_class",
        "evidence_ref_class_required"
      ],
      "properties": {
        "record_kind": { "const": "command_preview_gate_metadata" },
        "schema_version": { "type": "integer", "const": 1 },
        "gate_class": { "$ref": "#/$defs/non_empty_string" },
        "requirement_class": { "$ref": "#/$defs/non_empty_string" },
        "review_surface_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "apply_guard_ref": { "$ref": "#/$defs/opaque_id" },
        "revert_posture_class": { "$ref": "#/$defs/non_empty_string" },
        "evidence_ref_class_required": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "namespace_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "namespace_class",
        "command_id_prefix",
        "canonical_verb_prefixes",
        "default_origin_badge_class",
        "lifecycle_bounds",
        "new_binding_policy",
        "machine_name_policy",
        "notes"
      ],
      "properties": {
        "namespace_class": { "$ref": "#/$defs/namespace_class" },
        "command_id_prefix": { "$ref": "#/$defs/non_empty_string" },
        "canonical_verb_prefixes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "default_origin_badge_class": {
          "$ref": "#/$defs/origin_badge_class"
        },
        "lifecycle_bounds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/lifecycle_state" }
        },
        "new_binding_policy": {
          "type": "string",
          "enum": [
            "canonical_id_only",
            "canonical_or_stable_alias"
          ]
        },
        "machine_name_policy": {
          "type": "string",
          "enum": [
            "canonical_verb_required",
            "canonical_verb_plus_stable_aliases",
            "no_stable_machine_names"
          ]
        },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "alias_deprecation_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aliases_must_resolve_to_canonical_id",
        "new_shortcuts_bind_canonical_ids",
        "retired_alias_surface_policy",
        "cli_aliases_require_deprecation_window",
        "stable_machine_names_may_be_reused",
        "imported_bridge_aliases_must_record_source"
      ],
      "properties": {
        "aliases_must_resolve_to_canonical_id": { "type": "boolean" },
        "new_shortcuts_bind_canonical_ids": { "type": "boolean" },
        "retired_alias_surface_policy": {
          "type": "string",
          "enum": [
            "migration_bridge_and_help_only",
            "help_search_only"
          ]
        },
        "cli_aliases_require_deprecation_window": { "type": "boolean" },
        "stable_machine_names_may_be_reused": { "type": "boolean" },
        "imported_bridge_aliases_must_record_source": { "type": "boolean" }
      }
    },
    "command_registry_entry_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "command_registry_schema_version",
        "registry_entry_id",
        "title",
        "summary",
        "namespace_class",
        "descriptor",
        "seed_enablement_snapshot",
        "alias_records",
        "discoverability_record",
        "automation_labels",
        "dominant_side_effect_class",
        "current_keybinding_refs",
        "disabled_reason_records",
        "origin_badge",
        "target_badges",
        "diagnostic_projection_refs",
        "preferred_surface_exposures",
        "machine_name_records",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "record_kind": { "const": "command_registry_entry_record" },
        "command_registry_schema_version": {
          "$ref": "#/$defs/command_registry_schema_version"
        },
        "registry_entry_id": { "$ref": "#/$defs/opaque_id" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/non_empty_string" },
        "namespace_class": { "$ref": "#/$defs/namespace_class" },
        "descriptor": {
          "$ref": "command_descriptor.schema.json#/$defs/command_descriptor_record"
        },
        "seed_enablement_snapshot": {
          "$ref": "#/$defs/seed_enablement_snapshot"
        },
        "alias_records": {
          "type": "array",
          "items": { "$ref": "#/$defs/alias_record" }
        },
        "discoverability_record": {
          "$ref": "#/$defs/discoverability_record"
        },
        "automation_labels": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/automation_label" }
        },
        "dominant_side_effect_class": {
          "$ref": "#/$defs/dominant_side_effect_class"
        },
        "preview_gate_metadata": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/preview_gate_metadata" }
          ]
        },
        "current_keybinding_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/current_keybinding_ref" }
        },
        "disabled_reason_records": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/disabled_reason_record" }
        },
        "origin_badge": { "$ref": "#/$defs/origin_badge_record" },
        "target_badges": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/target_badge_record" }
        },
        "diagnostic_projection_refs": {
          "$ref": "#/$defs/diagnostic_projection_ref_block"
        },
        "preferred_surface_exposures": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_exposure_record" }
        },
        "machine_name_records": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/machine_name_record" }
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "namespace_class": { "const": "labs" }
            }
          },
          "then": {
            "properties": {
              "descriptor": {
                "properties": {
                  "lifecycle_state": {
                    "enum": [
                      "labs",
                      "preview"
                    ]
                  }
                },
                "required": ["lifecycle_state"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "namespace_class": { "const": "built_in_extension" }
            }
          },
          "then": {
            "properties": {
              "origin_badge": {
                "properties": {
                  "badge_class": { "const": "built_in_extension" }
                },
                "required": ["badge_class"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "namespace_class": { "const": "imported_bridge" }
            }
          },
          "then": {
            "properties": {
              "origin_badge": {
                "properties": {
                  "badge_class": { "const": "imported_bridge" }
                },
                "required": ["badge_class"]
              }
            }
          }
        }
      ]
    },
    "command_registry_seed_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "command_registry_schema_version",
        "seed_id",
        "title",
        "seed_scope_summary",
        "source_contract_refs",
        "command_descriptor_schema_ref",
        "ui_slot_taxonomy_schema_ref",
        "entry_fixture_root",
        "entry_fixture_refs",
        "namespace_rules",
        "alias_deprecation_rules",
        "reserved_projection_classes",
        "entries"
      ],
      "properties": {
        "record_kind": { "const": "command_registry_seed_record" },
        "command_registry_schema_version": {
          "$ref": "#/$defs/command_registry_schema_version"
        },
        "seed_id": { "$ref": "#/$defs/opaque_id" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "seed_scope_summary": { "$ref": "#/$defs/non_empty_string" },
        "source_contract_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "command_descriptor_schema_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "ui_slot_taxonomy_schema_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "entry_fixture_root": { "$ref": "#/$defs/non_empty_string" },
        "entry_fixture_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "namespace_rules": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/namespace_rule" }
        },
        "alias_deprecation_rules": {
          "$ref": "#/$defs/alias_deprecation_rules"
        },
        "reserved_projection_classes": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/projection_class" }
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/command_registry_entry_record" }
        }
      }
    }
  }
}
