{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/palette_result.schema.json",
  "title": "Aureline command palette query-session and result-row contract",
  "description": "Boundary schema for palette_query_session_record and palette_result_row_record, frozen in docs/commands/palette_row_contract.md. Palette records are governed projections over the command registry, command descriptor, keybinding resolver, enablement decision, and shareability metadata. They carry materialized labels and state only with source refs so the palette, docs/help, settings, keybinding help, migration guidance, automation explainers, and support exports cannot drift into handwritten command copies.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/palette_query_session_record" },
    { "$ref": "#/$defs/palette_result_row_record" }
  ],
  "$defs": {
    "palette_result_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for palette result projections. Additive optional fields or enum values bump this const; repurposing an existing value is breaking."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "palette_query_session_record",
        "palette_result_row_record"
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "$ref": "command_descriptor.schema.json#/$defs/monotonic_timestamp"
    },
    "canonical_verb": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
    },
    "repair_hook_ref": {
      "$ref": "command_descriptor.schema.json#/$defs/repair_hook_ref"
    },
    "docs_help_anchor_ref": {
      "$ref": "command_descriptor.schema.json#/$defs/docs_help_anchor_ref"
    },
    "enablement_decision_class": {
      "$ref": "command_descriptor.schema.json#/$defs/enablement_decision_class"
    },
    "disabled_reason_code": {
      "$ref": "command_descriptor.schema.json#/$defs/disabled_reason_code"
    },
    "lifecycle_state": {
      "$ref": "command_descriptor.schema.json#/$defs/lifecycle_state"
    },
    "support_class": {
      "$ref": "command_descriptor.schema.json#/$defs/support_class"
    },
    "release_channel": {
      "$ref": "command_descriptor.schema.json#/$defs/release_channel"
    },
    "declared_freshness_class": {
      "$ref": "command_descriptor.schema.json#/$defs/freshness_class"
    },
    "preview_class": {
      "$ref": "command_descriptor.schema.json#/$defs/preview_class"
    },
    "approval_posture_class": {
      "$ref": "command_descriptor.schema.json#/$defs/approval_posture_class"
    },
    "origin_badge_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/origin_badge_class"
    },
    "target_badge_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/target_badge_class"
    },
    "badge_priority_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/badge_priority_class"
    },
    "automation_label": {
      "$ref": "command_registry_entry.schema.json#/$defs/automation_label"
    },
    "dominant_side_effect_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/dominant_side_effect_class"
    },
    "current_shortcut_display_state": {
      "$ref": "command_registry_entry.schema.json#/$defs/current_shortcut_display_state"
    },
    "keybinding_source_layer": {
      "$ref": "command_registry_entry.schema.json#/$defs/keybinding_source_layer"
    },
    "platform_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/platform_class"
    },
    "owner_boundary_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/owner_boundary_class"
    },
    "copy_form_class": {
      "$ref": "shareability_metadata.schema.json#/$defs/copy_form_class"
    },
    "automation_safety_cue": {
      "$ref": "shareability_metadata.schema.json#/$defs/automation_safety_cue"
    },
    "shareability_why_unavailable_reason": {
      "$ref": "shareability_metadata.schema.json#/$defs/shareability_why_unavailable_reason"
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "scenario"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/non_empty_string" },
        "source_registry_fixture": { "$ref": "#/$defs/non_empty_string" },
        "exercised_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "query_state_class": {
      "type": "string",
      "enum": [
        "idle",
        "focused_empty",
        "ime_composing",
        "filtering",
        "results_streaming",
        "provider_degraded",
        "empty_after_filter",
        "committed",
        "cancelled"
      ]
    },
    "query_text_storage_class": {
      "type": "string",
      "enum": [
        "not_recorded",
        "volatile_session_only",
        "local_profile_history",
        "local_per_device_history",
        "managed_history_policy_allowed"
      ]
    },
    "history_retention_class": {
      "type": "string",
      "enum": [
        "none",
        "session_only",
        "local_profile_recent",
        "local_per_device_recent",
        "managed_governed_recent"
      ]
    },
    "history_export_class": {
      "type": "string",
      "enum": [
        "not_exported",
        "export_command_refs_only",
        "export_redacted_query_refs",
        "export_allowed_by_policy"
      ]
    },
    "provider_class": {
      "type": "string",
      "enum": [
        "command_registry",
        "keybinding_resolver",
        "docs_help",
        "settings_registry",
        "recent_history",
        "file_index",
        "symbol_index",
        "extension_provider"
      ]
    },
    "provider_state_class": {
      "type": "string",
      "enum": [
        "ready",
        "warming",
        "streaming",
        "stale",
        "partial",
        "policy_blocked",
        "unavailable"
      ]
    },
    "held_modifier_intent_class": {
      "type": "string",
      "enum": [
        "none",
        "alternate_enter",
        "primary_modifier_enter",
        "secondary_modifier_enter",
        "copy_intent",
        "detail_intent",
        "recipe_insert_intent"
      ]
    },
    "palette_group_kind": {
      "type": "string",
      "enum": [
        "category",
        "source",
        "recent",
        "migration",
        "docs_help",
        "settings",
        "policy_or_admin",
        "automation"
      ]
    },
    "projection_target_class": {
      "type": "string",
      "enum": [
        "command_palette",
        "docs_help",
        "settings_command_detail",
        "keybinding_help",
        "migration_guidance",
        "command_docs",
        "automation_recipe_builder",
        "support_export"
      ]
    },
    "subtitle_source_class": {
      "type": "string",
      "enum": [
        "registry_summary",
        "discoverability_category",
        "contextual_scope",
        "target_summary",
        "docs_help_context",
        "settings_context",
        "migration_alias_context"
      ]
    },
    "row_availability_class": {
      "type": "string",
      "enum": [
        "enabled",
        "disabled_selectable",
        "hidden_explainable",
        "preview_required",
        "approval_required",
        "policy_blocked",
        "ui_only",
        "not_automatable"
      ]
    },
    "inline_explanation_zone_class": {
      "type": "string",
      "enum": [
        "disabled_reason",
        "policy_block",
        "preview_required",
        "approval_required",
        "automation_blocker",
        "shortcut_conflict",
        "source_origin",
        "migration_alias",
        "history_privacy",
        "docs_help"
      ]
    },
    "preview_detail_affordance_class": {
      "type": "string",
      "enum": [
        "none",
        "docs_help_detail",
        "argument_detail",
        "target_summary_detail",
        "preview_required_detail",
        "why_unavailable_detail",
        "automation_detail"
      ]
    },
    "keyboard_action_class": {
      "type": "string",
      "enum": [
        "focus_query",
        "move_previous",
        "move_next",
        "primary_run_or_open",
        "alternate_open_or_split",
        "new_tab_or_window",
        "open_detail",
        "focus_footer",
        "copy_selected_action",
        "dismiss"
      ]
    },
    "source_record_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_entry_id",
        "command_descriptor_ref",
        "discoverability_record_id",
        "projection_ref"
      ],
      "properties": {
        "registry_entry_id": { "$ref": "#/$defs/opaque_id" },
        "command_descriptor_ref": { "$ref": "#/$defs/opaque_id" },
        "discoverability_record_id": { "$ref": "#/$defs/opaque_id" },
        "shareability_metadata_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "keybinding_snapshot_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "enablement_snapshot_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "projection_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "command_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "command_revision_ref",
        "canonical_verb"
      ],
      "properties": {
        "command_id": { "$ref": "#/$defs/opaque_id" },
        "command_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "canonical_verb": { "$ref": "#/$defs/canonical_verb" }
      }
    },
    "palette_group_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_id",
        "group_kind",
        "label_ref",
        "source_ref"
      ],
      "properties": {
        "group_id": { "$ref": "#/$defs/opaque_id" },
        "group_kind": { "$ref": "#/$defs/palette_group_kind" },
        "label_ref": { "$ref": "#/$defs/opaque_id" },
        "source_ref": { "$ref": "#/$defs/opaque_id" },
        "visible_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "provider_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_class",
        "state_class",
        "truth_label_ref"
      ],
      "properties": {
        "provider_class": { "$ref": "#/$defs/provider_class" },
        "state_class": { "$ref": "#/$defs/provider_state_class" },
        "truth_label_ref": { "$ref": "#/$defs/opaque_id" },
        "degrade_reason_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "history_privacy_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query_text_storage_class",
        "history_retention_class",
        "history_export_class",
        "raw_query_export_allowed",
        "synced_history_allowed"
      ],
      "properties": {
        "query_text_storage_class": { "$ref": "#/$defs/query_text_storage_class" },
        "history_retention_class": { "$ref": "#/$defs/history_retention_class" },
        "history_export_class": { "$ref": "#/$defs/history_export_class" },
        "raw_query_export_allowed": { "type": "boolean" },
        "synced_history_allowed": { "type": "boolean" },
        "governance_record_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "keyboard_binding_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "keyboard_action_class",
        "gesture_ref",
        "narration_ref"
      ],
      "properties": {
        "keyboard_action_class": { "$ref": "#/$defs/keyboard_action_class" },
        "gesture_ref": { "$ref": "#/$defs/opaque_id" },
        "footer_action_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "narration_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "keyboard_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_starts_in_query_field",
        "dismiss_returns_focus",
        "bindings"
      ],
      "properties": {
        "focus_starts_in_query_field": { "type": "boolean" },
        "dismiss_returns_focus": { "type": "boolean" },
        "bindings": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/keyboard_binding_contract" }
        }
      }
    },
    "badge_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "badge_class",
        "label_ref",
        "priority",
        "projection_ref"
      ],
      "properties": {
        "badge_class": {
          "oneOf": [
            { "$ref": "#/$defs/origin_badge_class" },
            { "$ref": "#/$defs/target_badge_class" }
          ]
        },
        "label_ref": { "$ref": "#/$defs/opaque_id" },
        "priority": { "$ref": "#/$defs/badge_priority_class" },
        "projection_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "shortcut_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform_class",
        "display_state",
        "keybinding_ref",
        "source_layer",
        "display_label_ref",
        "narration_ref"
      ],
      "properties": {
        "platform_class": { "$ref": "#/$defs/platform_class" },
        "display_state": { "$ref": "#/$defs/current_shortcut_display_state" },
        "keybinding_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "source_layer": { "$ref": "#/$defs/keybinding_source_layer" },
        "display_label_ref": { "$ref": "#/$defs/opaque_id" },
        "narration_ref": { "$ref": "#/$defs/opaque_id" },
        "why_shortcut_state_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "disabled_reason_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disabled_reason_code",
        "owner_boundary_class",
        "explanation_ref",
        "repair_hook_ref"
      ],
      "properties": {
        "disabled_reason_code": { "$ref": "#/$defs/disabled_reason_code" },
        "owner_boundary_class": { "$ref": "#/$defs/owner_boundary_class" },
        "explanation_ref": { "$ref": "#/$defs/opaque_id" },
        "repair_hook_ref": { "$ref": "#/$defs/repair_hook_ref" },
        "fallback_command_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "shareability_reason_code": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/shareability_why_unavailable_reason" }
          ]
        }
      }
    },
    "availability_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_availability_class",
        "enablement_decision",
        "disabled_reason",
        "row_is_selectable",
        "primary_invocation_allowed",
        "copy_actions_allowed",
        "docs_help_allowed"
      ],
      "properties": {
        "row_availability_class": { "$ref": "#/$defs/row_availability_class" },
        "enablement_decision": { "$ref": "#/$defs/enablement_decision_class" },
        "disabled_reason": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/disabled_reason_projection" }
          ]
        },
        "row_is_selectable": { "type": "boolean" },
        "primary_invocation_allowed": { "type": "boolean" },
        "copy_actions_allowed": { "type": "boolean" },
        "docs_help_allowed": { "type": "boolean" },
        "next_safe_action_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enablement_decision": { "const": "enabled" }
            }
          },
          "then": {
            "properties": {
              "disabled_reason": { "type": "null" },
              "primary_invocation_allowed": { "const": true }
            }
          }
        },
        {
          "if": {
            "properties": {
              "enablement_decision": {
                "enum": [
                  "disabled_with_reason",
                  "hidden_with_reason"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "disabled_reason": { "$ref": "#/$defs/disabled_reason_projection" },
              "primary_invocation_allowed": { "const": false }
            }
          }
        }
      ]
    },
    "inline_explanation_zone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "zone_class",
        "label_ref",
        "detail_ref",
        "source_ref"
      ],
      "properties": {
        "zone_class": { "$ref": "#/$defs/inline_explanation_zone_class" },
        "label_ref": { "$ref": "#/$defs/opaque_id" },
        "detail_ref": { "$ref": "#/$defs/opaque_id" },
        "source_ref": { "$ref": "#/$defs/opaque_id" },
        "repair_hook_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/repair_hook_ref" }
          ]
        }
      }
    },
    "preview_detail_affordance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "affordance_class",
        "label_ref",
        "detail_target_ref"
      ],
      "properties": {
        "affordance_class": { "$ref": "#/$defs/preview_detail_affordance_class" },
        "label_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "detail_target_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "opens_without_invocation": { "type": "boolean" }
      }
    },
    "lifecycle_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lifecycle_state",
        "support_class",
        "release_channel",
        "declared_freshness_class"
      ],
      "properties": {
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "release_channel": { "$ref": "#/$defs/release_channel" },
        "declared_freshness_class": { "$ref": "#/$defs/declared_freshness_class" }
      }
    },
    "automation_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "automation_labels",
        "automation_safety_cues",
        "dominant_side_effect_class",
        "why_not_automatable_ref"
      ],
      "properties": {
        "automation_labels": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/automation_label" }
        },
        "automation_safety_cues": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/automation_safety_cue" }
        },
        "dominant_side_effect_class": { "$ref": "#/$defs/dominant_side_effect_class" },
        "why_not_automatable_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "command_lifecycle_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_class",
        "approval_posture_class"
      ],
      "properties": {
        "preview_class": { "$ref": "#/$defs/preview_class" },
        "approval_posture_class": { "$ref": "#/$defs/approval_posture_class" }
      }
    },
    "palette_query_session_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "palette_result_schema_version",
        "palette_session_id",
        "query_state",
        "query_text_ref",
        "provider_states",
        "held_modifier_intent",
        "history_privacy",
        "groups",
        "result_row_refs",
        "selected_palette_row_ref",
        "keyboard_contract",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "palette_query_session_record" },
        "palette_result_schema_version": { "$ref": "#/$defs/palette_result_schema_version" },
        "palette_session_id": { "$ref": "#/$defs/opaque_id" },
        "query_state": { "$ref": "#/$defs/query_state_class" },
        "query_text_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "provider_states": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/provider_state" }
        },
        "held_modifier_intent": { "$ref": "#/$defs/held_modifier_intent_class" },
        "history_privacy": { "$ref": "#/$defs/history_privacy_block" },
        "groups": {
          "type": "array",
          "items": { "$ref": "#/$defs/palette_group_ref" }
        },
        "result_row_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "selected_palette_row_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "keyboard_contract": { "$ref": "#/$defs/keyboard_contract" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    },
    "palette_result_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "palette_result_schema_version",
        "palette_row_id",
        "source_record_refs",
        "command_identity",
        "user_label",
        "user_label_ref",
        "subtitle",
