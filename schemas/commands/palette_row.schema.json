{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/palette_row.schema.json",
  "title": "Aureline command palette row, modifier-action, and automation-cue contract",
  "description": "Boundary schema for the combined command-palette row contract frozen in docs/commands/palette_row_and_modifier_contract.md. A row record is the cross-surface projection that desktop palette rows, docs examples, CLI discoverability aids, automation explainers, and support captures may all cite. It carries the required row anatomy, modifier/footer actions, no-bypass guards, explanation links, and fallback/degraded states without inventing labels, command IDs, automation vocabulary, or disabled reasons outside the command descriptor, command registry, keybinding resolver, diagnostic projection, and shareability metadata records.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/palette_row_contract_record" }
  ],
  "$defs": {
    "palette_row_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the combined row/modifier contract."
    },
    "record_kind": {
      "type": "string",
      "enum": ["palette_row_contract_record"]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "$ref": "command_descriptor.schema.json#/$defs/monotonic_timestamp"
    },
    "canonical_verb": {
      "$ref": "shareability_metadata.schema.json#/$defs/canonical_verb"
    },
    "docs_help_anchor_ref": {
      "$ref": "command_descriptor.schema.json#/$defs/docs_help_anchor_ref"
    },
    "repair_hook_ref": {
      "$ref": "command_descriptor.schema.json#/$defs/repair_hook_ref"
    },
    "capability_scope_class": {
      "$ref": "command_descriptor.schema.json#/$defs/capability_scope_class"
    },
    "preview_class": {
      "$ref": "command_descriptor.schema.json#/$defs/preview_class"
    },
    "approval_posture_class": {
      "$ref": "command_descriptor.schema.json#/$defs/approval_posture_class"
    },
    "disabled_reason_code": {
      "$ref": "command_descriptor.schema.json#/$defs/disabled_reason_code"
    },
    "lifecycle_state": {
      "$ref": "command_descriptor.schema.json#/$defs/lifecycle_state"
    },
    "support_class": {
      "$ref": "command_descriptor.schema.json#/$defs/support_class"
    },
    "release_channel": {
      "$ref": "command_descriptor.schema.json#/$defs/release_channel"
    },
    "declared_freshness_class": {
      "$ref": "command_descriptor.schema.json#/$defs/freshness_class"
    },
    "origin_badge_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/origin_badge_class"
    },
    "target_badge_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/target_badge_class"
    },
    "badge_priority_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/badge_priority_class"
    },
    "automation_label": {
      "$ref": "command_registry_entry.schema.json#/$defs/automation_label"
    },
    "dominant_side_effect_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/dominant_side_effect_class"
    },
    "current_shortcut_display_state": {
      "$ref": "command_registry_entry.schema.json#/$defs/current_shortcut_display_state"
    },
    "keybinding_source_layer": {
      "$ref": "command_registry_entry.schema.json#/$defs/keybinding_source_layer"
    },
    "platform_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/platform_class"
    },
    "owner_boundary_class": {
      "$ref": "command_registry_entry.schema.json#/$defs/owner_boundary_class"
    },
    "copy_form_class": {
      "$ref": "shareability_metadata.schema.json#/$defs/copy_form_class"
    },
    "cli_equivalent_presence_class": {
      "$ref": "shareability_metadata.schema.json#/$defs/cli_equivalent_presence_class"
    },
    "headless_mode_class": {
      "$ref": "shareability_metadata.schema.json#/$defs/headless_mode_class"
    },
    "automation_safety_cue": {
      "$ref": "shareability_metadata.schema.json#/$defs/automation_safety_cue"
    },
    "shareability_why_unavailable_reason": {
      "$ref": "shareability_metadata.schema.json#/$defs/shareability_why_unavailable_reason"
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/non_empty_string" },
        "source_registry_fixture": { "$ref": "#/$defs/non_empty_string" },
        "exercised_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "row_status_class": {
      "type": "string",
      "enum": [
        "enabled",
        "preview_required",
        "approval_required",
        "disabled_selectable",
        "hidden_explainable",
        "deprecated_with_successor",
        "provider_backed_degraded",
        "ui_only_explainable",
        "not_automatable"
      ]
    },
    "scope_detail_class": {
      "type": "string",
      "enum": [
        "current_workspace",
        "focused_selection",
        "active_file",
        "selected_symbol",
        "remote_workspace",
        "managed_admin_surface",
        "docs_or_help",
        "provider_context",
        "global_no_target"
      ]
    },
    "reason_chip_class": {
      "type": "string",
      "enum": [
        "none",
        "disabled_reason",
        "policy_blocked",
        "preview_required",
        "approval_required",
        "lifecycle_deprecated",
        "provider_degraded",
        "ui_only",
        "hidden_with_reason",
        "not_automatable"
      ]
    },
    "automation_posture_class": {
      "type": "string",
      "enum": [
        "automation_safe",
        "automation_safe_with_preview",
        "approval_gated_automation",
        "ui_only_not_automatable",
        "provider_or_extension_declared",
        "unknown_automation_support",
        "automation_denied_with_reason"
      ]
    },
    "target_or_authority_hint_class": {
      "type": "string",
      "enum": [
        "target_hint",
        "authority_hint",
        "target_and_authority_hint",
        "no_target_needed"
      ]
    },
    "projection_surface_class": {
      "type": "string",
      "enum": [
        "desktop_command_palette",
        "docs_example",
        "cli_discoverability",
        "support_capture",
        "keybinding_help",
        "menu_command_bar",
        "leader_overlay",
        "automation_recipe_builder",
        "ai_tool_surface",
        "migration_guidance"
      ]
    },
    "modifier_action_class": {
      "type": "string",
      "enum": [
        "primary_invoke",
        "alternate_placement",
        "alternate_target",
        "copy_canonical_command_id",
        "copy_cli_form",
        "add_to_recipe",
        "inspect_why_not_automatable"
      ]
    },
    "modifier_gesture_class": {
      "type": "string",
      "enum": [
        "enter",
        "alt_enter",
        "primary_modifier_enter",
        "secondary_modifier_enter",
        "tab_or_arrow_to_footer",
        "copy_chord",
        "space_or_enter_on_action",
        "no_default_gesture"
      ]
    },
    "modifier_semantics_class": {
      "type": "string",
      "enum": [
        "dispatch_primary",
        "dispatch_with_placement_delta",
        "dispatch_with_target_delta",
        "copy_only_no_dispatch",
        "recipe_insert_no_dispatch",
        "inspect_only_no_dispatch"
      ]
    },
    "modifier_action_state": {
      "type": "string",
      "enum": [
        "enabled",
        "disabled_with_reason",
        "hidden_with_reason"
      ]
    },
    "degraded_state_class": {
      "type": "string",
      "enum": [
        "none",
        "hidden_but_explainable",
        "deprecated_successor_available",
        "provider_unavailable_or_stale",
        "provider_capability_limited",
        "ui_only_interactive_required",
        "automation_not_supported",
        "policy_or_trust_blocked"
      ]
    },
    "label_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label_ref", "display_text", "source_ref"],
      "properties": {
        "label_ref": { "$ref": "#/$defs/opaque_id" },
        "display_text": { "$ref": "#/$defs/non_empty_string" },
        "source_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "secondary_scope_detail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_detail_class", "detail_ref", "display_text", "source_ref"],
      "properties": {
        "scope_detail_class": { "$ref": "#/$defs/scope_detail_class" },
        "detail_ref": { "$ref": "#/$defs/opaque_id" },
        "display_text": { "$ref": "#/$defs/non_empty_string" },
        "source_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "badge_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["badge_class", "label_ref", "priority", "source_ref"],
      "properties": {
        "badge_class": {
          "oneOf": [
            { "$ref": "#/$defs/origin_badge_class" },
            { "$ref": "#/$defs/target_badge_class" }
          ]
        },
        "label_ref": { "$ref": "#/$defs/opaque_id" },
        "priority": { "$ref": "#/$defs/badge_priority_class" },
        "source_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "shortcut_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform_class",
        "display_state",
        "winning_keybinding_ref",
        "source_layer",
        "display_label_ref",
        "narration_ref"
      ],
      "properties": {
        "platform_class": { "$ref": "#/$defs/platform_class" },
        "display_state": { "$ref": "#/$defs/current_shortcut_display_state" },
        "winning_keybinding_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "source_layer": { "$ref": "#/$defs/keybinding_source_layer" },
        "display_label_ref": { "$ref": "#/$defs/opaque_id" },
        "narration_ref": { "$ref": "#/$defs/opaque_id" },
        "why_shortcut_state_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "reason_chip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason_chip_class",
        "label_ref",
        "reason_ref",
        "disabled_reason_code",
        "shareability_reason_code"
      ],
      "properties": {
        "reason_chip_class": { "$ref": "#/$defs/reason_chip_class" },
        "label_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "reason_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "disabled_reason_code": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/disabled_reason_code" }
          ]
        },
        "shareability_reason_code": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/shareability_why_unavailable_reason" }
          ]
        },
        "owner_boundary_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/owner_boundary_class" }
          ]
        },
        "repair_hook_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/repair_hook_ref" }
          ]
        }
      }
    },
    "automation_cue_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "automation_posture_class",
        "registry_automation_labels",
        "shareability_safety_cues",
        "dominant_side_effect_class",
        "cli_equivalent_presence_class",
        "headless_mode_class",
        "automation_posture_ref",
        "why_not_automatable_ref"
      ],
      "properties": {
        "automation_posture_class": { "$ref": "#/$defs/automation_posture_class" },
        "registry_automation_labels": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/automation_label" }
        },
        "shareability_safety_cues": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/automation_safety_cue" }
        },
        "dominant_side_effect_class": { "$ref": "#/$defs/dominant_side_effect_class" },
        "cli_equivalent_presence_class": { "$ref": "#/$defs/cli_equivalent_presence_class" },
        "headless_mode_class": { "$ref": "#/$defs/headless_mode_class" },
        "automation_posture_ref": { "$ref": "#/$defs/opaque_id" },
        "why_not_automatable_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "lifecycle_cue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lifecycle_state",
        "support_class",
        "release_channel",
        "declared_freshness_class",
        "label_ref",
        "source_ref"
      ],
      "properties": {
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "release_channel": { "$ref": "#/$defs/release_channel" },
        "declared_freshness_class": { "$ref": "#/$defs/declared_freshness_class" },
        "label_ref": { "$ref": "#/$defs/opaque_id" },
        "source_ref": { "$ref": "#/$defs/opaque_id" },
        "replacement_command_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "target_or_authority_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hint_class",
        "capability_scope_class",
        "target_badges",
        "authority_label_ref",
        "source_ref"
      ],
      "properties": {
        "hint_class": { "$ref": "#/$defs/target_or_authority_hint_class" },
        "capability_scope_class": { "$ref": "#/$defs/capability_scope_class" },
        "target_badges": {
          "type": "array",
          "items": { "$ref": "#/$defs/badge_projection" }
        },
        "authority_label_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "source_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "required_row_elements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_label",
        "secondary_scope_detail",
        "origin_badge",
        "winning_shortcut_hint",
        "reason_chip",
        "automation_cues",
        "lifecycle_cue",
        "target_or_authority_hint"
      ],
      "properties": {
        "primary_label": { "$ref": "#/$defs/label_projection" },
        "secondary_scope_detail": { "$ref": "#/$defs/secondary_scope_detail" },
        "origin_badge": { "$ref": "#/$defs/badge_projection" },
        "winning_shortcut_hint": { "$ref": "#/$defs/shortcut_hint" },
        "reason_chip": { "$ref": "#/$defs/reason_chip" },
        "automation_cues": { "$ref": "#/$defs/automation_cue_block" },
        "lifecycle_cue": { "$ref": "#/$defs/lifecycle_cue" },
        "target_or_authority_hint": { "$ref": "#/$defs/target_or_authority_hint" }
      }
    },
    "command_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_id", "command_revision_ref", "canonical_verb"],
      "properties": {
        "command_id": { "$ref": "#/$defs/opaque_id" },
        "command_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "canonical_verb": { "$ref": "#/$defs/canonical_verb" }
      }
    },
    "source_record_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_entry_id",
        "command_descriptor_ref",
        "discoverability_record_id",
        "keybinding_snapshot_ref",
        "enablement_snapshot_ref",
        "shareability_metadata_ref",
        "diagnostic_projection_ref",
        "projection_ref"
      ],
      "properties": {
        "registry_entry_id": { "$ref": "#/$defs/opaque_id" },
        "command_descriptor_ref": { "$ref": "#/$defs/opaque_id" },
        "discoverability_record_id": { "$ref": "#/$defs/opaque_id" },
        "keybinding_snapshot_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "enablement_snapshot_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "shareability_metadata_ref": { "$ref": "#/$defs/opaque_id" },
        "diagnostic_projection_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "projection_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "preview_approval_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_class",
        "approval_posture_class",
        "preview_required_before_dispatch",
        "approval_required_before_dispatch"
      ],
      "properties": {
        "preview_class": { "$ref": "#/$defs/preview_class" },
        "approval_posture_class": { "$ref": "#/$defs/approval_posture_class" },
        "preview_required_before_dispatch": { "type": "boolean" },
        "approval_required_before_dispatch": { "type": "boolean" }
      }
    },
    "no_bypass_guard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust_revalidation_required",
        "policy_revalidation_required",
        "permission_prompt_revalidation_required",
        "preview_path_preserved",
        "approval_path_preserved",
        "capability_class_preserved",
        "target_delta_may_not_widen_authority",
        "automation_insertion_does_not_execute",
        "copy_forms_do_not_execute"
      ],
      "properties": {
        "trust_revalidation_required": { "const": true },
        "policy_revalidation_required": { "const": true },
        "permission_prompt_revalidation_required": { "const": true },
        "preview_path_preserved": { "const": true },
        "approval_path_preserved": { "const": true },
        "capability_class_preserved": { "const": true },
        "target_delta_may_not_widen_authority": { "const": true },
        "automation_insertion_does_not_execute": { "const": true },
        "copy_forms_do_not_execute": { "const": true }
      }
    },
    "modifier_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "action_class",
        "enabled_state",
        "label_ref",
        "narration_ref",
        "gesture_class",
        "semantics_class",
        "copy_form_class",
        "invocation_or_recipe_ref",
        "argument_delta_refs",
        "unavailable_reason_ref",
        "bypass_guard",
        "consistent_on_surfaces"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "action_class": { "$ref": "#/$defs/modifier_action_class" },
        "enabled_state": { "$ref": "#/$defs/modifier_action_state" },
        "label_ref": { "$ref": "#/$defs/opaque_id" },
        "narration_ref": { "$ref": "#/$defs/opaque_id" },
        "gesture_class": { "$ref": "#/$defs/modifier_gesture_class" },
        "semantics_class": { "$ref": "#/$defs/modifier_semantics_class" },
        "copy_form_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/copy_form_class" }
          ]
        },
        "cli_equivalent_presence_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/cli_equivalent_presence_class" }
          ]
        },
        "headless_mode_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/headless_mode_class" }
          ]
        },
        "invocation_or_recipe_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "argument_delta_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "unavailable_reason_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "bypass_guard": { "$ref": "#/$defs/no_bypass_guard" },
        "consistent_on_surfaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/projection_surface_class" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action_class": {
                "enum": ["copy_canonical_command_id", "copy_cli_form"]
              }
            }
          },
          "then": {
            "properties": {
              "semantics_class": { "const": "copy_only_no_dispatch" }
            }
          }
        },
        {
          "if": {
            "properties": { "action_class": { "const": "add_to_recipe" } }
          },
          "then": {
            "properties": {
              "semantics_class": { "const": "recipe_insert_no_dispatch" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action_class": { "const": "inspect_why_not_automatable" }
            }
          },
          "then": {
            "properties": {
              "semantics_class": { "const": "inspect_only_no_dispatch" }
            }
          }
        },
        {
          "if": {
            "properties": { "action_class": { "const": "primary_invoke" } }
          },
          "then": {
            "properties": {
              "semantics_class": { "const": "dispatch_primary" }
            }
          }
        },
        {
          "if": {
            "properties": { "action_class": { "const": "alternate_placement" } }
          },
          "then": {
            "properties": {
              "semantics_class": { "const": "dispatch_with_placement_delta" }
            }
          }
        },
        {
          "if": {
            "properties": { "action_class": { "const": "alternate_target" } }
          },
          "then": {
            "properties": {
              "semantics_class": { "const": "dispatch_with_target_delta" }
            }
          }
        }
      ]
    },
    "fallback_degraded_state": {
