{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/finalize_traffic_origin_and_exposure_chips.schema.json",
  "title": "Aureline traffic-origin and exposure chips finalization record",
  "$comment": "Rust owner: aureline_commands::finalize_traffic_origin_and_exposure_chips::FinalizeTrafficOriginExposureChipsPacket.",
  "description": "Boundary schema for the metadata-only traffic-origin and exposure chips finalization record. For one command or network-action family on a claimed stable row, the packet binds the declared traffic-origin chip set (origin classes for all traffic paths the family can initiate or accept), the exposure chip set (exposure classes for all endpoints the family can expose), tunnel explainability records (one per active or pending tunnel, naming kind, target-port ref, traffic-origin, exposure, approval scope, and drift-forces-reapproval), port explainability records (one per forwarded or exposed port, naming protocol, exposure, and traffic-origin), publish-target explainability records (one per publish target, naming target class, exposure, traffic-origin, approval scope, and spend posture), and cross-surface chip parity rows that prove all chips are reachable from every claimed stable surface without widening authority. It does not re-derive the descriptor, registry, invocation, authority, high-risk hardening, command-parity, or client-origin/route-class models; it binds them by their canonical schema refs. It carries refs, state tokens, coarse classes, counts, and review labels only. Raw port numbers, raw endpoint hostnames, raw tunnel URLs, raw credentials, exact cost figures, and billing-account ids must not appear. Adding a new enum member or a new optional field is additive-minor; repurposing an existing member is breaking and bumps schema_version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "command_family_id",
    "display_label",
    "claimed_stable",
    "policy_epoch_ref",
    "contract_refs",
    "traffic_origin_classes",
    "exposure_classes",
    "tunnel_records",
    "port_records",
    "publish_target_records",
    "chip_surface_rows",
    "evidence_export",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "traffic_origin_exposure_chips_finalization_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "command_family_id": { "type": "string", "minLength": 1 },
    "display_label": { "type": "string", "minLength": 1 },
    "claimed_stable": { "type": "boolean" },
    "policy_epoch_ref": { "type": "string", "minLength": 1 },
    "contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "descriptor_schema_ref",
        "registry_entry_schema_ref",
        "registry_seed_ref",
        "invocation_session_schema_ref",
        "result_packet_schema_ref",
        "public_contract_schema_ref",
        "parity_expectation_schema_ref",
        "disabled_reason_vocabulary_ref"
      ],
      "properties": {
        "descriptor_schema_ref": { "type": "string" },
        "registry_entry_schema_ref": { "type": "string" },
        "registry_seed_ref": { "type": "string" },
        "invocation_session_schema_ref": { "type": "string" },
        "result_packet_schema_ref": { "type": "string" },
        "public_contract_schema_ref": { "type": "string" },
        "parity_expectation_schema_ref": { "type": "string" },
        "disabled_reason_vocabulary_ref": { "type": "string" }
      }
    },
    "traffic_origin_classes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "local_process",
          "loopback_client",
          "tunnel_ingress",
          "port_forward_ingress",
          "publish_target_relay",
          "provider_callback",
          "browser_companion_relay"
        ]
      },
      "minItems": 1
    },
    "exposure_classes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "unexposed",
          "localhost_only",
          "port_forwarded",
          "tunnel_exposed",
          "publicly_published",
          "provider_managed",
          "enterprise_gateway"
        ]
      },
      "minItems": 1
    },
    "tunnel_records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "tunnel_ref",
          "tunnel_kind",
          "target_port_ref",
          "traffic_origin",
          "exposure",
          "approval_scope_ref",
          "approval_owner_label",
          "drift_forces_reapproval",
          "disclosed_in_chip",
          "disclosed_in_preview",
          "disclosed_in_support_export"
        ],
        "properties": {
          "tunnel_ref": { "type": "string", "minLength": 1 },
          "tunnel_kind": {
            "type": "string",
            "enum": ["ssh_forward", "dev_tunnel", "reverse_tunnel", "provider_tunnel"]
          },
          "target_port_ref": { "type": "string", "minLength": 1 },
          "traffic_origin": {
            "type": "string",
            "enum": [
              "local_process", "loopback_client", "tunnel_ingress",
              "port_forward_ingress", "publish_target_relay",
              "provider_callback", "browser_companion_relay"
            ]
          },
          "exposure": {
            "type": "string",
            "enum": [
              "unexposed", "localhost_only", "port_forwarded",
              "tunnel_exposed", "publicly_published", "provider_managed", "enterprise_gateway"
            ]
          },
          "approval_scope_ref": { "type": "string", "minLength": 1 },
          "approval_owner_label": { "type": "string", "minLength": 1 },
          "drift_forces_reapproval": { "type": "boolean", "const": true },
          "disclosed_in_chip": { "type": "boolean", "const": true },
          "disclosed_in_preview": { "type": "boolean", "const": true },
          "disclosed_in_support_export": { "type": "boolean", "const": true }
        }
      }
    },
    "port_records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "port_ref",
          "protocol",
          "exposure",
          "traffic_origin",
          "disclosed_in_chip",
          "disclosed_in_support_export"
        ],
        "properties": {
          "port_ref": { "type": "string", "minLength": 1 },
          "protocol": {
            "type": "string",
            "enum": ["tcp", "http", "https", "ws", "wss", "udp"]
          },
          "exposure": {
            "type": "string",
            "enum": [
              "unexposed", "localhost_only", "port_forwarded",
              "tunnel_exposed", "publicly_published", "provider_managed", "enterprise_gateway"
            ]
          },
          "traffic_origin": {
            "type": "string",
            "enum": [
              "local_process", "loopback_client", "tunnel_ingress",
              "port_forward_ingress", "publish_target_relay",
              "provider_callback", "browser_companion_relay"
            ]
          },
          "disclosed_in_chip": { "type": "boolean", "const": true },
          "disclosed_in_support_export": { "type": "boolean", "const": true }
        }
      }
    },
    "publish_target_records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "publish_target_ref",
          "target_class",
          "exposure",
          "traffic_origin",
          "approval_scope_ref",
          "spend_posture_token",
          "disclosed_in_chip",
          "disclosed_in_support_export"
        ],
        "properties": {
          "publish_target_ref": { "type": "string", "minLength": 1 },
          "target_class": {
            "type": "string",
            "enum": [
              "static_host", "container_registry", "managed_service",
              "external_host", "provider_push"
            ]
          },
          "exposure": {
            "type": "string",
            "enum": [
              "unexposed", "localhost_only", "port_forwarded",
              "tunnel_exposed", "publicly_published", "provider_managed", "enterprise_gateway"
            ]
          },
          "traffic_origin": {
            "type": "string",
            "enum": [
              "local_process", "loopback_client", "tunnel_ingress",
              "port_forward_ingress", "publish_target_relay",
              "provider_callback", "browser_companion_relay"
            ]
          },
          "approval_scope_ref": { "type": "string", "minLength": 1 },
          "spend_posture_token": { "type": "string", "minLength": 1 },
          "disclosed_in_chip": { "type": "boolean", "const": true },
          "disclosed_in_support_export": { "type": "boolean", "const": true }
        }
      }
    },
    "chip_surface_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface_class",
          "chip_visible",
          "discloses_origin_class",
          "discloses_exposure_class",
          "discloses_network_explainability",
          "policy_checked",
          "no_authority_widening",
          "qualification",
          "claimed_stable"
        ],
        "properties": {
          "surface_class": {
            "type": "string",
            "enum": [
              "menu_or_button", "keybinding", "command_palette",
              "cli_headless", "ai_tool", "voice", "recipe",
              "deep_link", "browser_companion"
            ]
          },
          "chip_visible": { "type": "boolean" },
          "discloses_origin_class": { "type": "boolean" },
          "discloses_exposure_class": { "type": "boolean" },
          "discloses_network_explainability": { "type": "boolean" },
          "policy_checked": { "type": "boolean" },
          "no_authority_widening": { "type": "boolean" },
          "qualification": {
            "type": "string",
            "enum": ["stable", "beta", "not_applicable"]
          },
          "claimed_stable": { "type": "boolean" }
        }
      },
      "minItems": 1
    },
    "evidence_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "json_export_ref",
        "markdown_summary_ref",
        "admin_inspector_ref",
        "support_export_ref",
        "rollback_lineage_refs",
        "export_lineage_refs"
      ],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "json_export_ref": { "type": "string", "minLength": 1 },
        "markdown_summary_ref": { "type": "string", "minLength": 1 },
        "admin_inspector_ref": { "type": "string", "minLength": 1 },
        "support_export_ref": { "type": "string", "minLength": 1 },
        "rollback_lineage_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "export_lineage_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "source_contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  }
}
