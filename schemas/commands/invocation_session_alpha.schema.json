{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/invocation_session_alpha.schema.json",
  "title": "Aureline alpha command invocation-session and result baseline",
  "description": "Alpha publication schema for checked-in invocation-session and result baseline fixtures. These fixtures prove issuing surface, argument provenance, context snapshot, preflight decision, route/policy source, actor, outcome, artifact refs, checkpoint refs, rollback refs, and export-safe redaction posture for the launch-wedge command set.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/invocation_session_packet_record" },
    { "$ref": "#/$defs/command_result_packet_record" },
    { "$ref": "#/$defs/disabled_reason_alpha_fixture_record" }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": ["string", "null"]
    },
    "disabled_reason_code": {
      "type": "string",
      "enum": [
        "workspace_trust_restricted",
        "capability_lifecycle_retired",
        "capability_disabled_by_policy",
        "kill_switch_tripped",
        "client_scope_excludes_surface",
        "freshness_floor_unmet",
        "required_provider_unlinked",
        "required_credential_missing",
        "required_argument_unresolved",
        "execution_context_unavailable",
        "managed_only_channel_required",
        "dependency_state_below_command_ceiling",
        "command_deprecated_within_window",
        "command_retired",
        "command_version_unknown",
        "preview_denial_no_safe_preview",
        "approval_denial_no_approval_path",
        "publisher_not_permitted",
        "policy_blocked_in_context",
        "authority_class_unresolved",
        "issuing_surface_unresolved",
        "scope_class_drifted_from_descriptor",
        "preview_required_not_shown",
        "basis_snapshot_drifted"
      ]
    },
    "argument_provenance_entry": {
      "type": "object",
      "required": ["argument_name", "provenance", "resolved_value_ref"],
      "properties": {
        "argument_name": { "$ref": "#/$defs/non_empty_string" },
        "provenance": { "$ref": "#/$defs/non_empty_string" },
        "resolved_value_ref": { "$ref": "#/$defs/nullable_string" }
      },
      "additionalProperties": false
    },
    "policy_context": {
      "type": "object",
      "required": ["policy_epoch", "trust_state", "execution_context_id"],
      "properties": {
        "policy_epoch": { "$ref": "#/$defs/non_empty_string" },
        "trust_state": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_id": { "$ref": "#/$defs/nullable_string" }
      },
      "additionalProperties": true
    },
    "repair_hook_ref": {
      "type": "object",
      "required": ["hook_kind", "hook_id", "display_label"],
      "properties": {
        "hook_kind": { "$ref": "#/$defs/non_empty_string" },
        "hook_id": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": true
    },
    "enablement_decision": {
      "type": "object",
      "required": ["decision_class", "disabled_reason_code", "repair_hook_ref"],
      "properties": {
        "decision_class": {
          "type": "string",
          "enum": ["enabled", "disabled_with_reason", "hidden_with_reason"]
        },
        "disabled_reason_code": {
          "oneOf": [
            { "$ref": "#/$defs/disabled_reason_code" },
            { "type": "null" }
          ]
        },
        "repair_hook_ref": {
          "oneOf": [
            { "$ref": "#/$defs/repair_hook_ref" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "preview_posture": {
      "type": "object",
      "required": ["preview_class_declared", "preview_shown", "preview_record_ref"],
      "properties": {
        "preview_class_declared": { "$ref": "#/$defs/non_empty_string" },
        "preview_shown": { "type": "boolean" },
        "preview_record_ref": { "$ref": "#/$defs/nullable_string" }
      },
      "additionalProperties": false
    },
    "approval_posture": {
      "type": "object",
      "required": ["approval_posture_class_declared", "approval_state", "approval_ticket_ref"],
      "properties": {
        "approval_posture_class_declared": { "$ref": "#/$defs/non_empty_string" },
        "approval_state": { "$ref": "#/$defs/non_empty_string" },
        "approval_ticket_ref": { "$ref": "#/$defs/nullable_string" }
      },
      "additionalProperties": false
    },
    "context_snapshot": {
      "type": "object",
      "required": [
        "focused_entity_ref",
        "selection_ref",
        "workspace_trust_state",
        "execution_context_id",
        "scope_filter_class_ref",
        "basis_snapshot_ref"
      ],
      "properties": {
        "focused_entity_ref": { "$ref": "#/$defs/nullable_string" },
        "selection_ref": { "$ref": "#/$defs/nullable_string" },
        "workspace_trust_state": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_id": { "$ref": "#/$defs/nullable_string" },
        "scope_filter_class_ref": { "$ref": "#/$defs/nullable_string" },
        "basis_snapshot_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "route_policy_source": {
      "type": "object",
      "required": [
        "command_router_ref",
        "route_class",
        "policy_source_class",
        "policy_epoch"
      ],
      "properties": {
        "command_router_ref": { "$ref": "#/$defs/non_empty_string" },
        "route_class": { "$ref": "#/$defs/non_empty_string" },
        "policy_source_class": { "$ref": "#/$defs/non_empty_string" },
        "policy_epoch": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "invocation_outcome": {
      "type": "object",
      "required": [
        "outcome_class",
        "disabled_reason_code",
        "warnings_summary_refs",
        "partially_applied_artifact_refs",
        "unapplied_artifact_refs"
      ],
      "properties": {
        "outcome_class": { "$ref": "#/$defs/non_empty_string" },
        "disabled_reason_code": {
          "oneOf": [
            { "$ref": "#/$defs/disabled_reason_code" },
            { "type": "null" }
          ]
        },
        "warnings_summary_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "partially_applied_artifact_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "unapplied_artifact_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      },
      "additionalProperties": false
    },
    "created_artifact_ref": {
      "type": "object",
      "required": ["result_contract_class", "artifact_ref"],
      "properties": {
        "result_contract_class": { "$ref": "#/$defs/non_empty_string" },
        "artifact_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "evidence_ref": {
      "type": "object",
      "required": ["evidence_ref_class", "evidence_id"],
      "properties": {
        "evidence_ref_class": { "$ref": "#/$defs/non_empty_string" },
        "evidence_id": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "invocation_session_packet_record": {
      "type": "object",
      "required": [
        "record_kind",
        "command_descriptor_schema_version",
        "invocation_session_id",
        "command_id",
        "command_revision_ref",
        "issuing_surface",
        "authority_class",
        "argument_provenance_map",
        "context_snapshot",
        "route_policy_source",
        "enablement_decision",
        "preview_posture",
        "approval_posture",
        "execution_intent",
        "outcome",
        "created_artifact_refs",
        "evidence_refs",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "record_kind": { "const": "invocation_session_packet_record" },
        "command_descriptor_schema_version": { "type": "integer", "const": 1 },
        "invocation_session_id": { "$ref": "#/$defs/non_empty_string" },
        "command_id": { "$ref": "#/$defs/non_empty_string" },
        "command_revision_ref": { "$ref": "#/$defs/non_empty_string" },
        "issuing_surface": { "$ref": "#/$defs/non_empty_string" },
        "authority_class": { "$ref": "#/$defs/non_empty_string" },
        "argument_provenance_map": {
          "type": "array",
          "items": { "$ref": "#/$defs/argument_provenance_entry" }
        },
        "context_snapshot": { "$ref": "#/$defs/context_snapshot" },
        "route_policy_source": { "$ref": "#/$defs/route_policy_source" },
        "enablement_decision": { "$ref": "#/$defs/enablement_decision" },
        "preview_posture": { "$ref": "#/$defs/preview_posture" },
        "approval_posture": { "$ref": "#/$defs/approval_posture" },
        "execution_intent": { "$ref": "#/$defs/non_empty_string" },
        "outcome": { "$ref": "#/$defs/invocation_outcome" },
        "created_artifact_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/created_artifact_ref" }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_ref" }
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/non_empty_string" },
        "minted_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "command_result_packet_record": {
      "$ref": "result_packet.schema.json#/$defs/command_result_packet_record"
    },
    "disabled_reason_alpha_fixture_record": {
      "type": "object",
      "required": ["record_kind", "schema_version", "case_id", "cause_family", "command_id", "disabled_reason_code", "repair_hook_ref"],
      "properties": {
        "record_kind": { "const": "disabled_reason_alpha_fixture_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "case_id": { "$ref": "#/$defs/non_empty_string" },
        "cause_family": { "$ref": "#/$defs/non_empty_string" },
        "command_id": { "$ref": "#/$defs/non_empty_string" },
        "disabled_reason_code": { "$ref": "#/$defs/disabled_reason_code" },
        "repair_hook_ref": { "$ref": "#/$defs/repair_hook_ref" },
        "surface_disclosure": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": true
    }
  }
}
