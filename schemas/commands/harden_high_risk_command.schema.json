{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/harden_high_risk_command.schema.json",
  "title": "Aureline hardened high-risk command record",
  "$comment": "Rust owner: aureline_commands::harden_high_risk_command::HighRiskCommandHardeningPacket.",
  "description": "Boundary schema for the metadata-only hardened high-risk command record. For one canonical high-risk command family on a claimed stable row, the packet binds the declared high-risk effect classes, the high-risk preview contract (a required, non-bypassable preview that shows the effect summary, scope/targets, dominant side-effect, provider/route disclosure, spend/egress disclosure, and tainted-context handling, with an apply-guard ref and a no-blind-apply guard), the approval lineage (the requested/reviewed/granted/recorded-in-audit chain, each record carrying an authority class, decision ref, and basis snapshot ref, bound to one policy epoch, with no-self-approval, no-authority-widening, and enforced-expiry guards), the rollback-handle issuance contract (an issued, replayable handle bound to checkpoint refs and the in-product evidence id, with a typed revert posture and no-durable-apply-without-handle guard), and the cross-surface authority-parity rows that prove menu/button, keybinding, palette, CLI/headless, AI tool, voice, recipe, deep link, and browser companion enforce the same preview, approval, rollback, route disclosure, and policy without widening authority or claiming the Stable lane while narrowed below it, plus exportable evidence/rollback lineage. It does not re-derive the descriptor, registry, invocation, result, authority, or preview-gate models; it binds them by their canonical schema refs. It carries refs, state tokens, coarse classes, counts, and review labels only. It never carries raw command arguments, raw prompt bodies, raw diff bodies, source file bodies, endpoint URLs, credentials, or signing-key material. Adding a new enum member or a new optional field is additive-minor; repurposing an existing member is breaking and bumps schema_version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "command_family_id",
    "display_label",
    "claimed_stable",
    "policy_epoch_ref",
    "contract_refs",
    "risk_classes",
    "preview_contract",
    "approval_lineage",
    "rollback_handle",
    "surface_parity_rows",
    "evidence_export",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "high_risk_command_hardening_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "command_family_id": { "type": "string", "minLength": 1 },
    "display_label": { "type": "string", "minLength": 1 },
    "claimed_stable": { "type": "boolean" },
    "policy_epoch_ref": { "type": "string", "minLength": 1 },
    "contract_refs": { "$ref": "#/$defs/stable_contract_refs" },
    "risk_classes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/high_risk_class" }
    },
    "preview_contract": { "$ref": "#/$defs/high_risk_preview_contract" },
    "approval_lineage": { "$ref": "#/$defs/approval_lineage_contract" },
    "rollback_handle": { "$ref": "#/$defs/rollback_handle_contract" },
    "surface_parity_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/high_risk_surface_parity_row" }
    },
    "evidence_export": { "$ref": "#/$defs/evidence_export_block" },
    "source_contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "high_risk_class": {
      "type": "string",
      "enum": [
        "destructive_filesystem",
        "bulk_multi_file_edit",
        "irreversible_vcs",
        "external_network_effect",
        "credential_or_secret_access",
        "spend_incurring",
        "policy_sensitive_automation"
      ]
    },
    "preview_requirement_class": {
      "type": "string",
      "enum": [
        "effect_summary",
        "scope_and_targets",
        "diff_or_impact",
        "route_and_spend_disclosure",
        "destructive_confirmation"
      ]
    },
    "approval_authority_class": {
      "type": "string",
      "enum": [
        "self_only",
        "workspace_owner",
        "policy_admin",
        "second_human_reviewer",
        "managed_policy_gate"
      ]
    },
    "approval_step_class": {
      "type": "string",
      "enum": ["requested", "reviewed", "granted", "recorded_in_audit"]
    },
    "rollback_posture_class": {
      "type": "string",
      "enum": [
        "fully_reversible",
        "checkpoint_revert",
        "compensating_action",
        "irreversible_with_explicit_confirmation",
        "no_rollback_available"
      ]
    },
    "command_surface_class": {
      "type": "string",
      "enum": [
        "menu_or_button",
        "keybinding",
        "command_palette",
        "cli_headless",
        "ai_tool",
        "voice",
        "recipe",
        "deep_link",
        "browser_companion"
      ]
    },
    "surface_qualification_class": {
      "type": "string",
      "enum": ["stable", "beta", "experimental", "not_applicable"]
    },
    "stable_contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "descriptor_schema_ref",
        "registry_entry_schema_ref",
        "registry_seed_ref",
        "invocation_session_schema_ref",
        "result_packet_schema_ref",
        "public_contract_schema_ref",
        "parity_expectation_schema_ref",
        "disabled_reason_vocabulary_ref"
      ],
      "properties": {
        "descriptor_schema_ref": { "type": "string", "minLength": 1 },
        "registry_entry_schema_ref": { "type": "string", "minLength": 1 },
        "registry_seed_ref": { "type": "string", "minLength": 1 },
        "invocation_session_schema_ref": { "type": "string", "minLength": 1 },
        "result_packet_schema_ref": { "type": "string", "minLength": 1 },
        "public_contract_schema_ref": { "type": "string", "minLength": 1 },
        "parity_expectation_schema_ref": { "type": "string", "minLength": 1 },
        "disabled_reason_vocabulary_ref": { "type": "string", "minLength": 1 }
      }
    },
    "high_risk_preview_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "requirements",
        "shows_effect_summary",
        "shows_scope_and_targets",
        "shows_dominant_side_effect",
        "discloses_route_and_provider",
        "discloses_spend_and_egress",
        "surfaces_tainted_context",
        "apply_guard_ref",
        "no_blind_apply"
      ],
      "properties": {
        "required": { "type": "boolean" },
        "requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/preview_requirement_class" }
        },
        "shows_effect_summary": { "type": "boolean" },
        "shows_scope_and_targets": { "type": "boolean" },
        "shows_dominant_side_effect": { "type": "boolean" },
        "discloses_route_and_provider": { "type": "boolean" },
        "discloses_spend_and_egress": { "type": "boolean" },
        "surfaces_tainted_context": { "type": "boolean" },
        "apply_guard_ref": { "type": "string", "minLength": 1 },
        "no_blind_apply": { "type": "boolean" }
      }
    },
    "approval_lineage_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_class",
        "authority_class",
        "decision_ref",
        "basis_snapshot_ref",
        "recorded_in_audit"
      ],
      "properties": {
        "step_class": { "$ref": "#/$defs/approval_step_class" },
        "authority_class": { "$ref": "#/$defs/approval_authority_class" },
        "decision_ref": { "type": "string", "minLength": 1 },
        "basis_snapshot_ref": { "type": "string", "minLength": 1 },
        "recorded_in_audit": { "type": "boolean" }
      }
    },
    "approval_lineage_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "requester_authority",
        "approver_authority",
        "records",
        "policy_epoch_ref",
        "basis_snapshot_ref",
        "no_self_approval",
        "no_authority_widening",
        "expiry_enforced"
      ],
      "properties": {
        "required": { "type": "boolean" },
        "requester_authority": { "$ref": "#/$defs/approval_authority_class" },
        "approver_authority": { "$ref": "#/$defs/approval_authority_class" },
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/approval_lineage_record" }
        },
        "policy_epoch_ref": { "type": "string", "minLength": 1 },
        "basis_snapshot_ref": { "type": "string", "minLength": 1 },
        "no_self_approval": { "type": "boolean" },
        "no_authority_widening": { "type": "boolean" },
        "expiry_enforced": { "type": "boolean" }
      }
    },
    "rollback_handle_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issued",
        "handle_ref",
        "posture",
        "checkpoint_refs",
        "bound_to_evidence_id",
        "no_durable_apply_without_handle",
        "revert_replayable"
      ],
      "properties": {
        "issued": { "type": "boolean" },
        "handle_ref": { "type": "string", "minLength": 1 },
        "posture": { "$ref": "#/$defs/rollback_posture_class" },
        "checkpoint_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "bound_to_evidence_id": { "type": "boolean" },
        "no_durable_apply_without_handle": { "type": "boolean" },
        "revert_replayable": { "type": "boolean" }
      }
    },
    "high_risk_surface_parity_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "descriptor_ref",
        "reachable",
        "enforces_preview",
        "enforces_approval",
        "issues_rollback_handle",
        "discloses_route",
        "policy_checked",
        "no_authority_widening",
        "qualification",
        "claimed_stable"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/command_surface_class" },
        "descriptor_ref": { "type": "string", "minLength": 1 },
        "reachable": { "type": "boolean" },
        "enforces_preview": { "type": "boolean" },
        "enforces_approval": { "type": "boolean" },
        "issues_rollback_handle": { "type": "boolean" },
        "discloses_route": { "type": "boolean" },
        "policy_checked": { "type": "boolean" },
        "no_authority_widening": { "type": "boolean" },
        "qualification": { "$ref": "#/$defs/surface_qualification_class" },
        "claimed_stable": { "type": "boolean" }
      }
    },
    "evidence_export_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "json_export_ref",
        "markdown_summary_ref",
        "admin_inspector_ref",
        "support_export_ref",
        "rollback_lineage_refs",
        "export_lineage_refs"
      ],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "json_export_ref": { "type": "string", "minLength": 1 },
        "markdown_summary_ref": { "type": "string", "minLength": 1 },
        "admin_inspector_ref": { "type": "string", "minLength": 1 },
        "support_export_ref": { "type": "string", "minLength": 1 },
        "rollback_lineage_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "export_lineage_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
