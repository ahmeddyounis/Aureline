{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/commands/m5_command_governance.schema.json",
  "title": "M5 Command Governance Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "schema_ref",
    "doc_ref",
    "source_registry_ref",
    "rows",
    "summary"
  ],
  "properties": {
    "record_kind": {
      "const": "m5_command_governance_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "schema_ref": {
      "type": "string",
      "minLength": 1
    },
    "doc_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_registry_ref": {
      "type": "string",
      "minLength": 1
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/command_row"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "surface_class": {
      "type": "string",
      "enum": [
        "desktop",
        "cli",
        "ai",
        "recipe",
        "extension",
        "browser_companion"
      ]
    },
    "route_posture_class": {
      "type": "string",
      "enum": [
        "direct_allowed",
        "preview_required",
        "approval_required",
        "diagnostics_required",
        "desktop_handoff_required"
      ]
    },
    "approval_model_class": {
      "type": "string",
      "enum": [
        "no_approval_required",
        "human_confirm_required"
      ]
    },
    "disabled_reason_family": {
      "type": "string",
      "enum": [
        "focus_mismatch",
        "trust_blocked",
        "policy_blocked",
        "rollout_blocked",
        "missing_runtime",
        "missing_capability_state",
        "preview_required",
        "approval_required"
      ]
    },
    "copy_safe_introspection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "copy_command_id",
        "copy_cli_form",
        "add_to_recipe",
        "inspect_why_not_automatable"
      ],
      "properties": {
        "copy_command_id": {
          "type": "boolean"
        },
        "copy_cli_form": {
          "type": "boolean"
        },
        "add_to_recipe": {
          "type": "boolean"
        },
        "inspect_why_not_automatable": {
          "type": "boolean"
        }
      }
    },
    "preview_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_class",
        "dry_run_supported",
        "copy_safe_introspection",
        "why_not_automatable_reason",
        "export_safe"
      ],
      "properties": {
        "preview_class": {
          "type": "string",
          "minLength": 1
        },
        "dry_run_supported": {
          "type": "boolean"
        },
        "copy_safe_introspection": {
          "$ref": "#/$defs/copy_safe_introspection"
        },
        "why_not_automatable_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "export_safe": {
          "type": "boolean"
        }
      }
    },
    "disabled_reason_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "command_id",
        "surface_class",
        "reason_family",
        "disabled_reason_code",
        "explanation_ref",
        "repair_hook_id",
        "actor_ref",
        "target_ref",
        "trust_epoch_ref",
        "rollout_state_ref",
        "redaction_class",
        "support_export_safe"
      ],
      "properties": {
        "packet_id": {
          "type": "string",
          "minLength": 1
        },
        "command_id": {
          "type": "string",
          "minLength": 1
        },
        "surface_class": {
          "$ref": "#/$defs/surface_class"
        },
        "reason_family": {
          "$ref": "#/$defs/disabled_reason_family"
        },
        "disabled_reason_code": {
          "type": "string",
          "minLength": 1
        },
        "explanation_ref": {
          "type": "string",
          "minLength": 1
        },
        "repair_hook_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "actor_ref": {
          "type": "string",
          "minLength": 1
        },
        "target_ref": {
          "type": "string",
          "minLength": 1
        },
        "trust_epoch_ref": {
          "type": "string",
          "minLength": 1
        },
        "rollout_state_ref": {
          "type": "string",
          "minLength": 1
        },
        "redaction_class": {
          "type": "string",
          "minLength": 1
        },
        "support_export_safe": {
          "type": "boolean"
        }
      }
    },
    "approval_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "command_id",
        "surface_class",
        "preview_class",
        "approval_model_class",
        "decision_class",
        "actor_ref",
        "target_ref",
        "trust_epoch_ref",
        "rollout_state_ref",
        "no_bypass_rule_preserved",
        "support_export_safe"
      ],
      "properties": {
        "packet_id": {
          "type": "string",
          "minLength": 1
        },
        "command_id": {
          "type": "string",
          "minLength": 1
        },
        "surface_class": {
          "$ref": "#/$defs/surface_class"
        },
        "preview_class": {
          "type": "string",
          "minLength": 1
        },
        "approval_model_class": {
          "$ref": "#/$defs/approval_model_class"
        },
        "decision_class": {
          "type": "string",
          "minLength": 1
        },
        "actor_ref": {
          "type": "string",
          "minLength": 1
        },
        "target_ref": {
          "type": "string",
          "minLength": 1
        },
        "trust_epoch_ref": {
          "type": "string",
          "minLength": 1
        },
        "rollout_state_ref": {
          "type": "string",
          "minLength": 1
        },
        "no_bypass_rule_preserved": {
          "type": "boolean"
        },
        "support_export_safe": {
          "type": "boolean"
        }
      }
    },
    "surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "client_scope",
        "route_posture_class",
        "preview_parity",
        "disabled_reason_packets",
        "approval_parity_packet",
        "preview_parity_preserved",
        "approval_parity_preserved",
        "disabled_reason_parity_preserved"
      ],
      "properties": {
        "surface_class": {
          "$ref": "#/$defs/surface_class"
        },
        "client_scope": {
          "type": "string",
          "minLength": 1
        },
        "route_posture_class": {
          "$ref": "#/$defs/route_posture_class"
        },
        "preview_parity": {
          "$ref": "#/$defs/preview_parity"
        },
        "disabled_reason_packets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/disabled_reason_packet"
          }
        },
        "approval_parity_packet": {
          "$ref": "#/$defs/approval_packet"
        },
        "preview_parity_preserved": {
          "type": "boolean"
        },
        "approval_parity_preserved": {
          "type": "boolean"
        },
        "disabled_reason_parity_preserved": {
          "type": "boolean"
        }
      }
    },
    "command_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "command_revision_ref",
        "canonical_verb",
        "lifecycle_state",
        "capability_scope_class",
        "preview_class",
        "approval_posture_class",
        "ai_tool_surfacing_class",
        "automation_labels",
        "invocation_schema_ref",
        "result_schema_ref",
        "preview_gate_declared",
        "high_risk",
        "surface_rows",
        "finding_codes"
      ],
      "properties": {
        "command_id": {
          "type": "string",
          "minLength": 1
        },
        "command_revision_ref": {
          "type": "string",
          "minLength": 1
        },
        "canonical_verb": {
          "type": "string",
          "minLength": 1
        },
        "lifecycle_state": {
          "type": "string",
          "minLength": 1
        },
        "capability_scope_class": {
          "type": "string",
          "minLength": 1
        },
        "preview_class": {
          "type": "string",
          "minLength": 1
        },
        "approval_posture_class": {
          "type": "string",
          "minLength": 1
        },
        "ai_tool_surfacing_class": {
          "type": "string",
          "minLength": 1
        },
        "automation_labels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "invocation_schema_ref": {
          "type": "string",
          "minLength": 1
        },
        "result_schema_ref": {
          "type": "string",
          "minLength": 1
        },
        "preview_gate_declared": {
          "type": "boolean"
        },
        "high_risk": {
          "type": "boolean"
        },
        "surface_rows": {
          "type": "array",
          "minItems": 6,
          "items": {
            "$ref": "#/$defs/surface_row"
          }
        },
        "finding_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_count",
        "surface_row_count",
        "high_risk_command_count",
        "preview_gate_count",
        "missing_preview_gate_count",
        "finding_count"
      ],
      "properties": {
        "command_count": {
          "type": "integer",
          "minimum": 0
        },
        "surface_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "high_risk_command_count": {
          "type": "integer",
          "minimum": 0
        },
        "preview_gate_count": {
          "type": "integer",
          "minimum": 0
        },
        "missing_preview_gate_count": {
          "type": "integer",
          "minimum": 0
        },
        "finding_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
