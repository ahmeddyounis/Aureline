{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/review/freeze-the-m5-work-item-provider-link-acting-identity-and-publish-later-continuity-matrix.schema.json",
  "title": "M5 Provider-Work-Item Governance Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "matrix_label",
    "object_vocabulary_rows",
    "acting_identity_rows",
    "truth_state_rows",
    "lane_rows",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "freeze_m5_work_item_provider_link_acting_identity_and_publish_later_continuity_matrix"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "matrix_label": {
      "type": "string",
      "minLength": 1
    },
    "object_vocabulary_rows": {
      "type": "array",
      "minItems": 6,
      "items": {
        "$ref": "#/$defs/objectVocabularyRow"
      }
    },
    "acting_identity_rows": {
      "type": "array",
      "minItems": 6,
      "items": {
        "$ref": "#/$defs/actingIdentityRow"
      }
    },
    "truth_state_rows": {
      "type": "array",
      "minItems": 7,
      "items": {
        "$ref": "#/$defs/truthStateRow"
      }
    },
    "lane_rows": {
      "type": "array",
      "minItems": 6,
      "items": {
        "$ref": "#/$defs/laneRow"
      }
    },
    "trust_review": {
      "$ref": "#/$defs/trustReview"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumerProjection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proofFreshness"
    },
    "source_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "redaction_class_token": {
      "type": "string",
      "minLength": 1
    },
    "minted_at": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "objectClass": {
      "type": "string",
      "enum": [
        "provider_work_item",
        "review_linked_change_intent",
        "browser_handoff_packet",
        "deferred_publish_packet",
        "imported_snapshot",
        "provider_event_envelope"
      ]
    },
    "actingIdentityClass": {
      "type": "string",
      "enum": [
        "human_account",
        "installation_grant",
        "delegated_credential",
        "browser_only_fallback",
        "denied_scope",
        "publish_later_local_draft"
      ]
    },
    "effectiveScopeClass": {
      "type": "string",
      "enum": [
        "provider_mutation",
        "limited_comment_link",
        "browser_only_fallback",
        "denied_scope",
        "publish_later_local_draft"
      ]
    },
    "truthStateClass": {
      "type": "string",
      "enum": [
        "local_draft",
        "queued_publish",
        "provider_committed",
        "stale_snapshot",
        "partial_scope",
        "mirror_derived",
        "callback_denied"
      ]
    },
    "lane": {
      "type": "string",
      "enum": [
        "work_item_object_vocabulary",
        "provider_linked_mutation",
        "acting_identity_and_effective_scope",
        "browser_handoff_continuity",
        "deferred_publish_continuity",
        "provider_event_reconciliation"
      ]
    },
    "qualification": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "evidenceRequirement": {
      "type": "string",
      "enum": [
        "required",
        "recommended",
        "optional",
        "not_applicable"
      ]
    },
    "downgradeTrigger": {
      "type": "string",
      "enum": [
        "provider_authority_stale",
        "effective_scope_drift",
        "browser_only_fallback",
        "return_anchor_unproven",
        "publish_later_continuity_stale",
        "callback_reconciliation_stale",
        "replay_ledger_unavailable",
        "callback_denied",
        "imported_snapshot_stale",
        "upstream_dependency_narrowed"
      ]
    },
    "rollbackPosture": {
      "type": "string",
      "enum": [
        "local_draft_preserved",
        "attributable_publish_later",
        "return_anchor_preserved",
        "audit_only_no_mutation",
        "provider_committed_distinct",
        "not_applicable"
      ]
    },
    "consumerSurface": {
      "type": "string",
      "enum": [
        "review_workspace",
        "work_item_detail",
        "incident_workspace",
        "companion_triage",
        "browser_handoff",
        "cli_headless",
        "support_export",
        "docs_help",
        "release_packet"
      ]
    },
    "objectVocabularyRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_class",
        "summary",
        "provider_authority_visible",
        "acting_identity_visible",
        "effective_scope_visible",
        "local_anchor_required",
        "state_classes"
      ],
      "properties": {
        "object_class": {
          "$ref": "#/$defs/objectClass"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "provider_authority_visible": {
          "type": "boolean"
        },
        "acting_identity_visible": {
          "type": "boolean"
        },
        "effective_scope_visible": {
          "type": "boolean"
        },
        "local_anchor_required": {
          "type": "boolean"
        },
        "state_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/truthStateClass"
          }
        }
      }
    },
    "actingIdentityRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity_class",
        "effective_scope_class",
        "summary",
        "publish_now_allowed",
        "browser_handoff_required",
        "denied_scope_visible",
        "local_draft_continuity_preserved"
      ],
      "properties": {
        "identity_class": {
          "$ref": "#/$defs/actingIdentityClass"
        },
        "effective_scope_class": {
          "$ref": "#/$defs/effectiveScopeClass"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "publish_now_allowed": {
          "type": "boolean"
        },
        "browser_handoff_required": {
          "type": "boolean"
        },
        "denied_scope_visible": {
          "type": "boolean"
        },
        "local_draft_continuity_preserved": {
          "type": "boolean"
        }
      }
    },
    "truthStateRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truth_state_class",
        "summary",
        "provider_authoritative",
        "local_continuity_preserved",
        "review_before_replay_required",
        "lineage_visible"
      ],
      "properties": {
        "truth_state_class": {
          "$ref": "#/$defs/truthStateClass"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "provider_authoritative": {
          "type": "boolean"
        },
        "local_continuity_preserved": {
          "type": "boolean"
        },
        "review_before_replay_required": {
          "type": "boolean"
        },
        "lineage_visible": {
          "type": "boolean"
        }
      }
    },
    "laneRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane",
        "qualification",
        "scope_summary",
        "evidence_requirement",
        "required_evidence_packet_refs",
        "downgrade_triggers",
        "rollback_posture",
        "source_contract_refs",
        "consumer_surfaces"
      ],
      "properties": {
        "lane": {
          "$ref": "#/$defs/lane"
        },
        "qualification": {
          "$ref": "#/$defs/qualification"
        },
        "scope_summary": {
          "type": "string",
          "minLength": 1
        },
        "evidence_requirement": {
          "$ref": "#/$defs/evidenceRequirement"
        },
        "required_evidence_packet_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgradeTrigger"
          }
        },
        "rollback_posture": {
          "$ref": "#/$defs/rollbackPosture"
        },
        "source_contract_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/consumerSurface"
          }
        }
      }
    },
    "trustReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_objects_never_masquerade_as_local_truth",
        "publish_mode_explicit",
        "acting_identity_visible",
        "effective_scope_visible",
        "local_and_provider_state_distinct",
        "imported_snapshot_never_claims_provider_commit",
        "browser_handoff_return_anchor_safe",
        "deferred_publish_survives_restart",
        "deferred_publish_survives_reconnect",
        "callback_events_deduplicated",
        "callback_denials_auditable",
        "downgrade_narrows_instead_of_hides"
      ],
      "properties": {
        "provider_objects_never_masquerade_as_local_truth": { "type": "boolean" },
        "publish_mode_explicit": { "type": "boolean" },
        "acting_identity_visible": { "type": "boolean" },
        "effective_scope_visible": { "type": "boolean" },
        "local_and_provider_state_distinct": { "type": "boolean" },
        "imported_snapshot_never_claims_provider_commit": { "type": "boolean" },
        "browser_handoff_return_anchor_safe": { "type": "boolean" },
        "deferred_publish_survives_restart": { "type": "boolean" },
        "deferred_publish_survives_reconnect": { "type": "boolean" },
        "callback_events_deduplicated": { "type": "boolean" },
        "callback_denials_auditable": { "type": "boolean" },
        "downgrade_narrows_instead_of_hides": { "type": "boolean" }
      }
    },
    "consumerProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_workspace_reuses_canonical_vocabulary",
        "work_item_detail_shows_identity_scope_and_state",
        "incident_workspace_preserves_provider_lineage",
        "companion_triage_shows_scoped_draft_or_handoff_truth",
        "browser_handoff_shows_reason_and_return_anchor",
        "cli_headless_shows_qualification",
        "support_export_shows_provider_authority_and_state",
        "docs_help_shows_publish_mode_terminology",
        "release_packet_shows_qualification_and_narrowing"
      ],
      "properties": {
        "review_workspace_reuses_canonical_vocabulary": { "type": "boolean" },
        "work_item_detail_shows_identity_scope_and_state": { "type": "boolean" },
        "incident_workspace_preserves_provider_lineage": { "type": "boolean" },
        "companion_triage_shows_scoped_draft_or_handoff_truth": { "type": "boolean" },
        "browser_handoff_shows_reason_and_return_anchor": { "type": "boolean" },
        "cli_headless_shows_qualification": { "type": "boolean" },
        "support_export_shows_provider_authority_and_state": { "type": "boolean" },
        "docs_help_shows_publish_mode_terminology": { "type": "boolean" },
        "release_packet_shows_qualification_and_narrowing": { "type": "boolean" }
      }
    },
    "proofFreshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_authority_stale",
        "auto_narrow_on_reconciliation_stale",
        "auto_narrow_on_publish_later_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "minLength": 1
        },
        "auto_narrow_on_authority_stale": { "type": "boolean" },
        "auto_narrow_on_reconciliation_stale": { "type": "boolean" },
        "auto_narrow_on_publish_later_stale": { "type": "boolean" }
      }
    }
  }
}
