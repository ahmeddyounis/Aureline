{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/review/certify-launch-bundles-imported-user-handoff-bundles-and.schema.json",
  "title": "Aureline bundle-archetype certification packet",
  "description": "Boundary schema for the bundle-archetype certification packet emitted by crates/aureline-workspace. One packet binds a certified_bundle_identity, a machine-readable bundle_compatibility_scorecard with rows linking bundle id, imported-extension class, bridge state, supported deployment/profile rows, and certified reference-workspace ids, the bundle_certification_claim after the scorecard is applied (with automatic downgrade), an optional imported_handoff_report, and an inspection projection. A stable badge (certified or managed_approved) may only render when it resolves to a current scorecard row; parity is never implied from prose alone.",
  "type": "object",
  "$ref": "#/$defs/bundle_archetype_certification_packet",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log and safe in support/export packets."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "bundle_class": {
      "type": "string",
      "enum": [
        "launch_bundle",
        "imported_user_bundle",
        "org_approved_bundle",
        "design_partner_bundle",
        "local_draft_bundle"
      ]
    },
    "bundle_source_class": {
      "type": "string",
      "enum": [
        "certified",
        "managed_approved",
        "community",
        "imported",
        "local_draft"
      ]
    },
    "archetype_class": {
      "type": "string",
      "enum": [
        "tsjs_web",
        "python_service",
        "rust_systems",
        "polyglot_monorepo",
        "data_notebook",
        "imported_generic",
        "local_unclassified"
      ]
    },
    "certification_state_class": {
      "type": "string",
      "enum": [
        "certified_current",
        "managed_approved_current",
        "community_unverified",
        "imported_pending_review",
        "local_draft",
        "retest_pending",
        "certification_stale",
        "status_unknown"
      ]
    },
    "effective_badge_class": {
      "type": "string",
      "enum": [
        "certified",
        "managed_approved",
        "community",
        "imported",
        "local_draft",
        "retest_pending",
        "limited",
        "status_unknown"
      ]
    },
    "support_claim_class": {
      "type": "string",
      "enum": [
        "stable_launch_wedge_claim",
        "managed_org_claim",
        "community_no_certification_claim",
        "imported_pending_review_claim",
        "local_draft_no_claim",
        "limited_retest_pending_claim"
      ]
    },
    "claim_basis_class": {
      "type": "string",
      "enum": ["scorecard_row_backed", "prose_only"]
    },
    "scorecard_freshness_class": {
      "type": "string",
      "enum": [
        "fresh_current",
        "aging_within_window",
        "stale_past_window",
        "imported_evidence",
        "evidence_unknown"
      ]
    },
    "bridge_state_class": {
      "type": "string",
      "enum": [
        "exact_bridge",
        "partial_bridge",
        "approximate_bridge",
        "unsupported_bridge",
        "bridge_unknown"
      ]
    },
    "scorecard_downgrade_state_class": {
      "type": "string",
      "enum": [
        "no_downgrade",
        "downgraded_freshness_expired",
        "downgraded_bridge_narrowed",
        "downgraded_gap_detected"
      ]
    },
    "known_gap_state_class": {
      "type": "string",
      "enum": ["no_known_gaps", "known_gaps_disclosed", "gaps_unknown"]
    },
    "imported_extension_class": {
      "type": "string",
      "enum": [
        "mapped_native",
        "bridged_compatibility",
        "approximate_shim",
        "unsupported_extension",
        "not_applicable"
      ]
    },
    "distribution_class": {
      "type": "string",
      "enum": ["public_registry", "mirror_first", "offline_archive"]
    },
    "downgrade_reason": {
      "type": "string",
      "enum": [
        "scorecard_freshness_expired",
        "bridge_parity_narrowed",
        "known_gap_detected",
        "missing_scorecard_row",
        "scorecard_row_bundle_mismatch",
        "prose_only_claim",
        "reference_workspace_missing",
        "certification_state_stale"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "start_center_bundle_card",
        "bundle_detail_page",
        "diagnostics_lane",
        "cli_headless_install",
        "support_export",
        "docs_surface",
        "about_surface"
      ]
    },
    "certified_bundle_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "bundle_id",
        "bundle_revision",
        "bundle_class",
        "bundle_source_class",
        "archetype_class",
        "signer_source_class",
        "signer_ref",
        "compatible_aureline_range",
        "certification_state_class",
        "distribution_class"
      ],
      "properties": {
        "record_kind": { "const": "certified_bundle_identity" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "bundle_id": { "$ref": "#/$defs/opaque_id" },
        "bundle_revision": { "type": "integer", "minimum": 0 },
        "bundle_class": { "$ref": "#/$defs/bundle_class" },
        "bundle_source_class": { "$ref": "#/$defs/bundle_source_class" },
        "archetype_class": { "$ref": "#/$defs/archetype_class" },
        "signer_source_class": { "$ref": "#/$defs/opaque_id" },
        "signer_ref": { "$ref": "#/$defs/opaque_id" },
        "compatible_aureline_range": { "type": "string", "minLength": 1 },
        "certification_state_class": { "$ref": "#/$defs/certification_state_class" },
        "distribution_class": { "$ref": "#/$defs/distribution_class" }
      }
    },
    "bundle_compatibility_scorecard_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "row_id",
        "bundle_id_ref",
        "imported_extension_class",
        "bridge_state_class",
        "supported_deployment_refs",
        "supported_profile_refs",
        "certified_reference_workspace_ids",
        "freshness_class",
        "freshness_expires_at",
        "downgrade_state_class",
        "known_gap_state_class",
        "known_gap_refs",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "bundle_compatibility_scorecard_row" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "row_id": { "$ref": "#/$defs/opaque_id" },
        "bundle_id_ref": { "$ref": "#/$defs/opaque_id" },
        "imported_extension_class": { "$ref": "#/$defs/imported_extension_class" },
        "bridge_state_class": { "$ref": "#/$defs/bridge_state_class" },
        "supported_deployment_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "supported_profile_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "certified_reference_workspace_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "freshness_class": { "$ref": "#/$defs/scorecard_freshness_class" },
        "freshness_expires_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "downgrade_state_class": { "$ref": "#/$defs/scorecard_downgrade_state_class" },
        "known_gap_state_class": { "$ref": "#/$defs/known_gap_state_class" },
        "known_gap_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "bundle_compatibility_scorecard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "scorecard_id",
        "scorecard_ref",
        "generated_at",
        "rows"
      ],
      "properties": {
        "record_kind": { "const": "bundle_compatibility_scorecard" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "scorecard_id": { "$ref": "#/$defs/opaque_id" },
        "scorecard_ref": { "type": "string", "minLength": 1 },
        "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bundle_compatibility_scorecard_row" }
        }
      }
    },
    "bundle_certification_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "claimed_badge_class",
        "effective_badge_class",
        "support_claim_class",
        "claim_basis_class",
        "asserts_reference_workspace",
        "downgraded",
        "downgrade_reasons",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "bundle_certification_claim" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "claimed_badge_class": { "$ref": "#/$defs/effective_badge_class" },
        "effective_badge_class": { "$ref": "#/$defs/effective_badge_class" },
        "support_claim_class": { "$ref": "#/$defs/support_claim_class" },
        "claim_basis_class": { "$ref": "#/$defs/claim_basis_class" },
        "scorecard_row_ref": { "$ref": "#/$defs/opaque_id" },
        "asserts_reference_workspace": { "type": "boolean" },
        "downgraded": { "type": "boolean" },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason" }
        },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      },
      "allOf": [
        {
          "description": "A stable effective badge must be scorecard-backed and never downgraded.",
          "if": {
            "properties": {
              "effective_badge_class": { "enum": ["certified", "managed_approved"] }
            }
          },
          "then": {
            "properties": {
              "claim_basis_class": { "const": "scorecard_row_backed" },
              "downgraded": { "const": false }
            },
            "required": ["scorecard_row_ref"]
          }
        },
        {
          "description": "A downgraded claim must carry at least one reason.",
          "if": { "properties": { "downgraded": { "const": true } } },
          "then": {
            "properties": {
              "downgrade_reasons": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "imported_handoff_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "handoff_id",
        "migration_report_ref",
        "unsupported_item_refs",
        "partial_item_refs",
        "preserved",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "imported_handoff_report" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "handoff_id": { "$ref": "#/$defs/opaque_id" },
        "migration_report_ref": { "type": "string", "minLength": 1 },
        "unsupported_item_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "partial_item_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "preserved": { "type": "boolean" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "bundle_archetype_certification_inspection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "bundle_id_ref",
        "effective_badge_class",
        "stable_claim",
        "resolves_to_current_scorecard_row",
        "downgraded",
        "no_prose_only_stable_claim",
        "identity_consistent",
        "imported_handoff_preserved",
        "offline_parity_preserved",
        "no_hidden_authority_widening",
        "scorecard_row_count",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "bundle_archetype_certification_inspection" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "bundle_id_ref": { "$ref": "#/$defs/opaque_id" },
        "effective_badge_class": { "$ref": "#/$defs/effective_badge_class" },
        "stable_claim": { "type": "boolean" },
        "resolves_to_current_scorecard_row": { "type": "boolean" },
        "downgraded": { "type": "boolean" },
        "no_prose_only_stable_claim": { "const": true },
        "identity_consistent": { "const": true },
        "imported_handoff_preserved": { "const": true },
        "offline_parity_preserved": { "const": true },
        "no_hidden_authority_widening": { "const": true },
        "scorecard_row_count": { "type": "integer", "minimum": 1 },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "bundle_archetype_certification_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "generated_at",
        "identity",
        "scorecard",
        "claim",
        "consumer_surfaces",
        "source_schema_refs",
        "allows_hidden_setup_hooks",
        "allows_secret_injection",
        "allows_silent_trust_widening",
        "inspection"
      ],
      "properties": {
        "record_kind": { "const": "bundle_archetype_certification_packet" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "identity": { "$ref": "#/$defs/certified_bundle_identity" },
        "scorecard": { "$ref": "#/$defs/bundle_compatibility_scorecard" },
        "claim": { "$ref": "#/$defs/bundle_certification_claim" },
        "imported_handoff": { "$ref": "#/$defs/imported_handoff_report" },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/consumer_surface" }
        },
        "source_schema_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "allows_hidden_setup_hooks": { "const": false },
        "allows_secret_injection": { "const": false },
        "allows_silent_trust_widening": { "const": false },
        "inspection": { "$ref": "#/$defs/bundle_archetype_certification_inspection" }
      }
    }
  }
}
