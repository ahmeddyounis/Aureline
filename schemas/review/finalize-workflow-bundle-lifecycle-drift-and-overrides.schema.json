{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/review/finalize-workflow-bundle-lifecycle-drift-and-overrides.schema.json",
  "title": "Aureline bundle-lifecycle finalization record",
  "description": "Finalized workflow-bundle lifecycle record covering install/update/remove/rebase operations, drift detection with scorecard linkage, local override visibility, dependency marker honesty, trust/egress/control-plane change disclosure, and asset provenance classification for removal review. Consumed by Start Center, CLI/headless, diagnostics, support export, docs, and mirror-first/offline install surfaces.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "record_id",
    "generated_at",
    "operation",
    "dependency_markers",
    "drift_summary",
    "trust_egress_disclosures",
    "asset_provenance",
    "consumer_surfaces",
    "source_schema_refs",
    "inspection",
    "summary_label"
  ],
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "bundle_lifecycle_finalization_record"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "operation": {
      "$ref": "#/$defs/bundle_lifecycle_operation_record"
    },
    "dependency_markers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bundle_dependency_marker_record"
      }
    },
    "drift_summary": {
      "$ref": "#/$defs/scorecard_linked_drift_summary_record"
    },
    "trust_egress_disclosures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trust_egress_change_disclosure_record"
      }
    },
    "asset_provenance": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bundle_asset_provenance_record"
      }
    },
    "consumer_surfaces": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "start_center",
          "bundle_detail",
          "cli_headless",
          "diagnostics",
          "support_export",
          "docs_workspace",
          "mirror_first_install",
          "offline_archive_install"
        ]
      },
      "minItems": 1
    },
    "source_schema_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "inspection": {
      "$ref": "#/$defs/bundle_lifecycle_inspection_record"
    },
    "summary_label": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "bundle_lifecycle_operation_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "operation_kind",
        "bundle_id",
        "bundle_revision",
        "review_packet_id",
        "certification_packet_id",
        "rollback_checkpoint_ref"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "bundle_lifecycle_operation_record"
        },
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "operation_kind": {
          "type": "string",
          "enum": ["install", "update", "remove", "rebase"]
        },
        "bundle_id": {
          "type": "string",
          "minLength": 1
        },
        "bundle_revision": {
          "type": "integer",
          "minimum": 1
        },
        "review_packet_id": {
          "type": "string",
          "minLength": 1
        },
        "certification_packet_id": {
          "type": "string",
          "minLength": 1
        },
        "scorecard_row_ref": {
          "type": "string"
        },
        "rollback_checkpoint_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "bundle_dependency_marker_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "marker_id",
        "capability_class",
        "narrowing_class",
        "active_dependency",
        "disclosure_required",
        "summary_label"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "bundle_dependency_marker_record"
        },
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "marker_id": {
          "type": "string",
          "minLength": 1
        },
        "capability_class": {
          "type": "string",
          "enum": [
            "preview_learning_surface",
            "beta_learning_surface",
            "managed_seat_entitlement",
            "org_mirrored_content",
            "labs_only_capability",
            "stable_public_capability"
          ]
        },
        "narrowing_class": {
          "type": "string",
          "enum": [
            "no_narrowing",
            "narrowed_to_preview",
            "narrowed_to_beta",
            "narrowed_to_managed_only",
            "narrowed_to_org_mirror",
            "narrowed_to_labs",
            "narrowed_below_stable"
          ]
        },
        "active_dependency": {
          "type": "boolean"
        },
        "disclosure_required": {
          "type": "boolean"
        },
        "summary_label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scorecard_linked_drift_summary_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "summary_id",
        "drift_state_class",
        "drift_entries",
        "field_package_task_granular",
        "scorecard_id_ref",
        "scorecard_row_ref"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "scorecard_linked_drift_summary_record"
        },
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "summary_id": {
          "type": "string",
          "minLength": 1
        },
        "drift_state_class": {
          "type": "string",
          "minLength": 1
        },
        "drift_entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scorecard_linked_drift_entry"
          }
        },
        "field_package_task_granular": {
          "type": "boolean"
        },
        "scorecard_id_ref": {
          "type": "string",
          "minLength": 1
        },
        "scorecard_row_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scorecard_linked_drift_entry": {
      "type": "object",
      "required": [
        "entry_id",
        "drift_axis",
        "subject_ref",
        "claim_narrowing_class",
        "scorecard_linkage_preserved"
      ],
      "properties": {
        "entry_id": {
          "type": "string",
          "minLength": 1
        },
        "drift_axis": {
          "type": "string",
          "minLength": 1
        },
        "subject_ref": {
          "type": "string",
          "minLength": 1
        },
        "claim_narrowing_class": {
          "type": "string",
          "minLength": 1
        },
        "local_override_ref": {
          "type": "string"
        },
        "scorecard_linkage_preserved": {
          "type": "boolean"
        }
      }
    },
    "trust_egress_change_disclosure_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "disclosure_id",
        "change_class",
        "severity_class",
        "alters_authority_boundary",
        "summary_label"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "trust_egress_change_disclosure_record"
        },
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "disclosure_id": {
          "type": "string",
          "minLength": 1
        },
        "change_class": {
          "type": "string",
          "enum": [
            "trust_widened",
            "trust_narrowed",
            "egress_widened",
            "egress_narrowed",
            "managed_control_plane_increased",
            "managed_control_plane_decreased",
            "stable_to_preview",
            "stable_to_beta",
            "preview_to_stable",
            "beta_to_stable",
            "no_change"
          ]
        },
        "severity_class": {
          "type": "string",
          "enum": [
            "ordinary_package_churn",
            "capability_dependency_change",
            "trust_boundary_change",
            "egress_boundary_change",
            "managed_dependence_change",
            "certification_downgrade",
            "certification_upgrade"
          ]
        },
        "alters_authority_boundary": {
          "type": "boolean"
        },
        "summary_label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "bundle_asset_provenance_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "asset_ref",
        "asset_kind",
        "provenance_class",
        "bundle_created",
        "adopted",
        "user_owned"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "bundle_asset_provenance_record"
        },
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "asset_ref": {
          "type": "string",
          "minLength": 1
        },
        "asset_kind": {
          "type": "string",
          "minLength": 1
        },
        "provenance_class": {
          "type": "string",
          "enum": [
            "bundle_created",
            "bundle_adopted",
            "user_created_on_bundle",
            "user_created_independent",
            "mixed_unknown_provenance"
          ]
        },
        "bundle_created": {
          "type": "boolean"
        },
        "adopted": {
          "type": "boolean"
        },
        "user_owned": {
          "type": "boolean"
        }
      }
    },
    "bundle_lifecycle_inspection_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "record_id_ref",
        "operation_kind",
        "bundle_id",
        "effective_badge_class",
        "reversible",
        "dependency_markers_disclosed",
        "scorecard_linkage_preserved",
        "no_hidden_boundary_changes",
        "removal_preserves_user_assets",
        "support_export_safe",
        "dependency_marker_count",
        "drift_entry_count",
        "trust_egress_disclosure_count",
        "asset_provenance_count",
        "summary_label"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "bundle_lifecycle_inspection_record"
        },
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "record_id_ref": {
          "type": "string",
          "minLength": 1
        },
        "operation_kind": {
          "type": "string",
          "enum": ["install", "update", "remove", "rebase"]
        },
        "bundle_id": {
          "type": "string",
          "minLength": 1
        },
        "effective_badge_class": {
          "type": "string",
          "minLength": 1
        },
        "reversible": {
          "type": "boolean"
        },
        "dependency_markers_disclosed": {
          "type": "boolean"
        },
        "scorecard_linkage_preserved": {
          "type": "boolean"
        },
        "no_hidden_boundary_changes": {
          "type": "boolean"
        },
        "removal_preserves_user_assets": {
          "type": "boolean"
        },
        "support_export_safe": {
          "type": "boolean"
        },
        "dependency_marker_count": {
          "type": "integer",
          "minimum": 0
        },
        "drift_entry_count": {
          "type": "integer",
          "minimum": 0
        },
        "trust_egress_disclosure_count": {
          "type": "integer",
          "minimum": 0
        },
        "asset_provenance_count": {
          "type": "integer",
          "minimum": 0
        },
        "summary_label": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
