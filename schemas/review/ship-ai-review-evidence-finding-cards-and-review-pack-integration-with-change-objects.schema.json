{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/review/ship-ai-review-evidence-finding-cards-and-review-pack-integration-with-change-objects.schema.json",
  "title": "Aureline AI review evidence, finding cards, and review-pack integration with change objects",
  "description": "Export-safe packet binding AI-produced review evidence to the finding cards a reviewer reads and to the review pack and explicit change objects those cards are scoped against. Evidence rows carry an explicit source class, freshness state, and provenance label; finding cards carry severity, status, a durable anchor, the evidence they cite, an apply posture, and the change object they are scoped to; review-pack bindings bind a review pack to an explicit change object, record required-check coverage, and label detachment rather than silently dropping the binding. Raw diff bodies, raw model prompts or completions, raw build logs, raw provider payloads, credentials, and live provider responses never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "surface_label",
    "evidence_rows",
    "finding_cards",
    "review_pack_bindings",
    "downgrade_triggers",
    "consumer_surfaces",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "ai_review_evidence_finding_cards_and_review_pack_change_object_integration"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "surface_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "evidence_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_row"
      }
    },
    "finding_cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/finding_row"
      }
    },
    "review_pack_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/review_pack_binding_row"
      }
    },
    "downgrade_triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/downgrade_trigger"
      }
    },
    "consumer_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/consumer_surface"
      }
    },
    "trust_review": {
      "$ref": "#/$defs/trust_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "evidence_source": {
      "type": "string",
      "enum": [
        "model_generated",
        "static_analysis",
        "local_check",
        "provider_imported"
      ]
    },
    "evidence_freshness": {
      "type": "string",
      "enum": [
        "fresh",
        "stale_diff",
        "superseded",
        "unavailable"
      ]
    },
    "finding_severity": {
      "type": "string",
      "enum": [
        "blocking",
        "high",
        "medium",
        "low",
        "info"
      ]
    },
    "finding_status": {
      "type": "string",
      "enum": [
        "open",
        "acknowledged",
        "resolved",
        "dismissed",
        "superseded"
      ]
    },
    "apply_posture": {
      "type": "string",
      "enum": [
        "no_suggestion",
        "safe_apply_previewed",
        "manual_only",
        "apply_blocked"
      ]
    },
    "binding_state": {
      "type": "string",
      "enum": [
        "bound_current",
        "bound_stale_base",
        "unbound_pending",
        "detached_relabeled"
      ]
    },
    "check_coverage": {
      "type": "string",
      "enum": [
        "all_required_present",
        "required_missing_labeled",
        "advisory_only",
        "unavailable_offline"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "evidence_stale",
        "finding_evidence_missing",
        "binding_detach_unlabeled",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "review_workspace_findings",
        "review_pack_panel",
        "merge_queue_panel",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "evidence_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "source",
        "freshness",
        "provenance_label",
        "summary_label",
        "source_contract_refs"
      ],
      "properties": {
        "evidence_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source": {
          "$ref": "#/$defs/evidence_source"
        },
        "freshness": {
          "$ref": "#/$defs/evidence_freshness"
        },
        "provenance_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "finding_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "severity",
        "status",
        "anchor_id",
        "evidence_ref",
        "apply_posture",
        "change_object_ref",
        "title_label",
        "apply_block_label"
      ],
      "properties": {
        "finding_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "severity": {
          "$ref": "#/$defs/finding_severity"
        },
        "status": {
          "$ref": "#/$defs/finding_status"
        },
        "anchor_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "apply_posture": {
          "$ref": "#/$defs/apply_posture"
        },
        "change_object_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "apply_block_label": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "apply_posture": {
                "const": "apply_blocked"
              }
            }
          },
          "then": {
            "properties": {
              "apply_block_label": {
                "$ref": "#/$defs/non_empty_string"
              }
            }
          }
        }
      ]
    },
    "review_pack_binding_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_pack_id",
        "change_object_id",
        "binding_state",
        "required_check_coverage",
        "attribution_label",
        "detach_label"
      ],
      "properties": {
        "review_pack_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "change_object_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "binding_state": {
          "$ref": "#/$defs/binding_state"
        },
        "required_check_coverage": {
          "$ref": "#/$defs/check_coverage"
        },
        "attribution_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "detach_label": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "binding_state": {
                "const": "detached_relabeled"
              }
            }
          },
          "then": {
            "properties": {
              "detach_label": {
                "$ref": "#/$defs/non_empty_string"
              }
            }
          }
        }
      ]
    },
    "trust_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ai_evidence_provenance_explicit",
        "evidence_freshness_labeled_not_hidden",
        "finding_cards_cite_real_evidence",
        "finding_severity_and_status_explicit",
        "apply_posture_explicit_no_silent_write",
        "review_pack_binds_to_change_object",
        "binding_detach_labeled_not_hidden",
        "change_object_attribution_explicit",
        "no_hidden_write_scope",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "ai_evidence_provenance_explicit": {
          "type": "boolean",
          "const": true
        },
        "evidence_freshness_labeled_not_hidden": {
          "type": "boolean",
          "const": true
        },
        "finding_cards_cite_real_evidence": {
          "type": "boolean",
          "const": true
        },
        "finding_severity_and_status_explicit": {
          "type": "boolean",
          "const": true
        },
        "apply_posture_explicit_no_silent_write": {
          "type": "boolean",
          "const": true
        },
        "review_pack_binds_to_change_object": {
          "type": "boolean",
          "const": true
        },
        "binding_detach_labeled_not_hidden": {
          "type": "boolean",
          "const": true
        },
        "change_object_attribution_explicit": {
          "type": "boolean",
          "const": true
        },
        "no_hidden_write_scope": {
          "type": "boolean",
          "const": true
        },
        "downgrade_narrows_instead_of_hides": {
          "type": "boolean",
          "const": true
        },
        "stale_or_underqualified_blocks_promotion": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_cards_show_severity_status",
        "finding_cards_show_evidence_provenance",
        "finding_cards_show_apply_posture",
        "review_pack_shows_change_object_binding",
        "binding_shows_detach_label",
        "cli_headless_shows_truth",
        "support_export_shows_truth",
        "diagnostics_shows_truth",
        "help_about_shows_truth",
        "preview_labs_label_for_unqualified"
      ],
      "properties": {
        "finding_cards_show_severity_status": {
          "type": "boolean",
          "const": true
        },
        "finding_cards_show_evidence_provenance": {
          "type": "boolean",
          "const": true
        },
        "finding_cards_show_apply_posture": {
          "type": "boolean",
          "const": true
        },
        "review_pack_shows_change_object_binding": {
          "type": "boolean",
          "const": true
        },
        "binding_shows_detach_label": {
          "type": "boolean",
          "const": true
        },
        "cli_headless_shows_truth": {
          "type": "boolean",
          "const": true
        },
        "support_export_shows_truth": {
          "type": "boolean",
          "const": true
        },
        "diagnostics_shows_truth": {
          "type": "boolean",
          "const": true
        },
        "help_about_shows_truth": {
          "type": "boolean",
          "const": true
        },
        "preview_labs_label_for_unqualified": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
