        "local_outcome_class": { "type": "string" },
        "ci_outcome_class": { "type": "string" },
        "ai_review_outcome_class": { "type": "string" },
        "provider_outcome_class": { "type": "string" },
        "divergence_label_class": { "$ref": "#/$defs/ci_check_divergence_class" },
        "inspect_only": { "type": "boolean" },
        "run_control_permitted": { "type": "boolean" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "pipeline_overlay_audit_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "audit_id_ref",
        "overlay_audit_id",
        "provider_descriptor_ref",
        "overlay_kind",
        "fetched_at",
        "provider_source_class",
        "artifact_trust_class",
        "read_only_subset_label",
        "run_control_subset_label",
        "mutation_mode_disclosure",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "pipeline_overlay_audit_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "audit_id_ref": { "$ref": "#/$defs/opaque_id" },
        "overlay_audit_id": { "$ref": "#/$defs/opaque_id" },
        "provider_descriptor_ref": { "$ref": "#/$defs/opaque_id" },
        "overlay_kind": { "type": "string" },
        "fetched_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "provider_source_class": { "type": "string" },
        "artifact_trust_class": { "type": "string" },
        "read_only_subset_label": { "type": "boolean" },
        "run_control_subset_label": { "type": "boolean" },
        "mutation_mode_disclosure": { "type": "string" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "run_control_audit_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "audit_id_ref",
        "run_control_audit_id",
        "run_control_id_ref",
        "control_class",
        "mutation_mode",
        "provider_scope_disclosure",
        "actor_mode_disclosure",
        "target_run_identity",
        "browser_handoff_fallback_present",
        "review_pack_digest_ref",
        "base_revision_ref",
        "head_revision_ref",
        "summary_label"
      ],
      "properties": {
