{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/review/freeze-the-m5-review-workspace-merge-queue-and-pipeline-viewer-maturity-matrix.schema.json",
  "title": "Aureline M5 review-workspace, merge-queue, and pipeline-viewer maturity matrix",
  "description": "Export-safe packet freezing the M5 depth qualification for four review, CI, and preview lanes: durable review-workspace anchors, fresh merge-queue truth with attributable rerun/cancel authority, safe-previewed pipeline logs and artifacts, and time-bounded, attributable remote preview routes. The packet binds each lane to its qualification class, evidence requirements, downgrade triggers, rollback posture, source contracts, and consumer-surface parity. Raw diff bodies, raw build logs, raw pipeline artifacts, raw provider payloads, credentials, and live preview origin responses never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "matrix_label",
    "lane_rows",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "freeze_m5_review_workspace_merge_queue_and_pipeline_viewer_maturity_matrix"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "matrix_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "lane_rows": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/lane_row"
      }
    },
    "trust_review": {
      "$ref": "#/$defs/trust_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "lane": {
      "type": "string",
      "enum": [
        "review_workspace",
        "merge_queue",
        "pipeline_viewer",
        "remote_preview"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "evidence_requirement": {
      "type": "string",
      "enum": [
        "required",
        "recommended",
        "optional",
        "not_applicable"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "merge_queue_status_stale",
        "anchor_drift",
        "safe_preview_unavailable",
        "preview_route_expired",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "rollback_posture": {
      "type": "string",
      "enum": [
        "read_only_no_mutation",
        "attributable_rerun_or_cancel",
        "return_path_preserved",
        "time_bounded_auto_expire",
        "evidence_preserved_no_revert",
        "not_applicable"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "review_workspace",
        "merge_queue_panel",
        "pipeline_viewer",
        "remote_preview_panel",
        "browser_companion",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "lane_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane",
        "qualification",
        "scope_summary",
        "evidence_requirement",
        "required_evidence_packet_refs",
        "downgrade_triggers",
        "rollback_posture",
        "source_contract_refs",
        "consumer_surfaces"
      ],
      "properties": {
        "lane": {
          "$ref": "#/$defs/lane"
        },
        "qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "scope_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_requirement": {
          "$ref": "#/$defs/evidence_requirement"
        },
        "required_evidence_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "rollback_posture": {
          "$ref": "#/$defs/rollback_posture"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/consumer_surface"
          }
        }
      }
    },
    "trust_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_workspace_anchors_durable",
        "stale_base_labels_explicit",
        "merge_queue_truth_fresh",
        "rerun_cancel_authority_attributable",
        "pipeline_logs_artifacts_safe_previewed",
        "remote_preview_time_bounded",
        "remote_preview_attributable",
        "browser_handoff_return_path_safe",
        "no_hidden_write_scope",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "review_workspace_anchors_durable": {
          "type": "boolean",
          "const": true
        },
        "stale_base_labels_explicit": {
          "type": "boolean",
          "const": true
        },
        "merge_queue_truth_fresh": {
          "type": "boolean",
          "const": true
        },
        "rerun_cancel_authority_attributable": {
          "type": "boolean",
          "const": true
        },
        "pipeline_logs_artifacts_safe_previewed": {
          "type": "boolean",
          "const": true
        },
        "remote_preview_time_bounded": {
          "type": "boolean",
          "const": true
        },
        "remote_preview_attributable": {
          "type": "boolean",
          "const": true
        },
        "browser_handoff_return_path_safe": {
          "type": "boolean",
          "const": true
        },
        "no_hidden_write_scope": {
          "type": "boolean",
          "const": true
        },
        "downgrade_narrows_instead_of_hides": {
          "type": "boolean",
          "const": true
        },
        "stale_or_underqualified_blocks_promotion": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_workspace_shows_anchor_and_stale_base",
        "merge_queue_shows_ci_status_and_freshness",
        "pipeline_viewer_shows_safe_preview_state",
        "remote_preview_shows_expiry_and_attribution",
        "cli_headless_shows_qualification",
        "support_export_shows_qualification",
        "diagnostics_shows_qualification",
        "help_about_shows_qualification",
        "preview_labs_label_for_unqualified_lanes"
      ],
      "properties": {
        "review_workspace_shows_anchor_and_stale_base": {
          "type": "boolean",
          "const": true
        },
        "merge_queue_shows_ci_status_and_freshness": {
          "type": "boolean",
          "const": true
        },
        "pipeline_viewer_shows_safe_preview_state": {
          "type": "boolean",
          "const": true
        },
        "remote_preview_shows_expiry_and_attribution": {
          "type": "boolean",
          "const": true
        },
        "cli_headless_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "support_export_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "diagnostics_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "help_about_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "preview_labs_label_for_unqualified_lanes": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
