{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/review/implement-normalized-pipeline-run-rows-log-viewers-artifact-browsers-and-safe-preview-trust-classes.schema.json",
  "title": "Aureline normalized pipeline run rows, log viewers, artifact browsers, and safe-preview trust classes",
  "description": "Export-safe packet implementing four pipeline-viewer lane pillars: normalized pipeline run rows that carry target identity, durable review anchor, normalized run status, freshness, trigger attribution, and rerun/cancel authority plus the attention reasons behind a non-green status; log viewer rows that record the safe-preview trust class, safe-open path, stream state, and truncation label for a run's logs; artifact browser rows that record the artifact kind, safe-preview trust class, safe-open path, freshness, size disclosure, and retention label for a run's artifacts; and safe-preview trust classes drawn verbatim from the frozen architecture vocabulary, where TrustedLocalActive is never admissible for provider-boundary logs or artifacts. The packet binds run rows, log views, artifact cards, downgrade triggers, consumer surfaces, trust review, consumer projection, and proof freshness. Raw run/log/artifact bodies, raw provider payloads, raw URLs, raw absolute paths, credentials, and live provider responses never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "surface_label",
    "run_rows",
    "log_views",
    "artifact_cards",
    "downgrade_triggers",
    "consumer_surfaces",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "normalized_pipeline_run_rows_log_viewers_artifact_browsers_and_safe_preview_trust_classes"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "surface_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "run_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/run_row"
      }
    },
    "log_views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/log_view_row"
      }
    },
    "artifact_cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact_card_row"
      }
    },
    "downgrade_triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/downgrade_trigger"
      }
    },
    "consumer_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/consumer_surface"
      }
    },
    "trust_review": {
      "$ref": "#/$defs/trust_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "run_status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "cancelled",
        "action_required",
        "skipped",
        "timed_out",
        "unknown"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },
    "run_control_authority": {
      "type": "string",
      "enum": [
        "read_only_no_control",
        "attributable_rerun",
        "attributable_cancel",
        "attributable_rerun_and_cancel"
      ]
    },
    "safe_preview_trust_class": {
      "type": "string",
      "enum": [
        "RawText",
        "SanitizedRich",
        "TrustedLocalActive",
        "IsolatedRemoteActive"
      ],
      "description": "Frozen safe-preview trust-class vocabulary re-exported verbatim from schemas/security/trust_class.schema.json#trust_class. TrustedLocalActive is not admissible on log or artifact rows because pipeline content arrives from a provider boundary."
    },
    "provider_boundary_trust_class": {
      "type": "string",
      "enum": [
        "RawText",
        "SanitizedRich",
        "IsolatedRemoteActive"
      ]
    },
    "safe_open_path": {
      "type": "string",
      "enum": [
        "open_in_structured_viewer",
        "open_in_safe_preview_sanitized",
        "open_in_safe_preview_metadata_only",
        "download_only_no_in_product_open",
        "denied_no_open_path"
      ]
    },
    "open_path_no_live_bytes": {
      "type": "string",
      "enum": [
        "open_in_safe_preview_metadata_only",
        "download_only_no_in_product_open",
        "denied_no_open_path"
      ]
    },
    "log_stream_state": {
      "type": "string",
      "enum": [
        "live_streaming",
        "completed_replay",
        "partial_retained",
        "unavailable"
      ]
    },
    "artifact_kind": {
      "type": "string",
      "enum": [
        "log_bundle",
        "test_report",
        "coverage_report",
        "binary_executable",
        "container_image",
        "archive",
        "sbom",
        "image_media",
        "other_artifact"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "run_status_unverified",
        "safe_preview_trust_narrowed",
        "log_truncation_unlabeled",
        "artifact_retention_expired",
        "run_control_authority_revoked",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "pipeline_viewer",
        "runs_panel",
        "log_pane",
        "artifact_browser",
        "review_workspace_header",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "run_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "target_identity_label",
        "durable_anchor_id",
        "pipeline_label",
        "run_status",
        "freshness",
        "trigger_attribution_label",
        "run_control_authority",
        "status_summary",
        "attention_reasons",
        "source_contract_refs"
      ],
      "properties": {
        "run_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_identity_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "durable_anchor_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pipeline_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "run_status": {
          "$ref": "#/$defs/run_status"
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        },
        "trigger_attribution_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "run_control_authority": {
          "$ref": "#/$defs/run_control_authority"
        },
        "status_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "attention_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "run_status": {
                "enum": [
                  "failed",
                  "cancelled",
                  "action_required",
                  "timed_out",
                  "unknown"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "attention_reasons": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "log_view_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "view_id",
        "log_label",
        "stream_state",
        "safe_preview_trust_class",
        "safe_open_path",
        "truncation_label"
      ],
      "properties": {
        "run_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "view_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "log_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "stream_state": {
          "$ref": "#/$defs/log_stream_state"
        },
        "safe_preview_trust_class": {
          "$ref": "#/$defs/provider_boundary_trust_class"
        },
        "safe_open_path": {
          "$ref": "#/$defs/safe_open_path"
        },
        "truncation_label": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "stream_state": {
                "enum": ["partial_retained", "unavailable"]
              }
            }
          },
          "then": {
            "properties": {
              "truncation_label": {
                "$ref": "#/$defs/non_empty_string"
              },
              "safe_open_path": {
                "$ref": "#/$defs/open_path_no_live_bytes"
              }
            }
          }
        }
      ]
    },
    "artifact_card_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "artifact_id",
        "artifact_label",
        "artifact_kind",
        "safe_preview_trust_class",
        "safe_open_path",
        "freshness",
        "size_disclosure_label",
        "retention_label"
      ],
      "properties": {
        "run_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "artifact_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "artifact_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "artifact_kind": {
          "$ref": "#/$defs/artifact_kind"
        },
        "safe_preview_trust_class": {
          "$ref": "#/$defs/provider_boundary_trust_class"
        },
        "safe_open_path": {
          "$ref": "#/$defs/safe_open_path"
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        },
        "size_disclosure_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "retention_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "artifact_kind": {
                "enum": ["binary_executable", "container_image", "archive"]
              }
            }
          },
          "then": {
            "properties": {
              "safe_open_path": {
                "$ref": "#/$defs/open_path_no_live_bytes"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "freshness": {
                "enum": ["degraded_cached", "stale", "unverified"]
              }
            }
          },
          "then": {
            "properties": {
              "safe_open_path": {
                "$ref": "#/$defs/open_path_no_live_bytes"
              }
            }
          }
        }
      ]
    },
    "trust_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_status_explicit",
        "run_status_never_overstated",
        "safe_preview_trust_class_explicit",
        "active_content_never_trusted_local",
        "log_truncation_labeled_not_hidden",
        "artifact_retention_labeled_not_hidden",
        "freshness_explicit_and_narrows_open_path",
        "rerun_cancel_authority_explicit_and_attributable",
        "no_hidden_write_scope",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "run_status_explicit": {
          "type": "boolean",
          "const": true
        },
        "run_status_never_overstated": {
          "type": "boolean",
          "const": true
        },
        "safe_preview_trust_class_explicit": {
          "type": "boolean",
          "const": true
        },
        "active_content_never_trusted_local": {
          "type": "boolean",
          "const": true
        },
        "log_truncation_labeled_not_hidden": {
          "type": "boolean",
          "const": true
        },
        "artifact_retention_labeled_not_hidden": {
          "type": "boolean",
          "const": true
        },
        "freshness_explicit_and_narrows_open_path": {
          "type": "boolean",
          "const": true
        },
        "rerun_cancel_authority_explicit_and_attributable": {
          "type": "boolean",
          "const": true
        },
        "no_hidden_write_scope": {
          "type": "boolean",
          "const": true
        },
        "downgrade_narrows_instead_of_hides": {
          "type": "boolean",
          "const": true
        },
        "stale_or_underqualified_blocks_promotion": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pipeline_viewer_shows_run_status",
        "pipeline_viewer_shows_freshness",
        "runs_panel_shows_attention_reasons",
        "log_pane_shows_safe_preview_trust_class",
        "log_pane_shows_truncation",
        "artifact_browser_shows_safe_open_path",
        "artifact_browser_shows_retention",
        "run_control_shows_authority_and_attribution",
        "cli_headless_shows_truth",
        "support_export_shows_truth",
        "diagnostics_shows_truth",
        "help_about_shows_truth",
        "preview_labs_label_for_unqualified"
      ],
      "properties": {
        "pipeline_viewer_shows_run_status": {
          "type": "boolean",
          "const": true
        },
        "pipeline_viewer_shows_freshness": {
          "type": "boolean",
          "const": true
        },
        "runs_panel_shows_attention_reasons": {
          "type": "boolean",
          "const": true
        },
        "log_pane_shows_safe_preview_trust_class": {
          "type": "boolean",
          "const": true
        },
        "log_pane_shows_truncation": {
          "type": "boolean",
          "const": true
        },
        "artifact_browser_shows_safe_open_path": {
          "type": "boolean",
          "const": true
        },
        "artifact_browser_shows_retention": {
          "type": "boolean",
          "const": true
        },
        "run_control_shows_authority_and_attribution": {
          "type": "boolean",
          "const": true
        },
        "cli_headless_shows_truth": {
          "type": "boolean",
          "const": true
        },
        "support_export_shows_truth": {
          "type": "boolean",
          "const": true
        },
        "diagnostics_shows_truth": {
          "type": "boolean",
          "const": true
        },
        "help_about_shows_truth": {
          "type": "boolean",
          "const": true
        },
        "preview_labs_label_for_unqualified": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
