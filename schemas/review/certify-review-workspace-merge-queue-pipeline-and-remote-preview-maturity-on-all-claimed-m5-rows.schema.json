{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/review/certify-review-workspace-merge-queue-pipeline-and-remote-preview-maturity-on-all-claimed-m5-rows.schema.json",
  "title": "Aureline M5 review-workspace, merge-queue, pipeline, and remote-preview certification",
  "description": "Export-safe packet certifying every claimed M5 review, CI, and preview row: durable review-workspace headers, merge-queue readiness, pipeline-viewer depth, remote preview routes, attributable rerun/cancel authority, AI review evidence cards, review/export bundles, and the frozen maturity matrix. Each row binds a certification verdict to the upstream evidence packet (record kind, support-export artifact, schema, and contract doc), its downgrade triggers, rollback posture, and proof freshness. A compatibility report aggregates the per-row verdicts into a promotion verdict. Raw diff bodies, raw build logs, raw pipeline artifacts, raw provider payloads, credentials, and live preview origin responses never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "certification_label",
    "certified_rows",
    "compatibility_report",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "certify_review_workspace_merge_queue_pipeline_and_remote_preview_maturity_on_all_claimed_m5_rows"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "certification_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "certified_rows": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/certified_row"
      }
    },
    "compatibility_report": {
      "$ref": "#/$defs/compatibility_report"
    },
    "trust_review": {
      "$ref": "#/$defs/trust_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "claimed_row": {
      "type": "string",
      "enum": [
        "durable_review_header",
        "merge_queue_readiness",
        "pipeline_viewer",
        "remote_preview_route",
        "rerun_cancel_review",
        "evidence_card",
        "review_export_bundle",
        "maturity_matrix"
      ]
    },
    "lane": {
      "type": "string",
      "enum": [
        "review_workspace",
        "merge_queue",
        "pipeline_viewer",
        "remote_preview",
        "cross_cutting"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "certified",
        "narrowed_certified",
        "blocked",
        "not_certified"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "evidence_packet_invalid",
        "policy_blocked",
        "merge_queue_status_stale",
        "anchor_drift",
        "safe_preview_unavailable",
        "preview_route_expired",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "rollback_posture": {
      "type": "string",
      "enum": [
        "read_only_no_mutation",
        "attributable_rerun_or_cancel",
        "return_path_preserved",
        "time_bounded_auto_expire",
        "evidence_preserved_no_revert",
        "not_applicable"
      ]
    },
    "row_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "proof_fresh"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "proof_fresh": {
          "type": "boolean"
        }
      }
    },
    "certified_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row",
        "lane",
        "claimed_qualification",
        "verdict",
        "upstream_record_kind",
        "evidence_artifact_ref",
        "evidence_schema_ref",
        "evidence_doc_ref",
        "downgrade_triggers",
        "rollback_posture",
        "proof_freshness"
      ],
      "properties": {
        "row": {
          "$ref": "#/$defs/claimed_row"
        },
        "lane": {
          "$ref": "#/$defs/lane"
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "verdict": {
          "$ref": "#/$defs/verdict"
        },
        "upstream_record_kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_artifact_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_schema_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_doc_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "rollback_posture": {
          "$ref": "#/$defs/rollback_posture"
        },
        "proof_freshness": {
          "$ref": "#/$defs/row_freshness"
        }
      }
    },
    "compatibility_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows",
        "certified_count",
        "narrowed_count",
        "blocked_count",
        "not_certified_count",
        "all_rows_publishable",
        "promotion_note"
      ],
      "properties": {
        "total_rows": {
          "type": "integer",
          "minimum": 0
        },
        "certified_count": {
          "type": "integer",
          "minimum": 0
        },
        "narrowed_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "not_certified_count": {
          "type": "integer",
          "minimum": 0
        },
        "all_rows_publishable": {
          "type": "boolean"
        },
        "promotion_note": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "trust_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_workspace_anchors_durable",
        "stale_base_labels_explicit",
        "merge_queue_truth_fresh",
        "rerun_cancel_authority_attributable",
        "pipeline_logs_artifacts_safe_previewed",
        "remote_preview_time_bounded",
        "remote_preview_attributable",
        "browser_handoff_return_path_safe",
        "no_hidden_write_scope",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "review_workspace_anchors_durable": {
          "type": "boolean",
          "const": true
        },
        "stale_base_labels_explicit": {
          "type": "boolean",
          "const": true
        },
        "merge_queue_truth_fresh": {
          "type": "boolean",
          "const": true
        },
        "rerun_cancel_authority_attributable": {
          "type": "boolean",
          "const": true
        },
        "pipeline_logs_artifacts_safe_previewed": {
          "type": "boolean",
          "const": true
        },
        "remote_preview_time_bounded": {
          "type": "boolean",
          "const": true
        },
        "remote_preview_attributable": {
          "type": "boolean",
          "const": true
        },
        "browser_handoff_return_path_safe": {
          "type": "boolean",
          "const": true
        },
        "no_hidden_write_scope": {
          "type": "boolean",
          "const": true
        },
        "downgrade_narrows_instead_of_hides": {
          "type": "boolean",
          "const": true
        },
        "stale_or_underqualified_blocks_promotion": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_workspace_shows_certification",
        "merge_queue_shows_certification",
        "pipeline_viewer_shows_certification",
        "remote_preview_shows_certification",
        "cli_headless_shows_certification",
        "support_export_shows_certification",
        "diagnostics_shows_certification",
        "help_about_shows_certification",
        "preview_labs_label_for_unqualified_rows"
      ],
      "properties": {
        "review_workspace_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "merge_queue_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "pipeline_viewer_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "remote_preview_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "cli_headless_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "support_export_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "diagnostics_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "help_about_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "preview_labs_label_for_unqualified_rows": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
