        "open_external_action_label": { "type": "string", "minLength": 1 },
        "linked_transition_review_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "linked_offline_handoff_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "summary_label": { "type": "string", "minLength": 1 }
      }
    },
    "transition_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "transition_review_record_id_ref",
        "work_item_detail_record_id_ref",
        "status_transition_packet_record_id_ref",
        "target_item_ref",
        "current_state_summary",
        "requested_state_summary",
        "linked_branch_or_review_note",
