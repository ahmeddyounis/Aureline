        "detail_headers_disclose_state_and_owner",
        "detail_headers_disclose_sync_state_and_open_external",
        "transition_sheets_disclose_side_effects",
        "transition_sheets_disclose_authority_and_publish_mode",
        "comment_reviews_split_local_draft_from_external_post",
