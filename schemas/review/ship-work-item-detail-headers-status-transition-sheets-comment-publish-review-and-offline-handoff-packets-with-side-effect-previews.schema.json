        "permission_scope_class",
        "publish_mode_class",
        "disposition_summary_label",
        "confirm_action_available",
        "export_action_available",
        "cancel_action_available",
        "side_effect_summaries",
        "local_draft_preserved_on_failure",
        "fallback_label",
        "summary_label"
      ],
      "properties": {
        "row_id": { "type": "string", "minLength": 1 },
        "transition_review_record_id_ref": { "type": "string", "minLength": 1 },
        "work_item_detail_record_id_ref": { "type": "string", "minLength": 1 },
        "status_transition_packet_record_id_ref": { "type": "string", "minLength": 1 },
        "target_item_ref": { "type": "string", "minLength": 1 },
        "current_state_summary": { "type": "string", "minLength": 1 },
        "requested_state_summary": { "type": "string", "minLength": 1 },
        "linked_branch_or_review_note": { "type": "string", "minLength": 1 },
        "actor_authority_summary": { "type": "string", "minLength": 1 },
        "permission_scope_class": { "type": "string", "minLength": 1 },
        "publish_mode_class": { "type": "string", "minLength": 1 },
        "disposition_summary_label": { "type": "string", "minLength": 1 },
        "confirm_action_available": { "type": "boolean" },
        "export_action_available": { "type": "boolean" },
        "cancel_action_available": { "type": "boolean" },
        "side_effect_summaries": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "local_draft_preserved_on_failure": { "type": "boolean" },
        "fallback_label": { "type": "string", "minLength": 1 },
        "summary_label": { "type": "string", "minLength": 1 }
      }
    },
    "comment_publish_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "publish_review_record_id_ref",
        "work_item_detail_record_id_ref",
        "action_class",
        "publish_mode_class",
        "disposition_class",
        "actor_scope_class",
        "local_draft_summary",
        "external_post_summary",
        "visibility_target_label",
        "evidence_refs",
        "notify_behavior_label",
        "fallback_label",
        "side_effect_summaries",
        "summary_label"
      ],
      "properties": {
        "row_id": { "type": "string", "minLength": 1 },
        "publish_review_record_id_ref": { "type": "string", "minLength": 1 },
        "work_item_detail_record_id_ref": { "type": "string", "minLength": 1 },
        "comment_sync_state_record_id_ref": { "type": "string" },
        "status_transition_packet_record_id_ref": { "type": "string" },
        "action_class": { "type": "string", "minLength": 1 },
        "publish_mode_class": { "type": "string", "minLength": 1 },
        "disposition_class": { "type": "string", "minLength": 1 },
        "actor_scope_class": { "type": "string", "minLength": 1 },
        "local_draft_summary": { "type": "string", "minLength": 1 },
        "external_post_summary": { "type": "string", "minLength": 1 },
        "visibility_target_label": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notify_behavior_label": { "type": "string", "minLength": 1 },
        "fallback_label": { "type": "string", "minLength": 1 },
        "side_effect_summaries": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "summary_label": { "type": "string", "minLength": 1 }
      }
    },
    "offline_handoff_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "offline_handoff_packet_record_id_ref",
        "work_item_detail_record_id_ref",
        "status_transition_packet_record_id_ref",
