        "offline_packets_preserve_redaction_and_expiry": { "type": "boolean" },
        "offline_packets_do_not_claim_provider_acceptance": { "type": "boolean" },
        "outage_or_policy_block_preserves_local_intent": { "type": "boolean" },
        "stable_vocabulary_across_surfaces": { "type": "boolean" },
        "downgrade_narrows_instead_of_hides": { "type": "boolean" },
