        "work_item_detail_record_id_ref",
        "provider_family",
        "provider_label",
        "project_or_space_ref",
        "canonical_id",
        "title_label",
        "provider_boundary_label",
        "current_state_summary",
        "owner_or_assignee_summary",
        "sync_state_summary",
        "freshness_class",
        "write_authority_class",
        "publish_posture_class",
        "open_external_action_class",
        "open_external_action_label",
        "linked_transition_review_ids",
