        "header_id": { "type": "string", "minLength": 1 },
        "work_item_detail_record_id_ref": { "type": "string", "minLength": 1 },
        "provider_family": { "type": "string", "minLength": 1 },
        "provider_label": { "type": "string", "minLength": 1 },
        "project_or_space_ref": { "type": "string", "minLength": 1 },
        "canonical_id": { "type": "string", "minLength": 1 },
        "title_label": { "type": "string", "minLength": 1 },
        "provider_boundary_label": { "type": "string", "minLength": 1 },
        "current_state_summary": { "type": "string", "minLength": 1 },
        "owner_or_assignee_summary": { "type": "string", "minLength": 1 },
        "sync_state_summary": { "type": "string", "minLength": 1 },
