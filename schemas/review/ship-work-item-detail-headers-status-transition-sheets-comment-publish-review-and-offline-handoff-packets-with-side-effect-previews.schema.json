      "properties": {
        "detail_headers_disclose_provider_boundary": { "type": "boolean" },
        "detail_headers_disclose_canonical_identity": { "type": "boolean" },
        "detail_headers_disclose_state_and_owner": { "type": "boolean" },
        "detail_headers_disclose_sync_state_and_open_external": { "type": "boolean" },
        "transition_sheets_disclose_side_effects": { "type": "boolean" },
        "transition_sheets_disclose_authority_and_publish_mode": { "type": "boolean" },
        "comment_reviews_split_local_draft_from_external_post": { "type": "boolean" },
