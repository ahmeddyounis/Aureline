        "retry_route_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "captured_note_summary": { "type": "string", "minLength": 1 },
        "code_link_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "redaction_class": { "type": "string", "minLength": 1 },
        "redaction_manifest_ref": { "type": "string", "minLength": 1 },
        "expires_at": { "type": "string", "minLength": 1 },
        "publish_target_ref": { "type": "string", "minLength": 1 },
        "retry_action_ref": { "type": "string", "minLength": 1 },
        "export_action_ref": { "type": "string", "minLength": 1 },
        "packet_survives_restart": { "type": "boolean" },
        "summary_label": { "type": "string", "minLength": 1 }
      }
    },
