{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/review/ship-work-item-detail-headers-status-transition-sheets-comment-publish-review-and-offline-handoff-packets-with-side-effect-previews.schema.json",
  "title": "Aureline work-item mutation review side-effect preview packet",
  "description": "Boundary schema for the M5 packet that projects work-item detail headers, status-transition review sheets, comment publish review rows, and offline handoff packet continuity into one export-safe cross-surface record. The packet keeps provider boundary, canonical identity, state, publish mode, side effects, local-draft separation, notification behavior, redaction, expiry, and retry/export continuity explicit before any provider mutation leaves the machine. Raw provider payloads, raw URLs, raw comment bodies, credentials, and live provider responses never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "surface_label",
    "detail_headers",
    "transition_reviews",
    "comment_publish_reviews",
    "offline_handoff_packets",
    "downgrade_triggers",
    "consumer_surfaces",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "ship_work_item_detail_headers_status_transition_sheets_comment_publish_review_and_offline_handoff_packets_with_side_effect_previews"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "surface_label": {
      "type": "string",
      "minLength": 1
    },
    "detail_headers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/detail_header"
      }
    },
    "transition_reviews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/transition_review"
      }
    },
    "comment_publish_reviews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/comment_publish_review"
      }
    },
    "offline_handoff_packets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/offline_handoff_packet"
      }
    },
    "downgrade_triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "consumer_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "trust_review": {
      "$ref": "#/$defs/trust_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "redaction_class_token": {
      "type": "string",
      "minLength": 1
    },
    "minted_at": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "detail_header": {
