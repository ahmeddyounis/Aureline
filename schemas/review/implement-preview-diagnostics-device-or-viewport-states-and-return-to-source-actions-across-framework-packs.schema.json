{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/review/implement-preview-diagnostics-device-or-viewport-states-and-return-to-source-actions-across-framework-packs.schema.json",
  "title": "Aureline preview diagnostics, device/viewport states, and return-to-source actions across framework packs",
  "description": "Export-safe packet implementing four preview-diagnostics lane pillars: framework pack rows that name a convenience framework integration and disclose whether it supports source mapping, viewport emulation, and hot reload; preview diagnostic rows that carry the durable review anchor, the framework pack id, a typed severity and kind, a redaction-aware message label, an attention block, and an actor attribution with an audit row; device/viewport states that disclose the viewport class, device label, dimensions label, and emulation flag; and return-to-source actions that disclose the source-mapping exactness and freshness plus a typed action kind so a jump from a preview back to source is read-only navigation unless an attributable browser handoff is cited, and a stale or missing source map narrows the action rather than jumping blind. A bound framework-pack table records the packs diagnostics reference. The packet binds framework pack rows, diagnostic rows, downgrade triggers, consumer surfaces, trust review, consumer projection, and proof freshness. A read-only action carries no handoff ref; open_in_browser_handoff must cite a handoff_ref; an unsupported_no_source_map action must be blocked. Raw preview URLs, raw host names, raw diagnostic stacks, raw source bodies, raw provider payloads, raw absolute paths, raw author email addresses, credentials, and live provider responses never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "surface_label",
    "framework_pack_rows",
    "diagnostic_rows",
    "downgrade_triggers",
    "consumer_surfaces",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "implement_preview_diagnostics_device_or_viewport_states_and_return_to_source_actions_across_framework_packs"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "surface_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "framework_pack_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/framework_pack_row"
      }
    },
    "diagnostic_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/diagnostic_row"
      }
    },
    "downgrade_triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/downgrade_trigger"
      }
    },
    "consumer_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/consumer_surface"
      }
    },
    "trust_review": {
      "$ref": "#/$defs/trust_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "nullable_ref": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "framework_pack_class": {
      "type": "string",
      "enum": [
        "web_react",
        "web_vue",
        "web_svelte",
        "web_angular",
        "web_static_html",
        "native_runtime",
        "generic_framework_pack",
        "unknown_pack_provider_owned"
      ]
    },
    "diagnostic_severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "error",
        "fatal",
        "unknown_severity_provider_owned"
      ]
    },
    "diagnostic_kind": {
      "type": "string",
      "enum": [
        "build_error",
        "compile_error",
        "runtime_error",
        "hot_reload_failure",
        "type_error",
        "lint_warning",
        "console_error",
        "unknown_diagnostic_provider_owned"
      ]
    },
    "viewport_class": {
      "type": "string",
      "enum": [
        "desktop",
        "tablet",
        "mobile",
        "responsive_fluid",
        "custom_viewport",
        "device_emulation",
        "unknown_viewport_provider_owned"
      ]
    },
    "source_mapping_class": {
      "type": "string",
      "enum": [
        "exact_line_column",
        "approximate_line",
        "file_only",
        "generated_no_source_map",
        "unknown_mapping_provider_owned"
      ]
    },
    "source_mapping_freshness": {
      "type": "string",
      "enum": [
        "fresh_current_build",
        "stale_prior_build",
        "unknown_freshness_provider_owned"
      ]
    },
    "return_to_source_action_kind": {
      "type": "string",
      "enum": [
        "jump_to_source_local",
        "reveal_in_editor",
        "copy_source_location",
        "open_in_browser_handoff",
        "unsupported_no_source_map"
      ]
    },
    "return_to_source_blocked_class": {
      "type": "string",
      "enum": [
        "not_blocked",
        "blocked_no_source_map",
        "blocked_source_map_stale_review_required",
        "blocked_generated_content_no_origin",
        "blocked_policy_forbids_handoff",
        "blocked_offline_or_disconnected",
        "blocked_unknown_reason_provider_owned"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "diagnostic_attribution_missing",
        "source_map_stale",
        "source_map_undisclosed",
        "viewport_state_undisclosed",
        "framework_pack_unknown",
        "return_to_source_unsupported",
        "trust_narrowing",
        "upstream_dependency_narrowed"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "preview_diagnostics_panel",
        "preview_panel",
        "diagnostic_card",
        "return_to_source_action",
        "review_workspace_header",
        "command_palette",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "device_viewport_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "viewport_class",
        "device_label",
        "dimensions_label",
        "emulated",
        "state_disclosed"
      ],
      "properties": {
        "viewport_class": {
          "$ref": "#/$defs/viewport_class"
        },
        "device_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "dimensions_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "emulated": {
          "type": "boolean"
        },
        "state_disclosed": {
          "const": true
        }
      }
    },
    "source_mapping_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mapping_class",
        "freshness_class",
        "mapping_disclosed",
        "mapping_label"
      ],
      "properties": {
        "mapping_class": {
          "$ref": "#/$defs/source_mapping_class"
        },
        "freshness_class": {
          "$ref": "#/$defs/source_mapping_freshness"
        },
        "mapping_disclosed": {
          "const": true
        },
        "mapping_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "return_to_source_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_kind",
        "action_disclosed",
        "read_only",
        "action_label",
        "handoff_ref"
      ],
      "properties": {
        "action_kind": {
          "$ref": "#/$defs/return_to_source_action_kind"
        },
        "action_disclosed": {
          "const": true
        },
        "read_only": {
          "type": "boolean"
        },
        "action_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "handoff_ref": {
          "$ref": "#/$defs/nullable_ref"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action_kind": {
                "const": "open_in_browser_handoff"
              }
            }
          },
          "then": {
            "properties": {
              "read_only": {
                "const": false
              },
              "handoff_ref": {
                "$ref": "#/$defs/non_empty_string"
              }
            }
          },
          "else": {
            "properties": {
              "read_only": {
                "const": true
              }
            }
          }
        }
      ]
    },
    "framework_pack_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pack_id",
        "pack_class",
        "pack_label",
        "supports_source_mapping",
        "supports_viewport_emulation",
        "supports_hot_reload",
        "coverage_label",
        "disclosure_label"
      ],
      "properties": {
        "pack_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pack_class": {
          "$ref": "#/$defs/framework_pack_class"
        },
        "pack_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "supports_source_mapping": {
          "type": "boolean"
        },
        "supports_viewport_emulation": {
          "type": "boolean"
        },
        "supports_hot_reload": {
          "type": "boolean"
        },
        "coverage_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "disclosure_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "diagnostic_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diagnostic_id",
        "durable_anchor_id",
        "pack_id",
        "preview_target_label",
        "viewport_state",
        "severity",
        "diagnostic_kind",
        "message_label",
        "source_mapping",
        "return_to_source",
        "blocked_class",
        "actor_attribution_label",
        "audit_row_ref",
        "attention_reasons",
        "review_summary",
        "source_contract_refs"
      ],
      "properties": {
        "diagnostic_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "durable_anchor_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pack_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preview_target_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "viewport_state": {
          "$ref": "#/$defs/device_viewport_state"
        },
        "severity": {
          "$ref": "#/$defs/diagnostic_severity"
        },
        "diagnostic_kind": {
          "$ref": "#/$defs/diagnostic_kind"
        },
        "message_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_mapping": {
          "$ref": "#/$defs/source_mapping_disclosure"
        },
        "return_to_source": {
          "$ref": "#/$defs/return_to_source_action"
        },
        "blocked_class": {
          "$ref": "#/$defs/return_to_source_blocked_class"
        },
        "actor_attribution_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "audit_row_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "attention_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "review_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "trust_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diagnostic_severity_explicit",
        "device_viewport_state_disclosed",
        "source_mapping_disclosed",
        "source_mapping_freshness_disclosed",
        "return_to_source_action_disclosed",
        "return_to_source_read_only_unless_attributed",
        "framework_pack_identity_explicit",
        "every_diagnostic_anchored",
        "every_action_attributable",
        "no_hidden_write_scope",
        "stale_source_map_narrows_action",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "diagnostic_severity_explicit": {
          "const": true
        },
        "device_viewport_state_disclosed": {
          "const": true
        },
        "source_mapping_disclosed": {
          "const": true
        },
        "source_mapping_freshness_disclosed": {
          "const": true
        },
        "return_to_source_action_disclosed": {
          "const": true
        },
        "return_to_source_read_only_unless_attributed": {
          "const": true
        },
        "framework_pack_identity_explicit": {
          "const": true
        },
        "every_diagnostic_anchored": {
          "const": true
        },
        "every_action_attributable": {
          "const": true
        },
        "no_hidden_write_scope": {
          "const": true
        },
        "stale_source_map_narrows_action": {
          "const": true
        },
        "downgrade_narrows_instead_of_hides": {
          "const": true
        },
        "stale_or_underqualified_blocks_promotion": {
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_diagnostics_panel_shows_severity",
        "preview_panel_shows_viewport_state",
        "diagnostic_card_shows_framework_pack",
        "diagnostic_card_shows_source_mapping",
        "return_to_source_action_shows_freshness",
        "review_workspace_header_shows_attribution",
        "command_palette_shows_diagnostic_state",
        "cli_headless_shows_truth",
        "support_export_shows_truth",
        "diagnostics_shows_truth",
        "help_about_shows_truth",
        "preview_labs_label_for_unqualified"
      ],
      "properties": {
        "preview_diagnostics_panel_shows_severity": {
          "const": true
        },
        "preview_panel_shows_viewport_state": {
          "const": true
        },
        "diagnostic_card_shows_framework_pack": {
          "const": true
        },
        "diagnostic_card_shows_source_mapping": {
          "const": true
        },
        "return_to_source_action_shows_freshness": {
          "const": true
        },
        "review_workspace_header_shows_attribution": {
          "const": true
        },
        "command_palette_shows_diagnostic_state": {
          "const": true
        },
        "cli_headless_shows_truth": {
          "const": true
        },
        "support_export_shows_truth": {
          "const": true
        },
        "diagnostics_shows_truth": {
          "const": true
        },
        "help_about_shows_truth": {
          "const": true
        },
        "preview_labs_label_for_unqualified": {
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
