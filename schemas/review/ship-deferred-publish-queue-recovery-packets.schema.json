{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/review/ship-deferred-publish-queue-recovery-packets.schema.json",
  "title": "Aureline deferred publish queue recovery packet",
  "description": "Boundary schema for the deferred-publish recovery packet that keeps queue identity, dependency order, freshness, retry posture, conflict policy, durable local packet continuity, activity projection vocabulary, and support-export-safe recovery detail aligned for provider-backed publish-later flows.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "surface_label",
    "queue_rows",
    "local_packets",
    "activity_rows",
    "support_export",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "ship_deferred_publish_queue_recovery_packets"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "surface_label": {
      "type": "string",
      "minLength": 1
    },
    "queue_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/queue_row"
      }
    },
    "local_packets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/local_packet"
      }
    },
    "activity_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/activity_row"
      }
    },
    "support_export": {
      "$ref": "#/$defs/support_export"
    },
    "trust_review": {
      "$ref": "#/$defs/trust_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "redaction_class_token": {
      "type": "string",
      "minLength": 1
    },
    "minted_at": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dependency_order_index",
        "dependency_class_token",
        "dependency_state_token",
        "rationale_summary"
      ],
      "properties": {
        "dependency_order_index": {
          "type": "integer",
          "minimum": 0
        },
        "dependency_class_token": {
          "type": "string",
          "minLength": 1
        },
        "dependency_state_token": {
          "type": "string",
          "minLength": 1
        },
        "rationale_summary": {
          "type": "string",
          "minLength": 1
        },
        "linked_record_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "action_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "action_class",
        "label",
        "route_ref",
        "enabled"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "minLength": 1
        },
        "action_class": {
          "type": "string",
          "enum": [
            "retry",
            "discard",
            "export_packet",
            "open_external"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "route_ref": {
          "type": "string",
          "minLength": 1
        },
        "enabled": {
          "type": "boolean"
        },
        "disabled_reason_label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "queue_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "queue_id",
        "canonical_object_ref",
        "canonical_object_label",
        "provider_family",
        "scope_review_resolution_id_ref",
        "local_packet_id_ref",
        "lifecycle_state",
        "target_freshness_requirement_class",
        "retry_posture_class",
        "conflict_policy_class",
        "dependency_chain",
        "audit_event_refs",
        "replay_requires_fresh_target_identity",
        "replay_requires_current_effective_scope",
        "changed_boundary_review_required",
        "high_impact_provider_mutation",
        "auto_replay_allowed",
        "action_routes",
        "summary_label"
      ],
      "properties": {
        "row_id": { "type": "string", "minLength": 1 },
        "queue_id": { "type": "string", "minLength": 1 },
        "canonical_object_ref": { "type": "string", "minLength": 1 },
        "canonical_object_label": { "type": "string", "minLength": 1 },
        "provider_family": { "type": "string", "minLength": 1 },
        "work_item_detail_record_id_ref": { "type": "string", "minLength": 1 },
        "publish_review_id_ref": { "type": "string", "minLength": 1 },
        "scope_review_resolution_id_ref": { "type": "string", "minLength": 1 },
        "local_packet_id_ref": { "type": "string", "minLength": 1 },
        "linked_publish_later_queue_item_ref": { "type": "string", "minLength": 1 },
        "linked_browser_handoff_packet_ref": { "type": "string", "minLength": 1 },
        "linked_offline_handoff_packet_ref": { "type": "string", "minLength": 1 },
        "lifecycle_state": {
          "type": "string",
          "enum": [
            "draft_only",
            "queued_for_publish",
            "blocked",
            "stale_target",
            "conflict_review_required",
            "published"
          ]
        },
        "block_reason_class": {
          "type": "string",
          "enum": [
            "auth_denied",
            "provider_outage",
            "validation_conflict",
            "redaction_policy_blocked",
            "fresh_target_required",
            "changed_boundary_needs_review"
          ]
        },
        "target_freshness_requirement_class": { "type": "string", "minLength": 1 },
        "retry_posture_class": { "type": "string", "minLength": 1 },
        "conflict_policy_class": { "type": "string", "minLength": 1 },
        "dependency_chain": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependency" }
        },
        "audit_event_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "replay_requires_fresh_target_identity": { "type": "boolean" },
        "replay_requires_current_effective_scope": { "type": "boolean" },
        "changed_boundary_review_required": { "type": "boolean" },
        "high_impact_provider_mutation": { "type": "boolean" },
        "auto_replay_allowed": { "type": "boolean" },
        "action_routes": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/action_route" }
        },
        "summary_label": { "type": "string", "minLength": 1 }
      }
    },
    "local_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_kind",
        "canonical_object_ref",
        "canonical_object_label",
        "lifecycle_state",
        "redaction_class_token",
        "persisted_across_restart",
        "export_safe_support_handoff",
        "audit_event_refs",
        "action_routes",
        "summary_label"
      ],
      "properties": {
        "packet_id": { "type": "string", "minLength": 1 },
        "packet_kind": { "type": "string", "minLength": 1 },
        "canonical_object_ref": { "type": "string", "minLength": 1 },
        "canonical_object_label": { "type": "string", "minLength": 1 },
        "lifecycle_state": { "type": "string", "minLength": 1 },
        "block_reason_class": { "type": "string", "minLength": 1 },
        "linked_queue_id_ref": { "type": "string", "minLength": 1 },
        "linked_browser_handoff_packet_ref": { "type": "string", "minLength": 1 },
        "linked_offline_handoff_packet_ref": { "type": "string", "minLength": 1 },
        "redaction_class_token": { "type": "string", "minLength": 1 },
        "persisted_across_restart": { "type": "boolean" },
        "export_safe_support_handoff": { "type": "boolean" },
        "audit_event_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "action_routes": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/action_route" }
        },
        "summary_label": { "type": "string", "minLength": 1 }
      }
    },
    "activity_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "canonical_object_ref",
        "queue_row_id_ref",
        "local_packet_id_ref",
        "lifecycle_state",
        "retry_posture_class",
        "conflict_policy_class",
        "exact_reopen_ref",
        "support_export_row_ref",
        "phase_label",
        "summary_label",
        "detail_label"
      ],
      "properties": {
        "row_id": { "type": "string", "minLength": 1 },
        "canonical_object_ref": { "type": "string", "minLength": 1 },
        "queue_row_id_ref": { "type": "string", "minLength": 1 },
        "local_packet_id_ref": { "type": "string", "minLength": 1 },
        "lifecycle_state": { "type": "string", "minLength": 1 },
        "block_reason_class": { "type": "string", "minLength": 1 },
        "retry_posture_class": { "type": "string", "minLength": 1 },
        "conflict_policy_class": { "type": "string", "minLength": 1 },
        "exact_reopen_ref": { "type": "string", "minLength": 1 },
        "support_export_row_ref": { "type": "string", "minLength": 1 },
        "phase_label": { "type": "string", "minLength": 1 },
        "summary_label": { "type": "string", "minLength": 1 },
        "detail_label": { "type": "string", "minLength": 1 }
      }
    },
    "support_export_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "canonical_object_ref",
        "queue_row_id_ref",
        "local_packet_id_ref",
        "lifecycle_state",
        "target_freshness_requirement_class",
        "retry_posture_class",
        "conflict_policy_class",
        "action_route_ids",
        "summary_label"
      ],
      "properties": {
        "row_id": { "type": "string", "minLength": 1 },
        "canonical_object_ref": { "type": "string", "minLength": 1 },
        "queue_row_id_ref": { "type": "string", "minLength": 1 },
        "local_packet_id_ref": { "type": "string", "minLength": 1 },
        "lifecycle_state": { "type": "string", "minLength": 1 },
        "block_reason_class": { "type": "string", "minLength": 1 },
        "target_freshness_requirement_class": { "type": "string", "minLength": 1 },
        "retry_posture_class": { "type": "string", "minLength": 1 },
        "conflict_policy_class": { "type": "string", "minLength": 1 },
        "action_route_ids": {
          "type": "array",
          "minItems": 4,
          "items": { "type": "string", "minLength": 1 }
        },
        "summary_label": { "type": "string", "minLength": 1 }
      }
    },
    "support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_id",
        "rows",
        "consumer_surfaces",
        "raw_provider_material_excluded"
      ],
      "properties": {
        "export_id": { "type": "string", "minLength": 1 },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/support_export_row" }
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "raw_provider_material_excluded": { "type": "boolean" }
      }
    },
    "trust_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queue_rows_preserve_replay_contract",
        "durable_local_packets_survive_restart_and_export",
        "blocked_publish_preserves_intent_and_actions",
        "replay_requires_fresh_target_and_scope",
        "high_impact_actions_never_auto_replay"
      ],
      "properties": {
        "queue_rows_preserve_replay_contract": { "type": "boolean" },
        "durable_local_packets_survive_restart_and_export": { "type": "boolean" },
        "blocked_publish_preserves_intent_and_actions": { "type": "boolean" },
        "replay_requires_fresh_target_and_scope": { "type": "boolean" },
        "high_impact_actions_never_auto_replay": { "type": "boolean" }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queue_rows_use_shared_lifecycle_vocabulary",
        "activity_rows_use_shared_lifecycle_vocabulary",
        "support_export_uses_shared_lifecycle_vocabulary",
        "authoritative_object_identity_is_shared",
        "authoritative_object_keeps_stable_actions"
      ],
      "properties": {
        "queue_rows_use_shared_lifecycle_vocabulary": { "type": "boolean" },
        "activity_rows_use_shared_lifecycle_vocabulary": { "type": "boolean" },
        "support_export_uses_shared_lifecycle_vocabulary": { "type": "boolean" },
        "authoritative_object_identity_is_shared": { "type": "boolean" },
        "authoritative_object_keeps_stable_actions": { "type": "boolean" }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "minLength": 1
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
