{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/review/certify-work-item-provider-linked-mutation-acting-identity-and-publish-later-or-reconciliation-depth-on-all-claimed-m5-team-workflow-rows.schema.json",
  "title": "Aureline M5 provider-backed team-workflow certification",
  "description": "Export-safe packet certifying every claimed M5 provider-backed team-workflow row: work-item object vocabulary, provider-linked mutation review, acting identity and effective scope, browser handoff continuity, deferred publish continuity, and provider event reconciliation. Each row carries its evidence refs, downgrade triggers, rollback posture, feature-scorecard summary, provider-family compatibility story, acting-identity story, offline/publish-later story, and reconciliation proof. A compatibility report aggregates the per-row verdicts into one promotion result so release, help/about, service-health, and support surfaces can ingest the same certification truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "certification_label",
    "certified_rows",
    "compatibility_report",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "certify_work_item_provider_linked_mutation_acting_identity_and_publish_later_or_reconciliation_depth_on_all_claimed_m5_team_workflow_rows"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "certification_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "certified_rows": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "$ref": "#/$defs/certified_row"
      }
    },
    "compatibility_report": {
      "$ref": "#/$defs/compatibility_report"
    },
    "trust_review": {
      "$ref": "#/$defs/trust_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "claimed_row": {
      "type": "string",
      "enum": [
        "work_item_object_vocabulary",
        "provider_linked_mutation",
        "acting_identity_and_effective_scope",
        "browser_handoff_continuity",
        "deferred_publish_continuity",
        "provider_event_reconciliation"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "limited",
        "experimental",
        "not_marketed"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "certified",
        "narrowed_certified",
        "blocked",
        "not_certified"
      ]
    },
    "provider_family": {
      "type": "string",
      "enum": [
        "issue_tracker",
        "code_host",
        "ci_checks"
      ]
    },
    "provider_family_posture": {
      "type": "string",
      "enum": [
        "qualified",
        "limited",
        "not_marketed"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "evidence_packet_invalid",
        "provider_authority_stale",
        "effective_scope_drift",
        "browser_only_fallback",
        "publish_later_continuity_stale",
        "callback_reconciliation_stale",
        "return_anchor_unproven",
        "replay_ledger_unavailable",
        "upstream_dependency_narrowed"
      ]
    },
    "rollback_posture": {
      "type": "string",
      "enum": [
        "provider_truth_separation_preserved",
        "local_draft_preserved",
        "recompute_scope_before_retry",
        "return_anchor_preserved",
        "deferred_publish_packet_preserved",
        "audit_only_evidence_preserved"
      ]
    },
    "row_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "proof_fresh"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "proof_fresh": {
          "type": "boolean"
        }
      }
    },
    "provider_family_compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_family",
        "posture",
        "rationale"
      ],
      "properties": {
        "provider_family": {
          "$ref": "#/$defs/provider_family"
        },
        "posture": {
          "$ref": "#/$defs/provider_family_posture"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "acting_identity_story": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_ref",
        "human_account_visible",
        "installation_grant_visible",
        "delegated_credential_visible",
        "browser_only_fallback_visible",
        "denied_scope_visible",
        "rationale"
      ],
      "properties": {
        "proof_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "human_account_visible": {
          "type": "boolean"
        },
        "installation_grant_visible": {
          "type": "boolean"
        },
        "delegated_credential_visible": {
          "type": "boolean"
        },
        "browser_only_fallback_visible": {
          "type": "boolean"
        },
        "denied_scope_visible": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "offline_publish_later_story": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_ref",
        "local_draft_preserved",
        "queued_publish_preserved",
        "export_safe_packet_preserved",
        "return_anchor_preserved",
        "replay_requires_review_after_drift",
        "rationale"
      ],
      "properties": {
        "proof_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "local_draft_preserved": {
          "type": "boolean"
        },
        "queued_publish_preserved": {
          "type": "boolean"
        },
        "export_safe_packet_preserved": {
          "type": "boolean"
        },
        "return_anchor_preserved": {
          "type": "boolean"
        },
        "replay_requires_review_after_drift": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "reconciliation_story": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_ref",
        "typed_event_envelopes_visible",
        "replay_ledger_visible",
        "callback_denials_auditable",
        "dedupe_visible",
        "typed_reconciliation_required_for_mutation",
        "rationale"
      ],
      "properties": {
        "proof_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "typed_event_envelopes_visible": {
          "type": "boolean"
        },
        "replay_ledger_visible": {
          "type": "boolean"
        },
        "callback_denials_auditable": {
          "type": "boolean"
        },
        "dedupe_visible": {
          "type": "boolean"
        },
        "typed_reconciliation_required_for_mutation": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "certified_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row",
        "claimed_qualification",
        "verdict",
        "upstream_record_kind",
        "evidence_artifact_ref",
        "evidence_schema_ref",
        "evidence_doc_ref",
        "feature_scorecard_summary",
        "provider_family_compatibility",
        "acting_identity_story",
        "offline_publish_later_story",
        "reconciliation_story",
        "downgrade_triggers",
        "rollback_posture",
        "proof_freshness"
      ],
      "properties": {
        "row": {
          "$ref": "#/$defs/claimed_row"
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "verdict": {
          "$ref": "#/$defs/verdict"
        },
        "upstream_record_kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_artifact_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_schema_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_doc_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "feature_scorecard_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "provider_family_compatibility": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/provider_family_compatibility"
          }
        },
        "acting_identity_story": {
          "$ref": "#/$defs/acting_identity_story"
        },
        "offline_publish_later_story": {
          "$ref": "#/$defs/offline_publish_later_story"
        },
        "reconciliation_story": {
          "$ref": "#/$defs/reconciliation_story"
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "rollback_posture": {
          "$ref": "#/$defs/rollback_posture"
        },
        "proof_freshness": {
          "$ref": "#/$defs/row_freshness"
        }
      }
    },
    "compatibility_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows",
        "certified_count",
        "narrowed_count",
        "blocked_count",
        "not_certified_count",
        "all_rows_publishable",
        "promotion_note"
      ],
      "properties": {
        "total_rows": {
          "type": "integer",
          "minimum": 0
        },
        "certified_count": {
          "type": "integer",
          "minimum": 0
        },
        "narrowed_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "not_certified_count": {
          "type": "integer",
          "minimum": 0
        },
        "all_rows_publishable": {
          "type": "boolean"
        },
        "promotion_note": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "trust_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_objects_never_masquerade_as_local_truth",
        "truth_states_remain_visibly_distinct",
        "acting_identity_visible",
        "effective_scope_visible",
        "browser_handoff_return_anchor_safe",
        "deferred_publish_survives_restart",
        "deferred_publish_survives_reconnect",
        "callback_events_deduplicated",
        "callback_denials_auditable",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_broad_claims"
      ],
      "properties": {
        "provider_objects_never_masquerade_as_local_truth": {
          "type": "boolean"
        },
        "truth_states_remain_visibly_distinct": {
          "type": "boolean"
        },
        "acting_identity_visible": {
          "type": "boolean"
        },
        "effective_scope_visible": {
          "type": "boolean"
        },
        "browser_handoff_return_anchor_safe": {
          "type": "boolean"
        },
        "deferred_publish_survives_restart": {
          "type": "boolean"
        },
        "deferred_publish_survives_reconnect": {
          "type": "boolean"
        },
        "callback_events_deduplicated": {
          "type": "boolean"
        },
        "callback_denials_auditable": {
          "type": "boolean"
        },
        "downgrade_narrows_instead_of_hides": {
          "type": "boolean"
        },
        "stale_or_underqualified_blocks_broad_claims": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_workspace_shows_certification",
        "work_item_detail_shows_certification",
        "incident_workspace_shows_certification",
        "cli_headless_shows_certification",
        "support_export_shows_certification",
        "help_about_shows_certification",
        "service_health_shows_certification",
        "public_truth_pack_shows_certification",
        "release_manifests_show_certification",
        "provider_family_specific_badging_visible"
      ],
      "properties": {
        "review_workspace_shows_certification": {
          "type": "boolean"
        },
        "work_item_detail_shows_certification": {
          "type": "boolean"
        },
        "incident_workspace_shows_certification": {
          "type": "boolean"
        },
        "cli_headless_shows_certification": {
          "type": "boolean"
        },
        "support_export_shows_certification": {
          "type": "boolean"
        },
        "help_about_shows_certification": {
          "type": "boolean"
        },
        "service_health_shows_certification": {
          "type": "boolean"
        },
        "public_truth_pack_shows_certification": {
          "type": "boolean"
        },
        "release_manifests_show_certification": {
          "type": "boolean"
        },
        "provider_family_specific_badging_visible": {
          "type": "boolean"
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_provider_authority_stale",
        "auto_narrow_on_publish_later_stale",
        "auto_narrow_on_reconciliation_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_provider_authority_stale": {
          "type": "boolean"
        },
        "auto_narrow_on_publish_later_stale": {
          "type": "boolean"
        },
        "auto_narrow_on_reconciliation_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
