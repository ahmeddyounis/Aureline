{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/compat/m3_preview_row_packet.schema.json",
  "title": "Aureline M3 runtime and ecosystem preview-row packet register",
  "description": "Boundary schema for the metadata-only preview-row packets that bind notebook trust, repair posture, install review, compatibility labels, activation budgets, and support projections to claimed beta rows.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "packet_ref",
    "as_of",
    "generated_at",
    "source_claim_manifest_ref",
    "source_claimed_surface_register_ref",
    "docs_ref",
    "fixture_dir_ref",
    "support_export_projection_ref",
    "rows"
  ],
  "properties": {
    "record_kind": {
      "const": "m3_preview_row_packet_register"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "packet_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "as_of": {
      "$ref": "#/$defs/non_empty_string"
    },
    "generated_at": {
      "$ref": "#/$defs/non_empty_string"
    },
    "source_claim_manifest_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "source_claimed_surface_register_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "docs_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "fixture_dir_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "support_export_projection_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/preview_row_packet"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "uniqueItems": true
    },
    "ref_array": {
      "$ref": "#/$defs/string_array"
    },
    "projection": {
      "type": "object",
      "required": [
        "surface",
        "projection_ref",
        "preserves_same_packet",
        "raw_private_material_excluded"
      ],
      "properties": {
        "surface": {
          "enum": [
            "docs_help",
            "release_packet",
            "support_export",
            "cli_headless",
            "install_review",
            "marketplace_discovery",
            "review_workspace",
            "ai_context"
          ]
        },
        "projection_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preserves_same_packet": {
          "const": true
        },
        "raw_private_material_excluded": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "lane_state": {
      "type": "object",
      "required": [
        "state"
      ],
      "properties": {
        "state": {
          "enum": [
            "current",
            "not_applicable",
            "downgraded_out_of_scope",
            "blocked"
          ]
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "packet_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "class": {
          "$ref": "#/$defs/non_empty_string"
        },
        "trust_rung": {
          "$ref": "#/$defs/non_empty_string"
        },
        "round_trip_risk_class": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kernel_execution_posture": {
          "$ref": "#/$defs/non_empty_string"
        },
        "repair_class": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rollback_posture": {
          "$ref": "#/$defs/non_empty_string"
        },
        "subject_class": {
          "$ref": "#/$defs/non_empty_string"
        },
        "native_review_required": {
          "type": "boolean"
        },
        "disclosure_complete": {
          "type": "boolean"
        },
        "label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_class": {
          "$ref": "#/$defs/non_empty_string"
        },
        "compatibility_row_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "budget_required": {
          "type": "boolean"
        },
        "blocks_promotion_when_stale": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "promotion_gate": {
      "type": "object",
      "required": [
        "state",
        "blocks_beta_promotion",
        "downgrade_reason_tokens"
      ],
      "properties": {
        "state": {
          "enum": [
            "promotable_with_limit",
            "downgraded_out_of_claimed_set",
            "blocked"
          ]
        },
        "blocks_beta_promotion": {
          "type": "boolean"
        },
        "downgrade_reason_tokens": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    },
    "preview_row_packet": {
      "type": "object",
      "required": [
        "row_id",
        "source_row_ref",
        "row_kind",
        "row_family",
        "packet_state",
        "lifecycle_label",
        "claim_posture_effective",
        "support_effective",
        "notebook_trust",
        "repair_posture",
        "install_review",
        "compatibility_label",
        "activation_budget",
        "promotion_gate",
        "consumer_projections",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_row_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "row_kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "row_family": {
          "enum": [
            "runtime_heavy",
            "ecosystem_heavy",
            "runtime_and_ecosystem",
            "proof_only_runtime"
          ]
        },
        "packet_state": {
          "enum": [
            "current_packet",
            "downgraded_out_of_claimed_set"
          ]
        },
        "lifecycle_label": {
          "enum": [
            "preview",
            "beta",
            "held_for_later",
            "explicitly_out_of_scope"
          ]
        },
        "claim_posture_effective": {
          "$ref": "#/$defs/non_empty_string"
        },
        "support_effective": {
          "$ref": "#/$defs/non_empty_string"
        },
        "notebook_trust": {
          "$ref": "#/$defs/lane_state"
        },
        "repair_posture": {
          "$ref": "#/$defs/lane_state"
        },
        "install_review": {
          "$ref": "#/$defs/lane_state"
        },
        "compatibility_label": {
          "$ref": "#/$defs/lane_state"
        },
        "activation_budget": {
          "$ref": "#/$defs/lane_state"
        },
        "promotion_gate": {
          "$ref": "#/$defs/promotion_gate"
        },
        "consumer_projections": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/projection"
          }
        },
        "raw_private_material_excluded": {
          "const": true
        },
        "ambient_authority_excluded": {
          "const": true
        }
      },
      "additionalProperties": false
    }
  }
}
