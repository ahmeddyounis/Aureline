{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aureline.dev/compat/mixed-version-compatibility-and-skew-governance.schema.json",
  "title": "Mixed-version compatibility and skew governance",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "governance_id",
    "as_of",
    "boundary_rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "record_kind": { "const": "mixed_version_compatibility_and_skew_governance" },
    "governance_id": { "type": "string", "pattern": "^mixed_version_governance:" },
    "status": { "type": "string" },
    "overview_page": { "type": "string" },
    "as_of": { "type": "string" },
    "claim_manifest_ref": { "type": "string" },
    "lifecycle_labels": { "type": "array", "items": { "type": "string" } },
    "boundary_families": { "type": "array", "items": { "type": "string" } },
    "skew_window_classes": { "type": "array", "items": { "type": "string" } },
    "governance_states": { "type": "array", "items": { "type": "string" } },
    "unsupported_flow_labels": { "type": "array", "items": { "type": "string" } },
    "gap_reasons": { "type": "array", "items": { "type": "string" } },
    "launch_cutline": { "type": "object" },
    "required_boundary_families": { "type": "array", "items": { "type": "string" } },
    "governance_rules": { "type": "array", "items": { "type": "object" } },
    "boundary_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "boundary_row_id",
          "boundary_family",
          "claim_label",
          "effective_label",
          "governance_state",
          "negotiated_fields",
          "supported_skew_window",
          "upgrade_order",
          "rollback_order",
          "downgrade_posture",
          "unsupported_behavior",
          "skew_window_drill_packet",
          "rollback_order_packet",
          "downstream_bindings",
          "owner_signoff"
        ],
        "properties": {
          "boundary_row_id": { "type": "string", "pattern": "^mixed_version_boundary:" },
          "boundary_family": {
            "enum": [
              "launcher_and_local_sidecars",
              "desktop_cli_and_remote_agent",
              "managed_control_plane",
              "extension_host_and_sdk",
              "schema_or_state_bundle",
              "provider_linked_packet",
              "audit_or_event_producer_consumer"
            ]
          },
          "claim_label": { "type": "string" },
          "effective_label": { "type": "string" },
          "governance_state": { "type": "string" },
          "negotiated_fields": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "supported_skew_window": { "type": "object" },
          "upgrade_order": { "type": "object" },
          "rollback_order": { "type": "object" },
          "downgrade_posture": { "type": "object" },
          "unsupported_behavior": { "type": "object" },
          "skew_window_drill_packet": { "type": "object" },
          "rollback_order_packet": { "type": "object" },
          "downstream_bindings": { "type": "object" },
          "owner_signoff": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "publication": { "type": "object" },
    "summary": { "type": "object" }
  },
  "additionalProperties": true
}
