{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/change/portable_bundle.schema.json",
  "title": "Aureline portable change bundle and shelf record",
  "description": "Boundary schema for portable change bundles and shelf entries consumed by review, shell, browser-companion, incident, and support-export paths. A portable bundle carries bundle identity, diff refs, evidence refs, review-pack binding, target/worktree identity, validation freshness, redaction posture, and support-export lineage without requiring code-host or cloud residency. Raw credentials, ambient authority, live bearer tokens, raw remote URLs, raw absolute paths, and raw secret material never cross this boundary. Adding a closed vocabulary value is additive-minor and bumps schema_version; repurposing a value is breaking.",
  "type": "object",
  "$ref": "#/$defs/portable_bundle_record",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable identifier safe for logs, RPC, review packets, support exports, and browser companion handoff. Raw paths, raw URLs, and secrets never appear here."
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "object_class": {
      "type": "string",
      "enum": ["portable_bundle", "shelf_entry"]
    },
    "handoff_purpose_class": {
      "type": "string",
      "enum": [
        "offline_review_handoff",
        "browser_companion_handoff",
        "incident_follow_up",
        "support_export",
        "review_export"
      ]
    },
    "bundle_state_class": {
      "type": "string",
      "enum": [
        "exported_read_only",
        "shelf_entry_saved",
        "imported_compare_only",
        "desktop_resume_pending_revalidation",
        "browser_companion_read_only",
        "destroyed_tombstone"
      ]
    },
    "target_kind_class": {
      "type": "string",
      "enum": [
        "local_worktree",
        "linked_worktree",
        "managed_workspace",
        "provider_review_target",
        "incident_workspace",
        "target_kind_unknown_requires_review"
      ]
    },
    "diff_ref_class": {
      "type": "string",
      "enum": [
        "patch_ref",
        "structured_diff_ref",
        "review_workspace_diff_ref",
        "evidence_only_diff_ref",
        "pathset_manifest_ref"
      ]
    },
    "evidence_ref_class": {
      "type": "string",
      "enum": [
        "review_pack_result",
        "ai_evidence_packet",
        "incident_packet",
        "support_export_manifest",
        "validation_result",
        "browser_handoff_record",
        "mutation_journal_slice",
        "runbook_packet",
        "provider_status_snapshot"
      ]
    },
    "review_pack_parity_class": {
      "type": "string",
      "enum": [
        "review_pack_current",
        "review_pack_stale",
        "review_pack_unavailable_offline",
        "review_pack_unknown_requires_review"
      ]
    },
    "validation_freshness_class": {
      "type": "string",
      "enum": [
        "validation_current",
        "stale_base_changed",
        "stale_worktree_scope_changed",
        "stale_review_pack_version_changed",
        "stale_environment_capsule_changed",
        "provider_overlay_unavailable_local_continues",
        "imported_compare_only_validation"
      ]
    },
    "stale_validation_label": {
      "type": "string",
      "enum": [
        "base_revision_changed",
        "worktree_scope_changed",
        "review_pack_version_changed",
        "environment_capsule_changed",
        "provider_overlay_unavailable",
        "evidence_snapshot_stale",
        "imported_bundle_not_live"
      ]
    },
    "authority_class": {
      "type": "string",
      "enum": [
        "no_live_provider_authority",
        "imported_stale_provider_snapshot",
        "desktop_reauth_required",
        "local_resume_only",
        "authority_unknown_requires_review"
      ]
    },
    "open_mode_class": {
      "type": "string",
      "enum": [
        "inspect_offline",
        "compare_only_reopen",
        "desktop_resume_after_revalidation",
        "browser_companion_read_only",
        "support_export_inspect"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "redacted_diff_summary",
        "operator_only_restricted",
        "internal_support_restricted"
      ]
    },
    "destruction_semantics_class": {
      "type": "string",
      "enum": [
        "retention_policy_bound",
        "destroy_on_import_request",
        "tombstone_after_destroy"
      ]
    },
    "support_lineage_class": {
      "type": "string",
      "enum": [
        "review_export_lineage",
        "support_export_lineage",
        "incident_handoff_lineage",
        "browser_handoff_lineage"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "portable_bundle_inspector",
        "review_preview",
        "browser_companion",
        "cli_headless_entry",
        "support_export",
        "incident_workspace",
        "docs_review"
      ]
    },
    "target_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_ref",
        "repo_ref",
        "worktree_ref",
        "base_ref",
        "target_ref",
        "target_kind_class"
      ],
      "properties": {
        "workspace_ref": { "$ref": "#/$defs/opaque_id" },
        "repo_ref": { "$ref": "#/$defs/opaque_id" },
        "worktree_ref": { "$ref": "#/$defs/opaque_id" },
        "base_ref": { "$ref": "#/$defs/opaque_id" },
        "head_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "target_ref": { "$ref": "#/$defs/opaque_id" },
        "target_kind_class": { "$ref": "#/$defs/target_kind_class" },
        "environment_capsule_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "diff_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diff_ref",
        "diff_ref_class",
        "path_scope_ref",
        "raw_diff_body_included",
        "compare_only"
      ],
      "properties": {
        "diff_ref": { "$ref": "#/$defs/opaque_id" },
        "diff_ref_class": { "$ref": "#/$defs/diff_ref_class" },
        "path_scope_ref": { "$ref": "#/$defs/opaque_id" },
        "body_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "raw_diff_body_included": { "const": false },
        "compare_only": { "type": "boolean" }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_ref",
        "evidence_ref_class",
        "freshness_class",
        "redaction_class"
      ],
      "properties": {
        "evidence_ref": { "$ref": "#/$defs/opaque_id" },
        "evidence_ref_class": { "$ref": "#/$defs/evidence_ref_class" },
        "freshness_class": { "$ref": "#/$defs/validation_freshness_class" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    },
    "review_pack_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_pack_ref",
        "review_pack_version",
        "review_pack_digest_ref",
        "parity_class"
      ],
      "properties": {
        "review_pack_ref": { "$ref": "#/$defs/opaque_id" },
        "review_pack_version": { "$ref": "#/$defs/non_empty_string" },
        "review_pack_digest_ref": { "$ref": "#/$defs/opaque_id" },
        "parity_class": { "$ref": "#/$defs/review_pack_parity_class" }
      }
    },
    "validation_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness_class",
        "staleness_labels",
        "revalidation_required_before_resume"
      ],
      "properties": {
        "freshness_class": { "$ref": "#/$defs/validation_freshness_class" },
        "staleness_labels": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/stale_validation_label" }
        },
        "validated_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/monotonic_timestamp" }
          ]
        },
        "revalidation_required_before_resume": { "type": "boolean" }
      }
    },
    "authority_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_class",
        "live_bearer_authority_included",
        "ambient_credentials_included",
        "secret_material_included",
        "desktop_reauth_required_before_mutation"
      ],
      "properties": {
        "authority_class": { "$ref": "#/$defs/authority_class" },
        "provider_snapshot_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "live_bearer_authority_included": { "const": false },
        "ambient_credentials_included": { "const": false },
        "secret_material_included": { "const": false },
        "desktop_reauth_required_before_mutation": { "type": "boolean" }
      }
    },
    "redaction_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redaction_class",
        "profile_ref",
        "raw_path_export_allowed",
        "raw_remote_url_export_allowed",
        "raw_secret_export_allowed",
        "raw_credential_export_allowed",
        "destruction_semantics_class",
        "destruction_receipt_refs",
        "destroy_after_import_supported"
      ],
      "properties": {
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "profile_ref": { "$ref": "#/$defs/opaque_id" },
        "raw_path_export_allowed": { "const": false },
        "raw_remote_url_export_allowed": { "const": false },
        "raw_secret_export_allowed": { "const": false },
        "raw_credential_export_allowed": { "const": false },
        "destruction_semantics_class": { "$ref": "#/$defs/destruction_semantics_class" },
        "destruction_receipt_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "destroy_after_import_supported": { "type": "boolean" }
      }
    },
    "support_export_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lineage_class",
        "support_export_ref",
        "mutation_journal_refs"
      ],
      "properties": {
        "lineage_class": { "$ref": "#/$defs/support_lineage_class" },
        "support_export_ref": { "$ref": "#/$defs/opaque_id" },
        "parent_export_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "review_workspace_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "incident_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "browser_handoff_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "mutation_journal_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      }
    },
    "review_invariants": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "open_import_export_parity",
        "target_identity_pinned",
        "diff_refs_preserved",
        "evidence_refs_preserved",
        "no_live_provider_authority",
        "secrets_excluded",
        "stale_validation_labeled",
        "redaction_profile_declared"
      ],
      "properties": {
        "open_import_export_parity": { "const": true },
        "target_identity_pinned": { "const": true },
        "diff_refs_preserved": { "const": true },
        "evidence_refs_preserved": { "const": true },
        "no_live_provider_authority": { "const": true },
        "secrets_excluded": { "const": true },
        "stale_validation_labeled": { "const": true },
        "redaction_profile_declared": { "const": true }
      }
    },
    "portable_bundle_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "bundle_id",
        "object_class",
        "handoff_purpose_class",
        "bundle_state_class",
        "display_label",
        "summary",
        "target_identity",
        "review_pack",
        "diff_refs",
        "evidence_refs",
        "validation_state",
        "authority_state",
        "open_modes",
        "redaction_profile",
        "support_export_lineage",
        "consumer_surfaces",
        "review_invariants",
        "minted_at"
      ],
      "properties": {
        "record_kind": { "const": "portable_change_bundle_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "bundle_id": { "$ref": "#/$defs/opaque_id" },
        "object_class": { "$ref": "#/$defs/object_class" },
        "handoff_purpose_class": { "$ref": "#/$defs/handoff_purpose_class" },
        "bundle_state_class": { "$ref": "#/$defs/bundle_state_class" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "target_identity": { "$ref": "#/$defs/target_identity" },
        "review_pack": { "$ref": "#/$defs/review_pack_binding" },
        "diff_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/diff_ref" }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidence_ref" }
        },
        "validation_state": { "$ref": "#/$defs/validation_state" },
        "authority_state": { "$ref": "#/$defs/authority_state" },
        "open_modes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/open_mode_class" },
          "contains": { "const": "inspect_offline" }
        },
        "redaction_profile": { "$ref": "#/$defs/redaction_profile" },
        "support_export_lineage": { "$ref": "#/$defs/support_export_lineage" },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/consumer_surface" },
          "contains": { "const": "portable_bundle_inspector" }
        },
        "review_invariants": { "$ref": "#/$defs/review_invariants" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Stale or imported validation states must carry at least one stale-validation label.",
          "if": {
            "properties": {
              "validation_state": {
                "properties": {
                  "freshness_class": {
                    "not": { "const": "validation_current" }
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "validation_state": {
                "properties": {
                  "staleness_labels": { "minItems": 1 }
                }
              },
              "open_modes": {
                "contains": { "const": "compare_only_reopen" }
              }
            }
          }
        },
        {
          "description": "Shelf entries must be saved, pending desktop revalidation, or tombstoned.",
          "if": {
            "properties": {
              "object_class": { "const": "shelf_entry" }
            }
          },
          "then": {
            "properties": {
              "bundle_state_class": {
                "enum": [
                  "shelf_entry_saved",
                  "desktop_resume_pending_revalidation",
                  "destroyed_tombstone"
                ]
              }
            }
          }
        }
      ]
    }
  }
}
