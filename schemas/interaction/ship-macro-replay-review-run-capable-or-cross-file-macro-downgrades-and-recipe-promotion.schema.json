{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/interaction/ship-macro-replay-review-run-capable-or-cross-file-macro-downgrades-and-recipe-promotion.schema.json",
  "title": "Aureline M5 macro-replay review: run-capable / cross-file downgrades and recipe-promotion paths",
  "description": "Export-safe packet binding each claimed M5 modal surface (editor, notebook, data/API, preview, docs, review, runtime, companion) to one macro-replay attempt and its resolved outcome. Each record preserves the source register the macro was recorded into, the target scope (with file / surface span counts), the timing posture, and an ordered exact command lineage keyed by command_id / command_revision_ref, so a replay is never reduced to opaque text. A macro whose scope crosses files or surfaces, whose lineage invokes a run-capable / elevated command, whose timing is unstable, whose lineage carries an unmapped or unsafe step, or whose review proof is stale or missing fires one or more replay triggers; each trigger imposes a minimum-safety floor so the record can never resolve to exact_replay_local_editor_only — it must open review, downgrade to observe-no-mutation, promote to a declarative recipe, or be rejected. A provider-linked surface never reads as a locally verified replay. Raw keystroke buffers, raw editor buffer bytes, raw shell fragments, raw provider payloads, file contents, private paths, and credentials never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "label",
    "records",
    "guardrails",
    "consumer_projection",
    "verification_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "m5_macro_replay_review_run_capable_cross_file_downgrade_recipe_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/macro_replay_review_record"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "verification_freshness": {
      "$ref": "#/$defs/verification_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "keyboard_surface_kind": {
      "type": "string",
      "enum": [
        "editor_core",
        "notebook_surface",
        "data_api_surface",
        "preview_surface",
        "docs_surface",
        "review_surface",
        "runtime_surface",
        "companion_surface"
      ]
    },
    "surface_origin_class": {
      "type": "string",
      "enum": [
        "first_party_surface",
        "embedded_runtime_surface",
        "provider_linked_surface",
        "imported_read_only_surface"
      ]
    },
    "proof_currency": {
      "type": "string",
      "enum": [
        "verified_current",
        "cached_within_window",
        "imported_current",
        "stale_expired",
        "requires_review",
        "missing_proof"
      ]
    },
    "register_class": {
      "type": "string",
      "enum": [
        "named_register",
        "numbered_register",
        "append_register",
        "clipboard_linked_register",
        "recording_buffer_register"
      ]
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "single_surface_single_file",
        "single_surface_multi_selection",
        "cross_file_within_surface",
        "cross_surface_span",
        "workspace_wide_span"
      ]
    },
    "timing_class": {
      "type": "string",
      "enum": [
        "stable_deterministic",
        "depends_on_async_output",
        "depends_on_external_state"
      ]
    },
    "command_lineage_class": {
      "type": "string",
      "enum": [
        "core_command",
        "imported_command",
        "extension_command",
        "ai_tool_handle",
        "cli_verb",
        "run_capable_command",
        "unmapped_keystroke_unsafe"
      ]
    },
    "write_class": {
      "type": "string",
      "enum": [
        "read_only",
        "editor_buffer_mutation",
        "multi_file_mutation",
        "run_capable_execution",
        "network_mutation",
        "settings_mutation"
      ]
    },
    "outcome_class": {
      "type": "string",
      "enum": [
        "exact_replay_local_editor_only",
        "review_required_before_apply",
        "downgraded_to_observer_no_mutation",
        "promoted_to_declarative_recipe",
        "rejected_unsafe_replay"
      ]
    },
    "replay_trigger": {
      "type": "string",
      "enum": [
        "cross_file_scope",
        "cross_surface_or_workspace_scope",
        "run_capable_or_elevated_command",
        "unstable_timing",
        "unmapped_or_unsafe_step",
        "stale_or_missing_review_proof"
      ]
    },
    "surface_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_id", "origin_class", "surface_fingerprint_token"],
      "properties": {
        "surface_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "origin_class": {
          "$ref": "#/$defs/surface_origin_class"
        },
        "surface_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "source_register": {
      "type": "object",
      "additionalProperties": false,
      "required": ["register_token", "register_class", "display_label"],
      "properties": {
        "register_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "register_class": {
          "$ref": "#/$defs/register_class"
        },
        "display_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "command_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "lineage_class",
        "command_id",
        "command_revision_ref",
        "write_class",
        "run_capable",
        "display_label"
      ],
      "properties": {
        "step_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "lineage_class": {
          "$ref": "#/$defs/command_lineage_class"
        },
        "command_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "command_revision_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "write_class": {
          "$ref": "#/$defs/write_class"
        },
        "run_capable": {
          "type": "boolean"
        },
        "display_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "ai_tool_handle_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_currency", "summary"],
      "properties": {
        "proof_currency": {
          "$ref": "#/$defs/proof_currency"
        },
        "proof_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "proof_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "macro_replay_review_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "surface_kind",
        "subject",
        "label_summary",
        "source_register",
        "scope",
        "files_touched",
        "surfaces_spanned",
        "timing",
        "command_lineage",
        "lineage_summary",
        "verification",
        "outcome",
        "fired_triggers",
        "raw_keystroke_bytes_present",
        "raw_buffer_bytes_present",
        "raw_shell_fragment_present",
        "lineage_collapsed_to_opaque_text",
        "silent_authority_widening_taken",
        "evidence_refs",
        "minted_at"
      ],
      "properties": {
        "record_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_kind": {
          "$ref": "#/$defs/keyboard_surface_kind"
        },
        "subject": {
          "$ref": "#/$defs/surface_subject"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_register": {
          "$ref": "#/$defs/source_register"
        },
        "scope": {
          "$ref": "#/$defs/scope_class"
        },
        "files_touched": {
          "type": "integer",
          "minimum": 0
        },
        "surfaces_spanned": {
          "type": "integer",
          "minimum": 0
        },
        "timing": {
          "$ref": "#/$defs/timing_class"
        },
        "command_lineage": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/command_step"
          }
        },
        "lineage_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "verification": {
          "$ref": "#/$defs/verification"
        },
        "outcome": {
          "$ref": "#/$defs/outcome_class"
        },
        "fired_triggers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/replay_trigger"
          }
        },
        "review_reason_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "downgrade_target_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "promoted_recipe_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rejection_reason_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "raw_keystroke_bytes_present": {
          "const": false
        },
        "raw_buffer_bytes_present": {
          "const": false
        },
        "raw_shell_fragment_present": {
          "const": false
        },
        "lineage_collapsed_to_opaque_text": {
          "const": false
        },
        "silent_authority_widening_taken": {
          "const": false
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "minted_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "comment": "A broad macro can never resolve to the silent exact lane.",
          "if": {
            "properties": {
              "fired_triggers": {
                "minItems": 1
              }
            },
            "required": ["fired_triggers"]
          },
          "then": {
            "properties": {
              "outcome": {
                "not": {
                  "const": "exact_replay_local_editor_only"
                }
              }
            }
          }
        }
      ]
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "broad_macros_never_replay_silently",
        "exact_command_lineage_preserved",
        "source_register_and_scope_preserved",
        "unstable_or_cross_surface_promoted_to_recipe",
        "provider_replays_never_read_as_local",
        "no_new_macro_language_introduced"
      ],
      "properties": {
        "broad_macros_never_replay_silently": {
          "const": true
        },
        "exact_command_lineage_preserved": {
          "const": true
        },
        "source_register_and_scope_preserved": {
          "const": true
        },
        "unstable_or_cross_surface_promoted_to_recipe": {
          "const": true
        },
        "provider_replays_never_read_as_local": {
          "const": true
        },
        "no_new_macro_language_introduced": {
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_packet",
        "help_migration_ingests_packet",
        "support_export_ingests_packet",
        "release_control_ingests_packet",
        "exact_downgraded_promoted_distinguishable"
      ],
      "properties": {
        "product_ingests_packet": {
          "const": true
        },
        "help_migration_ingests_packet": {
          "const": true
        },
        "support_export_ingests_packet": {
          "const": true
        },
        "release_control_ingests_packet": {
          "const": true
        },
        "exact_downgraded_promoted_distinguishable": {
          "const": true
        }
      }
    },
    "verification_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verification_freshness_slo_hours",
        "last_verification_refresh",
        "auto_review_on_stale"
      ],
      "properties": {
        "verification_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_verification_refresh": {
          "$ref": "#/$defs/non_empty_string"
        },
        "auto_review_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
