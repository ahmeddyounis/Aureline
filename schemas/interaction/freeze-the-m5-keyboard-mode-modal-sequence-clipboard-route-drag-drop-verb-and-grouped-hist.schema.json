{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/interaction/freeze-the-m5-keyboard-mode-modal-sequence-clipboard-route-drag-drop-verb-and-grouped-hist.schema.json",
  "title": "Aureline M5 keyboard-mode / clipboard-route / drag-drop-verb / grouped-history continuity matrix",
  "description": "Frozen, export-safe matrix binding every claimed M5 switching-wedge and power-user surface (editor, notebook, data/API, preview, docs, review, runtime, companion) to the canonical keyboard-first interaction vocabulary it must advertise: a mode-strip class, a leader-key sequence-guide class, a register/clipboard-route class, a drag/drop-verb class, an undo class, a grouped-history class, a reopen/recover class, and an orientation-aid class, plus a claimed and effective continuity-parity grade. Each row is verification-bound: it names a proof currency and, unless the proof is missing, a reopenable proof ref keyed by a non-display fingerprint. A row whose modal sequence is unsupported, whose clipboard route drops plain text, whose drag/drop verb is destructive-by-default, whose orientation aids collapse, or whose verification is stale, missing, review-pending, or imported proof standing in for a local claim, auto-downgrades to an effective grade strictly below its claim, with a recorded downgrade trigger and a precise label. Exact undo, grouped exact undo, compensating action, and checkpoint restore stay distinct; a provider-linked surface never reads as a locally verified surface. Raw clipboard bodies, raw key buffers, raw provider payloads, file contents, private paths, and credentials never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "label",
    "rows",
    "guardrails",
    "consumer_projection",
    "verification_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "freeze_m5_keyboard_mode_clipboard_drag_drop_grouped_history_matrix_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/keyboard_parity_row"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "verification_freshness": {
      "$ref": "#/$defs/verification_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "keyboard_surface_kind": {
      "type": "string",
      "enum": [
        "editor_core",
        "notebook_surface",
        "data_api_surface",
        "preview_surface",
        "docs_surface",
        "review_surface",
        "runtime_surface",
        "companion_surface"
      ]
    },
    "surface_origin_class": {
      "type": "string",
      "enum": [
        "first_party_surface",
        "embedded_runtime_surface",
        "provider_linked_surface",
        "imported_read_only_surface"
      ]
    },
    "mode_strip_class": {
      "type": "string",
      "enum": [
        "modal_parity_complete",
        "modal_read_only_navigation",
        "non_modal_keyboard_complete",
        "mode_unsupported_downgraded"
      ]
    },
    "sequence_guide_class": {
      "type": "string",
      "enum": [
        "leader_sequence_complete",
        "prefix_discoverable",
        "single_stroke_only",
        "sequence_unsupported_downgraded"
      ]
    },
    "clipboard_route_class": {
      "type": "string",
      "enum": [
        "plain_text_preserved",
        "rich_with_plain_fallback",
        "named_register_routed",
        "sensitive_copy_warned",
        "rich_only_denied"
      ]
    },
    "drag_drop_verb_class": {
      "type": "string",
      "enum": [
        "move_verb_explicit",
        "copy_verb_explicit",
        "link_verb_explicit",
        "verb_choice_on_modifier",
        "destructive_default_denied"
      ]
    },
    "undo_class": {
      "type": "string",
      "enum": [
        "exact_undo",
        "grouped_exact_undo",
        "compensating_undo",
        "checkpoint_restore",
        "no_undo_honest"
      ]
    },
    "history_class": {
      "type": "string",
      "enum": [
        "linear_step_history",
        "grouped_step_history",
        "branching_history",
        "checkpoint_lineage",
        "cross_surface_continuity"
      ]
    },
    "reopen_recover_class": {
      "type": "string",
      "enum": [
        "exact_reopen",
        "recovered_approximate",
        "checkpoint_recover",
        "reopen_unavailable_honest"
      ]
    },
    "orientation_aid_class": {
      "type": "string",
      "enum": [
        "full_orientation_aids",
        "reduced_orientation_aids_honest",
        "orientation_aids_degraded_honest",
        "orientation_aids_absent_downgraded"
      ]
    },
    "continuity_parity_grade": {
      "type": "string",
      "enum": [
        "switching_certified",
        "parity_complete",
        "parity_partial",
        "parity_unverified",
        "not_applicable"
      ]
    },
    "axis_proof_currency": {
      "type": "string",
      "enum": [
        "verified_current",
        "cached_within_window",
        "imported_current",
        "stale_expired",
        "requires_review",
        "missing_proof"
      ]
    },
    "parity_downgrade_trigger": {
      "type": "string",
      "enum": [
        "mode_state_unidentified",
        "unsupported_sequence_downgraded",
        "clipboard_plain_text_unavailable",
        "drag_drop_verb_ambiguous",
        "history_class_unidentified",
        "reopen_path_unverified",
        "orientation_aids_collapsed",
        "stale_verification_proof",
        "imported_proof_on_local_surface",
        "upstream_surface_downgraded"
      ]
    },
    "keyboard_surface_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "origin_class",
        "surface_fingerprint_token"
      ],
      "properties": {
        "surface_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "origin_class": {
          "$ref": "#/$defs/surface_origin_class"
        },
        "surface_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "axis_verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_currency",
        "summary"
      ],
      "properties": {
        "proof_currency": {
          "$ref": "#/$defs/axis_proof_currency"
        },
        "proof_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "proof_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "keyboard_parity_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "surface_kind",
        "subject",
        "label_summary",
        "keyboard_complete",
        "macro_replay_explicit",
        "mode_strip",
        "sequence_guide",
        "clipboard_route",
        "drag_drop_verb",
        "undo_class",
        "history_class",
        "reopen_recover",
        "orientation_aid",
        "verification",
        "claimed_grade",
        "effective_grade",
        "evidence_refs",
        "source_contract_refs"
      ],
      "properties": {
        "row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_kind": {
          "$ref": "#/$defs/keyboard_surface_kind"
        },
        "subject": {
          "$ref": "#/$defs/keyboard_surface_subject"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "keyboard_complete": {
          "type": "boolean"
        },
        "macro_replay_explicit": {
          "type": "boolean"
        },
        "mode_strip": {
          "$ref": "#/$defs/mode_strip_class"
        },
        "sequence_guide": {
          "$ref": "#/$defs/sequence_guide_class"
        },
        "clipboard_route": {
          "$ref": "#/$defs/clipboard_route_class"
        },
        "drag_drop_verb": {
          "$ref": "#/$defs/drag_drop_verb_class"
        },
        "undo_class": {
          "$ref": "#/$defs/undo_class"
        },
        "history_class": {
          "$ref": "#/$defs/history_class"
        },
        "reopen_recover": {
          "$ref": "#/$defs/reopen_recover_class"
        },
        "orientation_aid": {
          "$ref": "#/$defs/orientation_aid_class"
        },
        "verification": {
          "$ref": "#/$defs/axis_verification"
        },
        "claimed_grade": {
          "$ref": "#/$defs/continuity_parity_grade"
        },
        "effective_grade": {
          "$ref": "#/$defs/continuity_parity_grade"
        },
        "downgrade_trigger": {
          "$ref": "#/$defs/parity_downgrade_trigger"
        },
        "downgraded_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unsupported_sequences_never_silently_approximated",
        "plain_text_copy_always_available",
        "drag_drop_never_destructive_by_default",
        "undo_classes_never_flattened",
        "orientation_aids_degrade_honestly",
        "rows_auto_downgrade_without_identified_behavior"
      ],
      "properties": {
        "unsupported_sequences_never_silently_approximated": {
          "type": "boolean"
        },
        "plain_text_copy_always_available": {
          "type": "boolean"
        },
        "drag_drop_never_destructive_by_default": {
          "type": "boolean"
        },
        "undo_classes_never_flattened": {
          "type": "boolean"
        },
        "orientation_aids_degrade_honestly": {
          "type": "boolean"
        },
        "rows_auto_downgrade_without_identified_behavior": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_matrix",
        "help_migration_ingests_matrix",
        "accessibility_ingests_matrix",
        "diagnostics_ingests_matrix",
        "release_control_ingests_matrix",
        "downgraded_rows_labeled_below_claim"
      ],
      "properties": {
        "product_ingests_matrix": {
          "type": "boolean"
        },
        "help_migration_ingests_matrix": {
          "type": "boolean"
        },
        "accessibility_ingests_matrix": {
          "type": "boolean"
        },
        "diagnostics_ingests_matrix": {
          "type": "boolean"
        },
        "release_control_ingests_matrix": {
          "type": "boolean"
        },
        "downgraded_rows_labeled_below_claim": {
          "type": "boolean"
        }
      }
    },
    "verification_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verification_freshness_slo_hours",
        "last_verification_refresh",
        "auto_downgrade_on_stale"
      ],
      "properties": {
        "verification_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_verification_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_downgrade_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
