{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/interaction/implement-clipboard-contracts-with-plain-text-default-copy-with-context-variants-sensitive.schema.json",
  "title": "Aureline M5 clipboard contracts: plain-text-default copy, copy-with-context variants, and sensitive-copy labels",
  "description": "Export-safe packet binding each claimed M5 artifact surface (editor, notebook, data/API, preview, docs, review, runtime, companion) to one copy flow and its resolved copy variant. Each record preserves the copied object (a class plus an opaque / workspace-relative token), the ordered exact clipboard representation set (keyed by flavor), the content sensitivity, and a reopenable verification proof. A copy that bundles context beyond the bare object, that carries sensitive token / fingerprint / private-path / support-link material, that offers only a rich representation with no plain-text flavor, or whose copy proof is stale or missing fires one or more contract triggers; each trigger imposes a minimum-safety floor so the record can never resolve to plain_text_default_copy when it is non-trivial — it must expose an explicit copy-with-context variant, label the sensitive copy, relativize / redact the content, or be rejected. Every non-rejected copy preserves at least one plain-text representation, so pretty rich text never becomes the only readable output. A provider-linked surface never reads as a locally verified copy. Raw clipboard byte buffers, raw secret material, raw provider payloads, file contents, and absolute private paths never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "label",
    "records",
    "guardrails",
    "consumer_projection",
    "verification_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "m5_clipboard_contract_plain_text_default_copy_with_context_sensitive_label_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/clipboard_contract_record"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "verification_freshness": {
      "$ref": "#/$defs/verification_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "keyboard_surface_kind": {
      "type": "string",
      "enum": [
        "editor_core",
        "notebook_surface",
        "data_api_surface",
        "preview_surface",
        "docs_surface",
        "review_surface",
        "runtime_surface",
        "companion_surface"
      ]
    },
    "surface_origin_class": {
      "type": "string",
      "enum": [
        "first_party_surface",
        "embedded_runtime_surface",
        "provider_linked_surface",
        "imported_read_only_surface"
      ]
    },
    "proof_currency": {
      "type": "string",
      "enum": [
        "verified_current",
        "cached_within_window",
        "imported_current",
        "stale_expired",
        "requires_review",
        "missing_proof"
      ]
    },
    "object_class": {
      "type": "string",
      "enum": [
        "source_code_fragment",
        "relative_path",
        "permalink",
        "command_id",
        "diagnostic_detail",
        "artifact_evidence_ref",
        "support_link"
      ]
    },
    "sensitivity_class": {
      "type": "string",
      "enum": [
        "non_sensitive",
        "access_token_material",
        "fingerprint_digest",
        "private_absolute_path",
        "support_session_link"
      ]
    },
    "flavor_class": {
      "type": "string",
      "enum": [
        "plain_text_utf8",
        "markdown_rich",
        "html_rich",
        "relative_path_text",
        "permalink_url",
        "command_id_token",
        "diagnostic_detail_text"
      ]
    },
    "resolution_class": {
      "type": "string",
      "enum": [
        "plain_text_default_copy",
        "copy_with_context_variant",
        "sensitive_labeled_before_copy",
        "relativized_or_redacted_copy",
        "rejected_rich_only_or_unsafe"
      ]
    },
    "contract_trigger": {
      "type": "string",
      "enum": [
        "context_beyond_bare_object",
        "sensitive_token_or_fingerprint",
        "support_link_present",
        "private_absolute_path",
        "rich_only_no_plain_text",
        "stale_or_missing_copy_proof"
      ]
    },
    "surface_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_id", "origin_class", "surface_fingerprint_token"],
      "properties": {
        "surface_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "origin_class": {
          "$ref": "#/$defs/surface_origin_class"
        },
        "surface_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "copy_object_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object_class", "object_token", "display_label"],
      "properties": {
        "object_class": {
          "$ref": "#/$defs/object_class"
        },
        "object_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "display_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "copy_representation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["representation_id", "flavor_class", "display_label"],
      "properties": {
        "representation_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "flavor_class": {
          "$ref": "#/$defs/flavor_class"
        },
        "display_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_currency", "summary"],
      "properties": {
        "proof_currency": {
          "$ref": "#/$defs/proof_currency"
        },
        "proof_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "proof_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "clipboard_contract_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "surface_kind",
        "subject",
        "label_summary",
        "object",
        "representations",
        "representations_summary",
        "context_bundled",
        "sensitivity",
        "verification",
        "resolution",
        "fired_triggers",
        "raw_clipboard_bytes_present",
        "raw_secret_material_present",
        "absolute_private_path_present",
        "representations_collapsed_to_rich_blob",
        "silent_sensitive_push_taken",
        "evidence_refs",
        "minted_at"
      ],
      "properties": {
        "record_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_kind": {
          "$ref": "#/$defs/keyboard_surface_kind"
        },
        "subject": {
          "$ref": "#/$defs/surface_subject"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "object": {
          "$ref": "#/$defs/copy_object_ref"
        },
        "representations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/copy_representation"
          }
        },
        "representations_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "context_bundled": {
          "type": "boolean"
        },
        "sensitivity": {
          "$ref": "#/$defs/sensitivity_class"
        },
        "verification": {
          "$ref": "#/$defs/verification"
        },
        "resolution": {
          "$ref": "#/$defs/resolution_class"
        },
        "fired_triggers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contract_trigger"
          }
        },
        "context_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "sensitive_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "transform_note": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rejection_reason_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "raw_clipboard_bytes_present": {
          "const": false
        },
        "raw_secret_material_present": {
          "const": false
        },
        "absolute_private_path_present": {
          "const": false
        },
        "representations_collapsed_to_rich_blob": {
          "const": false
        },
        "silent_sensitive_push_taken": {
          "const": false
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "minted_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "comment": "A non-trivial copy can never resolve to the silent default lane.",
          "if": {
            "properties": {
              "fired_triggers": {
                "minItems": 1
              }
            },
            "required": ["fired_triggers"]
          },
          "then": {
            "properties": {
              "resolution": {
                "not": {
                  "const": "plain_text_default_copy"
                }
              }
            }
          }
        }
      ]
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plain_text_preserved_by_default",
        "rich_text_never_the_only_representation",
        "sensitive_copy_labeled_not_silent",
        "object_and_representations_preserved",
        "provider_copies_never_read_as_local",
        "no_new_macro_language_introduced"
      ],
      "properties": {
        "plain_text_preserved_by_default": {
          "const": true
        },
        "rich_text_never_the_only_representation": {
          "const": true
        },
        "sensitive_copy_labeled_not_silent": {
          "const": true
        },
        "object_and_representations_preserved": {
          "const": true
        },
        "provider_copies_never_read_as_local": {
          "const": true
        },
        "no_new_macro_language_introduced": {
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_packet",
        "help_migration_ingests_packet",
        "support_export_ingests_packet",
        "release_control_ingests_packet",
        "copy_variants_and_routes_nameable"
      ],
      "properties": {
        "product_ingests_packet": {
          "const": true
        },
        "help_migration_ingests_packet": {
          "const": true
        },
        "support_export_ingests_packet": {
          "const": true
        },
        "release_control_ingests_packet": {
          "const": true
        },
        "copy_variants_and_routes_nameable": {
          "const": true
        }
      }
    },
    "verification_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verification_freshness_slo_hours",
        "last_verification_refresh",
        "auto_label_on_stale"
      ],
      "properties": {
        "verification_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_verification_refresh": {
          "$ref": "#/$defs/non_empty_string"
        },
        "auto_label_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
