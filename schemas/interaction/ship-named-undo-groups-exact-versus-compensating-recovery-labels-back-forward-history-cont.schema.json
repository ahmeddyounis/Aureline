{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/interaction/ship-named-undo-groups-exact-versus-compensating-recovery-labels-back-forward-history-cont.schema.json",
  "title": "Aureline M5 grouped-history continuity: named undo groups, exact-versus-compensating recovery labels, back/forward continuity, and reopen-closed affordances",
  "description": "Export-safe packet binding each claimed M5 mutation / navigation surface (editor, notebook, data/API, preview, docs, review, runtime, companion) to one history entry and its resolved recovery affordance. Each record preserves whether the entry is a mutation or a navigation, the affected-object summary (a class, an opaque / workspace-relative token, object and file counts, and a label), the source attribution, the canonical undo / history / reopen-recover class, the loss cause that distinguishes an intentional close from a crash / disconnect loss, an optional close timestamp, and a reopenable verification proof. An entry whose mutation touches many objects / files, whose navigation crosses surfaces, that is not literally invertible, that was generated / automated, that is recoverable only from a checkpoint, that sits on a closed / lost surface, or whose history proof is stale / missing fires one or more contract triggers; each trigger imposes a minimum-safety floor so the record can never resolve to a flat exact_step_undo when it is consequential — it must offer a named exact group, preserve back/forward continuity, expose a labeled compensating action, regenerate from source, restore from a checkpoint, or reopen / recover with the loss cause named. Exact undo, compensating action, and checkpoint restore stay distinct rather than flattened into one vague history label, and a provider-linked surface never reads as a locally verified history. Raw provider payloads, file contents, and absolute private paths never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "label",
    "records",
    "guardrails",
    "consumer_projection",
    "verification_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "m5_named_undo_group_recovery_label_back_forward_continuity_reopen_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/history_continuity_record"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "verification_freshness": {
      "$ref": "#/$defs/verification_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "editor_core",
        "notebook_surface",
        "data_api_surface",
        "preview_surface",
        "docs_surface",
        "review_surface",
        "runtime_surface",
        "companion_surface"
      ]
    },
    "origin_class": {
      "type": "string",
      "enum": [
        "first_party_surface",
        "embedded_runtime_surface",
        "provider_linked_surface",
        "imported_read_only_surface"
      ]
    },
    "entry_kind": {
      "type": "string",
      "enum": ["mutation", "navigation"]
    },
    "object_class": {
      "type": "string",
      "enum": [
        "editor_range",
        "notebook_cell_group",
        "result_row_set",
        "docs_section",
        "preview_target",
        "review_item",
        "runtime_session",
        "companion_thread"
      ]
    },
    "source_attribution": {
      "type": "string",
      "enum": [
        "user_direct",
        "automation_agent",
        "provider_sync",
        "generated_from_source",
        "checkpoint_system"
      ]
    },
    "undo_class": {
      "type": "string",
      "enum": [
        "exact_undo",
        "grouped_exact_undo",
        "compensating_undo",
        "checkpoint_restore",
        "no_undo_honest"
      ]
    },
    "history_class": {
      "type": "string",
      "enum": [
        "linear_step_history",
        "grouped_step_history",
        "branching_history",
        "checkpoint_lineage",
        "cross_surface_continuity"
      ]
    },
    "reopen_recover": {
      "type": "string",
      "enum": [
        "exact_reopen",
        "recovered_approximate",
        "checkpoint_recover",
        "reopen_unavailable_honest"
      ]
    },
    "loss_cause": {
      "type": "string",
      "enum": [
        "not_closed",
        "intentional_close",
        "crash_loss",
        "disconnect_loss"
      ]
    },
    "resolution": {
      "type": "string",
      "enum": [
        "exact_step_undo",
        "named_group_exact_undo",
        "back_forward_continuity_preserved",
        "compensating_action_labeled",
        "regenerate_from_source",
        "checkpoint_restore_labeled",
        "reopen_or_recover_labeled"
      ]
    },
    "contract_trigger": {
      "type": "string",
      "enum": [
        "broad_multi_object_mutation",
        "cross_surface_navigation",
        "not_literally_invertible",
        "generated_or_automated_change",
        "checkpoint_only_recovery",
        "surface_closed_or_lost",
        "stale_or_missing_history_proof"
      ]
    },
    "proof_currency": {
      "type": "string",
      "enum": [
        "verified_current",
        "cached_within_window",
        "imported_current",
        "stale_expired",
        "requires_review",
        "missing_proof"
      ]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_id", "origin_class", "surface_fingerprint_token"],
      "properties": {
        "surface_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "origin_class": {
          "$ref": "#/$defs/origin_class"
        },
        "surface_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "affected_object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_class",
        "object_token",
        "object_count",
        "file_count",
        "display_label"
      ],
      "properties": {
        "object_class": {
          "$ref": "#/$defs/object_class"
        },
        "object_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "object_count": {
          "type": "integer",
          "minimum": 1
        },
        "file_count": {
          "type": "integer",
          "minimum": 1
        },
        "display_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_currency", "summary"],
      "properties": {
        "proof_currency": {
          "$ref": "#/$defs/proof_currency"
        },
        "proof_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "proof_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "history_continuity_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "surface_kind",
        "subject",
        "label_summary",
        "entry_kind",
        "affected_object",
        "source_attribution",
        "undo_class",
        "history_class",
        "reopen_recover",
        "loss_cause",
        "literally_invertible",
        "generated_or_automated",
        "cross_surface_navigation",
        "checkpoint_only",
        "verification",
        "resolution",
        "fired_triggers",
        "raw_provider_payload_present",
        "absolute_private_path_present",
        "distinct_classes_flattened",
        "reopen_loss_cause_conflated",
        "evidence_refs",
        "minted_at"
      ],
      "properties": {
        "record_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_kind": {
          "$ref": "#/$defs/surface_kind"
        },
        "subject": {
          "$ref": "#/$defs/subject"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "entry_kind": {
          "$ref": "#/$defs/entry_kind"
        },
        "affected_object": {
          "$ref": "#/$defs/affected_object"
        },
        "source_attribution": {
          "$ref": "#/$defs/source_attribution"
        },
        "undo_class": {
          "$ref": "#/$defs/undo_class"
        },
        "history_class": {
          "$ref": "#/$defs/history_class"
        },
        "reopen_recover": {
          "$ref": "#/$defs/reopen_recover"
        },
        "loss_cause": {
          "$ref": "#/$defs/loss_cause"
        },
        "closed_at": {
          "type": "string",
          "format": "date-time"
        },
        "literally_invertible": {
          "type": "boolean"
        },
        "generated_or_automated": {
          "type": "boolean"
        },
        "cross_surface_navigation": {
          "type": "boolean"
        },
        "checkpoint_only": {
          "type": "boolean"
        },
        "verification": {
          "$ref": "#/$defs/verification"
        },
        "resolution": {
          "$ref": "#/$defs/resolution"
        },
        "fired_triggers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contract_trigger"
          }
        },
        "group_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "continuity_note": {
          "$ref": "#/$defs/non_empty_string"
        },
        "compensating_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "regenerate_source_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "checkpoint_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reopen_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "raw_provider_payload_present": {
          "type": "boolean"
        },
        "absolute_private_path_present": {
          "type": "boolean"
        },
        "distinct_classes_flattened": {
          "type": "boolean"
        },
        "reopen_loss_cause_conflated": {
          "type": "boolean"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "minted_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "distinct_classes_never_flattened",
        "exact_versus_compensating_distinguished",
        "back_forward_continuity_preserved",
        "reopen_distinguishes_intentional_from_loss",
        "timestamps_or_source_preserved",
        "provider_history_never_reads_as_local",
        "no_new_macro_language_introduced"
      ],
      "properties": {
        "distinct_classes_never_flattened": {
          "type": "boolean"
        },
        "exact_versus_compensating_distinguished": {
          "type": "boolean"
        },
        "back_forward_continuity_preserved": {
          "type": "boolean"
        },
        "reopen_distinguishes_intentional_from_loss": {
          "type": "boolean"
        },
        "timestamps_or_source_preserved": {
          "type": "boolean"
        },
        "provider_history_never_reads_as_local": {
          "type": "boolean"
        },
        "no_new_macro_language_introduced": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_packet",
        "help_migration_ingests_packet",
        "support_export_ingests_packet",
        "release_control_ingests_packet",
        "history_classes_and_recovery_labels_nameable"
      ],
      "properties": {
        "product_ingests_packet": {
          "type": "boolean"
        },
        "help_migration_ingests_packet": {
          "type": "boolean"
        },
        "support_export_ingests_packet": {
          "type": "boolean"
        },
        "release_control_ingests_packet": {
          "type": "boolean"
        },
        "history_classes_and_recovery_labels_nameable": {
          "type": "boolean"
        }
      }
    },
    "verification_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verification_freshness_slo_hours",
        "last_verification_refresh",
        "auto_escalate_on_stale"
      ],
      "properties": {
        "verification_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_verification_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_escalate_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
