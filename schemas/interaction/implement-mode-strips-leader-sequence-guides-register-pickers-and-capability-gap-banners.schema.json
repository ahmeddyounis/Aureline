{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/interaction/implement-mode-strips-leader-sequence-guides-register-pickers-and-capability-gap-banners.schema.json",
  "title": "Aureline M5 mode-strip / leader-sequence-guide / register-picker / capability-gap surfaces",
  "description": "Export-safe packet that binds the frozen M5 keyboard-mode taxonomy to the live keyboard posture of every claimed M5 switching-wedge surface (notebook, data/API, preview, docs, companion, plus editor anchors). Each strip names the imported keymap source preset, the visible current mode, the frozen mode-strip class it realizes, a live pending-sequence state (operator/sequence tokens, count prefix, timeout posture, resolution), a register/clipboard picker, an accessibility block, and any capability-gap banner that explains why an affordance narrowed or was rejected. Each strip is verification-bound: it names a proof currency and, unless missing, a reopenable proof ref keyed by a non-display fingerprint. A strip whose visible mode is unidentified, whose leader sequence is unsupported, whose clipboard route drops plain text, that stops being keyboard-complete or macro-explicit, or whose verification is stale, missing, review-pending, or imported proof standing in for a local claim, auto-downgrades to an effective grade strictly below its claim, with a recorded downgrade trigger, a precise label, and a capability-gap banner for any narrowed affordance. Mode changes and sequence ambiguity stay keyboard- and screen-reader-reachable, never hover-only. Raw clipboard bodies, raw key buffers, raw provider payloads, file contents, private paths, and credentials never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "label",
    "strips",
    "guardrails",
    "consumer_projection",
    "verification_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "m5_mode_strip_leader_sequence_register_picker_capability_gap_banner_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "strips": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/surface_mode_strip"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "verification_freshness": {
      "$ref": "#/$defs/verification_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "keyboard_surface_kind": {
      "type": "string",
      "enum": [
        "editor_core",
        "notebook_surface",
        "data_api_surface",
        "preview_surface",
        "docs_surface",
        "review_surface",
        "runtime_surface",
        "companion_surface"
      ]
    },
    "surface_origin_class": {
      "type": "string",
      "enum": [
        "first_party_surface",
        "embedded_runtime_surface",
        "provider_linked_surface",
        "imported_read_only_surface"
      ]
    },
    "keymap_source_preset": {
      "type": "string",
      "enum": [
        "vim_preset",
        "neovim_preset",
        "emacs_preset",
        "helix_preset",
        "non_modal_default",
        "imported_custom_preset"
      ]
    },
    "mode_indicator": {
      "type": "string",
      "enum": [
        "normal_mode",
        "insert_mode",
        "visual_mode",
        "visual_line_mode",
        "visual_block_mode",
        "replace_mode",
        "operator_pending_mode",
        "command_mode",
        "read_only_navigation_mode",
        "non_modal_editing_mode",
        "mode_unknown_downgraded"
      ]
    },
    "mode_strip_class": {
      "type": "string",
      "enum": [
        "modal_parity_complete",
        "modal_read_only_navigation",
        "non_modal_keyboard_complete",
        "mode_unsupported_downgraded"
      ]
    },
    "sequence_guide_class": {
      "type": "string",
      "enum": [
        "leader_sequence_complete",
        "prefix_discoverable",
        "single_stroke_only",
        "sequence_unsupported_downgraded"
      ]
    },
    "sequence_timeout_posture": {
      "type": "string",
      "enum": [
        "no_pending_sequence",
        "waits_for_explicit_completion",
        "timeout_cancels_pending",
        "timeout_commits_longest_prefix",
        "ambiguity_held_for_explicit_choice"
      ]
    },
    "sequence_resolution": {
      "type": "string",
      "enum": [
        "no_pending_sequence",
        "unambiguous",
        "awaiting_disambiguation",
        "resolved_longest_match",
        "unsupported_downgraded"
      ]
    },
    "clipboard_route_class": {
      "type": "string",
      "enum": [
        "plain_text_preserved",
        "rich_with_plain_fallback",
        "named_register_routed",
        "sensitive_copy_warned",
        "rich_only_denied"
      ]
    },
    "capability_gap_kind": {
      "type": "string",
      "enum": [
        "modal_mode_unsupported",
        "modal_sequence_unsupported",
        "named_register_unsupported",
        "clipboard_plain_text_unavailable",
        "drag_drop_verb_narrowed",
        "timeout_posture_narrowed",
        "orientation_aid_reduced",
        "macro_replay_unavailable"
      ]
    },
    "gap_disposition": {
      "type": "string",
      "enum": [
        "narrowed_to_supported_subset",
        "rejected_outright"
      ]
    },
    "continuity_parity_grade": {
      "type": "string",
      "enum": [
        "switching_certified",
        "parity_complete",
        "parity_partial",
        "parity_unverified",
        "not_applicable"
      ]
    },
    "axis_proof_currency": {
      "type": "string",
      "enum": [
        "verified_current",
        "cached_within_window",
        "imported_current",
        "stale_expired",
        "requires_review",
        "missing_proof"
      ]
    },
    "parity_downgrade_trigger": {
      "type": "string",
      "enum": [
        "mode_state_unidentified",
        "unsupported_sequence_downgraded",
        "clipboard_plain_text_unavailable",
        "drag_drop_verb_ambiguous",
        "history_class_unidentified",
        "reopen_path_unverified",
        "orientation_aids_collapsed",
        "stale_verification_proof",
        "imported_proof_on_local_surface",
        "upstream_surface_downgraded"
      ]
    },
    "keyboard_surface_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "origin_class",
        "surface_fingerprint_token"
      ],
      "properties": {
        "surface_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "origin_class": {
          "$ref": "#/$defs/surface_origin_class"
        },
        "surface_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "axis_verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_currency",
        "summary"
      ],
      "properties": {
        "proof_currency": {
          "$ref": "#/$defs/axis_proof_currency"
        },
        "proof_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "proof_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "pending_sequence_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence_guide",
        "awaiting_more_input",
        "timeout_posture",
        "resolution",
        "sequence_guide_announced"
      ],
      "properties": {
        "sequence_guide": {
          "$ref": "#/$defs/sequence_guide_class"
        },
        "pending_operator_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pending_sequence_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "count_prefix": {
          "type": "integer",
          "minimum": 0
        },
        "awaiting_more_input": {
          "type": "boolean"
        },
        "timeout_posture": {
          "$ref": "#/$defs/sequence_timeout_posture"
        },
        "resolution": {
          "$ref": "#/$defs/sequence_resolution"
        },
        "sequence_guide_announced": {
          "type": "boolean"
        }
      }
    },
    "register_clipboard_picker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clipboard_route",
        "available_register_tokens",
        "plain_text_representation_available",
        "sensitive_copy_warning_active",
        "picker_keyboard_reachable"
      ],
      "properties": {
        "clipboard_route": {
          "$ref": "#/$defs/clipboard_route_class"
        },
        "active_register_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "available_register_tokens": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "plain_text_representation_available": {
          "type": "boolean"
        },
        "sensitive_copy_warning_active": {
          "type": "boolean"
        },
        "picker_keyboard_reachable": {
          "type": "boolean"
        }
      }
    },
    "capability_gap_banner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gap_id",
        "gap_kind",
        "disposition",
        "explanation",
        "export_safe_reason_token",
        "keyboard_reachable",
        "screen_reader_announced",
        "hover_only"
      ],
      "properties": {
        "gap_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "gap_kind": {
          "$ref": "#/$defs/capability_gap_kind"
        },
        "disposition": {
          "$ref": "#/$defs/gap_disposition"
        },
        "explanation": {
          "$ref": "#/$defs/non_empty_string"
        },
        "export_safe_reason_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "keyboard_reachable": {
          "type": "boolean"
        },
        "screen_reader_announced": {
          "type": "boolean"
        },
        "hover_only": {
          "type": "boolean"
        }
      }
    },
    "mode_strip_accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode_change_announced",
        "pending_sequence_announced",
        "keyboard_reachable",
        "hover_only"
      ],
      "properties": {
        "mode_change_announced": {
          "type": "boolean"
        },
        "pending_sequence_announced": {
          "type": "boolean"
        },
        "keyboard_reachable": {
          "type": "boolean"
        },
        "hover_only": {
          "type": "boolean"
        }
      }
    },
    "surface_mode_strip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strip_id",
        "surface_kind",
        "subject",
        "label_summary",
        "source_preset",
        "current_mode",
        "mode_strip_class",
        "keyboard_complete",
        "macro_replay_explicit",
        "pending_sequence",
        "register_picker",
        "accessibility",
        "capability_gaps",
        "verification",
        "claimed_grade",
        "effective_grade",
        "evidence_refs",
        "source_contract_refs"
      ],
      "properties": {
        "strip_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_kind": {
          "$ref": "#/$defs/keyboard_surface_kind"
        },
        "subject": {
          "$ref": "#/$defs/keyboard_surface_subject"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_preset": {
          "$ref": "#/$defs/keymap_source_preset"
        },
        "current_mode": {
          "$ref": "#/$defs/mode_indicator"
        },
        "mode_strip_class": {
          "$ref": "#/$defs/mode_strip_class"
        },
        "keyboard_complete": {
          "type": "boolean"
        },
        "macro_replay_explicit": {
          "type": "boolean"
        },
        "pending_sequence": {
          "$ref": "#/$defs/pending_sequence_state"
        },
        "register_picker": {
          "$ref": "#/$defs/register_clipboard_picker"
        },
        "accessibility": {
          "$ref": "#/$defs/mode_strip_accessibility"
        },
        "capability_gaps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/capability_gap_banner"
          }
        },
        "verification": {
          "$ref": "#/$defs/axis_verification"
        },
        "claimed_grade": {
          "$ref": "#/$defs/continuity_parity_grade"
        },
        "effective_grade": {
          "$ref": "#/$defs/continuity_parity_grade"
        },
        "downgrade_trigger": {
          "$ref": "#/$defs/parity_downgrade_trigger"
        },
        "downgraded_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "visible_current_mode_preserved",
        "pending_sequence_never_silently_approximated",
        "register_clipboard_route_visible",
        "capability_gaps_explained_not_hidden",
        "mode_changes_keyboard_and_screen_reader_reachable",
        "rows_auto_downgrade_without_identified_behavior"
      ],
      "properties": {
        "visible_current_mode_preserved": {
          "type": "boolean"
        },
        "pending_sequence_never_silently_approximated": {
          "type": "boolean"
        },
        "register_clipboard_route_visible": {
          "type": "boolean"
        },
        "capability_gaps_explained_not_hidden": {
          "type": "boolean"
        },
        "mode_changes_keyboard_and_screen_reader_reachable": {
          "type": "boolean"
        },
        "rows_auto_downgrade_without_identified_behavior": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_strips",
        "help_migration_reconstructs_posture",
        "accessibility_ingests_strips",
        "diagnostics_ingests_strips",
        "support_export_reconstructs_capability_gaps",
        "downgraded_strips_labeled_below_claim"
      ],
      "properties": {
        "product_ingests_strips": {
          "type": "boolean"
        },
        "help_migration_reconstructs_posture": {
          "type": "boolean"
        },
        "accessibility_ingests_strips": {
          "type": "boolean"
        },
        "diagnostics_ingests_strips": {
          "type": "boolean"
        },
        "support_export_reconstructs_capability_gaps": {
          "type": "boolean"
        },
        "downgraded_strips_labeled_below_claim": {
          "type": "boolean"
        }
      }
    },
    "verification_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verification_freshness_slo_hours",
        "last_verification_refresh",
        "auto_downgrade_on_stale"
      ],
      "properties": {
        "verification_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_verification_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_downgrade_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
