{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/interaction/implement-multi-cursor-fold-state-breadcrumb-minimap-overview-ruler-and-degraded-orientati.schema.json",
  "title": "Aureline M5 orientation aids: multi-cursor, fold-state, breadcrumb, minimap, overview-ruler, and degraded-orientation truth",
  "description": "Export-safe packet binding each claimed M5 editor / viewer / diff / browser-runtime surface (editor, notebook, data/API, preview, docs, review, runtime, companion) to one orientation aid and its resolved disclosure. Each record names which aid it renders (multi-cursor, fold-state, breadcrumb, minimap, overview-ruler), the marker summary (an object class, an opaque / workspace-relative object token aligned with the same object identity shown elsewhere, the marker and rendered counts, and a label), the canonical orientation-aid posture, and a reopenable verification proof. An aid whose markers exceed the live-render budget, whose breadcrumb identity is shared across surfaces, that sits on a constrained viewport, that runs under a reduced-motion profile, that reflects a large / unsafe artifact, that runs under a limited capability profile, or whose orientation proof is stale / missing fires one or more contract triggers; each trigger imposes a minimum-disclosure floor so the record can never resolve to a flat aid_fully_active when it is constrained — it must preserve an honest count summary, align identity across surfaces, disclose reduced detail, disclose suppressed motion, disclose a degraded aid, or disclose an unavailable aid. A degraded or unavailable aid is always disclosed with a precise reason label rather than silently removed, stale markers are never shown, and a provider-linked surface never reads as a locally verified orientation truth. Raw provider payloads, file contents, and absolute private paths never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "label",
    "records",
    "guardrails",
    "consumer_projection",
    "verification_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "m5_multi_cursor_fold_breadcrumb_minimap_overview_orientation_aid_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/orientation_aid_record"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "verification_freshness": {
      "$ref": "#/$defs/verification_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "editor_core",
        "notebook_surface",
        "data_api_surface",
        "preview_surface",
        "docs_surface",
        "review_surface",
        "runtime_surface",
        "companion_surface"
      ]
    },
    "origin_class": {
      "type": "string",
      "enum": [
        "first_party_surface",
        "embedded_runtime_surface",
        "provider_linked_surface",
        "imported_read_only_surface"
      ]
    },
    "aid_kind": {
      "type": "string",
      "enum": [
        "multi_cursor",
        "fold_state",
        "breadcrumb",
        "minimap",
        "overview_ruler"
      ]
    },
    "object_class": {
      "type": "string",
      "enum": [
        "editor_buffer",
        "notebook_cell_group",
        "data_result_grid",
        "preview_document",
        "docs_outline",
        "review_diff",
        "runtime_overlay",
        "companion_transcript"
      ]
    },
    "aid_posture": {
      "type": "string",
      "enum": [
        "full_orientation_aids",
        "reduced_orientation_aids_honest",
        "orientation_aids_degraded_honest",
        "orientation_aids_absent_downgraded"
      ]
    },
    "resolution": {
      "type": "string",
      "enum": [
        "aid_fully_active",
        "count_summary_preserved",
        "identity_aligned_across_surfaces",
        "reduced_detail_disclosed",
        "motion_reduced_disclosed",
        "degraded_disclosed",
        "unavailable_disclosed"
      ]
    },
    "contract_trigger": {
      "type": "string",
      "enum": [
        "high_cardinality_markers",
        "cross_surface_identity_shared",
        "constrained_viewport",
        "reduced_motion_profile",
        "large_or_unsafe_artifact",
        "limited_capability_profile",
        "stale_or_missing_orientation_proof"
      ]
    },
    "proof_currency": {
      "type": "string",
      "enum": [
        "verified_current",
        "cached_within_window",
        "imported_current",
        "stale_expired",
        "requires_review",
        "missing_proof"
      ]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_id", "origin_class", "surface_fingerprint_token"],
      "properties": {
        "surface_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "origin_class": {
          "$ref": "#/$defs/origin_class"
        },
        "surface_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "marker_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_class",
        "object_token",
        "marker_count",
        "rendered_count",
        "display_label"
      ],
      "properties": {
        "object_class": {
          "$ref": "#/$defs/object_class"
        },
        "object_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "marker_count": {
          "type": "integer",
          "minimum": 1
        },
        "rendered_count": {
          "type": "integer",
          "minimum": 0
        },
        "display_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_currency", "summary"],
      "properties": {
        "proof_currency": {
          "$ref": "#/$defs/proof_currency"
        },
        "proof_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "proof_fingerprint_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "orientation_aid_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "surface_kind",
        "subject",
        "label_summary",
        "aid_kind",
        "marker_summary",
        "aid_posture",
        "cross_surface_identity_shared",
        "constrained_viewport",
        "reduced_motion_profile",
        "large_or_unsafe_artifact",
        "limited_capability_profile",
        "verification",
        "resolution",
        "fired_triggers",
        "raw_provider_payload_present",
        "absolute_private_path_present",
        "aid_silently_removed",
        "stale_markers_shown",
        "evidence_refs",
        "minted_at"
      ],
      "properties": {
        "record_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_kind": {
          "$ref": "#/$defs/surface_kind"
        },
        "subject": {
          "$ref": "#/$defs/subject"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "aid_kind": {
          "$ref": "#/$defs/aid_kind"
        },
        "marker_summary": {
          "$ref": "#/$defs/marker_summary"
        },
        "aid_posture": {
          "$ref": "#/$defs/aid_posture"
        },
        "cross_surface_identity_shared": {
          "type": "boolean"
        },
        "constrained_viewport": {
          "type": "boolean"
        },
        "reduced_motion_profile": {
          "type": "boolean"
        },
        "large_or_unsafe_artifact": {
          "type": "boolean"
        },
        "limited_capability_profile": {
          "type": "boolean"
        },
        "verification": {
          "$ref": "#/$defs/verification"
        },
        "resolution": {
          "$ref": "#/$defs/resolution"
        },
        "fired_triggers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contract_trigger"
          }
        },
        "count_summary_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "identity_note": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reduced_detail_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "motion_reduced_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "degrade_reason_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "unavailable_reason_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "raw_provider_payload_present": {
          "type": "boolean"
        },
        "absolute_private_path_present": {
          "type": "boolean"
        },
        "aid_silently_removed": {
          "type": "boolean"
        },
        "stale_markers_shown": {
          "type": "boolean"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "minted_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aids_degrade_honestly_never_silently_removed",
        "stale_markers_never_shown",
        "multi_cursor_and_fold_truth_preserved",
        "breadcrumb_identity_aligned_with_object_ids",
        "minimap_overview_markers_named",
        "provider_orientation_never_reads_as_local",
        "no_new_editor_core_introduced"
      ],
      "properties": {
        "aids_degrade_honestly_never_silently_removed": {
          "type": "boolean"
        },
        "stale_markers_never_shown": {
          "type": "boolean"
        },
        "multi_cursor_and_fold_truth_preserved": {
          "type": "boolean"
        },
        "breadcrumb_identity_aligned_with_object_ids": {
          "type": "boolean"
        },
        "minimap_overview_markers_named": {
          "type": "boolean"
        },
        "provider_orientation_never_reads_as_local": {
          "type": "boolean"
        },
        "no_new_editor_core_introduced": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_packet",
        "help_migration_ingests_packet",
        "support_export_ingests_packet",
        "release_control_ingests_packet",
        "aid_states_nameable_for_accessibility_and_support"
      ],
      "properties": {
        "product_ingests_packet": {
          "type": "boolean"
        },
        "help_migration_ingests_packet": {
          "type": "boolean"
        },
        "support_export_ingests_packet": {
          "type": "boolean"
        },
        "release_control_ingests_packet": {
          "type": "boolean"
        },
        "aid_states_nameable_for_accessibility_and_support": {
          "type": "boolean"
        }
      }
    },
    "verification_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verification_freshness_slo_hours",
        "last_verification_refresh",
        "auto_escalate_on_stale"
      ],
      "properties": {
        "verification_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_verification_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_escalate_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
