{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/region_tenant_key_mode_beta.schema.json",
  "title": "Aureline region / tenant / key-mode beta page",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "source_matrix_ref",
    "region_rows",
    "tenant_rows",
    "key_mode_rows",
    "drill_packets",
    "defects",
    "summary"
  ],
  "properties": {
    "record_kind": {
      "const": "security_region_tenant_key_mode_beta_page_record"
    },
    "schema_version": {
      "$ref": "#/$defs/schema_version"
    },
    "shared_contract_ref": {
      "$ref": "#/$defs/shared_contract_ref"
    },
    "source_matrix_ref": {
      "type": "string",
      "minLength": 1
    },
    "region_rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/region_disclosure_row"
      }
    },
    "tenant_rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tenant_boundary_row"
      }
    },
    "key_mode_rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/key_mode_row"
      }
    },
    "drill_packets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/drill_packet"
      }
    },
    "defects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/defect"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "security:region_tenant_key_mode_beta:v1"
    },
    "token": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "profile_token": {
      "type": "string",
      "enum": [
        "connected",
        "mirror_only",
        "offline",
        "enterprise_managed"
      ]
    },
    "managed_lane_token": {
      "type": "string",
      "enum": [
        "ai_inference",
        "provider_tool_call",
        "remote_attach",
        "mirror_sync",
        "support_export_upload",
        "admin_policy_push"
      ]
    },
    "axis_token": {
      "type": "string",
      "enum": ["region", "tenant", "key_mode"]
    },
    "authority_token": {
      "type": "string",
      "enum": [
        "allowed",
        "read_only",
        "degraded_preview_only",
        "blocked_pending_trust",
        "blocked_pending_approval",
        "approval_required_per_invocation",
        "policy_denied",
        "quarantine_denied",
        "not_applicable"
      ]
    },
    "region_disclosure_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_id",
        "managed_lane",
        "managed_lane_token",
        "profile",
        "profile_token",
        "claimed_region_mode",
        "claimed_region_mode_token",
        "active_region_mode",
        "active_region_mode_token",
        "residency_mode",
        "residency_mode_token",
        "pinning_state",
        "pinning_state_token",
        "disclosure",
        "effective_authority",
        "effective_authority_token",
        "linked_drill_packet_id",
        "no_public_endpoint_fallback",
        "raw_private_material_excluded",
        "local_editing_preserved"
      ],
      "properties": {
        "record_kind": {
          "const": "security_region_tenant_key_mode_beta_region_disclosure_row_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "row_id": { "type": "string", "minLength": 1 },
        "managed_lane": { "$ref": "#/$defs/managed_lane_token" },
        "managed_lane_token": { "$ref": "#/$defs/managed_lane_token" },
        "profile": { "$ref": "#/$defs/profile_token" },
        "profile_token": { "$ref": "#/$defs/profile_token" },
        "claimed_region_mode": { "$ref": "#/$defs/token" },
        "claimed_region_mode_token": { "$ref": "#/$defs/token" },
        "active_region_mode": { "$ref": "#/$defs/token" },
        "active_region_mode_token": { "$ref": "#/$defs/token" },
        "residency_mode": { "$ref": "#/$defs/token" },
        "residency_mode_token": { "$ref": "#/$defs/token" },
        "pinning_state": {
          "type": "string",
          "enum": [
            "pinned_matches_claim",
            "pinned_recheck_required",
            "provider_default_disclosed",
            "pinning_lost",
            "drifted_from_claim",
            "unresolved"
          ]
        },
        "pinning_state_token": { "$ref": "#/$defs/token" },
        "disclosure": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "region_id",
            "region_label",
            "residency_zone_id",
            "disclosed_origin_ref"
          ],
          "properties": {
            "region_id": { "type": "string" },
            "region_label": { "type": "string" },
            "residency_zone_id": { "type": "string" },
            "disclosed_origin_ref": { "type": "string" }
          }
        },
        "effective_authority": { "$ref": "#/$defs/authority_token" },
        "effective_authority_token": { "$ref": "#/$defs/authority_token" },
        "linked_drill_packet_id": { "type": "string" },
        "no_public_endpoint_fallback": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "local_editing_preserved": { "type": "boolean" }
      }
    },
    "tenant_boundary_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_id",
        "managed_lane",
        "managed_lane_token",
        "profile",
        "profile_token",
        "claimed_tenant_id",
        "active_tenant_id",
        "workspace_boundary_id",
        "boundary_state",
        "boundary_state_token",
        "disclosed_origin_ref",
        "effective_authority",
        "effective_authority_token",
        "linked_drill_packet_id",
        "no_public_endpoint_fallback",
        "raw_private_material_excluded",
        "local_editing_preserved"
      ],
      "properties": {
        "record_kind": {
          "const": "security_region_tenant_key_mode_beta_tenant_boundary_row_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "row_id": { "type": "string", "minLength": 1 },
        "managed_lane": { "$ref": "#/$defs/managed_lane_token" },
        "managed_lane_token": { "$ref": "#/$defs/managed_lane_token" },
        "profile": { "$ref": "#/$defs/profile_token" },
        "profile_token": { "$ref": "#/$defs/profile_token" },
        "claimed_tenant_id": { "type": "string" },
        "active_tenant_id": { "type": "string" },
        "workspace_boundary_id": { "type": "string" },
        "boundary_state": {
          "type": "string",
          "enum": [
            "bound_matches_claim",
            "bound_recheck_required",
            "drifted_from_claim",
            "binding_lost",
            "unresolved",
            "not_applicable_local"
          ]
        },
        "boundary_state_token": { "$ref": "#/$defs/token" },
        "disclosed_origin_ref": { "type": "string" },
        "effective_authority": { "$ref": "#/$defs/authority_token" },
        "effective_authority_token": { "$ref": "#/$defs/authority_token" },
        "linked_drill_packet_id": { "type": "string" },
        "no_public_endpoint_fallback": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "local_editing_preserved": { "type": "boolean" }
      }
    },
    "key_mode_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_id",
        "managed_lane",
        "managed_lane_token",
        "profile",
        "profile_token",
        "claimed_key_mode",
        "claimed_key_mode_token",
        "active_key_mode",
        "active_key_mode_token",
        "key_state",
        "key_state_token",
        "custody_origin_ref",
        "effective_authority",
        "effective_authority_token",
        "linked_drill_packet_id",
        "no_public_endpoint_fallback",
        "raw_private_material_excluded",
        "local_editing_preserved"
      ],
      "properties": {
        "record_kind": {
          "const": "security_region_tenant_key_mode_beta_key_mode_row_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "row_id": { "type": "string", "minLength": 1 },
        "managed_lane": { "$ref": "#/$defs/managed_lane_token" },
        "managed_lane_token": { "$ref": "#/$defs/managed_lane_token" },
        "profile": { "$ref": "#/$defs/profile_token" },
        "profile_token": { "$ref": "#/$defs/profile_token" },
        "claimed_key_mode": { "$ref": "#/$defs/token" },
        "claimed_key_mode_token": { "$ref": "#/$defs/token" },
        "active_key_mode": { "$ref": "#/$defs/token" },
        "active_key_mode_token": { "$ref": "#/$defs/token" },
        "key_state": {
          "type": "string",
          "enum": [
            "matches_claim",
            "matches_recheck_required",
            "drifted_from_claim",
            "custody_degraded",
            "unresolved"
          ]
        },
        "key_state_token": { "$ref": "#/$defs/token" },
        "custody_origin_ref": { "type": "string" },
        "effective_authority": { "$ref": "#/$defs/authority_token" },
        "effective_authority_token": { "$ref": "#/$defs/authority_token" },
        "linked_drill_packet_id": { "type": "string" },
        "no_public_endpoint_fallback": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "local_editing_preserved": { "type": "boolean" }
      }
    },
    "drill_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "drill_packet_id",
        "drill_kind",
        "drill_kind_token",
        "axis_token",
        "managed_lane",
        "managed_lane_token",
        "profile",
        "profile_token",
        "outcome",
        "outcome_token",
        "before_state_label",
        "after_state_label",
        "before_authority",
        "before_authority_token",
        "after_authority",
        "after_authority_token",
        "explanation",
        "started_at",
        "resolved_at",
        "artifact_ref",
        "local_editing_preserved",
        "sibling_lanes_unwidened",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "const": "security_region_tenant_key_mode_beta_drill_packet_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "drill_packet_id": { "type": "string", "minLength": 1 },
        "drill_kind": {
          "type": "string",
          "enum": [
            "region_pinning_failure",
            "region_failover",
            "tenant_boundary_drift",
            "tenant_failover",
            "key_mode_drift",
            "key_mode_failover"
          ]
        },
        "drill_kind_token": { "$ref": "#/$defs/token" },
        "axis_token": { "$ref": "#/$defs/axis_token" },
        "managed_lane": { "$ref": "#/$defs/managed_lane_token" },
        "managed_lane_token": { "$ref": "#/$defs/managed_lane_token" },
        "profile": { "$ref": "#/$defs/profile_token" },
        "profile_token": { "$ref": "#/$defs/profile_token" },
        "outcome": {
          "type": "string",
          "enum": [
            "narrowed_then_recovered",
            "narrowed_awaiting_admin",
            "failed_over_to_declared_fallback"
          ]
        },
        "outcome_token": { "$ref": "#/$defs/token" },
        "before_state_label": { "type": "string" },
        "after_state_label": { "type": "string" },
        "before_authority": { "$ref": "#/$defs/authority_token" },
        "before_authority_token": { "$ref": "#/$defs/authority_token" },
        "after_authority": { "$ref": "#/$defs/authority_token" },
        "after_authority_token": { "$ref": "#/$defs/authority_token" },
        "explanation": { "type": "string" },
        "started_at": { "$ref": "#/$defs/timestamp" },
        "resolved_at": { "$ref": "#/$defs/timestamp" },
        "artifact_ref": { "type": "string" },
        "local_editing_preserved": { "type": "boolean" },
        "sibling_lanes_unwidened": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_kind",
        "defect_kind_token",
        "subject_id",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": {
          "const": "security_region_tenant_key_mode_beta_defect_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_kind": {
          "type": "string",
          "enum": [
            "token_drift",
            "claimed_managed_region_undisclosed",
            "claimed_managed_tenant_undisclosed",
            "claimed_managed_key_mode_undisclosed",
            "narrowing_authority_drift",
            "mismatch_masks_issue",
            "hidden_public_endpoint_fallback",
            "raw_private_material_exposed",
            "local_editing_not_preserved",
            "drill_axis_token_drift",
            "drill_sibling_lane_widened",
            "drill_local_editing_not_preserved",
            "drill_axis_coverage_missing",
            "profile_coverage_missing"
          ]
        },
        "defect_kind_token": { "$ref": "#/$defs/token" },
        "subject_id": { "type": "string" },
        "field": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_record_kind",
        "record_kind",
        "region_row_count",
        "tenant_row_count",
        "key_mode_row_count",
        "drill_packet_count",
        "profiles_present",
        "managed_lanes_present",
        "drill_axes_present",
        "drill_kinds_present",
        "defect_count",
        "defect_counts_by_kind"
      ],
      "properties": {
        "page_record_kind": {
          "const": "security_region_tenant_key_mode_beta_page_record"
        },
        "record_kind": {
          "const": "security_region_tenant_key_mode_beta_summary_record"
        },
        "region_row_count": { "type": "integer", "minimum": 0 },
        "tenant_row_count": { "type": "integer", "minimum": 0 },
        "key_mode_row_count": { "type": "integer", "minimum": 0 },
        "drill_packet_count": { "type": "integer", "minimum": 0 },
        "profiles_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/profile_token" }
        },
        "managed_lanes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/managed_lane_token" }
        },
        "drill_axes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/axis_token" }
        },
        "drill_kinds_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/token" }
        },
        "defect_count": { "type": "integer", "minimum": 0 },
        "defect_counts_by_kind": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
