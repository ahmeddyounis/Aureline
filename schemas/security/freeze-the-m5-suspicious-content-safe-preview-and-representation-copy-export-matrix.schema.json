{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/freeze-the-m5-suspicious-content-safe-preview-and-representation-copy-export-matrix.schema.json",
  "title": "Aureline M5 suspicious-content, safe-preview, and representation-labeled copy/export matrix",
  "description": "Export-safe packet freezing the M5 content-integrity qualification for every claimed M5 artifact/viewer family: notebooks, docs/browser panels, AI evidence viewers, pipeline and artifact browsers, provider overlays, marketplace install/update surfaces, remote preview targets, incident/export packets, generated artifacts, and structured compare views. Each family row binds a trust-class ladder, raw-versus-rendered posture, active-content policy, copy/export representation semantics, safe-preview limited-mode posture, decision-strictness display mode, evidence requirements, downgrade triggers, source contracts, and consumer-surface parity. Raw suspicious bytes, raw rendered trees, raw provider payloads, credentials, and live preview-origin responses never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "matrix_label",
    "family_rows",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "freeze_m5_suspicious_content_safe_preview_and_representation_copy_export_matrix"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "matrix_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "family_rows": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "$ref": "#/$defs/family_row"
      }
    },
    "trust_review": {
      "$ref": "#/$defs/trust_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "family": {
      "type": "string",
      "enum": [
        "notebook_rich_output",
        "docs_browser_panel",
        "ai_evidence_viewer",
        "pipeline_artifact_browser",
        "provider_overlay",
        "marketplace_install_update",
        "remote_preview_target",
        "incident_export_packet",
        "generated_artifact",
        "structured_compare_view"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "trust_class": {
      "type": "string",
      "enum": [
        "raw_text",
        "sanitized_rich",
        "trusted_local_active",
        "isolated_remote_active",
        "blocked"
      ]
    },
    "raw_rendered_posture": {
      "type": "string",
      "enum": [
        "raw_and_rendered_distinct_both_reachable",
        "rendered_default_raw_on_demand",
        "raw_only_no_rendering",
        "not_applicable"
      ]
    },
    "active_content_policy": {
      "type": "string",
      "enum": [
        "inert_never_executes",
        "isolated_remote_sandbox_only",
        "trusted_local_only",
        "blocked_pending_review"
      ]
    },
    "copy_export_representation": {
      "type": "string",
      "enum": [
        "raw_and_escaped_labeled_distinct",
        "escaped_default_raw_reachable",
        "metadata_only_no_raw_body",
        "not_applicable"
      ]
    },
    "safe_preview_mode": {
      "type": "string",
      "enum": [
        "full_preview",
        "limited_mode_available",
        "limited_mode_default",
        "blocked"
      ]
    },
    "display_mode": {
      "type": "string",
      "enum": [
        "ordinary_browsing",
        "strong_decision_strict_identity"
      ]
    },
    "evidence_requirement": {
      "type": "string",
      "enum": [
        "required",
        "recommended",
        "optional",
        "not_applicable"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "suspicious_content_detected",
        "raw_rendered_divergence_unresolved",
        "active_content_untrusted",
        "safe_preview_unavailable",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "notebook_viewer",
        "docs_browser_panel",
        "ai_evidence_viewer",
        "pipeline_artifact_browser",
        "provider_overlay",
        "marketplace_surface",
        "remote_preview_panel",
        "incident_export",
        "structured_compare_view",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "family_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "qualification",
        "scope_summary",
        "trust_class_ladder",
        "raw_rendered_posture",
        "active_content_policy",
        "copy_export_representation",
        "safe_preview_mode",
        "display_mode",
        "evidence_requirement",
        "required_evidence_packet_refs",
        "downgrade_triggers",
        "source_contract_refs",
        "consumer_surfaces"
      ],
      "properties": {
        "family": {
          "$ref": "#/$defs/family"
        },
        "qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "scope_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "trust_class_ladder": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/trust_class"
          }
        },
        "raw_rendered_posture": {
          "$ref": "#/$defs/raw_rendered_posture"
        },
        "active_content_policy": {
          "$ref": "#/$defs/active_content_policy"
        },
        "copy_export_representation": {
          "$ref": "#/$defs/copy_export_representation"
        },
        "safe_preview_mode": {
          "$ref": "#/$defs/safe_preview_mode"
        },
        "display_mode": {
          "$ref": "#/$defs/display_mode"
        },
        "evidence_requirement": {
          "$ref": "#/$defs/evidence_requirement"
        },
        "required_evidence_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/consumer_surface"
          }
        }
      }
    },
    "trust_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "one_shared_policy_library_governs_all_families",
        "trust_decision_surfaces_use_stricter_display_mode",
        "raw_inspection_and_copy_reachable_on_divergence",
        "active_content_never_executes_outside_trust_class",
        "bidi_invisible_confusable_never_silently_rewritten",
        "suspicious_bytes_not_normalized_away",
        "rendered_copy_never_masquerades_as_raw",
        "no_auto_execute_in_embedded_or_review_surfaces",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "one_shared_policy_library_governs_all_families": {
          "type": "boolean",
          "const": true
        },
        "trust_decision_surfaces_use_stricter_display_mode": {
          "type": "boolean",
          "const": true
        },
        "raw_inspection_and_copy_reachable_on_divergence": {
          "type": "boolean",
          "const": true
        },
        "active_content_never_executes_outside_trust_class": {
          "type": "boolean",
          "const": true
        },
        "bidi_invisible_confusable_never_silently_rewritten": {
          "type": "boolean",
          "const": true
        },
        "suspicious_bytes_not_normalized_away": {
          "type": "boolean",
          "const": true
        },
        "rendered_copy_never_masquerades_as_raw": {
          "type": "boolean",
          "const": true
        },
        "no_auto_execute_in_embedded_or_review_surfaces": {
          "type": "boolean",
          "const": true
        },
        "downgrade_narrows_instead_of_hides": {
          "type": "boolean",
          "const": true
        },
        "stale_or_underqualified_blocks_promotion": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "notebook_shows_trust_class_and_active_content_state",
        "docs_browser_shows_raw_rendered_and_safe_preview_state",
        "ai_evidence_viewer_shows_representation_labels",
        "marketplace_install_uses_strict_identity_rendering",
        "copy_export_labels_raw_versus_rendered",
        "cli_headless_shows_qualification",
        "support_export_shows_qualification",
        "diagnostics_shows_qualification",
        "help_about_shows_qualification",
        "preview_labs_label_for_unqualified_families"
      ],
      "properties": {
        "notebook_shows_trust_class_and_active_content_state": {
          "type": "boolean",
          "const": true
        },
        "docs_browser_shows_raw_rendered_and_safe_preview_state": {
          "type": "boolean",
          "const": true
        },
        "ai_evidence_viewer_shows_representation_labels": {
          "type": "boolean",
          "const": true
        },
        "marketplace_install_uses_strict_identity_rendering": {
          "type": "boolean",
          "const": true
        },
        "copy_export_labels_raw_versus_rendered": {
          "type": "boolean",
          "const": true
        },
        "cli_headless_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "support_export_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "diagnostics_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "help_about_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "preview_labs_label_for_unqualified_families": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
