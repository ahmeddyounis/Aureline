{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/security/m5-secret-boundary-depth.schema.json",
  "title": "M5 Secret Boundary Depth Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "matrix_id",
    "label",
    "minted_at",
    "shared_contract_ref",
    "schema_ref",
    "doc_ref",
    "fixture_dir",
    "source_contract_refs",
    "surface_rows",
    "consumer_projections",
    "summary"
  ],
  "properties": {
    "record_kind": {
      "const": "m5_secret_boundary_depth_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "matrix_id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "minted_at": {
      "type": "string",
      "minLength": 1
    },
    "shared_contract_ref": {
      "const": "security:m5_secret_boundary_depth:v1"
    },
    "schema_ref": {
      "const": "schemas/security/m5-secret-boundary-depth.schema.json"
    },
    "doc_ref": {
      "const": "docs/security/m5/m5-secret-boundary-depth.md"
    },
    "fixture_dir": {
      "const": "fixtures/security/m5/m5-secret-boundary-depth"
    },
    "source_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "surface_rows": {
      "type": "array",
      "minItems": 8,
      "items": {
        "$ref": "#/$defs/surface_row"
      }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/consumer_projection"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "domain": {
      "type": "string",
      "enum": [
        "request_workspaces",
        "database_tooling",
        "provider_model_lanes",
        "registries",
        "preview_routes",
        "infra_connectors",
        "companion_handoff",
        "managed_surfaces"
      ]
    },
    "credential_mode": {
      "type": "string",
      "enum": [
        "os_store",
        "enterprise_vault",
        "session_only",
        "handle_only",
        "delegated",
        "device_code",
        "browser_handoff",
        "remote_vault_fetch",
        "not_configured"
      ]
    },
    "projection_mode": {
      "type": "string",
      "enum": [
        "handle_only",
        "delegated",
        "browser_handoff",
        "remote_vault_fetch",
        "request_header",
        "file_descriptor",
        "client_cert",
        "sign_only",
        "mount_ref"
      ]
    },
    "storage_class": {
      "type": "string",
      "enum": [
        "os_store",
        "enterprise_vault",
        "session_only",
        "remote_vault",
        "not_configured"
      ]
    },
    "acting_identity": {
      "type": "string",
      "enum": [
        "human_account",
        "installation_app_grant",
        "delegated_credential",
        "forwarded_local_credential",
        "local_only_handle",
        "service_issued_authority"
      ]
    },
    "trust_dependency": {
      "type": "string",
      "enum": [
        "os_store",
        "org_ca_bundle",
        "pinned_control_plane",
        "known_hosts",
        "vault_ref"
      ]
    },
    "export_posture": {
      "type": "string",
      "enum": [
        "metadata_only",
        "alias_only",
        "redacted_support_export",
        "release_summary_only"
      ]
    },
    "repair_owner": {
      "type": "string",
      "enum": [
        "user",
        "admin",
        "provider_operator",
        "remote_operator",
        "data_operator",
        "service_operator"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "docs_help",
        "diagnostics",
        "support_export",
        "release_public_truth"
      ]
    },
    "surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matrix_row_id",
        "title",
        "domain",
        "surface_ref",
        "allowed_credential_modes",
        "default_credential_mode",
        "projection_modes",
        "storage_classes",
        "acting_identities",
        "trust_store_dependencies",
        "export_posture",
        "repair_owner",
        "repair_path",
        "local_safe_behavior"
      ],
      "properties": {
        "matrix_row_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "$ref": "#/$defs/domain"
        },
        "surface_ref": {
          "type": "string",
          "minLength": 1
        },
        "allowed_credential_modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/credential_mode"
          }
        },
        "default_credential_mode": {
          "$ref": "#/$defs/credential_mode"
        },
        "projection_modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/projection_mode"
          }
        },
        "storage_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/storage_class"
          }
        },
        "acting_identities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/acting_identity"
          }
        },
        "trust_store_dependencies": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/trust_dependency"
          }
        },
        "export_posture": {
          "$ref": "#/$defs/export_posture"
        },
        "repair_owner": {
          "$ref": "#/$defs/repair_owner"
        },
        "repair_path": {
          "type": "string",
          "minLength": 1
        },
        "local_safe_behavior": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "surface_ref",
        "matrix_id",
        "vocabulary_ref",
        "shows_matrix_row_ids",
        "uses_shared_vocabulary",
        "notes"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/consumer_surface"
        },
        "surface_ref": {
          "type": "string",
          "minLength": 1
        },
        "matrix_id": {
          "type": "string",
          "minLength": 1
        },
        "vocabulary_ref": {
          "const": "docs/security/m5/m5-secret-boundary-depth.md#shared-vocabulary"
        },
        "shows_matrix_row_ids": {
          "type": "boolean"
        },
        "uses_shared_vocabulary": {
          "type": "boolean"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_count",
        "domain_tokens_present",
        "default_credential_mode_tokens_present",
        "consumer_surface_tokens_present",
        "raw_secret_values_excluded",
        "raw_handle_ids_excluded"
      ],
      "properties": {
        "surface_count": {
          "type": "integer",
          "minimum": 1
        },
        "domain_tokens_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/domain"
          }
        },
        "default_credential_mode_tokens_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/credential_mode"
          }
        },
        "consumer_surface_tokens_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/consumer_surface"
          }
        },
        "raw_secret_values_excluded": {
          "type": "boolean"
        },
        "raw_handle_ids_excluded": {
          "type": "boolean"
        }
      }
    }
  }
}
