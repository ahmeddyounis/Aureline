        "spend_attempt_id": { "$ref": "#/$defs/opaque_ref" },
        "profile": { "$ref": "#/$defs/profile" },
        "profile_token": { "$ref": "#/$defs/token" },
        "mutation_ref": { "$ref": "#/$defs/opaque_ref" },
