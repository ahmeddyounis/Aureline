        "current_target_identity": { "$ref": "#/$defs/target_identity" },
        "current_sandbox_profile_ref": { "$ref": "#/$defs/opaque_ref" },
        "current_capability_envelope_ref": { "$ref": "#/$defs/opaque_ref" },
        "current_trust_profile_ref": { "$ref": "#/$defs/opaque_ref" },
        "current_policy_epoch_ref": { "$ref": "#/$defs/opaque_ref" },
        "evaluated_at": { "$ref": "#/$defs/timestamp" },
