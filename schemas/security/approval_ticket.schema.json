        "expires_at": { "$ref": "#/$defs/timestamp" },
        "lifetime_seconds": { "type": "integer", "minimum": 0 },
        "use_posture": { "$ref": "#/$defs/use_posture" },
        "use_posture_token": { "$ref": "#/$defs/token" },
        "authority_requirement": { "$ref": "#/$defs/authority_requirement" },
        "authority_requirement_token": { "$ref": "#/$defs/token" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "rollback_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "runtime_approval_ticket_ref": { "$ref": "#/$defs/opaque_ref" },
        "provider_plane_approval_ticket_ref": { "$ref": "#/$defs/opaque_ref" },
        "guardrails": { "$ref": "#/$defs/guardrails" }
      }
    },
    "spend_attempt_event": {
      "type": "object",
