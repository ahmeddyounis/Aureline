{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/remembered_decision_rule.schema.json",
  "title": "Aureline remembered decision rule",
  "description": "Narrow remembered-decision rule consumed by the runtime-authority-issuer projection. A rule compiles a remembered approval into a renewable short-lived ticket bound to an explicit target, actor, authority source, scope, sandbox profile, policy epoch, expiry, and revoke path. Credential projection, privileged debug attach, and policy/trust/admin tickets must always reprompt and cannot be remembered.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "rule_id",
    "display_label",
    "owning_issuer_id",
    "ticket_class",
    "ticket_class_token",
    "target_identity",
    "actor_class",
    "actor_class_token",
    "actor_subject_ref",
    "authority_source_class",
    "authority_source_class_token",
    "authority_source_ref",
    "scope_ref",
    "sandbox_binding",
    "renewable_ticket_lifetime_seconds",
    "rule_expires_at",
    "revoke_path_ref",
    "audit_event_refs"
  ],
  "properties": {
    "record_kind": { "const": "security_remembered_decision_rule_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": {
      "type": "string",
      "const": "security:runtime_authority_issuer_beta:v1"
    },
    "rule_id": { "type": "string", "minLength": 1 },
    "display_label": { "type": "string", "minLength": 1 },
    "owning_issuer_id": { "type": "string", "minLength": 1 },
    "ticket_class": {
      "type": "string",
      "enum": [
        "local_mutation",
        "external_provider_mutation"
      ]
    },
    "ticket_class_token": {
      "type": "string",
      "enum": [
        "local_mutation",
        "external_provider_mutation"
      ]
    },
    "target_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_class",
        "target_class_token",
        "target_ref",
        "target_label",
        "target_fingerprint_ref"
      ],
      "properties": {
        "target_class": {
          "type": "string",
          "enum": [
            "local_workspace",
            "provider_object",
            "credential_consumer",
            "debug_attach_target",
            "trust_store",
            "policy_admin_object"
          ]
        },
        "target_class_token": {
          "type": "string",
          "enum": [
            "local_workspace",
            "provider_object",
            "credential_consumer",
            "debug_attach_target",
            "trust_store",
            "policy_admin_object"
          ]
        },
        "target_ref": { "type": "string", "minLength": 1 },
        "target_label": { "type": "string", "minLength": 1 },
        "target_fingerprint_ref": { "type": "string", "minLength": 1 }
      }
    },
    "actor_class": {
      "type": "string",
      "enum": [
        "human_account",
        "local_admin",
        "organization_admin",
        "installation_or_app_grant",
        "delegated_credential",
        "policy_injected_service_identity",
        "local_only_authority"
      ]
    },
    "actor_class_token": {
      "type": "string",
      "enum": [
        "human_account",
        "local_admin",
        "organization_admin",
        "installation_or_app_grant",
        "delegated_credential",
        "policy_injected_service_identity",
        "local_only_authority"
      ]
    },
    "actor_subject_ref": { "type": "string", "minLength": 1 },
    "authority_source_class": {
      "type": "string",
      "enum": [
        "human_account",
        "installation_grant",
        "delegated_credential",
        "local_only_authority"
      ]
    },
    "authority_source_class_token": {
      "type": "string",
      "enum": [
        "human_account",
        "installation_grant",
        "delegated_credential",
        "local_only_authority"
      ]
    },
    "authority_source_ref": { "type": "string", "minLength": 1 },
    "scope_ref": { "type": "string", "minLength": 1 },
    "sandbox_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sandbox_profile_ref",
        "sandbox_profile_fingerprint_ref",
        "capability_envelope_ref",
        "policy_epoch_ref"
      ],
      "properties": {
        "sandbox_profile_ref": { "type": "string", "minLength": 1 },
        "sandbox_profile_fingerprint_ref": { "type": "string", "minLength": 1 },
        "capability_envelope_ref": { "type": "string", "minLength": 1 },
        "policy_epoch_ref": { "type": "string", "minLength": 1 }
      }
    },
    "renewable_ticket_lifetime_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 900
    },
    "rule_expires_at": { "type": "string", "format": "date-time" },
    "revoke_path_ref": { "type": "string", "minLength": 1 },
    "audit_event_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
