{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/workspace_trust_beta.schema.json",
  "title": "Aureline workspace-trust beta audit page",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "source_matrix_ref",
    "rows",
    "support_rows",
    "defects",
    "summary"
  ],
  "properties": {
    "record_kind": {
      "const": "security_workspace_trust_beta_page_record"
    },
    "schema_version": {
      "$ref": "#/$defs/schema_version"
    },
    "shared_contract_ref": {
      "$ref": "#/$defs/shared_contract_ref"
    },
    "source_matrix_ref": {
      "type": "string",
      "minLength": 1
    },
    "rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/row"
      },
      "minItems": 26,
      "uniqueItems": true
    },
    "support_rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/support_row"
      },
      "minItems": 26,
      "uniqueItems": true
    },
    "defects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/defect"
      },
      "uniqueItems": true
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "security:workspace_trust_beta:v1"
    },
    "token": {
      "type": "string",
      "minLength": 1
    },
    "lane": {
      "type": "string",
      "enum": [
        "open",
        "run",
        "debug",
        "extension",
        "ai",
        "provider",
        "review",
        "support",
        "admin"
      ]
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "workspace_open_restore",
        "editor_read_write",
        "search_local",
        "local_git_read",
        "local_git_write",
        "shell_command_palette",
        "tasks_run",
        "terminal_manual_open",
        "terminal_repo_recipe_launch",
        "debug_launch",
        "notebook_kernel_connect",
        "notebook_cell_execute",
        "notebook_rich_output_render",
        "ai_context_read",
        "ai_apply_mutation",
        "ai_tool_call_mutating",
        "extension_activation",
        "extension_install",
        "environment_activator_run",
        "scaffold_template_run",
        "connected_provider_open",
        "connected_provider_tool_call",
        "remote_attach",
        "mcp_server_launch",
        "support_bundle_export",
        "admin_policy_read"
      ]
    },
    "authority": {
      "type": "string",
      "enum": [
        "allowed",
        "read_only",
        "degraded_preview_only",
        "blocked_pending_trust",
        "blocked_pending_approval",
        "approval_required_per_invocation",
        "policy_denied",
        "quarantine_denied",
        "not_applicable"
      ]
    },
    "profile": {
      "type": "string",
      "enum": [
        "connected",
        "mirror_only",
        "offline",
        "enterprise_managed"
      ]
    },
    "defect_kind": {
      "type": "string",
      "enum": [
        "missing_matrix_surface",
        "missing_restricted_mode_availability",
        "run_or_mutation_allowed_before_trust",
        "trust_loss_not_propagated",
        "missing_escalation_cue",
        "profile_coverage_missing",
        "hidden_public_endpoint_fallback",
        "support_row_vocabulary_drift",
        "policy_degraded_widens_trusted",
        "raw_private_material_exposed"
      ]
    },
    "profile_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_class",
        "profile_token",
        "authority",
        "authority_token",
        "source_label",
        "no_public_endpoint_fallback"
      ],
      "properties": {
        "profile_class": {
          "$ref": "#/$defs/profile"
        },
        "profile_token": {
          "$ref": "#/$defs/profile"
        },
        "authority": {
          "$ref": "#/$defs/authority"
        },
        "authority_token": {
          "$ref": "#/$defs/authority"
        },
        "source_label": {
          "$ref": "#/$defs/token"
        },
        "no_public_endpoint_fallback": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_id",
        "lane",
        "lane_token",
        "surface_family",
        "surface_family_token",
        "source_matrix_ref",
        "restricted_authority",
        "restricted_authority_token",
        "trusted_authority",
        "trusted_authority_token",
        "trusted_policy_degraded_authority",
        "trusted_policy_degraded_authority_token",
        "trust_loss_authority",
        "trust_loss_authority_token",
        "profile_authorities",
        "restricted_mode_available_before_trust",
        "restricted_mode_explainer",
        "floor_capability",
        "run_or_mutation_capable",
        "requires_explicit_trust_elevation",
        "trust_elevation_audit_event_token",
        "trust_loss_audit_event_token",
        "trust_loss_propagates_to_shell",
        "trust_loss_propagates_to_runtime",
        "trust_loss_propagates_to_extension",
        "trust_loss_propagates_to_support",
        "escalation_cue_tokens",
        "support_export_summary",
        "no_public_endpoint_fallback",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "const": "security_workspace_trust_beta_row_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "row_id": {
          "$ref": "#/$defs/token"
        },
        "lane": {
          "$ref": "#/$defs/lane"
        },
        "lane_token": {
          "$ref": "#/$defs/lane"
        },
        "surface_family": {
          "$ref": "#/$defs/surface_family"
        },
        "surface_family_token": {
          "$ref": "#/$defs/surface_family"
        },
        "source_matrix_ref": {
          "$ref": "#/$defs/token"
        },
        "restricted_authority": {
          "$ref": "#/$defs/authority"
        },
        "restricted_authority_token": {
          "$ref": "#/$defs/authority"
        },
        "trusted_authority": {
          "$ref": "#/$defs/authority"
        },
        "trusted_authority_token": {
          "$ref": "#/$defs/authority"
        },
        "trusted_policy_degraded_authority": {
          "$ref": "#/$defs/authority"
        },
        "trusted_policy_degraded_authority_token": {
          "$ref": "#/$defs/authority"
        },
        "trust_loss_authority": {
          "$ref": "#/$defs/authority"
        },
        "trust_loss_authority_token": {
          "$ref": "#/$defs/authority"
        },
        "profile_authorities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/profile_authority"
          },
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true
        },
        "restricted_mode_available_before_trust": {
          "type": "boolean",
          "const": true
        },
        "restricted_mode_explainer": {
          "$ref": "#/$defs/token"
        },
        "floor_capability": {
          "type": "boolean"
        },
        "run_or_mutation_capable": {
          "type": "boolean"
        },
        "requires_explicit_trust_elevation": {
          "type": "boolean"
        },
        "trust_elevation_audit_event_token": {
          "const": "workspace_trust_granted"
        },
        "trust_loss_audit_event_token": {
          "const": "workspace_trust_revoked"
        },
        "trust_loss_propagates_to_shell": {
          "type": "boolean",
          "const": true
        },
        "trust_loss_propagates_to_runtime": {
          "type": "boolean",
          "const": true
        },
        "trust_loss_propagates_to_extension": {
          "type": "boolean",
          "const": true
        },
        "trust_loss_propagates_to_support": {
          "type": "boolean",
          "const": true
        },
        "escalation_cue_tokens": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/token"
          },
          "uniqueItems": true
        },
        "support_export_summary": {
          "$ref": "#/$defs/token"
        },
        "no_public_endpoint_fallback": {
          "type": "boolean",
          "const": true
        },
        "raw_private_material_excluded": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "support_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_id",
        "lane_token",
        "surface_family_token",
        "restricted_authority_token",
        "trust_loss_authority_token",
        "profile_authority_tokens",
        "escalation_cue_tokens",
        "support_export_summary",
        "no_public_endpoint_fallback",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "const": "security_workspace_trust_beta_support_row_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "row_id": {
          "$ref": "#/$defs/token"
        },
        "lane_token": {
          "$ref": "#/$defs/lane"
        },
        "surface_family_token": {
          "$ref": "#/$defs/surface_family"
        },
        "restricted_authority_token": {
          "$ref": "#/$defs/authority"
        },
        "trust_loss_authority_token": {
          "$ref": "#/$defs/authority"
        },
        "profile_authority_tokens": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/authority"
          }
        },
        "escalation_cue_tokens": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/token"
          },
          "uniqueItems": true
        },
        "support_export_summary": {
          "$ref": "#/$defs/token"
        },
        "no_public_endpoint_fallback": {
          "type": "boolean"
        },
        "raw_private_material_excluded": {
          "type": "boolean"
        }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_kind",
        "defect_kind_token",
        "row_id",
        "surface_family_token",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": {
          "const": "security_workspace_trust_beta_defect_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "defect_kind": {
          "$ref": "#/$defs/defect_kind"
        },
        "defect_kind_token": {
          "$ref": "#/$defs/defect_kind"
        },
        "row_id": {
          "$ref": "#/$defs/token"
        },
        "surface_family_token": {
          "type": "string"
        },
        "field": {
          "$ref": "#/$defs/token"
        },
        "note": {
          "$ref": "#/$defs/token"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_record_kind",
        "row_count",
        "support_row_count",
        "restricted_floor_row_count",
        "blocked_or_review_before_trust_count",
        "run_or_mutation_capable_count",
        "lanes_present",
        "profiles_present",
        "defect_count",
        "defect_counts_by_kind"
      ],
      "properties": {
        "page_record_kind": {
          "const": "security_workspace_trust_beta_page_record"
        },
        "row_count": {
          "type": "integer",
          "minimum": 26
        },
        "support_row_count": {
          "type": "integer",
          "minimum": 26
        },
        "restricted_floor_row_count": {
          "type": "integer",
          "minimum": 1
        },
        "blocked_or_review_before_trust_count": {
          "type": "integer",
          "minimum": 1
        },
        "run_or_mutation_capable_count": {
          "type": "integer",
          "minimum": 1
        },
        "lanes_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lane"
          },
          "uniqueItems": true
        },
        "profiles_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/profile"
          },
          "uniqueItems": true
        },
        "defect_count": {
          "type": "integer",
          "minimum": 0
        },
        "defect_counts_by_kind": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
