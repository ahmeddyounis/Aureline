{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/offline_entitlement.schema.json",
  "title": "Aureline offline policy-bundle and entitlement verifier beta page",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "source_matrix_ref",
    "rows",
    "defects",
    "summary"
  ],
  "properties": {
    "record_kind": {
      "const": "security_offline_entitlement_verifier_beta_page_record"
    },
    "schema_version": {
      "$ref": "#/$defs/schema_version"
    },
    "shared_contract_ref": {
      "$ref": "#/$defs/shared_contract_ref"
    },
    "source_matrix_ref": {
      "type": "string",
      "minLength": 1
    },
    "rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/row"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "defects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/defect"
      },
      "uniqueItems": true
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "security:offline_entitlement_verifier_beta:v1"
    },
    "token": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string",
      "enum": [
        "connected",
        "mirror_only",
        "offline",
        "enterprise_managed"
      ]
    },
    "bundle_kind": {
      "type": "string",
      "enum": [
        "policy_bundle",
        "entitlement_snapshot"
      ]
    },
    "trust_anchor_source": {
      "type": "string",
      "enum": [
        "vendor_managed_root",
        "customer_self_hosted_root",
        "signed_mirror_root",
        "manual_import_root",
        "air_gapped_root",
        "runtime_preload_root",
        "local_advisory_no_root"
      ]
    },
    "outcome": {
      "type": "string",
      "enum": [
        "verified_live",
        "verified_mirror",
        "verified_manual_import",
        "verified_air_gapped",
        "unsigned_local_advisory",
        "expired",
        "signature_missing",
        "signature_invalid",
        "untrusted_signer",
        "bundle_not_present",
        "revoked"
      ]
    },
    "managed_impact": {
      "type": "string",
      "enum": [
        "full_authority_active",
        "narrowed_to_inspect_only",
        "narrowed_to_read_or_preview",
        "paused_with_visible_recovery",
        "blocked_pending_repair",
        "not_applicable_local_only"
      ]
    },
    "local_editing": {
      "type": "string",
      "enum": [
        "preserved",
        "preserved_with_advisory",
        "not_applicable_local_only"
      ]
    },
    "recovery_action": {
      "type": "string",
      "enum": [
        "no_action_verified",
        "refresh_signed_bundle_live",
        "refresh_signed_bundle_mirror",
        "import_signed_bundle_file",
        "import_air_gapped_transfer",
        "escalate_admin_quorum",
        "continue_local_only"
      ]
    },
    "defect_kind": {
      "type": "string",
      "enum": [
        "untrusted_signer_accepted",
        "expired_bundle_accepted_without_downgrade",
        "verified_outcome_without_trust_anchor",
        "outcome_impact_mismatch",
        "outcome_token_drift",
        "profile_token_drift",
        "bundle_kind_token_drift",
        "trust_anchor_token_drift",
        "impact_token_drift",
        "local_editing_token_drift",
        "recovery_action_token_drift",
        "local_editing_blocked_on_failed_verification",
        "hidden_public_endpoint_fallback",
        "raw_private_material_exposed",
        "profile_coverage_missing",
        "bundle_kind_coverage_missing",
        "unsigned_local_advisory_on_managed_anchor",
        "downgrade_missing_recovery_action"
      ]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_ref",
        "bundle_kind",
        "bundle_kind_token",
        "bundle_version",
        "bundle_epoch_ref",
        "signer_id",
        "signed_at",
        "valid_until"
      ],
      "properties": {
        "bundle_ref": {
          "$ref": "#/$defs/token"
        },
        "bundle_kind": {
          "$ref": "#/$defs/bundle_kind"
        },
        "bundle_kind_token": {
          "$ref": "#/$defs/bundle_kind"
        },
        "bundle_version": {
          "$ref": "#/$defs/token"
        },
        "bundle_epoch_ref": {
          "$ref": "#/$defs/token"
        },
        "signer_id": {
          "$ref": "#/$defs/token"
        },
        "signed_at": {
          "$ref": "#/$defs/token"
        },
        "valid_until": {
          "$ref": "#/$defs/token"
        }
      }
    },
    "trust_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "source_token",
        "anchor_ref",
        "anchor_label",
        "last_rotated_at"
      ],
      "properties": {
        "source_class": {
          "$ref": "#/$defs/trust_anchor_source"
        },
        "source_token": {
          "$ref": "#/$defs/trust_anchor_source"
        },
        "anchor_ref": {
          "$ref": "#/$defs/token"
        },
        "anchor_label": {
          "$ref": "#/$defs/token"
        },
        "last_rotated_at": {
          "$ref": "#/$defs/token"
        }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_id",
        "display_label",
        "profile_class",
        "profile_token",
        "subject",
        "trust_anchor",
        "outcome_class",
        "outcome_token",
        "outcome_label",
        "managed_capability_impact",
        "managed_capability_impact_token",
        "local_editing_preservation",
        "local_editing_preservation_token",
        "recovery_action",
        "recovery_action_token",
        "explanation_label",
        "no_public_endpoint_fallback",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "const": "security_offline_entitlement_verifier_beta_row_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "row_id": {
          "$ref": "#/$defs/token"
        },
        "display_label": {
          "$ref": "#/$defs/token"
        },
        "profile_class": {
          "$ref": "#/$defs/profile"
        },
        "profile_token": {
          "$ref": "#/$defs/profile"
        },
        "subject": {
          "$ref": "#/$defs/subject"
        },
        "trust_anchor": {
          "$ref": "#/$defs/trust_anchor"
        },
        "outcome_class": {
          "$ref": "#/$defs/outcome"
        },
        "outcome_token": {
          "$ref": "#/$defs/outcome"
        },
        "outcome_label": {
          "$ref": "#/$defs/token"
        },
        "managed_capability_impact": {
          "$ref": "#/$defs/managed_impact"
        },
        "managed_capability_impact_token": {
          "$ref": "#/$defs/managed_impact"
        },
        "local_editing_preservation": {
          "$ref": "#/$defs/local_editing"
        },
        "local_editing_preservation_token": {
          "$ref": "#/$defs/local_editing"
        },
        "recovery_action": {
          "$ref": "#/$defs/recovery_action"
        },
        "recovery_action_token": {
          "$ref": "#/$defs/recovery_action"
        },
        "explanation_label": {
          "$ref": "#/$defs/token"
        },
        "no_public_endpoint_fallback": {
          "type": "boolean",
          "const": true
        },
        "raw_private_material_excluded": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_kind",
        "defect_kind_token",
        "subject_id",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": {
          "const": "security_offline_entitlement_verifier_beta_defect_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "defect_kind": {
          "$ref": "#/$defs/defect_kind"
        },
        "defect_kind_token": {
          "$ref": "#/$defs/defect_kind"
        },
        "subject_id": {
          "$ref": "#/$defs/token"
        },
        "field": {
          "$ref": "#/$defs/token"
        },
        "note": {
          "$ref": "#/$defs/token"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_record_kind",
        "record_kind",
        "row_count",
        "verified_row_count",
        "failed_row_count",
        "local_editing_preserved_row_count",
        "managed_authority_narrowed_row_count",
        "profiles_present",
        "bundle_kinds_present",
        "outcomes_present",
        "defect_count",
        "defect_counts_by_kind"
      ],
      "properties": {
        "page_record_kind": {
          "const": "security_offline_entitlement_verifier_beta_page_record"
        },
        "record_kind": {
          "const": "security_offline_entitlement_verifier_beta_summary_record"
        },
        "row_count": {
          "type": "integer",
          "minimum": 0
        },
        "verified_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "failed_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "local_editing_preserved_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "managed_authority_narrowed_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "profiles_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/profile"
          },
          "uniqueItems": true
        },
        "bundle_kinds_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/bundle_kind"
          },
          "uniqueItems": true
        },
        "outcomes_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/outcome"
          },
          "uniqueItems": true
        },
        "defect_count": {
          "type": "integer",
          "minimum": 0
        },
        "defect_counts_by_kind": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
