{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/m5-mutation-path-fix-flow.schema.json",
  "title": "Aureline M5 mutation-path fix-flow and auditable-suppression packet",
  "description": "Export-safe packet that governs the new M5 mutation paths (save, format, organize-imports, AI-apply) over the new mutation-bearing artifact families (notebooks, docs pages, AI-evidence artifacts, structured/generated artifacts). Every mutation path blocks silent suspicious-byte rewrites: a fix that would rewrite bidi/invisible/confusable bytes always routes through a previewable diff (local-edit paths) or a review sheet (AI-apply) before any bytes change. The shared suspicious-content detector runs over the content each path touches; the fix flow offers a bidi, invisible, or confusable fix for each detected class. When a warning is suppressed instead of fixed, the suppression is a scope-aware, auditable object (actor, reason, timestamp, scope, optional expiry, reachable audit log) recorded at an occurrence/file/workspace/admin-policy scope, never hidden per-pane state. Suspicious bytes are never normalized away, the escaped inspection excerpt never masquerades as the raw bytes, and the guard is preserved in product, exported review packets, and support handoff. The packet carries only metadata: opaque refs to the artifact and its raw bytes plus the detector's escaped excerpt, never the raw artifact bodies, credentials, or payloads.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "case_id",
    "path_count",
    "paths_with_findings_count",
    "suppressed_path_count",
    "fix_flow_modes",
    "recorded_suppression_scopes",
    "normalization_applied",
    "paths",
    "review",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "m5_mutation_path_fix_flow_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "case_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "path_count": {
      "type": "integer",
      "minimum": 0
    },
    "paths_with_findings_count": {
      "type": "integer",
      "minimum": 0
    },
    "suppressed_path_count": {
      "type": "integer",
      "minimum": 0
    },
    "fix_flow_modes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fix_flow_mode"
      }
    },
    "recorded_suppression_scopes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/suppression_scope"
      }
    },
    "normalization_applied": {
      "const": false
    },
    "paths": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/path_projection"
      }
    },
    "review": {
      "$ref": "#/$defs/review"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "mutation_path": {
      "type": "string",
      "enum": [
        "save",
        "format",
        "organize_imports",
        "ai_apply"
      ]
    },
    "fix_flow_mode": {
      "type": "string",
      "enum": [
        "previewable_diff",
        "review_sheet"
      ]
    },
    "fix_kind": {
      "type": "string",
      "enum": [
        "bidi",
        "invisible",
        "confusable"
      ]
    },
    "suppression_scope": {
      "type": "string",
      "enum": [
        "occurrence",
        "file",
        "workspace",
        "admin_policy"
      ]
    },
    "fix_flow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "mode_token",
        "label",
        "preview_required",
        "shows_raw_and_proposed",
        "fix_kinds_offered"
      ],
      "properties": {
        "mode": {
          "$ref": "#/$defs/fix_flow_mode"
        },
        "mode_token": {
          "$ref": "#/$defs/fix_flow_mode"
        },
        "label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preview_required": {
          "const": true
        },
        "shows_raw_and_proposed": {
          "const": true
        },
        "fix_kinds_offered": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fix_kind"
          }
        }
      }
    },
    "suppression_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_aware",
        "allowed_scopes",
        "records_actor",
        "records_reason",
        "records_timestamp",
        "records_scope",
        "supports_expiry",
        "audit_log_reachable",
        "hidden_per_pane_state"
      ],
      "properties": {
        "scope_aware": {
          "const": true
        },
        "allowed_scopes": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/suppression_scope"
          }
        },
        "records_actor": {
          "const": true
        },
        "records_reason": {
          "const": true
        },
        "records_timestamp": {
          "const": true
        },
        "records_scope": {
          "const": true
        },
        "supports_expiry": {
          "const": true
        },
        "audit_log_reachable": {
          "const": true
        },
        "hidden_per_pane_state": {
          "const": false
        }
      }
    },
    "suppression_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suppression_id",
        "scope",
        "scope_token",
        "suppressed_fix_kinds",
        "actor_ref",
        "reason",
        "recorded_at",
        "expires_at",
        "audit_log_ref",
        "finding_artifact_ref",
        "hidden_per_pane_state"
      ],
      "properties": {
        "suppression_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "scope": {
          "$ref": "#/$defs/suppression_scope"
        },
        "scope_token": {
          "$ref": "#/$defs/suppression_scope"
        },
        "suppressed_fix_kinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/fix_kind"
          }
        },
        "actor_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "audit_log_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "finding_artifact_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "hidden_per_pane_state": {
          "const": false
        }
      }
    },
    "path_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "path_token",
        "path_display_name",
        "artifact_ref",
        "raw_content_ref",
        "suspicious_excerpt_escaped",
        "findings_present",
        "finding_count",
        "threat_classes",
        "detector_outcome_token",
        "fix_flow",
        "silent_byte_rewrite_blocked",
        "bytes_change_only_after_preview",
        "suppression_audit",
        "recorded_suppression",
        "preserved_in_product",
        "preserved_in_exported_review_packet",
        "preserved_in_support_handoff",
        "rationale"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/mutation_path"
        },
        "path_token": {
          "$ref": "#/$defs/mutation_path"
        },
        "path_display_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "artifact_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "raw_content_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "suspicious_excerpt_escaped": {
          "$ref": "#/$defs/non_empty_string"
        },
        "findings_present": {
          "type": "boolean"
        },
        "finding_count": {
          "type": "integer",
          "minimum": 0
        },
        "threat_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "detector_outcome_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "fix_flow": {
          "$ref": "#/$defs/fix_flow"
        },
        "silent_byte_rewrite_blocked": {
          "const": true
        },
        "bytes_change_only_after_preview": {
          "const": true
        },
        "suppression_audit": {
          "$ref": "#/$defs/suppression_audit"
        },
        "recorded_suppression": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/suppression_record"
            }
          ]
        },
        "preserved_in_product": {
          "const": true
        },
        "preserved_in_exported_review_packet": {
          "const": true
        },
        "preserved_in_support_handoff": {
          "const": true
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "one_shared_policy_library_governs_all_paths",
        "save_format_organize_imports_and_ai_apply_covered",
        "all_mutation_paths_block_silent_byte_rewrite",
        "fixes_route_through_preview_before_bytes_change",
        "fix_flows_offer_bidi_invisible_confusable",
        "suspicious_bytes_never_normalized_away",
        "escaped_excerpt_never_masquerades_as_raw",
        "suppressions_are_scope_aware_and_auditable",
        "suppressions_never_hidden_per_pane_state",
        "guard_preserved_in_product_export_and_handoff"
      ],
      "properties": {
        "one_shared_policy_library_governs_all_paths": {
          "const": true
        },
        "save_format_organize_imports_and_ai_apply_covered": {
          "const": true
        },
        "all_mutation_paths_block_silent_byte_rewrite": {
          "const": true
        },
        "fixes_route_through_preview_before_bytes_change": {
          "const": true
        },
        "fix_flows_offer_bidi_invisible_confusable": {
          "const": true
        },
        "suspicious_bytes_never_normalized_away": {
          "const": true
        },
        "escaped_excerpt_never_masquerades_as_raw": {
          "const": true
        },
        "suppressions_are_scope_aware_and_auditable": {
          "const": true
        },
        "suppressions_never_hidden_per_pane_state": {
          "const": true
        },
        "guard_preserved_in_product_export_and_handoff": {
          "const": true
        }
      }
    }
  }
}
