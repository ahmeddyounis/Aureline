{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/text_representation_action.schema.json",
  "title": "Aureline text representation action row",
  "description": "Boundary schema for one representation-labeled copy or export action frozen in docs/accessibility/locale_fallback_and_copy_representation_contract.md. The row names action availability, defaulting, payload posture, required peer actions, and disclosure fields so editor, diff, docs preview, install review, terminal transcript, support export, and security review surfaces cannot use ambiguous Copy or Export labels when raw, rendered, escaped, sanitized, or metadata-only outputs differ.",
  "type": "object",
  "$ref": "#/$defs/text_representation_action_record",
  "$defs": {
    "text_representation_action_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this action-row contract. Additive enum values bump this const; repurposing values is breaking."
    },
    "record_kind": {
      "type": "string",
      "const": "text_representation_action_record"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "description": "Opaque id safe for fixtures, logs, support bundles, and security review exports."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "bounded_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "bounded_note": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "editor",
        "diff",
        "docs_preview",
        "install_review",
        "terminal_transcript",
        "support_export",
        "security_review",
        "rich_preview",
        "approval_surface"
      ],
      "description": "Cross-surface family that consumes the same canonical representation labels."
    },
    "trust_class": {
      "type": "string",
      "enum": [
        "RawText",
        "SanitizedRich",
        "TrustedLocalActive",
        "IsolatedRemoteActive",
        "not_applicable"
      ]
    },
    "representation_action_id": {
      "type": "string",
      "enum": [
        "copy_raw",
        "copy_rendered",
        "copy_escaped",
        "export_sanitized_snapshot",
        "export_metadata_only"
      ]
    },
    "canonical_label": {
      "type": "string",
      "enum": [
        "Copy raw",
        "Copy rendered",
        "Copy escaped",
        "Export sanitized snapshot",
        "Export metadata only"
      ]
    },
    "representation_class": {
      "type": "string",
      "enum": [
        "raw",
        "rendered",
        "escaped",
        "sanitized_snapshot",
        "metadata_only"
      ]
    },
    "body_posture": {
      "type": "string",
      "enum": [
        "exact_source_bytes",
        "rendered_view",
        "escaped_source_text",
        "sanitized_static_snapshot",
        "metadata_only_envelope"
      ]
    },
    "availability_state": {
      "type": "string",
      "enum": [
        "available",
        "unavailable",
        "blocked_by_policy",
        "source_missing",
        "not_applicable"
      ]
    },
    "default_state": {
      "type": "string",
      "enum": [
        "primary_default",
        "secondary_available",
        "fallback_default",
        "not_available"
      ]
    },
    "action_condition": {
      "type": "string",
      "enum": [
        "exact_source_available",
        "rendered_view_available",
        "escaped_source_available",
        "suspicious_content_present",
        "raw_rendered_divergence_present",
        "active_content_present",
        "active_content_removed",
        "sanitized_snapshot_available",
        "source_representation_missing",
        "policy_blocks_raw_body",
        "malformed_decode_or_replacement_present",
        "support_or_security_export_boundary",
        "origin_or_owner_verified",
        "terminal_transcript_available",
        "assistive_label_available"
      ]
    },
    "disclosure_field": {
      "type": "string",
      "enum": [
        "representation_label",
        "source_surface",
        "trust_class",
        "owner_identity",
        "origin_identity",
        "snapshot_age",
        "warning_state",
        "metadata_only_reason",
        "raw_rendered_divergence_note",
        "active_content_removed_note",
        "malformed_text_note"
      ]
    },
    "unavailable_reason": {
      "type": "string",
      "enum": [
        "none",
        "policy_requires_metadata_only",
        "source_bytes_missing",
        "rendered_view_not_available",
        "active_content_not_exportable",
        "origin_unverified",
        "redaction_blocks_body",
        "not_meaningful_for_surface"
      ]
    },
    "payload_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "body_posture",
        "raw_source_required",
        "active_content_removed",
        "includes_body"
      ],
      "properties": {
        "body_posture": { "$ref": "#/$defs/body_posture" },
        "raw_source_required": { "type": "boolean" },
        "active_content_removed": { "type": "boolean" },
        "includes_body": { "type": "boolean" }
      }
    },
    "defaulting_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_state",
        "reason"
      ],
      "properties": {
        "default_state": { "$ref": "#/$defs/default_state" },
        "reason": { "$ref": "#/$defs/bounded_note" }
      }
    },
    "text_representation_action_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "text_representation_action_schema_version",
        "action_row_id",
        "source_surface_family",
        "source_trust_class",
        "action_id",
        "canonical_label",
        "surface_label",
        "representation_class",
        "availability_state",
        "availability_conditions",
        "defaulting_rule",
        "payload_posture",
        "required_peer_actions",
        "required_disclosure_fields",
        "unavailable_reason",
        "parity_surface_refs",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": {
          "type": "object",
          "additionalProperties": true
        },
        "record_kind": { "const": "text_representation_action_record" },
        "text_representation_action_schema_version": {
          "$ref": "#/$defs/text_representation_action_schema_version"
        },
        "action_row_id": { "$ref": "#/$defs/opaque_id" },
        "policy_transfer_record_ref": {
          "oneOf": [
            { "$ref": "#/$defs/opaque_id" },
            { "type": "null" }
          ],
          "description": "Optional ref to a schemas/security/text_representation_policy.schema.json representation_transfer_record."
        },
        "source_surface_family": { "$ref": "#/$defs/surface_family" },
        "source_trust_class": { "$ref": "#/$defs/trust_class" },
        "action_id": { "$ref": "#/$defs/representation_action_id" },
        "canonical_label": { "$ref": "#/$defs/canonical_label" },
        "surface_label": {
          "$ref": "#/$defs/bounded_label",
          "description": "Visible label. It may append a target noun, but must preserve canonical_label as its stem."
        },
        "representation_class": { "$ref": "#/$defs/representation_class" },
        "availability_state": { "$ref": "#/$defs/availability_state" },
        "availability_conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/action_condition" },
          "uniqueItems": true
        },
        "defaulting_rule": { "$ref": "#/$defs/defaulting_rule" },
        "payload_posture": { "$ref": "#/$defs/payload_posture" },
        "required_peer_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/representation_action_id" },
          "uniqueItems": true
        },
        "required_disclosure_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/disclosure_field" },
          "uniqueItems": true,
          "contains": { "const": "representation_label" }
        },
        "unavailable_reason": { "$ref": "#/$defs/unavailable_reason" },
        "parity_surface_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_family" },
          "uniqueItems": true,
          "description": "Surface families that must preserve this canonical label stem when they expose the same action."
        },
        "review_note": { "$ref": "#/$defs/bounded_note" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "action_id": { "const": "copy_raw" } },
            "required": ["action_id"]
          },
          "then": {
            "properties": {
              "canonical_label": { "const": "Copy raw" },
              "surface_label": { "pattern": "^Copy raw(\\b|$)" },
              "representation_class": { "const": "raw" },
              "payload_posture": {
                "properties": {
                  "body_posture": { "const": "exact_source_bytes" },
                  "raw_source_required": { "const": true },
                  "active_content_removed": { "const": false },
                  "includes_body": { "const": true }
                },
                "required": [
                  "body_posture",
                  "raw_source_required",
                  "active_content_removed",
                  "includes_body"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "action_id": { "const": "copy_rendered" } },
            "required": ["action_id"]
          },
          "then": {
            "properties": {
              "canonical_label": { "const": "Copy rendered" },
              "surface_label": { "pattern": "^Copy rendered(\\b|$)" },
              "representation_class": { "const": "rendered" },
              "payload_posture": {
                "properties": {
                  "body_posture": { "const": "rendered_view" },
                  "includes_body": { "const": true }
                },
                "required": ["body_posture", "includes_body"]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "action_id": { "const": "copy_escaped" } },
            "required": ["action_id"]
          },
          "then": {
            "properties": {
              "canonical_label": { "const": "Copy escaped" },
              "surface_label": { "pattern": "^Copy escaped(\\b|$)" },
              "representation_class": { "const": "escaped" },
              "payload_posture": {
                "properties": {
                  "body_posture": { "const": "escaped_source_text" },
                  "raw_source_required": { "const": true },
                  "active_content_removed": { "const": false },
                  "includes_body": { "const": true }
                },
                "required": [
                  "body_posture",
                  "raw_source_required",
                  "active_content_removed",
                  "includes_body"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action_id": { "const": "export_sanitized_snapshot" }
            },
            "required": ["action_id"]
          },
          "then": {
            "properties": {
              "canonical_label": { "const": "Export sanitized snapshot" },
              "surface_label": { "pattern": "^Export sanitized snapshot(\\b|$)" },
              "representation_class": { "const": "sanitized_snapshot" },
              "payload_posture": {
                "properties": {
                  "body_posture": { "const": "sanitized_static_snapshot" },
                  "raw_source_required": { "const": false },
                  "active_content_removed": { "const": true },
                  "includes_body": { "const": true }
                },
                "required": [
                  "body_posture",
                  "raw_source_required",
                  "active_content_removed",
                  "includes_body"
                ]
              },
              "required_disclosure_fields": {
                "contains": { "const": "active_content_removed_note" }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "action_id": { "const": "export_metadata_only" } },
            "required": ["action_id"]
          },
          "then": {
            "properties": {
              "canonical_label": { "const": "Export metadata only" },
              "surface_label": { "pattern": "^Export metadata only(\\b|$)" },
              "representation_class": { "const": "metadata_only" },
              "payload_posture": {
                "properties": {
                  "body_posture": { "const": "metadata_only_envelope" },
                  "raw_source_required": { "const": false },
                  "active_content_removed": { "const": false },
                  "includes_body": { "const": false }
                },
                "required": [
                  "body_posture",
                  "raw_source_required",
                  "active_content_removed",
                  "includes_body"
                ]
              },
              "required_disclosure_fields": {
                "contains": { "const": "metadata_only_reason" }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "availability_state": {
                "enum": [
                  "unavailable",
                  "blocked_by_policy",
                  "source_missing",
                  "not_applicable"
                ]
              }
            },
            "required": ["availability_state"]
          },
          "then": {
            "properties": {
              "defaulting_rule": {
                "properties": {
                  "default_state": { "const": "not_available" }
                },
                "required": ["default_state"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "defaulting_rule": {
                "properties": {
                  "default_state": {
                    "enum": [
                      "primary_default",
                      "secondary_available",
                      "fallback_default"
                    ]
                  }
                },
                "required": ["default_state"]
              }
            },
            "required": ["defaulting_rule"]
          },
          "then": {
            "properties": {
              "availability_state": { "const": "available" }
            }
          }
        }
      ]
    }
  }
}
