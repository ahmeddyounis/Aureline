{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/advisory_timeline_entry.schema.json",
  "title": "Aureline advisory history timeline boundary",
  "description": "Boundary schema for advisory_timeline_entry_record and advisory_history_timeline_record frozen in docs/security/advisory_history_and_resolution_contract.md. The timeline contract preserves auditability after incidents by freezing how advisory lifecycle events (draft, published, mitigated, superseded, resolved, withdrawn) remain inspectable across product surfaces, docs/help, support exports, and admin exports. It encodes resolved-state downgrade behavior (prominence may step down but advisories never silently disappear or lose copy-safe IDs) and it requires mirror/offline projections to disclose stale or partial history instead of implying a complete record. Raw exploit payloads, raw reporter identities, raw hostnames/paths, raw signing material, raw evidence bodies, raw URLs, and secret material never cross this boundary; the timeline carries stable IDs, typed vocabulary, and reviewable summaries only. Adding a new enum value is additive-minor and bumps advisory_timeline_schema_version; repurposing an existing value is breaking and requires a governance decision.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/advisory_timeline_entry_record" },
    { "$ref": "#/$defs/advisory_history_timeline_record" }
  ],
  "$defs": {
    "advisory_timeline_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for advisory timeline exports."
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario", "contract_sections"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "contract_sections": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "description": "Optional fixture-only metadata used by worked cases."
    },

    "opaque_id": {
      "$ref": "./emergency_action_record.schema.json#/$defs/opaque_id"
    },
    "monotonic_timestamp": {
      "$ref": "./emergency_action_record.schema.json#/$defs/monotonic_timestamp"
    },
    "reviewable_sentence": {
      "$ref": "./emergency_action_record.schema.json#/$defs/reviewable_sentence"
    },
    "nullable_reviewable_sentence": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/reviewable_sentence" }
      ]
    },

    "advisory_identity": {
      "$ref": "./advisory_identity.schema.json#/$defs/advisory_identity"
    },
    "aureline_advisory_id_string": {
      "$ref": "./advisory_identity.schema.json#/$defs/aureline_advisory_id_string"
    },
    "visibility_class": {
      "$ref": "./advisory_identity.schema.json#/$defs/visibility_class"
    },
    "publication_state_class": {
      "$ref": "./advisory_identity.schema.json#/$defs/publication_state_class"
    },
    "lifecycle_state_class": {
      "$ref": "./advisory_identity.schema.json#/$defs/lifecycle_state_class"
    },

    "mirror_freshness_class": {
      "$ref": "./affected_install_assessment.schema.json#/$defs/mirror_freshness_class"
    },
    "current_mitigation_status_class": {
      "$ref": "./private_triage_workspace_packet.schema.json#/$defs/current_mitigation_status_class"
    },

    "timeline_entry_class": {
      "type": "string",
      "enum": [
        "draft",
        "published",
        "mitigated",
        "superseded",
        "resolved",
        "withdrawn"
      ],
      "description": "Major lifecycle entry kinds frozen by docs/security/advisory_history_and_resolution_contract.md."
    },

    "surface_retention_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product", "docs", "support_export", "admin_export"],
      "properties": {
        "product": { "type": "boolean" },
        "docs": { "type": "boolean" },
        "support_export": { "type": "boolean" },
        "admin_export": { "type": "boolean" }
      },
      "description": "Per-surface retention declaration for one timeline entry."
    },

    "advisory_timeline_entry_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "advisory_timeline_schema_version",
        "record_kind",
        "entry_id",
        "advisory_identity",
        "entry_class",
        "publication_state",
        "visibility_class",
        "lifecycle_state",
        "summary",
        "surface_retention",
        "recorded_at"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "advisory_timeline_schema_version": { "$ref": "#/$defs/advisory_timeline_schema_version" },
        "record_kind": {
          "type": "string",
          "const": "advisory_timeline_entry_record",
          "description": "Discriminator for one advisory timeline entry."
        },
        "entry_id": { "$ref": "#/$defs/opaque_id" },

        "advisory_identity": { "$ref": "#/$defs/advisory_identity" },
        "entry_class": { "$ref": "#/$defs/timeline_entry_class" },

        "publication_state": { "$ref": "#/$defs/publication_state_class" },
        "visibility_class": { "$ref": "#/$defs/visibility_class" },
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state_class" },

        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "surface_retention": { "$ref": "#/$defs/surface_retention_matrix" },

        "superseded_by_advisory_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/aureline_advisory_id_string" }
          ],
          "description": "When entry_class is superseded, the advisory id that superseded this one (if known)."
        },
        "resolved_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/monotonic_timestamp" }
          ]
        },
        "resolved_by_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Opaque ref to the fix/build/postmortem/control that resolved the advisory (when applicable)."
        },
        "note": { "$ref": "#/$defs/nullable_reviewable_sentence" },

        "recorded_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "entry_class": { "const": "superseded" } },
            "required": ["entry_class"]
          },
          "then": {
            "required": ["superseded_by_advisory_id"]
          }
        },
        {
          "if": {
            "properties": { "entry_class": { "const": "resolved" } },
            "required": ["entry_class"]
          },
          "then": {
            "required": ["resolved_at", "resolved_by_ref"]
          }
        }
      ],
      "description": "One advisory history timeline entry. Entries are append-only summaries; they never backdate or mutate in place."
    },

    "history_completeness_class": {
      "type": "string",
      "enum": [
        "complete",
        "partial_missing_prior_entries",
        "partial_stale_cache",
        "unknown"
      ],
      "description": "Whether the timeline snapshot claims complete chronology or admits missing history."
    },

    "advisory_history_timeline_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "advisory_timeline_schema_version",
        "record_kind",
        "timeline_id",
        "advisory_identity",
        "publication_state",
        "visibility_class",
        "lifecycle_state",
        "current_mitigation_status",
        "supersedes_advisory_ids",
        "superseded_by_advisory_id",
        "resolved_at",
        "resolved_by_ref",
        "linked_postmortem_refs",
        "local_continuity_note",
        "mirror_freshness_class",
        "history_completeness_class",
        "history_completeness_note",
        "timeline_entries",
        "minted_at",
        "updated_at"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "advisory_timeline_schema_version": { "$ref": "#/$defs/advisory_timeline_schema_version" },
        "record_kind": {
          "type": "string",
          "const": "advisory_history_timeline_record",
          "description": "Discriminator for one renderable advisory history timeline snapshot."
        },
        "timeline_id": { "$ref": "#/$defs/opaque_id" },

        "advisory_identity": { "$ref": "#/$defs/advisory_identity" },

        "publication_state": { "$ref": "#/$defs/publication_state_class" },
        "visibility_class": { "$ref": "#/$defs/visibility_class" },
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state_class" },
        "current_mitigation_status": { "$ref": "#/$defs/current_mitigation_status_class" },

        "supersedes_advisory_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/aureline_advisory_id_string" }
        },
        "superseded_by_advisory_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/aureline_advisory_id_string" }
          ]
        },
        "resolved_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/monotonic_timestamp" }
          ]
        },
        "resolved_by_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "linked_postmortem_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "description": "Opaque refs to linked postmortem_record ids when a post-incident review exists."
        },
        "local_continuity_note": { "$ref": "#/$defs/reviewable_sentence" },

        "mirror_freshness_class": { "$ref": "#/$defs/mirror_freshness_class" },
        "history_completeness_class": { "$ref": "#/$defs/history_completeness_class" },
        "history_completeness_note": { "$ref": "#/$defs/reviewable_sentence" },

        "timeline_entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/advisory_timeline_entry_record" },
          "description": "Append-only timeline entries retained in this snapshot (may be partial when history_completeness_class is not complete)."
        },

        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "updated_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "description": "A renderable advisory history timeline snapshot: identity, current mitigation linkage, mirror/offline freshness disclosure, and the retained set of timeline entries."
    }
  }
}

