{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/m5-trust-class-ladder.schema.json",
  "title": "Aureline M5 trust-class ladder, downgrade-rule, and compare-only fallback packet",
  "description": "Export-safe packet that makes the runtime trust class of every new M5 preview and embedded surface explicit. Each surface climbs an explicit ladder from raw text to sanitized rich to trusted-local-active or isolated-remote-active. When a requested rung cannot be trusted (policy block, missing isolation runtime, unestablished local trust, suspicious bytes, unresolved raw/rendered divergence, unavailable safe preview, or stale proof), a named downgrade rule degrades the surface to sanitized visibility, a compare-only fallback, or a blocked metadata view -- never silent execution and never opaque failure. Active content never executes outside its declared trust class, embedded/review surfaces never auto-execute, strong-decision surfaces render stricter identity, raw inspection and raw copy stay reachable on every surface, and suspicious bytes are never normalized away. The packet carries only metadata: no raw suspicious bytes, raw rendered trees, raw provider payloads, or credentials cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "case_id",
    "downgraded_surface_count",
    "fallback_kinds",
    "normalization_applied",
    "surfaces",
    "downgrade_rules",
    "trust_review",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "m5_trust_class_ladder_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "case_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "downgraded_surface_count": {
      "type": "integer",
      "minimum": 0
    },
    "fallback_kinds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fallback_mode"
      }
    },
    "normalization_applied": {
      "const": false
    },
    "surfaces": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/surface_projection"
      }
    },
    "downgrade_rules": {
      "type": "array",
      "minItems": 8,
      "items": {
        "$ref": "#/$defs/downgrade_rule"
      }
    },
    "trust_review": {
      "$ref": "#/$defs/trust_review"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "surface": {
      "type": "string",
      "enum": [
        "notebook_rich_output",
        "docs_browser_panel",
        "ai_evidence_viewer",
        "pipeline_artifact_browser",
        "provider_overlay",
        "marketplace_install_review",
        "remote_preview_target",
        "structured_compare_view"
      ]
    },
    "trust_class": {
      "type": "string",
      "enum": [
        "raw_text",
        "sanitized_rich",
        "trusted_local_active",
        "isolated_remote_active",
        "compare_only",
        "blocked"
      ]
    },
    "active_content_posture": {
      "type": "string",
      "enum": [
        "inert_never_executes",
        "trusted_local_execution",
        "isolated_remote_execution",
        "blocked_pending_review"
      ]
    },
    "display_mode": {
      "type": "string",
      "enum": [
        "ordinary_browsing",
        "strong_decision_strict_identity"
      ]
    },
    "fallback_mode": {
      "type": "string",
      "enum": [
        "no_fallback",
        "sanitized_visibility",
        "compare_only",
        "blocked_metadata_only"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "policy_blocked",
        "isolation_runtime_unavailable",
        "local_trust_not_established",
        "raw_rendered_divergence_unresolved",
        "safe_preview_unavailable",
        "suspicious_content_detected",
        "proof_stale",
        "embedded_review_surface"
      ]
    },
    "surface_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "surface_token",
        "subject_ref",
        "display_mode",
        "display_mode_token",
        "requested_trust_class",
        "requested_trust_class_token",
        "effective_trust_class",
        "effective_trust_class_token",
        "trust_class_ladder",
        "active_content_present",
        "active_content_posture",
        "active_content_posture_token",
        "fallback_mode",
        "fallback_mode_token",
        "downgraded",
        "fired_triggers",
        "applied_downgrade_rules",
        "suspicious_annotated",
        "raw_inspection_reachable",
        "raw_copy_reachable",
        "compare_only_fallback_available",
        "rationale"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/surface"
        },
        "surface_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "subject_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "display_mode": {
          "$ref": "#/$defs/display_mode"
        },
        "display_mode_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "requested_trust_class": {
          "$ref": "#/$defs/trust_class"
        },
        "requested_trust_class_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "effective_trust_class": {
          "$ref": "#/$defs/trust_class"
        },
        "effective_trust_class_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "trust_class_ladder": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/trust_class"
          }
        },
        "active_content_present": {
          "type": "boolean"
        },
        "active_content_posture": {
          "$ref": "#/$defs/active_content_posture"
        },
        "active_content_posture_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "fallback_mode": {
          "$ref": "#/$defs/fallback_mode"
        },
        "fallback_mode_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "downgraded": {
          "type": "boolean"
        },
        "fired_triggers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "applied_downgrade_rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "suspicious_annotated": {
          "type": "boolean"
        },
        "raw_inspection_reachable": {
          "const": true
        },
        "raw_copy_reachable": {
          "const": true
        },
        "compare_only_fallback_available": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "trigger",
        "trigger_token",
        "target_fallback",
        "target_fallback_token",
        "applies_to_active_only",
        "rationale"
      ],
      "properties": {
        "rule_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "trigger_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_fallback": {
          "$ref": "#/$defs/fallback_mode"
        },
        "target_fallback_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "applies_to_active_only": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "trust_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "one_shared_policy_library_governs_all_surfaces",
        "active_content_never_executes_outside_declared_class",
        "unsafe_states_degrade_to_sanitized_or_compare_only",
        "downgrade_narrows_instead_of_hiding",
        "raw_inspection_and_copy_always_reachable",
        "suspicious_bytes_never_normalized_away",
        "rendered_never_masquerades_as_raw",
        "no_auto_execute_in_embedded_or_review_surfaces",
        "strong_decision_surfaces_use_strict_identity",
        "compare_only_fallback_available_when_render_untrusted"
      ],
      "properties": {
        "one_shared_policy_library_governs_all_surfaces": {
          "const": true
        },
        "active_content_never_executes_outside_declared_class": {
          "const": true
        },
        "unsafe_states_degrade_to_sanitized_or_compare_only": {
          "const": true
        },
        "downgrade_narrows_instead_of_hiding": {
          "const": true
        },
        "raw_inspection_and_copy_always_reachable": {
          "const": true
        },
        "suspicious_bytes_never_normalized_away": {
          "const": true
        },
        "rendered_never_masquerades_as_raw": {
          "const": true
        },
        "no_auto_execute_in_embedded_or_review_surfaces": {
          "const": true
        },
        "strong_decision_surfaces_use_strict_identity": {
          "const": true
        },
        "compare_only_fallback_available_when_render_untrusted": {
          "const": true
        }
      }
    }
  }
}
