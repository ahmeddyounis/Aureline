{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/secret_handle.schema.json",
  "title": "Aureline secret-broker beta page",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "source_matrix_ref",
    "handle_rows",
    "consumer_audit",
    "defects",
    "summary"
  ],
  "properties": {
    "record_kind": { "const": "security_secret_broker_beta_page_record" },
    "schema_version": { "$ref": "#/$defs/schema_version" },
    "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
    "source_matrix_ref": { "type": "string", "minLength": 1 },
    "handle_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/handle_row" }
    },
    "consumer_audit": {
      "type": "array",
      "items": { "$ref": "#/$defs/consumer_audit_event" }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/defect" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": {
      "type": "string",
      "const": "security:secret_broker_beta:v1"
    },
    "token": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string" },
    "profile": {
      "type": "string",
      "enum": ["connected", "mirror_only", "offline", "enterprise_managed"]
    },
    "vault_adapter": {
      "type": "string",
      "enum": [
        "os_keychain",
        "enterprise_vault_managed",
        "enterprise_vault_self_hosted_mirror",
        "enterprise_vault_air_gapped_snapshot",
        "platform_agent",
        "hsm_or_kms_backed",
        "session_memory_cache",
        "managed_policy_injector"
      ]
    },
    "signature_state": {
      "type": "string",
      "enum": [
        "verified_live",
        "verified_mirror",
        "verified_manual_import",
        "verified_air_gapped",
        "not_required_local_origin"
      ]
    },
    "projection_mode": {
      "type": "string",
      "enum": [
        "alias_only",
        "broker_callback",
        "request_header_signer",
        "ephemeral_fd",
        "bounded_mount",
        "env_var_isolated_child",
        "sign_only",
        "decrypt_only",
        "token_exchange",
        "policy_materialised",
        "inspect_metadata"
      ]
    },
    "reference_mode": {
      "type": "string",
      "enum": ["handle", "session_only", "delegated"]
    },
    "secret_class": {
      "type": "string",
      "enum": [
        "ai_provider_token",
        "code_host_token",
        "package_registry_token",
        "database_credential",
        "ssh_key_material",
        "client_certificate",
        "signing_key_material",
        "provider_session",
        "device_secret",
        "ephemeral_operation_token"
      ]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "live",
        "pending_rotation",
        "expiring",
        "expired",
        "revoked",
        "paused_trust_changed",
        "paused_vault_locked",
        "paused_vault_unavailable"
      ]
    },
    "audit_outcome": {
      "type": "string",
      "enum": [
        "granted_handle",
        "granted_delegated",
        "granted_session_only",
        "denied_by_policy",
        "denied_by_trust_state",
        "denied_by_lifecycle_state",
        "denied_by_missing_approval",
        "denied_by_plaintext_requested",
        "denied_by_silent_in_memory_promotion",
        "denied_by_stale_handle_reuse",
        "denied_by_public_endpoint_fallback",
        "denied_by_expiry",
        "denied_by_revocation"
      ]
    },
    "defect_kind": {
      "type": "string",
      "enum": [
        "raw_secret_material_present",
        "plaintext_persistence_allowed",
        "silent_in_memory_promotion_allowed",
        "stale_handle_reuse_allowed",
        "public_endpoint_fallback_allowed",
        "handle_ref_missing",
        "session_ref_missing",
        "delegated_credential_ref_missing",
        "managed_authority_missing_signature",
        "consumer_audit_missing",
        "consumer_lineage_drift",
        "denied_audit_missing_reason",
        "granted_reference_mode_mismatch",
        "profile_coverage_missing",
        "profile_token_drift",
        "vault_adapter_token_drift",
        "signature_state_token_drift",
        "projection_mode_token_drift",
        "reference_mode_token_drift",
        "secret_class_token_drift",
        "lifecycle_state_token_drift",
        "audit_outcome_token_drift"
      ]
    },
    "consumer_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["consumer_id", "consumer_label", "capability_hash_ref"],
      "properties": {
        "consumer_id": { "$ref": "#/$defs/token" },
        "consumer_label": { "type": "string", "minLength": 1 },
        "capability_hash_ref": { "$ref": "#/$defs/token" }
      }
    },
    "vault_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vault_adapter",
        "vault_adapter_token",
        "adapter_label",
        "vault_entry_ref",
        "signature_state",
        "signature_state_token",
        "signer_id",
        "signed_at",
        "fetched_at",
        "valid_until",
        "signature_blob_ref"
      ],
      "properties": {
        "vault_adapter": { "$ref": "#/$defs/vault_adapter" },
        "vault_adapter_token": { "$ref": "#/$defs/vault_adapter" },
        "adapter_label": { "type": "string", "minLength": 1 },
        "vault_entry_ref": { "type": "string", "minLength": 1 },
        "signature_state": { "$ref": "#/$defs/signature_state" },
        "signature_state_token": { "$ref": "#/$defs/signature_state" },
        "signer_id": { "type": "string" },
        "signed_at": { "$ref": "#/$defs/timestamp" },
        "fetched_at": { "$ref": "#/$defs/timestamp" },
        "valid_until": { "$ref": "#/$defs/timestamp" },
        "signature_blob_ref": { "type": "string" }
      }
    },
    "handle_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "secret_broker_row_id",
        "display_label",
        "profile",
        "profile_token",
        "consumer",
        "target_ref",
        "workspace_scope_ref",
        "secret_class",
        "secret_class_token",
        "reference_mode",
        "reference_mode_token",
        "projection_mode",
        "projection_mode_token",
        "vault_binding",
        "lifecycle_state",
        "lifecycle_state_token",
        "authority_alias_ref",
        "approval_ticket_ref",
        "revocation_path_label",
        "minted_at",
        "raw_secret_material_present",
        "plaintext_persistence_allowed",
        "silent_in_memory_promotion_allowed",
        "stale_handle_reuse_allowed",
        "public_endpoint_fallback_allowed"
      ],
      "properties": {
        "record_kind": {
          "const": "security_secret_broker_beta_handle_row_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "secret_broker_row_id": { "$ref": "#/$defs/token" },
        "display_label": { "type": "string", "minLength": 1 },
        "profile": { "$ref": "#/$defs/profile" },
        "profile_token": { "$ref": "#/$defs/profile" },
        "consumer": { "$ref": "#/$defs/consumer_identity" },
        "target_ref": { "type": "string", "minLength": 1 },
        "workspace_scope_ref": { "type": "string", "minLength": 1 },
        "secret_class": { "$ref": "#/$defs/secret_class" },
        "secret_class_token": { "$ref": "#/$defs/secret_class" },
        "reference_mode": { "$ref": "#/$defs/reference_mode" },
        "reference_mode_token": { "$ref": "#/$defs/reference_mode" },
        "projection_mode": { "$ref": "#/$defs/projection_mode" },
        "projection_mode_token": { "$ref": "#/$defs/projection_mode" },
        "vault_binding": { "$ref": "#/$defs/vault_binding" },
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
        "lifecycle_state_token": { "$ref": "#/$defs/lifecycle_state" },
        "authority_alias_ref": { "type": "string", "minLength": 1 },
        "credential_handle_ref": { "type": "string" },
        "session_ref": { "type": "string" },
        "delegated_credential_ref": { "type": "string" },
        "approval_ticket_ref": { "type": "string", "minLength": 1 },
        "revocation_path_label": { "type": "string", "minLength": 1 },
        "minted_at": { "$ref": "#/$defs/timestamp" },
        "raw_secret_material_present": { "const": false },
        "plaintext_persistence_allowed": { "const": false },
        "silent_in_memory_promotion_allowed": { "const": false },
        "stale_handle_reuse_allowed": { "const": false },
        "public_endpoint_fallback_allowed": { "const": false }
      }
    },
    "consumer_audit_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "audit_event_id",
        "secret_broker_row_ref",
        "profile",
        "profile_token",
        "consumer",
        "target_ref",
        "workspace_scope_ref",
        "secret_class",
        "secret_class_token",
        "projection_mode",
        "projection_mode_token",
        "outcome",
        "outcome_token",
        "requested_at",
        "raw_secret_material_present",
        "raw_handle_id_exposed",
        "no_public_endpoint_fallback"
      ],
      "properties": {
        "record_kind": {
          "const": "security_secret_broker_beta_consumer_audit_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "audit_event_id": { "$ref": "#/$defs/token" },
        "secret_broker_row_ref": { "$ref": "#/$defs/token" },
        "profile": { "$ref": "#/$defs/profile" },
        "profile_token": { "$ref": "#/$defs/profile" },
        "consumer": { "$ref": "#/$defs/consumer_identity" },
        "target_ref": { "type": "string", "minLength": 1 },
        "workspace_scope_ref": { "type": "string", "minLength": 1 },
        "secret_class": { "$ref": "#/$defs/secret_class" },
        "secret_class_token": { "$ref": "#/$defs/secret_class" },
        "projection_mode": { "$ref": "#/$defs/projection_mode" },
        "projection_mode_token": { "$ref": "#/$defs/projection_mode" },
        "outcome": { "$ref": "#/$defs/audit_outcome" },
        "outcome_token": { "$ref": "#/$defs/audit_outcome" },
        "granted_reference_mode": { "$ref": "#/$defs/reference_mode" },
        "granted_reference_mode_token": { "$ref": "#/$defs/reference_mode" },
        "denial_note": { "type": "string" },
        "requested_at": { "$ref": "#/$defs/timestamp" },
        "raw_secret_material_present": { "const": false },
        "raw_handle_id_exposed": { "const": false },
        "no_public_endpoint_fallback": { "const": true }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_kind",
        "defect_kind_token",
        "subject_id",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": { "const": "security_secret_broker_beta_defect_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_kind": { "$ref": "#/$defs/defect_kind" },
        "defect_kind_token": { "$ref": "#/$defs/defect_kind" },
        "subject_id": { "type": "string", "minLength": 1 },
        "field": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_record_kind",
        "record_kind",
        "handle_row_count",
        "consumer_audit_count",
        "profiles_present",
        "vault_adapters_present",
        "reference_modes_present",
        "projection_modes_present",
        "secret_classes_present",
        "lifecycle_states_present",
        "audit_outcomes_present",
        "audit_grants_by_reference_mode",
        "audit_denials_by_outcome",
        "defect_count",
        "defect_counts_by_kind"
      ],
      "properties": {
        "page_record_kind": {
          "const": "security_secret_broker_beta_page_record"
        },
        "record_kind": {
          "const": "security_secret_broker_beta_summary_record"
        },
        "handle_row_count": { "type": "integer", "minimum": 0 },
        "consumer_audit_count": { "type": "integer", "minimum": 0 },
        "profiles_present": { "type": "array", "items": { "$ref": "#/$defs/profile" } },
        "vault_adapters_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/vault_adapter" }
        },
        "reference_modes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/reference_mode" }
        },
        "projection_modes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/projection_mode" }
        },
        "secret_classes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/secret_class" }
        },
        "lifecycle_states_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_state" }
        },
        "audit_outcomes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/audit_outcome" }
        },
        "audit_grants_by_reference_mode": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "audit_denials_by_outcome": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "defect_count": { "type": "integer", "minimum": 0 },
        "defect_counts_by_kind": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
