{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/m5-suspicious-text-detector-parity.schema.json",
  "title": "Aureline M5 shared suspicious-text detector parity packet",
  "description": "Export-safe packet that projects one shared suspicious-content detector run across the new M5 viewer and decision surfaces (notebook output, docs/browser panels, marketplace install/update, remote-host attach, collaboration share, AI evidence viewers, and provider/policy overlays). Every surface shares one threat-class cue vocabulary; raw inspection and a distinctly labeled raw-versus-escaped copy/export path stay reachable wherever a cue materially affects trust; strong-decision surfaces render stricter identity; and a support/admin export preserves the same threat-class cues with escaped exemplars and continuity refs only. Raw suspicious bytes never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "case_id",
    "detector_outcome",
    "finding_classes",
    "threat_classes",
    "source_len_bytes",
    "normalization_applied",
    "surfaces",
    "support_admin_export",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "m5_suspicious_text_detector_parity_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "case_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "detector_outcome": {
      "$ref": "#/$defs/detector_outcome"
    },
    "finding_classes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/content_class"
      }
    },
    "threat_classes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/threat_class"
      }
    },
    "source_len_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "normalization_applied": {
      "const": false
    },
    "surfaces": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "$ref": "#/$defs/surface_projection"
      }
    },
    "support_admin_export": {
      "$ref": "#/$defs/support_admin_export"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "detector_outcome": {
      "type": "string",
      "enum": [
        "allow",
        "sanitize",
        "isolate",
        "block",
        "route_to_system_browser"
      ]
    },
    "content_class": {
      "type": "string",
      "enum": [
        "bidi_control",
        "invisible_formatting",
        "mixed_script_confusable",
        "whole_script_confusable",
        "raw_rendered_divergence"
      ]
    },
    "threat_class": {
      "type": "string",
      "enum": [
        "text_reordering_spoof",
        "hidden_codepoint_smuggling",
        "identity_confusable_spoof",
        "rendered_source_divergence"
      ]
    },
    "threat_severity": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "elevated"
      ]
    },
    "display_mode": {
      "type": "string",
      "enum": [
        "ordinary_browsing",
        "strong_decision_strict_identity"
      ]
    },
    "surface": {
      "type": "string",
      "enum": [
        "notebook_output",
        "docs_browser_panel",
        "marketplace_install_update",
        "remote_host_attach",
        "collaboration_share",
        "ai_evidence_viewer",
        "provider_policy_overlay"
      ]
    },
    "warning_action": {
      "type": "string",
      "enum": [
        "reveal_raw_source",
        "reveal_escaped_source",
        "inspect_codepoints",
        "copy_raw",
        "copy_escaped",
        "export_safe_representation"
      ]
    },
    "threat_cue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "threat_class",
        "threat_class_token",
        "cue_label",
        "cue_detail",
        "severity",
        "materially_affects_trust"
      ],
      "properties": {
        "threat_class": {
          "$ref": "#/$defs/threat_class"
        },
        "threat_class_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "cue_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "cue_detail": {
          "$ref": "#/$defs/non_empty_string"
        },
        "severity": {
          "$ref": "#/$defs/threat_severity"
        },
        "materially_affects_trust": {
          "type": "boolean"
        }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "warning_id",
        "detector_finding_id",
        "content_class",
        "threat_cue",
        "continuity_ref",
        "byte_offset",
        "char_offset",
        "length_chars",
        "matched_codepoints",
        "raw_snippet",
        "escaped_snippet",
        "available_actions"
      ],
      "properties": {
        "warning_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "detector_finding_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "content_class": {
          "$ref": "#/$defs/content_class"
        },
        "threat_cue": {
          "$ref": "#/$defs/threat_cue"
        },
        "continuity_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "byte_offset": {
          "type": "integer",
          "minimum": 0
        },
        "char_offset": {
          "type": "integer",
          "minimum": 0
        },
        "length_chars": {
          "type": "integer",
          "minimum": 0
        },
        "matched_codepoints": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "raw_snippet": {
          "type": "string"
        },
        "escaped_snippet": {
          "type": "string"
        },
        "available_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning_action"
          }
        }
      }
    },
    "transfer_choice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "representation_class",
        "body_posture",
        "label",
        "safe_representation_path",
        "attached_warning_ids"
      ],
      "properties": {
        "action_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "representation_class": {
          "$ref": "#/$defs/non_empty_string"
        },
        "body_posture": {
          "$ref": "#/$defs/non_empty_string"
        },
        "label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "safe_representation_path": {
          "type": "boolean"
        },
        "attached_warning_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "surface_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "surface_token",
        "subject_ref",
        "display_mode",
        "warnings",
        "copy_choices",
        "raw_inspection_reachable"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/surface"
        },
        "surface_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "subject_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "display_mode": {
          "$ref": "#/$defs/display_mode"
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        },
        "copy_choices": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transfer_choice"
          }
        },
        "raw_inspection_reachable": {
          "type": "boolean"
        }
      }
    },
    "threat_cue_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "threat_class",
        "threat_class_token",
        "cue_label",
        "severity",
        "materially_affects_trust",
        "warning_count",
        "surfaces",
        "escaped_exemplar",
        "continuity_refs"
      ],
      "properties": {
        "threat_class": {
          "$ref": "#/$defs/threat_class"
        },
        "threat_class_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "cue_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "severity": {
          "$ref": "#/$defs/threat_severity"
        },
        "materially_affects_trust": {
          "type": "boolean"
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0
        },
        "surfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "escaped_exemplar": {
          "type": "string"
        },
        "continuity_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "support_admin_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "case_id",
        "threat_cue_summaries",
        "surfaces_covered",
        "preserves_cues_without_pane",
        "redaction_class_token"
      ],
      "properties": {
        "record_kind": {
          "const": "m5_suspicious_text_support_admin_export"
        },
        "case_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "threat_cue_summaries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/threat_cue_summary"
          }
        },
        "surfaces_covered": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "preserves_cues_without_pane": {
          "type": "boolean"
        },
        "redaction_class_token": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
