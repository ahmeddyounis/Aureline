{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/audit_stream_record.schema.json",
  "title": "Aureline security audit-stream record",
  "description": "Boundary schema for audit_stream_record entries emitted by security-sensitive product, support, advisory, incident, admin, collaboration, remote, extension, policy, and AI surfaces. Each record links an actor, route, object, target context, decision, policy source, approval-ticket posture, threat classes, evidence refs, redaction class, export posture, evidence-window ref, and explicit field-disposition rows so exports never imply that omitted, redacted, expired, held, or unavailable fields were never recorded. Raw code content, raw secrets, raw tenant names, raw hostnames, raw provider tokens, raw collaborator identifiers, raw terminal bytes, and raw evidence bodies do not cross this boundary; records carry opaque refs, controlled vocabulary, timestamps, and redaction-safe notes only.",
  "$ref": "#/$defs/audit_stream_record",
  "$defs": {
    "audit_stream_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "audit_stream_record"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_timestamp": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/timestamp" }
      ]
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1
    },
    "stream_family": {
      "type": "string",
      "enum": [
        "extension_lifecycle",
        "policy_bundle_change",
        "workspace_trust_change",
        "ai_tool_action",
        "ai_apply_action",
        "collaboration_control_grant",
        "collaboration_control_revocation",
        "remote_session_join",
        "remote_session_leave",
        "advisory_incident_linkage",
        "support_export",
        "emergency_action"
      ]
    },
    "actor_class": {
      "type": "string",
      "enum": [
        "human_user",
        "org_admin",
        "security_operator",
        "support_operator",
        "release_operator",
        "service_identity",
        "policy_service",
        "extension_host",
        "ai_agent",
        "remote_agent",
        "collaboration_participant",
        "provider_actor",
        "system_supervisor",
        "unknown_redacted"
      ]
    },
    "route_class": {
      "type": "string",
      "enum": [
        "local_desktop",
        "cli",
        "headless_runner",
        "remote_agent",
        "managed_service",
        "browser_handoff",
        "provider_callback",
        "companion_client",
        "extension_host",
        "collaboration_relay",
        "offline_import"
      ]
    },
    "origin_class": {
      "type": "string",
      "enum": [
        "desktop_client",
        "cli",
        "headless_runner",
        "remote_target",
        "managed_service",
        "provider",
        "browser",
        "companion_client",
        "extension_host",
        "collaboration_relay"
      ]
    },
    "object_kind": {
      "type": "string",
      "enum": [
        "extension",
        "policy_bundle",
        "workspace_trust_decision",
        "ai_tool_call",
        "ai_apply_patch",
        "collaboration_control_grant",
        "collaboration_session",
        "remote_session",
        "remote_target",
        "advisory",
        "incident_packet",
        "support_export",
        "emergency_action",
        "secret_handle",
        "provider_resource",
        "managed_tenant",
        "release_artifact"
      ]
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "local_workspace",
        "remote_host",
        "container",
        "managed_workspace",
        "collaboration_session",
        "provider_resource",
        "release_channel",
        "policy_bundle",
        "extension_runtime",
        "ai_provider",
        "support_case",
        "tenant_boundary",
        "unknown_redacted"
      ]
    },
    "deployment_profile_class": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud"
      ]
    },
    "decision_type": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "approve",
        "reject",
        "mutate",
        "revoke",
        "expire",
        "quarantine",
        "export",
        "no_op"
      ]
    },
    "decision_outcome": {
      "type": "string",
      "enum": [
        "allowed",
        "denied",
        "applied",
        "blocked",
        "revoked",
        "expired",
        "pending_review",
        "quarantined",
        "captured_offline",
        "failed",
        "partial_success"
      ]
    },
    "policy_source_layer": {
      "type": "string",
      "enum": [
        "embedded_product_defaults",
        "signed_local_admin_bundle",
        "user_workspace_configuration",
        "optional_managed_override",
        "emergency_disable",
        "not_applicable",
        "redacted"
      ]
    },
    "policy_source_freshness": {
      "type": "string",
      "enum": [
        "current",
        "stale_within_grace",
        "stale_past_grace",
        "offline_snapshot_unexpired",
        "offline_snapshot_expired",
        "unknown",
        "not_applicable"
      ]
    },
    "approval_ticket_state": {
      "type": "string",
      "enum": [
        "not_required",
        "present_valid",
        "present_spent",
        "missing",
        "expired",
        "revoked",
        "redacted"
      ]
    },
    "threat_class_id": {
      "type": "string",
      "enum": [
        "credential_theft",
        "supply_chain_compromise",
        "unauthorized_mutation",
        "data_exfiltration",
        "trust_boundary_confusion",
        "provider_spoofing",
        "stale_evidence_misread",
        "unsafe_emergency_action",
        "hostile_collaborator_session_grant_abuse",
        "tenant_isolation_key_management_failure"
      ]
    },
    "evidence_kind": {
      "type": "string",
      "enum": [
        "audit_stream_record",
        "evidence_window",
        "log_slice",
        "metric_slice",
        "trace_slice",
        "incident_timeline_entry",
        "evidence_bundle",
        "approval_ticket",
        "policy_decision",
        "ai_evidence_packet",
        "support_bundle",
        "advisory_record",
        "emergency_action_record",
        "collaboration_archive",
        "remote_session_record"
      ]
    },
    "evidence_embedding_state": {
      "type": "string",
      "enum": [
        "embedded",
        "by_reference",
        "redacted_summary",
        "omitted",
        "metadata_only"
      ]
    },
    "evidence_collection_state": {
      "type": "string",
      "enum": [
        "recorded",
        "redacted",
        "expired",
        "withheld_by_policy",
        "unavailable_source"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "log_safe",
        "support_export_only",
        "evidence_packet_only",
        "release_public",
        "private_triage_only"
      ]
    },
    "export_posture": {
      "type": "string",
      "enum": [
        "not_exported",
        "local_only",
        "support_exportable",
        "admin_exportable",
        "advisory_exportable",
        "postmortem_exportable",
        "reference_only",
        "blocked_by_policy"
      ]
    },
    "export_destination_class": {
      "type": "string",
      "enum": [
        "local_preview",
        "support_bundle",
        "admin_export",
        "advisory_packet",
        "postmortem_packet",
        "mirror_bundle",
        "not_applicable"
      ]
    },
    "field_disposition_class": {
      "type": "string",
      "enum": [
        "recorded_and_present",
        "not_recorded_by_design",
        "omitted_by_redaction",
        "omitted_by_expiry",
        "omitted_by_policy",
        "omitted_by_legal_hold",
        "unavailable_source",
        "outside_platform_scope"
      ]
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_class",
        "actor_ref",
        "acting_for_ref",
        "actor_display_redacted",
        "actor_note"
      ],
      "properties": {
        "actor_class": { "$ref": "#/$defs/actor_class" },
        "actor_ref": { "$ref": "#/$defs/opaque_id" },
        "acting_for_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "actor_display_redacted": { "type": "boolean" },
        "actor_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_class",
        "origin_class",
        "route_ref",
        "browser_handoff_packet_ref",
        "route_note"
      ],
      "properties": {
        "route_class": { "$ref": "#/$defs/route_class" },
        "origin_class": { "$ref": "#/$defs/origin_class" },
        "route_ref": { "$ref": "#/$defs/opaque_id" },
        "browser_handoff_packet_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "route_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_kind",
        "object_ref",
        "object_version_ref",
        "workspace_ref",
        "tenant_ref",
        "object_note"
      ],
      "properties": {
        "object_kind": { "$ref": "#/$defs/object_kind" },
        "object_ref": { "$ref": "#/$defs/opaque_id" },
        "object_version_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "workspace_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "tenant_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "object_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "target_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_kind",
        "target_context_ref",
        "deployment_profile",
        "tenant_scope_ref",
        "region_ref",
        "trust_boundary_ref",
        "target_note"
      ],
      "properties": {
        "target_kind": { "$ref": "#/$defs/target_kind" },
        "target_context_ref": { "$ref": "#/$defs/opaque_id" },
        "deployment_profile": { "$ref": "#/$defs/deployment_profile_class" },
        "tenant_scope_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "region_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "trust_boundary_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "target_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_type",
        "decision_outcome",
        "reason_code",
        "decided_at",
        "consequence_note"
      ],
      "properties": {
        "decision_type": { "$ref": "#/$defs/decision_type" },
        "decision_outcome": { "$ref": "#/$defs/decision_outcome" },
        "reason_code": { "$ref": "#/$defs/opaque_id" },
        "decided_at": { "$ref": "#/$defs/timestamp" },
        "consequence_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "policy_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_layer",
        "policy_ref",
        "policy_epoch",
        "policy_decision_ref",
        "source_freshness",
        "explain_ref"
      ],
      "properties": {
        "source_layer": { "$ref": "#/$defs/policy_source_layer" },
        "policy_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "policy_epoch": { "$ref": "#/$defs/nullable_opaque_id" },
        "policy_decision_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "source_freshness": { "$ref": "#/$defs/policy_source_freshness" },
        "explain_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "approval_ticket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_ticket_state",
        "approval_ticket_ref",
        "issued_at",
        "expires_at",
        "approval_note"
      ],
      "properties": {
        "approval_ticket_state": { "$ref": "#/$defs/approval_ticket_state" },
        "approval_ticket_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "issued_at": { "$ref": "#/$defs/nullable_timestamp" },
        "expires_at": { "$ref": "#/$defs/nullable_timestamp" },
        "approval_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_ref_id",
        "evidence_kind",
        "evidence_window_ref",
        "embedding_state",
        "collection_state",
        "note"
      ],
      "properties": {
        "evidence_ref_id": { "$ref": "#/$defs/opaque_id" },
        "evidence_kind": { "$ref": "#/$defs/evidence_kind" },
        "evidence_window_ref": { "$ref": "#/$defs/opaque_id" },
        "embedding_state": { "$ref": "#/$defs/evidence_embedding_state" },
        "collection_state": { "$ref": "#/$defs/evidence_collection_state" },
        "note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redaction_class",
        "redaction_profile_ref",
        "redacted_field_paths",
        "redaction_note"
      ],
      "properties": {
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "redaction_profile_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "redacted_field_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "redaction_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_posture",
        "destination_class",
        "export_manifest_ref",
        "export_note"
      ],
      "properties": {
        "export_posture": { "$ref": "#/$defs/export_posture" },
        "destination_class": { "$ref": "#/$defs/export_destination_class" },
        "export_manifest_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "export_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "field_disposition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_path",
        "disposition",
        "evidence_window_ref",
        "note"
      ],
      "properties": {
        "field_path": { "type": "string", "minLength": 1 },
        "disposition": { "$ref": "#/$defs/field_disposition_class" },
        "evidence_window_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "absence_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_field_default",
        "requires_disposition_for_export",
        "disposition_count"
      ],
      "properties": {
        "missing_field_default": {
          "type": "string",
          "enum": [
            "unknown_until_field_disposition_present"
          ]
        },
        "requires_disposition_for_export": { "type": "boolean", "const": true },
        "disposition_count": { "type": "integer", "minimum": 1 }
      }
    },
    "linked_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_kind", "record_ref"],
      "properties": {
        "record_kind": { "$ref": "#/$defs/opaque_id" },
        "record_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "audit_stream_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audit_stream_schema_version",
        "record_kind",
        "audit_event_id",
        "event_name",
        "stream_family",
        "emitted_at",
        "actor",
        "route",
        "object",
        "target_context",
        "decision",
        "policy_source",
        "approval_ticket",
        "threat_refs",
        "evidence_refs",
        "evidence_window_ref",
        "redaction",
        "export",
        "field_dispositions",
        "absence_summary",
        "linked_records"
      ],
      "properties": {
        "audit_stream_schema_version": { "$ref": "#/$defs/audit_stream_schema_version" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "audit_event_id": { "$ref": "#/$defs/opaque_id" },
        "event_name": { "$ref": "#/$defs/opaque_id" },
        "stream_family": { "$ref": "#/$defs/stream_family" },
        "emitted_at": { "$ref": "#/$defs/timestamp" },
        "actor": { "$ref": "#/$defs/actor" },
        "route": { "$ref": "#/$defs/route" },
        "object": { "$ref": "#/$defs/object" },
        "target_context": { "$ref": "#/$defs/target_context" },
        "decision": { "$ref": "#/$defs/decision" },
        "policy_source": { "$ref": "#/$defs/policy_source" },
        "approval_ticket": { "$ref": "#/$defs/approval_ticket" },
        "threat_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/threat_class_id" }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence_ref" }
        },
        "evidence_window_ref": { "$ref": "#/$defs/opaque_id" },
        "redaction": { "$ref": "#/$defs/redaction" },
        "export": { "$ref": "#/$defs/export" },
        "field_dispositions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field_disposition" }
        },
        "absence_summary": { "$ref": "#/$defs/absence_summary" },
        "linked_records": {
          "type": "array",
          "items": { "$ref": "#/$defs/linked_record" }
        }
      }
    }
  }
}
