{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/admin_audit_export_beta.schema.json",
  "title": "Aureline admin-audit export beta page",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "source_matrix_ref",
    "provisioning_events",
    "policy_bundle_history",
    "entitlement_changes",
    "defects",
    "summary"
  ],
  "properties": {
    "record_kind": {
      "const": "security_admin_audit_export_beta_page_record"
    },
    "schema_version": {
      "$ref": "#/$defs/schema_version"
    },
    "shared_contract_ref": {
      "$ref": "#/$defs/shared_contract_ref"
    },
    "source_matrix_ref": {
      "type": "string",
      "minLength": 1
    },
    "provisioning_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/provisioning_event"
      }
    },
    "policy_bundle_history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/policy_bundle_history_event"
      }
    },
    "entitlement_changes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entitlement_change_event"
      }
    },
    "defects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/defect"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "security:admin_audit_export_beta:v1"
    },
    "token": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string",
      "enum": [
        "connected",
        "mirror_only",
        "offline",
        "enterprise_managed"
      ]
    },
    "provisioning_source": {
      "type": "string",
      "enum": [
        "scim_managed_endpoint",
        "scim_self_hosted_endpoint",
        "signed_file_import",
        "signed_mirror_import",
        "air_gapped_signed_import",
        "local_advisory_file",
        "runtime_preload_origin"
      ]
    },
    "provisioning_event_class": {
      "type": "string",
      "enum": [
        "user_created",
        "user_updated",
        "user_suspended",
        "user_reactivated",
        "user_deleted",
        "group_created",
        "group_updated",
        "group_deleted",
        "membership_added",
        "membership_removed"
      ]
    },
    "subject_kind": {
      "type": "string",
      "enum": ["user", "group", "membership"]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": ["active", "suspended", "disabled", "deleted"]
    },
    "freshness": {
      "type": "string",
      "enum": ["live", "cached", "stale", "expired", "missing"]
    },
    "bundle_transition": {
      "type": "string",
      "enum": [
        "applied",
        "staged",
        "replaced_by_successor",
        "rolled_back",
        "revoked"
      ]
    },
    "entitlement_change_class": {
      "type": "string",
      "enum": [
        "granted",
        "revoked",
        "scope_narrowed",
        "scope_widened",
        "seat_added",
        "seat_removed",
        "quota_changed",
        "expiry_shortened",
        "expiry_extended"
      ]
    },
    "authority": {
      "type": "string",
      "enum": [
        "allowed",
        "read_only",
        "degraded_preview_only",
        "blocked_pending_trust",
        "blocked_pending_approval",
        "approval_required_per_invocation",
        "policy_denied",
        "quarantine_denied",
        "not_applicable"
      ]
    },
    "defect_kind": {
      "type": "string",
      "enum": [
        "source_token_drift",
        "event_class_token_drift",
        "subject_kind_token_drift",
        "lifecycle_state_token_drift",
        "freshness_token_drift",
        "bundle_transition_token_drift",
        "entitlement_change_token_drift",
        "entitlement_authority_token_drift",
        "managed_source_missing_signature",
        "subject_kind_mismatch",
        "history_transition_missing_predecessor",
        "history_managed_source_missing_signature",
        "entitlement_narrowing_without_managed_source",
        "hidden_public_endpoint_fallback",
        "raw_private_material_exposed",
        "profile_coverage_missing"
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "signer_id",
        "signed_at",
        "fetched_at",
        "valid_until",
        "transport_label",
        "signature_blob_ref"
      ],
      "properties": {
        "source_ref": { "type": "string" },
        "signer_id": { "type": "string" },
        "signed_at": { "$ref": "#/$defs/timestamp" },
        "fetched_at": { "$ref": "#/$defs/timestamp" },
        "valid_until": { "$ref": "#/$defs/timestamp" },
        "transport_label": { "type": "string" },
        "signature_blob_ref": { "type": "string" }
      }
    },
    "provisioning_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "event_id",
        "source_class",
        "source_token",
        "event_class",
        "event_token",
        "subject_kind",
        "subject_kind_token",
        "subject_id",
        "lifecycle_state",
        "lifecycle_state_token",
        "freshness",
        "freshness_token",
        "applied_at",
        "profile_token",
        "provenance",
        "no_public_endpoint_fallback",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "const": "security_admin_audit_export_beta_provisioning_event_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "event_id": { "type": "string", "minLength": 1 },
        "source_class": { "$ref": "#/$defs/provisioning_source" },
        "source_token": { "$ref": "#/$defs/provisioning_source" },
        "event_class": { "$ref": "#/$defs/provisioning_event_class" },
        "event_token": { "$ref": "#/$defs/provisioning_event_class" },
        "subject_kind": { "$ref": "#/$defs/subject_kind" },
        "subject_kind_token": { "$ref": "#/$defs/subject_kind" },
        "subject_id": { "type": "string", "minLength": 1 },
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
        "lifecycle_state_token": { "$ref": "#/$defs/lifecycle_state" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "freshness_token": { "$ref": "#/$defs/freshness" },
        "applied_at": { "$ref": "#/$defs/timestamp" },
        "profile_token": { "$ref": "#/$defs/profile" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "no_public_endpoint_fallback": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" }
      }
    },
    "policy_bundle_history_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "event_id",
        "pack_id",
        "pack_version",
        "replaces_pack_id",
        "transition",
        "transition_token",
        "source_token",
        "signature_state_token",
        "apply_state_token",
        "signer_id",
        "signed_at",
        "applied_at",
        "profile_token",
        "provenance_origin_ref",
        "provenance_signature_blob_ref"
      ],
      "properties": {
        "record_kind": {
          "const": "security_admin_audit_export_beta_policy_bundle_history_event_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "event_id": { "type": "string", "minLength": 1 },
        "pack_id": { "type": "string", "minLength": 1 },
        "pack_version": { "type": "string", "minLength": 1 },
        "replaces_pack_id": { "type": "string" },
        "transition": { "$ref": "#/$defs/bundle_transition" },
        "transition_token": { "$ref": "#/$defs/bundle_transition" },
        "source_token": { "$ref": "#/$defs/token" },
        "signature_state_token": { "$ref": "#/$defs/token" },
        "apply_state_token": { "$ref": "#/$defs/token" },
        "signer_id": { "type": "string" },
        "signed_at": { "$ref": "#/$defs/timestamp" },
        "applied_at": { "$ref": "#/$defs/timestamp" },
        "profile_token": { "$ref": "#/$defs/profile" },
        "provenance_origin_ref": { "type": "string" },
        "provenance_signature_blob_ref": { "type": "string" }
      }
    },
    "entitlement_change_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "event_id",
        "change_class",
        "change_token",
        "entitlement_id",
        "subject_id",
        "before_state",
        "after_state",
        "before_authority",
        "before_authority_token",
        "after_authority",
        "after_authority_token",
        "applied_at",
        "source_token",
        "signer_id",
        "profile_token",
        "explanation"
      ],
      "properties": {
        "record_kind": {
          "const": "security_admin_audit_export_beta_entitlement_change_event_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "event_id": { "type": "string", "minLength": 1 },
        "change_class": { "$ref": "#/$defs/entitlement_change_class" },
        "change_token": { "$ref": "#/$defs/entitlement_change_class" },
        "entitlement_id": { "type": "string", "minLength": 1 },
        "subject_id": { "type": "string", "minLength": 1 },
        "before_state": { "type": "string" },
        "after_state": { "type": "string" },
        "before_authority": { "$ref": "#/$defs/authority" },
        "before_authority_token": { "$ref": "#/$defs/authority" },
        "after_authority": { "$ref": "#/$defs/authority" },
        "after_authority_token": { "$ref": "#/$defs/authority" },
        "applied_at": { "$ref": "#/$defs/timestamp" },
        "source_token": { "$ref": "#/$defs/token" },
        "signer_id": { "type": "string" },
        "profile_token": { "$ref": "#/$defs/profile" },
        "explanation": { "type": "string" }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_kind",
        "defect_kind_token",
        "subject_id",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": {
          "const": "security_admin_audit_export_beta_defect_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_kind": { "$ref": "#/$defs/defect_kind" },
        "defect_kind_token": { "$ref": "#/$defs/defect_kind" },
        "subject_id": { "type": "string" },
        "field": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_record_kind",
        "record_kind",
        "provisioning_event_count",
        "policy_bundle_event_count",
        "entitlement_change_count",
        "profiles_present",
        "provisioning_sources_present",
        "provisioning_event_counts_by_class",
        "lifecycle_states_present",
        "freshness_states_present",
        "policy_bundle_transitions_present",
        "entitlement_changes_by_class",
        "defect_count",
        "defect_counts_by_kind"
      ],
      "properties": {
        "page_record_kind": {
          "const": "security_admin_audit_export_beta_page_record"
        },
        "record_kind": {
          "const": "security_admin_audit_export_beta_summary_record"
        },
        "provisioning_event_count": { "type": "integer", "minimum": 0 },
        "policy_bundle_event_count": { "type": "integer", "minimum": 0 },
        "entitlement_change_count": { "type": "integer", "minimum": 0 },
        "profiles_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/profile" }
        },
        "provisioning_sources_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/provisioning_source" }
        },
        "provisioning_event_counts_by_class": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "lifecycle_states_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_state" }
        },
        "freshness_states_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/freshness" }
        },
        "policy_bundle_transitions_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/bundle_transition" }
        },
        "entitlement_changes_by_class": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "defect_count": { "type": "integer", "minimum": 0 },
        "defect_counts_by_kind": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
