{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/secret_repair_beta.schema.json",
  "title": "Aureline secret-repair beta page",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "source_matrix_ref",
    "lock_state_rows",
    "denied_projection_rows",
    "repair_events",
    "defects",
    "summary"
  ],
  "properties": {
    "record_kind": { "const": "security_secret_repair_beta_page_record" },
    "schema_version": { "$ref": "#/$defs/schema_version" },
    "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
    "source_matrix_ref": { "type": "string", "minLength": 1 },
    "lock_state_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/lock_state_row" }
    },
    "denied_projection_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/denied_projection_row" }
    },
    "repair_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/repair_event" }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/defect" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": {
      "type": "string",
      "const": "security:secret_repair_beta:v1"
    },
    "token": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string" },
    "profile": {
      "type": "string",
      "enum": ["connected", "mirror_only", "offline", "enterprise_managed"]
    },
    "backing_store": {
      "type": "string",
      "enum": [
        "os_keychain",
        "enterprise_vault_managed",
        "enterprise_vault_self_hosted_mirror",
        "enterprise_vault_air_gapped_snapshot",
        "platform_agent",
        "hsm_or_kms_backed",
        "session_memory_cache",
        "managed_policy_injector"
      ]
    },
    "lock_state": {
      "type": "string",
      "enum": [
        "unlocked",
        "locked",
        "biometric_required",
        "user_password_required",
        "hardware_token_required",
        "daemon_unreachable",
        "adapter_misconfigured",
        "vault_snapshot_expired",
        "vault_mirror_outage",
        "policy_blocked"
      ]
    },
    "denial_reason": {
      "type": "string",
      "enum": [
        "backing_store_locked",
        "backing_store_unavailable",
        "backing_store_signature_missing",
        "handle_expired",
        "handle_revoked",
        "lifecycle_state_failed_closed",
        "policy_blocked",
        "plaintext_projection_requested",
        "stale_snapshot",
        "public_endpoint_fallback_requested",
        "missing_approval"
      ]
    },
    "projection_mode": {
      "type": "string",
      "enum": [
        "alias_only",
        "broker_callback",
        "request_header_signer",
        "ephemeral_fd",
        "bounded_mount",
        "env_var_isolated_child",
        "sign_only",
        "decrypt_only",
        "token_exchange",
        "policy_materialised",
        "inspect_metadata"
      ]
    },
    "secret_class": {
      "type": "string",
      "enum": [
        "ai_provider_token",
        "code_host_token",
        "package_registry_token",
        "database_credential",
        "ssh_key_material",
        "client_certificate",
        "signing_key_material",
        "provider_session",
        "device_secret",
        "ephemeral_operation_token"
      ]
    },
    "repair_action": {
      "type": "string",
      "enum": [
        "none_required",
        "prompt_keychain_unlock",
        "prompt_biometric",
        "prompt_user_password",
        "insert_hardware_token",
        "restart_keychain_daemon",
        "restart_credential_agent",
        "reconfigure_vault_adapter",
        "refresh_signed_vault_mirror",
        "import_signed_vault_snapshot",
        "contact_admin_to_unblock_policy",
        "reauth_and_recover_handles",
        "accept_visible_degraded_session_only"
      ]
    },
    "repair_outcome": {
      "type": "string",
      "enum": [
        "awaiting_user",
        "in_progress",
        "resolved",
        "user_declined",
        "failed_transient",
        "failed_permanent"
      ]
    },
    "consumer_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["consumer_id", "consumer_label", "capability_hash_ref"],
      "properties": {
        "consumer_id": { "type": "string", "minLength": 1 },
        "consumer_label": { "type": "string", "minLength": 1 },
        "capability_hash_ref": { "type": "string", "minLength": 1 }
      }
    },
    "lock_state_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "keychain_lock_row_id",
        "display_label",
        "profile",
        "profile_token",
        "backing_store",
        "backing_store_token",
        "adapter_label",
        "store_entry_alias_ref",
        "lock_state",
        "lock_state_token",
        "lock_state_note",
        "lock_state_observed_at",
        "affected_consumer",
        "affected_target_ref",
        "affected_workspace_scope_ref",
        "repair_action",
        "repair_action_token",
        "repair_action_label",
        "repair_action_detail",
        "remediation_path_ref",
        "raw_secret_material_present",
        "plaintext_fallback_attempted",
        "plaintext_fallback_offered",
        "local_editing_preserved"
      ],
      "properties": {
        "record_kind": {
          "const": "security_secret_repair_beta_lock_state_row_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "keychain_lock_row_id": { "type": "string", "minLength": 1 },
        "display_label": { "type": "string", "minLength": 1 },
        "profile": { "$ref": "#/$defs/profile" },
        "profile_token": { "$ref": "#/$defs/token" },
        "backing_store": { "$ref": "#/$defs/backing_store" },
        "backing_store_token": { "$ref": "#/$defs/token" },
        "adapter_label": { "type": "string", "minLength": 1 },
        "store_entry_alias_ref": { "type": "string", "minLength": 1 },
        "lock_state": { "$ref": "#/$defs/lock_state" },
        "lock_state_token": { "$ref": "#/$defs/token" },
        "lock_state_note": { "type": "string" },
        "lock_state_observed_at": { "$ref": "#/$defs/timestamp" },
        "affected_consumer": { "$ref": "#/$defs/consumer_identity" },
        "affected_target_ref": { "type": "string", "minLength": 1 },
        "affected_workspace_scope_ref": { "type": "string", "minLength": 1 },
        "affected_secret_broker_row_ref": { "type": "string" },
        "repair_action": { "$ref": "#/$defs/repair_action" },
        "repair_action_token": { "$ref": "#/$defs/token" },
        "repair_action_label": { "type": "string" },
        "repair_action_detail": { "type": "string" },
        "remediation_path_ref": { "type": "string" },
        "raw_secret_material_present": { "type": "boolean" },
        "plaintext_fallback_attempted": { "type": "boolean" },
        "plaintext_fallback_offered": { "type": "boolean" },
        "local_editing_preserved": { "type": "boolean" }
      }
    },
    "denied_projection_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "denied_projection_row_id",
        "display_label",
        "profile",
        "profile_token",
        "blocked_consumer",
        "blocked_target_ref",
        "blocked_workspace_scope_ref",
        "requested_secret_class",
        "requested_secret_class_token",
        "requested_projection_mode",
        "requested_projection_mode_token",
        "denial_reason",
        "denial_reason_token",
        "denial_note",
        "required_repair_action",
        "required_repair_action_token",
        "remediation_path_label",
        "remediation_path_ref",
        "observed_at",
        "raw_secret_material_present",
        "plaintext_fallback_offered",
        "public_endpoint_fallback_offered",
        "local_editing_preserved"
      ],
      "properties": {
        "record_kind": {
          "const": "security_secret_repair_beta_denied_projection_row_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "denied_projection_row_id": { "type": "string", "minLength": 1 },
        "display_label": { "type": "string", "minLength": 1 },
        "profile": { "$ref": "#/$defs/profile" },
        "profile_token": { "$ref": "#/$defs/token" },
        "blocked_consumer": { "$ref": "#/$defs/consumer_identity" },
        "blocked_target_ref": { "type": "string", "minLength": 1 },
        "blocked_workspace_scope_ref": { "type": "string", "minLength": 1 },
        "requested_secret_class": { "$ref": "#/$defs/secret_class" },
        "requested_secret_class_token": { "$ref": "#/$defs/token" },
        "requested_projection_mode": { "$ref": "#/$defs/projection_mode" },
        "requested_projection_mode_token": { "$ref": "#/$defs/token" },
        "denial_reason": { "$ref": "#/$defs/denial_reason" },
        "denial_reason_token": { "$ref": "#/$defs/token" },
        "denial_note": { "type": "string" },
        "linked_lock_state_row_ref": { "type": "string" },
        "linked_secret_broker_row_ref": { "type": "string" },
        "required_repair_action": { "$ref": "#/$defs/repair_action" },
        "required_repair_action_token": { "$ref": "#/$defs/token" },
        "remediation_path_label": { "type": "string" },
        "remediation_path_ref": { "type": "string" },
        "observed_at": { "$ref": "#/$defs/timestamp" },
        "raw_secret_material_present": { "type": "boolean" },
        "plaintext_fallback_offered": { "type": "boolean" },
        "public_endpoint_fallback_offered": { "type": "boolean" },
        "local_editing_preserved": { "type": "boolean" }
      }
    },
    "repair_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "repair_event_id",
        "profile",
        "profile_token",
        "consumer",
        "target_ref",
        "workspace_scope_ref",
        "repair_action",
        "repair_action_token",
        "outcome",
        "outcome_token",
        "repair_note",
        "requested_at",
        "raw_secret_material_present",
        "plaintext_fallback_taken"
      ],
      "properties": {
        "record_kind": {
          "const": "security_secret_repair_beta_repair_event_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "repair_event_id": { "type": "string", "minLength": 1 },
        "profile": { "$ref": "#/$defs/profile" },
        "profile_token": { "$ref": "#/$defs/token" },
        "keychain_lock_row_ref": { "type": "string" },
        "denied_projection_row_ref": { "type": "string" },
        "consumer": { "$ref": "#/$defs/consumer_identity" },
        "target_ref": { "type": "string", "minLength": 1 },
        "workspace_scope_ref": { "type": "string", "minLength": 1 },
        "repair_action": { "$ref": "#/$defs/repair_action" },
        "repair_action_token": { "$ref": "#/$defs/token" },
        "outcome": { "$ref": "#/$defs/repair_outcome" },
        "outcome_token": { "$ref": "#/$defs/token" },
        "repair_note": { "type": "string" },
        "requested_at": { "$ref": "#/$defs/timestamp" },
        "resolved_at": { "type": "string" },
        "raw_secret_material_present": { "type": "boolean" },
        "plaintext_fallback_taken": { "type": "boolean" }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_kind",
        "defect_kind_token",
        "subject_id",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": {
          "const": "security_secret_repair_beta_defect_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_kind": {
          "type": "string",
          "enum": [
            "raw_secret_material_present",
            "plaintext_fallback_attempted",
            "plaintext_fallback_offered",
            "plaintext_fallback_taken",
            "public_endpoint_fallback_offered",
            "local_editing_not_preserved",
            "repair_action_missing",
            "unexpected_repair_action_on_unlocked",
            "remediation_path_missing",
            "blocked_consumer_missing",
            "linked_lock_state_missing",
            "linked_lock_state_ref_unknown",
            "linked_row_ref_unknown",
            "repair_event_unlinked",
            "terminal_repair_outcome_missing_resolved_at",
            "open_repair_outcome_unexpected_resolved_at",
            "profile_coverage_missing",
            "profile_token_drift",
            "backing_store_token_drift",
            "lock_state_token_drift",
            "repair_action_token_drift",
            "denial_reason_token_drift",
            "secret_class_token_drift",
            "projection_mode_token_drift",
            "outcome_token_drift"
          ]
        },
        "defect_kind_token": { "$ref": "#/$defs/token" },
        "subject_id": { "type": "string" },
        "field": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_record_kind",
        "record_kind",
        "lock_state_row_count",
        "denied_projection_row_count",
        "repair_event_count",
        "profiles_present",
        "backing_stores_present",
        "lock_states_present",
        "denial_reasons_present",
        "repair_actions_present",
        "repair_outcomes_present",
        "repair_events_by_outcome",
        "denials_by_reason",
        "defect_count",
        "defect_counts_by_kind"
      ],
      "properties": {
        "page_record_kind": {
          "const": "security_secret_repair_beta_page_record"
        },
        "record_kind": {
          "const": "security_secret_repair_beta_summary_record"
        },
        "lock_state_row_count": { "type": "integer", "minimum": 0 },
        "denied_projection_row_count": { "type": "integer", "minimum": 0 },
        "repair_event_count": { "type": "integer", "minimum": 0 },
        "profiles_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/token" }
        },
        "backing_stores_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/token" }
        },
        "lock_states_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/token" }
        },
        "denial_reasons_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/token" }
        },
        "repair_actions_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/token" }
        },
        "repair_outcomes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/token" }
        },
        "repair_events_by_outcome": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "denials_by_reason": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "defect_count": { "type": "integer", "minimum": 0 },
        "defect_counts_by_kind": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
