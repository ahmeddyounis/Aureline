{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/m5-content-integrity-certification.schema.json",
  "title": "Aureline M5 content-integrity, safe-preview, and representation-honesty certification",
  "description": "Export-safe certification packet that binds the per-dimension M5 content-safety proofs (suspicious-content cues, safe-preview trust classes, strong-decision strict-identity display, raw-versus-rendered copy/export, active-content containment, and silent-rewrite guard) to every claimed M5 artifact/viewer family and auto-narrows any family that lacks a current proof on a required dimension. Raw suspicious bytes, raw rendered trees, raw provider payloads, credentials, and live preview-origin responses never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "certification_label",
    "family_rows",
    "summary",
    "review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "certify_m5_content_integrity_safe_preview_and_representation_honesty"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "certification_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "family_rows": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "$ref": "#/$defs/family_row"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "review": {
      "$ref": "#/$defs/review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "family": {
      "type": "string",
      "enum": [
        "notebook_rich_output",
        "docs_browser_panel",
        "ai_evidence_viewer",
        "pipeline_artifact_browser",
        "provider_overlay",
        "marketplace_install_update",
        "remote_preview_target",
        "incident_export_packet",
        "generated_artifact",
        "structured_compare_view"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "proof_dimension": {
      "type": "string",
      "enum": [
        "suspicious_content_cues",
        "safe_preview_trust_class",
        "strong_decision_display",
        "raw_rendered_copy_export",
        "active_content_containment",
        "silent_rewrite_guard"
      ]
    },
    "proof_lane": {
      "type": "string",
      "enum": [
        "suspicious_text_parity",
        "safe_preview_limited_mode",
        "trust_class_ladder",
        "trust_decision_identity",
        "raw_rendered_handoff",
        "mutation_path_fix_flow",
        "content_integrity_matrix"
      ]
    },
    "proof_state": {
      "type": "string",
      "enum": [
        "current_pass",
        "stale_pass",
        "failing",
        "missing",
        "not_applicable"
      ]
    },
    "applicability": {
      "type": "string",
      "enum": [
        "required",
        "not_applicable"
      ]
    },
    "narrowing_cause": {
      "type": "string",
      "enum": [
        "proof_missing",
        "proof_stale",
        "proof_failing"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "notebook_viewer",
        "docs_browser_panel",
        "ai_evidence_viewer",
        "pipeline_artifact_browser",
        "provider_overlay",
        "marketplace_surface",
        "remote_preview_panel",
        "incident_export",
        "structured_compare_view",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "dimension_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension",
        "backing_lane",
        "backing_packet_ref",
        "applicability",
        "state",
        "note"
      ],
      "properties": {
        "dimension": {
          "$ref": "#/$defs/proof_dimension"
        },
        "backing_lane": {
          "$ref": "#/$defs/proof_lane"
        },
        "backing_packet_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "applicability": {
          "$ref": "#/$defs/applicability"
        },
        "state": {
          "$ref": "#/$defs/proof_state"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "narrowing_reason": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension",
        "cause",
        "detail"
      ],
      "properties": {
        "dimension": {
          "$ref": "#/$defs/proof_dimension"
        },
        "cause": {
          "$ref": "#/$defs/narrowing_cause"
        },
        "detail": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "family_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "claimed_qualification",
        "certified_qualification",
        "dimension_proofs",
        "narrowing_reasons",
        "proof_refs",
        "consumer_surfaces"
      ],
      "properties": {
        "family": {
          "$ref": "#/$defs/family"
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "certified_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "dimension_proofs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dimension_proof"
          }
        },
        "narrowing_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/narrowing_reason"
          }
        },
        "proof_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/consumer_surface"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_families",
        "certified_stable",
        "narrowed_families"
      ],
      "properties": {
        "total_families": {
          "type": "integer",
          "minimum": 0
        },
        "certified_stable": {
          "type": "integer",
          "minimum": 0
        },
        "narrowed_families": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_dimensions_certified_together",
        "auto_narrow_on_missing_or_stale_proof",
        "strong_decision_families_certify_strict_identity",
        "downgrade_narrows_instead_of_hides",
        "regression_or_missing_coverage_blocks_promotion",
        "suspicious_bytes_not_normalized_away",
        "no_auto_execute_to_earn_proof"
      ],
      "properties": {
        "all_dimensions_certified_together": {
          "const": true
        },
        "auto_narrow_on_missing_or_stale_proof": {
          "const": true
        },
        "strong_decision_families_certify_strict_identity": {
          "const": true
        },
        "downgrade_narrows_instead_of_hides": {
          "const": true
        },
        "regression_or_missing_coverage_blocks_promotion": {
          "const": true
        },
        "suspicious_bytes_not_normalized_away": {
          "const": true
        },
        "no_auto_execute_to_earn_proof": {
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shiproom_ingests_certification",
        "docs_ingest_certification",
        "support_export_ingests_certification",
        "cli_headless_shows_certification",
        "diagnostics_shows_certification",
        "narrowed_families_visibly_labeled"
      ],
      "properties": {
        "shiproom_ingests_certification": {
          "const": true
        },
        "docs_ingest_certification": {
          "const": true
        },
        "support_export_ingests_certification": {
          "const": true
        },
        "cli_headless_shows_certification": {
          "const": true
        },
        "diagnostics_shows_certification": {
          "const": true
        },
        "narrowed_families_visibly_labeled": {
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_certified_at",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_certified_at": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "const": true
        }
      }
    }
  }
}
