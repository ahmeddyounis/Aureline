{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/runtime_authority_issuer.schema.json",
  "title": "Aureline runtime authority issuer boundary page",
  "description": "Boundary schema for the runtime-authority issuer projection owned by the aureline-policy runtime_authority_issuers module. The page binds issuer registration, requesting-surface registration, remembered-decision rules, issuer-boundary requests, and issuer-boundary decisions so that AI, extensions, recipes, CLI scripts, browser companions, remote helpers, admin consoles, automation schedulers, and local admin tools can request authority but never mint or refresh it on their own. Lineage packets preserve issuer chain, actor class, and authority-source class without raw credentials, raw policy payloads, or plaintext secret material.",
  "oneOf": [
    { "$ref": "#/$defs/runtime_authority_issuer_page" },
    { "$ref": "#/$defs/runtime_authority_lineage_packet" },
    { "$ref": "#/$defs/issuer_record" },
    { "$ref": "#/$defs/requesting_surface" },
    { "$ref": "#/$defs/boundary_request" },
    { "$ref": "#/$defs/boundary_decision" },
    { "$ref": "#/$defs/defect" },
    { "$ref": "#/$defs/summary" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": {
      "type": "string",
      "const": "security:runtime_authority_issuer_beta:v1"
    },
    "source_matrix_ref": {
      "type": "string",
      "const": "artifacts/security/m3/runtime_authority_lineage_packet.md"
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable ref safe for logs, audit rows, support exports, and fixture manifests."
    },
    "label": {
      "type": "string",
      "minLength": 1,
      "description": "Reviewable label that contains no secret bytes or raw external payloads."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "issuer_class": {
      "type": "string",
      "enum": ["shell", "policy_service", "supervisor"]
    },
    "ticket_class": {
      "type": "string",
      "enum": [
        "local_mutation",
        "external_provider_mutation",
        "credential_projection",
        "privileged_debug_attach",
        "policy_trust_admin_change"
      ]
    },
    "requesting_surface_class": {
      "type": "string",
      "enum": [
        "admin_console",
        "local_admin_tool",
        "ai_tool",
        "extension",
        "recipe_runner",
        "cli_script",
        "browser_companion",
        "remote_helper",
        "automation_scheduler"
      ]
    },
    "actor_class": {
      "type": "string",
      "enum": [
        "human_account",
        "local_admin",
        "organization_admin",
        "installation_or_app_grant",
        "delegated_credential",
        "policy_injected_service_identity",
        "local_only_authority"
      ]
    },
    "target_class": {
      "type": "string",
      "enum": [
        "local_workspace",
        "provider_object",
        "credential_consumer",
        "debug_attach_target",
        "trust_store",
        "policy_admin_object"
      ]
    },
    "authority_source_class": {
      "type": "string",
      "enum": [
        "human_account",
        "installation_grant",
        "delegated_credential",
        "local_only_authority"
      ]
    },
    "decision_class": {
      "type": "string",
      "enum": [
        "granted",
        "remembered_decision_narrowed",
        "refused"
      ]
    },
    "rejection_reason": {
      "type": "string",
      "enum": [
        "self_authorization_by_non_issuer",
        "ambient_privilege_inferred",
        "missing_issuer_binding",
        "issuer_not_allowed_for_surface",
        "remembered_decision_missing",
        "remembered_decision_too_broad",
        "remembered_decision_lifetime_exceeds_budget",
        "remembered_decision_forbidden_class",
        "remembered_decision_target_drift",
        "remembered_decision_actor_drift",
        "authority_source_mismatch",
        "authority_source_unreachable_target",
        "policy_epoch_drift",
        "sandbox_binding_drift",
        "root_authority_proof_missing"
      ]
    },
    "defect_kind": {
      "type": "string",
      "enum": [
        "record_shape_drift",
        "token_drift",
        "issuer_not_allowed",
        "issuer_overreach",
        "unauthorized_root_authority_claim",
        "requesting_surface_missing_issuer",
        "requesting_surface_issuer_not_found",
        "remembered_rule_not_narrow",
        "remembered_rule_lifetime_exceeds_budget",
        "remembered_rule_forbidden_class",
        "admitted_self_authorization",
        "admitted_ambient_privilege",
        "request_routed_through_forbidden_issuer",
        "decision_admitted_without_chain",
        "refused_decision_missing_reason",
        "decision_admitted_on_source_mismatch",
        "decision_admitted_beyond_rule_expiry",
        "decision_dropped_recovery_guidance",
        "requesting_surface_coverage_missing",
        "rejection_reason_coverage_missing",
        "lineage_packet_drifted_from_page"
      ]
    },
    "target_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_class",
        "target_class_token",
        "target_ref",
        "target_label",
        "target_fingerprint_ref"
      ],
      "properties": {
        "target_class": { "$ref": "#/$defs/target_class" },
        "target_class_token": { "$ref": "#/$defs/target_class" },
        "target_ref": { "$ref": "#/$defs/opaque_ref" },
        "target_label": { "$ref": "#/$defs/label" },
        "target_fingerprint_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "sandbox_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sandbox_profile_ref",
        "sandbox_profile_fingerprint_ref",
        "capability_envelope_ref",
        "policy_epoch_ref"
      ],
      "properties": {
        "sandbox_profile_ref": { "$ref": "#/$defs/opaque_ref" },
        "sandbox_profile_fingerprint_ref": { "$ref": "#/$defs/opaque_ref" },
        "capability_envelope_ref": { "$ref": "#/$defs/opaque_ref" },
        "policy_epoch_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "issuer_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "issuer_id",
        "display_label",
        "issuer_class",
        "issuer_class_token",
        "issuing_surface_ref",
        "mintable_ticket_classes",
        "mintable_ticket_class_tokens",
        "allowed_requesting_surfaces",
        "allowed_requesting_surface_tokens",
        "attestable_authority_sources",
        "attestable_authority_source_tokens",
        "may_mint_root_authority_changes",
        "audit_event_refs"
      ],
      "properties": {
        "record_kind": { "const": "security_runtime_authority_issuer_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "issuer_id": { "$ref": "#/$defs/opaque_ref" },
        "display_label": { "$ref": "#/$defs/label" },
        "issuer_class": { "$ref": "#/$defs/issuer_class" },
        "issuer_class_token": { "$ref": "#/$defs/issuer_class" },
        "issuing_surface_ref": { "$ref": "#/$defs/opaque_ref" },
        "mintable_ticket_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/ticket_class" }
        },
        "mintable_ticket_class_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/ticket_class" }
        },
        "allowed_requesting_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/requesting_surface_class" }
        },
        "allowed_requesting_surface_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/requesting_surface_class" }
        },
        "attestable_authority_sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/authority_source_class" }
        },
        "attestable_authority_source_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/authority_source_class" }
        },
        "may_mint_root_authority_changes": { "type": "boolean" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        }
      }
    },
    "requesting_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "surface_id",
        "display_label",
        "surface_class",
        "surface_class_token",
        "surface_ref",
        "allowed_issuer_ids",
        "usage_note"
      ],
      "properties": {
        "record_kind": { "const": "security_runtime_requesting_surface_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "surface_id": { "$ref": "#/$defs/opaque_ref" },
        "display_label": { "$ref": "#/$defs/label" },
        "surface_class": { "$ref": "#/$defs/requesting_surface_class" },
        "surface_class_token": { "$ref": "#/$defs/requesting_surface_class" },
        "surface_ref": { "$ref": "#/$defs/opaque_ref" },
        "allowed_issuer_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "minItems": 1
        },
        "usage_note": { "$ref": "#/$defs/label" }
      }
    },
    "remembered_decision_rule": {
      "$ref": "https://aureline.dev/schemas/security/remembered_decision_rule.schema.json"
    },
    "boundary_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "request_id",
        "display_label",
        "requesting_surface_id",
        "requesting_surface_class",
        "requesting_surface_class_token",
        "requesting_surface_ref",
        "routed_issuer_id",
        "requested_ticket_class",
        "requested_ticket_class_token",
        "actor_class",
        "actor_class_token",
        "actor_subject_ref",
        "authority_source_class",
        "authority_source_class_token",
        "authority_source_ref",
        "requested_target_identity",
        "requested_sandbox_binding",
        "claims_self_authorization",
        "claims_ambient_privilege",
        "root_authority_proof_present",
        "requested_at",
        "audit_event_refs"
      ],
      "properties": {
        "record_kind": { "const": "security_issuer_boundary_request_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "request_id": { "$ref": "#/$defs/opaque_ref" },
        "display_label": { "$ref": "#/$defs/label" },
        "requesting_surface_id": { "$ref": "#/$defs/opaque_ref" },
        "requesting_surface_class": { "$ref": "#/$defs/requesting_surface_class" },
        "requesting_surface_class_token": { "$ref": "#/$defs/requesting_surface_class" },
        "requesting_surface_ref": { "$ref": "#/$defs/opaque_ref" },
        "routed_issuer_id": {
          "type": "string",
          "description": "Opaque issuer id, or empty when the request attempted to self-authorize."
        },
        "requested_ticket_class": { "$ref": "#/$defs/ticket_class" },
        "requested_ticket_class_token": { "$ref": "#/$defs/ticket_class" },
        "remembered_rule_id": { "$ref": "#/$defs/opaque_ref" },
        "actor_class": { "$ref": "#/$defs/actor_class" },
        "actor_class_token": { "$ref": "#/$defs/actor_class" },
        "actor_subject_ref": { "$ref": "#/$defs/opaque_ref" },
        "authority_source_class": { "$ref": "#/$defs/authority_source_class" },
        "authority_source_class_token": { "$ref": "#/$defs/authority_source_class" },
        "authority_source_ref": { "$ref": "#/$defs/opaque_ref" },
        "requested_target_identity": { "$ref": "#/$defs/target_identity" },
        "requested_sandbox_binding": { "$ref": "#/$defs/sandbox_binding" },
        "claims_self_authorization": { "type": "boolean" },
        "claims_ambient_privilege": { "type": "boolean" },
        "root_authority_proof_present": { "type": "boolean" },
        "requested_at": { "$ref": "#/$defs/timestamp" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        }
      }
    },
    "boundary_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "decision_id",
        "request_id",
        "decision_class",
        "decision_class_token",
        "rejection_reasons",
        "rejection_reason_tokens",
        "actor_class",
        "actor_class_token",
        "authority_source_class",
        "authority_source_class_token",
        "issuer_class",
        "issuer_class_token",
        "explanation",
        "local_editing_preserved",
        "reprompt_required",
        "decided_at",
        "audit_event_refs"
      ],
      "properties": {
        "record_kind": { "const": "security_issuer_boundary_decision_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "decision_id": { "$ref": "#/$defs/opaque_ref" },
        "request_id": { "$ref": "#/$defs/opaque_ref" },
        "decision_class": { "$ref": "#/$defs/decision_class" },
        "decision_class_token": { "$ref": "#/$defs/decision_class" },
        "minted_authority_ticket_ref": { "$ref": "#/$defs/opaque_ref" },
        "renewed_from_rule_id": { "$ref": "#/$defs/opaque_ref" },
        "rejection_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/rejection_reason" }
        },
        "rejection_reason_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/rejection_reason" }
        },
        "actor_class": { "$ref": "#/$defs/actor_class" },
        "actor_class_token": { "$ref": "#/$defs/actor_class" },
        "authority_source_class": { "$ref": "#/$defs/authority_source_class" },
        "authority_source_class_token": { "$ref": "#/$defs/authority_source_class" },
        "issuer_class": { "$ref": "#/$defs/issuer_class" },
        "issuer_class_token": { "$ref": "#/$defs/issuer_class" },
        "explanation": { "$ref": "#/$defs/label" },
        "local_editing_preserved": { "type": "boolean" },
        "reprompt_required": { "type": "boolean" },
        "decided_at": { "$ref": "#/$defs/timestamp" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_kind",
        "defect_kind_token",
        "subject_id",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": { "const": "security_runtime_authority_issuer_defect_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_kind": { "$ref": "#/$defs/defect_kind" },
        "defect_kind_token": { "$ref": "#/$defs/defect_kind" },
        "subject_id": { "$ref": "#/$defs/opaque_ref" },
        "field": { "$ref": "#/$defs/opaque_ref" },
        "note": { "$ref": "#/$defs/label" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "issuer_count",
        "requesting_surface_count",
        "remembered_rule_count",
        "request_count",
        "decision_count",
        "requesting_surface_classes_present",
        "authority_source_classes_present",
        "decisions_by_class",
        "rejection_reasons_present",
        "defect_count",
        "defect_counts_by_kind"
      ],
      "properties": {
        "record_kind": { "const": "security_runtime_authority_issuer_summary_record" },
        "issuer_count": { "type": "integer", "minimum": 0 },
        "requesting_surface_count": { "type": "integer", "minimum": 0 },
        "remembered_rule_count": { "type": "integer", "minimum": 0 },
        "request_count": { "type": "integer", "minimum": 0 },
        "decision_count": { "type": "integer", "minimum": 0 },
        "requesting_surface_classes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/requesting_surface_class" }
        },
        "authority_source_classes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/authority_source_class" }
        },
        "decisions_by_class": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "rejection_reasons_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/rejection_reason" }
        },
        "defect_count": { "type": "integer", "minimum": 0 },
        "defect_counts_by_kind": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "runtime_authority_issuer_page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "source_matrix_ref",
        "issuers",
        "requesting_surfaces",
        "remembered_rules",
        "requests",
        "decisions",
        "defects",
        "summary"
      ],
      "properties": {
        "record_kind": { "const": "security_runtime_authority_issuer_page_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "source_matrix_ref": { "$ref": "#/$defs/source_matrix_ref" },
        "issuers": {
          "type": "array",
          "items": { "$ref": "#/$defs/issuer_record" }
        },
        "requesting_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/requesting_surface" }
        },
        "remembered_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/remembered_decision_rule" }
        },
        "requests": {
          "type": "array",
          "items": { "$ref": "#/$defs/boundary_request" }
        },
        "decisions": {
          "type": "array",
          "items": { "$ref": "#/$defs/boundary_decision" }
        },
        "defects": {
          "type": "array",
          "items": { "$ref": "#/$defs/defect" }
        },
        "summary": { "$ref": "#/$defs/summary" }
      }
    },
    "runtime_authority_lineage_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "request_id",
        "requesting_surface_class_token",
        "requesting_surface_ref",
        "issuer_class_token",
        "requested_ticket_class_token",
        "actor_class_token",
        "authority_source_class_token",
        "decision_class_token",
        "rejection_reason_tokens",
        "explanation",
        "decided_at",
        "audit_event_refs"
      ],
      "properties": {
        "decision_id": { "$ref": "#/$defs/opaque_ref" },
        "request_id": { "$ref": "#/$defs/opaque_ref" },
        "requesting_surface_class_token": { "$ref": "#/$defs/requesting_surface_class" },
        "requesting_surface_ref": { "$ref": "#/$defs/opaque_ref" },
        "issuer_class_token": { "$ref": "#/$defs/issuer_class" },
        "requested_ticket_class_token": { "$ref": "#/$defs/ticket_class" },
        "actor_class_token": { "$ref": "#/$defs/actor_class" },
        "authority_source_class_token": { "$ref": "#/$defs/authority_source_class" },
        "decision_class_token": { "$ref": "#/$defs/decision_class" },
        "rejection_reason_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/rejection_reason" }
        },
        "minted_authority_ticket_ref": { "$ref": "#/$defs/opaque_ref" },
        "renewed_from_rule_id": { "$ref": "#/$defs/opaque_ref" },
        "explanation": { "$ref": "#/$defs/label" },
        "decided_at": { "$ref": "#/$defs/timestamp" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        }
      }
    },
    "runtime_authority_lineage_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "packet_id",
        "display_label",
        "generated_at",
        "lineage_rows",
        "rejection_reason_counts",
        "raw_credentials_excluded",
        "provider_versus_local_distinguished",
        "redaction_summary"
      ],
      "properties": {
        "record_kind": { "const": "security_runtime_authority_lineage_packet_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "packet_id": { "$ref": "#/$defs/opaque_ref" },
        "display_label": { "$ref": "#/$defs/label" },
        "generated_at": { "$ref": "#/$defs/timestamp" },
        "lineage_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtime_authority_lineage_row" }
        },
        "rejection_reason_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "raw_credentials_excluded": { "type": "boolean" },
        "provider_versus_local_distinguished": { "type": "boolean" },
        "redaction_summary": { "$ref": "#/$defs/label" }
      }
    }
  }
}
