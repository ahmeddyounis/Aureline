{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/text_representation_policy.schema.json",
  "title": "Aureline text representation transfer policy",
  "description": "Boundary schema for the representation-labeled transfer policy frozen in docs/security/safe_preview_trust_classes.md. This schema narrows the broader shell interaction-safety representation vocabulary to the transfer-safe actions that move bytes or summaries off a surface: copy_raw, copy_rendered, copy_escaped, export_sanitized_snapshot, and export_metadata_only.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/representation_transfer_record" }
  ],
  "$defs": {
    "text_representation_policy_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the text representation transfer policy export. Current value is 1. Bumped only on breaking payload changes."
    },

    "record_kind": {
      "type": "string",
      "enum": [
        "representation_transfer_record"
      ],
      "description": "Discriminator for the concrete payload shape."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque id safe to log or export. Raw bodies and secrets never appear here."
    },

    "surface_family": {
      "type": "string",
      "enum": [
        "editor_content",
        "docs_help_page",
        "review_surface",
        "rich_preview",
        "install_review",
        "publish_review",
        "remote_attach_review",
        "approval_surface",
        "delete_review_surface",
        "support_export_surface"
      ],
      "description": "Closed surface-family vocabulary for representation transfer."
    },

    "trust_class": {
      "type": "string",
      "enum": [
        "RawText",
        "SanitizedRich",
        "TrustedLocalActive",
        "IsolatedRemoteActive"
      ],
      "description": "Frozen safe-preview trust-class vocabulary. The transfer action names what leaves the product; the trust class names the source surface posture."
    },

    "representation_action_id": {
      "type": "string",
      "enum": [
        "copy_raw",
        "copy_rendered",
        "copy_escaped",
        "export_sanitized_snapshot",
        "export_metadata_only"
      ],
      "description": "Closed transfer-action vocabulary. Generic unlabeled copy/export actions are non-conforming where representations differ materially."
    },

    "representation_class": {
      "type": "string",
      "enum": [
        "raw",
        "rendered",
        "escaped",
        "sanitized",
        "blocked_metadata_only"
      ],
      "description": "Transfer-safe subset of the broader representation-class vocabulary. sandboxed and generated are on-screen state classes, not transfer outputs."
    },

    "body_posture": {
      "type": "string",
      "enum": [
        "exact_source_bytes",
        "rendered_view",
        "escaped_source_text",
        "sanitized_static_snapshot",
        "metadata_only_envelope"
      ],
      "description": "Closed body-posture vocabulary naming what the transferred payload materially contains."
    },

    "disclosure_field": {
      "type": "string",
      "enum": [
        "representation_label",
        "trust_class_badge",
        "owner_identity",
        "origin_identity",
        "snapshot_age",
        "warning_state",
        "metadata_only_reason"
      ],
      "description": "Closed visible-disclosure field vocabulary. These fields remain explicit wherever the action is offered."
    },

    "fallback_reason": {
      "type": "string",
      "enum": [
        "source_bytes_missing",
        "active_content_not_exportable",
        "origin_unverified",
        "policy_requires_metadata_only",
        "snapshot_only_after_disconnect"
      ],
      "description": "Closed fallback-reason vocabulary naming why a transfer action narrows to a different representation."
    },

    "representation_transfer_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "text_representation_policy_schema_version",
        "case_id",
        "source_surface_family",
        "source_trust_class",
        "action_id",
        "representation_class",
        "label",
        "body_posture",
        "raw_source_required",
        "active_content_removed",
        "must_offer_also",
        "required_disclosure_fields"
      ],
      "properties": {
        "record_kind": { "const": "representation_transfer_record" },
        "text_representation_policy_schema_version": {
          "$ref": "#/$defs/text_representation_policy_schema_version"
        },
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "source_surface_family": { "$ref": "#/$defs/surface_family" },
        "source_trust_class": { "$ref": "#/$defs/trust_class" },
        "action_id": { "$ref": "#/$defs/representation_action_id" },
        "representation_class": { "$ref": "#/$defs/representation_class" },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "User-facing label shown for the transfer action."
        },
        "body_posture": { "$ref": "#/$defs/body_posture" },
        "raw_source_required": {
          "type": "boolean",
          "description": "True when the action requires the exact source representation to still be available."
        },
        "active_content_removed": {
          "type": "boolean",
          "description": "True when active/scriptable content has been stripped from the transferred payload."
        },
        "must_offer_also": {
          "type": "array",
          "items": { "$ref": "#/$defs/representation_action_id" },
          "uniqueItems": true,
          "description": "Other representation-labeled actions that must remain reachable on the same surface."
        },
        "required_disclosure_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/disclosure_field" },
          "minItems": 1,
          "uniqueItems": true,
          "contains": { "const": "representation_label" },
          "description": "Fields that must stay visible where this action is offered."
        },
        "fallback_action_id": {
          "$ref": "#/$defs/representation_action_id"
        },
        "fallback_reason": {
          "$ref": "#/$defs/fallback_reason"
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "description": "Optional reviewable note describing why the chosen transfer posture is the truthful one."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action_id": { "const": "copy_raw" }
            },
            "required": ["action_id"]
          },
          "then": {
            "properties": {
              "representation_class": { "const": "raw" },
              "body_posture": { "const": "exact_source_bytes" },
              "raw_source_required": { "const": true }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action_id": { "const": "copy_rendered" }
            },
            "required": ["action_id"]
          },
          "then": {
            "properties": {
              "representation_class": { "const": "rendered" },
              "body_posture": { "const": "rendered_view" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action_id": { "const": "copy_escaped" }
            },
            "required": ["action_id"]
          },
          "then": {
            "properties": {
              "representation_class": { "const": "escaped" },
              "body_posture": { "const": "escaped_source_text" },
              "raw_source_required": { "const": true }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action_id": { "const": "export_sanitized_snapshot" }
            },
            "required": ["action_id"]
          },
          "then": {
            "properties": {
              "representation_class": { "const": "sanitized" },
              "body_posture": { "const": "sanitized_static_snapshot" },
              "active_content_removed": { "const": true }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action_id": { "const": "export_metadata_only" }
            },
            "required": ["action_id"]
          },
          "then": {
            "properties": {
              "representation_class": { "const": "blocked_metadata_only" },
              "body_posture": { "const": "metadata_only_envelope" },
              "raw_source_required": { "const": false },
              "required_disclosure_fields": {
                "contains": { "const": "metadata_only_reason" }
              }
            },
            "required": [
              "fallback_reason"
            ]
          }
        },
        {
          "if": {
            "required": ["fallback_action_id"]
          },
          "then": {
            "required": ["fallback_reason"]
          }
        }
      ],
      "description": "Representation-labeled transfer decision for one surface and one action."
    }
  }
}
