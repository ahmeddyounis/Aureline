{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/m5-trust-decision-identity.schema.json",
  "title": "Aureline M5 trust-decision identity rendering packet",
  "description": "Export-safe packet that renders identity strings on the new M5 trust-decision surfaces (publisher/package names on install/update prompts, remote-host labels on attach, collaborator identities on invites, route-share targets, and policy-review text) in a stricter strong-decision mode than ordinary browsing panes. Every trust-decision surface resolves to the strong_decision render mode, whose strength rank is strictly higher than the ordinary_browsing baseline. The shared suspicious-content detector runs over each identity; surfaces whose identity carries bidi/invisible/confusable cues show a warning and a codepoint-inspection affordance. Raw identity inspection (open-raw and copy-escaped) stays reachable on every surface, the full identity is shown without truncation, suspicious bytes are never normalized away, and the escaped inspection form never masquerades as the raw bytes. The same stricter rendering is preserved in product, exported review packets, and support handoff. The packet carries only metadata: opaque refs to the raw identity plus the detector's escaped/safe inspection form, never the raw provider identity bytes, credentials, or payloads.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "case_id",
    "surface_count",
    "suspicious_surface_count",
    "ordinary_browsing_strength_rank",
    "strong_decision_strength_rank",
    "render_modes",
    "normalization_applied",
    "surfaces",
    "review",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "m5_trust_decision_identity_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "case_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "surface_count": {
      "type": "integer",
      "minimum": 0
    },
    "suspicious_surface_count": {
      "type": "integer",
      "minimum": 0
    },
    "ordinary_browsing_strength_rank": {
      "const": 1
    },
    "strong_decision_strength_rank": {
      "const": 2
    },
    "render_modes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/render_mode"
      }
    },
    "normalization_applied": {
      "const": false
    },
    "surfaces": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/surface_projection"
      }
    },
    "review": {
      "$ref": "#/$defs/review"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "surface": {
      "type": "string",
      "enum": [
        "publisher_package_name",
        "remote_host_label",
        "collaborator_identity",
        "route_share",
        "policy_review"
      ]
    },
    "decision_action": {
      "type": "string",
      "enum": [
        "install_or_update",
        "remote_attach",
        "collaboration_invite",
        "route_share",
        "policy_review"
      ]
    },
    "render_mode": {
      "type": "string",
      "enum": [
        "ordinary_browsing",
        "strong_decision"
      ]
    },
    "warning_kind": {
      "type": "string",
      "enum": [
        "bidi_or_invisible_bytes",
        "mixed_script_confusable"
      ]
    },
    "action_kind": {
      "type": "string",
      "enum": [
        "open_raw_identity",
        "copy_escaped_identity",
        "inspect_codepoints"
      ]
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "kind_token",
        "message"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/warning_kind"
        },
        "kind_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "message": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "kind_token",
        "target_ref",
        "label"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/action_kind"
        },
        "kind_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "surface_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "surface_token",
        "decision_action",
        "decision_action_token",
        "decision_verb",
        "subject_ref",
        "raw_identity_ref",
        "render_mode",
        "render_mode_token",
        "render_strength_rank",
        "identity_inspection_escaped",
        "identity_char_len",
        "displayed_char_len",
        "full_identity_shown",
        "has_suspicious_cues",
        "suspicious_finding_count",
        "threat_classes",
        "detector_outcome_token",
        "rendered_differs_from_raw",
        "warnings",
        "actions",
        "raw_inspection_reachable",
        "escaped_copy_reachable",
        "decision_affordance_distinct",
        "preserved_in_product",
        "preserved_in_exported_review_packet",
        "preserved_in_support_handoff",
        "rationale"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/surface"
        },
        "surface_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "decision_action": {
          "$ref": "#/$defs/decision_action"
        },
        "decision_action_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "decision_verb": {
          "$ref": "#/$defs/non_empty_string"
        },
        "subject_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "raw_identity_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "render_mode": {
          "const": "strong_decision"
        },
        "render_mode_token": {
          "const": "strong_decision"
        },
        "render_strength_rank": {
          "const": 2
        },
        "identity_inspection_escaped": {
          "$ref": "#/$defs/non_empty_string"
        },
        "identity_char_len": {
          "type": "integer",
          "minimum": 0
        },
        "displayed_char_len": {
          "type": "integer",
          "minimum": 0
        },
        "full_identity_shown": {
          "const": true
        },
        "has_suspicious_cues": {
          "type": "boolean"
        },
        "suspicious_finding_count": {
          "type": "integer",
          "minimum": 0
        },
        "threat_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "detector_outcome_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rendered_differs_from_raw": {
          "type": "boolean"
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/action"
          }
        },
        "raw_inspection_reachable": {
          "const": true
        },
        "escaped_copy_reachable": {
          "const": true
        },
        "decision_affordance_distinct": {
          "const": true
        },
        "preserved_in_product": {
          "const": true
        },
        "preserved_in_exported_review_packet": {
          "const": true
        },
        "preserved_in_support_handoff": {
          "const": true
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "one_shared_policy_library_governs_all_surfaces",
        "trust_decision_surfaces_use_strong_decision_mode",
        "strong_decision_stricter_than_ordinary_browsing",
        "full_identity_shown_without_truncation",
        "raw_identity_inspection_reachable_everywhere",
        "suspicious_bytes_never_normalized_away",
        "escaped_form_never_masquerades_as_raw",
        "suspicious_identities_carry_warning_and_inspection",
        "decision_affordance_distinct_from_browsing",
        "stricter_rendering_preserved_in_product_export_and_handoff"
      ],
      "properties": {
        "one_shared_policy_library_governs_all_surfaces": {
          "const": true
        },
        "trust_decision_surfaces_use_strong_decision_mode": {
          "const": true
        },
        "strong_decision_stricter_than_ordinary_browsing": {
          "const": true
        },
        "full_identity_shown_without_truncation": {
          "const": true
        },
        "raw_identity_inspection_reachable_everywhere": {
          "const": true
        },
        "suspicious_bytes_never_normalized_away": {
          "const": true
        },
        "escaped_form_never_masquerades_as_raw": {
          "const": true
        },
        "suspicious_identities_carry_warning_and_inspection": {
          "const": true
        },
        "decision_affordance_distinct_from_browsing": {
          "const": true
        },
        "stricter_rendering_preserved_in_product_export_and_handoff": {
          "const": true
        }
      }
    }
  }
}
