{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/policy_pack.schema.json",
  "title": "Aureline policy-pack beta inspection page",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "source_matrix_ref",
    "packs",
    "diffs",
    "denial_traces",
    "import_receipts",
    "defects",
    "summary"
  ],
  "properties": {
    "record_kind": {
      "const": "security_policy_pack_beta_page_record"
    },
    "schema_version": {
      "$ref": "#/$defs/schema_version"
    },
    "shared_contract_ref": {
      "$ref": "#/$defs/shared_contract_ref"
    },
    "source_matrix_ref": {
      "type": "string",
      "minLength": 1
    },
    "packs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pack"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "diffs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diff"
      },
      "uniqueItems": true
    },
    "denial_traces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/denial_trace"
      },
      "uniqueItems": true
    },
    "import_receipts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/import_receipt"
      },
      "uniqueItems": true
    },
    "defects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/defect"
      },
      "uniqueItems": true
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "security:policy_pack_beta:v1"
    },
    "token": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string",
      "enum": [
        "connected",
        "mirror_only",
        "offline",
        "enterprise_managed"
      ]
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "workspace_open_restore",
        "editor_read_write",
        "search_local",
        "local_git_read",
        "local_git_write",
        "shell_command_palette",
        "tasks_run",
        "terminal_manual_open",
        "terminal_repo_recipe_launch",
        "debug_launch",
        "notebook_kernel_connect",
        "notebook_cell_execute",
        "notebook_rich_output_render",
        "ai_context_read",
        "ai_apply_mutation",
        "ai_tool_call_mutating",
        "extension_activation",
        "extension_install",
        "environment_activator_run",
        "package_install_helper",
        "scaffold_template_run",
        "connected_provider_open",
        "connected_provider_tool_call",
        "remote_attach",
        "mcp_server_launch",
        "support_bundle_export",
        "admin_policy_read"
      ]
    },
    "authority": {
      "type": "string",
      "enum": [
        "allowed",
        "read_only",
        "degraded_preview_only",
        "blocked_pending_trust",
        "blocked_pending_approval",
        "approval_required_per_invocation",
        "policy_denied",
        "quarantine_denied",
        "not_applicable"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "local_advisory_file",
        "customer_self_hosted_origin",
        "vendor_managed_origin",
        "signed_mirror_origin",
        "manual_signed_file_import",
        "air_gapped_signed_transfer",
        "runtime_preload_origin"
      ]
    },
    "signature_state": {
      "type": "string",
      "enum": [
        "verified_live",
        "verified_mirror",
        "verified_manual_import",
        "verified_air_gapped",
        "not_required_local_origin",
        "missing_for_required_origin",
        "invalid"
      ]
    },
    "apply_state": {
      "type": "string",
      "enum": [
        "effective",
        "staged_awaiting_review",
        "replaced_by_successor",
        "revoked",
        "never_applied"
      ]
    },
    "effect_class": {
      "type": "string",
      "enum": [
        "deny",
        "require_approval",
        "narrow_to_read_or_preview",
        "allow_matrix_default",
        "audit_only"
      ]
    },
    "diff_kind": {
      "type": "string",
      "enum": [
        "added",
        "removed",
        "effect_changed",
        "scope_changed",
        "reason_changed"
      ]
    },
    "defect_kind": {
      "type": "string",
      "enum": [
        "unsigned_managed_authority",
        "source_token_drift",
        "signature_token_drift",
        "mirror_or_import_provenance_dropped",
        "mirror_or_import_signature_blob_dropped",
        "mirror_or_import_explanation_dropped",
        "hidden_public_endpoint_fallback",
        "profile_coverage_missing",
        "diff_entry_effect_mismatch",
        "denial_trace_unresolvable",
        "denial_trace_effect_not_denial",
        "denial_trace_surface_missing",
        "raw_private_material_exposed"
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin_ref",
        "signer_id",
        "signed_at",
        "fetched_at",
        "transport_label",
        "signature_blob_ref"
      ],
      "properties": {
        "origin_ref": {
          "$ref": "#/$defs/token"
        },
        "signer_id": {
          "$ref": "#/$defs/token"
        },
        "signed_at": {
          "$ref": "#/$defs/token"
        },
        "fetched_at": {
          "$ref": "#/$defs/token"
        },
        "transport_label": {
          "$ref": "#/$defs/token"
        },
        "signature_blob_ref": {
          "$ref": "#/$defs/token"
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "rule_id",
        "surface_family",
        "surface_family_token",
        "effect",
        "effect_token",
        "applied_authority",
        "applied_authority_token",
        "scope_label",
        "reason_token",
        "explanation"
      ],
      "properties": {
        "record_kind": {
          "const": "security_policy_pack_beta_rule_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "rule_id": {
          "$ref": "#/$defs/token"
        },
        "surface_family": {
          "$ref": "#/$defs/surface_family"
        },
        "surface_family_token": {
          "$ref": "#/$defs/surface_family"
        },
        "effect": {
          "$ref": "#/$defs/effect_class"
        },
        "effect_token": {
          "$ref": "#/$defs/effect_class"
        },
        "applied_authority": {
          "$ref": "#/$defs/authority"
        },
        "applied_authority_token": {
          "$ref": "#/$defs/authority"
        },
        "scope_label": {
          "$ref": "#/$defs/token"
        },
        "reason_token": {
          "$ref": "#/$defs/token"
        },
        "explanation": {
          "$ref": "#/$defs/token"
        }
      }
    },
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "pack_id",
        "pack_version",
        "source_class",
        "source_token",
        "signature_state",
        "signature_state_token",
        "apply_state",
        "apply_state_token",
        "provenance",
        "rules",
        "applies_to_profiles",
        "no_public_endpoint_fallback",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "const": "security_policy_pack_beta_pack_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "pack_id": {
          "$ref": "#/$defs/token"
        },
        "pack_version": {
          "$ref": "#/$defs/token"
        },
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "source_token": {
          "$ref": "#/$defs/source_class"
        },
        "signature_state": {
          "$ref": "#/$defs/signature_state"
        },
        "signature_state_token": {
          "$ref": "#/$defs/signature_state"
        },
        "apply_state": {
          "$ref": "#/$defs/apply_state"
        },
        "apply_state_token": {
          "$ref": "#/$defs/apply_state"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rule"
          },
          "uniqueItems": true
        },
        "applies_to_profiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/profile"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "no_public_endpoint_fallback": {
          "type": "boolean",
          "const": true
        },
        "raw_private_material_excluded": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "diff_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "kind",
        "kind_token",
        "rule_id",
        "surface_family_token",
        "before_effect_token",
        "after_effect_token",
        "before_scope_label",
        "after_scope_label",
        "before_reason_token",
        "after_reason_token",
        "note"
      ],
      "properties": {
        "record_kind": {
          "const": "security_policy_pack_beta_diff_entry_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "kind": {
          "$ref": "#/$defs/diff_kind"
        },
        "kind_token": {
          "$ref": "#/$defs/diff_kind"
        },
        "rule_id": {
          "$ref": "#/$defs/token"
        },
        "surface_family_token": {
          "$ref": "#/$defs/surface_family"
        },
        "before_effect_token": {
          "$ref": "#/$defs/token"
        },
        "after_effect_token": {
          "$ref": "#/$defs/token"
        },
        "before_scope_label": {
          "$ref": "#/$defs/token"
        },
        "after_scope_label": {
          "$ref": "#/$defs/token"
        },
        "before_reason_token": {
          "$ref": "#/$defs/token"
        },
        "after_reason_token": {
          "$ref": "#/$defs/token"
        },
        "note": {
          "$ref": "#/$defs/token"
        }
      }
    },
    "diff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "base_pack_id",
        "target_pack_id",
        "profile_token",
        "entries"
      ],
      "properties": {
        "record_kind": {
          "const": "security_policy_pack_beta_diff_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "base_pack_id": {
          "$ref": "#/$defs/token"
        },
        "target_pack_id": {
          "$ref": "#/$defs/token"
        },
        "profile_token": {
          "$ref": "#/$defs/profile"
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/diff_entry"
          },
          "uniqueItems": true
        }
      }
    },
    "denial_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "trace_id",
        "pack_id",
        "rule_id",
        "surface_family",
        "surface_family_token",
        "reason_token",
        "explanation",
        "profile_token"
      ],
      "properties": {
        "record_kind": {
          "const": "security_policy_pack_beta_denial_trace_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "trace_id": {
          "$ref": "#/$defs/token"
        },
        "pack_id": {
          "$ref": "#/$defs/token"
        },
        "rule_id": {
          "$ref": "#/$defs/token"
        },
        "surface_family": {
          "$ref": "#/$defs/surface_family"
        },
        "surface_family_token": {
          "$ref": "#/$defs/surface_family"
        },
        "reason_token": {
          "$ref": "#/$defs/token"
        },
        "explanation": {
          "$ref": "#/$defs/token"
        },
        "profile_token": {
          "$ref": "#/$defs/profile"
        }
      }
    },
    "import_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "receipt_id",
        "pack_id",
        "pack_version",
        "source_class",
        "source_token",
        "signature_state",
        "signature_state_token",
        "provenance",
        "applies_to_profiles",
        "preserves_signature_blob",
        "preserves_provenance",
        "preserves_explanation"
      ],
      "properties": {
        "record_kind": {
          "const": "security_policy_pack_beta_import_receipt_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "receipt_id": {
          "$ref": "#/$defs/token"
        },
        "pack_id": {
          "$ref": "#/$defs/token"
        },
        "pack_version": {
          "$ref": "#/$defs/token"
        },
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "source_token": {
          "$ref": "#/$defs/source_class"
        },
        "signature_state": {
          "$ref": "#/$defs/signature_state"
        },
        "signature_state_token": {
          "$ref": "#/$defs/signature_state"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "applies_to_profiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/profile"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "preserves_signature_blob": {
          "type": "boolean",
          "const": true
        },
        "preserves_provenance": {
          "type": "boolean",
          "const": true
        },
        "preserves_explanation": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_kind",
        "defect_kind_token",
        "subject_id",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": {
          "const": "security_policy_pack_beta_defect_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "defect_kind": {
          "$ref": "#/$defs/defect_kind"
        },
        "defect_kind_token": {
          "$ref": "#/$defs/defect_kind"
        },
        "subject_id": {
          "$ref": "#/$defs/token"
        },
        "field": {
          "$ref": "#/$defs/token"
        },
        "note": {
          "$ref": "#/$defs/token"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_record_kind",
        "record_kind",
        "pack_count",
        "effective_pack_count",
        "mirror_or_import_receipt_count",
        "diff_count",
        "denial_trace_count",
        "profiles_present",
        "source_tokens_present",
        "defect_count",
        "defect_counts_by_kind"
      ],
      "properties": {
        "page_record_kind": {
          "const": "security_policy_pack_beta_page_record"
        },
        "record_kind": {
          "const": "security_policy_pack_beta_summary_record"
        },
        "pack_count": {
          "type": "integer",
          "minimum": 0
        },
        "effective_pack_count": {
          "type": "integer",
          "minimum": 0
        },
        "mirror_or_import_receipt_count": {
          "type": "integer",
          "minimum": 0
        },
        "diff_count": {
          "type": "integer",
          "minimum": 0
        },
        "denial_trace_count": {
          "type": "integer",
          "minimum": 0
        },
        "profiles_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/profile"
          },
          "uniqueItems": true
        },
        "source_tokens_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_class"
          },
          "uniqueItems": true
        },
        "defect_count": {
          "type": "integer",
          "minimum": 0
        },
        "defect_counts_by_kind": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
