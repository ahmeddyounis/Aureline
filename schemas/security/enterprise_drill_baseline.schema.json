{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/security/enterprise_drill_baseline.schema.json",
  "title": "Aureline enterprise drill baseline page",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "source_matrix_ref",
    "drill_packets",
    "defects",
    "summary"
  ],
  "properties": {
    "record_kind": {
      "const": "security_enterprise_drill_baseline_page_record"
    },
    "schema_version": { "$ref": "#/$defs/schema_version" },
    "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
    "source_matrix_ref": { "type": "string", "minLength": 1 },
    "drill_packets": {
      "type": "array",
      "items": { "$ref": "#/$defs/drill_packet" }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/defect" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "security:enterprise_drill_baseline:v1"
    },
    "token": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "profile_token": {
      "type": "string",
      "enum": [
        "connected",
        "mirror_only",
        "offline",
        "enterprise_managed"
      ]
    },
    "drill_kind_token": {
      "type": "string",
      "enum": [
        "backup_restore",
        "failover",
        "key_rotation"
      ]
    },
    "row_family_token": {
      "type": "string",
      "enum": [
        "managed_policy_distribution",
        "managed_credential_handle",
        "enterprise_identity_session"
      ]
    },
    "outcome_token": {
      "type": "string",
      "enum": [
        "restored_from_trusted_snapshot",
        "failed_over_to_declared_fallback",
        "rotated_then_recovered",
        "downgraded_awaiting_admin"
      ]
    },
    "evidence_freshness_token": {
      "type": "string",
      "enum": [
        "fresh",
        "stale_within_window",
        "stale_beyond_window",
        "missing"
      ]
    },
    "claim_impact_token": {
      "type": "string",
      "enum": [
        "no_impact",
        "downgrade_affected_claim",
        "downgrade_family_claims"
      ]
    },
    "authority_token": {
      "type": "string",
      "enum": [
        "allowed",
        "read_only",
        "degraded_preview_only",
        "blocked_pending_trust",
        "blocked_pending_approval",
        "approval_required_per_invocation",
        "policy_denied",
        "quarantine_denied",
        "not_applicable"
      ]
    },
    "defect_kind_token": {
      "type": "string",
      "enum": [
        "token_drift",
        "drill_kind_coverage_missing_for_family",
        "drill_sibling_lane_widened",
        "drill_local_editing_not_preserved",
        "raw_private_material_exposed",
        "hidden_public_endpoint_fallback",
        "stale_evidence_without_downgrade",
        "fresh_evidence_with_unexpected_downgrade",
        "outcome_does_not_match_drill_kind"
      ]
    },
    "drill_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "drill_packet_id",
        "drill_kind",
        "drill_kind_token",
        "row_family",
        "row_family_token",
        "affected_claim_id",
        "profile",
        "profile_token",
        "outcome",
        "outcome_token",
        "evidence_freshness",
        "evidence_freshness_token",
        "claim_impact_if_stale",
        "claim_impact_if_stale_token",
        "before_state_label",
        "after_state_label",
        "before_authority",
        "before_authority_token",
        "after_authority",
        "after_authority_token",
        "explanation",
        "started_at",
        "resolved_at",
        "valid_until",
        "artifact_ref",
        "local_editing_preserved",
        "sibling_lanes_unwidened",
        "raw_private_material_excluded",
        "no_public_endpoint_fallback"
      ],
      "properties": {
        "record_kind": {
          "const": "security_enterprise_drill_baseline_packet_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "drill_packet_id": { "type": "string", "minLength": 1 },
        "drill_kind": { "$ref": "#/$defs/drill_kind_token" },
        "drill_kind_token": { "$ref": "#/$defs/drill_kind_token" },
        "row_family": { "$ref": "#/$defs/row_family_token" },
        "row_family_token": { "$ref": "#/$defs/row_family_token" },
        "affected_claim_id": { "type": "string", "minLength": 1 },
        "profile": { "$ref": "#/$defs/profile_token" },
        "profile_token": { "$ref": "#/$defs/profile_token" },
        "outcome": { "$ref": "#/$defs/outcome_token" },
        "outcome_token": { "$ref": "#/$defs/outcome_token" },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness_token" },
        "evidence_freshness_token": { "$ref": "#/$defs/evidence_freshness_token" },
        "claim_impact_if_stale": { "$ref": "#/$defs/claim_impact_token" },
        "claim_impact_if_stale_token": { "$ref": "#/$defs/claim_impact_token" },
        "before_state_label": { "type": "string" },
        "after_state_label": { "type": "string" },
        "before_authority": { "$ref": "#/$defs/authority_token" },
        "before_authority_token": { "$ref": "#/$defs/authority_token" },
        "after_authority": { "$ref": "#/$defs/authority_token" },
        "after_authority_token": { "$ref": "#/$defs/authority_token" },
        "explanation": { "type": "string" },
        "started_at": { "$ref": "#/$defs/timestamp" },
        "resolved_at": { "$ref": "#/$defs/timestamp" },
        "valid_until": { "$ref": "#/$defs/timestamp" },
        "artifact_ref": { "type": "string", "minLength": 1 },
        "local_editing_preserved": { "type": "boolean", "const": true },
        "sibling_lanes_unwidened": { "type": "boolean", "const": true },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "no_public_endpoint_fallback": { "type": "boolean", "const": true }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_kind",
        "defect_kind_token",
        "subject_id",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": {
          "const": "security_enterprise_drill_baseline_defect_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_kind": { "$ref": "#/$defs/defect_kind_token" },
        "defect_kind_token": { "$ref": "#/$defs/defect_kind_token" },
        "subject_id": { "type": "string", "minLength": 1 },
        "field": { "type": "string", "minLength": 1 },
        "note": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_record_kind",
        "record_kind",
        "drill_packet_count",
        "drill_kinds_present",
        "row_families_present",
        "profiles_present",
        "claim_downgrades_present",
        "defect_count",
        "defect_counts_by_kind"
      ],
      "properties": {
        "page_record_kind": {
          "const": "security_enterprise_drill_baseline_page_record"
        },
        "record_kind": {
          "const": "security_enterprise_drill_baseline_summary_record"
        },
        "drill_packet_count": { "type": "integer", "minimum": 0 },
        "drill_kinds_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/drill_kind_token" }
        },
        "row_families_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/row_family_token" }
        },
        "profiles_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/profile_token" }
        },
        "claim_downgrades_present": { "type": "integer", "minimum": 0 },
        "defect_count": { "type": "integer", "minimum": 0 },
        "defect_counts_by_kind": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
