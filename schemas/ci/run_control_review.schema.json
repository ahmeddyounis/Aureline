{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ci/run_control_review.schema.json",
  "title": "Aureline CI / pipeline run-control review",
  "description": "Boundary schema for the run_control_review_record frozen in docs/ci/pipeline_run_and_control_contract.md. Every disclosure / review surface for rerun, cancel, retry, approve, dismiss, force-retry, mark-required, request-artifact-redownload, or request-log-rehydrate emits one run_control_review_record so the user sees exactly what upstream effect will fire before the control is invoked. The record names the run row it acts on, the run-control class, the target scope class, the mutation mode (one of the five frozen provider-mode mutation modes), the auth / policy requirement, the blocked-class verdict, the disclosure class, the typed effect summary, and the audit row that will land if the control is invoked. local_draft mutation mode is not admissible for run-controls (run-controls reach upstream provider state). publish_now MUST cite an approval_ticket_ref; open_in_provider MUST cite a browser_handoff_packet_ref; deferred_publish MUST cite a publish_later_queue_item_ref. Raw URLs (provider host, run URL, branch URL, commit URL, artifact URL), raw absolute paths, raw author email addresses, raw step output bytes, raw artifact bodies, raw bearer / OAuth / delegated / approval tokens, and raw provider payloads never cross this boundary. Adding a new control_class, target_scope_class, mutation_mode_class, auth_or_policy_requirement, blocked_class, or disclosure_class value is additive-minor and bumps run_control_review_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/run_control_review_record" }
  ],
  "$defs": {
    "run_control_review_schema_version": {
      "type": "integer",
      "const": 1
    },

    "record_kind": {
      "type": "string",
      "const": "run_control_review_record"
    },

    "instance_schema_hint": {
      "type": "string",
      "format": "uri-reference"
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1
    },

    "redaction_aware_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480,
      "description": "Reviewer-facing short label. Redaction-aware; raw URLs, raw absolute paths, raw author email addresses, raw step output bytes, raw artifact bodies, and raw bearer / OAuth / delegated / approval tokens never appear here."
    },

    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "control_class": {
      "type": "string",
      "enum": [
        "rerun_workflow",
        "rerun_failed_jobs",
        "rerun_single_job",
        "rerun_single_step",
        "cancel_workflow",
        "cancel_single_job",
        "retry_failed_step",
        "approve_pending_deployment",
        "approve_required_review_gate",
        "dismiss_required_review_gate",
        "mark_check_run_required",
        "force_required_review_pass",
        "request_artifact_redownload",
        "request_log_rehydrate",
        "unknown_control_provider_owned"
      ],
      "description": "Closed run-control vocabulary."
    },

    "target_scope_class": {
      "type": "string",
      "enum": [
        "single_step_only",
        "single_job_only",
        "failed_jobs_only",
        "entire_workflow_run",
        "entire_check_run",
        "entire_deployment_run",
        "entire_release_run",
        "artifact_only_no_run_mutation",
        "log_only_no_run_mutation"
      ],
      "description": "Closed target-scope vocabulary."
    },

    "mutation_mode_class": {
      "type": "string",
      "enum": [
        "publish_now",
        "open_in_provider",
        "deferred_publish",
        "inspect_only"
      ],
      "description": "One of the five frozen provider-mode mutation modes admissible for run-controls. local_draft is intentionally absent; run-controls cannot remain local-only."
    },

    "auth_or_policy_requirement": {
      "type": "string",
      "enum": [
        "no_extra_requirement",
        "requires_signed_in_human_account",
        "requires_install_or_bot_account",
        "requires_delegated_grant_with_run_scope",
        "requires_step_up_authentication",
        "requires_admin_or_owner_grant",
        "requires_protected_branch_override_grant",
        "requires_environment_protection_grant",
        "requires_deployment_approver_grant",
        "requires_managed_workspace_envelope_grant",
        "requires_policy_review_pending_admin",
        "requires_browser_handoff_grant_returned",
        "requires_approval_ticket_spent",
        "requires_publish_later_drain_eligible",
        "unknown_requirement_provider_owned"
      ],
      "description": "Closed auth-or-policy requirement vocabulary."
    },

    "blocked_class": {
      "type": "string",
      "enum": [
        "not_blocked",
        "blocked_no_auth_for_target_scope",
        "blocked_policy_forbids_control",
        "blocked_provider_does_not_support_control",
        "blocked_run_state_not_eligible",
        "blocked_freshness_stale_review_required",
        "blocked_local_truth_disagreement_review_required",
        "blocked_partial_log_no_safe_action",
        "blocked_offline_or_disconnected",
        "blocked_pending_approval_ticket",
        "blocked_pending_browser_handoff_return",
        "blocked_pending_publish_later_drain",
        "blocked_managed_admin_lock",
        "blocked_unknown_reason_provider_owned"
      ],
      "description": "Closed blocked-class vocabulary."
    },

    "disclosure_class": {
      "type": "string",
      "enum": [
        "preview_only_no_invocation_offered",
        "two_step_confirmation_required",
        "approval_ticket_required",
        "browser_handoff_required",
        "queued_for_later_required",
        "denied_no_action"
      ],
      "description": "Closed disclosure-class vocabulary describing how the surface presents the control to the user."
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity_mode", "policy_epoch", "trust_state"],
      "properties": {
        "identity_mode": {
          "type": "string",
          "enum": [
            "account_free_local",
            "self_hosted_org",
            "managed_workspace"
          ]
        },
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted"]
        },
        "execution_context_id": { "type": "string", "minLength": 1 }
      }
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "scope_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "id"],
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "workspace",
            "window",
            "review_workspace",
            "remote_session",
            "tenant",
            "companion_surface"
          ]
        },
        "id": { "$ref": "#/$defs/opaque_id" }
      }
    },

    "effect_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "what_will_fire_label",
        "where_label",
        "under_whose_authority_label",
        "audit_row_label"
      ],
      "properties": {
        "what_will_fire_label": { "$ref": "#/$defs/reviewable_sentence" },
        "where_label": { "$ref": "#/$defs/redaction_aware_label" },
        "under_whose_authority_label": { "$ref": "#/$defs/redaction_aware_label" },
        "audit_row_label": { "$ref": "#/$defs/redaction_aware_label" }
      },
      "description": "Reviewable effect summary projected as four short reviewable strings: what upstream effect will fire, where it lands (target scope), under whose authority, and what audit row will land. The runs panel, gutter chip, status bar, command palette result, support packet, and AI evidence packet MUST all project the same effect_summary for the same run_control_review_id within an import session."
    },

    "run_control_review_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "run_control_review_schema_version",
        "run_control_review_id",
        "scope_ref",
        "pipeline_run_row_ref",
        "control_class",
        "target_scope_class",
        "mutation_mode_class",
        "effect_summary",
        "auth_or_policy_requirement",
        "blocked_class",
        "disclosure_class",
        "audit_note_ref",
        "policy_context",
        "redaction_class",
        "review_summary_label",
        "minted_at"
      ],
      "properties": {
        "$schema": { "$ref": "#/$defs/instance_schema_hint" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "run_control_review_record" },
        "run_control_review_schema_version": {
          "$ref": "#/$defs/run_control_review_schema_version"
        },
        "run_control_review_id": { "$ref": "#/$defs/opaque_id" },
        "scope_ref": { "$ref": "#/$defs/scope_ref" },
        "pipeline_run_row_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Reference to the pipeline_run_row_record this control would act on."
        },
        "control_class": { "$ref": "#/$defs/control_class" },
        "target_scope_class": { "$ref": "#/$defs/target_scope_class" },
        "mutation_mode_class": { "$ref": "#/$defs/mutation_mode_class" },
        "effect_summary": { "$ref": "#/$defs/effect_summary" },
        "auth_or_policy_requirement": { "$ref": "#/$defs/auth_or_policy_requirement" },
        "blocked_class": { "$ref": "#/$defs/blocked_class" },
        "disclosure_class": { "$ref": "#/$defs/disclosure_class" },
        "audit_note_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque ref to the audit row that will be emitted when the control is invoked."
        },
        "approval_ticket_ref": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "Reference to the approval_ticket_record. Required (non-null) when mutation_mode_class is publish_now."
        },
        "browser_handoff_packet_ref": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "Reference to the browser_handoff_packet. Required (non-null) when mutation_mode_class is open_in_provider."
        },
        "publish_later_queue_item_ref": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "Reference to the publish_later_queue_item_record. Required (non-null) when mutation_mode_class is deferred_publish."
        },
        "policy_review_ref": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "Opaque ref to a policy review row. Required (non-null) when auth_or_policy_requirement is requires_policy_review_pending_admin."
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "review_summary_label": { "$ref": "#/$defs/reviewable_sentence" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "publish_now MUST cite an approval_ticket_ref.",
          "if": {
            "type": "object",
            "required": ["mutation_mode_class"],
            "properties": {
              "mutation_mode_class": { "const": "publish_now" }
            }
          },
          "then": {
            "type": "object",
            "required": ["approval_ticket_ref"],
            "properties": {
              "approval_ticket_ref": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "description": "open_in_provider MUST cite a browser_handoff_packet_ref.",
          "if": {
            "type": "object",
            "required": ["mutation_mode_class"],
            "properties": {
              "mutation_mode_class": { "const": "open_in_provider" }
            }
          },
          "then": {
            "type": "object",
            "required": ["browser_handoff_packet_ref"],
            "properties": {
              "browser_handoff_packet_ref": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "description": "deferred_publish MUST cite a publish_later_queue_item_ref.",
          "if": {
            "type": "object",
            "required": ["mutation_mode_class"],
            "properties": {
              "mutation_mode_class": { "const": "deferred_publish" }
            }
          },
          "then": {
            "type": "object",
            "required": ["publish_later_queue_item_ref"],
            "properties": {
              "publish_later_queue_item_ref": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "description": "inspect_only is admissible only for request_artifact_redownload and request_log_rehydrate.",
          "if": {
            "type": "object",
            "required": ["mutation_mode_class"],
            "properties": {
              "mutation_mode_class": { "const": "inspect_only" }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "control_class": {
                "enum": ["request_artifact_redownload", "request_log_rehydrate"]
              }
            }
          }
        },
        {
          "description": "rerun_failed_jobs MUST resolve to failed_jobs_only.",
          "if": {
            "type": "object",
            "required": ["control_class"],
            "properties": { "control_class": { "const": "rerun_failed_jobs" } }
          },
          "then": {
            "type": "object",
            "properties": {
              "target_scope_class": { "const": "failed_jobs_only" }
            }
          }
        },
        {
          "description": "rerun_workflow MUST resolve to entire_workflow_run.",
          "if": {
            "type": "object",
            "required": ["control_class"],
            "properties": { "control_class": { "const": "rerun_workflow" } }
          },
          "then": {
            "type": "object",
            "properties": {
              "target_scope_class": { "const": "entire_workflow_run" }
            }
          }
        },
        {
          "description": "cancel_workflow MUST resolve to entire_workflow_run.",
          "if": {
            "type": "object",
            "required": ["control_class"],
            "properties": { "control_class": { "const": "cancel_workflow" } }
          },
          "then": {
            "type": "object",
            "properties": {
              "target_scope_class": { "const": "entire_workflow_run" }
            }
          }
        },
        {
          "description": "rerun_single_step and retry_failed_step MUST resolve to single_step_only.",
          "if": {
            "type": "object",
            "required": ["control_class"],
            "properties": {
              "control_class": {
                "enum": ["rerun_single_step", "retry_failed_step"]
              }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "target_scope_class": { "const": "single_step_only" }
            }
          }
        },
        {
          "description": "request_artifact_redownload MUST resolve to artifact_only_no_run_mutation.",
          "if": {
            "type": "object",
            "required": ["control_class"],
            "properties": {
              "control_class": { "const": "request_artifact_redownload" }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "target_scope_class": { "const": "artifact_only_no_run_mutation" }
            }
          }
        },
        {
          "description": "request_log_rehydrate MUST resolve to log_only_no_run_mutation.",
          "if": {
            "type": "object",
            "required": ["control_class"],
            "properties": {
              "control_class": { "const": "request_log_rehydrate" }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "target_scope_class": { "const": "log_only_no_run_mutation" }
            }
          }
        },
        {
          "description": "Blocked records MUST set disclosure_class to denied_no_action.",
          "if": {
            "type": "object",
            "required": ["blocked_class"],
            "properties": {
              "blocked_class": {
                "not": { "const": "not_blocked" }
              }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "disclosure_class": { "const": "denied_no_action" }
            }
          }
        },
        {
          "description": "Admissible records (not_blocked) MUST NOT set disclosure_class to denied_no_action.",
          "if": {
            "type": "object",
            "required": ["blocked_class"],
            "properties": {
              "blocked_class": { "const": "not_blocked" }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "disclosure_class": {
                "not": { "const": "denied_no_action" }
              }
            }
          }
        },
        {
          "description": "requires_policy_review_pending_admin MUST cite a policy_review_ref and resolve to denied_no_action with blocked_policy_forbids_control.",
          "if": {
            "type": "object",
            "required": ["auth_or_policy_requirement"],
            "properties": {
              "auth_or_policy_requirement": {
                "const": "requires_policy_review_pending_admin"
              }
            }
          },
          "then": {
            "type": "object",
            "required": ["policy_review_ref"],
            "properties": {
              "policy_review_ref": { "type": "string", "minLength": 1 },
              "disclosure_class": { "const": "denied_no_action" },
              "blocked_class": { "const": "blocked_policy_forbids_control" }
            }
          }
        },
        {
          "description": "Approval-ticket required disclosure aligns with publish_now mutation.",
          "if": {
            "type": "object",
            "required": ["disclosure_class"],
            "properties": {
              "disclosure_class": { "const": "approval_ticket_required" }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "mutation_mode_class": { "const": "publish_now" }
            }
          }
        },
        {
          "description": "browser_handoff_required disclosure aligns with open_in_provider mutation.",
          "if": {
            "type": "object",
            "required": ["disclosure_class"],
            "properties": {
              "disclosure_class": { "const": "browser_handoff_required" }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "mutation_mode_class": { "const": "open_in_provider" }
            }
          }
        },
        {
          "description": "queued_for_later_required disclosure aligns with deferred_publish mutation.",
          "if": {
            "type": "object",
            "required": ["disclosure_class"],
            "properties": {
              "disclosure_class": { "const": "queued_for_later_required" }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "mutation_mode_class": { "const": "deferred_publish" }
            }
          }
        }
      ]
    }
  }
}
