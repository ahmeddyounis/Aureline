{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ci/pipeline_run_row.schema.json",
  "title": "Aureline CI / pipeline run row",
  "description": "Boundary schema for the pipeline_run_row_record frozen in docs/ci/pipeline_run_and_control_contract.md. Every CI / pipeline / check / build / deploy / release run rendered in the product (runs panel, gutter chip, status bar, command palette result, support packet, AI evidence packet) emits one pipeline_run_row_record. The record carries provider identity, workflow / job / step label, target ref identity, status, duration, trigger actor class, freshness, origin, artifact count disclosure, local-truth binding, and the provider event / import session / replay record this row was minted from. Raw URLs (provider host, run URL, branch URL, commit URL, artifact URL), raw absolute paths, raw author email addresses, raw step output bytes, raw artifact bodies, raw bearer / OAuth / delegated / approval tokens, and raw provider payloads never cross this boundary. Adding a new provider_run_kind, status_class, trigger_actor_class, origin_class, local_truth_authority_class, target_ref_class, or artifact_count_truncation_reason value is additive-minor and bumps pipeline_run_row_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/pipeline_run_row_record" }
  ],
  "$defs": {
    "pipeline_run_row_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the pipeline-run-row boundary. Current value is 1. Bumped only on breaking payload changes; additive enum values do not bump this version."
    },

    "record_kind": {
      "type": "string",
      "const": "pipeline_run_row_record"
    },

    "instance_schema_hint": {
      "type": "string",
      "format": "uri-reference"
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, and safe in support / export packets. Raw absolute paths, raw URLs, raw hostnames, raw cookies, and raw credential material never appear here."
    },

    "redaction_aware_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480,
      "description": "Reviewer-facing short label. Redaction-aware; raw secrets, raw URLs, raw hostnames, raw absolute paths, and raw author email addresses never appear here."
    },

    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "provider_class": {
      "type": "string",
      "enum": [
        "code_host_ci",
        "ci_or_checks_provider",
        "build_pipeline_provider",
        "deployment_pipeline_provider",
        "release_pipeline_provider",
        "self_hosted_runner_pool",
        "managed_runner_pool",
        "unknown_provider_class"
      ],
      "description": "Closed provider-class vocabulary. unknown_provider_class is the correct posture when the provider returns a class the contract does not recognise yet."
    },

    "provider_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_class", "provider_host_ref"],
      "properties": {
        "provider_class": { "$ref": "#/$defs/provider_class" },
        "provider_host_ref": { "$ref": "#/$defs/opaque_id" },
        "tenant_or_org_scope_ref": { "$ref": "#/$defs/opaque_id" },
        "environment_ref": { "$ref": "#/$defs/opaque_id" },
        "connected_provider_record_ref": { "$ref": "#/$defs/opaque_id" }
      },
      "description": "Provider identity for this row. Refs are opaque; raw provider URLs, raw hostnames, raw tenant strings, and raw environment strings never appear here."
    },

    "provider_run_kind": {
      "type": "string",
      "enum": [
        "workflow_run",
        "job_run",
        "step_run",
        "check_run",
        "deployment_run",
        "release_run"
      ],
      "description": "Closed run-kind vocabulary."
    },

    "target_ref_class": {
      "type": "string",
      "enum": [
        "branch_target",
        "tag_target",
        "commit_digest_target",
        "pull_request_target",
        "release_tag_target",
        "scheduled_target_no_ref",
        "manual_dispatch_no_ref",
        "unknown_target_class"
      ],
      "description": "Closed target-ref class vocabulary."
    },

    "target_ref_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_ref_class"],
      "properties": {
        "target_ref_class": { "$ref": "#/$defs/target_ref_class" },
        "branch_ref": { "$ref": "#/$defs/opaque_id" },
        "tag_ref": { "$ref": "#/$defs/opaque_id" },
        "commit_digest_ref": { "$ref": "#/$defs/opaque_id" },
        "pull_request_ref": { "$ref": "#/$defs/opaque_id" },
        "release_tag_ref": { "$ref": "#/$defs/opaque_id" },
        "target_ref_label": { "$ref": "#/$defs/redaction_aware_label" }
      },
      "description": "Target-ref identity for the row. Raw branch URLs, raw commit URLs, raw PR URLs, raw release URLs, and raw author email addresses never appear here."
    },

    "status_class": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "cancelled",
        "action_required",
        "skipped",
        "neutral",
        "timed_out",
        "unknown_status_provider_owned"
      ],
      "description": "Closed run-status vocabulary. unknown_status_provider_owned MUST NOT be flattened into failed or neutral."
    },

    "duration_value": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "milliseconds"],
          "properties": {
            "status": { "const": "exact" },
            "milliseconds": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "milliseconds"],
          "properties": {
            "status": { "const": "approximate" },
            "milliseconds": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "const": "unknown" }
          }
        }
      ],
      "description": "Exact / approximate / unknown duration projection for the run."
    },

    "trigger_actor_class": {
      "type": "string",
      "enum": [
        "human_account",
        "install_or_bot_account",
        "delegated_user",
        "scheduled_trigger",
        "policy_injected_trigger",
        "replayed_trigger",
        "unknown_actor_class"
      ],
      "description": "Closed trigger-actor vocabulary."
    },

    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ],
      "description": "Freshness-class re-exported from the capability-lifecycle and safe-preview contracts."
    },

    "origin_class": {
      "type": "string",
      "enum": [
        "live_provider_overlay",
        "cached_provider_overlay",
        "replayed_import",
        "imported_snapshot",
        "support_packet_import"
      ],
      "description": "Closed origin-class vocabulary. Only live_provider_overlay may claim authoritative_live freshness and the running status."
    },

    "count_value": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "value"],
          "properties": {
            "status": { "const": "exact" },
            "value": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "value"],
          "properties": {
            "status": { "const": "approximate" },
            "value": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "const": "unknown" }
          }
        }
      ],
      "description": "Exact / approximate / unknown numeric truth."
    },

    "artifact_count_truncation_reason": {
      "type": "string",
      "enum": [
        "not_truncated",
        "client_size_cap",
        "provider_pagination_cap",
        "provider_retention_dropped",
        "policy_redacted",
        "denied_no_artifact_visibility",
        "unknown_truncation_provider_owned"
      ],
      "description": "Closed artifact-count-truncation reason vocabulary. Silent count truncation is non-conforming."
    },

    "artifact_count_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["count_value", "truncation_reason"],
      "properties": {
        "count_value": { "$ref": "#/$defs/count_value" },
        "truncation_reason": { "$ref": "#/$defs/artifact_count_truncation_reason" },
        "disclosed_label": { "$ref": "#/$defs/redaction_aware_label" }
      },
      "description": "Artifact count plus a typed truncation reason if the count was capped."
    },

    "local_truth_authority_class": {
      "type": "string",
      "enum": [
        "local_truth_is_authoritative",
        "provider_overlay_is_authoritative",
        "local_and_provider_disagree_review_required",
        "no_local_correspondent"
      ],
      "description": "Closed local-truth authority vocabulary. Provider overlays remain visibly secondary to local task / debug truth."
    },

    "local_truth_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_truth_authority_class", "local_truth_explanation_label"],
      "properties": {
        "local_truth_authority_class": { "$ref": "#/$defs/local_truth_authority_class" },
        "execution_context_record_ref": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "Local execution-context record this run row composes with. Null when local_truth_authority_class is no_local_correspondent."
        },
        "local_outcome_summary_ref": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "Opaque ref to the local task / debug outcome summary, when known."
        },
        "local_truth_explanation_label": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "description": "Binding between this provider-run row and the corresponding local task / debug execution-context, plus the closed authority verdict and a reviewable explanation. The runs panel, gutter chip, status bar, command palette result, support packet, and AI evidence packet MUST all project the same local_truth_binding for the same pipeline_run_row_id within an import session."
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity_mode", "policy_epoch", "trust_state"],
      "properties": {
        "identity_mode": {
          "type": "string",
          "enum": [
            "account_free_local",
            "self_hosted_org",
            "managed_workspace"
          ]
        },
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted"]
        },
        "execution_context_id": { "type": "string", "minLength": 1 }
      },
      "description": "Policy, identity-mode, and trust context the row was minted under. Shared with the live-set and provider-event contracts."
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ],
      "description": "Redaction class re-exported from other boundary contracts."
    },

    "scope_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "id"],
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "workspace",
            "window",
            "review_workspace",
            "remote_session",
            "tenant",
            "companion_surface"
          ]
        },
        "id": { "$ref": "#/$defs/opaque_id" }
      },
      "description": "Typed scope the row belongs to."
    },

    "pipeline_run_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "pipeline_run_row_schema_version",
        "pipeline_run_row_id",
        "scope_ref",
        "provider_identity",
        "provider_run_kind",
        "workflow_or_job_label",
        "target_ref_identity",
        "status_class",
        "duration",
        "trigger_actor_class",
        "freshness_class",
        "origin_class",
        "artifact_count_disclosure",
        "local_truth_binding",
        "policy_context",
        "redaction_class",
        "row_summary_label",
        "minted_at"
      ],
      "properties": {
        "$schema": { "$ref": "#/$defs/instance_schema_hint" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "pipeline_run_row_record" },
        "pipeline_run_row_schema_version": {
          "$ref": "#/$defs/pipeline_run_row_schema_version"
        },
        "pipeline_run_row_id": { "$ref": "#/$defs/opaque_id" },
        "scope_ref": { "$ref": "#/$defs/scope_ref" },
        "provider_identity": { "$ref": "#/$defs/provider_identity" },
        "provider_run_kind": { "$ref": "#/$defs/provider_run_kind" },
        "workflow_or_job_label": { "$ref": "#/$defs/redaction_aware_label" },
        "step_label": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/redaction_aware_label" }
          ],
          "description": "Optional step label when provider_run_kind is step_run; null otherwise."
        },
        "target_ref_identity": { "$ref": "#/$defs/target_ref_identity" },
        "status_class": { "$ref": "#/$defs/status_class" },
        "status_explanation_label": { "$ref": "#/$defs/reviewable_sentence" },
        "duration": { "$ref": "#/$defs/duration_value" },
        "trigger_actor_class": { "$ref": "#/$defs/trigger_actor_class" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "origin_class": { "$ref": "#/$defs/origin_class" },
        "artifact_count_disclosure": { "$ref": "#/$defs/artifact_count_disclosure" },
        "local_truth_binding": { "$ref": "#/$defs/local_truth_binding" },
        "provider_event_ref": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "Reference to the provider_event_record this row was minted from. Required (non-null) when origin_class is live_provider_overlay or cached_provider_overlay; MAY be null otherwise."
        },
        "import_session_ref": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "Reference to the import_session_record. Required (non-null) when origin_class is replayed_import, imported_snapshot, or support_packet_import; MAY be null otherwise."
        },
        "replay_record_ref": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "Reference to a webhook_replay_record. Required (non-null) when origin_class is replayed_import."
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "row_summary_label": { "$ref": "#/$defs/reviewable_sentence" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "freshness_observed_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Only live_provider_overlay may claim authoritative_live freshness.",
          "if": {
            "type": "object",
            "required": ["origin_class"],
            "properties": {
              "origin_class": {
                "enum": [
                  "cached_provider_overlay",
                  "replayed_import",
                  "imported_snapshot",
                  "support_packet_import"
                ]
              }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "freshness_class": {
                "not": { "const": "authoritative_live" }
              }
            }
          }
        },
        {
          "description": "Only live_provider_overlay may claim status_class = running.",
          "if": {
            "type": "object",
            "required": ["origin_class"],
            "properties": {
              "origin_class": {
                "enum": [
                  "cached_provider_overlay",
                  "replayed_import",
                  "imported_snapshot",
                  "support_packet_import"
                ]
              }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "status_class": {
                "not": { "const": "running" }
              }
            }
          }
        },
        {
          "description": "Live and cached overlay rows MUST cite a provider_event_ref.",
          "if": {
            "type": "object",
            "required": ["origin_class"],
            "properties": {
              "origin_class": {
                "enum": ["live_provider_overlay", "cached_provider_overlay"]
              }
            }
          },
          "then": {
            "type": "object",
            "required": ["provider_event_ref"],
            "properties": {
              "provider_event_ref": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "description": "Replayed-import rows MUST cite a replay_record_ref and an import_session_ref.",
          "if": {
            "type": "object",
            "required": ["origin_class"],
            "properties": {
              "origin_class": { "const": "replayed_import" }
            }
          },
          "then": {
            "type": "object",
            "required": ["replay_record_ref", "import_session_ref"],
            "properties": {
              "replay_record_ref": { "type": "string", "minLength": 1 },
              "import_session_ref": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "description": "Imported-snapshot and support-packet rows MUST cite an import_session_ref.",
          "if": {
            "type": "object",
            "required": ["origin_class"],
            "properties": {
              "origin_class": {
                "enum": ["imported_snapshot", "support_packet_import"]
              }
            }
          },
          "then": {
            "type": "object",
            "required": ["import_session_ref"],
            "properties": {
              "import_session_ref": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "description": "no_local_correspondent MUST leave execution_context_record_ref null.",
          "if": {
            "type": "object",
            "properties": {
              "local_truth_binding": {
                "type": "object",
                "required": ["local_truth_authority_class"],
                "properties": {
                  "local_truth_authority_class": { "const": "no_local_correspondent" }
                }
              }
            },
            "required": ["local_truth_binding"]
          },
          "then": {
            "type": "object",
            "properties": {
              "local_truth_binding": {
                "type": "object",
                "required": ["execution_context_record_ref"],
                "properties": {
                  "execution_context_record_ref": { "type": "null" }
                }
              }
            }
          }
        },
        {
          "description": "local_truth_is_authoritative and local_and_provider_disagree_review_required MUST cite an execution_context_record_ref.",
          "if": {
            "type": "object",
            "properties": {
              "local_truth_binding": {
                "type": "object",
                "required": ["local_truth_authority_class"],
                "properties": {
                  "local_truth_authority_class": {
                    "enum": [
                      "local_truth_is_authoritative",
                      "local_and_provider_disagree_review_required"
                    ]
                  }
                }
              }
            },
            "required": ["local_truth_binding"]
          },
          "then": {
            "type": "object",
            "properties": {
              "local_truth_binding": {
                "type": "object",
                "required": ["execution_context_record_ref"],
                "properties": {
                  "execution_context_record_ref": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        },
        {
          "description": "step_run kinds MUST carry a non-null step_label.",
          "if": {
            "type": "object",
            "required": ["provider_run_kind"],
            "properties": {
              "provider_run_kind": { "const": "step_run" }
            }
          },
          "then": {
            "type": "object",
            "required": ["step_label"],
            "properties": {
              "step_label": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    }
  }
}
