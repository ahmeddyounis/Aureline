{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/notebooks/output_include_policy.schema.json",
  "title": "Aureline notebook output include policy",
  "description": "Boundary schema for notebook_output_include_policy_record, the notebook-specific inclusion truth layer frozen in docs/notebooks/output_viewer_truth_contract.md. The record explains whether notebook output is embedded, omitted, summarized, truncated, detached, metadata-only, policy-blocked, widget-blocked, or unavailable for notebook save, copy, export, report, artifact-share, detached snapshot, automation evidence, or support capture. The record preserves reproducibility and support-review impact without carrying raw notebook JSON bodies, raw cell source bytes, raw output bytes, raw widget state, raw kernel protocol frames, raw absolute paths, raw URLs, raw hostnames, raw cookies, or raw credential material.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/notebook_output_include_policy_record" }
  ],
  "$defs": {
    "output_include_policy_schema_version": {
      "type": "integer",
      "const": 1
    },

    "record_kind": {
      "type": "string",
      "const": "notebook_output_include_policy_record"
    },

    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque ref to another boundary record or registry entry. Raw bodies, paths, URLs, hostnames, and secrets are forbidden."
    },

    "nullable_opaque_ref": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },

    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 640,
      "description": "Reviewer-facing redaction-aware label."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },

    "nullable_non_negative_integer": {
      "oneOf": [
        { "$ref": "#/$defs/non_negative_integer" },
        { "type": "null" }
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "support_bundle_scoped",
        "operator_only_restricted",
        "internal_support_restricted",
        "raw_payload_forbidden"
      ]
    },

    "destination_class": {
      "type": "string",
      "enum": [
        "notebook_file_save",
        "paired_text_export",
        "clean_notebook_export",
        "report_export",
        "artifact_share_bundle",
        "support_bundle",
        "clipboard_copy",
        "detached_viewer_snapshot",
        "automation_evidence_packet"
      ],
      "description": "Destination resolving the include decision. A decision admitted for one destination is not reusable for another destination without recomputing this record."
    },

    "output_scope_class": {
      "type": "string",
      "enum": [
        "whole_notebook",
        "cell",
        "output",
        "output_group",
        "variable_explorer",
        "detached_viewer",
        "report_section",
        "support_capture"
      ]
    },

    "include_decision_class": {
      "type": "string",
      "enum": [
        "include_full_payload",
        "include_metadata_only",
        "include_summary",
        "include_truncated_payload",
        "include_detached_reference",
        "exclude_by_default",
        "exclude_by_user_choice",
        "exclude_by_policy",
        "exclude_widget_not_trusted",
        "exclude_unavailable"
      ],
      "description": "Closed include/exclude decision vocabulary. Every output leaving or not leaving the product resolves one value."
    },

    "include_reason_class": {
      "type": "string",
      "enum": [
        "user_selected_full_payload",
        "default_safe_metadata",
        "safe_small_output_default",
        "too_large_for_destination",
        "active_content_blocked",
        "widget_runtime_untrusted",
        "support_minimized_scope",
        "policy_redaction",
        "raw_payload_forbidden",
        "reproducibility_requires_metadata",
        "unavailable_no_kernel_or_artifact",
        "orphaned_no_kernel_binding",
        "stale_or_replayed_evidence_only"
      ]
    },

    "payload_representation_class": {
      "type": "string",
      "enum": [
        "native_mime_bundle",
        "typed_table",
        "sanitized_html",
        "static_media",
        "media_proxy_thumbnail",
        "textual_fallback",
        "raw_fallback_metadata_only",
        "summary_markdown",
        "detached_artifact_ref",
        "provenance_only",
        "no_payload"
      ],
      "description": "Representation that is embedded or referenced by the destination. Raw payloads are represented by refs only."
    },

    "freshness_export_class": {
      "type": "string",
      "enum": [
        "live_snapshot_at_capture",
        "captured_prior_session",
        "stale_evidence",
        "replayed_evidence",
        "orphaned_evidence",
        "widget_blocked_static_only",
        "unavailable_metadata_only",
        "intentionally_omitted"
      ]
    },

    "size_bucket": {
      "type": "string",
      "enum": [
        "tiny",
        "small",
        "medium",
        "large",
        "very_large",
        "unbounded_stream",
        "unknown"
      ]
    },

    "byte_count_status_class": {
      "type": "string",
      "enum": [
        "exact",
        "estimated",
        "unknown",
        "omitted"
      ]
    },

    "truncation_class": {
      "type": "string",
      "enum": [
        "no_truncation",
        "row_windowed",
        "column_windowed",
        "byte_truncated",
        "cell_truncated",
        "sampled_summary",
        "media_proxy_only",
        "provider_or_kernel_cap",
        "policy_redacted",
        "not_applicable_no_payload"
      ]
    },

    "reproducibility_impact_class": {
      "type": "string",
      "enum": [
        "reproduce_from_source_and_context",
        "review_exact_payload_with_lineage",
        "review_limited_metadata_only",
        "review_limited_summary_only",
        "review_limited_truncated_payload",
        "review_requires_detached_artifact",
        "not_reproducible_payload_omitted",
        "not_reproducible_widget_live_state_missing",
        "not_reproducible_context_unavailable"
      ]
    },

    "support_visibility_class": {
      "type": "string",
      "enum": [
        "support_can_inspect_payload",
        "support_can_inspect_summary",
        "support_can_inspect_metadata_only",
        "support_must_resolve_detached_artifact",
        "support_blocked_by_policy",
        "support_blocked_unavailable"
      ]
    },

    "lineage_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "notebook_document_ref",
        "cell_id_ref",
        "output_id_ref",
        "output_viewer_state_ref"
      ],
      "properties": {
        "notebook_document_ref": { "$ref": "#/$defs/opaque_ref" },
        "cell_id_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "output_id_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "output_viewer_state_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "output_lineage_record_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "kernel_session_id_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "cell_execution_id_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "execution_context_record_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "widget_trust_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "detached_artifact_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },

    "size_and_truncation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "original_size_bucket",
        "exported_size_bucket",
        "original_byte_count_status",
        "original_byte_count",
        "exported_byte_count",
        "truncation_class",
        "preserves_truncation_disclosure"
      ],
      "properties": {
        "original_size_bucket": { "$ref": "#/$defs/size_bucket" },
        "exported_size_bucket": { "$ref": "#/$defs/size_bucket" },
        "original_byte_count_status": { "$ref": "#/$defs/byte_count_status_class" },
        "original_byte_count": { "$ref": "#/$defs/nullable_non_negative_integer" },
        "exported_byte_count": { "$ref": "#/$defs/nullable_non_negative_integer" },
        "row_count_original": { "$ref": "#/$defs/nullable_non_negative_integer" },
        "row_count_exported": { "$ref": "#/$defs/nullable_non_negative_integer" },
        "truncation_class": { "$ref": "#/$defs/truncation_class" },
        "preserves_truncation_disclosure": { "type": "boolean" },
        "summary_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "size_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },

    "reproducibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reproducibility_impact_class",
        "context_refs_preserved",
        "output_payload_preserved",
        "label"
      ],
      "properties": {
        "reproducibility_impact_class": { "$ref": "#/$defs/reproducibility_impact_class" },
        "context_refs_preserved": { "type": "boolean" },
        "output_payload_preserved": { "type": "boolean" },
        "environment_fingerprint_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "data_snapshot_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "label": { "$ref": "#/$defs/reviewable_label" }
      }
    },

    "support_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_visibility_class",
        "redaction_profile_ref",
        "label"
      ],
      "properties": {
        "support_visibility_class": { "$ref": "#/$defs/support_visibility_class" },
        "redaction_profile_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "support_bundle_scope_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "retention_policy_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "label": { "$ref": "#/$defs/reviewable_label" }
      }
    },

    "notebook_output_include_policy_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "output_include_policy_schema_version",
        "include_policy_id",
        "destination_class",
        "output_scope_class",
        "include_decision_class",
        "include_reason_class",
        "payload_representation_class",
        "freshness_export_class",
        "lineage_refs",
        "size_and_truncation",
        "reproducibility",
        "support_review",
        "reviewer_disclosure_label",
        "audit_event_refs",
        "redaction_class",
        "decided_at"
      ],
      "properties": {
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "output_include_policy_schema_version": { "$ref": "#/$defs/output_include_policy_schema_version" },
        "include_policy_id": { "$ref": "#/$defs/opaque_ref" },
        "destination_class": { "$ref": "#/$defs/destination_class" },
        "output_scope_class": { "$ref": "#/$defs/output_scope_class" },
        "include_decision_class": { "$ref": "#/$defs/include_decision_class" },
        "include_reason_class": { "$ref": "#/$defs/include_reason_class" },
        "payload_representation_class": { "$ref": "#/$defs/payload_representation_class" },
        "freshness_export_class": { "$ref": "#/$defs/freshness_export_class" },
        "lineage_refs": { "$ref": "#/$defs/lineage_refs" },
        "size_and_truncation": { "$ref": "#/$defs/size_and_truncation" },
        "reproducibility": { "$ref": "#/$defs/reproducibility" },
        "support_review": { "$ref": "#/$defs/support_review" },
        "reviewer_disclosure_label": { "$ref": "#/$defs/reviewable_label" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "decided_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Full payload inclusion must preserve output payload and use a real payload representation.",
          "if": {
            "properties": {
              "include_decision_class": { "const": "include_full_payload" }
            },
            "required": ["include_decision_class"]
          },
          "then": {
            "properties": {
              "payload_representation_class": {
                "not": {
                  "enum": [
                    "provenance_only",
                    "no_payload",
                    "raw_fallback_metadata_only"
                  ]
                }
              },
              "size_and_truncation": {
                "properties": {
                  "truncation_class": { "const": "no_truncation" },
                  "preserves_truncation_disclosure": { "const": true }
                }
              },
              "reproducibility": {
                "properties": {
                  "output_payload_preserved": { "const": true }
                }
              }
            }
          }
        },
        {
          "description": "Metadata-only inclusion carries provenance only and no payload bytes.",
          "if": {
            "properties": {
              "include_decision_class": { "const": "include_metadata_only" }
            },
            "required": ["include_decision_class"]
          },
          "then": {
            "properties": {
              "payload_representation_class": { "const": "provenance_only" },
              "size_and_truncation": {
                "properties": {
                  "truncation_class": { "const": "not_applicable_no_payload" }
                }
              },
              "reproducibility": {
                "properties": {
                  "output_payload_preserved": { "const": false }
                }
              }
            }
          }
        },
        {
          "description": "Truncated payload inclusion must preserve truncation disclosure.",
          "if": {
            "properties": {
              "include_decision_class": { "const": "include_truncated_payload" }
            },
            "required": ["include_decision_class"]
          },
          "then": {
            "properties": {
              "size_and_truncation": {
                "properties": {
                  "truncation_class": {
                    "not": { "const": "no_truncation" }
                  },
                  "preserves_truncation_disclosure": { "const": true }
                }
              },
              "reproducibility": {
                "properties": {
                  "reproducibility_impact_class": { "const": "review_limited_truncated_payload" }
                }
              }
            }
          }
        },
        {
          "description": "Detached-reference inclusion must cite a detached artifact ref.",
          "if": {
            "properties": {
              "include_decision_class": { "const": "include_detached_reference" }
            },
            "required": ["include_decision_class"]
          },
          "then": {
            "properties": {
              "payload_representation_class": { "const": "detached_artifact_ref" },
              "lineage_refs": {
                "properties": {
                  "detached_artifact_ref": { "$ref": "#/$defs/opaque_ref" }
                }
              },
              "support_review": {
                "properties": {
                  "support_visibility_class": { "const": "support_must_resolve_detached_artifact" }
                }
              }
            }
          }
        },
        {
          "description": "Excluded decisions carry no payload.",
          "if": {
            "properties": {
              "include_decision_class": {
                "enum": [
                  "exclude_by_default",
                  "exclude_by_user_choice",
                  "exclude_by_policy",
                  "exclude_widget_not_trusted",
                  "exclude_unavailable"
                ]
              }
            },
            "required": ["include_decision_class"]
          },
          "then": {
            "properties": {
              "payload_representation_class": { "const": "no_payload" },
              "size_and_truncation": {
                "properties": {
                  "truncation_class": { "const": "not_applicable_no_payload" }
                }
              },
              "reproducibility": {
                "properties": {
                  "output_payload_preserved": { "const": false }
                }
              }
            }
          }
        },
        {
          "description": "Policy exclusions are visible to support as policy-blocked.",
          "if": {
            "properties": {
              "include_decision_class": { "const": "exclude_by_policy" }
            },
            "required": ["include_decision_class"]
          },
          "then": {
            "properties": {
              "support_review": {
                "properties": {
                  "support_visibility_class": { "const": "support_blocked_by_policy" }
                }
              }
            }
          }
        },
        {
          "description": "Unavailable exclusions preserve unavailable freshness.",
          "if": {
            "properties": {
              "include_decision_class": { "const": "exclude_unavailable" }
            },
            "required": ["include_decision_class"]
          },
          "then": {
            "properties": {
              "freshness_export_class": { "const": "unavailable_metadata_only" },
              "support_review": {
                "properties": {
                  "support_visibility_class": { "const": "support_blocked_unavailable" }
                }
              }
            }
          }
        },
        {
          "description": "Widget-not-trusted exclusions preserve widget blocked freshness.",
          "if": {
            "properties": {
              "include_decision_class": { "const": "exclude_widget_not_trusted" }
            },
            "required": ["include_decision_class"]
          },
          "then": {
            "properties": {
              "freshness_export_class": { "const": "widget_blocked_static_only" }
            }
          }
        }
      ]
    }
  }
}
