{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/contracts/example_pack_index.schema.json",
  "title": "Aureline reference contract example pack index",
  "description": "Boundary schema for artifacts/contracts/example_pack_index.yaml. The index enumerates reference and supplemental example payloads for Aureline's contract-bearing schemas so implementers, documentation, CI validation, and support reproduction can share one canonical map of example sources. The index is metadata-only: payload bytes live in fixtures/ and are validated against their own boundary schemas after stripping fixture-only metadata keys ($schema, __fixture__).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "status",
    "as_of",
    "overview_page",
    "redaction_rules_page",
    "schema_ref",
    "families",
    "examples"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "pack_id": { "type": "string", "minLength": 1 },
    "status": { "$ref": "#/$defs/status_class" },
    "as_of": { "type": "string", "format": "date" },
    "overview_page": { "$ref": "#/$defs/path_ref" },
    "redaction_rules_page": { "$ref": "#/$defs/path_ref" },
    "schema_ref": { "$ref": "#/$defs/path_ref" },
    "example_roots": {
      "type": "array",
      "items": { "$ref": "#/$defs/path_ref" },
      "uniqueItems": true,
      "description": "Repo-relative directories that commonly host example payloads in this pack."
    },
    "families": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/family_row" }
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/example_row" }
    }
  },
  "$defs": {
    "path_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Repo-relative path reference. Consumers treat it as opaque text."
    },
    "stable_token": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Stable lower_snake identifier."
    },
    "status_class": {
      "type": "string",
      "enum": ["seeded", "in_progress", "complete"]
    },
    "maturity_lane": {
      "type": "string",
      "enum": ["stable", "beta", "experimental", "internal"]
    },
    "priority_class": {
      "type": "string",
      "enum": ["launch_critical", "beta_gate", "stable_gate", "nice_to_have"]
    },
    "family_status": {
      "type": "string",
      "enum": ["seeded", "placeholder", "needs_examples", "blocked_on_schema"]
    },
    "owner_dri": {
      "type": "string",
      "minLength": 1,
      "description": "Owner handle (for example @name)."
    },
    "fidelity_class": {
      "type": "string",
      "enum": ["canonical", "intentionally_partial", "redacted", "deprecated", "illustrative_only"],
      "description": "Declares how consumers may interpret the payload. canonical is the preferred example shape; intentionally_partial omits optional sections deliberately; redacted removes or replaces sensitive fields; deprecated captures historical or legacy shapes; illustrative_only is for narrative-only shape sketches."
    },
    "validation_gate": {
      "type": "string",
      "enum": ["ci_required", "ci_optional", "placeholder"],
      "description": "ci_required examples must validate against schema_ref under tools/validate_contract_example_pack.py. ci_optional examples are referenced but not a hard gate."
    },
    "payload_format": {
      "type": "string",
      "enum": ["json", "yaml"]
    },
    "family_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_id",
        "title",
        "summary",
        "owner_dri",
        "owner_lane",
        "maturity_lane",
        "priority_class",
        "status",
        "example_ids"
      ],
      "properties": {
        "family_id": { "$ref": "#/$defs/stable_token" },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "owner_dri": { "$ref": "#/$defs/owner_dri" },
        "owner_lane": { "$ref": "#/$defs/stable_token" },
        "maturity_lane": { "$ref": "#/$defs/maturity_lane" },
        "priority_class": { "$ref": "#/$defs/priority_class" },
        "status": { "$ref": "#/$defs/family_status" },
        "schema_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/path_ref" },
          "uniqueItems": true
        },
        "primary_doc_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/path_ref" },
          "uniqueItems": true
        },
        "example_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "notes": { "type": "string" }
      }
    },
    "example_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "example_id",
        "family_id",
        "title",
        "scenario",
        "payload_ref",
        "schema_ref",
        "payload_format",
        "fidelity_class",
        "validation_gate"
      ],
      "properties": {
        "example_id": { "type": "string", "minLength": 1 },
        "family_id": { "$ref": "#/$defs/stable_token" },
        "title": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "payload_ref": { "$ref": "#/$defs/path_ref" },
        "schema_ref": { "$ref": "#/$defs/path_ref" },
        "payload_format": { "$ref": "#/$defs/payload_format" },
        "fidelity_class": { "$ref": "#/$defs/fidelity_class" },
        "validation_gate": { "$ref": "#/$defs/validation_gate" },
        "source_attribution_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/path_ref" },
          "uniqueItems": true
        },
        "redaction_notes": { "type": "string" },
        "deprecated_by_ref": { "type": ["string", "null"] }
      }
    }
  }
}
