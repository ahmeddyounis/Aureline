{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/benchmarks/power_thermal_capture.schema.json",
  "title": "Aureline power and thermal capture record",
  "description": "Boundary schema for the raw power / thermal capture family consumed by docs/perf/power_thermal_methodology.md and tools/perf/power_thermal_audit/. The record freezes the minimum context required to compare two runs on the same reference posture without guessing hardware class, OS image, power source, battery mode, ambient assumptions, efficiency-state transitions, hidden-pane suppression behavior, or worker-budget decisions.",
  "$ref": "#/$defs/power_thermal_capture_record",
  "$defs": {
    "schema_token": {
      "type": "string",
      "const": "aureline.power_thermal_capture.v1"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "string_or_null": {
      "type": [
        "string",
        "null"
      ]
    },
    "non_negative_number": {
      "type": "number",
      "minimum": 0
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "run_context_class": {
      "type": "string",
      "enum": [
        "reference_capture",
        "provisional_capture",
        "self_capture",
        "smoke_subset"
      ]
    },
    "capture_class": {
      "type": "string",
      "enum": [
        "idle_draw",
        "active_interactive_draw",
        "thermal_pressure_transition",
        "hidden_pane_suppression",
        "worker_budget_behavior"
      ]
    },
    "host_platform_class": {
      "type": "string",
      "enum": [
        "macos",
        "linux",
        "windows"
      ]
    },
    "architecture_class": {
      "type": "string",
      "enum": [
        "arm64",
        "x86_64"
      ]
    },
    "power_source_class": {
      "type": "string",
      "enum": [
        "battery",
        "ac"
      ]
    },
    "battery_mode_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "battery_saver_off",
        "os_battery_saver",
        "user_low_power_mode",
        "critical_battery_protection"
      ]
    },
    "efficiency_state_class": {
      "type": "string",
      "enum": [
        "Nominal",
        "EfficiencyAware",
        "ThermalConstrained",
        "ProtectCore",
        "Recovery"
      ]
    },
    "thermal_pressure_class": {
      "type": "string",
      "enum": [
        "nominal",
        "fair",
        "serious",
        "critical",
        "unknown"
      ]
    },
    "work_class": {
      "type": "string",
      "enum": [
        "core_interaction",
        "core_navigation",
        "short_foreground_task",
        "background_knowledge_work",
        "optional_assistance",
        "upload_and_replication"
      ]
    },
    "queue_lane": {
      "type": "string",
      "enum": [
        "foreground",
        "interactive_background",
        "maintenance",
        "provider_overlay",
        "upload_replication"
      ]
    },
    "workload_id": {
      "type": "string",
      "enum": [
        "ai_warmup",
        "speculative_prefetch",
        "upload_transfer",
        "non_essential_animation",
        "indexing_refresh",
        "extension_polling",
        "preview_refresh",
        "graph_enrichment"
      ]
    },
    "workload_action": {
      "type": "string",
      "enum": [
        "admit",
        "throttle",
        "pause",
        "deny",
        "reduce_parallelism",
        "defer",
        "resume",
        "batch"
      ]
    },
    "visibility_state": {
      "type": "string",
      "enum": [
        "visible_focused",
        "visible_background",
        "occluded_window",
        "hidden_tab",
        "collapsed_split",
        "detached_offscreen"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "editor_viewport",
        "terminal_viewport",
        "diff_review_viewport",
        "search_results_viewport",
        "task_log_viewport",
        "preview_viewport",
        "graph_panel"
      ]
    },
    "work_class_count_map": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "core_interaction",
        "core_navigation",
        "short_foreground_task",
        "background_knowledge_work",
        "optional_assistance",
        "upload_and_replication"
      ],
      "properties": {
        "core_interaction": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "core_navigation": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "short_foreground_task": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "background_knowledge_work": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "optional_assistance": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "upload_and_replication": {
          "$ref": "#/$defs/non_negative_integer"
        }
      }
    },
    "surface_sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "surface_class",
        "visibility_state",
        "committed_paint_count",
        "hidden_pane_work",
        "offscreen_suppression_eligible"
      ],
      "properties": {
        "surface_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_class": {
          "$ref": "#/$defs/surface_class"
        },
        "visibility_state": {
          "$ref": "#/$defs/visibility_state"
        },
        "committed_paint_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "hidden_pane_work": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "offscreen_suppression_eligible": {
          "$ref": "#/$defs/non_negative_integer"
        }
      }
    },
    "sample_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "second",
        "efficiency_state",
        "battery_percent",
        "battery_energy_wh",
        "average_system_power_w",
        "hot_path_p95_ms",
        "thermal_pressure",
        "hidden_pane_work",
        "offscreen_suppression_eligible",
        "background_running_by_class",
        "background_queued_by_class",
        "surfaces"
      ],
      "properties": {
        "second": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "efficiency_state": {
          "$ref": "#/$defs/efficiency_state_class"
        },
        "battery_percent": {
          "$ref": "#/$defs/non_negative_number"
        },
        "battery_energy_wh": {
          "$ref": "#/$defs/non_negative_number"
        },
        "average_system_power_w": {
          "$ref": "#/$defs/non_negative_number"
        },
        "hot_path_p95_ms": {
          "$ref": "#/$defs/non_negative_number"
        },
        "thermal_pressure": {
          "$ref": "#/$defs/thermal_pressure_class"
        },
        "hidden_pane_work": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "offscreen_suppression_eligible": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "background_running_by_class": {
          "$ref": "#/$defs/work_class_count_map"
        },
        "background_queued_by_class": {
          "$ref": "#/$defs/work_class_count_map"
        },
        "surfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_sample"
          }
        }
      }
    },
    "timeline_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_second",
        "end_second",
        "state",
        "source",
        "reason"
      ],
      "properties": {
        "start_second": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "end_second": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "state": {
          "$ref": "#/$defs/efficiency_state_class"
        },
        "source": {
          "$ref": "#/$defs/string_or_null"
        },
        "reason": {
          "$ref": "#/$defs/string_or_null"
        }
      }
    },
    "event_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "second",
        "event_id",
        "efficiency_state"
      ],
      "properties": {
        "second": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "event_id": {
          "type": "string",
          "enum": [
            "capture_start",
            "efficiency_state_transition",
            "workload_budget_decision",
            "capture_end"
          ]
        },
        "efficiency_state": {
          "$ref": "#/$defs/efficiency_state_class"
        },
        "from_state": {
          "anyOf": [
            {
              "$ref": "#/$defs/efficiency_state_class"
            },
            {
              "type": "null"
            }
          ]
        },
        "to_state": {
          "anyOf": [
            {
              "$ref": "#/$defs/efficiency_state_class"
            },
            {
              "type": "null"
            }
          ]
        },
        "source": {
          "$ref": "#/$defs/string_or_null"
        },
        "reason": {
          "$ref": "#/$defs/string_or_null"
        },
        "context_present": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "workload_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/workload_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "work_class": {
          "anyOf": [
            {
              "$ref": "#/$defs/work_class"
            },
            {
              "type": "null"
            }
          ]
        },
        "queue_lane": {
          "anyOf": [
            {
              "$ref": "#/$defs/queue_lane"
            },
            {
              "type": "null"
            }
          ]
        },
        "action": {
          "anyOf": [
            {
              "$ref": "#/$defs/workload_action"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "expected_workloads_by_state": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "EfficiencyAware": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workload_id"
          }
        },
        "ThermalConstrained": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workload_id"
          }
        },
        "ProtectCore": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workload_id"
          }
        }
      }
    },
    "policy_expectations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transition_settle_window_seconds",
        "expected_workloads_by_state",
        "provisional_budget_refs"
      ],
      "properties": {
        "transition_settle_window_seconds": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "expected_workloads_by_state": {
          "$ref": "#/$defs/expected_workloads_by_state"
        },
        "provisional_budget_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "host_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "host_platform_class",
        "architecture_class",
        "os_image_id",
        "os_version_label"
      ],
      "properties": {
        "host_platform_class": {
          "$ref": "#/$defs/host_platform_class"
        },
        "architecture_class": {
          "$ref": "#/$defs/architecture_class"
        },
        "os_image_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "os_version_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "environment_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "power_source",
        "battery_mode",
        "user_power_mode",
        "charger_wattage",
        "display_brightness_nits",
        "display_refresh_hz",
        "network_profile",
        "ambient_temperature_c",
        "ambient_tolerance_c",
        "initial_battery_percent",
        "final_battery_percent",
        "initial_battery_energy_wh",
        "final_battery_energy_wh"
      ],
      "properties": {
        "power_source": {
          "$ref": "#/$defs/power_source_class"
        },
        "battery_mode": {
          "$ref": "#/$defs/battery_mode_class"
        },
        "user_power_mode": {
          "$ref": "#/$defs/non_empty_string"
        },
        "charger_wattage": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "display_brightness_nits": {
          "$ref": "#/$defs/non_negative_number"
        },
        "display_refresh_hz": {
          "$ref": "#/$defs/non_negative_number"
        },
        "network_profile": {
          "$ref": "#/$defs/non_empty_string"
        },
        "ambient_temperature_c": {
          "$ref": "#/$defs/non_negative_number"
        },
        "ambient_tolerance_c": {
          "$ref": "#/$defs/non_negative_number"
        },
        "initial_battery_percent": {
          "$ref": "#/$defs/non_negative_number"
        },
        "final_battery_percent": {
          "$ref": "#/$defs/non_negative_number"
        },
        "initial_battery_energy_wh": {
          "$ref": "#/$defs/non_negative_number"
        },
        "final_battery_energy_wh": {
          "$ref": "#/$defs/non_negative_number"
        }
      }
    },
    "power_thermal_capture_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "schema_version",
        "record_kind",
        "capture_id",
        "methodology_ref",
        "reference_profile_id",
        "reference_profile_revision",
        "reference_posture_id",
        "run_context_class",
        "capture_class",
        "scenario_id",
        "measured_at",
        "duration_seconds",
        "build_identity_ref",
        "corpus_refs",
        "host",
        "environment",
        "policy_expectations",
        "efficiency_state_timeline",
        "samples",
        "events"
      ],
      "properties": {
        "schema": {
          "$ref": "#/$defs/schema_token"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "record_kind": {
          "type": "string",
          "const": "power_thermal_capture_record"
        },
        "capture_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "methodology_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reference_profile_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reference_profile_revision": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "reference_posture_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "run_context_class": {
          "$ref": "#/$defs/run_context_class"
        },
        "capture_class": {
          "$ref": "#/$defs/capture_class"
        },
        "scenario_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "measured_at": {
          "$ref": "#/$defs/non_empty_string"
        },
        "duration_seconds": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "build_identity_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "corpus_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "host": {
          "$ref": "#/$defs/host_record"
        },
        "environment": {
          "$ref": "#/$defs/environment_record"
        },
        "policy_expectations": {
          "$ref": "#/$defs/policy_expectations"
        },
        "efficiency_state_timeline": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/timeline_record"
          }
        },
        "samples": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sample_record"
          }
        },
        "events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/event_record"
          }
        },
        "notes": {
          "$ref": "#/$defs/string_or_null"
        }
      }
    }
  }
}
