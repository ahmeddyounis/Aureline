{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/contexts/host_identity_chip.schema.json",
  "title": "Aureline host identity chip, path-truth presentation, and boundary-change banner record",
  "description": "Boundary schema for the host_identity_chip_record frozen in docs/ux/host_identity_contract.md. The record keeps logical object identity, actual host class, physical host/path basis, route truth, host lineage, boundary-change banners, copy-path and run-here action labels, accessibility cues, surface projections, and export receipt metadata aligned across shell, terminal, task/debug, notebook, AI evidence, preview, history, and export surfaces. Raw hostnames, raw IP addresses, raw ports, raw tokens, raw secret values, raw callback bodies, raw command lines, and unrestricted absolute paths never cross this boundary; records carry privacy-safe labels, opaque refs, handles, and controlled tokens.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "host_identity_chip_schema_version",
    "chip_id",
    "captured_at",
    "logical_object",
    "host_identity",
    "path_truth",
    "route_truth",
    "lineage",
    "actions",
    "surface_projections",
    "accessibility",
    "narrative_refs"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "__fixture__": {
      "$ref": "#/$defs/fixture_metadata"
    },
    "record_kind": {
      "type": "string",
      "const": "host_identity_chip_record"
    },
    "host_identity_chip_schema_version": {
      "$ref": "#/$defs/schema_version"
    },
    "chip_id": {
      "$ref": "#/$defs/opaque_id"
    },
    "captured_at": {
      "$ref": "#/$defs/monotonic_timestamp"
    },
    "logical_object": {
      "$ref": "#/$defs/logical_object"
    },
    "host_identity": {
      "$ref": "#/$defs/host_identity"
    },
    "path_truth": {
      "$ref": "#/$defs/path_truth"
    },
    "route_truth": {
      "$ref": "#/$defs/route_truth"
    },
    "lineage": {
      "$ref": "#/$defs/lineage"
    },
    "boundary_change_banner": {
      "oneOf": [
        { "$ref": "#/$defs/boundary_change_banner" },
        { "type": "null" }
      ]
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/host_action" },
      "minItems": 2
    },
    "surface_projections": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_projection" },
      "minItems": 9
    },
    "accessibility": {
      "$ref": "#/$defs/accessibility"
    },
    "export_receipt": {
      "oneOf": [
        { "$ref": "#/$defs/export_receipt" },
        { "type": "null" }
      ]
    },
    "narrative_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_ref" },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lineage": {
            "properties": {
              "boundary_change_kind": {
                "enum": [
                  "reconnect",
                  "failover",
                  "operator_host_switch",
                  "route_changed",
                  "tenant_changed",
                  "path_changed"
                ]
              }
            },
            "required": ["boundary_change_kind"]
          }
        },
        "required": ["lineage"]
      },
      "then": {
        "properties": {
          "boundary_change_banner": { "$ref": "#/$defs/boundary_change_banner" }
        },
        "required": ["boundary_change_banner"]
      }
    },
    {
      "properties": {
        "actions": {
          "contains": {
            "type": "object",
            "properties": {
              "action_kind": { "const": "copy_path" }
            },
            "required": ["action_kind"]
          }
        }
      }
    },
    {
      "properties": {
        "actions": {
          "contains": {
            "type": "object",
            "properties": {
              "action_kind": { "const": "run_here" }
            },
            "required": ["action_kind"]
          }
        }
      }
    },
    { "$ref": "#/$defs/required_surface_title_context_bar" },
    { "$ref": "#/$defs/required_surface_terminal_header" },
    { "$ref": "#/$defs/required_surface_task_launcher" },
    { "$ref": "#/$defs/required_surface_debug_launcher" },
    { "$ref": "#/$defs/required_surface_notebook_kernel" },
    { "$ref": "#/$defs/required_surface_ai_evidence" },
    { "$ref": "#/$defs/required_surface_preview_strip" },
    { "$ref": "#/$defs/required_surface_history_row" },
    { "$ref": "#/$defs/required_surface_export_receipt" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Document-level schema version. Additive optional fields or enum values bump this const when fixture payloads change; repurposing a value is breaking."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "linked_docs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "description": "Opaque stable id safe for logs, support bundles, and fixtures. Raw paths, hostnames, URLs, ports, tokens, and payload bodies never appear here."
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 320,
      "description": "Opaque ref to an owning record, registry row, path-truth packet, route packet, authority ticket, execution context, or export receipt."
    },
    "nullable_opaque_ref": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },
    "short_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "description": "Privacy-safe display label. Raw hostnames, raw IP addresses, raw account handles, raw ports, raw tokens, and unrestricted absolute paths do not appear."
    },
    "summary_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 560,
      "description": "Short privacy-safe sentence for live UI, history, or export review."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 UTC timestamp captured from the shell or execution monotonic event timeline."
    },
    "host_class": {
      "type": "string",
      "enum": [
        "local_desktop",
        "remote_host",
        "container_devcontainer",
        "managed_workspace",
        "browser_runtime_bridge",
        "service_plane",
        "unknown_requires_review"
      ]
    },
    "host_state_class": {
      "type": "string",
      "enum": [
        "ready",
        "warming",
        "probing",
        "reconnecting",
        "read_only_degraded",
        "offline",
        "failover_pending",
        "failover_complete",
        "operator_switch_pending",
        "route_changed",
        "tenant_changed",
        "path_changed",
        "policy_blocked",
        "unknown_requires_review"
      ]
    },
    "target_class": {
      "type": "string",
      "enum": [
        "local_host",
        "ssh_remote",
        "container_local",
        "devcontainer",
        "remote_workspace_vm",
        "managed_workspace",
        "notebook_kernel_local",
        "notebook_kernel_remote",
        "ai_sandbox",
        "browser_runtime",
        "service_plane",
        "unknown_requires_review"
      ]
    },
    "host_boundary_cue_class": {
      "type": "string",
      "enum": [
        "local_host_boundary",
        "user_mode_sandbox_boundary",
        "container_kernel_boundary",
        "devcontainer_boundary",
        "remote_ssh_boundary",
        "remote_agent_boundary",
        "managed_workspace_boundary",
        "notebook_kernel_boundary",
        "ai_sandbox_boundary",
        "browser_handoff_return_boundary",
        "bridged_host_boundary"
      ]
    },
    "logical_object_class": {
      "type": "string",
      "enum": [
        "workspace_root",
        "workspace",
        "workset",
        "terminal_session",
        "task_run",
        "debug_session",
        "notebook_kernel",
        "ai_evidence_packet",
        "preview_route",
        "export_receipt",
        "service_operation"
      ]
    },
    "path_basis_class": {
      "type": "string",
      "enum": [
        "local_filesystem_path",
        "remote_filesystem_path",
        "container_mount_path",
        "managed_workspace_path",
        "browser_origin_uri",
        "service_plane_object_handle",
        "redacted_path_receipt",
        "unknown_requires_review"
      ]
    },
    "path_redaction_class": {
      "type": "string",
      "enum": [
        "display_safe",
        "workspace_relative_only",
        "opaque_handle_only",
        "operator_only_restricted",
        "redacted_for_export"
      ]
    },
    "route_change_reason_code": {
      "type": "string",
      "enum": [
        "canonical_no_route_change",
        "route_escalated_to_approval_required",
        "route_escalated_to_browser_handoff",
        "route_escalated_to_publish_pipeline",
        "route_escalated_to_tunnel_exposure",
        "route_changed_target_unreachable",
        "route_changed_target_reassigned",
        "route_changed_policy_narrowed",
        "route_changed_authority_escalation",
        "route_changed_wrong_target_detected",
        "route_changed_approval_withdrawn",
        "route_changed_freshness_floor_unmet",
        "route_changed_host_mismatch",
        "route_unknown_requires_review"
      ]
    },
    "action_origin_class": {
      "type": "string",
      "enum": [
        "user_keystroke_local",
        "user_voice_or_gesture_local",
        "cli_invocation_local",
        "ai_tool_call_local",
        "ai_tool_call_managed",
        "recipe_or_automation_local",
        "extension_host_local",
        "remote_agent_request",
        "managed_control_plane_request",
        "provider_callback_inbound",
        "webhook_inbound",
        "scheduled_trigger",
        "supervisor_repair_origin",
        "import_or_restore_session",
        "unknown_origin_class"
      ]
    },
    "action_target_class": {
      "type": "string",
      "enum": [
        "local_host_target",
        "user_mode_sandbox_target",
        "container_local_target",
        "devcontainer_target",
        "remote_ssh_target",
        "remote_agent_target",
        "managed_workspace_target",
        "notebook_kernel_local_target",
        "notebook_kernel_remote_target",
        "ai_sandbox_target",
        "connected_provider_target",
        "embedded_webview_target",
        "system_browser_target",
        "native_os_callback_target",
        "publish_release_target",
        "tunnel_exposed_target",
        "bridged_helper_target",
        "unknown_target_class"
      ]
    },
    "action_route_class": {
      "type": "string",
      "enum": [
        "in_process_route",
        "local_rpc_route",
        "remote_rpc_route",
        "managed_control_plane_route",
        "remote_agent_attach_route",
        "approval_gated_route",
        "browser_handoff_route",
        "embedded_webview_route",
        "native_callback_route",
        "provider_webhook_return_route",
        "publish_pipeline_route",
        "tunnel_exposed_route",
        "mirror_or_private_registry_route",
        "bridged_helper_route",
        "heuristic_unknown_route"
      ]
    },
    "action_exposure_class": {
      "type": "string",
      "enum": [
        "no_side_effect_local_read",
        "local_only_mutation",
        "workspace_visible_mutation",
        "provider_visible_mutation",
        "publicly_visible_publish",
        "cross_tenant_visible",
        "third_party_callback_visible",
        "browser_session_visible",
        "tunnel_exposed_public",
        "exposure_unknown_requires_review"
      ]
    },
    "authority_linkage_class": {
      "type": "string",
      "enum": [
        "no_authority_required_read_only",
        "local_user_keystroke_authority",
        "approval_ticket_linked",
        "browser_handoff_packet_linked",
        "publish_evidence_packet_linked",
        "remote_agent_attach_ticket_linked",
        "managed_control_plane_token_linked",
        "policy_injected_service_identity_linked",
        "supervisor_repair_ticket_linked",
        "authority_missing_denied"
      ]
    },
    "boundary_change_kind": {
      "type": "string",
      "enum": [
        "none",
        "reconnect",
        "failover",
        "operator_host_switch",
        "route_changed",
        "tenant_changed",
        "path_changed"
      ]
    },
    "user_impact_class": {
      "type": "string",
      "enum": [
        "no_user_visible_impact",
        "local_work_continues_remote_narrowed",
        "read_only_until_revalidated",
        "rerun_required",
        "terminal_state_lost",
        "kernel_reattach_required",
        "ports_reopen_required",
        "writes_blocked_pending_review",
        "export_history_only",
        "unknown_requires_review"
      ]
    },
    "action_kind": {
      "type": "string",
      "enum": [
        "copy_path",
        "run_here",
        "reveal_location",
        "open_host_details",
        "open_path_truth_details",
        "retry_reconnect",
        "review_boundary_change",
        "open_export_receipt",
        "copy_export_receipt",
        "no_action_required"
      ]
    },
    "action_state": {
      "type": "string",
      "enum": [
        "enabled",
        "requires_confirmation",
        "disabled_read_only",
        "disabled_policy",
        "disabled_unknown_host",
        "disabled_unavailable"
      ]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "title_context_bar",
        "terminal_header",
        "task_launcher",
        "debug_launcher",
        "notebook_kernel",
        "ai_evidence",
        "preview_strip",
        "history_row",
        "export_receipt"
      ]
    },
    "field_path": {
      "type": "string",
      "enum": [
        "logical_object.display_label",
        "logical_object.object_class",
        "host_identity.host_class",
        "host_identity.host_state",
        "host_identity.host_display_label",
        "host_identity.host_boundary_cue_stack",
        "path_truth.presentation_path_label",
        "path_truth.physical_path_label",
        "path_truth.path_basis",
        "route_truth.action_origin_class",
        "route_truth.action_target_class",
        "route_truth.action_route_class",
        "route_truth.action_exposure_class",
        "route_truth.route_change_reason_code",
        "route_truth.authority_linkage_class",
        "route_truth.tenant_or_org_label",
        "lineage.boundary_change_kind",
        "lineage.prior_host_label",
        "lineage.current_host_label",
        "boundary_change_banner.summary",
        "actions.copy_path",
        "actions.run_here"
      ]
    },
    "logical_object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_class",
        "object_ref",
        "display_label",
        "workspace_ref",
        "root_ref",
        "logical_path_or_uri_label"
      ],
      "properties": {
        "object_class": { "$ref": "#/$defs/logical_object_class" },
        "object_ref": { "$ref": "#/$defs/opaque_ref" },
        "display_label": { "$ref": "#/$defs/short_label" },
        "workspace_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "root_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "logical_path_or_uri_label": { "$ref": "#/$defs/short_label" },
        "source_evidence_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "host_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "host_class",
        "host_state",
        "target_class",
        "host_ref",
        "host_display_label",
        "host_boundary_cue_stack",
        "lifecycle_label"
      ],
      "properties": {
        "host_class": { "$ref": "#/$defs/host_class" },
        "host_state": { "$ref": "#/$defs/host_state_class" },
        "target_class": { "$ref": "#/$defs/target_class" },
        "host_ref": { "$ref": "#/$defs/opaque_ref" },
        "host_display_label": { "$ref": "#/$defs/short_label" },
        "host_boundary_cue_stack": {
          "type": "array",
          "items": { "$ref": "#/$defs/host_boundary_cue_class" },
          "minItems": 1,
          "uniqueItems": true
        },
        "lifecycle_label": { "$ref": "#/$defs/short_label" },
        "reachability_state_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "managed_lifecycle_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "path_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_basis",
        "presentation_path_label",
        "physical_path_label",
        "path_handle_ref",
        "path_truth_record_ref",
        "redaction_class",
        "canonical_differs_from_presentation"
      ],
      "properties": {
        "path_basis": { "$ref": "#/$defs/path_basis_class" },
        "presentation_path_label": { "$ref": "#/$defs/short_label" },
        "physical_path_label": { "$ref": "#/$defs/short_label" },
        "path_handle_ref": { "$ref": "#/$defs/opaque_ref" },
        "path_truth_record_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "redaction_class": { "$ref": "#/$defs/path_redaction_class" },
        "canonical_differs_from_presentation": { "type": "boolean" },
        "copy_representation_label": { "$ref": "#/$defs/short_label" },
        "reveal_action_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "authority_linkage_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_ticket_ref",
        "browser_handoff_packet_ref",
        "publish_evidence_packet_ref",
        "remote_agent_attach_ticket_ref",
        "managed_control_plane_token_ref",
        "policy_injected_service_identity_ref",
        "supervisor_repair_ticket_ref"
      ],
      "properties": {
        "approval_ticket_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "browser_handoff_packet_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "publish_evidence_packet_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "remote_agent_attach_ticket_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "managed_control_plane_token_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "policy_injected_service_identity_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "supervisor_repair_ticket_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "route_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_truth_ref",
        "invocation_session_ref",
        "execution_context_ref",
        "action_origin_class",
        "action_target_class",
        "action_route_class",
        "action_exposure_class",
        "route_change_reason_code",
        "authority_linkage_class",
        "authority_linkage_ref",
        "tenant_or_org_label",
        "exposure_summary"
      ],
      "properties": {
        "route_truth_ref": { "$ref": "#/$defs/opaque_ref" },
        "invocation_session_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "execution_context_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "action_origin_class": { "$ref": "#/$defs/action_origin_class" },
        "action_target_class": { "$ref": "#/$defs/action_target_class" },
        "action_route_class": { "$ref": "#/$defs/action_route_class" },
        "action_exposure_class": { "$ref": "#/$defs/action_exposure_class" },
        "route_change_reason_code": { "$ref": "#/$defs/route_change_reason_code" },
        "authority_linkage_class": { "$ref": "#/$defs/authority_linkage_class" },
        "authority_linkage_ref": { "$ref": "#/$defs/authority_linkage_ref" },
        "tenant_or_org_label": { "$ref": "#/$defs/short_label" },
        "exposure_summary": { "$ref": "#/$defs/summary_text" },
        "repair_hook_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "boundary_change_kind",
        "lineage_event_ref",
        "prior_host_ref",
        "prior_host_label",
        "current_host_ref",
        "current_host_label",
        "prior_path_handle_ref",
        "current_path_handle_ref",
        "history_event_ref",
        "export_event_ref",
        "transition_explainable"
      ],
      "properties": {
        "boundary_change_kind": { "$ref": "#/$defs/boundary_change_kind" },
        "lineage_event_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "prior_host_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "prior_host_label": {
          "oneOf": [
            { "$ref": "#/$defs/short_label" },
            { "type": "null" }
          ]
        },
        "current_host_ref": { "$ref": "#/$defs/opaque_ref" },
        "current_host_label": { "$ref": "#/$defs/short_label" },
        "prior_path_handle_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "current_path_handle_ref": { "$ref": "#/$defs/opaque_ref" },
        "history_event_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "export_event_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "transition_explainable": { "type": "boolean", "const": true }
      }
    },
    "boundary_change_banner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "banner_id",
        "change_kind",
        "summary",
        "prior_context_label",
        "current_context_label",
        "user_impact",
        "history_event_ref",
        "export_event_ref",
        "primary_action_ref",
        "secondary_action_refs"
      ],
      "properties": {
        "banner_id": { "$ref": "#/$defs/opaque_id" },
        "change_kind": { "$ref": "#/$defs/boundary_change_kind" },
        "summary": { "$ref": "#/$defs/summary_text" },
        "prior_context_label": { "$ref": "#/$defs/short_label" },
        "current_context_label": { "$ref": "#/$defs/short_label" },
        "user_impact": { "$ref": "#/$defs/user_impact_class" },
        "history_event_ref": { "$ref": "#/$defs/opaque_ref" },
        "export_event_ref": { "$ref": "#/$defs/opaque_ref" },
        "primary_action_ref": { "$ref": "#/$defs/opaque_ref" },
        "secondary_action_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "host_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_ref",
        "action_kind",
        "state",
        "label",
        "confirmation_label",
        "host_ref",
        "path_handle_ref",
        "preserves_host_truth",
        "disabled_reason"
      ],
      "properties": {
        "action_ref": { "$ref": "#/$defs/opaque_ref" },
        "action_kind": { "$ref": "#/$defs/action_kind" },
        "state": { "$ref": "#/$defs/action_state" },
        "label": { "$ref": "#/$defs/short_label" },
        "confirmation_label": { "$ref": "#/$defs/summary_text" },
        "host_ref": { "$ref": "#/$defs/opaque_ref" },
        "path_handle_ref": { "$ref": "#/$defs/opaque_ref" },
        "preserves_host_truth": { "type": "boolean", "const": true },
        "disabled_reason": {
          "oneOf": [
            { "$ref": "#/$defs/summary_text" },
            { "type": "null" }
          ]
        }
      }
    },
    "surface_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "field_paths",
        "visible_label",
        "accessible_name",
        "preserves_canonical_tokens"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/surface_kind" },
        "field_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/field_path" },
          "minItems": 2,
          "uniqueItems": true
        },
        "visible_label": { "$ref": "#/$defs/short_label" },
        "accessible_name": { "$ref": "#/$defs/summary_text" },
        "preserves_canonical_tokens": { "type": "boolean", "const": true }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text_label",
        "accessible_name",
        "icon_token",
        "does_not_rely_on_color",
        "details_action_ref"
      ],
      "properties": {
        "text_label": { "$ref": "#/$defs/short_label" },
        "accessible_name": { "$ref": "#/$defs/summary_text" },
        "icon_token": { "$ref": "#/$defs/short_label" },
        "does_not_rely_on_color": { "type": "boolean", "const": true },
        "details_action_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "export_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_ref",
        "redaction_class",
        "includes_host_lineage",
        "includes_boundary_change",
        "summary"
      ],
      "properties": {
        "receipt_ref": { "$ref": "#/$defs/opaque_ref" },
        "redaction_class": { "$ref": "#/$defs/path_redaction_class" },
        "includes_host_lineage": { "type": "boolean", "const": true },
        "includes_boundary_change": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/summary_text" }
      }
    },
    "required_surface_title_context_bar": {
