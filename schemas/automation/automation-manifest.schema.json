{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/automation/automation-manifest.schema.json",
  "title": "Aureline safe automation manifest and qualification packet",
  "description": "Boundary schema for safe automation labels, manifest rows, and command-surface actions. It covers recorded macros, workspace recipes, extension recipes, admin or curated recipe packs, and ephemeral generated recipes without graduating a broad recipe runner. The schema keeps command labels, manifest fields, preview policy, provenance, lifecycle gating, and support-safe export posture in one typed contract.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/safe_automation_qualification_packet" },
    { "$ref": "#/$defs/automation_class_manifest_row" }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "record_kind": {
      "type": "string",
      "const": "safe_automation_qualification_packet"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "controlled_automation_label": {
      "type": "string",
      "enum": [
        "macro_safe",
        "recipe_safe",
        "headless_safe",
        "ui_only",
        "approval_required",
        "writes_files",
        "runs_process",
        "network_call",
        "remote_mutation",
        "unknown_automation_support"
      ]
    },
    "automation_object_class": {
      "type": "string",
      "enum": [
        "recorded_macro",
        "workspace_recipe",
        "extension_recipe",
        "admin_curated_recipe_pack",
        "ephemeral_ai_generated_recipe"
      ]
    },
    "storage_form": {
      "type": "string",
      "enum": [
        "local_user_artifact",
        "versioned_text_manifest",
        "signed_extension_package_manifest",
        "signed_policy_bundle",
        "transient_generated_plan",
        "support_safe_projection"
      ]
    },
    "required_capability": {
      "type": "string",
      "enum": [
        "editor_review_state_replay",
        "workspace_read",
        "filesystem_write",
        "process_launch",
        "network_access",
        "remote_target_access",
        "ai_tool_invocation",
        "secret_handle_reference",
        "admin_policy_mutation",
        "extension_invocation"
      ]
    },
    "trust_requirement": {
      "type": "string",
      "enum": [
        "local_only",
        "trusted_workspace",
        "signed_source",
        "admin_allowlist",
        "extension_permission_envelope",
        "policy_provided"
      ]
    },
    "preview_policy": {
      "type": "string",
      "enum": [
        "no_mutation_preview_not_applicable",
        "checkpoint_required_before_replay",
        "displayable_plan_required_before_mutation",
        "dry_run_required_before_apply",
        "diff_preview_required",
        "impact_summary_required",
        "non_simulatable_step_must_explain"
      ]
    },
    "idempotency_hint": {
      "type": "string",
      "enum": [
        "deterministic_given_same_target_context",
        "retry_requires_fresh_context_resolution",
        "retry_requires_reconciliation_receipt",
        "non_idempotent_requires_explicit_review"
      ]
    },
    "provenance": {
      "type": "string",
      "enum": [
        "user_recorded",
        "workspace_authored",
        "extension_publisher",
        "admin_curated_signer",
        "ai_evidence_packet",
        "support_redacted_export"
      ]
    },
    "lifecycle_label": {
      "type": "string",
      "enum": [
        "stable_qualified",
        "stable_labels_only_narrowed_runner",
        "labs_only",
        "preview_only",
        "dependency_gated",
        "denied_for_stable"
      ]
    },
    "artifact_authority": {
      "type": "string",
      "enum": [
        "local_only",
        "signed_artifact",
        "policy_provided",
        "support_projection_only"
      ]
    },
    "surface_action": {
      "type": "string",
      "enum": [
        "add_to_recipe",
        "inspect_descriptor",
        "replay_as_macro"
      ]
    },
    "automation_class_manifest_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_class",
        "storage_form",
        "required_capabilities",
        "trust_requirement",
        "preview_policy",
        "idempotency_hint",
        "provenance",
        "lifecycle_label",
        "artifact_authority",
        "scope_narrower_than_stable",
        "deterministic_replay_boundary",
        "forbids_raw_secret_capture",
        "forbids_undeclared_network_or_process_access",
        "forbids_hidden_authority",
        "edit_history_checkpoint_required",
        "claimed_stable"
      ],
      "properties": {
        "object_class": { "$ref": "#/$defs/automation_object_class" },
        "storage_form": { "$ref": "#/$defs/storage_form" },
        "required_capabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/required_capability" }
        },
        "trust_requirement": { "$ref": "#/$defs/trust_requirement" },
        "preview_policy": { "$ref": "#/$defs/preview_policy" },
        "idempotency_hint": { "$ref": "#/$defs/idempotency_hint" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "lifecycle_label": { "$ref": "#/$defs/lifecycle_label" },
        "artifact_authority": { "$ref": "#/$defs/artifact_authority" },
        "scope_narrower_than_stable": { "type": "boolean" },
        "deterministic_replay_boundary": { "type": "boolean", "const": true },
        "forbids_raw_secret_capture": { "type": "boolean", "const": true },
        "forbids_undeclared_network_or_process_access": { "type": "boolean", "const": true },
        "forbids_hidden_authority": { "type": "boolean", "const": true },
        "edit_history_checkpoint_required": { "type": "boolean" },
        "claimed_stable": { "type": "boolean" },
        "proof_or_dependency_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "object_class": { "const": "recorded_macro" } },
            "required": ["object_class"]
          },
          "then": {
            "properties": {
              "storage_form": { "const": "local_user_artifact" },
              "trust_requirement": { "const": "local_only" },
              "preview_policy": { "const": "checkpoint_required_before_replay" },
              "edit_history_checkpoint_required": { "const": true },
              "required_capabilities": {
                "items": {
                  "enum": ["editor_review_state_replay", "workspace_read"]
                }
              }
            }
          }
        },
        {
          "if": {
            "not": {
              "properties": { "object_class": { "const": "recorded_macro" } },
              "required": ["object_class"]
            }
          },
          "then": {
            "properties": {
              "claimed_stable": { "const": false },
              "lifecycle_label": {
                "enum": [
                  "stable_labels_only_narrowed_runner",
                  "labs_only",
                  "preview_only",
                  "dependency_gated",
                  "denied_for_stable"
                ]
              }
            },
            "required": ["proof_or_dependency_ref"]
          }
        }
      ]
    },
    "surface_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_class",
        "required_labels",
        "backing_manifest_fields",
        "lifecycle_ceiling",
        "insertion_or_inspection_only",
        "consumes_command_descriptor",
        "consumes_preview_policy",
        "no_saved_artifact_captures_secrets",
        "no_undeclared_network_or_process_access",
        "no_hidden_authority",
        "deterministic_replay_boundary_preserved",
        "claimed_stable"
      ],
      "properties": {
        "action_class": { "$ref": "#/$defs/surface_action" },
        "required_labels": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/controlled_automation_label" }
        },
        "backing_manifest_fields": {
          "type": "array",
          "minItems": 7,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/non_empty_string" },
          "contains": { "const": "required_capabilities" }
        },
        "lifecycle_ceiling": { "$ref": "#/$defs/lifecycle_label" },
        "insertion_or_inspection_only": { "type": "boolean" },
        "consumes_command_descriptor": { "type": "boolean", "const": true },
        "consumes_preview_policy": { "type": "boolean", "const": true },
        "no_saved_artifact_captures_secrets": { "type": "boolean", "const": true },
        "no_undeclared_network_or_process_access": { "type": "boolean", "const": true },
        "no_hidden_authority": { "type": "boolean", "const": true },
        "deterministic_replay_boundary_preserved": { "type": "boolean", "const": true },
        "claimed_stable": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "action_class": { "const": "add_to_recipe" } },
            "required": ["action_class"]
          },
          "then": {
            "properties": {
              "required_labels": { "contains": { "const": "recipe_safe" } },
              "insertion_or_inspection_only": { "const": true }
            }
          }
        },
        {
          "if": {
            "properties": { "action_class": { "const": "replay_as_macro" } },
            "required": ["action_class"]
          },
          "then": {
            "properties": {
              "required_labels": { "contains": { "const": "macro_safe" } }
            }
          }
        }
      ]
    },
    "export_import_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "distinguishes_local_signed_policy_artifacts",
        "support_safe_projection_only",
        "strips_raw_secrets_and_prompts",
        "preserves_deterministic_replay_boundaries",
        "import_revalidates_trust_and_policy",
        "preserves_manifest_identity_refs",
        "prevents_authority_downgrade_on_import"
      ],
      "properties": {
        "distinguishes_local_signed_policy_artifacts": { "type": "boolean", "const": true },
        "support_safe_projection_only": { "type": "boolean", "const": true },
        "strips_raw_secrets_and_prompts": { "type": "boolean", "const": true },
        "preserves_deterministic_replay_boundaries": { "type": "boolean", "const": true },
        "import_revalidates_trust_and_policy": { "type": "boolean", "const": true },
        "preserves_manifest_identity_refs": { "type": "boolean", "const": true },
        "prevents_authority_downgrade_on_import": { "type": "boolean", "const": true }
      }
    },
    "evidence_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "support_export_ref",
        "matrix_ref",
        "schema_ref",
        "preview_lifecycle_doc_ref"
      ],
      "properties": {
        "evidence_id": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "const": "artifacts/automation/m4/safe_automation_qualification/support_export.json" },
        "matrix_ref": { "const": "artifacts/automation/m4/safe-automation-matrix.md" },
        "schema_ref": { "const": "schemas/automation/automation-manifest.schema.json" },
        "preview_lifecycle_doc_ref": { "const": "docs/automation/preview-and-lifecycle.md" }
      }
    },
    "safe_automation_qualification_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "claimed_stable_label_truth",
        "policy_epoch_ref",
        "controlled_labels",
        "automation_classes",
        "surface_contracts",
        "export_import_contract",
        "evidence_export",
        "source_contract_refs",
        "redaction_class_token",
        "minted_at"
      ],
      "properties": {
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "claimed_stable_label_truth": { "type": "boolean", "const": true },
        "policy_epoch_ref": { "$ref": "#/$defs/non_empty_string" },
        "controlled_labels": {
          "type": "array",
          "minItems": 9,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/controlled_automation_label" }
        },
        "automation_classes": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/automation_class_manifest_row" }
        },
        "surface_contracts": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/surface_contract" }
        },
        "export_import_contract": { "$ref": "#/$defs/export_import_contract" },
        "evidence_export": { "$ref": "#/$defs/evidence_export" },
        "source_contract_refs": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/non_empty_string" },
          "contains": { "const": "docs/automation/preview-and-lifecycle.md" }
        },
        "redaction_class_token": { "$ref": "#/$defs/non_empty_string" },
        "minted_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
