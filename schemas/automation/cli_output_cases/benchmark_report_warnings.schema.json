{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/automation/cli_output_cases/benchmark_report_warnings.schema.json",
  "title": "Aureline benchmark.report_emit warnings payload",
  "description": "Schema for the warnings payload emitted when benchmark.report_emit completes with partial_success_with_warnings.",
  "type": "array",
  "items": { "$ref": "#/$defs/benchmark_warning" },
  "$defs": {
    "benchmark_warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["warning_code", "affected_iteration_refs", "reason_ref", "repair_hook_ref"],
      "properties": {
        "warning_code": { "type": "string", "minLength": 1 },
        "affected_iteration_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "reason_ref": { "type": "string", "minLength": 1 },
        "repair_hook_ref": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        }
      }
    }
  }
}
