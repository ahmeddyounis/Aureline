{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/automation/cli_output_cases/benchmark_report_junit_adapter.schema.json",
  "title": "Aureline benchmark.report_emit JUnit adapter sketch",
  "description": "Schema for the JUnit XML adapter sketch emitted by the benchmark.report_emit CLI surface. This is a contract for Aureline's stable projection (refs and stable fields), not a full JUnit validator.",
  "type": "object",
  "additionalProperties": false,
  "required": ["testsuites_ref", "testsuite_refs", "testcase_refs", "properties_ref"],
  "properties": {
    "testsuites_ref": { "type": "string", "minLength": 1 },
    "testsuite_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "testcase_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "properties_ref": { "type": "string", "minLength": 1 }
  }
}
