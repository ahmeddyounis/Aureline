{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/automation/cli_output_cases/workspace_open_folder_payload.schema.json",
  "title": "Aureline workspace.open_folder CLI machine payload",
  "description": "Schema for the primary machine-output payload emitted by the CLI/headless workspace.open_folder surface. The payload is consumed by automation and support tooling; it carries opaque refs and closed vocabulary only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cli_output_payload_schema_version",
    "record_kind",
    "command_id",
    "command_revision_ref",
    "invocation_session_id",
    "outcome_class",
    "applied",
    "planned_but_not_applied",
    "warnings",
    "minted_at"
  ],
  "properties": {
    "cli_output_payload_schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "workspace_open_folder_cli_result" },
    "command_id": { "type": "string", "minLength": 1 },
    "command_revision_ref": { "type": "string", "minLength": 1 },
    "invocation_session_id": { "type": "string", "minLength": 1 },
    "outcome_class": {
      "type": "string",
      "enum": [
        "success",
        "policy_or_trust_denied",
        "dry_run_would_have_applied",
        "cancelled_by_user",
        "input_validation_error",
        "usage_error",
        "unrecoverable_internal_error"
      ]
    },
    "applied": { "type": "boolean" },
    "planned_but_not_applied": { "type": "boolean" },
    "opened_workspace_scope_ref": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "effective_profile_ref": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "effective_trust_state_class": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "policy_context_class": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "redaction_class": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "planned_effect_summary_ref": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "planned_workspace_scope_ref": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "planned_profile_ref": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "denial": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["reason_code", "owner_boundary_class", "explanation_ref", "repair_hook_ref", "successor_command_id"],
          "properties": {
            "reason_code": { "type": "string", "minLength": 1 },
            "owner_boundary_class": { "type": "string", "minLength": 1 },
            "explanation_ref": { "type": "string", "minLength": 1 },
            "repair_hook_ref": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "minLength": 1 }
              ]
            },
            "successor_command_id": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "minLength": 1 }
              ]
            }
          }
        }
      ]
    },
    "warnings": {
      "type": "array",
      "items": { "type": "object" }
    },
    "minted_at": { "type": "string", "format": "date-time" }
  }
}
