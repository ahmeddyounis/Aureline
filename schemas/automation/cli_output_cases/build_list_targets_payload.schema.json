{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/automation/cli_output_cases/build_list_targets_payload.schema.json",
  "title": "Aureline build.list_targets CLI machine payload",
  "description": "Schema for the primary machine-output payload emitted by the CLI/headless build.list_targets surface. The payload lists discovered build targets and their reproducibility posture.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cli_output_payload_schema_version",
    "record_kind",
    "command_id",
    "command_revision_ref",
    "invocation_session_id",
    "outcome_class",
    "warnings",
    "minted_at"
  ],
  "properties": {
    "cli_output_payload_schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "build_list_targets_cli_result" },
    "command_id": { "type": "string", "minLength": 1 },
    "command_revision_ref": { "type": "string", "minLength": 1 },
    "invocation_session_id": { "type": "string", "minLength": 1 },
    "outcome_class": {
      "type": "string",
      "enum": [
        "success",
        "usage_error",
        "input_validation_error",
        "policy_or_trust_denied",
        "dependency_missing_or_stale",
        "network_or_remote_unavailable",
        "unrecoverable_internal_error"
      ]
    },
    "workspace_scope_ref": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "nondeterminism_disclosure_class": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "order_declaration_ref": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "discovered_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target_ref", "target_kind_class", "declared_dependencies_refs", "reproducibility_posture_class", "package_group_ref"],
        "properties": {
          "target_ref": { "type": "string", "minLength": 1 },
          "target_kind_class": { "type": "string", "minLength": 1 },
          "declared_dependencies_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "reproducibility_posture_class": { "type": "string", "minLength": 1 },
          "package_group_ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    "denial": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["reason_code", "owner_boundary_class", "explanation_ref", "repair_hook_ref", "successor_command_id"],
          "properties": {
            "reason_code": { "type": "string", "minLength": 1 },
            "owner_boundary_class": { "type": "string", "minLength": 1 },
            "explanation_ref": { "type": "string", "minLength": 1 },
            "repair_hook_ref": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "minLength": 1 }
              ]
            },
            "successor_command_id": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "minLength": 1 }
              ]
            }
          }
        }
      ]
    },
    "warnings": {
      "type": "array",
      "items": { "type": "object" }
    },
    "minted_at": { "type": "string", "format": "date-time" }
  }
}
