{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/automation/cli_output_cases/workspace_open_folder_event_stream.schema.json",
  "title": "Aureline workspace.open_folder CLI NDJSON event stream frame",
  "description": "Schema for one NDJSON frame emitted by the workspace.open_folder CLI event-stream adapter. The stream is a sequence of JSON objects, each validating against exactly one frame shape.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/invocation_started" },
    { "$ref": "#/$defs/trust_revalidation_complete" },
    { "$ref": "#/$defs/invocation_completed" }
  ],
  "$defs": {
    "opaque_id": { "type": "string", "minLength": 1 },
    "monotonic_timestamp": { "type": "string", "format": "date-time" },

    "invocation_started": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cli_event_frame_schema_version",
        "frame_kind",
        "invocation_session_id",
        "command_id",
        "frame_sequence_index",
        "minted_at"
      ],
      "properties": {
        "cli_event_frame_schema_version": { "type": "integer", "const": 1 },
        "frame_kind": { "type": "string", "const": "invocation_started" },
        "invocation_session_id": { "$ref": "#/$defs/opaque_id" },
        "command_id": { "$ref": "#/$defs/opaque_id" },
        "frame_sequence_index": { "type": "integer", "minimum": 0 },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    },

    "trust_revalidation_complete": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cli_event_frame_schema_version",
        "frame_kind",
        "invocation_session_id",
        "effective_trust_state_class",
        "frame_sequence_index",
        "minted_at"
      ],
      "properties": {
        "cli_event_frame_schema_version": { "type": "integer", "const": 1 },
        "frame_kind": { "type": "string", "const": "trust_revalidation_complete" },
        "invocation_session_id": { "$ref": "#/$defs/opaque_id" },
        "effective_trust_state_class": { "$ref": "#/$defs/opaque_id" },
        "frame_sequence_index": { "type": "integer", "minimum": 0 },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    },

    "invocation_completed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cli_event_frame_schema_version",
        "frame_kind",
        "invocation_session_id",
        "outcome_class",
        "numeric_code",
        "frame_sequence_index",
        "minted_at"
      ],
      "properties": {
        "cli_event_frame_schema_version": { "type": "integer", "const": 1 },
        "frame_kind": { "type": "string", "const": "invocation_completed" },
        "invocation_session_id": { "$ref": "#/$defs/opaque_id" },
        "outcome_class": { "$ref": "#/$defs/opaque_id" },
        "numeric_code": { "type": "integer", "minimum": 0, "maximum": 255 },
        "frame_sequence_index": { "type": "integer", "minimum": 0 },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    }
  }
}
