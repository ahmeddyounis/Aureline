{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/automation/cli_output_cases/support_export_bundle_spdx_adapter.schema.json",
  "title": "Aureline support.export_bundle SPDX adapter sketch",
  "description": "Schema for the SPDX adapter sketch emitted by the support.export_bundle CLI surface. This is a contract for the stable projection Aureline exports (refs and stable fields), not a full SPDX 2.3 validator.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spdxVersion",
    "dataLicense",
    "SPDXID",
    "name",
    "documentNamespace_ref",
    "creationInfo",
    "packages_ref",
    "relationships_ref"
  ],
  "properties": {
    "spdxVersion": { "type": "string", "minLength": 1 },
    "dataLicense": { "type": "string", "minLength": 1 },
    "SPDXID": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "documentNamespace_ref": { "type": "string", "minLength": 1 },
    "creationInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created", "creators_ref"],
      "properties": {
        "created": { "type": "string", "format": "date-time" },
        "creators_ref": { "type": "string", "minLength": 1 }
      }
    },
    "packages_ref": { "type": "string", "minLength": 1 },
    "relationships_ref": { "type": "string", "minLength": 1 }
  }
}
