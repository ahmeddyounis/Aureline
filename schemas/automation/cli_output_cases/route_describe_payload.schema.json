{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/automation/cli_output_cases/route_describe_payload.schema.json",
  "title": "Aureline route.describe CLI machine payload",
  "description": "Schema for the primary machine-output payload emitted by the CLI/headless route.describe surface. The payload describes a resolved invocation plan without dispatching the target command.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cli_output_payload_schema_version",
    "record_kind",
    "command_id",
    "command_revision_ref",
    "invocation_session_id",
    "outcome_class",
    "warnings",
    "minted_at"
  ],
  "properties": {
    "cli_output_payload_schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "route_describe_cli_result" },
    "command_id": { "type": "string", "minLength": 1 },
    "command_revision_ref": { "type": "string", "minLength": 1 },
    "invocation_session_id": { "type": "string", "minLength": 1 },
    "outcome_class": {
      "type": "string",
      "enum": [
        "success",
        "input_validation_error",
        "usage_error",
        "unrecoverable_internal_error"
      ]
    },
    "resolved_target_command_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "resolved_command_revision_ref": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "resolved_typed_arguments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["argument_name", "argument_kind", "argument_inspection_kind"],
        "properties": {
          "argument_name": { "type": "string", "minLength": 1 },
          "argument_kind": { "type": "string", "minLength": 1 },
          "argument_inspection_kind": { "type": "string", "minLength": 1 }
        }
      }
    },
    "resolved_gating_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate_class", "decision_class"],
        "properties": {
          "gate_class": { "type": "string", "minLength": 1 },
          "decision_class": { "type": "string", "minLength": 1 }
        }
      }
    },
    "resolved_preview_class": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "resolved_approval_posture_class": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "expected_exit_code_class": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "denial": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["reason_code", "owner_boundary_class", "explanation_ref", "repair_hook_ref", "successor_command_id"],
          "properties": {
            "reason_code": { "type": "string", "minLength": 1 },
            "owner_boundary_class": { "type": "string", "minLength": 1 },
            "explanation_ref": { "type": "string", "minLength": 1 },
            "repair_hook_ref": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "minLength": 1 }
              ]
            },
            "successor_command_id": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "minLength": 1 }
              ]
            }
          }
        }
      ]
    },
    "warnings": {
      "type": "array",
      "items": { "type": "object" }
    },
    "minted_at": { "type": "string", "format": "date-time" }
  }
}
