{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/automation/cli_output_cases/benchmark_report_sarif_adapter.schema.json",
  "title": "Aureline benchmark.report_emit SARIF adapter sketch",
  "description": "Schema for the SARIF adapter sketch emitted by the benchmark.report_emit CLI surface. This is a contract for Aureline's stable projection (refs and stable fields), not a full SARIF validator.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "$schema", "runs_ref", "run_tool_ref", "run_results_ref", "run_invocations_ref"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "$schema": { "type": "string", "minLength": 1 },
    "runs_ref": { "type": "string", "minLength": 1 },
    "run_tool_ref": { "type": "string", "minLength": 1 },
    "run_results_ref": { "type": "string", "minLength": 1 },
    "run_invocations_ref": { "type": "string", "minLength": 1 }
  }
}
