{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/automation/cli_output_cases/build_list_targets_cyclonedx_adapter.schema.json",
  "title": "Aureline build.list_targets CycloneDX adapter sketch",
  "description": "Schema for the CycloneDX SBOM adapter sketch emitted by the build.list_targets CLI surface. This is a contract for Aureline's stable projection (refs and stable fields), not a full CycloneDX validator.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bomFormat",
    "specVersion",
    "version",
    "serialNumber_ref",
    "metadata",
    "components_ref",
    "dependencies_ref"
  ],
  "properties": {
    "bomFormat": { "type": "string", "minLength": 1 },
    "specVersion": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "serialNumber_ref": { "type": "string", "minLength": 1 },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp", "tools_ref", "component_ref"],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "tools_ref": { "type": "string", "minLength": 1 },
        "component_ref": { "type": "string", "minLength": 1 }
      }
    },
    "components_ref": { "type": "string", "minLength": 1 },
    "dependencies_ref": { "type": "string", "minLength": 1 }
  }
}
