{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/automation/cli_output_cases/benchmark_report_payload.schema.json",
  "title": "Aureline benchmark.report_emit CLI machine payload",
  "description": "Schema for the primary machine-output payload emitted by the CLI benchmark/report surface. The payload is written to --out-file and references per-iteration artifacts and metrics.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cli_output_payload_schema_version",
    "record_kind",
    "command_id",
    "command_revision_ref",
    "invocation_session_id",
    "outcome_class",
    "scenario_ref",
    "warnings",
    "minted_at"
  ],
  "properties": {
    "cli_output_payload_schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "benchmark_report_cli_result" },
    "command_id": { "type": "string", "minLength": 1 },
    "command_revision_ref": { "type": "string", "minLength": 1 },
    "invocation_session_id": { "type": "string", "minLength": 1 },
    "outcome_class": {
      "type": "string",
      "enum": [
        "success",
        "partial_success_with_warnings",
        "timeout_or_deadline_exceeded",
        "input_validation_error",
        "usage_error",
        "unrecoverable_internal_error"
      ]
    },
    "scenario_ref": { "type": "string", "minLength": 1 },
    "nondeterminism_disclosure_class": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "host_profile_ref": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "iteration_count": {
      "oneOf": [
        { "type": "null" },
        { "type": "integer", "minimum": 0 }
      ]
    },
    "warmup_iteration_count": {
      "oneOf": [
        { "type": "null" },
        { "type": "integer", "minimum": 0 }
      ]
    },
    "aggregate_metrics": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "wall_time_seconds_p50_ref",
            "wall_time_seconds_p95_ref",
            "wall_time_seconds_p99_ref",
            "throughput_ops_per_second_mean_ref",
            "allocations_per_iteration_mean_ref"
          ],
          "properties": {
            "wall_time_seconds_p50_ref": { "type": "string", "minLength": 1 },
            "wall_time_seconds_p95_ref": { "type": "string", "minLength": 1 },
            "wall_time_seconds_p99_ref": { "type": "string", "minLength": 1 },
            "throughput_ops_per_second_mean_ref": { "type": "string", "minLength": 1 },
            "allocations_per_iteration_mean_ref": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "per_iteration_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "benchmark_report_warnings.schema.json#/$defs/benchmark_warning" }
    },
    "minted_at": { "type": "string", "format": "date-time" }
  }
}
