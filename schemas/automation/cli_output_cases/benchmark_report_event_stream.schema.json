{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/automation/cli_output_cases/benchmark_report_event_stream.schema.json",
  "title": "Aureline benchmark.report_emit CLI NDJSON event stream frame",
  "description": "Schema for one NDJSON frame emitted by the benchmark.report_emit CLI event-stream adapter. The stream is a sequence of JSON objects, each validating against exactly one frame shape.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/benchmark_started" },
    { "$ref": "#/$defs/benchmark_iteration_complete" },
    { "$ref": "#/$defs/benchmark_completed" }
  ],
  "$defs": {
    "opaque_id": { "type": "string", "minLength": 1 },
    "monotonic_timestamp": { "type": "string", "format": "date-time" },

    "benchmark_started": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cli_event_frame_schema_version",
        "frame_kind",
        "invocation_session_id",
        "scenario_ref",
        "frame_sequence_index",
        "minted_at"
      ],
      "properties": {
        "cli_event_frame_schema_version": { "type": "integer", "const": 1 },
        "frame_kind": { "type": "string", "const": "benchmark_started" },
        "invocation_session_id": { "$ref": "#/$defs/opaque_id" },
        "scenario_ref": { "$ref": "#/$defs/opaque_id" },
        "frame_sequence_index": { "type": "integer", "minimum": 0 },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    },

    "benchmark_iteration_complete": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cli_event_frame_schema_version",
        "frame_kind",
        "invocation_session_id",
        "iteration_index",
        "iteration_ref",
        "frame_sequence_index",
        "minted_at"
      ],
      "properties": {
        "cli_event_frame_schema_version": { "type": "integer", "const": 1 },
        "frame_kind": { "type": "string", "const": "benchmark_iteration_complete" },
        "invocation_session_id": { "$ref": "#/$defs/opaque_id" },
        "iteration_index": { "type": "integer", "minimum": 0 },
        "iteration_ref": { "$ref": "#/$defs/opaque_id" },
        "frame_sequence_index": { "type": "integer", "minimum": 0 },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    },

    "benchmark_completed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cli_event_frame_schema_version",
        "frame_kind",
        "invocation_session_id",
        "outcome_class",
        "numeric_code",
        "frame_sequence_index",
        "minted_at"
      ],
      "properties": {
        "cli_event_frame_schema_version": { "type": "integer", "const": 1 },
        "frame_kind": { "type": "string", "const": "benchmark_completed" },
        "invocation_session_id": { "$ref": "#/$defs/opaque_id" },
        "outcome_class": { "$ref": "#/$defs/opaque_id" },
        "numeric_code": { "type": "integer", "minimum": 0, "maximum": 255 },
        "frame_sequence_index": { "type": "integer", "minimum": 0 },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    }
  }
}
