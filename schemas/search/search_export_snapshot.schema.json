{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/search/search_export_snapshot.schema.json",
  "title": "Aureline search export snapshot artifact contract",
  "description": "Boundary schema for captured search collection snapshots exported to support, docs, local replay, review, or governed handoff surfaces. Snapshots carry scope summaries, result refs, source labels, partiality reasons, hidden/omitted counts, destination, privacy, retention, sync, redaction profile, and captured-vs-live semantics. Support and docs exports default to hashes, refs, counts, and partiality reasons rather than literal query text.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/search_collection_snapshot" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "opaque_id": { "type": "string", "minLength": 1 },
    "timestamp_or_fixture_time": { "type": "string", "minLength": 1 },
    "reviewable_reason": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "source_class": {
      "type": "string",
      "enum": [
        "user_authored",
        "repo_provided",
        "policy_provided",
        "team_shared",
        "support_captured",
        "session_history"
      ]
    },
    "privacy_class": {
      "type": "string",
      "enum": [
        "local_only_private",
        "workspace_shared_redacted",
        "support_export_redacted",
        "policy_withheld"
      ]
    },
    "retention_mode": {
      "type": "string",
      "enum": [
        "local_only_default",
        "local_only_ephemeral",
        "workspace_shared_explicit",
        "repo_provided_read_only",
        "policy_owned_managed",
        "support_export_bounded"
      ]
    },
    "sync_class": {
      "type": "string",
      "enum": [
        "local_only",
        "explicit_user_sync",
        "workspace_shared",
        "repo_provided",
        "policy_managed",
        "support_export_only"
      ]
    },
    "redaction_profile": {
      "type": "string",
      "enum": [
        "literal_local_only",
        "hashes_scope_and_result_refs",
        "metadata_only_no_query_material",
        "policy_withheld",
        "explicit_literal_consent"
      ]
    },
    "retention_widening_basis": {
      "type": "string",
      "enum": [
        "not_widened_local_default",
        "explicit_user_opt_in",
        "policy_owned",
        "repo_provided_artifact",
        "team_shared_artifact",
        "support_case_export"
      ]
    },
    "destination": {
      "type": "string",
      "enum": ["local_replay", "support_bundle", "docs_handoff"]
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "current_repo",
        "selected_workset",
        "sparse_slice",
        "full_workspace",
        "policy_limited_view"
      ]
    },
    "result_semantics": {
      "type": "string",
      "enum": [
        "current_live_results",
        "captured_snapshot",
        "live_rerun_required",
        "scope_changed_since_capture",
        "empty_because_scope_changed"
      ]
    },
    "snapshot_truth": {
      "type": "string",
      "enum": [
        "live_rerun",
        "captured_snapshot",
        "scope_changed_since_capture"
      ]
    },
    "count_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "visible_rows",
        "selected_rows",
        "included_rows",
        "omitted_result_count",
        "hidden_by_current_scope_rows",
        "hidden_by_policy_rows",
        "hidden_by_remote_cache_rows",
        "count_is_partial"
      ],
      "properties": {
        "visible_rows": { "type": "integer", "minimum": 0 },
        "selected_rows": { "type": "integer", "minimum": 0 },
        "included_rows": { "type": "integer", "minimum": 0 },
        "omitted_result_count": { "type": "integer", "minimum": 0 },
        "hidden_by_current_scope_rows": { "type": "integer", "minimum": 0 },
        "hidden_by_policy_rows": { "type": "integer", "minimum": 0 },
        "hidden_by_remote_cache_rows": { "type": "integer", "minimum": 0 },
        "count_is_partial": { "type": "boolean" }
      }
    },
    "search_collection_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "snapshot_id",
        "source_class",
        "privacy_class",
        "retention_mode",
        "sync_class",
        "redaction_profile",
        "retention_widening_basis",
        "destination",
        "query_session_id_ref",
        "result_set_id_ref",
        "planner_pass_id_ref",
        "scope_binding_id_ref",
        "scope_class",
        "scope_label",
        "stable_scope_id",
        "selected_result_refs",
        "included_result_refs",
        "result_source_labels",
        "partiality_reasons",
        "count_summary",
        "snapshot_truth",
        "omitted_or_truncated_flags",
        "evidence_refs",
        "result_semantics",
        "scope_honesty_state",
        "current_truth_requires_rerun",
        "literal_query_text_included",
        "created_at"
      ],
      "properties": {
        "record_kind": { "const": "search_collection_snapshot" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "snapshot_id": { "$ref": "#/$defs/opaque_id" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "privacy_class": { "$ref": "#/$defs/privacy_class" },
        "retention_mode": { "$ref": "#/$defs/retention_mode" },
        "sync_class": { "$ref": "#/$defs/sync_class" },
        "redaction_profile": { "$ref": "#/$defs/redaction_profile" },
        "retention_widening_basis": { "$ref": "#/$defs/retention_widening_basis" },
        "destination": { "$ref": "#/$defs/destination" },
        "query_session_id_ref": { "$ref": "#/$defs/opaque_id" },
        "result_set_id_ref": { "$ref": "#/$defs/opaque_id" },
        "planner_pass_id_ref": { "$ref": "#/$defs/opaque_id" },
        "scope_binding_id_ref": { "$ref": "#/$defs/opaque_id" },
        "scope_class": { "$ref": "#/$defs/scope_class" },
        "scope_label": { "type": "string", "minLength": 1 },
        "stable_scope_id": { "$ref": "#/$defs/opaque_id" },
        "selected_result_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "included_result_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "result_source_labels": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "partiality_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_reason" }
        },
        "count_summary": { "$ref": "#/$defs/count_summary" },
        "snapshot_truth": { "$ref": "#/$defs/snapshot_truth" },
        "omitted_or_truncated_flags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/reviewable_reason" }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "result_semantics": { "$ref": "#/$defs/result_semantics" },
        "scope_honesty_state": {
          "type": "string",
          "enum": [
            "captured_scope_still_current",
            "recipient_must_re_resolve",
            "current_scope_wider_narrowed_to_captured",
            "current_scope_narrower_disclosed",
            "current_scope_changed_rebind_required"
          ]
        },
        "current_truth_requires_rerun": { "type": "boolean", "const": true },
        "literal_query_text_included": { "type": "boolean" },
        "query_hash": { "type": "string", "minLength": 1 },
        "created_at": { "$ref": "#/$defs/timestamp_or_fixture_time" }
      }
    }
  }
}
