{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/search/scope_provenance_truth.schema.json",
  "title": "Aureline hidden-scope, partial-scope, archived-item, and imported-provider truth packet",
  "description": "Boundary schema for the stable scope/provenance truth packet shared by search shell, graph topology, docs/help, CLI/headless, support export, and the release proof index.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_item_classes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "scope_provenance_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_item_classes": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/item_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/truth_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "item_class": {
      "enum": [
        "hidden_scope",
        "partial_scope",
        "archived_item",
        "imported_provider"
      ]
    },
    "surface_class": {
      "enum": ["search_row", "graph_node", "graph_edge"]
    },
    "provenance_class": {
      "enum": [
        "workspace_canonical",
        "partial_index_inferred",
        "archive_preserved",
        "imported_provider_derived",
        "heuristic_derived"
      ]
    },
    "freshness_class": {
      "enum": [
        "live",
        "partially_warmed",
        "stale_disclosed",
        "archived_frozen",
        "imported_snapshot",
        "unknown"
      ]
    },
    "downgrade_state": {
      "enum": [
        "canonical",
        "hidden_disclosed",
        "partial_disclosed",
        "archived_disclosed",
        "imported_disclosed"
      ]
    },
    "confidence_class": {
      "enum": ["high", "medium", "low", "heuristic"]
    },
    "imported_outcome_label": {
      "enum": ["exact", "translated", "partial", "shimmed", "unsupported"]
    },
    "consumer_surface": {
      "enum": [
        "search_shell",
        "graph_topology",
        "docs_help",
        "cli_headless",
        "support_export",
        "release_proof_index"
      ]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_item_class_coverage",
        "missing_disclosure_ref",
        "hidden_scope_missing_context",
        "partial_scope_missing_context",
        "archived_missing_context",
        "imported_missing_mapping",
        "imported_missing_diagnostic",
        "imported_missing_rollback",
        "provenance_class_mismatch",
        "downgrade_state_mismatch",
        "non_canonical_presented_as_canonical",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "item_class_vocabulary_collapsed",
        "provenance_vocabulary_dropped",
        "freshness_vocabulary_dropped",
        "downgrade_vocabulary_dropped",
        "imported_outcome_vocabulary_dropped",
        "raw_boundary_material_present",
        "promotion_state_mismatch"
      ]
    },
    "hidden_scope_context": {
      "type": "object",
      "required": ["reason_token", "rule_ref"],
      "properties": {
        "reason_token": { "$ref": "#/$defs/non_empty_string" },
        "rule_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "partial_scope_context": {
      "type": "object",
      "required": ["partial_lane_id", "coverage_percent"],
      "properties": {
        "partial_lane_id": { "$ref": "#/$defs/non_empty_string" },
        "coverage_percent": { "type": "integer", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "archived_context": {
      "type": "object",
      "required": ["archived_at", "archive_register_ref"],
      "properties": {
        "archived_at": { "$ref": "#/$defs/non_empty_string" },
        "archive_register_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "imported_mapping": {
      "type": "object",
      "required": [
        "imported_provider_id",
        "outcome_label",
        "rollback_checkpoint_ref"
      ],
      "properties": {
        "imported_provider_id": { "$ref": "#/$defs/non_empty_string" },
        "outcome_label": { "$ref": "#/$defs/imported_outcome_label" },
        "rollback_checkpoint_ref": { "$ref": "#/$defs/non_empty_string" },
        "mapping_diagnostic_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "truth_row": {
      "type": "object",
      "required": [
        "row_id",
        "item_class",
        "surface_class",
        "workspace_id",
        "scope_ref",
        "provenance_class",
        "freshness_class",
        "downgrade_state",
        "confidence_class",
        "disclosure_ref",
        "raw_boundary_material_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "item_class": { "$ref": "#/$defs/item_class" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "workspace_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_ref": { "$ref": "#/$defs/non_empty_string" },
        "provenance_class": { "$ref": "#/$defs/provenance_class" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "downgrade_state": { "$ref": "#/$defs/downgrade_state" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "hidden_scope_context": { "$ref": "#/$defs/hidden_scope_context" },
        "partial_scope_context": { "$ref": "#/$defs/partial_scope_context" },
        "archived_context": { "$ref": "#/$defs/archived_context" },
        "imported_mapping": { "$ref": "#/$defs/imported_mapping" },
        "raw_boundary_material_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "scope_provenance_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_item_class_vocabulary",
        "preserves_provenance_vocabulary",
        "preserves_freshness_vocabulary",
        "preserves_downgrade_vocabulary",
        "preserves_imported_outcome_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "scope_provenance_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_item_class_vocabulary": { "type": "boolean" },
        "preserves_provenance_vocabulary": { "type": "boolean" },
        "preserves_freshness_vocabulary": { "type": "boolean" },
        "preserves_downgrade_vocabulary": { "type": "boolean" },
        "preserves_imported_outcome_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
