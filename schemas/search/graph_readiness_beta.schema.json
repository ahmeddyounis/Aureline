{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/search/graph_readiness_beta.schema.json",
  "title": "Aureline semantic graph readiness and exact-vs-imported fact label beta",
  "description": "Boundary schema for the graph_readiness_beta_case_record and graph_readiness_beta_report_record consumed by aureline-graph's readiness/beta module. A case record binds one graph consumer surface (navigation, ai_context, review, support_export) to one claimed fact lane drawn from the closed beta vocabulary (exact_local_graph_fact, imported_graph_fact, inferred_graph_fact, partial_graph_fact, stale_graph_fact, waiting_on_graph_provider, out_of_scope_graph_fact, fallback_search_fact), the lane the underlying alpha graph fact cue packet actually observed, the alpha readiness state, the derived claim_alignment_state (aligned, weaker_claim_accepted, overclaim_blocked), a metadata-safe evidence_export projection that preserves the fact lane label, readiness token, and consumer surface, and a closed downgrade_label for failing rows. The report record folds every case into per-fact-lane and per-consumer-surface summaries so support and export pipelines can audit graph-truth labeling without re-reading alpha envelopes.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/graph_readiness_beta_case_record" },
    { "$ref": "#/$defs/graph_readiness_beta_report_record" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "non_empty_string": { "type": "string", "minLength": 1 },
    "reviewable_sentence": { "type": "string", "minLength": 1 },
    "monotonic_timestamp": { "type": "string", "minLength": 1 },
    "consumer_surface": {
      "type": "string",
      "enum": ["navigation", "ai_context", "review", "support_export"]
    },
    "fact_lane": {
      "type": "string",
      "enum": [
        "exact_local_graph_fact",
        "imported_graph_fact",
        "inferred_graph_fact",
        "partial_graph_fact",
        "stale_graph_fact",
        "waiting_on_graph_provider",
        "out_of_scope_graph_fact",
        "fallback_search_fact"
      ]
    },
    "readiness_claim": {
      "type": "string",
      "enum": [
        "ready",
        "hot_set_ready",
        "partial",
        "warming",
        "stale",
        "unavailable",
        "out_of_scope"
      ]
    },
    "claim_alignment_state": {
      "type": "string",
      "enum": ["aligned", "weaker_claim_accepted", "overclaim_blocked"]
    },
    "downgrade_label": {
      "type": "string",
      "enum": [
        "none",
        "red_blocks_beta_row",
        "yellow_fact_lane_partial",
        "yellow_evidence_export_skew",
        "degraded_to_fallback_search_only",
        "stale_corpus_blocks_release_candidate"
      ]
    },
    "open_gap_class": {
      "type": "string",
      "enum": [
        "none",
        "consumer_surface_pending",
        "fact_lane_pending",
        "evidence_export_pending",
        "fallback_truth_only",
        "overclaim_blocked"
      ]
    },
    "open_gap_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gap_class", "summary"],
      "properties": {
        "gap_class": { "$ref": "#/$defs/open_gap_class" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "evidence_export_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preserves_fact_lane_label",
        "preserves_readiness_token",
        "preserves_consumer_surface_label",
        "preserves_envelope_packet_ref",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "preserves_user_authored_files"
      ],
      "properties": {
        "preserves_fact_lane_label": { "type": "boolean", "const": true },
        "preserves_readiness_token": { "type": "boolean", "const": true },
        "preserves_consumer_surface_label": { "type": "boolean", "const": true },
        "preserves_envelope_packet_ref": { "type": "boolean", "const": true },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "ambient_authority_excluded": { "type": "boolean", "const": true },
        "preserves_user_authored_files": { "type": "boolean", "const": true }
      }
    },
    "case_safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "destructive_resets_present",
        "preserves_user_authored_files"
      ],
      "properties": {
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "ambient_authority_excluded": { "type": "boolean", "const": true },
        "destructive_resets_present": { "type": "boolean", "const": false },
        "preserves_user_authored_files": { "type": "boolean", "const": true }
      }
    },
    "case_references": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doc_ref", "schema_ref", "report_ref"],
      "properties": {
        "doc_ref": {
          "type": "string",
          "const": "docs/search/m3/graph_readiness_beta.md"
        },
        "schema_ref": {
          "type": "string",
          "const": "schemas/search/graph_readiness_beta.schema.json"
        },
        "report_ref": {
          "type": "string",
          "const": "artifacts/support/m3/graph_readiness_beta_report.md"
        }
      }
    },
    "graph_readiness_beta_case_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "case_id",
        "title",
        "consumer_surface",
        "subject_ref",
        "envelope_packet_ref",
        "claimed_fact_lane",
        "observed_envelope_lane",
        "observed_readiness",
        "claim_alignment_state",
        "evidence_export",
        "downgrade_label",
        "safety",
        "references",
        "captured_at"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "record_kind": {
          "type": "string",
          "const": "graph_readiness_beta_case_record"
        },
        "case_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "subject_ref": { "$ref": "#/$defs/non_empty_string" },
        "envelope_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "claimed_fact_lane": { "$ref": "#/$defs/fact_lane" },
        "observed_envelope_lane": { "$ref": "#/$defs/fact_lane" },
        "observed_readiness": { "$ref": "#/$defs/readiness_claim" },
        "claim_alignment_state": { "$ref": "#/$defs/claim_alignment_state" },
        "evidence_export": { "$ref": "#/$defs/evidence_export_projection" },
        "downgrade_label": { "$ref": "#/$defs/downgrade_label" },
        "open_gaps": {
          "type": "array",
          "items": { "$ref": "#/$defs/open_gap_entry" }
        },
        "safety": { "$ref": "#/$defs/case_safety" },
        "references": { "$ref": "#/$defs/case_references" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "reviewer_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "report_matrix_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "consumer_surface",
        "subject_ref",
        "claimed_fact_lane",
        "observed_envelope_lane",
        "observed_readiness",
        "claim_alignment_state",
        "downgrade_label",
        "open_gap_classes"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/non_empty_string" },
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "subject_ref": { "$ref": "#/$defs/non_empty_string" },
        "claimed_fact_lane": { "$ref": "#/$defs/fact_lane" },
        "observed_envelope_lane": { "$ref": "#/$defs/fact_lane" },
        "observed_readiness": { "$ref": "#/$defs/readiness_claim" },
        "claim_alignment_state": { "$ref": "#/$defs/claim_alignment_state" },
        "downgrade_label": { "$ref": "#/$defs/downgrade_label" },
        "open_gap_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/open_gap_class" }
        }
      }
    },
    "fact_lane_summary_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fact_lane",
        "case_count",
        "aligned_count",
        "weaker_claim_count",
        "overclaim_blocked_count",
        "downgrade_required_count"
      ],
      "properties": {
        "fact_lane": { "$ref": "#/$defs/fact_lane" },
        "case_count": { "type": "integer", "minimum": 0 },
        "aligned_count": { "type": "integer", "minimum": 0 },
        "weaker_claim_count": { "type": "integer", "minimum": 0 },
        "overclaim_blocked_count": { "type": "integer", "minimum": 0 },
        "downgrade_required_count": { "type": "integer", "minimum": 0 }
      }
    },
    "consumer_surface_summary_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer_surface",
        "case_count",
        "aligned_count",
        "weaker_claim_count",
        "overclaim_blocked_count",
        "downgrade_required_count"
      ],
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "case_count": { "type": "integer", "minimum": 0 },
        "aligned_count": { "type": "integer", "minimum": 0 },
        "weaker_claim_count": { "type": "integer", "minimum": 0 },
        "overclaim_blocked_count": { "type": "integer", "minimum": 0 },
        "downgrade_required_count": { "type": "integer", "minimum": 0 }
      }
    },
    "graph_readiness_beta_report_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "report_id",
        "captured_at",
        "doc_ref",
        "schema_ref",
        "corpus_manifest_ref",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "required_consumer_surfaces",
        "required_fact_lanes",
        "matrix_rows",
        "fact_lane_summaries",
        "consumer_surface_summaries"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "record_kind": {
          "type": "string",
          "const": "graph_readiness_beta_report_record"
        },
        "report_id": { "$ref": "#/$defs/non_empty_string" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "doc_ref": {
          "type": "string",
          "const": "docs/search/m3/graph_readiness_beta.md"
        },
        "schema_ref": {
          "type": "string",
          "const": "schemas/search/graph_readiness_beta.schema.json"
        },
        "corpus_manifest_ref": {
          "type": "string",
          "const": "fixtures/graph/m3/readiness_truth/manifest.yaml"
        },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "ambient_authority_excluded": { "type": "boolean", "const": true },
        "required_consumer_surfaces": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/consumer_surface" }
        },
        "required_fact_lanes": {
          "type": "array",
          "minItems": 8,
          "items": { "$ref": "#/$defs/fact_lane" }
        },
        "matrix_rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/report_matrix_row" }
        },
        "fact_lane_summaries": {
          "type": "array",
          "minItems": 8,
          "items": { "$ref": "#/$defs/fact_lane_summary_row" }
        },
        "consumer_surface_summaries": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/consumer_surface_summary_row" }
        }
      }
    }
  }
}
