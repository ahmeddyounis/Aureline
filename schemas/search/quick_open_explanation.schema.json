{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/search/quick_open_explanation.schema.json",
  "title": "Aureline quick-open same-surface explanation contract",
  "description": "Boundary schema for quick_open_explanation_record, frozen in docs/ux/quick_open_contract.md. Explanation records are opened inside quick open from row reason chips, readiness banners, hidden-result counts, policy chips, provider chips, target/host cues, and keyboard detail commands. They make ranking, hidden counts, policy-blocked counts, provider limits, target truth, scope truth, and focus-return behavior inspectable without leaving quick open.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/quick_open_explanation_record" }
  ],
  "$defs": {
    "quick_open_explanation_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "quick_open_explanation_record"
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "explanation_surface_class": {
      "type": "string",
      "enum": [
        "row_inline",
        "session_banner",
        "hidden_results_detail",
        "policy_detail",
        "provider_detail",
        "ranking_detail",
        "target_detail",
        "focus_detail"
      ]
    },
    "explanation_opened_from_class": {
      "type": "string",
      "enum": [
        "row_reason_chip",
        "scope_banner",
        "hidden_count_chip",
        "policy_chip",
        "provider_chip",
        "target_host_cue",
        "keyboard_detail"
      ]
    },
    "source_lane_class": {
      "type": "string",
      "enum": [
        "hot_set_file",
        "lexical_file",
        "symbol_index",
        "recent_place",
        "route_registry",
        "command_registry",
        "settings_registry",
        "docs_pack",
        "provider_overlay",
        "imported_precomputed",
        "support_projection"
      ]
    },
    "ranking_reason_class": {
      "type": "string",
      "enum": [
        "exact_name_match",
        "exact_path_match",
        "lexical_prefix_match",
        "lexical_fuzzy_match",
        "symbol_kind_prior",
        "graph_neighbourhood_hop",
        "recent_file_bias",
        "recent_edit_bias",
        "frequent_use_bias",
        "imported_fact_match",
        "heuristic_summary_cluster",
        "semantic_embedding_neighbour",
        "docs_anchor_match",
        "palette_command_canonical",
        "symbol_jump_declaration_anchor",
        "structural_fallback",
        "policy_hidden_placeholder"
      ]
    },
    "ranking_weight_class": {
      "type": "string",
      "enum": [
        "primary_signal",
        "tie_breaker",
        "recency_bias",
        "frequency_bias",
        "anchor_boost",
        "semantic_supplement",
        "structural_fallback_bias",
        "policy_required_inclusion"
      ]
    },
    "hidden_scope_reason": {
      "type": "string",
      "enum": [
        "trust_state_excludes_surface",
        "policy_narrows_source",
        "sparse_scope_excludes_root",
        "outside_loaded_scope",
        "excluded_by_user_filter",
        "client_scope_excludes_surface",
        "provider_overlay_unauthorised",
        "pack_quarantined",
        "redaction_narrowed",
        "remote_shard_unreachable"
      ]
    },
    "scope_filter_class": {
      "type": "string",
      "enum": [
        "current_root",
        "named_workset",
        "sparse_slice",
        "full_workspace",
        "docs_pack_only",
        "policy_limited_view",
        "review_workspace",
        "companion_surface",
        "remote_workspace"
      ]
    },
    "provider_state_class": {
      "type": "string",
      "enum": [
        "ready",
        "warming",
        "streaming",
        "stale",
        "partial",
        "policy_blocked",
        "unauthorized",
        "rate_limited",
        "offline",
        "unavailable"
      ]
    },
    "policy_limit_class": {
      "type": "string",
      "enum": [
        "none",
        "trust_restricted",
        "admin_policy",
        "client_scope",
        "redaction",
        "provider_authorization",
        "remote_unreachable"
      ]
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "workspace_file",
        "buffer_anchor",
        "graph_symbol",
        "recent_location",
        "command_route",
        "settings_route",
        "docs_anchor",
        "provider_resource",
        "generated_artifact",
        "terminal_zone",
        "output_viewer"
      ]
    },
    "host_class": {
      "type": "string",
      "enum": [
        "editor",
        "split_editor",
        "side_panel",
        "bottom_panel",
        "external_browser_handoff",
        "remote_host",
        "command_runtime",
        "no_host"
      ]
    },
    "route_cue_class": {
      "type": "string",
      "enum": [
        "current_workspace",
        "current_file",
        "current_symbol",
        "current_workset",
        "outside_current_workset",
        "remote_workspace",
        "docs_pack",
        "provider_overlay",
        "command_graph",
        "settings_surface"
      ]
    },
    "deep_link_drift_state": {
      "type": "string",
      "enum": [
        "resolved_exact",
        "resolved_remapped",
        "resolved_ambiguous",
        "target_missing",
        "target_moved",
        "target_renamed",
        "target_branch_drifted",
        "target_policy_blocked",
        "target_scope_excluded",
        "index_not_ready_for_target",
        "unresolvable"
      ]
    },
    "focus_origin_class": {
      "type": "string",
      "enum": [
        "editor_text",
        "editor_sidebar",
        "terminal",
        "panel",
        "modal_sheet",
        "command_palette",
        "quick_open",
        "workbench_shell"
      ]
    },
    "focus_outcome_class": {
      "type": "string",
      "enum": [
        "return_to_invoker",
        "focus_opened_target",
        "focus_preview_target",
        "keep_query_focused",
        "focus_detail_panel",
        "nearest_safe_ancestor"
      ]
    },
    "same_surface_action_class": {
      "type": "string",
      "enum": [
        "back_to_results",
        "widen_scope",
        "clear_filter",
        "retry_provider",
        "request_policy_change",
        "rebuild_index",
        "open_docs_help",
        "copy_support_ref"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "scenario"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/non_empty_string" },
        "exercised_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "ranking_trace_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank_order",
        "ranking_reason_class",
        "source_lane_class",
        "ranking_weight_class",
        "contribution_ref",
        "visible_to_user",
        "reason_label_ref"
      ],
      "properties": {
        "rank_order": {
          "type": "integer",
          "minimum": 0
        },
        "ranking_reason_class": { "$ref": "#/$defs/ranking_reason_class" },
        "source_lane_class": { "$ref": "#/$defs/source_lane_class" },
        "ranking_weight_class": { "$ref": "#/$defs/ranking_weight_class" },
        "contribution_ref": { "$ref": "#/$defs/opaque_id" },
        "visible_to_user": { "type": "boolean" },
        "reason_label_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "count_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "visible_result_count",
        "hidden_result_count",
        "policy_blocked_count",
        "hidden_by_filter_count",
        "provider_limited_count",
        "outside_current_workset_count",
        "count_is_approximate",
        "hidden_scope_reasons"
      ],
      "properties": {
        "visible_result_count": {
          "type": "integer",
          "minimum": 0
        },
        "hidden_result_count": {
          "type": "integer",
          "minimum": 0
        },
        "policy_blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "hidden_by_filter_count": {
          "type": "integer",
          "minimum": 0
        },
        "provider_limited_count": {
          "type": "integer",
          "minimum": 0
        },
        "outside_current_workset_count": {
          "type": "integer",
          "minimum": 0
        },
        "count_is_approximate": { "type": "boolean" },
        "hidden_scope_reasons": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/hidden_scope_reason" }
        }
      }
    },
    "scope_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_filter_class",
        "current_scope_ref",
        "captured_scope_ref",
        "result_set_ref",
        "scope_epoch_ref",
        "count_summary"
      ],
      "properties": {
        "scope_filter_class": { "$ref": "#/$defs/scope_filter_class" },
        "current_scope_ref": { "$ref": "#/$defs/opaque_id" },
        "captured_scope_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "result_set_ref": { "$ref": "#/$defs/opaque_id" },
        "scope_epoch_ref": { "$ref": "#/$defs/opaque_id" },
        "count_summary": { "$ref": "#/$defs/count_summary" }
      }
    },
    "policy_limit_detail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_limit_class",
        "policy_epoch_ref",
        "owner_boundary_ref",
        "repair_hook_refs"
      ],
      "properties": {
        "policy_limit_class": { "$ref": "#/$defs/policy_limit_class" },
        "policy_epoch_ref": { "$ref": "#/$defs/opaque_id" },
        "owner_boundary_ref": { "$ref": "#/$defs/opaque_id" },
        "repair_hook_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      }
    },
    "provider_limit_detail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_state_class",
        "provider_ref",
        "provider_authority_ref",
        "repair_hook_refs"
      ],
      "properties": {
        "provider_state_class": { "$ref": "#/$defs/provider_state_class" },
        "provider_ref": { "$ref": "#/$defs/opaque_id" },
        "provider_authority_ref": { "$ref": "#/$defs/opaque_id" },
        "repair_hook_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      }
    },
    "target_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_kind",
        "canonical_target_ref",
        "host_class",
        "route_cues",
        "deep_link_drift_state",
        "resolved_deep_link_ref"
      ],
      "properties": {
        "target_kind": { "$ref": "#/$defs/target_kind" },
        "canonical_target_ref": { "$ref": "#/$defs/opaque_id" },
        "host_class": { "$ref": "#/$defs/host_class" },
        "route_cues": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/route_cue_class" }
        },
        "deep_link_drift_state": { "$ref": "#/$defs/deep_link_drift_state" },
        "resolved_deep_link_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "focus_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_return_token_ref",
        "focus_origin_class",
        "opened_focus_outcome",
        "preview_focus_outcome",
        "cancel_focus_outcome",
        "inspect_focus_outcome",
        "nearest_safe_ancestor_ref"
      ],
      "properties": {
        "focus_return_token_ref": { "$ref": "#/$defs/opaque_id" },
        "focus_origin_class": { "$ref": "#/$defs/focus_origin_class" },
        "opened_focus_outcome": { "$ref": "#/$defs/focus_outcome_class" },
        "preview_focus_outcome": { "$ref": "#/$defs/focus_outcome_class" },
        "cancel_focus_outcome": { "$ref": "#/$defs/focus_outcome_class" },
        "inspect_focus_outcome": { "$ref": "#/$defs/focus_outcome_class" },
        "nearest_safe_ancestor_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "privacy_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redaction_class",
        "raw_query_visible",
        "raw_paths_exportable",
        "support_export_allowed"
      ],
      "properties": {
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "raw_query_visible": { "type": "boolean" },
        "raw_paths_exportable": { "type": "boolean" },
        "support_export_allowed": { "type": "boolean" }
      }
    },
    "quick_open_explanation_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "quick_open_explanation_schema_version",
        "explanation_id",
        "quick_open_session_id_ref",
        "quick_open_row_id_ref",
        "explanation_surface_class",
        "opened_from",
        "ranking_trace",
        "scope_truth",
        "policy_limit_detail",
        "provider_limit_detail",
        "target_truth",
        "focus_trace",
        "same_surface_available_actions",
        "privacy",
        "minted_at"
      ],
      "properties": {
        "$schema": { "$ref": "#/$defs/non_empty_string" },
        "record_kind": { "const": "quick_open_explanation_record" },
        "quick_open_explanation_schema_version": { "$ref": "#/$defs/quick_open_explanation_schema_version" },
        "explanation_id": { "$ref": "#/$defs/opaque_id" },
        "quick_open_session_id_ref": { "$ref": "#/$defs/opaque_id" },
        "quick_open_row_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "explanation_surface_class": { "$ref": "#/$defs/explanation_surface_class" },
        "opened_from": { "$ref": "#/$defs/explanation_opened_from_class" },
        "ranking_trace": {
          "type": "array",
          "items": { "$ref": "#/$defs/ranking_trace_entry" }
        },
        "scope_truth": { "$ref": "#/$defs/scope_truth" },
        "policy_limit_detail": { "$ref": "#/$defs/policy_limit_detail" },
        "provider_limit_detail": { "$ref": "#/$defs/provider_limit_detail" },
        "target_truth": { "$ref": "#/$defs/target_truth" },
        "focus_trace": { "$ref": "#/$defs/focus_trace" },
        "same_surface_available_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/same_surface_action_class" }
        },
        "privacy": { "$ref": "#/$defs/privacy_block" },
        "fixture_metadata": { "$ref": "#/$defs/fixture_metadata" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Ranking detail explanations carry at least one ranking trace entry.",
          "if": {
            "properties": {
              "explanation_surface_class": { "const": "ranking_detail" }
            },
            "required": ["explanation_surface_class"]
          },
          "then": {
            "properties": {
              "ranking_trace": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        },
        {
          "description": "Hidden-result detail explanations carry at least one hidden count.",
          "if": {
            "properties": {
              "explanation_surface_class": { "const": "hidden_results_detail" }
            },
            "required": ["explanation_surface_class"]
          },
          "then": {
            "properties": {
              "scope_truth": {
                "properties": {
                  "count_summary": {
                    "properties": {
                      "hidden_result_count": {
                        "type": "integer",
                        "minimum": 1
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
