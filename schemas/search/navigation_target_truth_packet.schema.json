{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/search/navigation_target_truth_packet.schema.json",
  "title": "Aureline navigation-target truth packet",
  "description": "Boundary schema for the stable navigation-target truth packet that pins find-references, rename-preview, and impact-surfacing rows across launch languages. Consumer surfaces (editor navigation pane, graph topology, AI context, review workspace, support export, CLI/headless, release proof index) read this packet verbatim instead of reinventing relation/access/provider/freshness/downgrade/ambiguity truth locally.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_row_classes",
    "covered_access_kinds",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "navigation_target_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_row_classes": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/row_class" }
    },
    "covered_access_kinds": {
      "type": "array",
      "minItems": 10,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/access_kind" }
    },
    "rows": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/truth_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "row_class": {
      "enum": [
        "definition",
        "declaration",
        "implementation",
        "reference",
        "call_hierarchy_edge",
        "type_hierarchy_edge",
        "related_object",
        "rename_preview"
      ]
    },
    "relation_kind": {
      "enum": [
        "definition",
        "declaration",
        "implementation",
        "reference",
        "type",
        "call",
        "route_binding",
        "owner_link",
        "doc_link",
        "test_link"
      ]
    },
    "access_kind": {
      "enum": [
        "read",
        "write",
        "call",
        "inherit",
        "import",
        "export",
        "route_binding",
        "test_only",
        "generated",
        "runtime_observed"
      ]
    },
    "provider_class": {
      "enum": [
        "language_server",
        "project_graph",
        "search_index",
        "framework_pack",
        "notebook_adapter",
        "generated_source_bridge",
        "runtime_observer",
        "imported_snapshot",
        "syntax_fallback",
        "remote_index"
      ]
    },
    "freshness_class": {
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified",
        "imported_snapshot"
      ]
    },
    "ambiguity_class": {
      "enum": [
        "unambiguous",
        "ambiguous_needs_selection",
        "multiple_candidates_ranked",
        "drifted_needs_review",
        "missing_target",
        "scope_unavailable"
      ]
    },
    "scope_completeness": {
      "enum": [
        "complete_for_declared_scope",
        "partial_for_declared_scope",
        "stale_for_declared_scope",
        "unavailable_for_declared_scope"
      ]
    },
    "downgrade_state": {
      "enum": [
        "canonical",
        "aliased_due_to_shallow_provider",
        "partial_index_disclosed",
        "stale_disclosed",
        "generated_boundary_disclosed",
        "runtime_or_framework_only_disclosed",
        "lexical_fallback_disclosed",
        "syntax_fallback_disclosed",
        "scope_unavailable_disclosed",
        "imported_snapshot_disclosed"
      ]
    },
    "confidence_class": {
      "enum": [
        "exact",
        "indexed",
        "partial",
        "imported",
        "stale",
        "heuristic",
        "unavailable"
      ]
    },
    "hierarchy_edge_kind": {
      "enum": [
        "calls",
        "runtime_calls",
        "inherits",
        "implements",
        "overrides",
        "framework_binding",
        "owner",
        "documented_by"
      ]
    },
    "rename_blocked_reason": {
      "enum": [
        "policy_hidden",
        "generated",
        "readonly",
        "partially_loaded",
        "sparse_scope_omission",
        "conflict_ambiguous"
      ]
    },
    "consumer_surface": {
      "enum": [
        "editor_navigation_pane",
        "graph_topology",
        "ai_context",
        "review_workspace",
        "support_export",
        "cli_headless",
        "release_proof_index"
      ]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_row_class_coverage",
        "missing_disclosure_ref",
        "reference_missing_access_context",
        "reference_missing_access_kind",
        "rename_preview_missing_context",
        "hierarchy_edge_missing_endpoints",
        "silent_relation_alias_present",
        "aliasing_context_missing_for_downgrade",
        "aliasing_context_relation_collision",
        "provider_class_freshness_mismatch",
        "access_context_invalid_for_row_class",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "row_class_vocabulary_collapsed",
        "relation_kind_vocabulary_dropped",
        "access_kind_vocabulary_dropped",
        "provider_class_vocabulary_dropped",
        "freshness_vocabulary_dropped",
        "downgrade_vocabulary_dropped",
        "ambiguity_vocabulary_dropped",
        "rename_blocked_candidate_vocabulary_dropped",
        "raw_boundary_material_present",
        "promotion_state_mismatch",
        "missing_access_kind_coverage"
      ]
    },
    "reference_context": {
      "type": "object",
      "required": ["access_kind", "occurrence_anchor_ref"],
      "properties": {
        "access_kind": { "$ref": "#/$defs/access_kind" },
        "occurrence_anchor_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "hierarchy_edge_context": {
      "type": "object",
      "required": [
        "source_object_ref",
        "target_object_ref",
        "edge_kind",
        "depth"
      ],
      "properties": {
        "source_object_ref": { "$ref": "#/$defs/non_empty_string" },
        "target_object_ref": { "$ref": "#/$defs/non_empty_string" },
        "edge_kind": { "$ref": "#/$defs/hierarchy_edge_kind" },
        "depth": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "rename_preview_context": {
      "type": "object",
      "required": [
        "rename_preview_id",
        "root_target_ref",
        "changed_candidate_count",
        "blocked_candidate_count",
        "generated_candidate_count",
        "readonly_candidate_count",
        "partial_loaded_candidate_count",
        "sparse_scope_omission_count",
        "conflict_note_count",
        "code_bodies_redacted",
        "policy_hides_candidates"
      ],
      "properties": {
        "rename_preview_id": { "$ref": "#/$defs/non_empty_string" },
        "root_target_ref": { "$ref": "#/$defs/non_empty_string" },
        "changed_candidate_count": { "type": "integer", "minimum": 0 },
        "blocked_candidate_count": { "type": "integer", "minimum": 0 },
        "generated_candidate_count": { "type": "integer", "minimum": 0 },
        "readonly_candidate_count": { "type": "integer", "minimum": 0 },
        "partial_loaded_candidate_count": { "type": "integer", "minimum": 0 },
        "sparse_scope_omission_count": { "type": "integer", "minimum": 0 },
        "conflict_note_count": { "type": "integer", "minimum": 0 },
        "code_bodies_redacted": { "type": "boolean" },
        "policy_hides_candidates": { "type": "boolean" },
        "blocked_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/rename_blocked_reason" },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "aliasing_context": {
      "type": "object",
      "required": [
        "aliased_to_relation",
        "aliased_reason_token",
        "alias_evidence_ref"
      ],
      "properties": {
        "aliased_to_relation": { "$ref": "#/$defs/relation_kind" },
        "aliased_reason_token": { "$ref": "#/$defs/non_empty_string" },
        "alias_evidence_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "truth_row": {
      "type": "object",
      "required": [
        "row_id",
        "row_class",
        "relation_kind",
        "language_lane",
        "workspace_id",
        "scope_ref",
        "object_ref",
        "provider_class",
        "freshness_class",
        "ambiguity_class",
        "scope_completeness",
        "downgrade_state",
        "confidence_class",
        "disclosure_ref",
        "raw_boundary_material_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "row_class": { "$ref": "#/$defs/row_class" },
        "relation_kind": { "$ref": "#/$defs/relation_kind" },
        "language_lane": { "$ref": "#/$defs/non_empty_string" },
        "workspace_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_ref": { "$ref": "#/$defs/non_empty_string" },
        "object_ref": { "$ref": "#/$defs/non_empty_string" },
        "provider_class": { "$ref": "#/$defs/provider_class" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "ambiguity_class": { "$ref": "#/$defs/ambiguity_class" },
        "scope_completeness": { "$ref": "#/$defs/scope_completeness" },
        "downgrade_state": { "$ref": "#/$defs/downgrade_state" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "reference_context": { "$ref": "#/$defs/reference_context" },
        "hierarchy_edge_context": { "$ref": "#/$defs/hierarchy_edge_context" },
        "rename_preview_context": { "$ref": "#/$defs/rename_preview_context" },
        "aliasing_context": { "$ref": "#/$defs/aliasing_context" },
        "raw_boundary_material_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "navigation_target_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_row_class_vocabulary",
        "preserves_relation_kind_vocabulary",
        "preserves_access_kind_vocabulary",
        "preserves_provider_class_vocabulary",
        "preserves_freshness_vocabulary",
        "preserves_downgrade_vocabulary",
        "preserves_ambiguity_vocabulary",
        "preserves_rename_blocked_candidate_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "navigation_target_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_relation_kind_vocabulary": { "type": "boolean" },
        "preserves_access_kind_vocabulary": { "type": "boolean" },
        "preserves_provider_class_vocabulary": { "type": "boolean" },
        "preserves_freshness_vocabulary": { "type": "boolean" },
        "preserves_downgrade_vocabulary": { "type": "boolean" },
        "preserves_ambiguity_vocabulary": { "type": "boolean" },
        "preserves_rename_blocked_candidate_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
