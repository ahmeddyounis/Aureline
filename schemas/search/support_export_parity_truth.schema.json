{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/search/support_export_parity_truth.schema.json",
  "title": "Aureline support-export parity, query-session/search-export, retrieval-debug, and operator-truth inspector truth packet",
  "description": "Boundary schema for the stable support-export parity truth packet shared by search shell, graph topology, docs/help, AI context, review workspace, CLI/headless, support export, and the release proof index. Every row binds a lane class, export packet class, query-session ref, count summary, redaction class, live-vs-captured class, downgrade state, and disclosure ref. Operator-truth inspector rows carry a reconstruction proof; query-session export rows carry a deep-link scope binding that forbids frozen recipient certainty.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lane_classes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "support_export_parity_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lane_classes": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/parity_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "non_negative_int": {
      "type": "integer",
      "minimum": 0
    },
    "lane_class": {
      "enum": [
        "search_export",
        "graph_topology_export",
        "docs_handoff_export",
        "operator_truth_inspector",
        "retrieval_debug",
        "query_session_export"
      ]
    },
    "export_packet_class": {
      "enum": [
        "search_collection_snapshot",
        "graph_topology_snapshot",
        "docs_handoff_packet",
        "operator_truth_packet",
        "retrieval_inspector_packet",
        "query_session_packet"
      ]
    },
    "redaction_class": {
      "enum": [
        "literal_local_only",
        "hashes_scope_and_result_refs",
        "metadata_only_no_query_material",
        "policy_withheld",
        "explicit_literal_consent"
      ]
    },
    "live_vs_captured_class": {
      "enum": [
        "current_live_results",
        "captured_snapshot",
        "live_rerun_required",
        "scope_changed_since_capture",
        "empty_because_scope_changed"
      ]
    },
    "downgrade_state": {
      "enum": [
        "none",
        "narrowed_query_redacted",
        "truncated_results",
        "policy_withheld",
        "provider_unavailable",
        "scope_changed_since_capture"
      ]
    },
    "confidence_class": {
      "enum": ["high", "medium", "low", "heuristic"]
    },
    "consumer_surface": {
      "enum": [
        "search_shell",
        "graph_topology",
        "docs_help",
        "ai_context",
        "review_workspace",
        "cli_headless",
        "support_export",
        "release_proof_index"
      ]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_lane_coverage",
        "missing_query_session_ref",
        "missing_evidence_refs",
        "missing_disclosure_ref",
        "invalid_count_summary",
        "operator_truth_missing_reconstruction",
        "query_session_missing_deep_link_binding",
        "deep_link_drops_scope_metadata",
        "deep_link_freezes_recipient_certainty",
        "raw_query_text_present",
        "secrets_present",
        "ambient_authority_present",
        "default_export_too_permissive",
        "export_packet_class_lane_mismatch",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "export_packet_class_vocabulary_collapsed",
        "redaction_vocabulary_collapsed",
        "live_vs_captured_vocabulary_collapsed",
        "downgrade_vocabulary_collapsed",
        "query_session_refs_dropped",
        "promotion_state_mismatch"
      ]
    },
    "count_summary": {
      "type": "object",
      "required": [
        "visible_rows",
        "selected_rows",
        "included_rows",
        "omitted_result_count",
        "hidden_by_current_scope_rows",
        "hidden_by_policy_rows",
        "hidden_by_remote_cache_rows",
        "count_is_partial"
      ],
      "properties": {
        "visible_rows": { "$ref": "#/$defs/non_negative_int" },
        "selected_rows": { "$ref": "#/$defs/non_negative_int" },
        "included_rows": { "$ref": "#/$defs/non_negative_int" },
        "omitted_result_count": { "$ref": "#/$defs/non_negative_int" },
        "hidden_by_current_scope_rows": { "$ref": "#/$defs/non_negative_int" },
        "hidden_by_policy_rows": { "$ref": "#/$defs/non_negative_int" },
        "hidden_by_remote_cache_rows": { "$ref": "#/$defs/non_negative_int" },
        "count_is_partial": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "operator_reconstruction_proof": {
      "type": "object",
      "required": [
        "reconstruction_id",
        "why_row_existed_ref",
        "what_was_hidden_ref",
        "approximate_count_disclosure_ref",
        "raw_query_text_excluded"
      ],
      "properties": {
        "reconstruction_id": { "$ref": "#/$defs/non_empty_string" },
        "why_row_existed_ref": { "$ref": "#/$defs/non_empty_string" },
        "what_was_hidden_ref": { "$ref": "#/$defs/non_empty_string" },
        "approximate_count_disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "raw_query_text_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "deep_link_scope_binding": {
      "type": "object",
      "required": [
        "deep_link_intent_ref",
        "scope_metadata_ref",
        "requires_recipient_resolution",
        "frozen_certainty_excluded"
      ],
      "properties": {
        "deep_link_intent_ref": { "$ref": "#/$defs/non_empty_string" },
        "scope_metadata_ref": { "$ref": "#/$defs/non_empty_string" },
        "requires_recipient_resolution": { "type": "boolean" },
        "frozen_certainty_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "parity_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "export_packet_class",
        "packet_id",
        "workspace_id",
        "query_session_id_ref",
        "count_summary",
        "omitted_flag",
        "truncated_flag",
        "redaction_class",
        "evidence_refs",
        "live_vs_captured_class",
        "downgrade_state",
        "confidence_class",
        "disclosure_ref",
        "raw_query_text_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/lane_class" },
        "export_packet_class": { "$ref": "#/$defs/export_packet_class" },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "workspace_id": { "$ref": "#/$defs/non_empty_string" },
        "query_session_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "planner_pass_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "selected_result_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "included_result_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "count_summary": { "$ref": "#/$defs/count_summary" },
        "omitted_flag": { "type": "boolean" },
        "truncated_flag": { "type": "boolean" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "live_vs_captured_class": { "$ref": "#/$defs/live_vs_captured_class" },
        "downgrade_state": { "$ref": "#/$defs/downgrade_state" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "operator_reconstruction_proof": { "$ref": "#/$defs/operator_reconstruction_proof" },
        "deep_link_scope_binding": { "$ref": "#/$defs/deep_link_scope_binding" },
        "raw_query_text_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "support_export_parity_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_export_packet_class_vocabulary",
        "preserves_redaction_vocabulary",
        "preserves_live_vs_captured_vocabulary",
        "preserves_downgrade_vocabulary",
        "preserves_query_session_refs",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_export_parity_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_export_packet_class_vocabulary": { "type": "boolean" },
        "preserves_redaction_vocabulary": { "type": "boolean" },
        "preserves_live_vs_captured_vocabulary": { "type": "boolean" },
        "preserves_downgrade_vocabulary": { "type": "boolean" },
        "preserves_query_session_refs": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
