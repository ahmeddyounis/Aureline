{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/search/search_benchmark_corpus_truth.schema.json",
  "title": "Aureline search benchmark corpus, ranking evaluation, and certified-archetype query-pack stable packet",
  "description": "Boundary schema for the stable search benchmark corpus, ranking evaluation, and certified-archetype query-pack truth packet shared by the search shell, docs/help, CLI/headless, support export, release proof index, and benchmark lab.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_archetypes",
    "covered_corpus_classes",
    "corpora",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "search_benchmark_corpus_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_archetypes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/certified_archetype" }
    },
    "covered_corpus_classes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/benchmark_corpus_class" }
    },
    "corpora": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/benchmark_corpus_definition" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/pack_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "certified_archetype": {
      "enum": [
        "typescript_javascript_web",
        "python_service_or_data_app",
        "rust_workspace",
        "go_service_or_monorepo_slice",
        "java_or_kotlin_service",
        "c_or_cpp_native_project"
      ]
    },
    "benchmark_corpus_class": {
      "enum": [
        "file_lookup_corpus",
        "symbol_navigation_corpus",
        "command_palette_corpus",
        "docs_lookup_corpus",
        "semantic_recall_corpus",
        "hybrid_retrieval_corpus"
      ]
    },
    "query_pack_class": {
      "enum": [
        "golden_query_pack",
        "regression_query_pack",
        "edge_case_query_pack",
        "imported_corpus_pack"
      ]
    },
    "ranking_metric_class": {
      "enum": [
        "ndcg_at_10",
        "mrr",
        "recall_at_50",
        "precision_at_5",
        "first_useful_row_latency_ms"
      ]
    },
    "retention_policy_class": {
      "enum": [
        "local_only",
        "tenant_only",
        "shared_internal",
        "published_external"
      ]
    },
    "provenance_class": {
      "enum": [
        "internally_authored",
        "imported_external",
        "community_contributed",
        "synthesized_seed"
      ]
    },
    "corpus_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "evaluation_downgrade_state": {
      "enum": [
        "none",
        "narrowed_below_baseline",
        "imported_baseline",
        "regression_detected",
        "corpus_redacted"
      ]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_archetype_or_corpus_row",
        "corpus_id_drift",
        "missing_published_baseline",
        "missing_observed_metric",
        "metric_regression_without_waiver",
        "waiver_without_ref",
        "missing_capture_ref",
        "missing_disclosure_ref",
        "missing_retention_policy",
        "imported_corpus_without_provenance",
        "raw_query_material_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "metric_vocabulary_collapsed",
        "query_pack_vocabulary_collapsed",
        "corpus_provenance_collapsed",
        "downgrade_state_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "metric_observation": {
      "type": "object",
      "required": [
        "metric_class",
        "published_baseline",
        "observed_value",
        "sample_size",
        "capture_ref"
      ],
      "properties": {
        "metric_class": { "$ref": "#/$defs/ranking_metric_class" },
        "published_baseline": { "type": "integer", "minimum": 1 },
        "observed_value": { "type": "integer", "minimum": 0 },
        "sample_size": { "type": "integer", "minimum": 1 },
        "capture_ref": { "$ref": "#/$defs/non_empty_string" },
        "waiver_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "benchmark_corpus_definition": {
      "type": "object",
      "required": [
        "corpus_id",
        "corpus_class",
        "archetype",
        "retention_policy",
        "provenance",
        "sample_size",
        "source_ref",
        "raw_query_material_excluded"
      ],
      "properties": {
        "corpus_id": { "$ref": "#/$defs/non_empty_string" },
        "corpus_class": { "$ref": "#/$defs/benchmark_corpus_class" },
        "archetype": { "$ref": "#/$defs/certified_archetype" },
        "retention_policy": { "$ref": "#/$defs/retention_policy_class" },
        "provenance": { "$ref": "#/$defs/provenance_class" },
        "sample_size": { "type": "integer", "minimum": 1 },
        "source_ref": { "$ref": "#/$defs/non_empty_string" },
        "raw_query_material_excluded": { "type": "boolean" },
        "imported_provenance_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "pack_row": {
      "type": "object",
      "required": [
        "row_id",
        "archetype",
        "corpus_class",
        "query_pack_class",
        "query_pack_id",
        "corpus_id_ref",
        "query_count",
        "metrics",
        "confidence_class",
        "downgrade_state",
        "raw_query_material_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "archetype": { "$ref": "#/$defs/certified_archetype" },
        "corpus_class": { "$ref": "#/$defs/benchmark_corpus_class" },
        "query_pack_class": { "$ref": "#/$defs/query_pack_class" },
        "query_pack_id": { "$ref": "#/$defs/non_empty_string" },
        "corpus_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "query_count": { "type": "integer", "minimum": 1 },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/metric_observation" }
        },
        "confidence_class": { "$ref": "#/$defs/corpus_confidence_class" },
        "downgrade_state": { "$ref": "#/$defs/evaluation_downgrade_state" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "raw_query_material_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "corpus_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_metric_vocabulary",
        "preserves_query_pack_vocabulary",
        "preserves_corpus_provenance",
        "preserves_downgrade_state",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "search_shell",
            "docs_help",
            "cli_headless",
            "support_export",
            "release_proof_index",
            "benchmark_lab"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "corpus_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_metric_vocabulary": { "type": "boolean" },
        "preserves_query_pack_vocabulary": { "type": "boolean" },
        "preserves_corpus_provenance": { "type": "boolean" },
        "preserves_downgrade_state": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
