{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/search/query_history.schema.json",
  "title": "Aureline query-history artifact contract",
  "description": "Boundary schema for durable query-history rows. Query history is local-first by default, declares source, privacy, retention, sync, redaction, stored-text mode, scope honesty, and live-versus-captured semantics, and stores hashes or omission stubs instead of literal query text whenever privacy, support export, sync, or policy forbids raw material.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/query_history_entry" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "opaque_id": { "type": "string", "minLength": 1 },
    "timestamp_or_fixture_time": { "type": "string", "minLength": 1 },
    "source_class": {
      "type": "string",
      "enum": [
        "user_authored",
        "repo_provided",
        "policy_provided",
        "team_shared",
        "support_captured",
        "session_history"
      ]
    },
    "privacy_class": {
      "type": "string",
      "enum": [
        "local_only_private",
        "workspace_shared_redacted",
        "support_export_redacted",
        "policy_withheld"
      ]
    },
    "retention_mode": {
      "type": "string",
      "enum": [
        "local_only_default",
        "local_only_ephemeral",
        "workspace_shared_explicit",
        "repo_provided_read_only",
        "policy_owned_managed",
        "support_export_bounded"
      ]
    },
    "sync_class": {
      "type": "string",
      "enum": [
        "local_only",
        "explicit_user_sync",
        "workspace_shared",
        "repo_provided",
        "policy_managed",
        "support_export_only"
      ]
    },
    "redaction_profile": {
      "type": "string",
      "enum": [
        "literal_local_only",
        "hashes_scope_and_result_refs",
        "metadata_only_no_query_material",
        "policy_withheld",
        "explicit_literal_consent"
      ]
    },
    "retention_widening_basis": {
      "type": "string",
      "enum": [
        "not_widened_local_default",
        "explicit_user_opt_in",
        "policy_owned",
        "repo_provided_artifact",
        "team_shared_artifact",
        "support_case_export"
      ]
    },
    "search_surface": {
      "type": "string",
      "enum": ["quick_open", "file_search", "symbol_search", "docs_search"]
    },
    "query_text_mode": {
      "type": "string",
      "enum": ["local_text", "hash_only", "omitted_by_policy"]
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "current_repo",
        "selected_workset",
        "sparse_slice",
        "full_workspace",
        "policy_limited_view"
      ]
    },
    "result_semantics": {
      "type": "string",
      "enum": [
        "current_live_results",
        "captured_snapshot",
        "live_rerun_required",
        "scope_changed_since_capture",
        "empty_because_scope_changed"
      ]
    },
    "scope_honesty_state": {
      "type": "string",
      "enum": [
        "captured_scope_still_current",
        "recipient_must_re_resolve",
        "current_scope_wider_narrowed_to_captured",
        "current_scope_narrower_disclosed",
        "current_scope_changed_rebind_required"
      ]
    },
    "query_history_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "history_id",
        "source_class",
        "privacy_class",
        "retention_mode",
        "sync_class",
        "redaction_profile",
        "retention_widening_basis",
        "query_session_id_ref",
        "surface",
        "stored_text_mode",
        "scope_binding_id_ref",
        "scope_class",
        "stable_scope_id",
        "result_semantics",
        "scope_honesty_state",
        "last_used_at"
      ],
      "properties": {
        "record_kind": { "const": "query_history_entry" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "history_id": { "$ref": "#/$defs/opaque_id" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "privacy_class": { "$ref": "#/$defs/privacy_class" },
        "retention_mode": { "$ref": "#/$defs/retention_mode" },
        "sync_class": { "$ref": "#/$defs/sync_class" },
        "redaction_profile": { "$ref": "#/$defs/redaction_profile" },
        "retention_widening_basis": { "$ref": "#/$defs/retention_widening_basis" },
        "query_session_id_ref": { "$ref": "#/$defs/opaque_id" },
        "saved_query_id_ref": { "$ref": "#/$defs/opaque_id" },
        "surface": { "$ref": "#/$defs/search_surface" },
        "stored_text_mode": { "$ref": "#/$defs/query_text_mode" },
        "query_hash": { "type": "string", "minLength": 1 },
        "scope_binding_id_ref": { "$ref": "#/$defs/opaque_id" },
        "scope_class": { "$ref": "#/$defs/scope_class" },
        "stable_scope_id": { "$ref": "#/$defs/opaque_id" },
        "result_semantics": { "$ref": "#/$defs/result_semantics" },
        "scope_honesty_state": { "$ref": "#/$defs/scope_honesty_state" },
        "last_used_at": { "$ref": "#/$defs/timestamp_or_fixture_time" },
        "expires_at": { "$ref": "#/$defs/timestamp_or_fixture_time" }
      }
    }
  }
}
