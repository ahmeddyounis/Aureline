{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/search/navigation-targets.schema.json",
  "title": "Aureline stable navigation-target contract",
  "description": "Boundary schema for stable NavigationTarget, ReferenceOccurrence, NavigationDisambiguationSet, HierarchyEdge, and RenamePreviewSet packets. Records are metadata-only and preserve relation kind, access kind, provider/source class, confidence, freshness, ambiguity, scope completeness, fallback mode, hierarchy edge class, and rename blocked/omitted candidate truth across editor, search, graph, review, AI, support export, and CLI/headless projections.",
  "oneOf": [
    { "$ref": "#/$defs/contract_case" },
    { "$ref": "#/$defs/contract_packet" }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "string_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "relation_kind": {
      "enum": [
        "definition",
        "declaration",
        "implementation",
        "reference",
        "type",
        "call",
        "route-binding",
        "owner-link",
        "doc-link"
      ]
    },
    "access_kind": {
      "enum": [
        "read",
        "write",
        "call",
        "inherit",
        "import",
        "export",
        "route-binding",
        "test-only",
        "generated",
        "runtime-observed"
      ]
    },
    "provider_source_class": {
      "enum": [
        "language_server",
        "parser",
        "search_index",
        "semantic_graph",
        "framework_analyzer",
        "generated_source",
        "notebook_adapter",
        "diff_adapter",
        "runtime_observer",
        "imported_snapshot"
      ]
    },
    "confidence_class": {
      "enum": ["exact", "indexed", "partial", "imported", "stale", "heuristic", "unavailable"]
    },
    "freshness_class": {
      "enum": ["authoritative_live", "warm_cached", "degraded_cached", "stale", "unverified"]
    },
    "ambiguity_class": {
      "enum": [
        "unambiguous",
        "ambiguous_needs_selection",
        "multiple_candidates_ranked",
        "drifted_needs_review",
        "missing_target"
      ]
    },
    "scope_completeness": {
      "enum": ["complete", "partial", "stale", "unavailable"]
    },
    "fallback_mode": {
      "enum": [
        "none",
        "unsupported_relation",
        "downgraded_provider",
        "lexical_fallback",
        "syntax_fallback",
        "stale_cache",
        "sparse_scope",
        "redacted_metadata_only",
        "generated_boundary",
        "runtime_observed_only",
        "framework_derived_only",
        "protected_row_omitted"
      ]
    },
    "proof_class": {
      "enum": [
        "direct",
        "transitive",
        "inferred",
        "framework_generated",
        "runtime_observed",
        "lexical_fallback",
        "unavailable"
      ]
    },
    "hierarchy_edge_kind": {
      "enum": ["direct", "transitive", "inferred", "framework_generated", "runtime_observed"]
    },
    "rename_candidate_disposition": {
      "enum": [
        "changeable",
        "blocked",
        "generated",
        "readonly",
        "sparse_scope_omitted",
        "partially_loaded",
        "redacted"
      ]
    },
    "consumer_surface": {
      "enum": [
        "editor_ui",
        "search",
        "graph",
        "review_evidence",
        "ai_context",
        "support_export",
        "cli_headless"
      ]
    },
    "navigation_target": {
      "type": "object",
      "required": [
        "target_id",
        "relation_kind",
        "object_ref",
        "anchor_ref",
        "provider_class",
        "confidence",
        "freshness",
        "ambiguity_class",
        "scope_completeness"
      ],
      "properties": {
        "target_id": { "$ref": "#/$defs/non_empty_string" },
        "relation_kind": { "$ref": "#/$defs/relation_kind" },
        "object_ref": { "$ref": "#/$defs/non_empty_string" },
        "anchor_ref": { "$ref": "#/$defs/non_empty_string" },
        "provider_class": { "$ref": "#/$defs/provider_source_class" },
        "confidence": { "$ref": "#/$defs/confidence_class" },
        "freshness": { "$ref": "#/$defs/freshness_class" },
        "ambiguity_class": { "$ref": "#/$defs/ambiguity_class" },
        "scope_completeness": { "$ref": "#/$defs/scope_completeness" },
        "fallback_mode": { "$ref": "#/$defs/fallback_mode" },
        "fallback_note": { "$ref": "#/$defs/non_empty_string" },
        "disambiguation_set_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/string_array" }
      },
      "additionalProperties": false
    },
    "reference_occurrence": {
      "type": "object",
      "required": [
        "occurrence_id",
        "target_ref",
        "anchor_ref",
        "access_kind",
        "scope_ref",
        "provider_class",
        "confidence",
        "freshness",
        "scope_completeness",
        "code_body_redacted"
      ],
      "properties": {
        "occurrence_id": { "$ref": "#/$defs/non_empty_string" },
        "target_ref": { "$ref": "#/$defs/non_empty_string" },
        "anchor_ref": { "$ref": "#/$defs/non_empty_string" },
        "access_kind": { "$ref": "#/$defs/access_kind" },
        "scope_ref": { "$ref": "#/$defs/non_empty_string" },
        "provider_class": { "$ref": "#/$defs/provider_source_class" },
        "confidence": { "$ref": "#/$defs/confidence_class" },
        "freshness": { "$ref": "#/$defs/freshness_class" },
        "scope_completeness": { "$ref": "#/$defs/scope_completeness" },
        "fallback_mode": { "$ref": "#/$defs/fallback_mode" },
        "fallback_note": { "$ref": "#/$defs/non_empty_string" },
        "code_body_redacted": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "navigation_disambiguation_set": {
      "type": "object",
      "required": [
        "set_id",
        "requested_relation",
        "candidate_target_refs",
        "selection_policy",
        "created_at",
        "ambiguity_class"
      ],
      "properties": {
        "set_id": { "$ref": "#/$defs/non_empty_string" },
        "requested_relation": { "$ref": "#/$defs/relation_kind" },
        "candidate_target_refs": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "selection_policy": { "$ref": "#/$defs/non_empty_string" },
        "created_at": { "$ref": "#/$defs/non_empty_string" },
        "ambiguity_class": { "$ref": "#/$defs/ambiguity_class" },
        "fallback_mode": { "$ref": "#/$defs/fallback_mode" },
        "fallback_note": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "hierarchy_edge": {
      "type": "object",
      "required": [
        "edge_id",
        "source_ref",
        "target_ref",
        "edge_kind",
        "proof_class",
        "depth",
        "scope_completeness",
        "freshness",
        "confidence"
      ],
      "properties": {
        "edge_id": { "$ref": "#/$defs/non_empty_string" },
        "source_ref": { "$ref": "#/$defs/non_empty_string" },
        "target_ref": { "$ref": "#/$defs/non_empty_string" },
        "edge_kind": { "$ref": "#/$defs/hierarchy_edge_kind" },
        "proof_class": { "$ref": "#/$defs/proof_class" },
        "depth": { "type": "integer", "minimum": 0 },
        "scope_completeness": { "$ref": "#/$defs/scope_completeness" },
        "freshness": { "$ref": "#/$defs/freshness_class" },
        "confidence": { "$ref": "#/$defs/confidence_class" },
        "fallback_mode": { "$ref": "#/$defs/fallback_mode" },
        "fallback_note": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/string_array" }
      },
      "additionalProperties": false
    },
    "rename_candidate_ref": {
      "type": "object",
      "required": ["candidate_ref", "access_kind", "disposition"],
      "properties": {
        "candidate_ref": { "$ref": "#/$defs/non_empty_string" },
        "access_kind": { "$ref": "#/$defs/access_kind" },
        "disposition": { "$ref": "#/$defs/rename_candidate_disposition" },
        "reason": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "rename_preview_set": {
      "type": "object",
      "required": [
        "rename_preview_id",
        "root_target_ref",
        "candidate_occurrence_refs",
        "redacted_candidate_count"
      ],
      "properties": {
        "rename_preview_id": { "$ref": "#/$defs/non_empty_string" },
        "root_target_ref": { "$ref": "#/$defs/non_empty_string" },
        "candidate_occurrence_refs": { "$ref": "#/$defs/string_array" },
        "blocked_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/rename_candidate_ref" }
        },
        "conflict_notes": { "$ref": "#/$defs/string_array" },
        "sparse_or_partial_reasons": { "$ref": "#/$defs/string_array" },
        "generated_scope_notes": { "$ref": "#/$defs/string_array" },
        "redacted_candidate_count": { "type": "integer", "minimum": 0 },
        "fallback_mode": { "$ref": "#/$defs/fallback_mode" },
        "fallback_note": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "packet_ref",
        "preserves_relation_kind",
        "preserves_access_kind",
        "preserves_provider_source",
        "preserves_confidence_and_freshness",
        "preserves_ambiguity",
        "preserves_hierarchy_edges",
        "preserves_rename_preview_truth",
        "raw_bodies_excluded"
      ],
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "preserves_relation_kind": { "type": "boolean" },
        "preserves_access_kind": { "type": "boolean" },
        "preserves_provider_source": { "type": "boolean" },
        "preserves_confidence_and_freshness": { "type": "boolean" },
        "preserves_ambiguity": { "type": "boolean" },
        "preserves_hierarchy_edges": { "type": "boolean" },
        "preserves_rename_preview_truth": { "type": "boolean" },
        "raw_bodies_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "contract_packet": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "generated_at",
        "navigation_targets",
        "reference_occurrences",
        "disambiguation_sets",
        "hierarchy_edges",
        "rename_preview_sets",
        "consumer_projections",
        "raw_bodies_excluded"
      ],
      "properties": {
        "record_kind": { "const": "navigation_target_and_hierarchy_contract_packet" },
        "schema_version": { "const": 1 },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "$ref": "#/$defs/non_empty_string" },
        "navigation_targets": {
          "type": "array",
          "items": { "$ref": "#/$defs/navigation_target" }
        },
        "reference_occurrences": {
          "type": "array",
          "items": { "$ref": "#/$defs/reference_occurrence" }
        },
        "disambiguation_sets": {
          "type": "array",
          "items": { "$ref": "#/$defs/navigation_disambiguation_set" }
        },
        "hierarchy_edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/hierarchy_edge" }
        },
        "rename_preview_sets": {
          "type": "array",
          "items": { "$ref": "#/$defs/rename_preview_set" }
        },
        "consumer_projections": {
          "type": "array",
          "items": { "$ref": "#/$defs/consumer_projection" }
        },
        "source_contract_refs": { "$ref": "#/$defs/string_array" },
        "raw_bodies_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "contract_case": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "case_id",
        "expected_finding_count",
        "packet"
      ],
      "properties": {
        "record_kind": { "const": "navigation_target_and_hierarchy_contract_case" },
        "schema_version": { "const": 1 },
        "case_id": { "$ref": "#/$defs/non_empty_string" },
        "expected_finding_count": { "type": "integer", "minimum": 0 },
        "packet": { "$ref": "#/$defs/contract_packet" }
      },
      "additionalProperties": false
    }
  }
}
