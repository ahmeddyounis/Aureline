{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/search/collection_portability_truth_packet.schema.json",
  "title": "Aureline saved-query / filter-AST / scope-pack / column-preset portability and collection truth packet",
  "description": "Boundary schema for the stable collection-portability packet that binds saved queries, filter ASTs, scope-pack bindings, saved views, column presets, scope counters, and batch-review sheets into one identity space shared by the desktop search shell, companion shell, CLI/headless inspector, AI context inspector, docs/help, support export, and release proof index.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "query_session_id_ref",
    "generated_at",
    "covered_reopen_states",
    "covered_surfaces",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "collection_portability_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "query_session_id_ref": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_reopen_states": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/reopen_state" }
    },
    "covered_surfaces": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/collection_surface_family" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "consumer_surface": {
      "enum": [
        "desktop_search_shell",
        "companion_search_shell",
        "cli_headless",
        "ai_context_inspector",
        "docs_help",
        "support_export",
        "release_proof_index"
      ]
    },
    "collection_surface_family": {
      "enum": [
        "search_collection",
        "review_collection",
        "package_or_inventory_grid",
        "work_item_collection",
        "admin_or_settings_grid"
      ]
    },
    "reopen_state": {
      "enum": [
        "captured_scope_still_current",
        "recipient_must_re_resolve",
        "current_scope_wider_narrowed_to_captured",
        "current_scope_narrower_disclosed",
        "current_scope_changed_rebind_required",
        "incompatible_artifact_migration_required"
      ]
    },
    "scope_class": {
      "enum": [
        "current_repo",
        "selected_workset",
        "sparse_slice",
        "full_workspace",
        "policy_limited_view"
      ]
    },
    "privacy_class": {
      "enum": [
        "local_only_private",
        "workspace_shared_redacted",
        "support_export_redacted",
        "policy_withheld"
      ]
    },
    "source_class": {
      "enum": [
        "user_authored",
        "repo_provided",
        "policy_provided",
        "team_shared",
        "support_captured",
        "session_history"
      ]
    },
    "share_policy": {
      "enum": [
        "local_only_no_share",
        "workspace_share_explicit",
        "support_export_redacted_only",
        "share_disabled_by_policy"
      ]
    },
    "retention_mode": {
      "enum": [
        "local_only_default",
        "local_only_ephemeral",
        "workspace_shared_explicit",
        "repo_provided_read_only",
        "policy_owned_managed",
        "support_export_bounded"
      ]
    },
    "sync_class": {
      "enum": [
        "local_only",
        "explicit_user_sync",
        "workspace_shared",
        "repo_provided",
        "policy_managed",
        "support_export_only"
      ]
    },
    "redaction_profile": {
      "enum": [
        "literal_local_only",
        "hashes_scope_and_result_refs",
        "metadata_only_no_query_material",
        "policy_withheld",
        "explicit_literal_consent"
      ]
    },
    "retention_widening_basis": {
      "enum": [
        "not_widened_local_default",
        "explicit_user_opt_in",
        "policy_owned",
        "repo_provided_artifact",
        "team_shared_artifact",
        "support_case_export"
      ]
    },
    "result_semantics": {
      "enum": [
        "current_live_results",
        "captured_snapshot",
        "live_rerun_required",
        "scope_changed_since_capture",
        "empty_because_scope_changed"
      ]
    },
    "scope_honesty_state": {
      "enum": [
        "captured_scope_still_current",
        "recipient_must_re_resolve",
        "current_scope_wider_narrowed_to_captured",
        "current_scope_narrower_disclosed",
        "current_scope_changed_rebind_required"
      ]
    },
    "migration_state": {
      "enum": ["current", "migrated_from_previous_version", "migration_required"]
    },
    "query_text_mode": { "enum": ["local_text", "hash_only", "omitted_by_policy"] },
    "surface": { "enum": ["quick_open", "file_search", "symbol_search", "docs_search"] },
    "selection_scope_class": {
      "enum": [
        "current_item_only",
        "visible_range",
        "loaded_set",
        "all_matching_query",
        "explicit_custom_set",
        "provider_side_query"
      ]
    },
    "saved_view_owner_scope": {
      "enum": ["user", "workspace", "shared", "policy_pinned", "provider_owned"]
    },
    "saved_view_privacy_class": {
      "enum": [
        "local_only_private",
        "workspace_portable",
        "shared_redacted",
        "policy_governed",
        "provider_owned"
      ]
    },
    "saved_view_fallback_behavior": {
      "enum": [
        "preserve_and_label_degraded",
        "load_portable_subset_with_labels",
        "refuse_until_rebound",
        "provider_rebind_required"
      ]
    },
    "collection_count_term": {
      "enum": [
        "visible",
        "loaded",
        "all_matching",
        "selected",
        "included",
        "excluded",
        "blocked",
        "hidden",
        "hidden_by_policy",
        "hidden_by_filter",
        "stale"
      ]
    },
    "collection_count_status": {
      "enum": [
        "exact",
        "approximate",
        "provider_limited",
        "client_limited",
        "stale",
        "cached",
        "partial",
        "unknown"
      ]
    },
    "filter_operator": {
      "enum": [
        "free_text",
        "equals",
        "not_equals",
        "contains",
        "prefix",
        "in",
        "range",
        "exists",
        "greater_or_equal",
        "less_or_equal"
      ]
    },
    "filter_source_class": {
      "enum": [
        "user",
        "saved_view",
        "policy",
        "workset",
        "provider_limit",
        "client_limit",
        "partial_data"
      ]
    },
    "filter_literal_material_class": {
      "enum": ["raw_local_only", "redacted_text", "hashed_literal", "operator_only"]
    },
    "filter_round_trip_state": {
      "enum": [
        "round_trippable",
        "unsupported_by_provider",
        "stale_provider_data",
        "literal_withheld_by_policy"
      ]
    },
    "batch_action_class": {
      "enum": [
        "routine_non_mutating",
        "local_reversible",
        "remote_mutation",
        "destructive_mutation",
        "export_or_share",
        "provider_owned_mutation"
      ]
    },
    "batch_execution_origin_class": {
      "enum": [
        "client_local_execution",
        "provider_authoritative_execution",
        "mixed_client_then_provider"
      ]
    },
    "batch_member_disposition": {
      "enum": ["included", "excluded", "blocked", "hidden", "stale"]
    },
    "count_value": {
      "type": "object",
      "required": ["term", "status", "label"],
      "properties": {
        "term": { "$ref": "#/$defs/collection_count_term" },
        "status": { "$ref": "#/$defs/collection_count_status" },
        "value": { "type": "integer", "minimum": 0 },
        "label": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "scope_counters": {
      "type": "object",
      "required": [
        "visible",
        "loaded",
        "all_matching",
        "selected",
        "blocked",
        "hidden",
        "hidden_by_policy",
        "hidden_by_filter"
      ],
      "properties": {
        "visible": { "$ref": "#/$defs/count_value" },
        "loaded": { "$ref": "#/$defs/count_value" },
        "all_matching": { "$ref": "#/$defs/count_value" },
        "selected": { "$ref": "#/$defs/count_value" },
        "blocked": { "$ref": "#/$defs/count_value" },
        "hidden": { "$ref": "#/$defs/count_value" },
        "hidden_by_policy": { "$ref": "#/$defs/count_value" },
        "hidden_by_filter": { "$ref": "#/$defs/count_value" }
      },
      "additionalProperties": false
    },
    "filter_literal": {
      "type": "object",
      "required": ["material_class"],
      "properties": {
        "material_class": { "$ref": "#/$defs/filter_literal_material_class" },
        "display_value": { "type": "string" },
        "value_hash": { "type": "string" }
      },
      "additionalProperties": false
    },
    "filter_clause": {
      "type": "object",
      "required": [
        "clause_id",
        "field_id",
        "label",
        "operator",
        "source_class",
        "locked",
        "negated",
        "hidden_narrowing",
        "round_trip_state"
      ],
      "properties": {
        "clause_id": { "$ref": "#/$defs/non_empty_string" },
        "field_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "operator": { "$ref": "#/$defs/filter_operator" },
        "literal": { "$ref": "#/$defs/filter_literal" },
        "source_class": { "$ref": "#/$defs/filter_source_class" },
        "locked": { "type": "boolean" },
        "negated": { "type": "boolean" },
        "hidden_narrowing": { "type": "boolean" },
        "round_trip_state": { "$ref": "#/$defs/filter_round_trip_state" },
        "fallback_label": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "filter_expression": {
      "type": "object",
      "required": ["expression_kind"],
      "oneOf": [
        {
          "required": ["clause"],
          "properties": {
            "expression_kind": { "const": "clause" },
            "clause": { "$ref": "#/$defs/filter_clause" }
          },
          "additionalProperties": false
        },
        {
          "required": ["children"],
          "properties": {
            "expression_kind": { "enum": ["and", "or"] },
            "children": {
              "type": "array",
              "items": { "$ref": "#/$defs/filter_expression" }
            }
          },
          "additionalProperties": false
        },
        {
          "required": ["child"],
          "properties": {
            "expression_kind": { "const": "not" },
            "child": { "$ref": "#/$defs/filter_expression" }
          },
          "additionalProperties": false
        }
      ]
    },
    "filter_ast": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "filter_ast_id",
        "compatibility_version",
        "root",
        "scope_label",
        "created_by",
        "created_at"
      ],
      "properties": {
        "record_kind": { "const": "collection_filter_ast_alpha" },
        "schema_version": { "const": 1 },
        "filter_ast_id": { "$ref": "#/$defs/non_empty_string" },
        "compatibility_version": { "$ref": "#/$defs/non_empty_string" },
        "root": { "$ref": "#/$defs/filter_expression" },
        "scope_label": { "$ref": "#/$defs/non_empty_string" },
        "degradation_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "created_by": { "$ref": "#/$defs/non_empty_string" },
        "created_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "sort_key": {
      "type": "object",
      "required": ["field_id", "descending"],
      "properties": {
        "field_id": { "$ref": "#/$defs/non_empty_string" },
        "descending": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "saved_view": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "saved_view_id",
        "name",
        "owner_scope",
        "privacy_class",
        "fallback_behavior",
        "filter_ast",
        "visible_column_ids",
        "pinned_column_ids",
        "scope_label",
        "captures_selection",
        "captures_provider_cursor",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "record_kind": { "const": "saved_collection_view_alpha" },
        "schema_version": { "const": 1 },
        "saved_view_id": { "$ref": "#/$defs/non_empty_string" },
        "name": { "$ref": "#/$defs/non_empty_string" },
        "owner_scope": { "$ref": "#/$defs/saved_view_owner_scope" },
        "privacy_class": { "$ref": "#/$defs/saved_view_privacy_class" },
        "fallback_behavior": { "$ref": "#/$defs/saved_view_fallback_behavior" },
        "filter_ast": { "$ref": "#/$defs/filter_ast" },
        "visible_column_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "pinned_column_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "sort_keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/sort_key" }
        },
        "scope_label": { "$ref": "#/$defs/non_empty_string" },
        "captures_selection": { "type": "boolean" },
        "captures_provider_cursor": { "type": "boolean" },
        "stale_or_degraded_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "created_at": { "$ref": "#/$defs/non_empty_string" },
        "updated_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "column_preset": {
      "type": "object",
      "required": ["column_preset_id", "visible_column_ids", "pinned_column_ids", "portable"],
      "properties": {
        "column_preset_id": { "$ref": "#/$defs/non_empty_string" },
        "visible_column_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "pinned_column_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "required_column_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "portable": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "selection_state": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "selection_id",
        "collection_view_id_ref",
        "scope_class",
        "selected_item_id_refs",
        "selected_count",
        "hidden_selected_count",
        "blocked_selected_count",
        "stale_selected_count",
        "basis_is_stale",
        "accessibility_summary"
      ],
      "properties": {
        "record_kind": { "const": "collection_selection_state_alpha" },
        "schema_version": { "const": 1 },
        "selection_id": { "$ref": "#/$defs/non_empty_string" },
        "collection_view_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "scope_class": { "$ref": "#/$defs/selection_scope_class" },
        "selected_item_id_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "anchor_item_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "selected_count": { "type": "integer", "minimum": 0 },
        "hidden_selected_count": { "type": "integer", "minimum": 0 },
        "blocked_selected_count": { "type": "integer", "minimum": 0 },
        "stale_selected_count": { "type": "integer", "minimum": 0 },
        "query_snapshot_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "basis_is_stale": { "type": "boolean" },
        "accessibility_summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "batch_review_member": {
      "type": "object",
      "required": ["item", "disposition", "reason_label"],
      "properties": {
        "item": {
          "type": "object",
          "required": [
            "stable_item_id",
            "surface_family",
            "source_ref",
            "display_label",
            "blocked",
            "hidden",
            "stale"
          ],
          "properties": {
            "stable_item_id": { "$ref": "#/$defs/non_empty_string" },
            "surface_family": { "$ref": "#/$defs/collection_surface_family" },
            "source_ref": { "$ref": "#/$defs/non_empty_string" },
            "display_label": { "$ref": "#/$defs/non_empty_string" },
            "blocked": { "type": "boolean" },
            "hidden": { "type": "boolean" },
            "stale": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "disposition": { "$ref": "#/$defs/batch_member_disposition" },
        "reason_label": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "batch_review_sheet": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "batch_review_id",
        "collection_view_id_ref",
        "action_id",
        "action_label",
        "action_class",
        "selection_scope_class",
        "execution_origin_class",
        "counters",
        "included_item_id_refs",
        "excluded_item_id_refs",
        "blocked_item_id_refs",
        "hidden_item_id_refs",
        "stale_item_id_refs",
        "members",
        "recovery_guidance",
        "review_required",
        "continue_action_id",
        "cancel_action_id"
      ],
      "properties": {
        "record_kind": { "const": "collection_batch_review_sheet_alpha" },
        "schema_version": { "const": 1 },
        "batch_review_id": { "$ref": "#/$defs/non_empty_string" },
        "collection_view_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "action_label": { "$ref": "#/$defs/non_empty_string" },
        "action_class": { "$ref": "#/$defs/batch_action_class" },
        "selection_scope_class": { "$ref": "#/$defs/selection_scope_class" },
        "execution_origin_class": { "$ref": "#/$defs/batch_execution_origin_class" },
        "counters": { "$ref": "#/$defs/scope_counters" },
        "included_item_id_refs": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "excluded_item_id_refs": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "blocked_item_id_refs": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "hidden_item_id_refs": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "stale_item_id_refs": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "members": { "type": "array", "items": { "$ref": "#/$defs/batch_review_member" } },
        "recovery_guidance": { "$ref": "#/$defs/non_empty_string" },
        "review_required": { "type": "boolean" },
        "continue_action_id": { "$ref": "#/$defs/non_empty_string" },
        "cancel_action_id": { "$ref": "#/$defs/non_empty_string" },
        "aftermath_summary": {
          "type": "object",
          "required": [
            "succeeded_count",
            "failed_count",
            "skipped_count",
            "blocked_count",
            "summary_label"
          ],
          "properties": {
            "succeeded_count": { "type": "integer", "minimum": 0 },
            "failed_count": { "type": "integer", "minimum": 0 },
            "skipped_count": { "type": "integer", "minimum": 0 },
            "blocked_count": { "type": "integer", "minimum": 0 },
            "summary_label": { "$ref": "#/$defs/non_empty_string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "saved_query": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "saved_query_id",
        "display_name",
        "source_class",
        "privacy_class",
        "retention_mode",
        "sync_class",
        "redaction_profile",
        "retention_widening_basis",
        "share_policy",
        "migration_state",
        "default_surface",
        "query_session_id_ref",
        "query_text_mode",
        "scope_binding_id_ref",
        "scope_class",
        "stable_scope_id",
        "scope_label",
        "captured_readiness_state",
        "planner_version",
        "result_semantics",
        "scope_honesty_state",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "record_kind": { "const": "saved_query" },
        "schema_version": { "const": 1 },
        "saved_query_id": { "$ref": "#/$defs/non_empty_string" },
        "display_name": { "$ref": "#/$defs/non_empty_string" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "privacy_class": { "$ref": "#/$defs/privacy_class" },
        "retention_mode": { "$ref": "#/$defs/retention_mode" },
        "sync_class": { "$ref": "#/$defs/sync_class" },
        "redaction_profile": { "$ref": "#/$defs/redaction_profile" },
        "retention_widening_basis": { "$ref": "#/$defs/retention_widening_basis" },
        "share_policy": { "$ref": "#/$defs/share_policy" },
        "migration_state": { "$ref": "#/$defs/migration_state" },
        "default_surface": { "$ref": "#/$defs/surface" },
        "query_session_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "query_text_mode": { "$ref": "#/$defs/query_text_mode" },
        "query_text": { "type": "string" },
        "query_hash": { "type": "string" },
