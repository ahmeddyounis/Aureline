{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/search/public_proof_publication_truth.schema.json",
  "title": "Aureline search, graph, and docs public-proof publication truth packet",
  "description": "Boundary schema for the stable public-proof publication of search, graph, and docs surfaces with known limits and downgrade automation. The packet is the single truth that the search shell, graph topology, docs/help, CLI/headless inspector, support export, release proof index, Help/About, and the published-truth dashboard all read; surfaces MUST NOT mint local copies or paraphrase publication posture.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "public_proof_publication_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/publication_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/publication_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "publication_lane_class": {
      "enum": [
        "search_public_proof_lane",
        "graph_public_proof_lane",
        "docs_public_proof_lane"
      ]
    },
    "publication_row_class": {
      "enum": [
        "search_public_truth",
        "graph_public_truth",
        "docs_public_truth",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "publication_state": {
      "enum": ["published_stable", "narrowed_below_stable", "withheld_pending_gap"]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "corpus_warmup_partial",
        "scope_subset_only",
        "imported_provider_only",
        "archived_snapshot_only",
        "heuristic_only",
        "feature_preview_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_partial_warm",
        "auto_withhold_on_provider_outage",
        "auto_archive_on_stale_capture",
        "auto_demote_on_low_confidence",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "proof_artifact_class": {
      "enum": [
        "release_proof_index_entry",
        "support_export_packet",
        "help_about_proof_card",
        "docs_published_truth_card",
        "dashboard_published_truth_row",
        "cli_headless_inspector_row"
      ]
    },
    "publication_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_publication_lane_coverage",
        "row_class_not_permitted_on_lane",
        "missing_known_limit",
        "missing_downgrade_automation",
        "published_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "raw_query_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "publication_state_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "proof_artifact_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "publication_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "publication_state",
        "known_limit_class",
        "downgrade_automation_class",
        "proof_artifact_class",
        "confidence_class",
        "evidence_refs",
        "raw_query_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/publication_lane_class" },
        "row_class": { "$ref": "#/$defs/publication_row_class" },
        "publication_state": { "$ref": "#/$defs/publication_state" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "proof_artifact_class": { "$ref": "#/$defs/proof_artifact_class" },
        "confidence_class": { "$ref": "#/$defs/publication_confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "raw_query_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "public_proof_publication_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_publication_state_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_proof_artifact_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "search_shell",
            "graph_topology",
            "docs_help",
            "cli_headless",
            "support_export",
            "release_proof_index",
            "help_about",
            "dashboard_published_truth"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "public_proof_publication_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_publication_state_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_proof_artifact_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
