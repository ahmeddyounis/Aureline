{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/search/knowledge_evidence_packet.schema.json",
  "title": "graph_knowledge_evidence_packet",
  "description": "Citation-ready knowledge-plane evidence packet: topology view, impact explorer cards, ownership cards, and architecture explainer snapshots bound to one shared node/edge identity space, one freshness/confidence vocabulary, and one out-of-scope count model.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "captured_vs_live",
    "shared_identity_model",
    "topology_view",
    "consumer_projections",
    "promotion_state"
  ],
  "properties": {
    "record_kind": {
      "const": "graph_knowledge_evidence_packet"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_or_surface_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "captured_vs_live": {
      "type": "string",
      "enum": ["live", "captured_snapshot", "rerun_replaced_snapshot", "narrowed_scope_rerun"]
    },
    "shared_identity_model": {
      "$ref": "#/$defs/SharedIdentityModel"
    },
    "topology_view": {
      "$ref": "#/$defs/TopologyView"
    },
    "impact_cards": {
      "type": "array",
      "items": {"$ref": "#/$defs/ImpactCard"},
      "default": []
    },
    "ownership_cards": {
      "type": "array",
      "items": {"$ref": "#/$defs/OwnershipCard"},
      "default": []
    },
    "explainer_snapshots": {
      "type": "array",
      "items": {"$ref": "#/$defs/ExplainerSnapshot"},
      "default": []
    },
    "consumer_projections": {
      "type": "array",
      "items": {"$ref": "#/$defs/ConsumerProjection"}
    },
    "source_contract_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "default": []
    },
    "promotion_state": {
      "type": "string",
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "validation_findings": {
      "type": "array",
      "items": {"$ref": "#/$defs/ValidationFinding"},
      "default": []
    }
  },
  "$defs": {
    "FreshnessClass": {
      "type": "string",
      "enum": ["live", "hot_set", "warming", "cached", "stale", "replayed", "imported", "unknown"]
    },
    "ConfidenceClass": {
      "type": "string",
      "enum": ["exact", "imported_authoritative", "inferred_derived", "heuristic", "withheld"]
    },
    "OwnershipClass": {
      "type": "string",
      "enum": [
        "curated_first_party",
        "policy_derived",
        "imported_provider_metadata",
        "heuristic_inferred"
      ]
    },
    "NoImpactState": {
      "type": "string",
      "enum": [
        "visible_impact_present",
        "no_impact_in_workspace_or_slice",
        "impact_outside_slice_disclosed"
      ]
    },
    "ExplainerSourceClass": {
      "type": "string",
      "enum": ["curated", "generated"]
    },
    "EvidenceOpeningActionClass": {
      "type": "string",
      "enum": [
        "open_source_at_anchor",
        "inspect_graph_relation",
        "open_topology_table",
        "widen_scope",
        "export_evidence_card"
      ]
    },
    "ConsumerSurface": {
      "type": "string",
      "enum": [
        "topology_canvas",
        "list_table_fallback",
        "breadcrumb",
        "ai_inspector",
        "onboarding_tour",
        "review_explainer_card",
        "cli_headless",
        "support_export",
        "release_proof_index"
      ]
    },
    "FindingKind": {
      "type": "string",
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_packet_identity",
        "missing_shared_identity_model",
        "missing_topology_view",
        "node_edge_identity_mismatch",
        "out_of_scope_count_dropped",
        "topology_missing_widen_action",
        "no_impact_collapsed_on_out_of_scope_impact",
        "impact_card_missing_widen_action",
        "ownership_class_missing",
        "ownership_partiality_note_missing",
        "explainer_source_class_missing",
        "generated_explainer_missing_citations_or_inference",
        "explainer_missing_evidence_opening_actions",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "node_edge_identity_dropped",
        "freshness_vocabulary_dropped",
        "confidence_vocabulary_dropped",
        "out_of_scope_count_model_dropped",
        "raw_boundary_material_present",
        "promotion_state_mismatch"
      ]
    },
    "FindingSeverity": {
      "type": "string",
      "enum": ["info", "warning", "blocker"]
    },
    "ValidationFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": {"$ref": "#/$defs/FindingKind"},
        "severity": {"$ref": "#/$defs/FindingSeverity"},
        "summary": {"type": "string", "minLength": 1}
      }
    },
    "SharedIdentityModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity_model_ref",
        "node_ids",
        "edge_ids",
        "freshness_vocabulary_ref",
        "confidence_vocabulary_ref",
        "out_of_scope_count_model_ref"
      ],
      "properties": {
        "identity_model_ref": {"type": "string", "minLength": 1},
        "node_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "edge_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "freshness_vocabulary_ref": {"type": "string", "minLength": 1},
        "confidence_vocabulary_ref": {"type": "string", "minLength": 1},
        "out_of_scope_count_model_ref": {"type": "string", "minLength": 1}
      }
    },
    "TopologyNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "display_label", "freshness", "confidence"],
      "properties": {
        "node_id": {"type": "string", "minLength": 1},
        "display_label": {"type": "string"},
        "freshness": {"$ref": "#/$defs/FreshnessClass"},
        "confidence": {"$ref": "#/$defs/ConfidenceClass"}
      }
    },
    "TopologyEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_id",
        "from_node_id",
        "to_node_id",
        "edge_class",
        "freshness",
        "confidence"
      ],
      "properties": {
        "edge_id": {"type": "string", "minLength": 1},
        "from_node_id": {"type": "string", "minLength": 1},
        "to_node_id": {"type": "string", "minLength": 1},
        "edge_class": {"type": "string", "minLength": 1},
        "freshness": {"$ref": "#/$defs/FreshnessClass"},
        "confidence": {"$ref": "#/$defs/ConfidenceClass"}
      }
    },
    "TopologyView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "view_id",
        "nodes",
        "edges",
        "visible_node_count",
        "visible_edge_count",
        "out_of_scope_node_count",
        "out_of_scope_edge_count"
      ],
      "properties": {
        "view_id": {"type": "string", "minLength": 1},
        "nodes": {"type": "array", "items": {"$ref": "#/$defs/TopologyNode"}},
        "edges": {"type": "array", "items": {"$ref": "#/$defs/TopologyEdge"}},
        "visible_node_count": {"type": "integer", "minimum": 0},
        "visible_edge_count": {"type": "integer", "minimum": 0},
        "out_of_scope_node_count": {"type": "integer", "minimum": 0},
        "out_of_scope_edge_count": {"type": "integer", "minimum": 0},
        "widen_scope_action_ref": {"type": "string"}
      }
    },
    "ImpactCard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id",
        "subject_node_id",
        "no_impact_state",
        "visible_impact_count",
        "hidden_or_out_of_scope_count",
        "freshness",
        "confidence",
        "raw_boundary_material_excluded"
      ],
      "properties": {
        "card_id": {"type": "string", "minLength": 1},
        "subject_node_id": {"type": "string", "minLength": 1},
        "no_impact_state": {"$ref": "#/$defs/NoImpactState"},
        "visible_impact_count": {"type": "integer", "minimum": 0},
        "hidden_or_out_of_scope_count": {"type": "integer", "minimum": 0},
        "widen_action_ref": {"type": "string"},
        "freshness": {"$ref": "#/$defs/FreshnessClass"},
        "confidence": {"$ref": "#/$defs/ConfidenceClass"},
        "raw_boundary_material_excluded": {"type": "boolean"}
      }
    },
    "OwnershipCard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id",
        "subject_node_id",
        "ownership_class",
        "owner_display_label",
        "source_ref",
        "freshness",
        "confidence",
        "raw_boundary_material_excluded"
      ],
      "properties": {
        "card_id": {"type": "string", "minLength": 1},
        "subject_node_id": {"type": "string", "minLength": 1},
        "ownership_class": {"$ref": "#/$defs/OwnershipClass"},
        "owner_display_label": {"type": "string", "minLength": 1},
        "source_ref": {"type": "string", "minLength": 1},
        "freshness": {"$ref": "#/$defs/FreshnessClass"},
        "confidence": {"$ref": "#/$defs/ConfidenceClass"},
        "partiality_note": {"type": "string"},
        "raw_boundary_material_excluded": {"type": "boolean"}
      }
    },
    "ExplainerCitation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["citation_id", "subject_ref", "display_label"],
      "properties": {
        "citation_id": {"type": "string", "minLength": 1},
        "subject_ref": {"type": "string", "minLength": 1},
        "display_label": {"type": "string", "minLength": 1}
      }
    },
    "EvidenceOpeningAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_class", "subject_ref", "preserves_scope"],
      "properties": {
        "action_id": {"type": "string", "minLength": 1},
        "action_class": {"$ref": "#/$defs/EvidenceOpeningActionClass"},
        "subject_ref": {"type": "string", "minLength": 1},
        "preserves_scope": {"type": "boolean"}
      }
    },
    "ExplainerSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_id",
        "subject_node_id",
        "source_class",
        "prose_ref",
        "citations",
        "evidence_opening_actions",
        "freshness",
        "confidence",
        "raw_boundary_material_excluded"
      ],
      "properties": {
        "snapshot_id": {"type": "string", "minLength": 1},
        "subject_node_id": {"type": "string", "minLength": 1},
        "source_class": {"$ref": "#/$defs/ExplainerSourceClass"},
        "prose_ref": {"type": "string", "minLength": 1},
        "citations": {"type": "array", "items": {"$ref": "#/$defs/ExplainerCitation"}},
        "inference_label": {"type": "string"},
        "evidence_opening_actions": {
          "type": "array",
          "items": {"$ref": "#/$defs/EvidenceOpeningAction"}
        },
        "freshness": {"$ref": "#/$defs/FreshnessClass"},
        "confidence": {"$ref": "#/$defs/ConfidenceClass"},
        "raw_boundary_material_excluded": {"type": "boolean"}
      }
    },
    "ConsumerProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer_surface",
        "projection_ref",
        "packet_id_ref",
        "rendered_at",
        "preserves_node_edge_identity",
        "preserves_freshness_vocabulary",
        "preserves_confidence_vocabulary",
        "preserves_out_of_scope_count_model",
        "preserves_widen_action",
        "preserves_ownership_class",
        "preserves_explainer_citations",
        "preserves_same_packet",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {"$ref": "#/$defs/ConsumerSurface"},
        "projection_ref": {"type": "string", "minLength": 1},
        "packet_id_ref": {"type": "string", "minLength": 1},
        "rendered_at": {"type": "string", "minLength": 1},
        "preserves_node_edge_identity": {"type": "boolean"},
        "preserves_freshness_vocabulary": {"type": "boolean"},
        "preserves_confidence_vocabulary": {"type": "boolean"},
        "preserves_out_of_scope_count_model": {"type": "boolean"},
        "preserves_widen_action": {"type": "boolean"},
        "preserves_ownership_class": {"type": "boolean"},
        "preserves_explainer_citations": {"type": "boolean"},
        "preserves_same_packet": {"type": "boolean"},
        "supports_json_export": {"type": "boolean"},
        "raw_private_material_excluded": {"type": "boolean"},
        "ambient_authority_excluded": {"type": "boolean"}
      }
    }
  }
}
