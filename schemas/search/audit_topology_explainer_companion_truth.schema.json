{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/search/audit_topology_explainer_companion_truth.schema.json",
  "title": "Aureline audit topology, explainer, and companion-adjacent surface truth packet",
  "description": "Boundary schema for the stable audit of topology, explainer, and companion-adjacent surfaces shared by the topology canvas, explainer panel, docs/help, CLI/headless inspector, support export, and release proof index.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_surfaces",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "audit_topology_explainer_companion_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_surfaces": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/audit_surface_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/audit_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "audit_surface_class": {
      "enum": [
        "topology_canvas",
        "topology_table",
        "impact_explainer",
        "evidence_card",
        "companion_navigator",
        "companion_filter",
        "companion_export",
        "companion_history"
      ]
    },
    "audit_row_class": {
      "enum": [
        "topology_node",
        "topology_edge",
        "impact_edge",
        "evidence_card_row",
        "companion_action",
        "companion_filter_row",
        "companion_export_row",
        "companion_history_row"
      ]
    },
    "qualification_state": {
      "enum": ["qualified_stable", "narrowed_below_stable", "not_qualified_stable"]
    },
    "scope_disclosure_class": {
      "enum": [
        "current_repo",
        "selected_workset",
        "full_workspace",
        "remote_cache",
        "outside_current_scope",
        "scope_unbound"
      ]
    },
    "freshness_disclosure_class": {
      "enum": [
        "live",
        "partially_warmed",
        "stale_disclosed",
        "archived_frozen",
        "imported_snapshot",
        "freshness_unbound"
      ]
    },
    "provenance_disclosure_class": {
      "enum": [
        "workspace_canonical",
        "partial_index_inferred",
        "archive_preserved",
        "imported_provider_derived",
        "heuristic_derived",
        "provenance_unbound"
      ]
    },
    "downgrade_state_disclosure_class": {
      "enum": [
        "none",
        "narrowed_below_stable",
        "blocks_stable",
        "imported_snapshot",
        "archived_frozen",
        "downgrade_state_unbound"
      ]
    },
    "audit_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_audit_surface_row",
        "row_class_not_permitted_on_surface",
        "missing_scope_disclosure",
        "missing_freshness_disclosure",
        "missing_provenance_disclosure",
        "missing_downgrade_state_disclosure",
        "non_qualified_row_masquerading_stable",
        "narrowed_row_missing_disclosure_ref",
        "provenance_missing_disclosure_ref",
        "downgrade_missing_disclosure_ref",
        "raw_query_material_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "surface_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "qualification_vocabulary_collapsed",
        "audit_pillar_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "audit_row": {
      "type": "object",
      "required": [
        "row_id",
        "surface_class",
        "row_class",
        "qualification_state",
        "scope_disclosure",
        "freshness_disclosure",
        "provenance_disclosure",
        "downgrade_state_disclosure",
        "confidence_class",
        "raw_query_material_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "surface_class": { "$ref": "#/$defs/audit_surface_class" },
        "row_class": { "$ref": "#/$defs/audit_row_class" },
        "qualification_state": { "$ref": "#/$defs/qualification_state" },
        "scope_disclosure": { "$ref": "#/$defs/scope_disclosure_class" },
        "freshness_disclosure": { "$ref": "#/$defs/freshness_disclosure_class" },
        "provenance_disclosure": { "$ref": "#/$defs/provenance_disclosure_class" },
        "downgrade_state_disclosure": { "$ref": "#/$defs/downgrade_state_disclosure_class" },
        "confidence_class": { "$ref": "#/$defs/audit_confidence_class" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "provenance_disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "downgrade_disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "raw_query_material_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "audit_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_surface_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_qualification_vocabulary",
        "preserves_audit_pillars",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "topology_canvas",
            "explainer_panel",
            "docs_help",
            "cli_headless",
            "support_export",
            "release_proof_index"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "audit_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_surface_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_qualification_vocabulary": { "type": "boolean" },
        "preserves_audit_pillars": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
