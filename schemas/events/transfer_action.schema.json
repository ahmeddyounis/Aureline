{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/events/transfer_action.schema.json",
  "title": "Aureline transfer-action and interaction-integrity event contract",
  "description": "Boundary schema for transfer_action_record, interaction_integrity_alpha_packet, and interaction_integrity_validation_report. The contract is consumed by copy, paste, drag/drop, reopen, recovery, and support/export surfaces so representation class, target boundary, sensitive-copy review, high-risk paste posture, drag/drop verb, progress/cancel, named undo/recovery groups, and reopen/recover source class remain structured. Raw clipboard bodies, raw terminal paste bodies, raw file contents, raw private paths, raw URLs, and credentials are excluded from this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/transfer_action_record" },
    { "$ref": "#/$defs/interaction_integrity_alpha_packet" },
    { "$ref": "#/$defs/interaction_integrity_validation_report" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "opaque_id": { "type": "string", "minLength": 1, "maxLength": 720 },
    "safe_text": { "type": "string", "minLength": 1, "maxLength": 1600 },
    "timestamp": { "type": "string", "minLength": 1 },
    "record_kind": {
      "type": "string",
      "enum": [
        "transfer_action_record",
        "interaction_integrity_alpha_packet",
        "interaction_integrity_validation_report"
      ]
    },
    "transfer_surface_class": {
      "type": "string",
      "enum": [
        "editor",
        "review_diff",
        "search",
        "terminal",
        "project_entry",
        "support_export"
      ]
    },
    "transfer_action_kind": {
      "type": "string",
      "enum": ["copy", "paste", "drop", "reopen", "recover"]
    },
    "representation_class": {
      "type": "string",
      "enum": [
        "plain_text",
        "raw_safe",
        "rendered",
        "with_context",
        "escaped",
        "sanitized",
        "generated",
        "metadata_only"
      ]
    },
    "boundary_class": {
      "type": "string",
      "enum": [
        "local_workspace",
        "local_clipboard",
        "remote_host",
        "container_host",
        "review_surface",
        "search_query",
        "project_entry",
        "support_export"
      ]
    },
    "clipboard_route_class": {
      "type": "string",
      "enum": [
        "local_system_clipboard",
        "remote_clipboard_bridge",
        "named_register",
        "search_register",
        "policy_blocked"
      ]
    },
    "recovery_class": {
      "type": "string",
      "enum": [
        "exact_undo",
        "compensating_rollback",
        "restore_checkpoint",
        "evidence_only_no_rerun",
        "audit_only_no_mutation",
        "no_recovery_available"
      ]
    },
    "transfer_verb": {
      "type": "string",
      "enum": [
        "copy",
        "move",
        "open",
        "import",
        "split",
        "attach",
        "paste",
        "reopen",
        "recover",
        "blocked"
      ]
    },
    "progress_class": {
      "type": "string",
      "enum": ["not_required", "inline_progress", "durable_progress_with_cancel"]
    },
    "submit_posture": {
      "type": "string",
      "enum": ["no_auto_submit", "submit_after_review"]
    },
    "gate_result": {
      "type": "string",
      "enum": ["allowed", "review_required", "blocked"]
    },
    "reopen_recovery_source_class": {
      "type": "string",
      "enum": ["closed_intentionally", "crash_recovery", "disconnect_recovery"]
    },
    "reopen_recovery_surface": {
      "type": "string",
      "enum": ["editor", "diff", "query_search", "terminal"]
    },
    "undo_recovery_group_scope": {
      "type": "string",
      "enum": [
        "single_surface",
        "paste_or_drop_mutation",
        "multi_file_transfer_import"
      ]
    },
    "target_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_ref",
        "target_label",
        "boundary_class",
        "boundary_class_token",
        "boundary_label"
      ],
      "properties": {
        "target_ref": { "$ref": "#/$defs/opaque_id" },
        "target_label": { "$ref": "#/$defs/safe_text" },
        "boundary_class": { "$ref": "#/$defs/boundary_class" },
        "boundary_class_token": { "$ref": "#/$defs/boundary_class" },
        "boundary_label": { "$ref": "#/$defs/safe_text" },
        "host_label": { "$ref": "#/$defs/safe_text" }
      }
    },
    "sensitive_copy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sensitive_value_classes",
        "preview_required",
        "label_first_path",
        "preview_action_id",
        "clipboard_write_deferred_until_review"
      ],
      "properties": {
        "sensitive_value_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "preview_required": { "const": true },
        "label_first_path": { "const": true },
        "preview_action_id": { "$ref": "#/$defs/opaque_id" },
        "clipboard_write_deferred_until_review": { "const": true }
      }
    },
    "undo_recovery_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_ref",
        "display_name",
        "group_scope",
        "group_scope_token",
        "command_id",
        "recovery_class",
        "recovery_class_token"
      ],
      "properties": {
        "group_ref": { "$ref": "#/$defs/opaque_id" },
        "display_name": { "$ref": "#/$defs/safe_text" },
        "group_scope": { "$ref": "#/$defs/undo_recovery_group_scope" },
        "group_scope_token": { "$ref": "#/$defs/undo_recovery_group_scope" },
        "command_id": { "$ref": "#/$defs/opaque_id" },
        "recovery_class": { "$ref": "#/$defs/recovery_class" },
        "recovery_class_token": { "$ref": "#/$defs/recovery_class" },
        "mutation_journal_ref": { "$ref": "#/$defs/opaque_id" },
        "checkpoint_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "progress_class",
        "progress_class_token",
        "progress_label",
        "cancel_available",
        "summary_action_id"
      ],
      "properties": {
        "progress_class": { "$ref": "#/$defs/progress_class" },
        "progress_class_token": { "$ref": "#/$defs/progress_class" },
        "progress_label": { "$ref": "#/$defs/safe_text" },
        "cancel_available": { "type": "boolean" },
        "cancel_action_id": { "$ref": "#/$defs/opaque_id" },
        "summary_action_id": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "terminal_paste_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_ref",
        "target_host_label",
        "clipboard_route",
        "clipboard_route_token",
        "line_count",
        "bulk_hint",
        "bracketed_paste_available",
        "submit_posture",
        "submit_posture_token",
        "policy_result",
        "policy_result_token",
        "trust_result",
        "trust_result_token",
        "cancel_action_id",
        "continue_action_id",
        "commit_without_review_forbidden",
        "auto_submit_forbidden",
        "risk_reason_tokens"
      ],
      "properties": {
        "session_ref": { "$ref": "#/$defs/opaque_id" },
        "target_host_label": { "$ref": "#/$defs/safe_text" },
        "clipboard_route": { "$ref": "#/$defs/clipboard_route_class" },
        "clipboard_route_token": { "$ref": "#/$defs/clipboard_route_class" },
        "line_count": { "type": "integer", "minimum": 1 },
        "bulk_hint": { "$ref": "#/$defs/safe_text" },
        "bracketed_paste_available": { "type": "boolean" },
        "submit_posture": { "$ref": "#/$defs/submit_posture" },
        "submit_posture_token": { "$ref": "#/$defs/submit_posture" },
        "policy_result": { "$ref": "#/$defs/gate_result" },
        "policy_result_token": { "$ref": "#/$defs/gate_result" },
        "trust_result": { "$ref": "#/$defs/gate_result" },
        "trust_result_token": { "$ref": "#/$defs/gate_result" },
        "cancel_action_id": { "$ref": "#/$defs/opaque_id" },
        "continue_action_id": { "$ref": "#/$defs/opaque_id" },
        "commit_without_review_forbidden": { "const": true },
        "auto_submit_forbidden": { "const": true },
        "risk_reason_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },
    "drag_drop": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verb",
        "verb_token",
        "destination_scope",
        "broad_workspace_mutation",
        "checkpoint_before_commit",
        "collision_or_overwrite_review",
        "modifier_cue",
        "target_slot_ref"
      ],
      "properties": {
        "verb": { "$ref": "#/$defs/transfer_verb" },
        "verb_token": { "$ref": "#/$defs/transfer_verb" },
        "destination_scope": { "$ref": "#/$defs/safe_text" },
        "broad_workspace_mutation": { "type": "boolean" },
        "checkpoint_before_commit": { "type": "boolean" },
        "collision_or_overwrite_review": { "type": "boolean" },
        "modifier_cue": { "$ref": "#/$defs/safe_text" },
        "target_slot_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "reopen_recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "surface_token",
        "source_class",
        "source_class_token",
        "closed_or_recovered_ref",
        "reopen_command_id",
        "restored_target_identity_ref",
        "restored_live_authority",
        "auto_rerun_forbidden",
        "continuity_label"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/reopen_recovery_surface" },
        "surface_token": { "$ref": "#/$defs/reopen_recovery_surface" },
        "source_class": { "$ref": "#/$defs/reopen_recovery_source_class" },
        "source_class_token": { "$ref": "#/$defs/reopen_recovery_source_class" },
        "closed_or_recovered_ref": { "$ref": "#/$defs/opaque_id" },
        "reopen_command_id": { "$ref": "#/$defs/opaque_id" },
        "restored_target_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "restored_selection_ref": { "$ref": "#/$defs/opaque_id" },
        "restored_scroll_anchor_ref": { "$ref": "#/$defs/opaque_id" },
        "restored_live_authority": { "type": "boolean" },
        "auto_rerun_forbidden": { "type": "boolean" },
        "continuity_label": { "$ref": "#/$defs/safe_text" }
      }
    },
    "transfer_action_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "action_id",
        "action_kind",
        "action_kind_token",
        "source_surface",
        "source_surface_token",
        "source_ref",
        "representation_class",
        "representation_class_token",
        "target_boundary",
        "default_transfer",
        "recovery_class",
        "recovery_class_token",
        "policy_epoch_ref",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "type": "object", "additionalProperties": true },
        "record_kind": { "const": "transfer_action_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "action_kind": { "$ref": "#/$defs/transfer_action_kind" },
        "action_kind_token": { "$ref": "#/$defs/transfer_action_kind" },
        "source_surface": { "$ref": "#/$defs/transfer_surface_class" },
        "source_surface_token": { "$ref": "#/$defs/transfer_surface_class" },
        "source_ref": { "$ref": "#/$defs/opaque_id" },
        "representation_class": { "$ref": "#/$defs/representation_class" },
        "representation_class_token": { "$ref": "#/$defs/representation_class" },
        "target_boundary": { "$ref": "#/$defs/target_boundary" },
        "default_transfer": { "type": "boolean" },
        "sensitive_copy": { "$ref": "#/$defs/sensitive_copy" },
        "recovery_class": { "$ref": "#/$defs/recovery_class" },
        "recovery_class_token": { "$ref": "#/$defs/recovery_class" },
        "undo_recovery_group": { "$ref": "#/$defs/undo_recovery_group" },
        "progress": { "$ref": "#/$defs/progress" },
        "terminal_paste_review": { "$ref": "#/$defs/terminal_paste_review" },
        "drag_drop": { "$ref": "#/$defs/drag_drop" },
        "reopen_recovery": { "$ref": "#/$defs/reopen_recovery" },
        "policy_epoch_ref": { "$ref": "#/$defs/opaque_id" },
        "minted_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_packet_ref",
        "included_action_ids",
        "raw_payload_bodies_included",
        "omitted_payload_classes",
        "schema_refs"
      ],
      "properties": {
        "support_packet_ref": { "$ref": "#/$defs/opaque_id" },
        "included_action_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "raw_payload_bodies_included": { "const": false },
        "omitted_payload_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "schema_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },
    "interaction_integrity_alpha_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "minted_at",
        "source_contract_refs",
        "actions",
        "support_export"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "type": "object", "additionalProperties": true },
        "record_kind": { "const": "interaction_integrity_alpha_packet" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "minted_at": { "$ref": "#/$defs/timestamp" },
        "source_contract_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/transfer_action_record" }
        },
        "support_export": { "$ref": "#/$defs/support_export" }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_count",
        "surface_tokens",
        "reopen_recovery_surface_tokens",
        "high_risk_terminal_paste_covered",
        "drag_drop_verb_truth_covered",
        "large_transfer_progress_cancel_covered",
        "support_export_metadata_only"
      ],
      "properties": {
        "action_count": { "type": "integer", "minimum": 1 },
        "surface_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/transfer_surface_class" },
          "uniqueItems": true
        },
        "reopen_recovery_surface_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/reopen_recovery_surface" },
          "uniqueItems": true
        },
        "high_risk_terminal_paste_covered": { "type": "boolean" },
        "drag_drop_verb_truth_covered": { "type": "boolean" },
        "large_transfer_progress_cancel_covered": { "type": "boolean" },
        "support_export_metadata_only": { "type": "boolean" }
      }
    },
    "violation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["violation_id", "summary"],
      "properties": {
        "violation_id": { "$ref": "#/$defs/opaque_id" },
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "summary": { "$ref": "#/$defs/safe_text" }
      }
    },
    "interaction_integrity_validation_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "status",
        "coverage",
        "violations"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "record_kind": { "const": "interaction_integrity_validation_report" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "status": { "type": "string", "enum": ["passed", "failed"] },
        "coverage": { "$ref": "#/$defs/coverage" },
        "violations": {
          "type": "array",
          "items": { "$ref": "#/$defs/violation" }
        }
      }
    }
  }
}
