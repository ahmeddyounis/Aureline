{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/provider_arbitration_diagnostics_convergence.schema.json",
  "title": "Aureline provider-arbitration diagnostics convergence packet",
  "description": "Boundary schema for the provider_arbitration_diagnostics_convergence_packet and converged_diagnostic_cluster_record. The packet converges compiler, LSP, linter, framework, runtime, and policy diagnostics into one typed model with explicit source, confidence, freshness, and suppression class. Raw diagnostic payloads, raw source text, raw scanner bodies, raw logs, raw stack traces, raw paths, raw URLs, and raw secret material never cross this boundary.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/provider_arbitration_diagnostics_convergence_packet"
    },
    {
      "$ref": "#/$defs/converged_diagnostic_cluster_record"
    }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },
    "diagnostic_severity_class": {
      "type": "string",
      "enum": ["error", "warning", "notice", "hint"]
    },
    "diagnostic_freshness_class": {
      "type": "string",
      "enum": ["current", "recent", "warm_cached", "degraded_cached", "stale", "superseded", "imported_snapshot", "unverified"]
    },
    "diagnostic_anchor_remap_state_class": {
      "type": "string",
      "enum": ["exact", "contextual", "stale", "unmapped", "imported_static"]
    },
    "diagnostic_source_family": {
      "type": "string",
      "enum": [
        "editor_structural",
        "compiler_or_build",
        "language_server",
        "linter_formatter_style",
        "framework_or_schema_analyzer",
        "runtime_test_or_debug",
        "scanner_import",
        "policy_trust_or_security",
        "project_graph",
        "heuristic"
      ]
    },
    "provider_family": {
      "type": "string",
      "enum": [
        "syntax",
        "project_graph",
        "language_server",
        "framework_pack",
        "notebook_adapter",
        "generated_source_bridge",
        "ai_assist"
      ]
    },
    "health_state": {
      "type": "string",
      "enum": ["ready", "warming", "degraded", "cached_only", "policy_blocked", "capability_missing", "crash_loop_quarantined", "unavailable"]
    },
    "locality_class": {
      "type": "string",
      "enum": ["local_in_process", "local_sidecar", "workspace_remote_agent", "managed_service", "imported_snapshot"]
    },
    "suppression_class": {
      "type": "string",
      "enum": ["not_suppressed", "time_bounded", "policy_governed", "provider_specific", "baseline_waived"]
    },
    "quick_fix_safety_class": {
      "type": "string",
      "enum": [
        "safe_to_apply",
        "preview_required",
        "blocked_for_disagreement",
        "blocked_for_stale_state",
        "blocked_for_partial_scope",
        "blocked_for_generated_or_read_only",
        "blocked_for_provider_health",
        "inspect_only"
      ]
    },
    "batch_fix_scope_class": {
      "type": "string",
      "enum": [
        "single_diagnostic",
        "same_rule_same_file",
        "same_provider_same_file",
        "same_rule_workspace",
        "same_provider_workspace",
        "mixed_provider_blocked"
      ]
    },
    "severity_convergence_class": {
      "type": "string",
      "enum": ["single_severity", "conflicting_severity_present", "policy_overridden_severity_present"]
    },
    "convergence_display_state_class": {
      "type": "string",
      "enum": [
        "current_exact_live",
        "current_remapped_live",
        "current_with_severity_conflict",
        "current_mixed_static_and_runtime",
        "stale_or_superseded",
        "imported_snapshot_only",
        "suppressed_or_baselined_governed",
        "downgraded_for_provider_disagreement"
      ]
    },
    "semantic_layer_state_class": {
      "type": "string",
      "enum": [
        "semantic_current_exact",
        "semantic_current_remapped",
        "semantic_narrowed_scope",
        "semantic_cached_recent",
        "semantic_stale_epoch_mismatch",
        "syntactic_or_text_only",
        "runtime_observed_no_semantic_basis",
        "imported_snapshot_only",
        "policy_asserted_non_semantic"
      ]
    },
    "confidence_outcome_class": {
      "type": "string",
      "enum": ["exact", "heuristic", "partial", "stale", "unavailable"]
    },
    "trust_state": {
      "type": "string",
      "enum": ["trusted", "restricted"]
    },
    "redaction_class": {
      "type": "string",
      "enum": ["metadata_safe_default", "operator_only_restricted", "internal_support_restricted", "signing_evidence_only"]
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state", "execution_context_id"],
      "properties": {
        "policy_epoch": { "$ref": "#/$defs/opaque_id" },
        "trust_state": { "$ref": "#/$defs/trust_state" },
        "execution_context_id": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "provider_claim_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "provider_family",
        "source_family",
        "health_state",
        "freshness_class",
        "severity_class",
        "remap_state_class",
        "rule_id_ref",
        "category_ref",
        "anchor_family_id",
        "suppression_class",
        "quick_fix_safety_class",
        "batch_fix_scope_class",
        "is_primary",
        "locality_class",
        "summary"
      ],
      "properties": {
        "provider_id": { "$ref": "#/$defs/opaque_id" },
        "provider_family": { "$ref": "#/$defs/provider_family" },
        "source_family": { "$ref": "#/$defs/diagnostic_source_family" },
        "health_state": { "$ref": "#/$defs/health_state" },
        "freshness_class": { "$ref": "#/$defs/diagnostic_freshness_class" },
        "severity_class": { "$ref": "#/$defs/diagnostic_severity_class" },
        "remap_state_class": { "$ref": "#/$defs/diagnostic_anchor_remap_state_class" },
        "rule_id_ref": { "$ref": "#/$defs/opaque_id" },
        "category_ref": { "$ref": "#/$defs/opaque_id" },
        "anchor_family_id": { "$ref": "#/$defs/opaque_id" },
        "suppression_class": { "$ref": "#/$defs/suppression_class" },
        "quick_fix_safety_class": { "$ref": "#/$defs/quick_fix_safety_class" },
        "batch_fix_scope_class": { "$ref": "#/$defs/batch_fix_scope_class" },
        "is_primary": { "type": "boolean" },
        "locality_class": { "$ref": "#/$defs/locality_class" },
        "summary": { "$ref": "#/$defs/reviewable_summary" }
      }
    },
    "convergence_aggregate_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_provider_claims",
        "live_count",
        "imported_snapshot_count",
        "stale_or_superseded_count",
        "suppressed_count",
        "conflicting_severity_count",
        "blocked_quick_fix_count",
        "blocked_batch_fix_count"
      ],
      "properties": {
        "total_provider_claims": { "type": "integer", "minimum": 0 },
        "live_count": { "type": "integer", "minimum": 0 },
        "imported_snapshot_count": { "type": "integer", "minimum": 0 },
        "stale_or_superseded_count": { "type": "integer", "minimum": 0 },
        "suppressed_count": { "type": "integer", "minimum": 0 },
        "conflicting_severity_count": { "type": "integer", "minimum": 0 },
        "blocked_quick_fix_count": { "type": "integer", "minimum": 0 },
        "blocked_batch_fix_count": { "type": "integer", "minimum": 0 }
      }
    },
    "converged_diagnostic_cluster_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "cluster_id",
        "cluster_title",
        "primary_diagnostic_ref",
        "rule_id_ref",
        "category_ref",
        "dominant_severity_class",
        "severity_convergence_class",
        "cluster_freshness_class",
        "dominant_display_state_class",
        "semantic_layer_state_class",
        "convergence_outcome_class",
        "provider_claim_rows",
        "aggregate_counts",
        "suppression_review_refs",
        "code_action_summary_refs",
        "policy_context",
        "redaction_class",
        "captured_at",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "converged_diagnostic_cluster_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "cluster_id": { "$ref": "#/$defs/opaque_id" },
        "cluster_title": { "$ref": "#/$defs/reviewable_summary" },
        "primary_diagnostic_ref": { "$ref": "#/$defs/opaque_id" },
        "rule_id_ref": { "$ref": "#/$defs/opaque_id" },
        "category_ref": { "$ref": "#/$defs/opaque_id" },
        "dominant_severity_class": { "$ref": "#/$defs/diagnostic_severity_class" },
        "severity_convergence_class": { "$ref": "#/$defs/severity_convergence_class" },
        "cluster_freshness_class": { "$ref": "#/$defs/diagnostic_freshness_class" },
        "dominant_display_state_class": { "$ref": "#/$defs/convergence_display_state_class" },
        "semantic_layer_state_class": { "$ref": "#/$defs/semantic_layer_state_class" },
        "convergence_outcome_class": { "$ref": "#/$defs/confidence_outcome_class" },
        "provider_claim_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/provider_claim_row" },
          "minItems": 1
        },
        "aggregate_counts": { "$ref": "#/$defs/convergence_aggregate_counts" },
        "suppression_review_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "code_action_summary_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "captured_at": { "$ref": "#/$defs/timestamp" },
        "export_safe_summary": { "$ref": "#/$defs/reviewable_summary" }
      }
    },
    "convergence_packet_aggregate_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_clusters",
        "exact_clusters",
        "heuristic_clusters",
        "partial_clusters",
        "stale_clusters",
        "unavailable_clusters",
        "conflict_clusters",
        "suppressed_clusters",
        "blocked_batch_fix_clusters"
      ],
      "properties": {
        "total_clusters": { "type": "integer", "minimum": 0 },
        "exact_clusters": { "type": "integer", "minimum": 0 },
        "heuristic_clusters": { "type": "integer", "minimum": 0 },
        "partial_clusters": { "type": "integer", "minimum": 0 },
        "stale_clusters": { "type": "integer", "minimum": 0 },
        "unavailable_clusters": { "type": "integer", "minimum": 0 },
        "conflict_clusters": { "type": "integer", "minimum": 0 },
        "suppressed_clusters": { "type": "integer", "minimum": 0 },
        "blocked_batch_fix_clusters": { "type": "integer", "minimum": 0 }
      }
    },
    "provider_arbitration_diagnostics_convergence_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "captured_at",
        "doc_ref",
        "schema_ref",
        "clusters",
        "aggregate_counts",
        "raw_payload_excluded",
        "raw_private_material_excluded",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "provider_arbitration_diagnostics_convergence_packet"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "captured_at": { "$ref": "#/$defs/timestamp" },
        "doc_ref": { "type": "string" },
        "schema_ref": { "type": "string" },
        "clusters": {
          "type": "array",
          "items": { "$ref": "#/$defs/converged_diagnostic_cluster_record" }
        },
        "aggregate_counts": { "$ref": "#/$defs/convergence_packet_aggregate_counts" },
        "raw_payload_excluded": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "export_safe_summary": { "$ref": "#/$defs/reviewable_summary" }
      }
    }
  }
}
