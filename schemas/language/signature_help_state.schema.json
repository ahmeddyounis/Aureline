{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/signature_help_state.schema.json",
  "title": "Aureline signature-help session and active-parameter visibility vocabulary",
  "description": "Boundary schema for the signature_help_state_record frozen in docs/language/completion_and_inline_hint_contract.md. The record captures one active or deliberately suppressed signature-help state, including source kind, source freshness, locality, availability posture, confidence label, overload presentation, active-parameter visibility, keyboard-review posture, documentation availability, and compact signature rows when the state is visible. Raw source text, raw provider payloads, raw signatures, raw file contents, raw URLs, raw hostnames, and raw secret material never cross this boundary; the record carries opaque ids, typed vocabulary, epoch bindings, and reviewable summaries only. Adding a new source kind, freshness class, availability state, confidence label, overload-presentation class, parameter-visibility class, keyboard-review class, docs-availability state, locality class, or epoch role is additive-minor and requires a signature_help_state_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/signature_help_state_record"
    }
  ],
  "$defs": {
    "signature_help_state_schema_version": {
      "type": "integer",
      "const": 1
    },

    "record_kind": {
      "type": "string",
      "const": "signature_help_state_record"
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1
    },

    "timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "reviewable_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },

    "source_kind_class": {
      "type": "string",
      "enum": [
        "language_service",
        "framework_provider",
        "snippet_metadata",
        "cached_snapshot",
        "fallback_text"
      ],
      "description": "Frozen signature-help source taxonomy."
    },

    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ],
      "description": "Freshness vocabulary shared with the wider provider and truth contracts."
    },

    "availability_state_class": {
      "type": "string",
      "enum": [
        "visible",
        "visible_with_notice",
        "suppressed",
        "blocked"
      ],
      "description": "Whether the signature-help state is visible, visible but degraded, suppressed, or blocked."
    },

    "confidence_label_class": {
      "type": "string",
      "enum": [
        "semantic_current",
        "semantic_partial",
        "cached_recent",
        "stale",
        "limited_fallback",
        "blocked"
      ],
      "description": "How trustworthy the current signature-help state is."
    },

    "overload_presentation_class": {
      "type": "string",
      "enum": [
        "single_signature",
        "multi_signature_with_active_index",
        "multi_signature_collapsed",
        "signature_count_only"
      ],
      "description": "How overload information is presented."
    },

    "parameter_visibility_class": {
      "type": "string",
      "enum": [
        "active_parameter_highlighted",
        "active_parameter_with_truncation",
        "parameter_names_only",
        "parameter_unavailable"
      ],
      "description": "How much active-parameter truth is currently safe to claim."
    },

    "keyboard_review_class": {
      "type": "string",
      "enum": [
        "stable_during_parameter_entry",
        "stable_until_context_change",
        "suppressed_during_ime",
        "pinned_secondary_review"
      ],
      "description": "How signature help behaves during keyboard and IME review."
    },

    "documentation_availability_class": {
      "type": "string",
      "enum": [
        "inline_docs_available",
        "full_docs_link_available",
        "cached_docs_stale",
        "summary_only",
        "no_docs"
      ]
    },

    "locality_class": {
      "type": "string",
      "enum": [
        "local_in_process",
        "local_sidecar",
        "workspace_remote_agent",
        "managed_service",
        "local_user_pack",
        "imported_snapshot"
      ],
      "description": "Where the current signature-help state or cache came from."
    },

    "epoch_role_class": {
      "type": "string",
      "enum": [
        "workspace_scope",
        "provider_session",
        "signature_cache",
        "framework_pack_snapshot",
        "snippet_pack_revision"
      ]
    },

    "trust_state": {
      "type": "string",
      "enum": [
        "trusted",
        "restricted"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_epoch",
        "trust_state",
        "execution_context_id"
      ],
      "properties": {
        "policy_epoch": {
          "$ref": "#/$defs/opaque_id"
        },
        "trust_state": {
          "$ref": "#/$defs/trust_state"
        },
        "execution_context_id": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },

    "epoch_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "epoch_role_class",
        "epoch_ref"
      ],
      "properties": {
        "epoch_role_class": {
          "$ref": "#/$defs/epoch_role_class"
        },
        "epoch_ref": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },

    "signature_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signature_index",
        "callable_label",
        "parameter_count",
        "summary"
      ],
      "properties": {
        "signature_index": {
          "type": "integer",
          "minimum": 0
        },
        "callable_label": {
          "$ref": "#/$defs/reviewable_summary"
        },
        "parameter_count": {
          "type": "integer",
          "minimum": 0
        },
        "parameter_label_summaries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reviewable_summary"
          }
        },
        "documentation_availability_class": {
          "$ref": "#/$defs/documentation_availability_class"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },

    "signature_help_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "signature_help_state_schema_version",
        "signature_help_state_id",
        "source_kind_class",
        "source_display_label",
        "freshness_class",
        "locality_class",
        "availability_state_class",
        "confidence_label_class",
        "overload_presentation_class",
        "total_signature_count",
        "parameter_visibility_class",
        "keyboard_review_class",
        "documentation_availability_class",
        "signature_rows",
        "current_epoch_bindings",
        "policy_context",
        "redaction_class",
        "captured_at",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": {
          "$ref": "#/$defs/record_kind"
        },
        "signature_help_state_schema_version": {
          "$ref": "#/$defs/signature_help_state_schema_version"
        },
        "signature_help_state_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "invocation_anchor_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/opaque_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "source_kind_class": {
          "$ref": "#/$defs/source_kind_class"
        },
        "source_display_label": {
          "$ref": "#/$defs/reviewable_summary"
        },
        "source_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/opaque_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "provider_status_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/opaque_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "freshness_class": {
          "$ref": "#/$defs/freshness_class"
        },
        "locality_class": {
          "$ref": "#/$defs/locality_class"
        },
        "availability_state_class": {
          "$ref": "#/$defs/availability_state_class"
        },
        "availability_summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/reviewable_summary"
            },
            {
              "type": "null"
            }
          ]
        },
        "confidence_label_class": {
          "$ref": "#/$defs/confidence_label_class"
        },
        "overload_presentation_class": {
          "$ref": "#/$defs/overload_presentation_class"
        },
        "total_signature_count": {
          "type": "integer",
          "minimum": 0
        },
        "active_signature_index": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "active_parameter_index": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "parameter_visibility_class": {
          "$ref": "#/$defs/parameter_visibility_class"
        },
        "keyboard_review_class": {
          "$ref": "#/$defs/keyboard_review_class"
        },
        "documentation_availability_class": {
          "$ref": "#/$defs/documentation_availability_class"
        },
        "signature_rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/signature_row"
          }
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "policy_context": {
          "$ref": "#/$defs/policy_context"
        },
        "redaction_class": {
          "$ref": "#/$defs/redaction_class"
        },
        "captured_at": {
          "$ref": "#/$defs/timestamp"
        },
        "export_safe_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "availability_state_class": {
                "enum": [
                  "visible",
                  "visible_with_notice"
                ]
              }
            },
            "required": [
              "availability_state_class"
            ]
          },
          "then": {
            "required": [
              "active_signature_index"
            ],
            "properties": {
              "active_signature_index": {
                "type": "integer",
                "minimum": 0
              },
              "signature_rows": {
                "minItems": 1
              },
              "total_signature_count": {
                "minimum": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "availability_state_class": {
                "enum": [
                  "suppressed",
                  "blocked"
                ]
              }
            },
            "required": [
              "availability_state_class"
            ]
          },
          "then": {
            "required": [
              "availability_summary"
            ],
            "properties": {
              "availability_summary": {
                "$ref": "#/$defs/reviewable_summary"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "availability_state_class": {
                "const": "blocked"
              }
            },
            "required": [
              "availability_state_class"
            ]
          },
          "then": {
            "properties": {
              "confidence_label_class": {
                "const": "blocked"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "source_kind_class": {
                "const": "cached_snapshot"
              }
            },
            "required": [
              "source_kind_class"
            ]
          },
          "then": {
            "properties": {
              "freshness_class": {
                "not": {
                  "const": "authoritative_live"
                }
              },
              "confidence_label_class": {
                "not": {
                  "const": "semantic_current"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "source_kind_class": {
                "enum": [
                  "snippet_metadata",
                  "fallback_text"
                ]
              }
            },
            "required": [
              "source_kind_class"
            ]
          },
          "then": {
            "properties": {
              "confidence_label_class": {
                "not": {
                  "const": "semantic_current"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "total_signature_count": {
                "const": 1
              }
            },
            "required": [
              "total_signature_count"
            ]
          },
          "then": {
            "properties": {
              "overload_presentation_class": {
                "const": "single_signature"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "parameter_visibility_class": {
                "enum": [
                  "active_parameter_highlighted",
                  "active_parameter_with_truncation"
                ]
              }
            },
            "required": [
              "parameter_visibility_class"
            ]
          },
          "then": {
            "required": [
              "active_parameter_index"
            ],
            "properties": {
              "active_parameter_index": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "overload_presentation_class": {
                "const": "signature_count_only"
              }
            },
            "required": [
              "overload_presentation_class"
            ]
          },
          "then": {
            "properties": {
              "signature_rows": {
                "maxItems": 0
              }
            }
          }
        }
      ]
    }
  }
}
