{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/capability_negotiation_packet.schema.json",
  "title": "Aureline language capability-negotiation and arbitration packet",
  "description": "Boundary schema for the capability_negotiation_packet_record frozen in docs/language/provider_graph_and_arbitration_contract.md. The packet is emitted before a protected language surface treats a provider as current truth. It captures the requested surface, requested authority floor, requested scope, candidate providers, winner selection, downgrade cue, cached-reuse posture, alternate-provider disclosure, and the export-safe explanation needed by UI, CLI, notebook, AI, and support/export consumers. Raw source text, raw generated artifacts, raw notebook bodies, raw provider logs, raw hostnames, raw URLs, raw process arguments, and raw secret material never cross this boundary; the packet carries opaque ids, typed vocabulary, epoch refs, and redaction-safe summaries only. Adding a new provider family, role, health state, freshness class, scope-claim class, completeness class, scope-limit class, locality class, authority floor, authority class, surface class, eligibility class, conflict class, downgrade cue, cached-reuse reason, alternate-provider reason, generated note, notebook note, or epoch role is additive-minor and requires a capability_negotiation_packet_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/capability_negotiation_packet_record"
    }
  ],
  "$defs": {
    "capability_negotiation_packet_schema_version": {
      "type": "integer",
      "const": 1
    },

    "record_kind": {
      "type": "string",
      "const": "capability_negotiation_packet_record"
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1
    },

    "timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "reviewable_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },

    "provider_family": {
      "type": "string",
      "enum": [
        "syntax",
        "project_graph",
        "language_server",
        "framework_pack",
        "notebook_adapter",
        "generated_source_bridge",
        "ai_assist"
      ]
    },

    "provider_role_class": {
      "type": "string",
      "enum": [
        "primary_semantic",
        "secondary_semantic",
        "framework_overlay",
        "notebook_projection",
        "generated_overlay",
        "text_fallback",
        "assist_only"
      ]
    },

    "health_state": {
      "type": "string",
      "enum": [
        "ready",
        "warming",
        "degraded",
        "cached_only",
        "policy_blocked",
        "capability_missing",
        "crash_loop_quarantined",
        "unavailable"
      ]
    },

    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },

    "scope_claim_class": {
      "type": "string",
      "enum": [
        "single_file",
        "notebook_cell",
        "loaded_slice",
        "active_workset",
        "whole_workspace",
        "unavailable"
      ]
    },

    "completeness_class": {
      "type": "string",
      "enum": [
        "complete_for_claimed_scope",
        "partial_for_claimed_scope",
        "unavailable_for_claimed_scope"
      ]
    },

    "scope_limit_class": {
      "type": "string",
      "enum": [
        "single_file_only",
        "active_workset_only",
        "unloaded_roots_omitted",
        "generated_overlay_only",
        "generated_candidates_omitted",
        "notebook_cell_projection_only",
        "cross_cell_context_unavailable",
        "diff_or_review_slice_only",
        "policy_narrowed",
        "remote_shard_unreachable"
      ]
    },

    "locality_class": {
      "type": "string",
      "enum": [
        "local_in_process",
        "local_sidecar",
        "workspace_remote_agent",
        "managed_service",
        "imported_snapshot"
      ]
    },

    "surface_class": {
      "type": "string",
      "enum": [
        "definition",
        "reference",
        "hover",
        "rename",
        "completion",
        "code_action",
        "diagnostic",
        "notebook_context",
        "ai_assist_context"
      ]
    },

    "requested_authority_floor_class": {
      "type": "string",
      "enum": [
        "authoritative_required",
        "authoritative_preferred",
        "advisory_allowed"
      ]
    },

    "authority_class": {
      "type": "string",
      "enum": [
        "authoritative_for_claimed_scope",
        "advisory_for_claimed_scope",
        "fallback_only",
        "inspect_only"
      ]
    },

    "surface_support_class": {
      "type": "string",
      "enum": [
        "authoritative",
        "advisory",
        "fallback_only",
        "unsupported"
      ]
    },

    "candidate_eligibility_class": {
      "type": "string",
      "enum": [
        "eligible_primary",
        "eligible_alternate",
        "ineligible_health",
        "ineligible_scope",
        "ineligible_policy",
        "ineligible_surface"
      ]
    },

    "conflict_class": {
      "type": "string",
      "enum": [
        "none",
        "target_set_disagreement",
        "scope_coverage_disagreement",
        "framework_language_disagreement",
        "semantic_text_disagreement",
        "edit_safety_disagreement",
        "freshness_or_epoch_disagreement",
        "generated_boundary_disagreement",
        "notebook_boundary_disagreement",
        "narrative_fact_disagreement"
      ]
    },

    "downgrade_cue_class": {
      "type": "string",
      "enum": [
        "none",
        "scope_narrowed",
        "semantic_to_text_fallback",
        "semantic_to_file_local_syntax",
        "semantic_to_cached_result",
        "framework_certainty_lowered",
        "generated_scope_narrowed",
        "notebook_scope_narrowed",
        "provider_unavailable",
        "provider_crash_loop_quarantined",
        "policy_blocked"
      ]
    },

    "cached_reuse_reason_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "provider_warming",
        "provider_unreachable",
        "freshness_grace_not_expired",
        "policy_blocks_refresh",
        "offline_last_known_good",
        "manual_pin"
      ]
    },

    "alternate_provider_reason_class": {
      "type": "string",
      "enum": [
        "lower_authority",
        "narrower_scope",
        "older_epoch",
        "lower_framework_certainty",
        "health_excluded",
        "policy_excluded",
        "mutation_safety_lower",
        "redundant_same_answer"
      ]
    },

    "generated_note_class": {
      "type": "string",
      "enum": [
        "generated_overlay_in_scope",
        "generated_target_only",
        "generated_candidates_omitted",
        "generated_lineage_unknown"
      ]
    },

    "notebook_note_class": {
      "type": "string",
      "enum": [
        "notebook_cell_projection",
        "cross_cell_context_limited",
        "paired_export_projection",
        "kernel_runtime_not_consulted"
      ]
    },

    "epoch_role_class": {
      "type": "string",
      "enum": [
        "workspace_scope",
        "graph_snapshot",
        "provider_session",
        "language_project_model",
        "framework_pack_snapshot",
        "notebook_projection",
        "generated_lineage",
        "ai_context"
      ]
    },

    "trust_state": {
      "type": "string",
      "enum": [
        "trusted",
        "restricted"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_epoch",
        "trust_state",
        "execution_context_id"
      ],
      "properties": {
        "policy_epoch": {
          "$ref": "#/$defs/opaque_id"
        },
        "trust_state": {
          "$ref": "#/$defs/trust_state"
        },
        "execution_context_id": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },

    "epoch_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "epoch_role_class",
        "epoch_ref"
      ],
      "properties": {
        "epoch_role_class": {
          "$ref": "#/$defs/epoch_role_class"
        },
        "epoch_ref": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },

    "provider_candidate_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "provider_family",
        "provider_display_label",
        "provider_role_class",
        "surface_support_class",
        "health_state",
        "freshness_class",
        "scope_claim_class",
        "completeness_class",
        "locality_class",
        "current_epoch_bindings",
        "candidate_eligibility_class",
        "summary"
      ],
      "properties": {
        "provider_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "provider_family": {
          "$ref": "#/$defs/provider_family"
        },
        "provider_display_label": {
          "$ref": "#/$defs/reviewable_summary"
        },
        "provider_role_class": {
          "$ref": "#/$defs/provider_role_class"
        },
        "surface_support_class": {
          "$ref": "#/$defs/surface_support_class"
        },
        "health_state": {
          "$ref": "#/$defs/health_state"
        },
        "freshness_class": {
          "$ref": "#/$defs/freshness_class"
        },
        "scope_claim_class": {
          "$ref": "#/$defs/scope_claim_class"
        },
        "completeness_class": {
          "$ref": "#/$defs/completeness_class"
        },
        "scope_limit_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scope_limit_class"
          },
          "uniqueItems": true,
          "default": []
        },
        "locality_class": {
          "$ref": "#/$defs/locality_class"
        },
        "host_identity_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/opaque_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "generated_note_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/generated_note_class"
          },
          "uniqueItems": true,
          "default": []
        },
        "notebook_note_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/notebook_note_class"
          },
          "uniqueItems": true,
          "default": []
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "candidate_eligibility_class": {
          "$ref": "#/$defs/candidate_eligibility_class"
        },
        "ineligibility_summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/reviewable_summary"
            },
            {
              "type": "null"
            }
          ]
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "candidate_eligibility_class": {
                "enum": [
                  "ineligible_health",
                  "ineligible_scope",
                  "ineligible_policy",
                  "ineligible_surface"
                ]
              }
            },
            "required": [
              "candidate_eligibility_class"
            ]
          },
          "then": {
            "required": [
              "ineligibility_summary"
            ],
            "properties": {
              "ineligibility_summary": {
                "$ref": "#/$defs/reviewable_summary"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "provider_family": {
                "const": "ai_assist"
              }
            },
            "required": [
              "provider_family"
            ]
          },
          "then": {
            "properties": {
              "provider_role_class": {
                "const": "assist_only"
              },
              "surface_support_class": {
                "not": {
                  "const": "authoritative"
                }
              }
            }
          }
        }
      ]
    },

    "alternate_provider_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "provider_family",
        "reason_not_primary_class",
        "summary"
      ],
      "properties": {
        "provider_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "provider_family": {
          "$ref": "#/$defs/provider_family"
        },
        "reason_not_primary_class": {
          "$ref": "#/$defs/alternate_provider_reason_class"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },

    "arbitration_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chosen_provider_snapshot",
        "negotiated_authority_class",
        "conflict_class",
        "downgrade_cue_class",
        "cached_reuse_reason_class",
        "alternate_provider_rows",
        "export_safe_decision_summary"
      ],
      "properties": {
        "chosen_provider_snapshot": {
          "anyOf": [
            {
              "$ref": "#/$defs/provider_candidate_snapshot"
            },
            {
              "type": "null"
            }
          ]
        },
        "negotiated_authority_class": {
          "$ref": "#/$defs/authority_class"
        },
        "conflict_class": {
          "$ref": "#/$defs/conflict_class"
        },
        "downgrade_cue_class": {
          "$ref": "#/$defs/downgrade_cue_class"
        },
        "cached_reuse_reason_class": {
          "$ref": "#/$defs/cached_reuse_reason_class"
        },
        "alternate_provider_rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/alternate_provider_row"
          }
        },
        "export_safe_decision_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "chosen_provider_snapshot": {
                "type": "null"
              }
            },
            "required": [
              "chosen_provider_snapshot"
            ]
          },
          "then": {
            "properties": {
              "negotiated_authority_class": {
                "const": "inspect_only"
              },
              "downgrade_cue_class": {
                "not": {
                  "const": "none"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "negotiated_authority_class": {
                "const": "authoritative_for_claimed_scope"
              }
            },
            "required": [
              "negotiated_authority_class"
            ]
          },
          "then": {
            "properties": {
              "chosen_provider_snapshot": {
                "type": "object",
                "properties": {
                  "surface_support_class": {
                    "const": "authoritative"
                  },
                  "health_state": {
                    "const": "ready"
                  },
                  "freshness_class": {
                    "const": "authoritative_live"
                  },
                  "completeness_class": {
                    "const": "complete_for_claimed_scope"
                  }
                },
                "required": [
                  "surface_support_class",
                  "health_state",
                  "freshness_class",
                  "completeness_class"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "negotiated_authority_class": {
                "const": "authoritative_for_claimed_scope"
              },
              "chosen_provider_snapshot": {
                "type": "object",
                "properties": {
                  "scope_claim_class": {
                    "const": "whole_workspace"
                  }
                },
                "required": [
                  "scope_claim_class"
                ]
              }
            },
            "required": [
              "negotiated_authority_class",
              "chosen_provider_snapshot"
            ]
          },
          "then": {
            "properties": {
              "chosen_provider_snapshot": {
                "properties": {
                  "provider_family": {
                    "enum": [
                      "project_graph",
                      "language_server",
                      "framework_pack"
                    ]
                  },
                  "scope_limit_classes": {
                    "maxItems": 0
                  }
                },
                "required": [
                  "provider_family",
                  "scope_limit_classes"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "cached_reuse_reason_class": {
                "not": {
                  "const": "not_applicable"
                }
              }
            },
            "required": [
              "cached_reuse_reason_class"
            ]
          },
          "then": {
            "properties": {
              "downgrade_cue_class": {
                "not": {
                  "const": "none"
                }
              },
              "chosen_provider_snapshot": {
                "type": "object",
                "properties": {
                  "freshness_class": {
                    "not": {
                      "const": "authoritative_live"
                    }
                  }
                },
                "required": [
                  "freshness_class"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "downgrade_cue_class": {
                "enum": [
                  "semantic_to_text_fallback",
                  "semantic_to_file_local_syntax"
                ]
              }
            },
            "required": [
              "downgrade_cue_class"
            ]
          },
          "then": {
            "properties": {
              "chosen_provider_snapshot": {
                "type": "object",
                "properties": {
                  "provider_family": {
                    "const": "syntax"
                  },
                  "provider_role_class": {
                    "const": "text_fallback"
                  }
                },
                "required": [
                  "provider_family",
                  "provider_role_class"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "conflict_class": {
                "not": {
                  "const": "none"
                }
              }
            },
            "required": [
              "conflict_class"
            ]
          },
          "then": {
            "properties": {
              "alternate_provider_rows": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },

    "capability_negotiation_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "capability_negotiation_packet_schema_version",
        "capability_negotiation_packet_id",
        "requested_surface_class",
        "requested_authority_floor_class",
        "requested_scope_claim_class",
        "requested_subject_ref",
        "candidate_provider_snapshots",
        "arbitration_outcome",
        "policy_context",
        "redaction_class",
        "captured_at",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": {
          "$ref": "#/$defs/record_kind"
        },
        "capability_negotiation_packet_schema_version": {
          "$ref": "#/$defs/capability_negotiation_packet_schema_version"
        },
        "capability_negotiation_packet_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "requested_surface_class": {
          "$ref": "#/$defs/surface_class"
        },
        "requested_authority_floor_class": {
          "$ref": "#/$defs/requested_authority_floor_class"
        },
        "requested_scope_claim_class": {
          "$ref": "#/$defs/scope_claim_class"
        },
        "requested_subject_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "candidate_provider_snapshots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/provider_candidate_snapshot"
          },
          "minItems": 1
        },
        "arbitration_outcome": {
          "$ref": "#/$defs/arbitration_outcome"
        },
        "policy_context": {
          "$ref": "#/$defs/policy_context"
        },
        "redaction_class": {
          "$ref": "#/$defs/redaction_class"
        },
        "captured_at": {
          "$ref": "#/$defs/timestamp"
        },
        "export_safe_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    }
  }
}
