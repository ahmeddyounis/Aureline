{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/provider_status_row.schema.json",
  "title": "Aureline language-provider status row vocabulary",
  "description": "Boundary schema for the provider_status_row_record frozen in docs/language/provider_graph_and_arbitration_contract.md. The row is the compact projection every language-status inspector, provenance panel, notebook-context inspector, AI evidence packet, support export, and review surface reads when it needs one stable answer to which language-intelligence provider is currently available, for which scope, with what health/freshness/locality posture, and for which protected surfaces it is authoritative, advisory, fallback-only, or unsupported. Raw source text, raw notebook payloads, raw generated artifacts, raw provider logs, raw process arguments, raw hostnames, and raw secret material never cross this boundary; the row carries opaque ids, typed vocabulary, epoch refs, and export-safe summaries only. Adding a new provider family, role, health state, freshness class, scope-claim class, completeness class, scope-limit class, locality class, surface class, surface-support class, generated note, notebook note, or epoch role is additive-minor and requires a provider_status_row_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/provider_status_row_record"
    }
  ],
  "$defs": {
    "provider_status_row_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the provider-status-row export. Current value is 1."
    },

    "record_kind": {
      "type": "string",
      "const": "provider_status_row_record"
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe to log, safe on RPC, and safe in support/export packets."
    },

    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp."
    },

    "reviewable_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480,
      "description": "Short export-safe summary. Never carries raw source text or raw provider payloads."
    },

    "provider_family": {
      "type": "string",
      "enum": [
        "syntax",
        "project_graph",
        "language_server",
        "framework_pack",
        "notebook_adapter",
        "generated_source_bridge",
        "ai_assist"
      ],
      "description": "Frozen language-provider family vocabulary."
    },

    "provider_role_class": {
      "type": "string",
      "enum": [
        "primary_semantic",
        "secondary_semantic",
        "framework_overlay",
        "notebook_projection",
        "generated_overlay",
        "text_fallback",
        "assist_only"
      ],
      "description": "Frozen provider-role vocabulary. Family and role are separate axes."
    },

    "health_state": {
      "type": "string",
      "enum": [
        "ready",
        "warming",
        "degraded",
        "cached_only",
        "policy_blocked",
        "capability_missing",
        "crash_loop_quarantined",
        "unavailable"
      ],
      "description": "Frozen provider-health vocabulary."
    },

    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ],
      "description": "Shared freshness scale reused from the wider governance/search truth vocabulary."
    },

    "scope_claim_class": {
      "type": "string",
      "enum": [
        "single_file",
        "notebook_cell",
        "loaded_slice",
        "active_workset",
        "whole_workspace",
        "unavailable"
      ],
      "description": "What scope the provider currently claims to cover."
    },

    "completeness_class": {
      "type": "string",
      "enum": [
        "complete_for_claimed_scope",
        "partial_for_claimed_scope",
        "unavailable_for_claimed_scope"
      ],
      "description": "How complete the provider is for the scope it claims above."
    },

    "scope_limit_class": {
      "type": "string",
      "enum": [
        "single_file_only",
        "active_workset_only",
        "unloaded_roots_omitted",
        "generated_overlay_only",
        "generated_candidates_omitted",
        "notebook_cell_projection_only",
        "cross_cell_context_unavailable",
        "diff_or_review_slice_only",
        "policy_narrowed",
        "remote_shard_unreachable"
      ],
      "description": "Concrete reason the provider is narrower than a larger potential scope."
    },

    "locality_class": {
      "type": "string",
      "enum": [
        "local_in_process",
        "local_sidecar",
        "workspace_remote_agent",
        "managed_service",
        "imported_snapshot"
      ],
      "description": "Where the provider ran or where the provider truth came from."
    },

    "surface_class": {
      "type": "string",
      "enum": [
        "definition",
        "reference",
        "hover",
        "rename",
        "completion",
        "code_action",
        "diagnostic",
        "notebook_context",
        "ai_assist_context"
      ],
      "description": "Protected language-capable surfaces and consumers that reuse this vocabulary."
    },

    "surface_support_class": {
      "type": "string",
      "enum": [
        "authoritative",
        "advisory",
        "fallback_only",
        "unsupported"
      ],
      "description": "How the provider may be treated on a given surface."
    },

    "generated_note_class": {
      "type": "string",
      "enum": [
        "generated_overlay_in_scope",
        "generated_target_only",
        "generated_candidates_omitted",
        "generated_lineage_unknown"
      ],
      "description": "Generated-source caveats attached to the provider row."
    },

    "notebook_note_class": {
      "type": "string",
      "enum": [
        "notebook_cell_projection",
        "cross_cell_context_limited",
        "paired_export_projection",
        "kernel_runtime_not_consulted"
      ],
      "description": "Notebook-specific caveats attached to the provider row."
    },

    "epoch_role_class": {
      "type": "string",
      "enum": [
        "workspace_scope",
        "graph_snapshot",
        "provider_session",
        "language_project_model",
        "framework_pack_snapshot",
        "notebook_projection",
        "generated_lineage",
        "ai_context"
      ],
      "description": "Opaque epoch role carried for replayability and support. The schema names the role, not the epoch grammar."
    },

    "trust_state": {
      "type": "string",
      "enum": [
        "trusted",
        "restricted"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ],
      "description": "Shared redaction posture. Raw payloads remain forbidden regardless of class."
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_epoch",
        "trust_state",
        "execution_context_id"
      ],
      "properties": {
        "policy_epoch": {
          "$ref": "#/$defs/opaque_id"
        },
        "trust_state": {
          "$ref": "#/$defs/trust_state"
        },
        "execution_context_id": {
          "$ref": "#/$defs/opaque_id"
        }
      },
      "description": "Minimal policy/trust context exported with the row."
    },

    "epoch_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "epoch_role_class",
        "epoch_ref"
      ],
      "properties": {
        "epoch_role_class": {
          "$ref": "#/$defs/epoch_role_class"
        },
        "epoch_ref": {
          "$ref": "#/$defs/opaque_id"
        }
      },
      "description": "One opaque epoch binding relevant to this provider row."
    },

    "surface_support_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "surface_support_class",
        "summary"
      ],
      "properties": {
        "surface_class": {
          "$ref": "#/$defs/surface_class"
        },
        "surface_support_class": {
          "$ref": "#/$defs/surface_support_class"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      },
      "description": "Per-surface support posture for this provider."
    },

    "provider_status_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "provider_status_row_schema_version",
        "provider_status_row_id",
        "provider_id",
        "provider_family",
        "provider_display_label",
        "provider_role_class",
        "health_state",
        "freshness_class",
        "scope_claim_class",
        "completeness_class",
        "locality_class",
        "current_epoch_bindings",
        "supported_surface_rows",
        "policy_context",
        "redaction_class",
        "captured_at",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": {
          "$ref": "#/$defs/record_kind"
        },
        "provider_status_row_schema_version": {
          "$ref": "#/$defs/provider_status_row_schema_version"
        },
        "provider_status_row_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "provider_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "provider_family": {
          "$ref": "#/$defs/provider_family"
        },
        "provider_display_label": {
          "$ref": "#/$defs/reviewable_summary"
        },
        "provider_role_class": {
          "$ref": "#/$defs/provider_role_class"
        },
        "connected_pack_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/opaque_id"
            },
            {
              "type": "null"
            }
          ],
          "description": "Optional pack, server, or model-pack ref owning this provider."
        },
        "health_state": {
          "$ref": "#/$defs/health_state"
        },
        "health_reason_summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/reviewable_summary"
            },
            {
              "type": "null"
            }
          ]
        },
        "freshness_class": {
          "$ref": "#/$defs/freshness_class"
        },
        "scope_claim_class": {
          "$ref": "#/$defs/scope_claim_class"
        },
        "completeness_class": {
          "$ref": "#/$defs/completeness_class"
        },
        "scope_limit_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scope_limit_class"
          },
          "uniqueItems": true,
          "default": []
        },
        "locality_class": {
          "$ref": "#/$defs/locality_class"
        },
        "host_identity_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/opaque_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "generated_note_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/generated_note_class"
          },
          "uniqueItems": true,
          "default": []
        },
        "notebook_note_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/notebook_note_class"
          },
          "uniqueItems": true,
          "default": []
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "supported_surface_rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_support_row"
          },
          "minItems": 1
        },
        "policy_context": {
          "$ref": "#/$defs/policy_context"
        },
        "redaction_class": {
          "$ref": "#/$defs/redaction_class"
        },
        "captured_at": {
          "$ref": "#/$defs/timestamp"
        },
        "export_safe_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "health_state": {
                "const": "crash_loop_quarantined"
              }
            },
            "required": [
              "health_state"
            ]
          },
          "then": {
            "required": [
              "health_reason_summary"
            ],
            "properties": {
              "health_reason_summary": {
                "$ref": "#/$defs/reviewable_summary"
              },
              "freshness_class": {
                "not": {
                  "const": "authoritative_live"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "locality_class": {
                "const": "imported_snapshot"
              }
            },
            "required": [
              "locality_class"
            ]
          },
          "then": {
            "properties": {
              "freshness_class": {
                "not": {
                  "const": "authoritative_live"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "scope_claim_class": {
                "const": "whole_workspace"
              },
              "completeness_class": {
                "const": "complete_for_claimed_scope"
              }
            },
            "required": [
              "scope_claim_class",
              "completeness_class"
            ]
          },
          "then": {
            "properties": {
              "scope_limit_classes": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "provider_family": {
                "const": "ai_assist"
              }
            },
            "required": [
              "provider_family"
            ]
          },
          "then": {
            "properties": {
              "provider_role_class": {
                "const": "assist_only"
              },
              "supported_surface_rows": {
                "items": {
                  "properties": {
                    "surface_support_class": {
                      "not": {
                        "const": "authoritative"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
