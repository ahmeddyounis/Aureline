{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/diagnostic_cluster.schema.json",
  "title": "Aureline diagnostic cluster, freshness, anchor-remap, and imported-baseline contract",
  "description": "Boundary schema for the diagnostic_cluster_record frozen in docs/language/diagnostics_and_code_action_contract.md. The record is the canonical issue-row packet every Problems surface, inline marker, hover, review annotation, CLI mirror, support export, and future quality-action surface reads when materially identical diagnostics need to collapse into one row without losing source taxonomy, evidence plane, imported/live origin, freshness, semantic-layer state, anchor-remap lineage, or imported-baseline context. Raw diagnostic payloads, raw source text, raw scanner bodies, raw logs, raw stack traces, raw paths, raw URLs, and raw secret material never cross this boundary; the record carries opaque ids, typed vocabulary, epoch bindings, and export-safe summaries only. Adding a new source kind, evidence plane, origin class, support class, confidence class, severity class, freshness class, semantic-layer state, dedupe reason, display state, detail-section class, anchor kind, anchor-remap state, epoch role, comparison state, or delta state is additive-minor and requires a diagnostic_cluster_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/diagnostic_cluster_record"
    }
  ],
  "$defs": {
    "diagnostic_cluster_schema_version": {
      "type": "integer",
      "const": 1
    },

    "record_kind": {
      "type": "string",
      "const": "diagnostic_cluster_record"
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1
    },

    "timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "reviewable_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },

    "short_or_null_summary": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/reviewable_summary"
        }
      ]
    },

    "source_kind_class": {
      "type": "string",
      "enum": [
        "compiler_or_build",
        "language_server",
        "linter_formatter_style",
        "framework_or_schema_analyzer",
        "runtime_test_or_debug",
        "policy_trust_or_security"
      ]
    },

    "evidence_plane_class": {
      "type": "string",
      "enum": [
        "static_analysis",
        "build_time_execution",
        "runtime_or_test_execution",
        "policy_or_trust_evaluation",
        "imported_snapshot_evidence"
      ]
    },

    "origin_class": {
      "type": "string",
      "enum": [
        "live_local_session",
        "live_remote_session",
        "managed_provider_live",
        "imported_snapshot",
        "replayed_support_bundle"
      ]
    },

    "support_class": {
      "type": "string",
      "enum": [
        "first_party_supported",
        "first_party_best_effort",
        "external_tooling",
        "policy_governed"
      ]
    },

    "confidence_class": {
      "type": "string",
      "enum": [
        "authoritative",
        "structured_import",
        "heuristic_best_effort",
        "degraded_partial",
        "policy_asserted"
      ]
    },

    "severity_class": {
      "type": "string",
      "enum": [
        "error",
        "warning",
        "information",
        "hint"
      ]
    },

    "severity_convergence_class": {
      "type": "string",
      "enum": [
        "single_severity",
        "conflicting_severity_present",
        "policy_overridden_severity_present"
      ]
    },

    "diagnostic_freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "recent",
        "stale",
        "superseded",
        "imported_snapshot"
      ]
    },

    "semantic_layer_state_class": {
      "type": "string",
      "enum": [
        "semantic_current_exact",
        "semantic_current_remapped",
        "semantic_narrowed_scope",
        "semantic_cached_recent",
        "semantic_stale_epoch_mismatch",
        "syntactic_or_text_only",
        "runtime_observed_no_semantic_basis",
        "imported_snapshot_only",
        "policy_asserted_non_semantic"
      ]
    },

    "dominant_display_state_class": {
      "type": "string",
      "enum": [
        "current_exact_live",
        "current_remapped_live",
        "current_with_severity_conflict",
        "current_mixed_static_and_runtime",
        "stale_or_superseded",
        "imported_snapshot_only",
        "suppressed_or_baselined_governed"
      ]
    },

    "dedupe_reason_class": {
      "type": "string",
      "enum": [
        "same_rule_same_exact_anchor",
        "same_rule_same_remap_family",
        "same_message_same_anchor_family",
        "same_entity_same_effect_scope",
        "runtime_static_same_failure_family",
        "imported_baseline_overlap"
      ]
    },

    "detail_section_class": {
      "type": "string",
      "enum": [
        "cluster_provenance_table",
        "freshness_and_epoch_strip",
        "severity_conflict_explainer",
        "runtime_static_evidence_split",
        "anchor_and_remap_history",
        "imported_baseline_and_delta",
        "suppression_and_baseline_governance",
        "available_code_actions",
        "generated_and_protected_impact",
        "raw_payload_and_export_links"
      ]
    },

    "anchor_kind_class": {
      "type": "string",
      "enum": [
        "file_span",
        "symbol_anchor",
        "generated_pair_anchor",
        "notebook_cell_anchor",
        "target_scope_only",
        "workspace_scope_only"
      ]
    },

    "anchor_remap_state_class": {
      "type": "string",
      "enum": [
        "exact",
        "contextual",
        "stale",
        "unmapped",
        "imported_static"
      ]
    },

    "epoch_role_class": {
      "type": "string",
      "enum": [
        "workspace_scope",
        "diagnostic_collection",
        "language_semantic_model",
        "build_graph",
        "execution_run",
        "imported_scan",
        "anchor_remap_family",
        "policy_bundle"
      ]
    },

    "comparison_state_class": {
      "type": "string",
      "enum": [
        "compatible_same_tool_profile",
        "compatible_rule_subset",
        "incompatible_profile_drift",
        "incompatible_target_drift",
        "unknown"
      ]
    },

    "delta_state_class": {
      "type": "string",
      "enum": [
        "new",
        "persisting",
        "resolved",
        "suppressed",
        "waived",
        "unmapped"
      ]
    },

    "language_provider_family": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "enum": [
            "syntax",
            "project_graph",
            "language_server",
            "framework_pack",
            "notebook_adapter",
            "generated_source_bridge",
            "ai_assist"
          ]
        }
      ]
    },

    "locality_class": {
      "type": "string",
      "enum": [
        "local_in_process",
        "local_sidecar",
        "workspace_remote_agent",
        "managed_service",
        "imported_snapshot"
      ]
    },

    "trust_state": {
      "type": "string",
      "enum": [
        "trusted",
        "restricted"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "non_negative_int": {
      "type": "integer",
      "minimum": 0
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_epoch",
        "trust_state",
        "execution_context_id"
      ],
      "properties": {
        "policy_epoch": {
          "$ref": "#/$defs/opaque_id"
        },
        "trust_state": {
          "$ref": "#/$defs/trust_state"
        },
        "execution_context_id": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },

    "epoch_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "epoch_role_class",
        "epoch_ref"
      ],
      "properties": {
        "epoch_role_class": {
          "$ref": "#/$defs/epoch_role_class"
        },
        "epoch_ref": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },

    "anchor_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "anchor_family_id",
        "anchor_kind_class",
        "anchor_ref",
        "path_ref",
        "span_summary"
      ],
      "properties": {
        "anchor_family_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "anchor_kind_class": {
          "$ref": "#/$defs/anchor_kind_class"
        },
        "anchor_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "path_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "span_summary": {
          "$ref": "#/$defs/short_or_null_summary"
        }
      }
    },

    "anchor_remap_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "original_anchor_ref",
        "current_anchor_ref",
        "remap_state_class",
        "evidence_basis_ref",
        "source_revision_ref",
        "current_revision_ref",
        "actor_tool_ref",
        "summary"
      ],
      "properties": {
        "original_anchor_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "current_anchor_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "remap_state_class": {
          "$ref": "#/$defs/anchor_remap_state_class"
        },
        "evidence_basis_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "source_revision_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "current_revision_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "actor_tool_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "summary": {
          "$ref": "#/$defs/short_or_null_summary"
        }
      }
    },

    "imported_baseline_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "import_session_ref",
        "baseline_family_ref",
        "run_descriptor_ref",
        "comparison_state_class",
        "delta_state_class",
        "origin_artifact_scope_summary"
      ],
      "properties": {
        "import_session_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "baseline_family_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "run_descriptor_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "comparison_state_class": {
          "$ref": "#/$defs/comparison_state_class"
        },
        "delta_state_class": {
          "$ref": "#/$defs/delta_state_class"
        },
        "origin_artifact_scope_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },

    "contributing_diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diagnostic_id",
        "source_descriptor_id",
        "source_kind_class",
        "evidence_plane_class",
        "origin_class",
        "support_class",
        "confidence_class",
        "rule_id_ref",
        "category_ref",
        "severity_class",
        "freshness_class",
        "language_provider_family",
        "locality_class",
        "semantic_layer_state_class",
        "origin_session_or_import_ref",
        "tool_identity_ref",
        "tool_version_ref",
        "environment_ref",
        "current_anchor",
        "anchor_remap",
        "current_epoch_bindings",
        "summary"
      ],
      "properties": {
        "diagnostic_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "source_descriptor_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "source_kind_class": {
          "$ref": "#/$defs/source_kind_class"
        },
        "evidence_plane_class": {
          "$ref": "#/$defs/evidence_plane_class"
        },
        "origin_class": {
          "$ref": "#/$defs/origin_class"
        },
        "support_class": {
          "$ref": "#/$defs/support_class"
        },
        "confidence_class": {
          "$ref": "#/$defs/confidence_class"
        },
        "rule_id_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "category_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "severity_class": {
          "$ref": "#/$defs/severity_class"
        },
        "freshness_class": {
          "$ref": "#/$defs/diagnostic_freshness_class"
        },
        "language_provider_family": {
          "$ref": "#/$defs/language_provider_family"
        },
        "locality_class": {
          "$ref": "#/$defs/locality_class"
        },
        "semantic_layer_state_class": {
          "$ref": "#/$defs/semantic_layer_state_class"
        },
        "origin_session_or_import_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "tool_identity_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "tool_version_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "environment_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "current_anchor": {
          "$ref": "#/$defs/anchor_projection"
        },
        "anchor_remap": {
          "$ref": "#/$defs/anchor_remap_record"
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          }
        },
        "imported_baseline_binding": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/imported_baseline_binding"
            }
          ]
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },

    "severity_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "error",
        "warning",
        "information",
        "hint"
      ],
      "properties": {
        "error": {
          "$ref": "#/$defs/non_negative_int"
        },
        "warning": {
          "$ref": "#/$defs/non_negative_int"
        },
        "information": {
          "$ref": "#/$defs/non_negative_int"
        },
        "hint": {
          "$ref": "#/$defs/non_negative_int"
        }
      }
    },

    "aggregate_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_contributing_diagnostics",
        "source_kind_count",
        "live_count",
        "imported_snapshot_count",
        "stale_or_superseded_count",
        "remapped_count",
        "exact_anchor_count",
        "runtime_or_test_count",
        "static_analysis_count",
        "suppressed_count",
        "baselined_count",
        "severity_counts"
      ],
      "properties": {
        "total_contributing_diagnostics": {
          "$ref": "#/$defs/non_negative_int"
        },
        "source_kind_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "live_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "imported_snapshot_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "stale_or_superseded_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "remapped_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "exact_anchor_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "runtime_or_test_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "static_analysis_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "suppressed_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "baselined_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "severity_counts": {
          "$ref": "#/$defs/severity_counts"
        }
      }
    },

    "diagnostic_cluster_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "diagnostic_cluster_schema_version",
        "diagnostic_cluster_id",
        "cluster_title",
        "primary_diagnostic_ref",
        "rule_id_ref",
        "category_ref",
        "primary_anchor",
        "primary_anchor_remap_state_class",
        "dominant_severity_class",
        "severity_convergence_class",
        "cluster_freshness_class",
        "dominant_display_state_class",
        "semantic_layer_state_class",
        "dedupe_reason_class",
        "aggregate_source_kind_classes",
        "aggregate_evidence_plane_classes",
        "contributing_diagnostics",
        "aggregate_counts",
        "detail_sheet_requirements",
        "current_epoch_bindings",
        "suppression_review_refs",
        "code_action_summary_refs",
        "policy_context",
        "redaction_class",
        "captured_at",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": {
          "$ref": "#/$defs/record_kind"
        },
        "diagnostic_cluster_schema_version": {
          "$ref": "#/$defs/diagnostic_cluster_schema_version"
        },
        "diagnostic_cluster_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "cluster_title": {
          "$ref": "#/$defs/reviewable_summary"
        },
        "primary_diagnostic_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "rule_id_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "category_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "primary_anchor": {
          "$ref": "#/$defs/anchor_projection"
        },
        "primary_anchor_remap_state_class": {
          "$ref": "#/$defs/anchor_remap_state_class"
        },
        "dominant_severity_class": {
          "$ref": "#/$defs/severity_class"
        },
        "severity_convergence_class": {
          "$ref": "#/$defs/severity_convergence_class"
        },
        "cluster_freshness_class": {
          "$ref": "#/$defs/diagnostic_freshness_class"
        },
        "dominant_display_state_class": {
          "$ref": "#/$defs/dominant_display_state_class"
        },
        "semantic_layer_state_class": {
          "$ref": "#/$defs/semantic_layer_state_class"
        },
        "dedupe_reason_class": {
          "$ref": "#/$defs/dedupe_reason_class"
        },
        "aggregate_source_kind_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_kind_class"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "aggregate_evidence_plane_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_plane_class"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "contributing_diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contributing_diagnostic"
          },
          "minItems": 1
        },
        "aggregate_counts": {
          "$ref": "#/$defs/aggregate_counts"
        },
        "detail_sheet_requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/detail_section_class"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          }
        },
        "suppression_review_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_id"
          },
          "uniqueItems": true
        },
        "code_action_summary_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_id"
          },
          "uniqueItems": true
        },
        "imported_baseline_binding": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/imported_baseline_binding"
            }
          ]
        },
        "policy_context": {
          "$ref": "#/$defs/policy_context"
        },
        "redaction_class": {
          "$ref": "#/$defs/redaction_class"
        },
        "captured_at": {
          "$ref": "#/$defs/timestamp"
        },
        "export_safe_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    }
  }
}
