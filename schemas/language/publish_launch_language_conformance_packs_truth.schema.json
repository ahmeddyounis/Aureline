{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/publish_launch_language_conformance_packs_truth.schema.json",
  "title": "Aureline launch-language conformance pack publication truth packet",
  "description": "Boundary schema for the stable launch-language conformance pack publication truth packet certifying conformance packs, support-class evidence, and downgrade rules for every stable launch-language lane (Python, TypeScript/JavaScript, Rust, Go, Java/Kotlin, C/C++) at the M4 launch-stable grade with daily-loop coverage, known limits, downgrade automation, and evidence binding. The packet is the single truth that the editor language pack, framework pack panel, language settings/help, CLI/headless inspector, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies or paraphrase conformance posture.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "publish_launch_language_conformance_packs_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/launch_language_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/conformance_pack_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "launch_language_lane_class": {
      "enum": [
        "python_launch_language_lane",
        "typescript_javascript_launch_language_lane",
        "rust_launch_language_lane",
        "go_launch_language_lane",
        "java_kotlin_launch_language_lane",
        "c_cpp_launch_language_lane"
      ]
    },
    "conformance_pack_row_class": {
      "enum": [
        "conformance_pack_quality",
        "support_class_evidence_admission",
        "downgrade_rule_admission",
        "daily_loop_step",
        "unsupported_gap",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "support_class_evidence_class": {
      "enum": [
        "archetype_repo_backed",
        "fixture_corpus_backed",
        "conformance_suite_backed",
        "benchmark_backed",
        "design_partner_backed",
        "framework_migration_backed",
        "docs_disclosure_only",
        "not_applicable",
        "evidence_unbound"
      ]
    },
    "downgrade_rule_class": {
      "enum": [
        "narrow_on_missing_fixture",
        "narrow_on_missing_archetype",
        "narrow_on_failed_migration",
        "narrow_on_low_confidence",
        "block_on_missing_evidence",
        "block_on_unsupported_gap",
        "manual_only_pending_review",
        "not_applicable",
        "rule_unbound"
      ]
    },
    "daily_loop_step_class": {
      "enum": [
        "open_or_import",
        "navigate",
        "edit",
        "complete",
        "refactor",
        "run_test_debug",
        "review",
        "migrate",
        "recover",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "archetype_repo_evidence",
        "framework_migration_evidence",
        "design_partner_evidence",
        "fixture_repo_evidence",
        "conformance_suite_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "language_subset_only",
        "framework_subset_only",
        "archetype_subset_only",
        "daily_loop_step_subset_only",
        "migration_subset_only",
        "unsupported_runtime_target",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_missing_fixture",
        "auto_narrow_on_missing_archetype",
        "auto_narrow_on_failed_migration",
        "auto_demote_on_low_confidence",
        "auto_block_on_missing_evidence",
        "auto_block_on_unsupported_gap",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "conformance_pack_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_lane_coverage",
        "missing_daily_loop_step_coverage",
        "missing_support_class_evidence_coverage",
        "missing_downgrade_rule_coverage",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "missing_support_class_evidence",
        "missing_downgrade_rule",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "daily_loop_step_not_applicable",
        "daily_loop_step_not_permitted_on_row_class",
        "support_class_evidence_not_applicable",
        "support_class_evidence_not_permitted_on_row_class",
        "downgrade_rule_not_applicable",
        "downgrade_rule_not_permitted_on_row_class",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "support_class_evidence_vocabulary_collapsed",
        "downgrade_rule_vocabulary_collapsed",
        "daily_loop_step_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "conformance_pack_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "support_class_evidence_class",
        "downgrade_rule_class",
        "daily_loop_step_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/launch_language_lane_class" },
        "row_class": { "$ref": "#/$defs/conformance_pack_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "support_class_evidence_class": { "$ref": "#/$defs/support_class_evidence_class" },
        "downgrade_rule_class": { "$ref": "#/$defs/downgrade_rule_class" },
        "daily_loop_step_class": { "$ref": "#/$defs/daily_loop_step_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/conformance_pack_confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "publish_launch_language_conformance_packs_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_support_class_evidence_vocabulary",
        "preserves_downgrade_rule_vocabulary",
        "preserves_daily_loop_step_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "editor_language_pack",
            "framework_pack_panel",
            "language_settings",
            "cli_headless",
            "support_export",
            "release_proof_index",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "publish_launch_language_conformance_packs_packet_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_evidence_vocabulary": { "type": "boolean" },
        "preserves_downgrade_rule_vocabulary": { "type": "boolean" },
        "preserves_daily_loop_step_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
