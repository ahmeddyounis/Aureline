{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/framework_migration_import_truth.schema.json",
  "title": "Aureline framework migration and import guidance truth packet",
  "description": "Boundary schema for the stable framework-migration-import truth packet certifying framework-specific migration guidance, import guidance, and unsupported-gap labeling across the launch bundles at the M4 launch-stable grade. Every lane that claims launch_stable MUST cover all five outcome labels (exact_match, translated_match, partial_match, shimmed_match, unsupported_gap) plus rollback-checkpoint admission, diagnostic-preservation admission, launch-bundle coverage, known limits, downgrade automation, and evidence binding. The packet is the single truth that the editor language pack, framework pack panel, language settings/help, CLI/headless inspector, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies or paraphrase migration posture.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "framework_migration_import_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/migration_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/framework_migration_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "migration_lane_class": {
      "enum": [
        "framework_migration_guidance_lane",
        "import_guidance_lane",
        "unsupported_gap_labeling_lane"
      ]
    },
    "framework_migration_row_class": {
      "enum": [
        "migration_guidance_quality",
        "outcome_label_truth",
        "rollback_checkpoint_admission",
        "diagnostic_preservation_admission",
        "launch_bundle_coverage",
        "unsupported_gap",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "outcome_label_class": {
      "enum": [
        "exact_match",
        "translated_match",
        "partial_match",
        "shimmed_match",
        "unsupported_gap",
        "not_applicable",
        "label_unbound"
      ]
    },
    "rollback_checkpoint_class": {
      "enum": [
        "checkpoint_preserved",
        "checkpoint_with_diagnostics",
        "checkpoint_pending",
        "not_applicable",
        "checkpoint_unbound"
      ]
    },
    "diagnostic_preservation_class": {
      "enum": [
        "diagnostics_preserved",
        "diagnostics_partial",
        "diagnostics_absent",
        "not_applicable",
        "diagnostic_unbound"
      ]
    },
    "launch_bundle_class": {
      "enum": [
        "python_launch_bundle",
        "typescript_javascript_launch_bundle",
        "rust_launch_bundle",
        "go_launch_bundle",
        "java_kotlin_launch_bundle",
        "c_cpp_launch_bundle",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "archetype_repo_evidence",
        "framework_migration_evidence",
        "design_partner_evidence",
        "fixture_repo_evidence",
        "conformance_suite_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "bundle_subset_only",
        "framework_subset_only",
        "outcome_label_subset_only",
        "checkpoint_subset_only",
        "diagnostic_subset_only",
        "archetype_subset_only",
        "unsupported_runtime_target",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_missing_fixture",
        "auto_narrow_on_missing_archetype",
        "auto_narrow_on_unsupported_gap",
        "auto_narrow_on_checkpoint_failure",
        "auto_narrow_on_diagnostic_loss",
        "auto_demote_on_low_confidence",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "framework_migration_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_migration_lane_coverage",
        "missing_outcome_label_coverage",
        "missing_rollback_checkpoint_coverage",
        "missing_diagnostic_preservation_coverage",
        "missing_launch_bundle_coverage",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "missing_outcome_label_class",
        "missing_rollback_checkpoint_class",
        "missing_diagnostic_preservation_class",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "outcome_label_not_applicable",
        "outcome_label_not_permitted_on_row_class",
        "rollback_checkpoint_not_applicable",
        "rollback_checkpoint_not_permitted_on_row_class",
        "diagnostic_preservation_not_applicable",
        "diagnostic_preservation_not_permitted_on_row_class",
        "launch_bundle_not_applicable",
        "launch_bundle_not_permitted_on_row_class",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "outcome_label_vocabulary_collapsed",
        "rollback_checkpoint_vocabulary_collapsed",
        "diagnostic_preservation_vocabulary_collapsed",
        "launch_bundle_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "framework_migration_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "outcome_label_class",
        "rollback_checkpoint_class",
        "diagnostic_preservation_class",
        "launch_bundle_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/migration_lane_class" },
        "row_class": { "$ref": "#/$defs/framework_migration_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "outcome_label_class": { "$ref": "#/$defs/outcome_label_class" },
        "rollback_checkpoint_class": { "$ref": "#/$defs/rollback_checkpoint_class" },
        "diagnostic_preservation_class": { "$ref": "#/$defs/diagnostic_preservation_class" },
        "launch_bundle_class": { "$ref": "#/$defs/launch_bundle_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/framework_migration_confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "framework_migration_import_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_outcome_label_vocabulary",
        "preserves_rollback_checkpoint_vocabulary",
        "preserves_diagnostic_preservation_vocabulary",
        "preserves_launch_bundle_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "editor_language_pack",
            "framework_pack_panel",
            "language_settings",
            "cli_headless",
            "support_export",
            "release_proof_index",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "framework_migration_import_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_outcome_label_vocabulary": { "type": "boolean" },
        "preserves_rollback_checkpoint_vocabulary": { "type": "boolean" },
        "preserves_diagnostic_preservation_vocabulary": { "type": "boolean" },
        "preserves_launch_bundle_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
