{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/result_provenance.schema.json",
  "title": "Aureline language result-provenance and framework-certainty vocabulary",
  "description": "Boundary schema for the result_provenance_record frozen in docs/language/provider_graph_and_arbitration_contract.md. The record follows one concrete language result, explanation, candidate set, or preview into UI, CLI, notebook, AI, review, and support/export lanes. It captures the primary provider, contributing providers, alternate providers, claimed scope, completeness, freshness, locality, downgrade cue, generated/notebook notes, framework certainty, proving artifacts, and source-of-certainty chains. Raw source text, raw notebook payloads, raw generated artifacts, raw provider logs, raw process arguments, raw URLs, raw hostnames, and raw secret material never cross this boundary; the record carries opaque ids, typed vocabulary, epoch refs, artifact refs, and export-safe summaries only. Adding a new provider family, role, health state, freshness class, scope-claim class, completeness class, scope-limit class, locality class, authority class, result-kind class, conflict class, downgrade cue, cached-reuse reason, alternate-provider reason, generated note, notebook note, framework certainty class, framework primary-source class, certainty-source class, or epoch role is additive-minor and requires a result_provenance_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/result_provenance_record"
    }
  ],
  "$defs": {
    "result_provenance_schema_version": {
      "type": "integer",
      "const": 1
    },

    "record_kind": {
      "type": "string",
      "const": "result_provenance_record"
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1
    },

    "timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "reviewable_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },

    "provider_family": {
      "type": "string",
      "enum": [
        "syntax",
        "project_graph",
        "language_server",
        "framework_pack",
        "notebook_adapter",
        "generated_source_bridge",
        "ai_assist"
      ]
    },

    "provider_role_class": {
      "type": "string",
      "enum": [
        "primary_semantic",
        "secondary_semantic",
        "framework_overlay",
        "notebook_projection",
        "generated_overlay",
        "text_fallback",
        "assist_only"
      ]
    },

    "health_state": {
      "type": "string",
      "enum": [
        "ready",
        "warming",
        "degraded",
        "cached_only",
        "policy_blocked",
        "capability_missing",
        "crash_loop_quarantined",
        "unavailable"
      ]
    },

    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },

    "scope_claim_class": {
      "type": "string",
      "enum": [
        "single_file",
        "notebook_cell",
        "loaded_slice",
        "active_workset",
        "whole_workspace",
        "unavailable"
      ]
    },

    "completeness_class": {
      "type": "string",
      "enum": [
        "complete_for_claimed_scope",
        "partial_for_claimed_scope",
        "unavailable_for_claimed_scope"
      ]
    },

    "scope_limit_class": {
      "type": "string",
      "enum": [
        "single_file_only",
        "active_workset_only",
        "unloaded_roots_omitted",
        "generated_overlay_only",
        "generated_candidates_omitted",
        "notebook_cell_projection_only",
        "cross_cell_context_unavailable",
        "diff_or_review_slice_only",
        "policy_narrowed",
        "remote_shard_unreachable"
      ]
    },

    "locality_class": {
      "type": "string",
      "enum": [
        "local_in_process",
        "local_sidecar",
        "workspace_remote_agent",
        "managed_service",
        "imported_snapshot"
      ]
    },

    "surface_class": {
      "type": "string",
      "enum": [
        "definition",
        "reference",
        "hover",
        "rename",
        "completion",
        "code_action",
        "diagnostic",
        "notebook_context",
        "ai_assist_context"
      ]
    },

    "result_kind_class": {
      "type": "string",
      "enum": [
        "definition_target",
        "reference_set",
        "hover_card",
        "rename_preview_set",
        "completion_list",
        "code_action_list",
        "diagnostic_set",
        "notebook_context_excerpt",
        "ai_assist_excerpt"
      ]
    },

    "authority_class": {
      "type": "string",
      "enum": [
        "authoritative_for_claimed_scope",
        "advisory_for_claimed_scope",
        "fallback_only",
        "inspect_only"
      ]
    },

    "surface_support_class": {
      "type": "string",
      "enum": [
        "authoritative",
        "advisory",
        "fallback_only",
        "unsupported"
      ]
    },

    "conflict_class": {
      "type": "string",
      "enum": [
        "none",
        "target_set_disagreement",
        "scope_coverage_disagreement",
        "framework_language_disagreement",
        "semantic_text_disagreement",
        "edit_safety_disagreement",
        "freshness_or_epoch_disagreement",
        "generated_boundary_disagreement",
        "notebook_boundary_disagreement",
        "narrative_fact_disagreement"
      ]
    },

    "downgrade_cue_class": {
      "type": "string",
      "enum": [
        "none",
        "scope_narrowed",
        "semantic_to_text_fallback",
        "semantic_to_file_local_syntax",
        "semantic_to_cached_result",
        "framework_certainty_lowered",
        "generated_scope_narrowed",
        "notebook_scope_narrowed",
        "provider_unavailable",
        "provider_crash_loop_quarantined",
        "policy_blocked"
      ]
    },

    "cached_reuse_reason_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "provider_warming",
        "provider_unreachable",
        "freshness_grace_not_expired",
        "policy_blocks_refresh",
        "offline_last_known_good",
        "manual_pin"
      ]
    },

    "alternate_provider_reason_class": {
      "type": "string",
      "enum": [
        "lower_authority",
        "narrower_scope",
        "older_epoch",
        "lower_framework_certainty",
        "health_excluded",
        "policy_excluded",
        "mutation_safety_lower",
        "redundant_same_answer"
      ]
    },

    "generated_note_class": {
      "type": "string",
      "enum": [
        "generated_overlay_in_scope",
        "generated_target_only",
        "generated_candidates_omitted",
        "generated_lineage_unknown"
      ]
    },

    "notebook_note_class": {
      "type": "string",
      "enum": [
        "notebook_cell_projection",
        "cross_cell_context_limited",
        "paired_export_projection",
        "kernel_runtime_not_consulted"
      ]
    },

    "epoch_role_class": {
      "type": "string",
      "enum": [
        "workspace_scope",
        "graph_snapshot",
        "provider_session",
        "language_project_model",
        "framework_pack_snapshot",
        "notebook_projection",
        "generated_lineage",
        "ai_context"
      ]
    },

    "framework_certainty_class": {
      "type": "string",
      "enum": [
        "framework_not_applicable",
        "framework_proven",
        "framework_inferred",
        "framework_imported",
        "framework_stale",
        "framework_unavailable"
      ]
    },

    "framework_primary_source_class": {
      "type": "string",
      "enum": [
        "framework_pack_analysis",
        "framework_pack_artifact",
        "project_graph_projection",
        "language_server_signal",
        "build_adapter_signal",
        "imported_snapshot",
        "ai_inference",
        "none"
      ]
    },

    "certainty_source_class": {
      "type": "string",
      "enum": [
        "framework_pack_analysis",
        "framework_pack_artifact",
        "project_graph_fact",
        "language_server_fact",
        "syntax_fact",
        "build_adapter_fact",
        "notebook_adapter_projection",
        "generated_source_lineage",
        "imported_snapshot",
        "ai_inference",
        "user_curated_override"
      ]
    },

    "trust_state": {
      "type": "string",
      "enum": [
        "trusted",
        "restricted"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_epoch",
        "trust_state",
        "execution_context_id"
      ],
      "properties": {
        "policy_epoch": {
          "$ref": "#/$defs/opaque_id"
        },
        "trust_state": {
          "$ref": "#/$defs/trust_state"
        },
        "execution_context_id": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },

    "epoch_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "epoch_role_class",
        "epoch_ref"
      ],
      "properties": {
        "epoch_role_class": {
          "$ref": "#/$defs/epoch_role_class"
        },
        "epoch_ref": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },

    "provider_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "provider_family",
        "provider_display_label",
        "provider_role_class",
        "surface_support_class",
        "health_state",
        "freshness_class",
        "scope_claim_class",
        "completeness_class",
        "locality_class",
        "current_epoch_bindings",
        "summary"
      ],
      "properties": {
        "provider_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "provider_family": {
          "$ref": "#/$defs/provider_family"
        },
        "provider_display_label": {
          "$ref": "#/$defs/reviewable_summary"
        },
        "provider_role_class": {
          "$ref": "#/$defs/provider_role_class"
        },
        "surface_support_class": {
          "$ref": "#/$defs/surface_support_class"
        },
        "health_state": {
          "$ref": "#/$defs/health_state"
        },
        "freshness_class": {
          "$ref": "#/$defs/freshness_class"
        },
        "scope_claim_class": {
          "$ref": "#/$defs/scope_claim_class"
        },
        "completeness_class": {
          "$ref": "#/$defs/completeness_class"
        },
        "scope_limit_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scope_limit_class"
          },
          "uniqueItems": true,
          "default": []
        },
        "locality_class": {
          "$ref": "#/$defs/locality_class"
        },
        "host_identity_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/opaque_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "generated_note_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/generated_note_class"
          },
          "uniqueItems": true,
          "default": []
        },
        "notebook_note_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/notebook_note_class"
          },
          "uniqueItems": true,
          "default": []
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "provider_family": {
                "const": "ai_assist"
              }
            },
            "required": [
              "provider_family"
            ]
          },
          "then": {
            "properties": {
              "provider_role_class": {
                "const": "assist_only"
              },
              "surface_support_class": {
                "not": {
                  "const": "authoritative"
                }
              }
            }
          }
        }
      ]
    },

    "alternate_provider_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "provider_family",
        "reason_not_primary_class",
        "summary"
      ],
      "properties": {
        "provider_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "provider_family": {
          "$ref": "#/$defs/provider_family"
        },
        "reason_not_primary_class": {
          "$ref": "#/$defs/alternate_provider_reason_class"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },

    "certainty_source_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "certainty_source_class",
        "summary"
      ],
      "properties": {
        "certainty_source_class": {
          "$ref": "#/$defs/certainty_source_class"
        },
        "provider_id_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/opaque_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "artifact_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/opaque_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },

    "framework_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "framework_certainty_class",
        "primary_source_class",
        "proving_artifact_refs",
        "source_of_certainty_chain",
        "summary"
      ],
      "properties": {
        "framework_certainty_class": {
          "$ref": "#/$defs/framework_certainty_class"
        },
        "primary_source_class": {
          "$ref": "#/$defs/framework_primary_source_class"
        },
        "proving_artifact_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_id"
          },
          "uniqueItems": true
        },
        "source_of_certainty_chain": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/certainty_source_row"
          }
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "framework_certainty_class": {
                "const": "framework_proven"
              }
            },
            "required": [
              "framework_certainty_class"
            ]
          },
          "then": {
            "properties": {
              "primary_source_class": {
                "enum": [
                  "framework_pack_analysis",
                  "framework_pack_artifact"
                ]
              },
              "proving_artifact_refs": {
                "minItems": 1
              },
              "source_of_certainty_chain": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "primary_source_class": {
                "enum": [
                  "language_server_signal",
                  "build_adapter_signal",
                  "imported_snapshot",
                  "ai_inference"
                ]
              }
            },
            "required": [
              "primary_source_class"
            ]
          },
          "then": {
            "properties": {
              "framework_certainty_class": {
                "not": {
                  "const": "framework_proven"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "framework_certainty_class": {
                "const": "framework_imported"
              }
            },
            "required": [
              "framework_certainty_class"
            ]
          },
          "then": {
            "properties": {
              "primary_source_class": {
                "const": "imported_snapshot"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "framework_certainty_class": {
                "const": "framework_unavailable"
              }
            },
            "required": [
              "framework_certainty_class"
            ]
          },
          "then": {
            "properties": {
              "primary_source_class": {
                "const": "none"
              },
              "proving_artifact_refs": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "framework_certainty_class": {
                "const": "framework_not_applicable"
              }
            },
            "required": [
              "framework_certainty_class"
            ]
          },
          "then": {
            "properties": {
              "primary_source_class": {
                "const": "none"
              }
            }
          }
        }
      ]
    },

    "result_provenance_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "result_provenance_schema_version",
        "result_provenance_id",
        "surface_class",
        "result_kind_class",
        "result_subject_ref",
        "authority_class",
        "primary_provider_snapshot",
        "contributing_provider_snapshots",
        "alternate_provider_rows",
        "conflict_class",
        "downgrade_cue_class",
        "cached_reuse_reason_class",
        "source_of_certainty_chain",
        "framework_evidence",
        "policy_context",
        "redaction_class",
        "captured_at",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": {
          "$ref": "#/$defs/record_kind"
        },
        "result_provenance_schema_version": {
          "$ref": "#/$defs/result_provenance_schema_version"
        },
        "result_provenance_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "surface_class": {
          "$ref": "#/$defs/surface_class"
        },
        "result_kind_class": {
          "$ref": "#/$defs/result_kind_class"
        },
        "result_subject_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "authority_class": {
          "$ref": "#/$defs/authority_class"
        },
        "primary_provider_snapshot": {
          "$ref": "#/$defs/provider_snapshot"
        },
        "contributing_provider_snapshots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/provider_snapshot"
          }
        },
        "alternate_provider_rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/alternate_provider_row"
          }
        },
        "conflict_class": {
          "$ref": "#/$defs/conflict_class"
        },
        "downgrade_cue_class": {
          "$ref": "#/$defs/downgrade_cue_class"
        },
        "cached_reuse_reason_class": {
          "$ref": "#/$defs/cached_reuse_reason_class"
        },
        "generated_note_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/generated_note_class"
          },
          "uniqueItems": true,
          "default": []
        },
        "notebook_note_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/notebook_note_class"
          },
          "uniqueItems": true,
          "default": []
        },
        "source_of_certainty_chain": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/certainty_source_row"
          },
          "minItems": 1
        },
        "framework_evidence": {
          "$ref": "#/$defs/framework_evidence"
        },
        "policy_context": {
          "$ref": "#/$defs/policy_context"
        },
        "redaction_class": {
          "$ref": "#/$defs/redaction_class"
        },
        "captured_at": {
          "$ref": "#/$defs/timestamp"
        },
        "export_safe_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "surface_class": {
                "const": "definition"
              }
            },
            "required": [
              "surface_class"
            ]
          },
          "then": {
            "properties": {
              "result_kind_class": {
                "const": "definition_target"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "surface_class": {
                "const": "reference"
              }
            },
            "required": [
              "surface_class"
            ]
          },
          "then": {
            "properties": {
              "result_kind_class": {
                "const": "reference_set"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "surface_class": {
                "const": "hover"
              }
            },
            "required": [
              "surface_class"
            ]
          },
          "then": {
            "properties": {
              "result_kind_class": {
                "const": "hover_card"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "surface_class": {
                "const": "rename"
              }
            },
            "required": [
              "surface_class"
            ]
          },
          "then": {
            "properties": {
              "result_kind_class": {
                "const": "rename_preview_set"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "surface_class": {
                "const": "completion"
              }
            },
            "required": [
              "surface_class"
            ]
          },
          "then": {
            "properties": {
              "result_kind_class": {
                "const": "completion_list"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "surface_class": {
                "const": "code_action"
              }
            },
            "required": [
              "surface_class"
            ]
          },
          "then": {
            "properties": {
              "result_kind_class": {
                "const": "code_action_list"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "surface_class": {
                "const": "diagnostic"
              }
            },
            "required": [
              "surface_class"
            ]
          },
          "then": {
            "properties": {
              "result_kind_class": {
                "const": "diagnostic_set"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "surface_class": {
                "const": "notebook_context"
              }
            },
            "required": [
              "surface_class"
            ]
          },
          "then": {
            "properties": {
              "result_kind_class": {
                "const": "notebook_context_excerpt"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "surface_class": {
                "const": "ai_assist_context"
              }
            },
            "required": [
              "surface_class"
            ]
          },
          "then": {
            "properties": {
              "result_kind_class": {
                "const": "ai_assist_excerpt"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "authority_class": {
                "const": "authoritative_for_claimed_scope"
              }
            },
            "required": [
              "authority_class"
            ]
          },
          "then": {
            "properties": {
              "primary_provider_snapshot": {
                "properties": {
                  "surface_support_class": {
                    "const": "authoritative"
                  },
                  "health_state": {
                    "const": "ready"
                  },
                  "freshness_class": {
                    "const": "authoritative_live"
                  },
                  "completeness_class": {
                    "const": "complete_for_claimed_scope"
                  }
                },
                "required": [
                  "surface_support_class",
                  "health_state",
                  "freshness_class",
                  "completeness_class"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "authority_class": {
                "const": "authoritative_for_claimed_scope"
              },
              "primary_provider_snapshot": {
                "properties": {
                  "scope_claim_class": {
                    "const": "whole_workspace"
                  }
                },
                "required": [
                  "scope_claim_class"
                ]
              }
            },
            "required": [
              "authority_class",
              "primary_provider_snapshot"
            ]
          },
          "then": {
            "properties": {
              "primary_provider_snapshot": {
                "properties": {
                  "provider_family": {
                    "enum": [
                      "project_graph",
                      "language_server",
                      "framework_pack"
                    ]
                  },
                  "scope_limit_classes": {
                    "maxItems": 0
                  }
                },
                "required": [
                  "provider_family",
                  "scope_limit_classes"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "cached_reuse_reason_class": {
                "not": {
                  "const": "not_applicable"
                }
              }
            },
            "required": [
              "cached_reuse_reason_class"
            ]
          },
          "then": {
            "properties": {
              "authority_class": {
                "not": {
                  "const": "authoritative_for_claimed_scope"
                }
              },
              "downgrade_cue_class": {
                "not": {
                  "const": "none"
                }
              },
              "primary_provider_snapshot": {
                "properties": {
                  "freshness_class": {
                    "not": {
                      "const": "authoritative_live"
                    }
                  }
                },
                "required": [
                  "freshness_class"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "downgrade_cue_class": {
                "enum": [
                  "semantic_to_text_fallback",
                  "semantic_to_file_local_syntax"
                ]
              }
            },
            "required": [
              "downgrade_cue_class"
            ]
          },
          "then": {
            "properties": {
              "primary_provider_snapshot": {
                "properties": {
                  "provider_family": {
                    "const": "syntax"
                  },
                  "provider_role_class": {
                    "const": "text_fallback"
                  }
                },
                "required": [
                  "provider_family",
                  "provider_role_class"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "conflict_class": {
                "not": {
                  "const": "none"
                }
              }
            },
            "required": [
              "conflict_class"
            ]
          },
          "then": {
            "properties": {
              "alternate_provider_rows": {
                "minItems": 1
              }
            }
          }
        }
      ]
    }
  }
}
