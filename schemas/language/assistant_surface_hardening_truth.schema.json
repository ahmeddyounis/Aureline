{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/assistant_surface_hardening_truth.schema.json",
  "title": "Aureline assistant-surface hardening truth packet",
  "description": "Boundary schema for the stable assistant-surface hardening truth packet certifying completion, signature help, snippet session, code action, additional edit, source labeling, and AI ghost text lanes at the M4 launch-hardened grade with provider/source classes, side-effect classes, snippet-session field truth, code-action field truth, and cross-cut condition coverage. The packet is the single truth that the editor language pack, framework pack panel, language settings/help, CLI/headless inspector, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies or paraphrase assistant-surface posture.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "assistant_surface_hardening_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/assistant_surface_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/assistant_surface_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "assistant_surface_lane_class": {
      "enum": [
        "completion_lane",
        "signature_help_lane",
        "snippet_session_lane",
        "code_action_lane",
        "additional_edit_lane",
        "source_labeling_lane",
        "ai_ghost_text_lane"
      ]
    },
    "assistant_surface_row_class": {
      "enum": [
        "assistant_surface_quality",
        "provider_source_binding",
        "side_effect_admission",
        "snippet_session_truth",
        "code_action_truth",
        "cross_cut_condition",
        "launch_language_coverage",
        "unsupported_gap",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_hardened",
        "launch_hardened_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "provider_source_class": {
      "enum": [
        "deterministic_completion",
        "cached_local_word_fallback",
        "snippet_only_suggestion",
        "ai_ghost_text",
        "not_applicable"
      ]
    },
    "side_effect_class": {
      "enum": [
        "no_side_effect",
        "additional_edits",
        "generated_files",
        "dependency_or_config_change",
        "protected_surface_write",
        "not_applicable",
        "side_effect_unbound"
      ]
    },
    "preview_requirement_class": {
      "enum": [
        "preview_not_required",
        "preview_required_for_multi_file",
        "preview_required_for_generated_file",
        "preview_required_for_dependency_change",
        "preview_required_for_protected_surface",
        "not_applicable",
        "preview_unbound"
      ]
    },
    "snippet_session_field_class": {
      "enum": [
        "snippet_or_source_label",
        "placeholder_index_count",
        "exit_route",
        "multi_cursor_compatibility",
        "not_applicable"
      ]
    },
    "code_action_field_class": {
      "enum": [
        "provider_or_source",
        "side_effect_class",
        "partial_support_reason",
        "preview_requirement",
        "not_applicable"
      ]
    },
    "cross_cut_condition_class": {
      "enum": [
        "ime",
        "multi_cursor",
        "large_file",
        "restricted_mode",
        "degraded_provider",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "archetype_repo_evidence",
        "framework_migration_evidence",
        "design_partner_evidence",
        "fixture_repo_evidence",
        "conformance_suite_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "provider_subset_only",
        "language_subset_only",
        "archetype_subset_only",
        "condition_subset_only",
        "field_subset_only",
        "side_effect_scope_only",
        "preview_subset_only",
        "unsupported_runtime_target",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_missing_fixture",
        "auto_narrow_on_missing_archetype",
        "auto_narrow_on_provider_gap",
        "auto_narrow_on_condition_failure",
        "auto_narrow_on_ghost_text_label_drift",
        "auto_demote_on_low_confidence",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "assistant_surface_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_assistant_surface_lane_coverage",
        "missing_cross_cut_condition_coverage",
        "missing_provider_source_binding_coverage",
        "missing_snippet_session_field_coverage",
        "missing_code_action_field_coverage",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "missing_side_effect_class",
        "missing_preview_requirement_class",
        "launch_hardened_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "provider_source_class_not_applicable",
        "provider_source_class_not_permitted_on_row_class",
        "side_effect_class_not_applicable",
        "side_effect_class_not_permitted_on_row_class",
        "snippet_session_field_not_applicable",
        "snippet_session_field_not_permitted_on_row_class",
        "code_action_field_not_applicable",
        "code_action_field_not_permitted_on_row_class",
        "cross_cut_condition_not_applicable",
        "cross_cut_condition_not_permitted_on_row_class",
        "preview_requirement_not_permitted_on_row_class",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "provider_source_class_vocabulary_collapsed",
        "side_effect_class_vocabulary_collapsed",
        "preview_requirement_vocabulary_collapsed",
        "snippet_session_field_vocabulary_collapsed",
        "code_action_field_vocabulary_collapsed",
        "cross_cut_condition_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "assistant_surface_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "provider_source_class",
        "side_effect_class",
        "preview_requirement_class",
        "snippet_session_field_class",
        "code_action_field_class",
        "cross_cut_condition_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/assistant_surface_lane_class" },
        "row_class": { "$ref": "#/$defs/assistant_surface_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "provider_source_class": { "$ref": "#/$defs/provider_source_class" },
        "side_effect_class": { "$ref": "#/$defs/side_effect_class" },
        "preview_requirement_class": { "$ref": "#/$defs/preview_requirement_class" },
        "snippet_session_field_class": { "$ref": "#/$defs/snippet_session_field_class" },
        "code_action_field_class": { "$ref": "#/$defs/code_action_field_class" },
        "cross_cut_condition_class": { "$ref": "#/$defs/cross_cut_condition_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/assistant_surface_confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "assistant_surface_hardening_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_provider_source_class_vocabulary",
        "preserves_side_effect_class_vocabulary",
        "preserves_preview_requirement_vocabulary",
        "preserves_snippet_session_field_vocabulary",
        "preserves_code_action_field_vocabulary",
        "preserves_cross_cut_condition_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "editor_language_pack",
            "framework_pack_panel",
            "language_settings",
            "cli_headless",
            "support_export",
            "release_proof_index",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "assistant_surface_hardening_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_provider_source_class_vocabulary": { "type": "boolean" },
        "preserves_side_effect_class_vocabulary": { "type": "boolean" },
        "preserves_preview_requirement_vocabulary": { "type": "boolean" },
        "preserves_snippet_session_field_vocabulary": { "type": "boolean" },
        "preserves_code_action_field_vocabulary": { "type": "boolean" },
        "preserves_cross_cut_condition_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
