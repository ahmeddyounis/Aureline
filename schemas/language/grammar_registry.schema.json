{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/grammar_registry.schema.json",
  "title": "Aureline Tree-sitter grammar registry record",
  "description": "Boundary schema for the launch-language Tree-sitter grammar registry consumed by the aureline-language runtime. The registry is metadata-only: it carries grammar ids, language ids, crate/version provenance, ABI refs, query-pack refs, file extension mappings, supported parse-derived cues, loader posture, and explicit fallback labels. Raw grammar binaries, raw source text, raw parser logs, absolute paths, URLs, hostnames, process args, and secret material never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "grammar_registry_schema_version",
    "registry_id",
    "status",
    "captured_at",
    "entries",
    "export_safe_summary"
  ],
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "tree_sitter_grammar_registry_record"
    },
    "grammar_registry_schema_version": {
      "type": "integer",
      "const": 1
    },
    "registry_id": {
      "$ref": "#/$defs/opaque_id"
    },
    "status": {
      "type": "string",
      "enum": [
        "seeded_launch_alpha",
        "stabilising",
        "deprecated"
      ]
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/grammar_registry_entry"
      }
    },
    "export_safe_summary": {
      "$ref": "#/$defs/reviewable_summary"
    }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "reviewable_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 720
    },
    "parser_substrate_class": {
      "type": "string",
      "enum": [
        "tree_sitter",
        "tree_sitter_compatible",
        "lightweight_bracket_scanner",
        "plain_text_lexical",
        "external_projection_import",
        "not_available"
      ]
    },
    "grammar_source_class": {
      "type": "string",
      "enum": [
        "bundled_curated_upstream",
        "bundled_first_party",
        "extension_pack",
        "workspace_pinned",
        "remote_agent_mirror",
        "not_applicable"
      ]
    },
    "grammar_resolution_state_class": {
      "type": "string",
      "enum": [
        "resolved_current",
        "resolved_with_workspace_override",
        "resolved_remote_mirror",
        "missing_for_language",
        "abi_mismatch",
        "signature_unverified",
        "blocked_by_trust_or_policy",
        "not_applicable_plain_text"
      ]
    },
    "derived_cue_class": {
      "type": "string",
      "enum": [
        "syntax_highlighting",
        "folds",
        "indent_guides",
        "structural_selection",
        "breadcrumbs",
        "outline",
        "local_symbols",
        "bracket_matching",
        "minimap_markers",
        "diagnostics",
        "refactor_preview",
        "semantic_graph_ingest",
        "support_export"
      ]
    },
    "budget_policy_class": {
      "type": "string",
      "enum": [
        "visible_edit_interactive",
        "foreground_visible_file",
        "background_workspace",
        "large_file_reduced",
        "export_replay_bounded"
      ]
    },
    "export_policy_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "range_refs_only",
        "support_export_safe",
        "blocked_raw_source_excluded",
        "not_exportable"
      ]
    },
    "grammar_registry_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grammar_id",
        "language_id",
        "display_name",
        "parser_substrate_class",
        "grammar_source_class",
        "grammar_resolution_state_class",
        "tree_sitter_crate",
        "crate_version",
        "grammar_version_ref",
        "grammar_abi_ref",
        "query_pack_ref",
        "artifact_hash_ref",
        "signature_ref",
        "upstream_ref",
        "local_patch_ref",
        "file_extensions",
        "language_aliases",
        "supported_cue_classes",
        "default_budget_policy_class",
        "runtime_loader",
        "node_kind_count",
        "export_policy_class",
        "fallback_label"
      ],
      "properties": {
        "grammar_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "language_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "parser_substrate_class": {
          "$ref": "#/$defs/parser_substrate_class"
        },
        "grammar_source_class": {
          "$ref": "#/$defs/grammar_source_class"
        },
        "grammar_resolution_state_class": {
          "$ref": "#/$defs/grammar_resolution_state_class"
        },
        "tree_sitter_crate": {
          "type": "string",
          "minLength": 1
        },
        "crate_version": {
          "type": "string",
          "minLength": 1
        },
        "grammar_version_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "grammar_abi_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "query_pack_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "artifact_hash_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "signature_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "upstream_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "local_patch_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "file_extensions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "language_aliases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "supported_cue_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/derived_cue_class"
          },
          "uniqueItems": true
        },
        "default_budget_policy_class": {
          "$ref": "#/$defs/budget_policy_class"
        },
        "runtime_loader": {
          "type": "string",
          "const": "rust_tree_sitter_static_language_fn"
        },
        "node_kind_count": {
          "type": "integer",
          "minimum": 1
        },
        "export_policy_class": {
          "$ref": "#/$defs/export_policy_class"
        },
        "fallback_label": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    }
  }
}
