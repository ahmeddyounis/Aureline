{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/spring_boot_expert_workflow_pack_truth.schema.json",
  "title": "Aureline Spring Boot Expert workflow pack truth packet",
  "description": "Boundary schema for the stable Spring Boot Expert workflow pack truth packet. The packet binds the Spring Boot Expert workflow pack across the create, open, run, test, debug, rename, and review loops at the promised support class with current fixture-repo, framework-migration, archetype, Spring Boot target discovery (`./gradlew bootRun`, `./gradlew bootBuildImage`, `./gradlew bootJar`, `./gradlew bootWar`, `mvn spring-boot:run`, `mvn spring-boot:build-image`, `mvn spring-boot:repackage`, custom Gradle/Maven targets, JUnit 5 / JUnit 4 / Spock / Kotest test tasks, JDWP / JPDA debug targets), Spring Boot config/property awareness (`application.properties`, `application.yml`, profile-specific `application-{profile}.properties` / `application-{profile}.yml`, `@ConfigurationProperties`, `@Value`, `@ConditionalOnProperty`, `@Profile`, `spring.config.import`, `spring.profiles.active`, `spring.profiles.include`, auto-configuration imports resolution), Spring Boot review-safe refactor (DI/IoC-aware rename, `@Component`/`@Service`/`@Repository`/`@Controller`/`@RestController`/`@Configuration` bean lifecycle, `@Autowired` / constructor-injection / `@Qualifier` resolution, AOP advice targets, bean rename across `@Bean(name)` references), and design-partner evidence. The packet is the single truth that the editor framework pack panel, workflow companion, framework settings/help, CLI/headless inspector, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies or paraphrase workflow-pack posture.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_packs",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "spring_boot_expert_workflow_pack_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_packs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/workflow_pack_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/workflow_pack_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "workflow_pack_class": {
      "enum": [
        "spring_boot_expert_workflow_pack"
      ]
    },
    "workflow_pack_row_class": {
      "enum": [
        "pack_qualification",
        "workflow_loop",
        "framework_migration_row",
        "archetype_repo_row",
        "target_discovery_row",
        "config_property_awareness_row",
        "review_safe_refactor_row",
        "design_partner_row",
        "unsupported_gap",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "expert_grade",
        "stable_below_expert",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "workflow_loop_class": {
      "enum": [
        "create",
        "open",
        "run",
        "test",
        "debug",
        "rename",
        "review",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "archetype_repo_evidence",
        "framework_migration_evidence",
        "design_partner_evidence",
        "fixture_repo_evidence",
        "conformance_suite_evidence",
        "benchmark_evidence",
        "target_discovery_evidence",
        "config_property_awareness_evidence",
        "review_safe_refactor_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "framework_subset_only",
        "language_subset_only",
        "archetype_subset_only",
        "migration_subset_only",
        "target_discovery_subset_only",
        "config_property_subset_only",
        "review_safe_refactor_subset_only",
        "unsupported_runtime_target",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_missing_fixture",
        "auto_narrow_on_missing_archetype",
        "auto_narrow_on_failed_migration",
        "auto_narrow_on_framework_gap",
        "auto_narrow_on_unproven_target_discovery",
        "auto_narrow_on_unproven_config_property_awareness",
        "auto_narrow_on_unproven_review_safe_refactor",
        "auto_demote_on_low_confidence",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "workflow_pack_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_workflow_pack_coverage",
        "missing_workflow_loop_coverage",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "expert_grade_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "workflow_loop_not_applicable",
        "workflow_loop_not_permitted_on_row_class",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "pack_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "workflow_loop_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "workflow_pack_row": {
      "type": "object",
      "required": [
        "row_id",
        "pack_class",
        "row_class",
        "support_class",
        "workflow_loop_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "pack_class": { "$ref": "#/$defs/workflow_pack_class" },
        "row_class": { "$ref": "#/$defs/workflow_pack_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "workflow_loop_class": { "$ref": "#/$defs/workflow_loop_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/workflow_pack_confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "spring_boot_expert_workflow_pack_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_pack_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_workflow_loop_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "editor_framework_pack_panel",
            "workflow_companion",
            "framework_settings",
            "cli_headless",
            "support_export",
            "release_proof_index",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "spring_boot_expert_workflow_pack_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_pack_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_workflow_loop_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
