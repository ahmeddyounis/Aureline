{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/code_action_summary.schema.json",
  "title": "Aureline code-action summary, mutation-safety, and validation contract",
  "description": "Boundary schema for the code_action_summary_record frozen in docs/language/diagnostics_and_code_action_contract.md. The record is the governed summary packet every quick-fix, fix-all, formatter rewrite, organize-imports operation, generated-aware edit, and future quality-action review surface reads before a mutation is treated as safe next work. It captures the acting provider, linked diagnostic clusters, safety class, mutation scope, preview requirement, apply posture, blocked/generated/protected counts, and validation or replay hints. Raw patch bodies, raw source text, raw generated artifacts, raw provider logs, raw tool arguments, raw paths, and raw secret material never cross this boundary; the record carries opaque ids, typed vocabulary, epoch bindings, and export-safe summaries only. Adding a new action class, source kind, support class, freshness class, semantic-layer state, safety class, mutation scope, preview requirement, apply posture, blocking reason, validation hint, replay hint, or epoch role is additive-minor and requires a code_action_summary_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/code_action_summary_record"
    }
  ],
  "$defs": {
    "code_action_summary_schema_version": {
      "type": "integer",
      "const": 1
    },

    "record_kind": {
      "type": "string",
      "const": "code_action_summary_record"
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1
    },

    "timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "reviewable_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },

    "source_kind_class": {
      "type": "string",
      "enum": [
        "compiler_or_build",
        "language_server",
        "linter_formatter_style",
        "framework_or_schema_analyzer",
        "runtime_test_or_debug",
        "policy_trust_or_security"
      ]
    },

    "support_class": {
      "type": "string",
      "enum": [
        "first_party_supported",
        "first_party_best_effort",
        "external_tooling",
        "policy_governed"
      ]
    },

    "diagnostic_freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "recent",
        "stale",
        "superseded",
        "imported_snapshot"
      ]
    },

    "semantic_layer_state_class": {
      "type": "string",
      "enum": [
        "semantic_current_exact",
        "semantic_current_remapped",
        "semantic_narrowed_scope",
        "semantic_cached_recent",
        "semantic_stale_epoch_mismatch",
        "syntactic_or_text_only",
        "runtime_observed_no_semantic_basis",
        "imported_snapshot_only",
        "policy_asserted_non_semantic"
      ]
    },

    "language_provider_family": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "enum": [
            "syntax",
            "project_graph",
            "language_server",
            "framework_pack",
            "notebook_adapter",
            "generated_source_bridge",
            "ai_assist"
          ]
        }
      ]
    },

    "locality_class": {
      "type": "string",
      "enum": [
        "local_in_process",
        "local_sidecar",
        "workspace_remote_agent",
        "managed_service",
        "imported_snapshot"
      ]
    },

    "action_class": {
      "type": "string",
      "enum": [
        "quick_fix_single_diagnostic",
        "quick_fix_cluster",
        "fix_all_rule",
        "organize_imports",
        "formatter_rewrite",
        "generated_source_sync",
        "validation_only_recheck"
      ]
    },

    "safety_class": {
      "type": "string",
      "enum": [
        "trivia_safe",
        "local_syntax_safe",
        "semantic_local",
        "cross_file_semantic",
        "generated_or_protected",
        "unknown_or_unstable"
      ]
    },

    "mutation_scope_class": {
      "type": "string",
      "enum": [
        "single_anchor",
        "single_file_localized",
        "single_file_whole_document",
        "multi_file_same_module",
        "multi_file_workspace",
        "generated_family",
        "protected_or_policy_scoped"
      ]
    },

    "preview_requirement_class": {
      "type": "string",
      "enum": [
        "not_required",
        "inline_summary",
        "structured_diff",
        "batch_scope_preview",
        "generated_or_protected_preview_required",
        "policy_or_repo_mutation_preview_required"
      ]
    },

    "apply_posture_class": {
      "type": "string",
      "enum": [
        "apply_inline_allowed",
        "preview_before_apply",
        "blocked_pending_user_review",
        "blocked_pending_policy_or_trust",
        "not_applicable_read_only"
      ]
    },

    "blocking_reason_class": {
      "type": "string",
      "enum": [
        "generated_paths_present",
        "protected_paths_present",
        "provider_freshness_unmet",
        "semantic_epoch_mismatch",
        "imported_snapshot_only",
        "policy_denied",
        "runtime_evidence_only_no_safe_edit"
      ]
    },

    "validation_hint_class": {
      "type": "string",
      "enum": [
        "rerun_diagnostic_producer",
        "rerun_build_or_test",
        "refresh_semantic_snapshot",
        "review_generated_outputs",
        "inspect_protected_paths",
        "compare_imported_baseline_delta",
        "no_automatic_validation_available"
      ]
    },

    "replay_hint_class": {
      "type": "string",
      "enum": [
        "replay_against_same_execution_context",
        "replay_against_new_semantic_epoch",
        "export_review_packet",
        "attach_support_bundle_evidence",
        "requires_rule_metadata_refresh"
      ]
    },

    "epoch_role_class": {
      "type": "string",
      "enum": [
        "workspace_scope",
        "diagnostic_collection",
        "language_semantic_model",
        "build_graph",
        "execution_run",
        "imported_scan",
        "anchor_remap_family",
        "policy_bundle"
      ]
    },

    "trust_state": {
      "type": "string",
      "enum": [
        "trusted",
        "restricted"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "non_negative_int": {
      "type": "integer",
      "minimum": 0
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_epoch",
        "trust_state",
        "execution_context_id"
      ],
      "properties": {
        "policy_epoch": {
          "$ref": "#/$defs/opaque_id"
        },
        "trust_state": {
          "$ref": "#/$defs/trust_state"
        },
        "execution_context_id": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },

    "epoch_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "epoch_role_class",
        "epoch_ref"
      ],
      "properties": {
        "epoch_role_class": {
          "$ref": "#/$defs/epoch_role_class"
        },
        "epoch_ref": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },

    "acting_provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "source_kind_class",
        "support_class",
        "provider_display_label",
        "tool_identity_ref",
        "tool_version_ref",
        "language_provider_family",
        "freshness_class",
        "locality_class",
        "semantic_layer_state_class",
        "current_epoch_bindings",
        "summary"
      ],
      "properties": {
        "provider_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "source_kind_class": {
          "$ref": "#/$defs/source_kind_class"
        },
        "support_class": {
          "$ref": "#/$defs/support_class"
        },
        "provider_display_label": {
          "$ref": "#/$defs/reviewable_summary"
        },
        "tool_identity_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "tool_version_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "language_provider_family": {
          "$ref": "#/$defs/language_provider_family"
        },
        "freshness_class": {
          "$ref": "#/$defs/diagnostic_freshness_class"
        },
        "locality_class": {
          "$ref": "#/$defs/locality_class"
        },
        "semantic_layer_state_class": {
          "$ref": "#/$defs/semantic_layer_state_class"
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          }
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },

    "mutation_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "affected_diagnostic_count",
        "affected_file_count",
        "affected_anchor_count",
        "generated_path_count",
        "protected_path_count",
        "blocked_path_count"
      ],
      "properties": {
        "affected_diagnostic_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "affected_file_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "affected_anchor_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "generated_path_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "protected_path_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "blocked_path_count": {
          "$ref": "#/$defs/non_negative_int"
        }
      }
    },

    "validation_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validation_hint_classes",
        "replay_hint_classes",
        "validation_summary"
      ],
      "properties": {
        "validation_hint_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validation_hint_class"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "replay_hint_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/replay_hint_class"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "validation_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },

    "code_action_summary_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "code_action_summary_schema_version",
        "code_action_summary_id",
        "action_class",
        "action_label",
        "acting_provider",
        "triggering_diagnostic_cluster_refs",
        "safety_class",
        "mutation_scope_class",
        "preview_requirement_class",
        "apply_posture_class",
        "blocking_reason_classes",
        "mutation_counts",
        "current_epoch_bindings",
        "validation_plan",
        "policy_context",
        "redaction_class",
        "captured_at",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": {
          "$ref": "#/$defs/record_kind"
        },
        "code_action_summary_schema_version": {
          "$ref": "#/$defs/code_action_summary_schema_version"
        },
        "code_action_summary_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "action_class": {
          "$ref": "#/$defs/action_class"
        },
        "action_label": {
          "$ref": "#/$defs/reviewable_summary"
        },
        "acting_provider": {
          "$ref": "#/$defs/acting_provider"
        },
        "triggering_diagnostic_cluster_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_id"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "safety_class": {
          "$ref": "#/$defs/safety_class"
        },
        "mutation_scope_class": {
          "$ref": "#/$defs/mutation_scope_class"
        },
        "preview_requirement_class": {
          "$ref": "#/$defs/preview_requirement_class"
        },
        "apply_posture_class": {
          "$ref": "#/$defs/apply_posture_class"
        },
        "blocking_reason_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/blocking_reason_class"
          },
          "uniqueItems": true
        },
        "mutation_counts": {
          "$ref": "#/$defs/mutation_counts"
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          }
        },
        "validation_plan": {
          "$ref": "#/$defs/validation_plan"
        },
        "checkpoint_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "review_packet_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "policy_context": {
          "$ref": "#/$defs/policy_context"
        },
        "redaction_class": {
          "$ref": "#/$defs/redaction_class"
        },
        "captured_at": {
          "$ref": "#/$defs/timestamp"
        },
        "export_safe_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    }
  }
}
