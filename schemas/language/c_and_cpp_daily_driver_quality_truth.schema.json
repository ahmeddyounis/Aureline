{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/c_and_cpp_daily_driver_quality_truth.schema.json",
  "title": "Aureline C and C++ daily-driver quality truth packet",
  "description": "Boundary schema for the stable C and C++ daily-driver quality truth packet. The packet binds the C and C++ language lane (CMake/Ninja build workspaces — CMakeLists.txt top-level and subdirectory targets, CMakePresets.json/CMakeUserPresets.json configure/build/test/package presets, CMakeCache.txt, cmake/ modules and toolchains, Ninja build.ninja and Ninja Multi-Config generators, CMAKE_BUILD_TYPE (Debug/Release/RelWithDebInfo/MinSizeRel), CMAKE_TOOLCHAIN_FILE, vcpkg vcpkg.json/vcpkg-configuration.json and Conan conanfile.txt/conanfile.py package-manager integration, and compile_commands.json export (CMAKE_EXPORT_COMPILE_COMMANDS=ON); compile/run/debug fidelity surface — cmake --build driving Ninja or Make targets, ctest/ctest --output-on-failure test invocation, executable launch via cmake --build --target <target> or ninja <target>, clang/gcc/MSVC column- and range-accurate compile diagnostics, SARIF import from clang-tidy and cppcheck, LLDB and GDB native debuggers, lldb-dap and CodeLLDB DAP bridges, launch and attach modes, gdbserver/lldb-server remote-debug transports, core-dump open; clangd rename/navigation surface — clangd LSP textDocument/rename, textDocument/definition, textDocument/references, textDocument/typeDefinition, extract/inline/code-action, type-hierarchy, call-hierarchy, header/source pairing (.h/.c, .hpp/.cc/.cpp/.cxx), include resolution from compile_commands.json -I paths, cross-translation-unit background index, clang-format/.clang-format formatting, clang-tidy/.clang-tidy quick-fixes) on the M4 stable lane with current fixture-repo, framework-migration, archetype, build-workspace, compile/run/debug, and clangd rename/navigation evidence. The packet is the single truth that the editor language pack, framework pack panel, language settings/help, CLI/headless inspector, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies or paraphrase daily-driver posture.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "c_and_cpp_daily_driver_quality_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/language_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/daily_driver_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "language_lane_class": {
      "enum": [
        "c_and_cpp_daily_driver_lane"
      ]
    },
    "daily_driver_row_class": {
      "enum": [
        "daily_driver_quality",
        "daily_loop_step",
        "framework_pack",
        "migration_evidence",
        "archetype_repo_evidence",
        "build_workspace_row",
        "compile_run_debug_row",
        "clangd_navigation_row",
        "unsupported_gap",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "replacement_grade",
        "daily_driver_below_replacement",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "daily_loop_step_class": {
      "enum": [
        "open_or_import",
        "navigate",
        "edit",
        "complete",
        "refactor",
        "run_test_debug",
        "review",
        "migrate",
        "recover",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "archetype_repo_evidence",
        "framework_migration_evidence",
        "design_partner_evidence",
        "fixture_repo_evidence",
        "conformance_suite_evidence",
        "benchmark_evidence",
        "build_workspace_evidence",
        "compile_run_debug_evidence",
        "clangd_navigation_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "framework_subset_only",
        "language_subset_only",
        "archetype_subset_only",
        "migration_subset_only",
        "build_workspace_subset_only",
        "compile_run_debug_subset_only",
        "clangd_navigation_subset_only",
        "unsupported_runtime_target",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_missing_fixture",
        "auto_narrow_on_missing_archetype",
        "auto_narrow_on_failed_migration",
        "auto_narrow_on_framework_gap",
        "auto_narrow_on_unproven_build_workspace",
        "auto_narrow_on_unproven_compile_run_debug",
        "auto_narrow_on_unproven_clangd_navigation",
        "auto_demote_on_low_confidence",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "daily_driver_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_language_lane_coverage",
        "missing_daily_loop_step_coverage",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "replacement_grade_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "daily_loop_step_not_applicable",
        "daily_loop_step_not_permitted_on_row_class",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "daily_loop_step_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "daily_driver_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "daily_loop_step_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/language_lane_class" },
        "row_class": { "$ref": "#/$defs/daily_driver_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "daily_loop_step_class": { "$ref": "#/$defs/daily_loop_step_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/daily_driver_confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "c_and_cpp_daily_driver_quality_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_daily_loop_step_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "editor_language_pack",
            "framework_pack_panel",
            "language_settings",
            "cli_headless",
            "support_export",
            "release_proof_index",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "c_and_cpp_daily_driver_quality_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_daily_loop_step_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
