{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/provider_health_state.schema.json",
  "title": "Aureline language-provider health-state inspector row",
  "description": "Boundary schema for the provider_health_state_record consumed by the language-intelligence arbitration and provider-health inspector. Each row is the compact projection editor chrome, quick-fix previews, diagnostics detail, command results, CLI/headless inspect, and support export read when they need one stable answer to how healthy, how fresh, how complete, and how reachable a language-server, framework-analyzer, notebook-adapter, generated-source bridge, project-graph, syntax, or AI-assist provider is right now, along with the explicit retry and isolate actions a user may take and the downgraded-promise copy that must be shown when the provider has narrowed below its claimed surface support. Raw source text, raw notebook bodies, raw generated artifact payloads, raw provider logs, raw hostnames, raw URLs, raw process arguments, and raw secret material never cross this boundary; the row carries opaque ids, typed vocabulary, epoch refs, and export-safe summaries only. Adding a new health-strip action, recovery hint, downgraded-promise reason, or freshness/health/scope/locality vocabulary value is additive-minor and requires a provider_health_state_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/provider_health_state_record"
    }
  ],
  "$defs": {
    "provider_health_state_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the provider-health-state export. Current value is 1."
    },

    "record_kind": {
      "type": "string",
      "const": "provider_health_state_record"
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1
    },

    "timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "reviewable_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },

    "provider_family": {
      "type": "string",
      "enum": [
        "syntax",
        "project_graph",
        "language_server",
        "framework_pack",
        "notebook_adapter",
        "generated_source_bridge",
        "ai_assist"
      ]
    },

    "provider_role_class": {
      "type": "string",
      "enum": [
        "primary_semantic",
        "secondary_semantic",
        "framework_overlay",
        "notebook_projection",
        "generated_overlay",
        "text_fallback",
        "assist_only"
      ]
    },

    "health_state": {
      "type": "string",
      "enum": [
        "ready",
        "warming",
        "degraded",
        "cached_only",
        "policy_blocked",
        "capability_missing",
        "crash_loop_quarantined",
        "unavailable"
      ]
    },

    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },

    "scope_claim_class": {
      "type": "string",
      "enum": [
        "single_file",
        "notebook_cell",
        "loaded_slice",
        "active_workset",
        "whole_workspace",
        "unavailable"
      ]
    },

    "completeness_class": {
      "type": "string",
      "enum": [
        "complete_for_claimed_scope",
        "partial_for_claimed_scope",
        "unavailable_for_claimed_scope"
      ]
    },

    "locality_class": {
      "type": "string",
      "enum": [
        "local_in_process",
        "local_sidecar",
        "workspace_remote_agent",
        "managed_service",
        "imported_snapshot"
      ]
    },

    "language_action_lane_class": {
      "type": "string",
      "enum": [
        "definition",
        "references",
        "rename",
        "formatting",
        "organize_imports",
        "code_action"
      ],
      "description": "Closed lane vocabulary the health-state inspector reports across. Definition, references, rename, formatting, organize-imports, and code-action are the high-confidence semantic lanes the contract protects."
    },

    "lane_support_class": {
      "type": "string",
      "enum": [
        "exact",
        "heuristic",
        "partial",
        "stale",
        "unsupported"
      ],
      "description": "How the provider currently serves a given lane. Exact and heuristic are mutually exclusive; partial means scope is narrower than claimed; stale means freshness fell below the floor."
    },

    "retry_action_class": {
      "type": "string",
      "enum": [
        "not_available",
        "soft_retry",
        "restart_session",
        "warm_from_snapshot",
        "manual_recovery_required"
      ],
      "description": "Retry actions surfaced to the user on a health strip. `not_available` means no retry path is admissible; `manual_recovery_required` means the supervisor needs explicit operator action."
    },

    "isolate_action_class": {
      "type": "string",
      "enum": [
        "not_available",
        "isolate_for_session",
        "isolate_until_recovery",
        "quarantine_for_workspace"
      ],
      "description": "Isolation actions exposed when the provider is misbehaving. `quarantine_for_workspace` blocks the provider until explicit recovery."
    },

    "recovery_hint_class": {
      "type": "string",
      "enum": [
        "none",
        "wait_for_warm_up",
        "wait_for_index",
        "reconnect_remote",
        "reload_config",
        "reinstall_pack",
        "review_policy",
        "report_to_support"
      ],
      "description": "Recovery hint shown next to the retry/isolate controls."
    },

    "downgraded_promise_reason_class": {
      "type": "string",
      "enum": [
        "none",
        "narrowed_to_file_local",
        "narrowed_to_active_workset",
        "narrowed_to_notebook_cell",
        "narrowed_to_loaded_slice",
        "fallback_to_text",
        "fallback_to_heuristic",
        "stale_cache_reuse",
        "crash_loop_excluded",
        "policy_excluded",
        "remote_unreachable",
        "advisory_only_ai_assist"
      ],
      "description": "Explicit downgraded-promise reason rendered on the health strip when the provider has narrowed below its claimed surface support."
    },

    "fault_domain_class": {
      "type": "string",
      "enum": [
        "shell_interaction_core",
        "workspace_knowledge_workers",
        "session_scoped_execution_hosts",
        "extension_and_tool_hosts",
        "ai_and_external_tool_brokers",
        "remote_connectors",
        "policy_entitlement_and_verifier_helpers"
      ]
    },

    "epoch_role_class": {
      "type": "string",
      "enum": [
        "workspace_scope",
        "graph_snapshot",
        "provider_session",
        "language_project_model",
        "framework_pack_snapshot",
        "notebook_projection",
        "generated_lineage",
        "ai_context"
      ]
    },

    "trust_state": {
      "type": "string",
      "enum": [
        "trusted",
        "restricted"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_epoch",
        "trust_state",
        "execution_context_id"
      ],
      "properties": {
        "policy_epoch": {
          "$ref": "#/$defs/opaque_id"
        },
        "trust_state": {
          "$ref": "#/$defs/trust_state"
        },
        "execution_context_id": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },

    "epoch_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "epoch_role_class",
        "epoch_ref"
      ],
      "properties": {
        "epoch_role_class": {
          "$ref": "#/$defs/epoch_role_class"
        },
        "epoch_ref": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },

    "lane_support_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language_action_lane_class",
        "lane_support_class",
        "summary"
      ],
      "properties": {
        "language_action_lane_class": {
          "$ref": "#/$defs/language_action_lane_class"
        },
        "lane_support_class": {
          "$ref": "#/$defs/lane_support_class"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      },
      "description": "Per-lane support posture rendered on the health strip."
    },

    "retry_isolate_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "retry_action_class",
        "isolate_action_class",
        "recovery_hint_class",
        "summary"
      ],
      "properties": {
        "retry_action_class": {
          "$ref": "#/$defs/retry_action_class"
        },
        "isolate_action_class": {
          "$ref": "#/$defs/isolate_action_class"
        },
        "recovery_hint_class": {
          "$ref": "#/$defs/recovery_hint_class"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },

    "downgraded_promise_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "downgraded_promise_reason_class",
        "summary"
      ],
      "properties": {
        "downgraded_promise_reason_class": {
          "$ref": "#/$defs/downgraded_promise_reason_class"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      },
      "description": "Downgraded-promise block. When the reason is `none`, the summary must explain that no downgrade applies; otherwise it must name what narrowed."
    },

    "provider_health_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "provider_health_state_schema_version",
        "provider_health_state_id",
        "provider_id",
        "provider_family",
        "provider_display_label",
        "provider_role_class",
        "health_state",
        "freshness_class",
        "scope_claim_class",
        "completeness_class",
        "locality_class",
        "fault_domain_class",
        "restart_strike_count",
        "lane_support_rows",
        "retry_isolate_controls",
        "downgraded_promise_block",
        "current_epoch_bindings",
        "policy_context",
        "redaction_class",
        "captured_at",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": {
          "$ref": "#/$defs/record_kind"
        },
        "provider_health_state_schema_version": {
          "$ref": "#/$defs/provider_health_state_schema_version"
        },
        "provider_health_state_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "provider_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "provider_family": {
          "$ref": "#/$defs/provider_family"
        },
        "provider_display_label": {
          "$ref": "#/$defs/reviewable_summary"
        },
        "provider_role_class": {
          "$ref": "#/$defs/provider_role_class"
        },
        "connected_pack_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/opaque_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "health_state": {
          "$ref": "#/$defs/health_state"
        },
        "health_reason_summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/reviewable_summary"
            },
            {
              "type": "null"
            }
          ]
        },
        "freshness_class": {
          "$ref": "#/$defs/freshness_class"
        },
        "last_good_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/timestamp"
            },
            {
              "type": "null"
            }
          ],
          "description": "Last time the provider answered with `ready + authoritative_live`. May be null when no successful good answer has been recorded for this provider."
        },
        "scope_claim_class": {
          "$ref": "#/$defs/scope_claim_class"
        },
        "completeness_class": {
          "$ref": "#/$defs/completeness_class"
        },
        "locality_class": {
          "$ref": "#/$defs/locality_class"
        },
        "host_identity_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/opaque_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "fault_domain_class": {
          "$ref": "#/$defs/fault_domain_class"
        },
        "restart_strike_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Restart strikes counted by the supervisor in the active accounting window. Zero is allowed and means no strikes have been observed yet."
        },
        "quarantine_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/opaque_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "lane_support_rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lane_support_row"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "retry_isolate_controls": {
          "$ref": "#/$defs/retry_isolate_controls"
        },
        "downgraded_promise_block": {
          "$ref": "#/$defs/downgraded_promise_block"
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "policy_context": {
          "$ref": "#/$defs/policy_context"
        },
        "redaction_class": {
          "$ref": "#/$defs/redaction_class"
        },
        "captured_at": {
          "$ref": "#/$defs/timestamp"
        },
        "export_safe_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "health_state": {
                "const": "crash_loop_quarantined"
              }
            },
            "required": [
              "health_state"
            ]
          },
          "then": {
            "required": [
              "health_reason_summary",
              "quarantine_ref"
            ],
            "properties": {
              "health_reason_summary": {
                "$ref": "#/$defs/reviewable_summary"
              },
              "quarantine_ref": {
                "$ref": "#/$defs/opaque_id"
              },
              "freshness_class": {
                "not": {
                  "const": "authoritative_live"
                }
              },
              "downgraded_promise_block": {
                "properties": {
                  "downgraded_promise_reason_class": {
                    "const": "crash_loop_excluded"
                  }
                },
                "required": [
                  "downgraded_promise_reason_class"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "provider_family": {
                "const": "ai_assist"
              }
            },
            "required": [
              "provider_family"
            ]
          },
          "then": {
            "properties": {
              "provider_role_class": {
                "const": "assist_only"
              },
              "lane_support_rows": {
                "items": {
                  "properties": {
                    "lane_support_class": {
                      "not": {
                        "const": "exact"
                      }
                    }
                  }
                }
              },
              "downgraded_promise_block": {
                "properties": {
                  "downgraded_promise_reason_class": {
                    "enum": [
                      "advisory_only_ai_assist",
                      "narrowed_to_file_local",
                      "fallback_to_heuristic",
                      "policy_excluded",
                      "remote_unreachable",
                      "stale_cache_reuse"
                    ]
                  }
                },
                "required": [
                  "downgraded_promise_reason_class"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "locality_class": {
                "const": "imported_snapshot"
              }
            },
            "required": [
              "locality_class"
            ]
          },
          "then": {
            "properties": {
              "freshness_class": {
                "not": {
                  "const": "authoritative_live"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "scope_claim_class": {
                "const": "whole_workspace"
              },
              "completeness_class": {
                "const": "complete_for_claimed_scope"
              }
            },
            "required": [
              "scope_claim_class",
              "completeness_class"
            ]
          },
          "then": {
            "properties": {
              "downgraded_promise_block": {
                "properties": {
                  "downgraded_promise_reason_class": {
                    "const": "none"
                  }
                },
                "required": [
                  "downgraded_promise_reason_class"
                ]
              }
            }
          }
        }
      ]
    }
  }
}
