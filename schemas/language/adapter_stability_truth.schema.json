{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/adapter_stability_truth.schema.json",
  "title": "Aureline adapter stability truth packet",
  "description": "Boundary schema for the stable adapter stability truth packet certifying formatter, linter, and test-adapter stability with degraded-provider truth across the launch wedges at the M4 launch-stable grade with full adapter-capability coverage (discover, execute, report), degraded-provider admission (provider_healthy, provider_degraded_warned, provider_unavailable), adapter-outcome admission, launch-wedge coverage, known limits, downgrade automation, and evidence binding. The packet is the single truth that the editor language pack, framework pack panel, language settings/help, CLI/headless inspector, support export, release proof index, Help/About proof card, and the conformance dashboard all read; surfaces MUST NOT mint local copies or paraphrase adapter posture.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lanes",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "adapter_stability_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/adapter_lane_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/adapter_stability_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "adapter_lane_class": {
      "enum": ["formatter_lane", "linter_lane", "test_adapter_lane"]
    },
    "adapter_stability_row_class": {
      "enum": [
        "adapter_stability_quality",
        "adapter_capability_truth",
        "degraded_provider_admission",
        "adapter_outcome_admission",
        "launch_wedge_coverage",
        "unsupported_gap",
        "known_limit",
        "downgrade_automation"
      ]
    },
    "support_class": {
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported",
        "support_unbound"
      ]
    },
    "adapter_capability_class": {
      "enum": ["discover", "execute", "report", "not_applicable"]
    },
    "degraded_provider_class": {
      "enum": [
        "provider_healthy",
        "provider_degraded_warned",
        "provider_unavailable",
        "provider_misconfigured",
        "provider_timed_out",
        "not_applicable",
        "state_unbound"
      ]
    },
    "adapter_outcome_class": {
      "enum": [
        "passed",
        "passed_with_warnings",
        "failed",
        "blocked",
        "pending",
        "unsupported",
        "not_applicable",
        "outcome_unbound"
      ]
    },
    "launch_wedge_class": {
      "enum": [
        "python_wedge",
        "typescript_javascript_wedge",
        "rust_wedge",
        "go_wedge",
        "java_kotlin_wedge",
        "c_cpp_wedge",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "enum": [
        "archetype_repo_evidence",
        "framework_migration_evidence",
        "design_partner_evidence",
        "fixture_repo_evidence",
        "conformance_suite_evidence",
        "benchmark_evidence",
        "docs_disclosure_evidence",
        "evidence_unbound"
      ]
    },
    "known_limit_class": {
      "enum": [
        "none_declared",
        "adapter_subset_only",
        "wedge_subset_only",
        "provider_state_subset_only",
        "capability_subset_only",
        "outcome_subset_only",
        "archetype_subset_only",
        "unsupported_runtime_target",
        "beta_capability_sample_only",
        "limit_unbound"
      ]
    },
    "downgrade_automation_class": {
      "enum": [
        "none",
        "auto_narrow_on_missing_fixture",
        "auto_narrow_on_missing_archetype",
        "auto_narrow_on_degraded_provider",
        "auto_narrow_on_outcome_failure",
        "auto_narrow_on_capability_gap",
        "auto_demote_on_low_confidence",
        "auto_block_on_missing_evidence",
        "manual_only_pending_review",
        "automation_unbound"
      ]
    },
    "adapter_stability_confidence_class": {
      "enum": ["high_confidence", "medium_confidence", "low_confidence"]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_adapter_lane_coverage",
        "missing_adapter_capability_coverage",
        "missing_degraded_provider_coverage",
        "missing_adapter_outcome_coverage",
        "missing_launch_wedge_coverage",
        "missing_support_class",
        "missing_known_limit",
        "missing_downgrade_automation",
        "missing_evidence_class",
        "missing_degraded_provider_class",
        "missing_adapter_outcome_class",
        "launch_stable_with_unbound_binding",
        "narrowed_row_missing_disclosure_ref",
        "known_limit_missing_disclosure_ref",
        "downgrade_automation_missing_disclosure_ref",
        "missing_evidence_refs",
        "adapter_capability_not_applicable",
        "adapter_capability_not_permitted_on_row_class",
        "degraded_provider_not_applicable",
        "degraded_provider_not_permitted_on_row_class",
        "adapter_outcome_not_applicable",
        "adapter_outcome_not_permitted_on_row_class",
        "launch_wedge_not_applicable",
        "launch_wedge_not_permitted_on_row_class",
        "raw_source_material_present",
        "secrets_present",
        "ambient_authority_present",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "row_class_vocabulary_collapsed",
        "support_class_vocabulary_collapsed",
        "adapter_capability_vocabulary_collapsed",
        "degraded_provider_vocabulary_collapsed",
        "adapter_outcome_vocabulary_collapsed",
        "launch_wedge_vocabulary_collapsed",
        "known_limit_vocabulary_collapsed",
        "downgrade_automation_vocabulary_collapsed",
        "evidence_class_vocabulary_collapsed",
        "promotion_state_mismatch"
      ]
    },
    "adapter_stability_row": {
      "type": "object",
      "required": [
        "row_id",
        "lane_class",
        "row_class",
        "support_class",
        "adapter_capability_class",
        "degraded_provider_class",
        "adapter_outcome_class",
        "launch_wedge_class",
        "evidence_class",
        "known_limit_class",
        "downgrade_automation_class",
        "confidence_class",
        "evidence_refs",
        "raw_source_material_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_class": { "$ref": "#/$defs/adapter_lane_class" },
        "row_class": { "$ref": "#/$defs/adapter_stability_row_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "adapter_capability_class": { "$ref": "#/$defs/adapter_capability_class" },
        "degraded_provider_class": { "$ref": "#/$defs/degraded_provider_class" },
        "adapter_outcome_class": { "$ref": "#/$defs/adapter_outcome_class" },
        "launch_wedge_class": { "$ref": "#/$defs/launch_wedge_class" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "known_limit_class": { "$ref": "#/$defs/known_limit_class" },
        "downgrade_automation_class": { "$ref": "#/$defs/downgrade_automation_class" },
        "confidence_class": { "$ref": "#/$defs/adapter_stability_confidence_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "raw_source_material_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "adapter_stability_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_row_class_vocabulary",
        "preserves_support_class_vocabulary",
        "preserves_adapter_capability_vocabulary",
        "preserves_degraded_provider_vocabulary",
        "preserves_adapter_outcome_vocabulary",
        "preserves_launch_wedge_vocabulary",
        "preserves_known_limit_vocabulary",
        "preserves_downgrade_automation_vocabulary",
        "preserves_evidence_class_vocabulary",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": {
          "enum": [
            "editor_language_pack",
            "framework_pack_panel",
            "language_settings",
            "cli_headless",
            "support_export",
            "release_proof_index",
            "help_about",
            "conformance_dashboard"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "adapter_stability_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_row_class_vocabulary": { "type": "boolean" },
        "preserves_support_class_vocabulary": { "type": "boolean" },
        "preserves_adapter_capability_vocabulary": { "type": "boolean" },
        "preserves_degraded_provider_vocabulary": { "type": "boolean" },
        "preserves_adapter_outcome_vocabulary": { "type": "boolean" },
        "preserves_launch_wedge_vocabulary": { "type": "boolean" },
        "preserves_known_limit_vocabulary": { "type": "boolean" },
        "preserves_downgrade_automation_vocabulary": { "type": "boolean" },
        "preserves_evidence_class_vocabulary": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
