{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/diagnostic_delta.schema.json",
  "title": "Aureline diagnostic delta, grouping, collapse, and attribution contract",
  "description": "Boundary schema for diagnostic_delta_record, the shared comparison packet for current, imported, baseline, stale, suppressed, waived, managed CI, provider, review-pack, and support-export diagnostic result sets. The record freezes compatibility checks, result-set roles, per-finding delta states, grouping rules, collapse posture, attribution, counts, and export survival fields so local runs, managed CI, provider imports, review views, CLI/headless output, release reports, and support bundles compare findings mechanically without raw log parsing. Raw source text, raw scanner payloads, raw logs, raw command lines, raw absolute paths, raw URLs, and raw secret material never cross this boundary; records carry opaque refs, class labels, counts, timestamps, and reviewable summaries only. Adding a new enum value or optional property is additive-minor and bumps diagnostic_delta_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/diagnostic_delta_record" }
  ],
  "$defs": {
    "diagnostic_delta_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "diagnostic_delta_record"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1
    },
    "opaque_ref_nullable": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480,
      "description": "Reviewable text safe for UI, CLI, support, release, and review exports. Raw source text, raw scanner bodies, raw paths, raw URLs, raw command lines, and raw secret material are forbidden."
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "comparison_class": {
      "type": "string",
      "enum": [
        "local_current_vs_baseline",
        "local_current_vs_imported",
        "managed_ci_vs_baseline",
        "provider_import_vs_local_current",
        "support_export_vs_current",
        "review_pack_diff",
        "multi_source_quality_delta",
        "comparison_unknown_requires_review"
      ]
    },
    "target_scope_class": {
      "type": "string",
      "enum": [
        "current_file",
        "current_root",
        "selected_workset",
        "workspace",
        "changed_files",
        "review_diff",
        "baseline_family",
        "release_candidate",
        "support_export",
        "provider_project",
        "target_scope_unknown_requires_review"
      ]
    },
    "result_set_role_class": {
      "type": "string",
      "enum": [
        "current_live",
        "imported_snapshot",
        "baseline_snapshot",
        "suppressed_findings",
        "stale_findings",
        "managed_ci_current",
        "provider_live",
        "support_export_snapshot",
        "review_pack_snapshot",
        "result_role_unknown_requires_review"
      ]
    },
    "authority_class": {
      "type": "string",
      "enum": [
        "current_live_authoritative",
        "imported_read_only_evidence",
        "provider_authoritative_snapshot",
        "managed_ci_authoritative_snapshot",
        "locally_confirmed_current",
        "baseline_authoritative_snapshot",
        "suppression_governed_interpretation",
        "support_replay_read_only",
        "authority_unknown_requires_review"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "recent",
        "stale",
        "superseded",
        "imported_snapshot",
        "freshness_unknown_requires_review"
      ]
    },
    "comparison_compatibility_class": {
      "type": "string",
      "enum": [
        "compatible_exact",
        "compatible_with_profile_drift",
        "compatible_with_mapping_drift",
        "compatible_with_environment_drift",
        "blocked_profile_or_tool_mismatch",
        "blocked_rule_pack_mismatch",
        "blocked_anchor_mapping_uncertain",
        "blocked_baseline_family_mismatch",
        "not_comparable_unknown_requires_review"
      ]
    },
    "compatibility_axis_class": {
      "type": "string",
      "enum": [
        "effective_profile",
        "tool_identity",
        "rule_pack",
        "baseline_family",
        "target_scope",
        "anchor_mapping_family",
        "environment_or_execution_context",
        "suppression_policy",
        "axis_unknown_requires_review"
      ]
    },
    "delta_state_class": {
      "type": "string",
      "enum": [
        "new",
        "persisting",
        "resolved",
        "suppressed",
        "waived",
        "stale",
        "needs_remap",
        "imported_only",
        "locally_confirmed",
        "remapped",
        "source_moved",
        "unsupported_anchor",
        "generated_anchor_only",
        "compatibility_blocked",
        "delta_state_unknown_requires_review"
      ]
    },
    "grouping_class": {
      "type": "string",
      "enum": [
        "rule_anchor_family",
        "rule_target_scope",
        "baseline_family",
        "source_kind",
        "owner_or_policy_scope",
        "suppression_scope",
        "severity_and_category",
        "provider_run",
        "no_grouping",
        "grouping_unknown_requires_review"
      ]
    },
    "collapse_class": {
      "type": "string",
      "enum": [
        "no_collapse",
        "collapse_display_only",
        "collapse_mechanical_equivalent",
        "collapse_under_suppression",
        "collapse_under_baseline",
        "collapse_blocked_requires_review",
        "collapse_unknown_requires_review"
      ]
    },
    "attribution_class": {
      "type": "string",
      "enum": [
        "local_run",
        "managed_ci",
        "provider_import",
        "provider_live",
        "baseline",
        "suppression",
        "support_export",
        "review_pack",
        "mixed_attribution_requires_detail",
        "attribution_unknown_requires_review"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "target_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_scope_class",
        "scope_ref",
        "target_revision_ref",
        "execution_context_ref",
        "summary"
      ],
      "properties": {
        "target_scope_class": { "$ref": "#/$defs/target_scope_class" },
        "scope_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "target_revision_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "execution_context_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "result_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_set_role_class",
        "result_set_ref",
        "authority_class",
        "freshness_class",
        "produced_at",
        "tool_identity_ref",
        "rule_pack_ref",
        "baseline_family_ref",
        "summary"
      ],
      "properties": {
        "result_set_role_class": { "$ref": "#/$defs/result_set_role_class" },
        "result_set_ref": { "$ref": "#/$defs/opaque_ref" },
        "authority_class": { "$ref": "#/$defs/authority_class" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "produced_at": { "$ref": "#/$defs/timestamp" },
        "tool_identity_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "rule_pack_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "baseline_family_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "compatibility_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_compatibility_class",
        "checked_axes",
        "blocked_axes",
        "profile_comparison_ref",
        "mapping_family_ref",
        "summary"
      ],
      "properties": {
        "comparison_compatibility_class": { "$ref": "#/$defs/comparison_compatibility_class" },
        "checked_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/compatibility_axis_class" },
          "uniqueItems": true
        },
        "blocked_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/compatibility_axis_class" },
          "uniqueItems": true
        },
        "profile_comparison_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "mapping_family_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "grouping_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_id",
        "grouping_class",
        "collapse_class",
        "attribution_class",
        "group_key_ref",
        "summary"
      ],
      "properties": {
        "group_id": { "$ref": "#/$defs/opaque_id" },
        "grouping_class": { "$ref": "#/$defs/grouping_class" },
        "collapse_class": { "$ref": "#/$defs/collapse_class" },
        "attribution_class": { "$ref": "#/$defs/attribution_class" },
        "group_key_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "delta_count_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "new_count",
        "persisting_count",
        "resolved_count",
        "suppressed_count",
        "waived_count",
        "stale_count",
        "needs_remap_count",
        "imported_only_count",
        "locally_confirmed_count",
        "remapped_count",
        "source_moved_count",
        "unsupported_anchor_count",
        "generated_anchor_only_count",
        "compatibility_blocked_count"
      ],
      "properties": {
        "new_count": { "$ref": "#/$defs/non_negative_integer" },
        "persisting_count": { "$ref": "#/$defs/non_negative_integer" },
        "resolved_count": { "$ref": "#/$defs/non_negative_integer" },
        "suppressed_count": { "$ref": "#/$defs/non_negative_integer" },
        "waived_count": { "$ref": "#/$defs/non_negative_integer" },
        "stale_count": { "$ref": "#/$defs/non_negative_integer" },
        "needs_remap_count": { "$ref": "#/$defs/non_negative_integer" },
        "imported_only_count": { "$ref": "#/$defs/non_negative_integer" },
        "locally_confirmed_count": { "$ref": "#/$defs/non_negative_integer" },
        "remapped_count": { "$ref": "#/$defs/non_negative_integer" },
        "source_moved_count": { "$ref": "#/$defs/non_negative_integer" },
        "unsupported_anchor_count": { "$ref": "#/$defs/non_negative_integer" },
        "generated_anchor_only_count": { "$ref": "#/$defs/non_negative_integer" },
        "compatibility_blocked_count": { "$ref": "#/$defs/non_negative_integer" }
      }
    },
    "finding_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_delta_id",
        "delta_state_class",
        "group_id_ref",
        "diagnostic_refs",
        "remap_state_ref",
        "sarif_import_ref",
        "baseline_ref",
        "suppression_ref",
        "authority_class",
        "attribution_class",
        "collapse_class",
        "current_anchor_ref",
        "summary"
      ],
      "properties": {
        "finding_delta_id": { "$ref": "#/$defs/opaque_id" },
        "delta_state_class": { "$ref": "#/$defs/delta_state_class" },
        "group_id_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "diagnostic_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "remap_state_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "sarif_import_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "baseline_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "suppression_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "authority_class": { "$ref": "#/$defs/authority_class" },
        "attribution_class": { "$ref": "#/$defs/attribution_class" },
        "collapse_class": { "$ref": "#/$defs/collapse_class" },
        "current_anchor_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "export_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_bundle_refs",
        "review_pack_refs",
        "cli_output_refs",
        "release_packet_refs",
        "redaction_class",
        "summary"
      ],
      "properties": {
        "support_bundle_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "review_pack_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "cli_output_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "release_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "diagnostic_delta_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "diagnostic_delta_schema_version",
        "diagnostic_delta_id",
        "workspace_ref",
        "comparison_class",
        "target_scope",
        "result_sets",
        "compatibility",
        "grouping_rules",
        "delta_counts",
        "finding_deltas",
        "export_projection",
        "computed_at",
        "summary"
      ],
      "properties": {
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "diagnostic_delta_schema_version": { "$ref": "#/$defs/diagnostic_delta_schema_version" },
        "diagnostic_delta_id": { "$ref": "#/$defs/opaque_id" },
        "workspace_ref": { "$ref": "#/$defs/opaque_ref" },
        "comparison_class": { "$ref": "#/$defs/comparison_class" },
        "target_scope": { "$ref": "#/$defs/target_scope" },
        "result_sets": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/result_set" }
        },
        "compatibility": { "$ref": "#/$defs/compatibility_summary" },
        "grouping_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/grouping_rule" }
        },
        "delta_counts": { "$ref": "#/$defs/delta_count_summary" },
        "finding_deltas": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding_delta" }
        },
        "export_projection": { "$ref": "#/$defs/export_projection" },
        "computed_at": { "$ref": "#/$defs/timestamp" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    }
  }
}
