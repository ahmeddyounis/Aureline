{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/language/sarif_import_record.schema.json",
  "title": "Aureline SARIF-like import and provider scan record contract",
  "description": "Boundary schema for sarif_import_record, the shared imported-scan envelope for SARIF 2.1.0, SARIF-like JSON, provider API snapshots, managed CI artifacts, review packets, release packets, and support-export replays. The record preserves scan time, import time, source tool identity, rule-pack version, baseline family, target scope, severity mapping, normalized finding refs, remap-state refs, delta refs, and imported-versus-live authority. Raw SARIF bodies, raw source text, raw paths, raw URLs, raw logs, raw command lines, raw provider payloads, and raw secret material never cross this boundary; records carry opaque refs, digests, class labels, counts, timestamps, and reviewable summaries only. Adding a new enum value or optional property is additive-minor and bumps sarif_import_record_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/sarif_import_record" }
  ],
  "$defs": {
    "sarif_import_record_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "sarif_import_record"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1
    },
    "opaque_ref_nullable": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480,
      "description": "Reviewable text safe for UI, CLI, support, release, and review exports. Raw source text, raw scanner bodies, raw paths, raw URLs, raw command lines, and raw secret material are forbidden."
    },
    "digest": {
      "type": "string",
      "minLength": 1
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "import_format_class": {
      "type": "string",
      "enum": [
        "sarif_2_1_0",
        "sarif_like_json",
        "provider_structured_scan",
        "provider_api_snapshot",
        "support_export_snapshot",
        "review_pack_snapshot",
        "release_packet_snapshot",
        "format_unknown_requires_review"
      ]
    },
    "import_source_class": {
      "type": "string",
      "enum": [
        "local_file_import",
        "managed_ci_artifact",
        "provider_api",
        "support_bundle",
        "review_pack",
        "release_packet",
        "source_unknown_requires_review"
      ]
    },
    "target_scope_class": {
      "type": "string",
      "enum": [
        "current_file",
        "current_root",
        "selected_workset",
        "workspace",
        "changed_files",
        "review_diff",
        "baseline_family",
        "release_candidate",
        "support_export",
        "provider_project",
        "target_scope_unknown_requires_review"
      ]
    },
    "source_severity_class": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "error",
        "warning",
        "note",
        "none",
        "info",
        "provider_custom",
        "severity_unknown_requires_review"
      ]
    },
    "normalized_severity_class": {
      "type": "string",
      "enum": [
        "error",
        "warning",
        "information",
        "hint"
      ]
    },
    "severity_mapping_authority_class": {
      "type": "string",
      "enum": [
        "schema_default",
        "tool_declared",
        "provider_declared",
        "policy_override",
        "user_reviewed",
        "mapping_unknown_requires_review"
      ]
    },
    "baseline_family_state_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "compatible",
        "compatible_with_local_confirmation",
        "stale_but_comparable",
        "incompatible_rule_pack",
        "incompatible_profile",
        "incompatible_mapping_family",
        "compatibility_unknown_requires_review"
      ]
    },
    "authority_class": {
      "type": "string",
      "enum": [
        "imported_read_only_evidence",
        "provider_authoritative_snapshot",
        "managed_ci_authoritative_snapshot",
        "locally_confirmed_current",
        "live_current_authoritative",
        "support_replay_read_only",
        "authority_unknown_requires_review"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "profile_ref_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_profile_ref",
        "imported_profile_ref",
        "effective_profile_ref",
        "provider_profile_ref"
      ],
      "properties": {
        "local_profile_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "imported_profile_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "effective_profile_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "provider_profile_ref": { "$ref": "#/$defs/opaque_ref_nullable" }
      }
    },
    "source_tool_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_id",
        "tool_version",
        "adapter_id",
        "adapter_version",
        "provider_ref",
        "toolchain_digest",
        "summary"
      ],
      "properties": {
        "tool_id": { "$ref": "#/$defs/opaque_id" },
        "tool_version": {
          "type": "string",
          "minLength": 1
        },
        "adapter_id": { "$ref": "#/$defs/opaque_id" },
        "adapter_version": {
          "type": "string",
          "minLength": 1
        },
        "provider_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "toolchain_digest": { "$ref": "#/$defs/digest" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "rule_pack_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_pack_ref",
        "rule_pack_version",
        "rule_pack_digest",
        "baseline_family_ref",
        "baseline_family_state_class",
        "summary"
      ],
      "properties": {
        "rule_pack_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "rule_pack_version": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "rule_pack_digest": { "$ref": "#/$defs/opaque_ref_nullable" },
        "baseline_family_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "baseline_family_state_class": { "$ref": "#/$defs/baseline_family_state_class" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "target_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_scope_class",
        "scope_ref",
        "target_revision_ref",
        "execution_context_ref",
        "environment_ref",
        "summary"
      ],
      "properties": {
        "target_scope_class": { "$ref": "#/$defs/target_scope_class" },
        "scope_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "target_revision_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "execution_context_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "environment_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "severity_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_severity_label_ref",
        "source_severity_class",
        "normalized_severity_class",
        "mapping_authority_class",
        "summary"
      ],
      "properties": {
        "source_severity_label_ref": { "$ref": "#/$defs/opaque_ref" },
        "source_severity_class": { "$ref": "#/$defs/source_severity_class" },
        "normalized_severity_class": { "$ref": "#/$defs/normalized_severity_class" },
        "mapping_authority_class": { "$ref": "#/$defs/severity_mapping_authority_class" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "finding_count_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_count",
        "accepted_count",
        "imported_only_count",
        "locally_confirmed_count",
        "baseline_matched_count",
        "delta_new_count",
        "delta_resolved_count",
        "suppressed_count",
        "needs_remap_count",
        "unsupported_anchor_count",
        "generated_anchor_only_count",
        "compatibility_blocked_count"
      ],
      "properties": {
        "total_count": { "$ref": "#/$defs/non_negative_integer" },
        "accepted_count": { "$ref": "#/$defs/non_negative_integer" },
        "imported_only_count": { "$ref": "#/$defs/non_negative_integer" },
        "locally_confirmed_count": { "$ref": "#/$defs/non_negative_integer" },
        "baseline_matched_count": { "$ref": "#/$defs/non_negative_integer" },
        "delta_new_count": { "$ref": "#/$defs/non_negative_integer" },
        "delta_resolved_count": { "$ref": "#/$defs/non_negative_integer" },
        "suppressed_count": { "$ref": "#/$defs/non_negative_integer" },
        "needs_remap_count": { "$ref": "#/$defs/non_negative_integer" },
        "unsupported_anchor_count": { "$ref": "#/$defs/non_negative_integer" },
        "generated_anchor_only_count": { "$ref": "#/$defs/non_negative_integer" },
        "compatibility_blocked_count": { "$ref": "#/$defs/non_negative_integer" }
      }
    },
    "authority_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_class",
        "local_confirmation_ref",
        "provider_run_ref",
        "imported_vs_live_summary"
      ],
      "properties": {
        "authority_class": { "$ref": "#/$defs/authority_class" },
        "local_confirmation_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "provider_run_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "imported_vs_live_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "normalized_ref_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diagnostic_cluster_refs",
        "diagnostic_remap_state_refs",
        "diagnostic_delta_refs",
        "suppression_review_refs"
      ],
      "properties": {
        "diagnostic_cluster_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "diagnostic_remap_state_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "diagnostic_delta_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "suppression_review_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        }
      }
    },
    "sarif_import_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "sarif_import_record_schema_version",
        "sarif_import_record_id",
        "workspace_ref",
        "import_format_class",
        "import_source_class",
        "source_artifact_ref",
        "raw_payload_ref",
        "scan_started_at",
        "scan_completed_at",
        "imported_at",
        "source_tool_identity",
        "rule_pack_identity",
        "profile_refs",
        "target_scope",
        "severity_mappings",
        "authority",
        "finding_counts",
        "normalized_refs",
        "redaction_class",
        "summary"
      ],
      "properties": {
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "sarif_import_record_schema_version": { "$ref": "#/$defs/sarif_import_record_schema_version" },
        "sarif_import_record_id": { "$ref": "#/$defs/opaque_id" },
        "workspace_ref": { "$ref": "#/$defs/opaque_ref" },
        "import_format_class": { "$ref": "#/$defs/import_format_class" },
        "import_source_class": { "$ref": "#/$defs/import_source_class" },
        "source_artifact_ref": { "$ref": "#/$defs/opaque_ref" },
        "raw_payload_ref": { "$ref": "#/$defs/opaque_ref" },
        "scan_started_at": { "$ref": "#/$defs/timestamp" },
        "scan_completed_at": { "$ref": "#/$defs/timestamp" },
        "imported_at": { "$ref": "#/$defs/timestamp" },
        "source_tool_identity": { "$ref": "#/$defs/source_tool_identity" },
        "rule_pack_identity": { "$ref": "#/$defs/rule_pack_identity" },
        "profile_refs": { "$ref": "#/$defs/profile_ref_set" },
        "target_scope": { "$ref": "#/$defs/target_scope" },
        "severity_mappings": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/severity_mapping" }
        },
        "authority": { "$ref": "#/$defs/authority_summary" },
        "finding_counts": { "$ref": "#/$defs/finding_count_summary" },
        "normalized_refs": { "$ref": "#/$defs/normalized_ref_set" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    }
  }
}
