{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/doctor/project-doctor-container-boundary-truth.schema.json",
  "title": "Aureline Project Doctor container boundary truth packet",
  "description": "Schema for the project_doctor_container_boundary_truth packet. Each scenario seeds one container-dependent situation in one M5 workflow surface (remote preview or incident workflow) and pins an engine summary (active engine class, reachability, support class, certification note, diagnostics actions), the workspace mode, the local/remote/managed boundary label, the target identity being rebuilt or attached, an open-in-container preflight / rebuild review (definition source, rebuild-versus-reuse, trust-gated lifecycle hooks, extension installs, published ports, writable mounts, affected services/images, and a non-empty stay-local alternative), and live/buffered/snapshot log truth with an export-safe time range and metadata-safe redaction posture. A non-inheriting preflight gate publishes each scenario's decision and reason from its own reachability, support class, and disclosed side effects, so an unreachable or policy-blocked engine routes to a non-dead-end offer-alternative outcome and an unsupported engine, a trust-gated hook, or any rebuild/port/mount side effect forces explicit disclosure. Records are read-only and metadata-only and carry no credential bodies or mount/port/tunnel secrets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "schema_ref",
    "as_of",
    "workflow_surfaces",
    "engine_classes",
    "engine_reachabilities",
    "support_classes",
    "workspace_modes",
    "boundary_labels",
    "log_availabilities",
    "preflight_decisions",
    "preflight_reasons",
    "parity_surfaces",
    "scenarios",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "project_doctor_container_boundary_truth" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "schema_ref": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "workflow_surfaces": { "type": "array", "items": { "$ref": "#/$defs/workflow_surface" } },
    "engine_classes": { "type": "array", "items": { "$ref": "#/$defs/engine_class" } },
    "engine_reachabilities": { "type": "array", "items": { "$ref": "#/$defs/engine_reachability" } },
    "support_classes": { "type": "array", "items": { "$ref": "#/$defs/support_class" } },
    "workspace_modes": { "type": "array", "items": { "$ref": "#/$defs/workspace_mode" } },
    "boundary_labels": { "type": "array", "items": { "$ref": "#/$defs/boundary_label" } },
    "log_availabilities": { "type": "array", "items": { "$ref": "#/$defs/log_availability" } },
    "preflight_decisions": { "type": "array", "items": { "$ref": "#/$defs/preflight_decision" } },
    "preflight_reasons": { "type": "array", "items": { "$ref": "#/$defs/preflight_reason" } },
    "parity_surfaces": { "type": "array", "items": { "$ref": "#/$defs/parity_surface" } },
    "scenarios": { "type": "array", "items": { "$ref": "#/$defs/scenario" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "workflow_surface": { "enum": ["remote_preview", "incident_workflow"] },
    "engine_class": { "enum": ["docker", "podman", "devcontainers_cli", "managed_cloud"] },
    "engine_reachability": { "enum": ["reachable", "unreachable", "policy_blocked"] },
    "support_class": { "enum": ["certified", "supported", "experimental", "unsupported"] },
    "workspace_mode": { "enum": ["attached_container", "devcontainer", "remote_managed"] },
    "boundary_label": { "enum": ["local", "remote", "managed"] },
    "definition_source": {
      "enum": ["devcontainer_json", "dockerfile", "compose_file", "image_reference", "managed_template"]
    },
    "rebuild_decision": { "enum": ["rebuild", "reuse_existing"] },
    "lifecycle_hook_kind": {
      "enum": ["initialize", "on_create", "update_content", "post_create", "post_start", "post_attach"]
    },
    "port_visibility": { "enum": ["local_only", "lan_visible", "public_tunnel"] },
    "mount_kind": { "enum": ["workspace_bind", "named_volume", "tmpfs_scratch", "host_path_bind"] },
    "log_availability": { "enum": ["live", "buffered", "snapshot", "unavailable"] },
    "preflight_decision": {
      "enum": ["proceed_full", "proceed_with_disclosure", "blocked_offer_alternative"]
    },
    "preflight_reason": {
      "enum": [
        "none",
        "engine_unreachable",
        "policy_blocked",
        "unsupported_engine",
        "trust_gated_hooks",
        "side_effects_require_review"
      ]
    },
    "parity_surface": {
      "enum": [
        "desktop_sheet",
        "cli_inspect",
        "headless_json",
        "browser_handoff",
        "support_export",
        "incident_packet"
      ]
    },
    "engine_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine_class",
        "engine_version_ref",
        "reachability",
        "support_class",
        "certification_note",
        "diagnostics_actions"
      ],
      "properties": {
        "engine_class": { "$ref": "#/$defs/engine_class" },
        "engine_version_ref": { "$ref": "#/$defs/non_empty_string" },
        "reachability": { "$ref": "#/$defs/engine_reachability" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "certification_note": { "$ref": "#/$defs/non_empty_string" },
        "diagnostics_actions": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } }
      }
    },
    "lifecycle_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "command_ref", "trust_gated"],
      "properties": {
        "kind": { "$ref": "#/$defs/lifecycle_hook_kind" },
        "command_ref": { "$ref": "#/$defs/non_empty_string" },
        "trust_gated": { "type": "boolean" }
      }
    },
    "port_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["container_port", "host_port", "visibility"],
      "properties": {
        "container_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "visibility": { "$ref": "#/$defs/port_visibility" }
      }
    },
    "mount_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "scope_ref", "writable"],
      "properties": {
        "kind": { "$ref": "#/$defs/mount_kind" },
        "scope_ref": { "$ref": "#/$defs/non_empty_string" },
        "writable": { "type": "boolean" }
      }
    },
    "rebuild_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "definition_source",
        "definition_source_ref",
        "rebuild_decision",
        "lifecycle_hooks",
        "extension_installs",
        "published_ports",
        "writable_mounts",
        "affected_services",
        "affected_images",
        "stay_local_alternative"
      ],
      "properties": {
        "definition_source": { "$ref": "#/$defs/definition_source" },
        "definition_source_ref": { "$ref": "#/$defs/non_empty_string" },
        "rebuild_decision": { "$ref": "#/$defs/rebuild_decision" },
        "lifecycle_hooks": { "type": "array", "items": { "$ref": "#/$defs/lifecycle_hook" } },
        "extension_installs": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "published_ports": { "type": "array", "items": { "$ref": "#/$defs/port_mapping" } },
        "writable_mounts": { "type": "array", "items": { "$ref": "#/$defs/mount_binding" } },
        "affected_services": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "affected_images": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "stay_local_alternative": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "log_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["availability", "export_time_range_ref", "redaction_posture", "truth_note"],
      "properties": {
        "availability": { "$ref": "#/$defs/log_availability" },
        "export_time_range_ref": { "type": "string" },
        "redaction_posture": { "const": "metadata_safe_default" },
        "truth_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "support_linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_manifest_ref",
        "escalation_packet_ref",
        "preserved_finding_ids",
        "preserved_repair_ids",
        "preserved_scope_refs",
        "durable_evidence_refs",
        "redaction_class",
        "raw_private_material_excluded",
        "overcapture_excluded"
      ],
      "properties": {
        "bundle_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "escalation_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "preserved_finding_ids": { "$ref": "#/$defs/string_array" },
        "preserved_repair_ids": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "preserved_scope_refs": { "$ref": "#/$defs/string_array" },
        "durable_evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "redaction_class": { "const": "metadata_safe_default" },
        "raw_private_material_excluded": { "const": true },
        "overcapture_excluded": { "const": true }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "surface",
        "title",
        "engine_summary",
        "workspace_mode",
        "boundary_label",
        "target_ref",
        "rebuild_review",
        "log_truth",
        "initiating_findings",
        "support_linkage",
        "parity_surfaces",
        "machine_meaning_keys",
        "explanation",
        "published_preflight_decision",
        "published_preflight_reason",
        "notes"
      ],
      "properties": {
        "scenario_id": { "$ref": "#/$defs/non_empty_string" },
        "surface": { "$ref": "#/$defs/workflow_surface" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "engine_summary": { "$ref": "#/$defs/engine_summary" },
        "workspace_mode": { "$ref": "#/$defs/workspace_mode" },
        "boundary_label": { "$ref": "#/$defs/boundary_label" },
        "target_ref": { "$ref": "#/$defs/non_empty_string" },
        "rebuild_review": { "$ref": "#/$defs/rebuild_review" },
        "log_truth": { "$ref": "#/$defs/log_truth" },
        "initiating_findings": { "$ref": "#/$defs/string_array" },
        "support_linkage": { "$ref": "#/$defs/support_linkage" },
        "parity_surfaces": { "type": "array", "items": { "$ref": "#/$defs/parity_surface" } },
        "machine_meaning_keys": { "$ref": "#/$defs/string_array" },
        "explanation": { "$ref": "#/$defs/non_empty_string" },
        "published_preflight_decision": { "$ref": "#/$defs/preflight_decision" },
        "published_preflight_reason": { "$ref": "#/$defs/preflight_reason" },
        "notes": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_count",
        "surfaces_covered",
        "proceed_full_count",
        "proceed_with_disclosure_count",
        "blocked_count",
        "rebuild_count",
        "trust_gated_hook_count",
        "engine_unavailable_count",
        "log_unavailable_count"
      ],
      "properties": {
        "scenario_count": { "type": "integer", "minimum": 0 },
        "surfaces_covered": { "type": "integer", "minimum": 0 },
        "proceed_full_count": { "type": "integer", "minimum": 0 },
        "proceed_with_disclosure_count": { "type": "integer", "minimum": 0 },
        "blocked_count": { "type": "integer", "minimum": 0 },
        "rebuild_count": { "type": "integer", "minimum": 0 },
        "trust_gated_hook_count": { "type": "integer", "minimum": 0 },
        "engine_unavailable_count": { "type": "integer", "minimum": 0 },
        "log_unavailable_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
