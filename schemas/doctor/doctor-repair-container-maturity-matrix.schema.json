{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/doctor/doctor-repair-container-maturity-matrix.schema.json",
  "title": "Aureline Doctor/repair/container maturity matrix",
  "description": "Schema for the doctor_repair_container_maturity_matrix packet. The packet certifies, for every blocked-user recovery capability (Project Doctor probes, guided repair, container/devcontainer boundary) and every deployment profile (local workspace, remote SSH, container, devcontainer), whether that cell carries a current feature scorecard, diagnosis-latency corpus, compatibility story, and rollback path of its own. The publication gate derives the maturity that may be published for each row from its declared maturity, evidence freshness, blocking reasons, and evidence: a stale, engine-unavailable, latency-breached, or evidence-missing row cannot publish a full certification, and its narrowing action records how the gate narrowed it. One row is required for every (capability, profile) cell so a strong local lane never implies maturity on a remote or containerized one, and guided-repair cells must carry a concrete reversal class.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "capabilities",
    "deployment_profiles",
    "maturity_classes",
    "evidence_freshness_classes",
    "reversal_classes",
    "support_parities",
    "blocking_reasons",
    "narrowing_actions",
    "rows",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "doctor_repair_container_maturity_matrix" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "capabilities": { "type": "array", "items": { "$ref": "#/$defs/capability" } },
    "deployment_profiles": { "type": "array", "items": { "$ref": "#/$defs/deployment_profile" } },
    "maturity_classes": { "type": "array", "items": { "$ref": "#/$defs/maturity_class" } },
    "evidence_freshness_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_freshness" }
    },
    "reversal_classes": { "type": "array", "items": { "$ref": "#/$defs/reversal_class" } },
    "support_parities": { "type": "array", "items": { "$ref": "#/$defs/support_parity" } },
    "blocking_reasons": { "type": "array", "items": { "$ref": "#/$defs/blocking_reason" } },
    "narrowing_actions": { "type": "array", "items": { "$ref": "#/$defs/narrowing_action" } },
    "rows": { "type": "array", "items": { "$ref": "#/$defs/row" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "capability": {
      "enum": ["project_doctor", "guided_repair", "container_boundary"]
    },
    "deployment_profile": {
      "enum": ["local_workspace", "remote_ssh", "container", "devcontainer"]
    },
    "maturity_class": {
      "enum": ["certified", "provisional", "underqualified", "unsupported"]
    },
    "evidence_freshness": {
      "enum": ["current", "stale", "expired", "unknown"]
    },
    "reversal_class": {
      "enum": ["reversible", "checkpointed", "irreversible", "not_applicable"]
    },
    "support_parity": {
      "enum": ["full", "desktop_cli", "desktop_only", "unavailable"]
    },
    "blocking_reason": {
      "enum": [
        "stale",
        "engine_unavailable",
        "latency_slo_breached",
        "missing_proof_corpus",
        "missing_rollback_path",
        "boundary_unverified"
      ]
    },
    "narrowing_action": {
      "enum": [
        "none",
        "narrow_to_provisional",
        "narrow_to_underqualified",
        "withhold_from_publication"
      ]
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "capability",
        "deployment_profile",
        "declared_maturity",
        "published_maturity",
        "evidence_freshness",
        "reversal_class",
        "support_parity",
        "narrowing_action",
        "scorecard_ref",
        "latency_corpus_ref",
        "rollback_ref",
        "compatibility_ref",
        "note"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "capability": { "$ref": "#/$defs/capability" },
        "deployment_profile": { "$ref": "#/$defs/deployment_profile" },
        "declared_maturity": { "$ref": "#/$defs/maturity_class" },
        "published_maturity": { "$ref": "#/$defs/maturity_class" },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness" },
        "reversal_class": { "$ref": "#/$defs/reversal_class" },
        "support_parity": { "$ref": "#/$defs/support_parity" },
        "narrowing_action": { "$ref": "#/$defs/narrowing_action" },
        "blocking_reasons": { "type": "array", "items": { "$ref": "#/$defs/blocking_reason" } },
        "scorecard_ref": { "$ref": "#/$defs/non_empty_string" },
        "latency_corpus_ref": { "$ref": "#/$defs/non_empty_string" },
        "rollback_ref": { "$ref": "#/$defs/non_empty_string" },
        "compatibility_ref": { "$ref": "#/$defs/non_empty_string" },
        "admin_policy_ref": { "type": ["string", "null"] },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows",
        "capability_count",
        "deployment_profile_count",
        "certified_rows",
        "provisional_rows",
        "underqualified_rows",
        "unsupported_rows",
        "promotable_rows",
        "narrowed_rows",
        "withheld_rows",
        "current_freshness_rows",
        "rows_with_blocking_reasons"
      ],
      "properties": {
        "total_rows": { "type": "integer", "minimum": 0 },
        "capability_count": { "type": "integer", "minimum": 0 },
        "deployment_profile_count": { "type": "integer", "minimum": 0 },
        "certified_rows": { "type": "integer", "minimum": 0 },
        "provisional_rows": { "type": "integer", "minimum": 0 },
        "underqualified_rows": { "type": "integer", "minimum": 0 },
        "unsupported_rows": { "type": "integer", "minimum": 0 },
        "promotable_rows": { "type": "integer", "minimum": 0 },
        "narrowed_rows": { "type": "integer", "minimum": 0 },
        "withheld_rows": { "type": "integer", "minimum": 0 },
        "current_freshness_rows": { "type": "integer", "minimum": 0 },
        "rows_with_blocking_reasons": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
