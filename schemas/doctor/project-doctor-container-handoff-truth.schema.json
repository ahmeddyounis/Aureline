{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/doctor/project-doctor-container-handoff-truth.schema.json",
  "title": "Aureline Project Doctor container handoff truth packet",
  "description": "Schema for the project_doctor_container_handoff_truth packet. Each scenario seeds one container-route share situation in one workflow surface (remote preview, incident workflow, or companion follow) and pins a published port or tunnel route (route kind, target/service identity and port, audience scope, policy posture, a time bound that is never unbounded, and a first-class revocation path), an environment-mutation disclosure (writable mounts and lifecycle/install scripts plus the reopen/attach/rebuild/export/support flows the disclosure survives in), and a browser or companion handoff attributed to its owner/origin, engine, target, route, and service plus its live-versus-snapshot freshness and revocation visibility. A non-inheriting handoff gate publishes each scenario's posture and reason from its own policy posture, revocation state, audience scope, write scope, and disclosed mutation, so a policy-blocked route offers a non-dead-end alternative, a revoked or expired route collapses to a snapshot-only share, and a public audience, bounded write channel, policy restriction, or disclosed environment mutation forces explicit disclosure. Records are read-only and metadata-only and carry no credential bodies or mount/port/tunnel secrets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "schema_ref",
    "as_of",
    "workflow_surfaces",
    "engine_classes",
    "boundary_labels",
    "route_kinds",
    "audience_scopes",
    "policy_postures",
    "time_bound_classes",
    "revocation_states",
    "handoff_channels",
    "handoff_livenesses",
    "handoff_mutation_scopes",
    "handoff_postures",
    "handoff_reasons",
    "disclosure_flows",
    "parity_surfaces",
    "scenarios",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "project_doctor_container_handoff_truth" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "schema_ref": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "workflow_surfaces": { "type": "array", "items": { "$ref": "#/$defs/workflow_surface" } },
    "engine_classes": { "type": "array", "items": { "$ref": "#/$defs/engine_class" } },
    "boundary_labels": { "type": "array", "items": { "$ref": "#/$defs/boundary_label" } },
    "route_kinds": { "type": "array", "items": { "$ref": "#/$defs/route_kind" } },
    "audience_scopes": { "type": "array", "items": { "$ref": "#/$defs/audience_scope" } },
    "policy_postures": { "type": "array", "items": { "$ref": "#/$defs/policy_posture" } },
    "time_bound_classes": { "type": "array", "items": { "$ref": "#/$defs/time_bound_class" } },
    "revocation_states": { "type": "array", "items": { "$ref": "#/$defs/revocation_state" } },
    "handoff_channels": { "type": "array", "items": { "$ref": "#/$defs/handoff_channel" } },
    "handoff_livenesses": { "type": "array", "items": { "$ref": "#/$defs/handoff_liveness" } },
    "handoff_mutation_scopes": { "type": "array", "items": { "$ref": "#/$defs/handoff_mutation_scope" } },
    "handoff_postures": { "type": "array", "items": { "$ref": "#/$defs/handoff_posture" } },
    "handoff_reasons": { "type": "array", "items": { "$ref": "#/$defs/handoff_reason" } },
    "disclosure_flows": { "type": "array", "items": { "$ref": "#/$defs/disclosure_flow" } },
    "parity_surfaces": { "type": "array", "items": { "$ref": "#/$defs/parity_surface" } },
    "scenarios": { "type": "array", "items": { "$ref": "#/$defs/scenario" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "workflow_surface": { "enum": ["remote_preview", "incident_workflow", "companion_follow"] },
    "engine_class": { "enum": ["docker", "podman", "devcontainers_cli", "managed_cloud"] },
    "boundary_label": { "enum": ["local", "remote", "managed"] },
    "route_kind": { "enum": ["published_port", "tunnel"] },
    "audience_scope": { "enum": ["local_only", "lan", "authenticated_team", "org", "public"] },
    "policy_posture": { "enum": ["policy_allowed", "policy_restricted", "policy_blocked"] },
    "time_bound_class": { "enum": ["session_bound", "time_boxed", "deadline"] },
    "revocation_state": { "enum": ["active", "expired", "revoked"] },
    "mount_kind": { "enum": ["workspace_bind", "named_volume", "tmpfs_scratch", "host_path_bind"] },
    "script_kind": {
      "enum": ["initialize", "on_create", "post_create", "post_start", "post_attach", "install_script"]
    },
    "disclosure_flow": { "enum": ["reopen", "attach", "rebuild", "export", "support_bundle"] },
    "handoff_channel": { "enum": ["browser", "companion"] },
    "handoff_liveness": { "enum": ["live", "snapshot"] },
    "handoff_mutation_scope": { "enum": ["read_only", "bounded_write"] },
    "handoff_posture": {
      "enum": ["share_live", "share_with_disclosure", "share_snapshot_only", "blocked_offer_alternative"]
    },
    "handoff_reason": {
      "enum": [
        "none",
        "audience_public",
        "policy_restricted",
        "bounded_write_requires_approval",
        "environment_mutation_disclosed",
        "route_expired",
        "route_revoked",
        "policy_blocked"
      ]
    },
    "parity_surface": {
      "enum": [
        "desktop_sheet",
        "cli_inspect",
        "headless_json",
        "browser_handoff",
        "companion_handoff",
        "support_export",
        "incident_packet"
      ]
    },
    "route_time_bound": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "expires_at_ref", "max_lifetime_note"],
      "properties": {
        "class": { "$ref": "#/$defs/time_bound_class" },
        "expires_at_ref": { "$ref": "#/$defs/non_empty_string" },
        "max_lifetime_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "route_revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "revocation_action_ref", "revoked_evidence_ref"],
      "properties": {
        "state": { "$ref": "#/$defs/revocation_state" },
        "revocation_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "revoked_evidence_ref": { "type": "string" }
      }
    },
    "published_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_kind",
        "route_id",
        "target_ref",
        "target_service_ref",
        "container_port",
        "host_port",
        "audience_scope",
        "policy_posture",
        "policy_note",
        "time_bound",
        "revocation"
      ],
      "properties": {
        "route_kind": { "$ref": "#/$defs/route_kind" },
        "route_id": { "$ref": "#/$defs/non_empty_string" },
        "target_ref": { "$ref": "#/$defs/non_empty_string" },
        "target_service_ref": { "$ref": "#/$defs/non_empty_string" },
        "container_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "audience_scope": { "$ref": "#/$defs/audience_scope" },
        "policy_posture": { "$ref": "#/$defs/policy_posture" },
        "policy_note": { "$ref": "#/$defs/non_empty_string" },
        "time_bound": { "$ref": "#/$defs/route_time_bound" },
        "revocation": { "$ref": "#/$defs/route_revocation" }
      }
    },
    "mount_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "scope_ref", "writable"],
      "properties": {
        "kind": { "$ref": "#/$defs/mount_kind" },
        "scope_ref": { "$ref": "#/$defs/non_empty_string" },
        "writable": { "type": "boolean" }
      }
    },
    "lifecycle_script": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "command_ref", "trust_gated", "writes_outside_container"],
      "properties": {
        "kind": { "$ref": "#/$defs/script_kind" },
        "command_ref": { "$ref": "#/$defs/non_empty_string" },
        "trust_gated": { "type": "boolean" },
        "writes_outside_container": { "type": "boolean" }
      }
    },
    "environment_mutation_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["writable_mounts", "lifecycle_scripts", "disclosure_persists_in", "disclosure_note"],
      "properties": {
        "writable_mounts": { "type": "array", "items": { "$ref": "#/$defs/mount_binding" } },
        "lifecycle_scripts": { "type": "array", "items": { "$ref": "#/$defs/lifecycle_script" } },
        "disclosure_persists_in": { "type": "array", "items": { "$ref": "#/$defs/disclosure_flow" } },
        "disclosure_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "handoff_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel",
        "handoff_id",
        "owner_ref",
        "origin_ref",
        "engine_class",
        "target_ref",
        "route_id",
        "target_service_ref",
        "liveness",
        "captured_at_ref",
        "revocation_visible",
        "mutation_scope",
        "approval_gated"
      ],
      "properties": {
        "channel": { "$ref": "#/$defs/handoff_channel" },
        "handoff_id": { "$ref": "#/$defs/non_empty_string" },
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "origin_ref": { "$ref": "#/$defs/non_empty_string" },
        "engine_class": { "$ref": "#/$defs/engine_class" },
        "target_ref": { "$ref": "#/$defs/non_empty_string" },
        "route_id": { "$ref": "#/$defs/non_empty_string" },
        "target_service_ref": { "$ref": "#/$defs/non_empty_string" },
        "liveness": { "$ref": "#/$defs/handoff_liveness" },
        "captured_at_ref": { "type": "string" },
        "revocation_visible": { "type": "boolean" },
        "mutation_scope": { "$ref": "#/$defs/handoff_mutation_scope" },
        "approval_gated": { "type": "boolean" }
      }
    },
    "support_linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_manifest_ref",
        "escalation_packet_ref",
        "preserved_finding_ids",
        "preserved_repair_ids",
        "preserved_scope_refs",
        "durable_evidence_refs",
        "redaction_class",
        "raw_private_material_excluded",
        "overcapture_excluded"
      ],
      "properties": {
        "bundle_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "escalation_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "preserved_finding_ids": { "$ref": "#/$defs/string_array" },
        "preserved_repair_ids": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "preserved_scope_refs": { "$ref": "#/$defs/string_array" },
        "durable_evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "redaction_class": { "const": "metadata_safe_default" },
        "raw_private_material_excluded": { "const": true },
        "overcapture_excluded": { "const": true }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "surface",
        "title",
        "engine_class",
        "boundary_label",
        "route",
        "environment_disclosure",
        "handoff",
        "stay_local_alternative",
        "initiating_findings",
        "support_linkage",
        "parity_surfaces",
        "machine_meaning_keys",
        "explanation",
        "published_handoff_posture",
        "published_handoff_reason",
        "notes"
      ],
      "properties": {
        "scenario_id": { "$ref": "#/$defs/non_empty_string" },
        "surface": { "$ref": "#/$defs/workflow_surface" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "engine_class": { "$ref": "#/$defs/engine_class" },
        "boundary_label": { "$ref": "#/$defs/boundary_label" },
        "route": { "$ref": "#/$defs/published_route" },
        "environment_disclosure": { "$ref": "#/$defs/environment_mutation_disclosure" },
        "handoff": { "$ref": "#/$defs/handoff_packet" },
        "stay_local_alternative": { "$ref": "#/$defs/non_empty_string" },
        "initiating_findings": { "$ref": "#/$defs/string_array" },
        "support_linkage": { "$ref": "#/$defs/support_linkage" },
        "parity_surfaces": { "type": "array", "items": { "$ref": "#/$defs/parity_surface" } },
        "machine_meaning_keys": { "$ref": "#/$defs/string_array" },
        "explanation": { "$ref": "#/$defs/non_empty_string" },
        "published_handoff_posture": { "$ref": "#/$defs/handoff_posture" },
        "published_handoff_reason": { "$ref": "#/$defs/handoff_reason" },
        "notes": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_count",
        "surfaces_covered",
        "share_live_count",
        "share_with_disclosure_count",
        "share_snapshot_only_count",
        "blocked_count",
        "tunnel_count",
        "public_audience_count",
        "revoked_or_expired_count",
        "bounded_write_count"
      ],
      "properties": {
        "scenario_count": { "type": "integer", "minimum": 0 },
        "surfaces_covered": { "type": "integer", "minimum": 0 },
        "share_live_count": { "type": "integer", "minimum": 0 },
        "share_with_disclosure_count": { "type": "integer", "minimum": 0 },
        "share_snapshot_only_count": { "type": "integer", "minimum": 0 },
        "blocked_count": { "type": "integer", "minimum": 0 },
        "tunnel_count": { "type": "integer", "minimum": 0 },
        "public_audience_count": { "type": "integer", "minimum": 0 },
        "revoked_or_expired_count": { "type": "integer", "minimum": 0 },
        "bounded_write_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
