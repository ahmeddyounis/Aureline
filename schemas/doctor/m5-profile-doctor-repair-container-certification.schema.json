{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/doctor/m5-profile-doctor-repair-container-certification.schema.json",
  "title": "Aureline M5-profile Doctor/repair/container certification",
  "description": "Schema for the m5_profile_doctor_repair_container_certification packet. The packet certifies every marketed M5 product profile (notebook, request/API, database, profiler, remote preview, sync, companion, incident) for combined Project Doctor, guided-repair, and container/devcontainer maturity. Each profile row names its own Doctor/repair/container maturities, the freshness of its qualification packet, its diagnosis-latency state, its engine reachability, and its container-boundary proof. A non-inheriting promotion gate derives the qualification that may be published from those inputs: a stale, diagnosis-latency red, repair-underqualified, engine-blocked, or boundary-proof-missing profile cannot publish a full certification, and its certification decision records whether the gate promoted, narrowed to provisional or underqualified, or failed promotion. One row is required per claimed profile so a strong notebook lane never implies container/devcontainer or blocked-user recovery maturity on an unrelated profile, and the recorded published qualification, decision, and narrowing reasons must equal the recomputed gate decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "m5_profiles",
    "qualification_classes",
    "certification_freshness_classes",
    "diagnosis_latency_states",
    "engine_reachability_classes",
    "boundary_proof_classes",
    "narrowing_reasons",
    "certification_decisions",
    "profiles",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_profile_doctor_repair_container_certification" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "m5_profiles": { "type": "array", "items": { "$ref": "#/$defs/m5_profile" } },
    "qualification_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/qualification_class" }
    },
    "certification_freshness_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/certification_freshness" }
    },
    "diagnosis_latency_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnosis_latency_state" }
    },
    "engine_reachability_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/engine_reachability" }
    },
    "boundary_proof_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/boundary_proof" }
    },
    "narrowing_reasons": { "type": "array", "items": { "$ref": "#/$defs/narrowing_reason" } },
    "certification_decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/certification_decision" }
    },
    "profiles": { "type": "array", "items": { "$ref": "#/$defs/profile" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "m5_profile": {
      "enum": [
        "notebook",
        "request_api",
        "database",
        "profiler",
        "remote_preview",
        "sync",
        "companion",
        "incident"
      ]
    },
    "qualification_class": {
      "enum": ["certified", "provisional", "underqualified", "unsupported"]
    },
    "certification_freshness": {
      "enum": ["current", "stale", "expired", "unknown"]
    },
    "diagnosis_latency_state": {
      "enum": ["green", "amber", "red", "unmeasured"]
    },
    "engine_reachability": {
      "enum": ["reachable", "degraded", "blocked", "not_applicable"]
    },
    "boundary_proof": {
      "enum": ["verified", "partial", "unverified", "not_applicable"]
    },
    "narrowing_reason": {
      "enum": [
        "stale",
        "diagnosis_latency_red",
        "repair_underqualified",
        "engine_blocked",
        "boundary_proof_missing"
      ]
    },
    "certification_decision": {
      "enum": [
        "promote",
        "narrow_to_provisional",
        "narrow_to_underqualified",
        "fail_promotion"
      ]
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "m5_profile",
        "declared_qualification",
        "published_qualification",
        "doctor_maturity",
        "repair_maturity",
        "container_maturity",
        "evidence_freshness",
        "diagnosis_latency_state",
        "engine_reachability",
        "boundary_proof",
        "certification_decision",
        "qualification_packet_ref",
        "latency_corpus_ref",
        "rollback_ref",
        "compatibility_ref",
        "support_export_ref",
        "note"
      ],
      "properties": {
        "profile_id": { "$ref": "#/$defs/non_empty_string" },
        "m5_profile": { "$ref": "#/$defs/m5_profile" },
        "declared_qualification": { "$ref": "#/$defs/qualification_class" },
        "published_qualification": { "$ref": "#/$defs/qualification_class" },
        "doctor_maturity": { "$ref": "#/$defs/qualification_class" },
        "repair_maturity": { "$ref": "#/$defs/qualification_class" },
        "container_maturity": { "$ref": "#/$defs/qualification_class" },
        "evidence_freshness": { "$ref": "#/$defs/certification_freshness" },
        "diagnosis_latency_state": { "$ref": "#/$defs/diagnosis_latency_state" },
        "engine_reachability": { "$ref": "#/$defs/engine_reachability" },
        "boundary_proof": { "$ref": "#/$defs/boundary_proof" },
        "certification_decision": { "$ref": "#/$defs/certification_decision" },
        "narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        },
        "qualification_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "latency_corpus_ref": { "$ref": "#/$defs/non_empty_string" },
        "rollback_ref": { "$ref": "#/$defs/non_empty_string" },
        "compatibility_ref": { "$ref": "#/$defs/non_empty_string" },
        "container_boundary_ref": { "type": ["string", "null"] },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_profiles",
        "profile_count",
        "certified_profiles",
        "provisional_profiles",
        "underqualified_profiles",
        "unsupported_profiles",
        "promotable_profiles",
        "narrowed_profiles",
        "failed_promotion_profiles",
        "current_freshness_profiles",
        "latency_red_profiles",
        "engine_blocked_profiles",
        "boundary_unverified_profiles",
        "profiles_with_narrowing_reasons"
      ],
      "properties": {
        "total_profiles": { "type": "integer", "minimum": 0 },
        "profile_count": { "type": "integer", "minimum": 0 },
        "certified_profiles": { "type": "integer", "minimum": 0 },
        "provisional_profiles": { "type": "integer", "minimum": 0 },
        "underqualified_profiles": { "type": "integer", "minimum": 0 },
        "unsupported_profiles": { "type": "integer", "minimum": 0 },
        "promotable_profiles": { "type": "integer", "minimum": 0 },
        "narrowed_profiles": { "type": "integer", "minimum": 0 },
        "failed_promotion_profiles": { "type": "integer", "minimum": 0 },
        "current_freshness_profiles": { "type": "integer", "minimum": 0 },
        "latency_red_profiles": { "type": "integer", "minimum": 0 },
        "engine_blocked_profiles": { "type": "integer", "minimum": 0 },
        "boundary_unverified_profiles": { "type": "integer", "minimum": 0 },
        "profiles_with_narrowing_reasons": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
