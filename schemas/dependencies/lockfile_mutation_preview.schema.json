{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/dependencies/lockfile_mutation_preview.schema.json",
  "title": "Aureline lockfile mutation preview boundary",
  "description": "Boundary schema for lockfile_mutation_preview payloads. Every package update, advisory remediation, automation or AI package action, and lockfile refresh that can write a lockfile must carry an attributable preview object before writing. Raw manifests, raw lockfiles, package-manager logs, registry URLs, tokens, and certificate material never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "preview_id",
    "action_class",
    "action_token",
    "actor_ref",
    "command_id_ref",
    "target_scope_ref",
    "affected_manifest_refs",
    "affected_manifest_paths",
    "affected_lockfile_refs",
    "affected_lockfile_paths",
    "manifest_delta_token",
    "lockfile_impact_token",
    "mutation_mode_token",
    "transitive_impact_token",
    "preview_created_before_write",
    "attributable_preview_object",
    "writes_allowed_after_preview",
    "source_package_operation_export_safe",
    "outcome_class",
    "outcome_token",
    "minted_at",
    "redaction_class",
    "redaction_token",
    "export_safe"
  ],
  "properties": {
    "record_kind": { "const": "lockfile_mutation_preview" },
    "schema_version": { "type": "integer", "const": 1 },
    "preview_id": { "$ref": "#/$defs/non_empty_string" },
    "action_class": { "$ref": "#/$defs/lockfile_preview_action_class" },
    "action_token": { "$ref": "#/$defs/lockfile_preview_action_class" },
    "package_operation_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
    "actor_ref": { "$ref": "#/$defs/non_empty_string" },
    "command_id_ref": { "$ref": "#/$defs/non_empty_string" },
    "target_scope_ref": { "$ref": "#/$defs/non_empty_string" },
    "affected_manifest_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "affected_manifest_paths": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "affected_lockfile_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "affected_lockfile_paths": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "manifest_delta_token": { "$ref": "#/$defs/non_empty_string" },
    "lockfile_impact_token": { "$ref": "#/$defs/non_empty_string" },
    "mutation_mode_token": { "$ref": "#/$defs/lockfile_mutation_mode" },
    "transitive_impact_token": { "$ref": "#/$defs/non_empty_string" },
    "rollback_checkpoint_refs": { "$ref": "#/$defs/ref_array" },
    "validation_task_tokens": { "$ref": "#/$defs/ref_array" },
    "preview_created_before_write": { "type": "boolean", "const": true },
    "attributable_preview_object": { "type": "boolean", "const": true },
    "writes_allowed_after_preview": { "type": "boolean" },
    "source_package_operation_export_safe": { "type": "boolean", "const": true },
    "outcome_class": { "$ref": "#/$defs/lockfile_preview_outcome_class" },
    "outcome_token": { "$ref": "#/$defs/lockfile_preview_outcome_class" },
    "minted_at": { "type": "string", "format": "date-time" },
    "redaction_class": { "$ref": "#/$defs/redaction_class" },
    "redaction_token": { "$ref": "#/$defs/redaction_class" },
    "export_safe": { "type": "boolean", "const": true }
  },
  "allOf": [
    {
      "description": "Mutating previews require at least one rollback/checkpoint boundary.",
      "if": {
        "properties": {
          "action_class": {
            "enum": [
              "package_install",
              "package_update",
              "package_remove",
              "advisory_remediation",
              "automation_or_ai_package_action",
              "lockfile_refresh"
            ]
          }
        },
        "required": ["action_class"]
      },
      "then": {
        "properties": { "rollback_checkpoint_refs": { "minItems": 1 } },
        "required": ["rollback_checkpoint_refs"]
      }
    },
    {
      "description": "Unknown mutation mode cannot be admitted to write.",
      "if": {
        "properties": { "mutation_mode_token": { "const": "blocked_unknown_requires_review" } },
        "required": ["mutation_mode_token"]
      },
      "then": {
        "properties": {
          "writes_allowed_after_preview": { "const": false },
          "outcome_class": { "const": "preview_blocked_unknown_impact" }
        }
      }
    }
  ],
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "nullable_non_empty_string": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/non_empty_string" }]
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "lockfile_preview_action_class": {
      "type": "string",
      "enum": [
        "package_install",
        "package_update",
        "package_remove",
        "advisory_remediation",
        "automation_or_ai_package_action",
        "lockfile_refresh",
        "audit_only_no_mutation"
      ]
    },
    "lockfile_mutation_mode": {
      "type": "string",
      "enum": [
        "inline_edit_round_trip_safe",
        "regenerate_and_review",
        "compare_only_inspect",
        "blocked_unknown_requires_review"
      ]
    },
    "lockfile_preview_outcome_class": {
      "type": "string",
      "enum": [
        "preview_ready_apply_pending",
        "preview_blocked_missing_checkpoint",
        "preview_blocked_unknown_impact",
        "preview_reported_read_only"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    }
  }
}
