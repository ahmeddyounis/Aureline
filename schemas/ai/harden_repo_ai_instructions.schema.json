{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/harden_repo_ai_instructions.schema.json",
  "title": "Aureline hardened repo-instruction record",
  "$comment": "Rust owner: aureline_ai::harden_repo_ai_instructions::RepoAiInstructionHardeningPacket.",
  "description": "Boundary schema for the metadata-only hardened repo-instruction record. The packet binds the repo-defined instruction rows (each pinned to its canonical instruction-following precedence rank and trust posture, with the closed rule that only a signed designated policy file may widen authority while a repo instruction bundle may narrow only), the policy-interaction rows that resolve every repo claim against higher authority strictly by precedence and name the typed prohibited case when a widening attempt is denied, the provider-neutral kill switch that fails closed across every provider/model/external-tool route at once and re-arms only behind an approval, the backout posture that preserves a rollback checkpoint and stays fully reversible, the cross-wedge command parity (palette, menu, keybinding, CLI/headless, deep link, automation recipe, AI assistant) over one shared command/preview/approval/result/rollback model, and exportable evidence/rollback lineage into one attributable artifact. It does not re-derive context-assembly, evidence, scoped-apply, or tainted-context truth; it references those lineages by id. It carries refs, state tokens, coarse classes, counts, and review labels only. It never carries raw instruction bodies, raw prompt bodies, source file bodies, provider payloads, endpoint URLs, credentials, signing-key material, raw token counts, exact prices, or billing-account ids. Adding a new enum member or a new optional field is additive-minor; repurposing an existing member is breaking and bumps schema_version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "display_label",
    "context_snapshot_ref",
    "evidence_packet_ref",
    "claimed_stable",
    "trust_state_token",
    "policy_epoch_ref",
    "instruction_rows",
    "policy_interaction_rows",
    "kill_switch",
    "backout",
    "surface_parity_rows",
    "evidence_export",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "harden_repo_ai_instructions" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "workflow_or_surface_id": { "type": "string", "minLength": 1 },
    "display_label": { "type": "string", "minLength": 1 },
    "context_snapshot_ref": { "type": "string", "minLength": 1 },
    "evidence_packet_ref": { "type": "string", "minLength": 1 },
    "claimed_stable": { "type": "boolean" },
    "trust_state_token": { "type": "string", "minLength": 1 },
    "policy_epoch_ref": { "type": "string", "minLength": 1 },
    "instruction_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/repo_instruction_row" }
    },
    "policy_interaction_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/policy_interaction_row" }
    },
    "kill_switch": { "$ref": "#/$defs/kill_switch_posture" },
    "backout": { "$ref": "#/$defs/backout_posture" },
    "surface_parity_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/command_surface_parity_row" }
    },
    "evidence_export": { "$ref": "#/$defs/evidence_export_block" },
    "source_contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "origin_locus_class": {
      "type": "string",
      "enum": [
        "local_in_process",
        "local_subprocess_same_device",
        "local_sandboxed_container_same_device",
        "remote_vendor_managed_service",
        "remote_self_hosted_service",
        "enterprise_gateway_brokered_service",
        "extension_provided_locus",
        "unknown_locus_must_be_disclosed"
      ]
    },
    "run_mode_class": {
      "type": "string",
      "enum": ["full_run", "explain_only", "local_only", "preview_only", "blocked"]
    },
    "repo_instruction_source_class": {
      "type": "string",
      "enum": [
        "designated_policy_file",
        "repo_instruction_bundle",
        "trusted_workspace_pinned_policy",
        "trusted_user_profile_policy",
        "unknown_repo_instruction_fail_closed"
      ]
    },
    "instruction_trust_posture_class": {
      "type": "string",
      "enum": [
        "signed_admin_authority",
        "trusted_first_party_authored",
        "workspace_pinned",
        "user_profile",
        "untrusted_must_fence"
      ]
    },
    "policy_interaction_outcome_class": {
      "type": "string",
      "enum": [
        "policy_overrides_repo",
        "repo_narrowing_admitted",
        "repo_widening_denied",
        "designated_policy_missing_fail_closed"
      ]
    },
    "repo_prohibited_case_class": {
      "type": "string",
      "enum": [
        "repo_text_widening_attempted",
        "repo_text_attempts_provider_route_change",
        "repo_text_attempts_trust_state_widening",
        "policy_file_self_modification_attempted",
        "model_self_authorization_attempted",
        "approval_path_bypass_attempted"
      ]
    },
    "kill_switch_scope_class": {
      "type": "string",
      "enum": [
        "all_providers_and_tools",
        "hosted_providers_only",
        "single_provider",
        "single_model"
      ]
    },
    "kill_switch_state_class": {
      "type": "string",
      "enum": ["disengaged_normal_routing", "engaged_fail_closed", "engaged_manual_hold"]
    },
    "backout_completeness_class": {
      "type": "string",
      "enum": [
        "full_backout_no_partial_writes",
        "partial_backout_needs_review",
        "backout_failed_escalated"
      ]
    },
    "command_surface_class": {
      "type": "string",
      "enum": [
        "palette_command",
        "menu_item",
        "keybinding",
        "cli_headless",
        "deep_link",
        "automation_recipe",
        "ai_assistant"
      ]
    },
    "surface_qualification_class": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "experimental", "unavailable"]
    },
    "repo_instruction_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instruction_ref",
        "source_path_label",
        "source_class",
        "trust_posture_class",
        "origin_locus_class",
        "precedence_rank",
        "claims_widening_authority",
        "may_narrow_authority",
        "policy_vetted",
        "fenced_to_data_only",
        "raw_body_forbidden",
        "user_visible_label"
      ],
      "properties": {
        "instruction_ref": { "type": "string", "minLength": 1 },
        "source_path_label": { "type": "string", "minLength": 1 },
        "source_class": { "$ref": "#/$defs/repo_instruction_source_class" },
        "trust_posture_class": { "$ref": "#/$defs/instruction_trust_posture_class" },
        "origin_locus_class": { "$ref": "#/$defs/origin_locus_class" },
        "precedence_rank": { "type": "integer", "minimum": 0 },
        "claims_widening_authority": { "type": "boolean" },
        "may_narrow_authority": { "type": "boolean" },
        "policy_vetted": { "type": "boolean" },
        "fenced_to_data_only": { "type": "boolean" },
        "signing_evidence_ref": { "type": "string", "minLength": 1 },
        "raw_body_forbidden": { "type": "boolean", "const": true },
        "user_visible_label": { "type": "string", "minLength": 1 }
      }
    },
    "policy_interaction_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interaction_ref",
        "instruction_ref",
        "repo_claim_label",
        "governing_authority_class",
        "outcome_class",
        "effective_mode_class",
        "auditable",
        "user_visible_label"
      ],
      "properties": {
        "interaction_ref": { "type": "string", "minLength": 1 },
        "instruction_ref": { "type": "string", "minLength": 1 },
        "repo_claim_label": { "type": "string", "minLength": 1 },
        "governing_authority_class": { "$ref": "#/$defs/repo_instruction_source_class" },
        "outcome_class": { "$ref": "#/$defs/policy_interaction_outcome_class" },
        "prohibited_case_class": { "$ref": "#/$defs/repo_prohibited_case_class" },
        "effective_mode_class": { "$ref": "#/$defs/run_mode_class" },
        "auditable": { "type": "boolean" },
        "user_visible_label": { "type": "string", "minLength": 1 }
      }
    },
    "kill_switch_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kill_switch_ref",
        "state_class",
        "scope_class",
        "provider_neutral",
        "fails_closed",
        "disables_hosted_routing",
        "disables_local_routing",
        "disables_external_tools",
        "re_arm_requires_approval",
        "effective_mode_when_engaged",
        "user_visible_label"
      ],
      "properties": {
        "kill_switch_ref": { "type": "string", "minLength": 1 },
        "state_class": { "$ref": "#/$defs/kill_switch_state_class" },
        "scope_class": { "$ref": "#/$defs/kill_switch_scope_class" },
        "provider_neutral": { "type": "boolean" },
        "fails_closed": { "type": "boolean" },
        "disables_hosted_routing": { "type": "boolean" },
        "disables_local_routing": { "type": "boolean" },
        "disables_external_tools": { "type": "boolean" },
        "re_arm_requires_approval": { "type": "boolean" },
        "effective_mode_when_engaged": { "$ref": "#/$defs/run_mode_class" },
        "user_visible_label": { "type": "string", "minLength": 1 }
      }
    },
    "backout_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backout_ref",
        "completeness_class",
        "rollback_checkpoint_ref",
        "reversible",
        "evidence_linked",
        "triggered_by_kill_switch",
        "user_visible_label"
      ],
      "properties": {
        "backout_ref": { "type": "string", "minLength": 1 },
        "completeness_class": { "$ref": "#/$defs/backout_completeness_class" },
        "rollback_checkpoint_ref": { "type": "string", "minLength": 1 },
        "reversible": { "type": "boolean" },
        "evidence_linked": { "type": "boolean" },
        "triggered_by_kill_switch": { "type": "boolean" },
        "user_visible_label": { "type": "string", "minLength": 1 }
      }
    },
    "command_surface_parity_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "descriptor_ref",
        "shares_command_descriptor",
        "shares_preview_model",
        "shares_approval_model",
        "shares_result_model",
        "shares_rollback_model",
        "honors_instruction_precedence",
        "obeys_kill_switch",
        "honors_backout_posture",
        "route_disclosed",
        "policy_checked",
        "reachable",
        "qualification",
        "claimed_stable"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/command_surface_class" },
        "descriptor_ref": { "type": "string", "minLength": 1 },
        "shares_command_descriptor": { "type": "boolean" },
        "shares_preview_model": { "type": "boolean" },
        "shares_approval_model": { "type": "boolean" },
        "shares_result_model": { "type": "boolean" },
        "shares_rollback_model": { "type": "boolean" },
        "honors_instruction_precedence": { "type": "boolean" },
        "obeys_kill_switch": { "type": "boolean" },
        "honors_backout_posture": { "type": "boolean" },
        "route_disclosed": { "type": "boolean" },
        "policy_checked": { "type": "boolean" },
        "reachable": { "type": "boolean" },
        "qualification": { "$ref": "#/$defs/surface_qualification_class" },
        "claimed_stable": { "type": "boolean" }
      }
    },
    "evidence_export_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "json_export_ref",
        "markdown_summary_ref",
        "admin_inspector_ref",
        "support_export_ref",
        "rollback_lineage_refs",
        "export_lineage_refs"
      ],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "json_export_ref": { "type": "string", "minLength": 1 },
        "markdown_summary_ref": { "type": "string", "minLength": 1 },
        "admin_inspector_ref": { "type": "string", "minLength": 1 },
        "support_export_ref": { "type": "string", "minLength": 1 },
        "rollback_lineage_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "export_lineage_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
