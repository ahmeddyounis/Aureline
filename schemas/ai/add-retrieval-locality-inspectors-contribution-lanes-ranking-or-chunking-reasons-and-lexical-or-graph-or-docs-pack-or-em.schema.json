{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/add-retrieval-locality-inspectors-contribution-lanes-ranking-or-chunking-reasons-and-lexical-or-graph-or-docs-pack-or-em.schema.json",
  "title": "Aureline retrieval-locality inspector with labeled contribution lanes and ranking-or-chunking reasons",
  "description": "Export-safe packet that inspects a produced recall result across search, docs recall, and AI context packs. Each surface row labels its contribution lanes (lexical, graph, docs-pack, embedding, provider-overlay), each lane's contribution state, ranking-or-chunking reason, retrieval locality, and generation, plus the surface's hidden-scope count, degraded lanes, provider-overlay posture, completeness claim, and replay/export label parity. Raw query or document bodies, raw embeddings, raw provider payloads, credentials, exact scores, and exact token or cost amounts never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "inspector_label",
    "surface_rows",
    "guardrails",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "retrieval_locality_inspector"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "inspector_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "surface_rows": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/surface_row"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "surface": {
      "type": "string",
      "enum": [
        "search",
        "docs_recall",
        "ai_context_pack"
      ]
    },
    "contribution_lane_class": {
      "type": "string",
      "enum": [
        "lexical_keyword",
        "graph_traversal",
        "docs_pack",
        "embedding_vector",
        "provider_overlay"
      ]
    },
    "contribution_state": {
      "type": "string",
      "enum": [
        "contributed",
        "degraded",
        "empty",
        "suppressed"
      ]
    },
    "selection_reason_kind": {
      "type": "string",
      "enum": [
        "ranking",
        "chunking",
        "overlay",
        "not_applicable"
      ]
    },
    "selection_reason_class": {
      "type": "string",
      "enum": [
        "rank_by_semantic_similarity",
        "rank_by_lexical_score",
        "rank_by_graph_proximity",
        "rank_by_hybrid_fusion",
        "chunk_by_semantic_boundary",
        "chunk_by_doc_structure",
        "chunk_by_fixed_window",
        "provider_overlay_merge",
        "not_applicable"
      ]
    },
    "retrieval_locality_class": {
      "type": "string",
      "enum": [
        "local_device_only",
        "workspace_local",
        "tenant_region_pinned",
        "managed_hosted_region_pinned",
        "provider_remote"
      ]
    },
    "retrieval_generation_state": {
      "type": "string",
      "enum": [
        "current",
        "recomputing",
        "stale",
        "mixed_generation_labeled"
      ]
    },
    "completeness_class": {
      "type": "string",
      "enum": [
        "complete",
        "partial_hidden_scope",
        "degraded_subset"
      ]
    },
    "provider_overlay_posture": {
      "type": "string",
      "enum": [
        "no_overlay",
        "local_only_no_overlay",
        "overlay_disclosed",
        "overlay_degraded"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "search_results",
        "docs_companion",
        "composer_context_pack",
        "diagnostics",
        "support_export",
        "replay_packet"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "lane_degraded",
        "mixed_generation_unlabeled",
        "hidden_scope_undisclosed",
        "provider_overlay_undisclosed",
        "replay_label_drift",
        "locality_unavailable",
        "proof_stale"
      ]
    },
    "contribution_lane_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane",
        "state",
        "selection_reason_kind",
        "selection_reason",
        "locality",
        "generation_state",
        "reason_summary"
      ],
      "properties": {
        "lane": {
          "$ref": "#/$defs/contribution_lane_class"
        },
        "state": {
          "$ref": "#/$defs/contribution_state"
        },
        "selection_reason_kind": {
          "$ref": "#/$defs/selection_reason_kind"
        },
        "selection_reason": {
          "$ref": "#/$defs/selection_reason_class"
        },
        "locality": {
          "$ref": "#/$defs/retrieval_locality_class"
        },
        "generation_state": {
          "$ref": "#/$defs/retrieval_generation_state"
        },
        "reason_summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "scope_summary",
        "contribution_lanes",
        "hidden_scope_count",
        "degraded_lanes",
        "provider_overlay_posture",
        "completeness_claim",
        "replay_label_parity",
        "downgrade_triggers",
        "source_contract_refs",
        "consumer_surfaces"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/surface"
        },
        "scope_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "contribution_lanes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/contribution_lane_row"
          }
        },
        "hidden_scope_count": {
          "type": "integer",
          "minimum": 0
        },
        "degraded_lanes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contribution_lane_class"
          }
        },
        "provider_overlay_posture": {
          "$ref": "#/$defs/provider_overlay_posture"
        },
        "completeness_claim": {
          "$ref": "#/$defs/completeness_class"
        },
        "replay_label_parity": {
          "type": "boolean"
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/consumer_surface"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_cross_workspace_recall_by_default",
        "no_cross_tenant_recall_by_default",
        "mixed_generation_labeled_never_masquerades",
        "degraded_lanes_never_implied_complete",
        "provider_overlay_always_disclosed",
        "replay_preserves_lane_and_locality_labels",
        "hidden_scope_counts_disclosed"
      ],
      "properties": {
        "no_cross_workspace_recall_by_default": {
          "type": "boolean",
          "const": true
        },
        "no_cross_tenant_recall_by_default": {
          "type": "boolean",
          "const": true
        },
        "mixed_generation_labeled_never_masquerades": {
          "type": "boolean",
          "const": true
        },
        "degraded_lanes_never_implied_complete": {
          "type": "boolean",
          "const": true
        },
        "provider_overlay_always_disclosed": {
          "type": "boolean",
          "const": true
        },
        "replay_preserves_lane_and_locality_labels": {
          "type": "boolean",
          "const": true
        },
        "hidden_scope_counts_disclosed": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "search_labels_all_contribution_lanes",
        "docs_recall_labels_lanes_and_locality",
        "context_pack_labels_lanes_and_ranking_or_chunking",
        "diagnostics_shows_hidden_scope_and_degraded",
        "support_export_preserves_labels",
        "replay_preserves_labels",
        "unqualified_completeness_labeled"
      ],
      "properties": {
        "search_labels_all_contribution_lanes": {
          "type": "boolean",
          "const": true
        },
        "docs_recall_labels_lanes_and_locality": {
          "type": "boolean",
          "const": true
        },
        "context_pack_labels_lanes_and_ranking_or_chunking": {
          "type": "boolean",
          "const": true
        },
        "diagnostics_shows_hidden_scope_and_degraded": {
          "type": "boolean",
          "const": true
        },
        "support_export_preserves_labels": {
          "type": "boolean",
          "const": true
        },
        "replay_preserves_labels": {
          "type": "boolean",
          "const": true
        },
        "unqualified_completeness_labeled": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
