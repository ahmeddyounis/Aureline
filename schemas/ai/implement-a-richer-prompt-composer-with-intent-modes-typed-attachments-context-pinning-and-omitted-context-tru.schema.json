{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/implement-a-richer-prompt-composer-with-intent-modes-typed-attachments-context-pinning-and-omitted-context-tru.schema.json",
  "title": "Aureline richer M5 prompt composer with intent modes, typed attachments, context pinning, and omitted-context truth",
  "description": "Export-safe packet unifying the M3 beta conformance and M4 stable stabilization lanes into one richer M5 prompt-composer packet. It adds mode-specific behavior constraints, attachment semantic roles and provenance chains, pinning policies with auto-refresh and stale-detection, and omitted-context restoration paths. Raw prompt bodies, raw diffs, raw provider payloads, credentials, exact token counts, and exact cost amounts never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "display_label",
    "composer_conformance_packet_ref",
    "composer_stabilization_packet_ref",
    "composer_context_snapshot_ref",
    "composer_session_ref",
    "composer_draft_ref",
    "thread_header",
    "intent_row",
    "attachment_rows",
    "pinned_context_rows",
    "omitted_context_rows",
    "budget_strip",
    "forked_thread_lineage",
    "surface_consistency_rows",
    "evidence_lineage",
    "source_contract_refs",
    "json_export_ref",
    "markdown_summary_ref",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "richer_prompt_composer_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "workflow_or_surface_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "display_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "composer_conformance_packet_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "composer_stabilization_packet_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "composer_context_snapshot_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "composer_session_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "composer_draft_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "thread_header": {
      "$ref": "#/$defs/richer_thread_header"
    },
    "intent_row": {
      "$ref": "#/$defs/richer_intent_mode_row"
    },
    "attachment_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/richer_attachment_row"
      }
    },
    "pinned_context_rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/richer_pinned_context_row"
      }
    },
    "omitted_context_rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/richer_omitted_context_row"
      }
    },
    "budget_strip": {
      "$ref": "#/$defs/richer_budget_strip"
    },
    "context_drift_banners": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/context_drift_banner"
      }
    },
    "compare_answer_rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/compare_answer_row"
      }
    },
    "forked_thread_lineage": {
      "$ref": "#/$defs/forked_thread_lineage"
    },
    "surface_consistency_rows": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/richer_surface_consistency_row"
      }
    },
    "evidence_lineage": {
      "$ref": "#/$defs/evidence_lineage"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "json_export_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "markdown_summary_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "intent_mode_class": {
      "type": "string",
      "enum": ["ask", "explain", "plan", "draft_patch", "review_diff", "generate_tests", "run_tool_with_approval"]
    },
    "execution_boundary_class": {
      "type": "string",
      "enum": ["local_only", "managed_hosted", "enterprise_gateway", "connected_provider", "dispatch_blocked"]
    },
    "budget_pressure_class": {
      "type": "string",
      "enum": ["within_budget", "warning", "overflow"]
    },
    "context_item_state_class": {
      "type": "string",
      "enum": ["included", "pinned", "omitted", "blocked", "stale", "tainted", "summarized", "trimmed", "not_requested"]
    },
    "context_freshness_class": {
      "type": "string",
      "enum": ["authoritative_live", "warm_cached", "stale", "unverified"]
    },
    "context_omission_reason_class": {
      "type": "string",
      "enum": ["budget", "policy", "duplicate", "stale", "blocked", "tainted", "scope_excluded", "citation_anchor_unavailable"]
    },
    "source_class": {
      "type": "string",
      "enum": ["workspace_file_slice", "workspace_symbol", "workspace_buffer_slice", "workspace_search_result", "workspace_diagnostics", "docs_pack_excerpt", "terminal_transcript_excerpt", "user_supplied_text", "user_supplied_file", "citation_anchor_quote"]
    },
    "trust_posture": {
      "type": "string",
      "enum": ["trusted_first_party", "reviewed_derived", "unreviewed_derived", "untrusted_user_supplied", "untrusted_external", "untrusted_extension_proposed", "policy_quarantined"]
    },
    "prompt_budget_action_class": {
      "type": "string",
      "enum": ["include_raw", "pin_keep", "omit", "summarize", "trim", "route_switch", "block"]
    },
    "prompt_composer_safe_fallback_class": {
      "type": "string",
      "enum": ["manual_edit_and_search", "local_only_review", "cli_headless_path", "deferred_review_export", "ai_only_dead_end"]
    },
    "composer_surface_class": {
      "type": "string",
      "enum": ["editor_attached", "sidebar", "detached"]
    },
    "thread_retention_mode_class": {
      "type": "string",
      "enum": ["local_only", "repo_shared", "org_shared", "ephemeral_no_retention"]
    },
    "retention_locus_class": {
      "type": "string",
      "enum": ["local_device", "repo_scoped", "org_scoped"]
    },
    "reuse_audience_class": {
      "type": "string",
      "enum": ["only_me", "repo_collaborators", "org_members", "nobody"]
    },
    "drift_source_class": {
      "type": "string",
      "enum": ["on_disk", "in_git", "live_state", "docs_source", "test_state"]
    },
    "pinned_freshness_state_class": {
      "type": "string",
      "enum": ["pinned_fresh", "pinned_but_stale", "pinned_refreshing"]
    },
    "stable_attachment_source_class": {
      "type": "string",
      "enum": ["workspace_file", "symbol", "docs_reference", "diagnostic", "test_result", "terminal_tool_output", "external_text"]
    },
    "intent_mode_behavior_constraint": {
      "type": "string",
      "enum": ["review_before_apply", "explicit_tool_approval", "read_only_context", "generated_tests_not_coverage_proof", "draft_only_no_in_place_apply", "requires_scoped_apply_hardening", "requires_evidence_packet"]
    },
    "attachment_semantic_role_class": {
      "type": "string",
      "enum": ["primary_context", "reference_material", "instruction_source", "test_fixture", "diagnostic_output", "generated_artifact", "external_reference"]
    },
    "attachment_provenance_class": {
      "type": "string",
      "enum": ["direct_workspace", "retrieved_query", "external_import", "ai_generated", "docs_knowledge_pack", "runtime_capture"]
    },
    "pin_policy_class": {
      "type": "string",
      "enum": ["manual_only", "auto_refresh_on_change", "auto_refresh_on_interval", "stale_after_duration"]
    },
    "pin_auto_refresh_class": {
      "type": "string",
      "enum": ["immediate", "deferred", "none"]
    },
    "omitted_context_restoration_class": {
      "type": "string",
      "enum": ["one_click_restore", "requires_re_review", "permanently_excluded", "session_only_excluded"]
    },
    "exclusion_freshness_class": {
      "type": "string",
      "enum": ["reason_still_valid", "reason_expired", "condition_changed"]
    },
    "prompt_evidence_packet_class": {
      "type": "string",
      "enum": ["inline_stub", "operator_packet", "support_packet", "compliance_audit_packet"]
    },
    "remember_preview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["retained_summary_label", "retention_locus_class", "reuse_audience_class", "memory_class_token", "preview_action_ref"],
      "properties": {
        "retained_summary_label": { "$ref": "#/$defs/non_empty_string" },
        "retention_locus_class": { "$ref": "#/$defs/retention_locus_class" },
        "reuse_audience_class": { "$ref": "#/$defs/reuse_audience_class" },
        "memory_class_token": { "$ref": "#/$defs/non_empty_string" },
        "preview_action_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "richer_thread_header": {
      "type": "object",
      "additionalProperties": false,
      "required": ["thread_id", "current_scope_label", "provider_label", "model_label", "execution_boundary_class", "retention_mode_class", "memory_class_token", "save_memory_action_ref", "delete_action_ref", "export_action_ref", "remember_preview"],
      "properties": {
        "thread_id": { "$ref": "#/$defs/non_empty_string" },
        "current_scope_label": { "$ref": "#/$defs/non_empty_string" },
        "provider_label": { "$ref": "#/$defs/non_empty_string" },
        "model_label": { "$ref": "#/$defs/non_empty_string" },
        "execution_boundary_class": { "$ref": "#/$defs/execution_boundary_class" },
        "retention_mode_class": { "$ref": "#/$defs/thread_retention_mode_class" },
        "memory_class_token": { "$ref": "#/$defs/non_empty_string" },
        "save_memory_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "delete_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "export_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "remember_preview": { "$ref": "#/$defs/remember_preview" }
      }
    },
    "richer_intent_mode_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode_class", "current_scope_label", "execution_boundary_class", "behavior_constraints", "required_tool_pack_refs", "approval_posture_class"],
      "properties": {
        "mode_class": { "$ref": "#/$defs/intent_mode_class" },
        "current_scope_label": { "$ref": "#/$defs/non_empty_string" },
        "execution_boundary_class": { "$ref": "#/$defs/execution_boundary_class" },
        "action_identity_ref": { "type": ["string", "null"] },
        "behavior_constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/intent_mode_behavior_constraint" }
        },
        "required_tool_pack_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "approval_posture_class": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "richer_attachment_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attachment_id", "stable_object_ref", "origin_label", "source_class", "trust_posture", "freshness_class", "semantic_role", "provenance_class", "mode_relevance", "context_state", "display_label", "estimated_byte_size", "preview_action_ref", "open_action_ref", "remove_action_ref", "keyboard_reachable", "screen_reader_label"],
      "properties": {
        "attachment_id": { "$ref": "#/$defs/non_empty_string" },
        "stable_object_ref": { "$ref": "#/$defs/non_empty_string" },
        "origin_label": { "$ref": "#/$defs/non_empty_string" },
        "source_class": { "$ref": "#/$defs/stable_attachment_source_class" },
        "trust_posture": { "$ref": "#/$defs/trust_posture" },
        "freshness_class": { "$ref": "#/$defs/context_freshness_class" },
        "semantic_role": { "$ref": "#/$defs/attachment_semantic_role_class" },
        "provenance_class": { "$ref": "#/$defs/attachment_provenance_class" },
        "mode_relevance": {
          "type": "array",
          "items": { "$ref": "#/$defs/intent_mode_class" }
        },
        "context_state": { "$ref": "#/$defs/context_item_state_class" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "estimated_byte_size": { "type": "integer", "minimum": 0 },
        "preview_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "open_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "remove_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "keyboard_reachable": { "type": "boolean" },
        "screen_reader_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "richer_pinned_context_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pin_id", "stable_object_ref", "display_label", "freshness_state", "pin_policy", "auto_refresh", "refresh_action_ref", "remove_action_ref", "blocks_send_until_resolved", "keyboard_reachable"],
      "properties": {
        "pin_id": { "$ref": "#/$defs/non_empty_string" },
        "stable_object_ref": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "freshness_state": { "$ref": "#/$defs/pinned_freshness_state_class" },
        "drift_source": { "$ref": "#/$defs/drift_source_class" },
        "pin_policy": { "$ref": "#/$defs/pin_policy_class" },
        "auto_refresh": { "$ref": "#/$defs/pin_auto_refresh_class" },
        "stale_after_duration_seconds": { "type": ["integer", "null"] },
        "refresh_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "remove_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "blocks_send_until_resolved": { "type": "boolean" },
        "keyboard_reachable": { "type": "boolean" }
      }
    },
    "richer_omitted_context_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_ref", "source_class", "omission_reason_class", "restoration_class", "exclusion_freshness", "inspectable_after_send", "inspect_action_ref", "restoration_action_ref", "replay_explains_exclusion", "keyboard_reachable"],
      "properties": {
        "source_ref": { "$ref": "#/$defs/non_empty_string" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "omission_reason_class": { "$ref": "#/$defs/context_omission_reason_class" },
        "restoration_class": { "$ref": "#/$defs/omitted_context_restoration_class" },
        "exclusion_freshness": { "$ref": "#/$defs/exclusion_freshness_class" },
        "inspectable_after_send": { "type": "boolean" },
        "inspect_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "restoration_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "replay_explains_exclusion": { "type": "boolean" },
        "keyboard_reachable": { "type": "boolean" }
      }
    },
    "richer_budget_decision_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "source_ref", "source_class", "context_state", "action_class", "estimated_byte_size", "driven_by_pin_policy"],
      "properties": {
        "decision_id": { "$ref": "#/$defs/non_empty_string" },
        "source_ref": { "$ref": "#/$defs/non_empty_string" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "context_state": { "$ref": "#/$defs/context_item_state_class" },
        "action_class": { "$ref": "#/$defs/prompt_budget_action_class" },
        "reason_token": { "type": ["string", "null"] },
        "estimated_byte_size": { "type": "integer", "minimum": 0 },
        "route_receipt_ref": { "type": ["string", "null"] },
        "driven_by_pin_policy": { "type": "boolean" }
      }
    },
    "richer_budget_strip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["aggregate_byte_estimate", "budget_byte_ceiling", "pressure_class", "included_context_group_tokens", "omitted_or_trimmed_group_tokens", "decision_rows", "safe_fallback_class", "explanation_label"],
      "properties": {
        "aggregate_byte_estimate": { "type": "integer", "minimum": 0 },
        "budget_byte_ceiling": { "type": "integer", "minimum": 0 },
        "pressure_class": { "$ref": "#/$defs/budget_pressure_class" },
        "included_context_group_tokens": { "type": "array", "items": { "type": "string" } },
        "omitted_or_trimmed_group_tokens": { "type": "array", "items": { "type": "string" } },
        "decision_rows": { "type": "array", "items": { "$ref": "#/$defs/richer_budget_decision_row" } },
        "safe_fallback_class": { "$ref": "#/$defs/prompt_composer_safe_fallback_class" },
        "explanation_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "context_drift_banner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["banner_id", "drift_source", "affected_object_ref", "previously_reviewed_snapshot_ref", "requires_rereview", "explanation_label", "keyboard_reachable", "screen_reader_label"],
      "properties": {
        "banner_id": { "$ref": "#/$defs/non_empty_string" },
        "drift_source": { "$ref": "#/$defs/drift_source_class" },
        "affected_object_ref": { "$ref": "#/$defs/non_empty_string" },
        "previously_reviewed_snapshot_ref": { "$ref": "#/$defs/non_empty_string" },
        "requires_rereview": { "type": "boolean" },
        "explanation_label": { "$ref": "#/$defs/non_empty_string" },
        "keyboard_reachable": { "type": "boolean" },
        "screen_reader_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "compare_answer_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["comparison_id", "left_run_ref", "right_run_ref", "left_context_snapshot_ref", "right_context_snapshot_ref", "context_parity_class", "hidden_drift_warning"],
      "properties": {
        "comparison_id": { "$ref": "#/$defs/non_empty_string" },
        "left_run_ref": { "$ref": "#/$defs/non_empty_string" },
        "right_run_ref": { "$ref": "#/$defs/non_empty_string" },
        "left_context_snapshot_ref": { "$ref": "#/$defs/non_empty_string" },
        "right_context_snapshot_ref": { "$ref": "#/$defs/non_empty_string" },
        "context_parity_class": {
          "type": "string",
          "enum": ["same_context_snapshot", "different_context_drift", "different_context_intentional"]
        },
        "provider_model_delta_label": { "type": ["string", "null"] },
        "instruction_stack_delta_label": { "type": ["string", "null"] },
        "hidden_drift_warning": { "type": "boolean" }
      }
    },
    "forked_thread_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["thread_id", "is_forked"],
      "properties": {
        "thread_id": { "$ref": "#/$defs/non_empty_string" },
        "is_forked": { "type": "boolean" },
        "parent_thread_ref": { "type": ["string", "null"] },
        "parent_run_ref": { "type": ["string", "null"] },
        "inherited_context_snapshot_ref": { "type": ["string", "null"] },
        "divergence_point_ref": { "type": ["string", "null"] }
      }
    },
    "richer_surface_consistency_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_class", "attachment_pills_keyboard_reachable", "mention_rows_screen_reader_describable", "omitted_context_review_reachable", "pinned_context_review_reachable", "context_drift_banner_reachable", "intent_mode_constraints_visible"],
      "properties": {
        "surface_class": { "$ref": "#/$defs/composer_surface_class" },
        "attachment_pills_keyboard_reachable": { "type": "boolean" },
        "mention_rows_screen_reader_describable": { "type": "boolean" },
        "omitted_context_review_reachable": { "type": "boolean" },
        "pinned_context_review_reachable": { "type": "boolean" },
        "context_drift_banner_reachable": { "type": "boolean" },
        "intent_mode_constraints_visible": { "type": "boolean" }
      }
    },
    "evidence_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "composer_session_ref", "turn_draft_ref", "composer_context_snapshot_ref", "packet_classes", "route_receipt_ref", "spend_receipt_ref", "redaction_manifest_ref", "replay_lineage_ref", "operator_packet_ref", "support_packet_ref", "compliance_packet_ref"],
      "properties": {
        "evidence_id": { "$ref": "#/$defs/non_empty_string" },
        "composer_session_ref": { "$ref": "#/$defs/non_empty_string" },
        "turn_draft_ref": { "$ref": "#/$defs/non_empty_string" },
        "composer_context_snapshot_ref": { "$ref": "#/$defs/non_empty_string" },
        "packet_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/prompt_evidence_packet_class" }
        },
        "route_receipt_ref": { "$ref": "#/$defs/non_empty_string" },
        "spend_receipt_ref": { "$ref": "#/$defs/non_empty_string" },
        "redaction_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "replay_lineage_ref": { "$ref": "#/$defs/non_empty_string" },
        "operator_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "compliance_packet_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  }
}
