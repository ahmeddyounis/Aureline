{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/certify-ai-memory-classes-prompt-result-cache-and-session-artifact-governance-hybrid-retrieval-or-embedding-locality-and.schema.json",
  "title": "Aureline M5 AI/docs/recall row certification of memory classes, prompt-result-cache and session-artifact governance, hybrid retrieval or embedding locality, and spend-receipt truth",
  "description": "Export-safe packet binding every claimed M5 AI/docs/recall row to four interlocking proof pillars: a memory-class proof, a prompt-result-cache and session-artifact governance proof, a hybrid-retrieval or embedding-locality proof, and a spend-receipt proof. Each pillar proof declares whether its checked-in proof is current, where the data lived, whether a durable artifact declares retention/delete/export posture, and whether a mixed retrieval generation is labeled. A claimed row whose any required pillar is not current auto-narrows to an effective qualification strictly below its claim, with a recorded narrowing trigger and a precise degraded label. The packet reuses the frozen M5 AI workflow matrix qualification and downgrade vocabularies and binds every pillar to the canonical source schema of its first-consumer packet. Raw prompt bodies, cached result bodies, raw embeddings, raw provider payloads, credentials, raw endpoint URLs, exact token counts, and exact cost amounts never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "certification_label",
    "rows",
    "guardrails",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "certify_ai_memory_classes_prompt_result_cache_and_session_artifact_governance_hybrid_retrieval_or_embedding_locality_and"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "certification_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/certified_recall_row"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "recall_surface": {
      "type": "string",
      "enum": [
        "composer_inline_assist",
        "patch_review",
        "branch_worktree_agent",
        "docs_browser_recall",
        "code_understanding",
        "semantic_hybrid_search",
        "managed_offline_report",
        "support_export"
      ]
    },
    "certification_pillar": {
      "type": "string",
      "enum": [
        "memory_class",
        "prompt_cache_session_artifact",
        "hybrid_retrieval_locality",
        "spend_receipt"
      ]
    },
    "proof_state": {
      "type": "string",
      "enum": [
        "current",
        "stale",
        "missing"
      ]
    },
    "locality_class": {
      "type": "string",
      "enum": [
        "local_on_device",
        "managed_hosted",
        "mirrored_offline",
        "mixed_labeled"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "provider_unavailable",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "pillar_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pillar",
        "proof_state",
        "canonical_schema_ref",
        "locality",
        "locality_disclosed",
        "durable",
        "retention_export_declared",
        "mixed_generation_present",
        "mixed_generation_labeled",
        "evidence_refs"
      ],
      "properties": {
        "pillar": {
          "$ref": "#/$defs/certification_pillar"
        },
        "proof_state": {
          "$ref": "#/$defs/proof_state"
        },
        "canonical_schema_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "locality": {
          "$ref": "#/$defs/locality_class"
        },
        "locality_disclosed": {
          "type": "boolean"
        },
        "durable": {
          "type": "boolean"
        },
        "retention_export_declared": {
          "type": "boolean"
        },
        "mixed_generation_present": {
          "type": "boolean"
        },
        "mixed_generation_labeled": {
          "type": "boolean"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "certified_recall_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "surface",
        "label_summary",
        "claimed_qualification",
        "effective_qualification",
        "pillar_proofs",
        "evidence_refs",
        "source_contract_refs"
      ],
      "properties": {
        "row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface": {
          "$ref": "#/$defs/recall_surface"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "effective_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "pillar_proofs": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/pillar_proof"
          }
        },
        "narrow_trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "degraded_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_default_cross_scope_recall",
        "prompt_result_caches_are_not_shadow_telemetry",
        "mixed_generation_always_labeled",
        "managed_locality_always_disclosed",
        "every_durable_artifact_declares_retention_export",
        "spend_route_failures_keep_precise_fallback",
        "rows_auto_narrow_on_stale_proof"
      ],
      "properties": {
        "no_default_cross_scope_recall": {
          "type": "boolean"
        },
        "prompt_result_caches_are_not_shadow_telemetry": {
          "type": "boolean"
        },
        "mixed_generation_always_labeled": {
          "type": "boolean"
        },
        "managed_locality_always_disclosed": {
          "type": "boolean"
        },
        "every_durable_artifact_declares_retention_export": {
          "type": "boolean"
        },
        "spend_route_failures_keep_precise_fallback": {
          "type": "boolean"
        },
        "rows_auto_narrow_on_stale_proof": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_certification",
        "docs_help_ingests_certification",
        "diagnostics_ingests_certification",
        "release_ingests_certification",
        "narrowed_rows_labeled_below_current"
      ],
      "properties": {
        "product_ingests_certification": {
          "type": "boolean"
        },
        "docs_help_ingests_certification": {
          "type": "boolean"
        },
        "diagnostics_ingests_certification": {
          "type": "boolean"
        },
        "release_ingests_certification": {
          "type": "boolean"
        },
        "narrowed_rows_labeled_below_current": {
          "type": "boolean"
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
