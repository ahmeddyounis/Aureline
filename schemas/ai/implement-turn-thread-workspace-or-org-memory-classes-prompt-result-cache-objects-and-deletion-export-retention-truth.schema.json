{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/implement-turn-thread-workspace-or-org-memory-classes-prompt-result-cache-objects-and-deletion-export-retention-truth.schema.json",
  "title": "Aureline materialized turn/thread/workspace/org AI memory classes, prompt-result-cache objects, and deletion/export/retention truth",
  "description": "Export-safe packet materializing the individual AI memory objects the frozen recall matrix qualifies. Each object binds its scope (turn, thread, workspace, org), artifact class (ephemeral turn state, evictable derived cache, prompt-result cache, reusable semantic memory, durable saved memory), retention, delete and export posture, locality, invalidation classes, availability, consumer flows, and evidence refs. Raw prompt bodies, cached result bodies, raw embeddings, raw provider payloads, credentials, exact token counts, and exact cost amounts never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "materialization_label",
    "memory_objects",
    "guardrails",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "implement_turn_thread_workspace_or_org_memory_classes_prompt_result_cache_objects_and_deletion_export_retention_truth"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "materialization_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "memory_objects": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/memory_object"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "scope": {
      "type": "string",
      "enum": [
        "turn",
        "thread",
        "workspace",
        "org"
      ]
    },
    "artifact_class": {
      "type": "string",
      "enum": [
        "ephemeral_turn_state",
        "evictable_derived_cache",
        "prompt_result_cache",
        "reusable_semantic_memory",
        "durable_saved_memory"
      ]
    },
    "retention_class": {
      "type": "string",
      "enum": [
        "session_only",
        "ttl_bounded",
        "until_manual_evict",
        "until_user_revoked",
        "evidence_retention_hold",
        "durable_until_deleted"
      ]
    },
    "delete_export_posture": {
      "type": "string",
      "enum": [
        "user_scoped",
        "workspace_scoped",
        "tenant_scoped",
        "org_scoped",
        "ephemeral_auto_expire",
        "not_applicable"
      ]
    },
    "locality_class": {
      "type": "string",
      "enum": [
        "local_device_only",
        "workspace_local",
        "tenant_region_pinned",
        "managed_hosted_region_pinned"
      ]
    },
    "invalidation_class": {
      "type": "string",
      "enum": [
        "ttl_expiry",
        "content_hash_key",
        "policy_epoch_bump",
        "trust_narrowing",
        "embedding_generation_bump",
        "scope_revocation",
        "manual_purge"
      ]
    },
    "consumer_flow": {
      "type": "string",
      "enum": [
        "composer_assist",
        "patch_review",
        "docs_browser_recall",
        "branch_agent",
        "support_export"
      ]
    },
    "availability_class": {
      "type": "string",
      "enum": [
        "available",
        "policy_blocked_retention_gate",
        "policy_blocked_region_gate",
        "unavailable_unsupported_backend",
        "narrowed_stale_proof",
        "revoked_by_user",
        "expired_auto_evicted"
      ]
    },
    "memory_object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "scope",
        "artifact_class",
        "label_summary",
        "retention",
        "delete_posture",
        "export_posture",
        "locality",
        "invalidation_classes",
        "availability",
        "consumer_flows",
        "evidence_refs",
        "source_contract_refs"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "artifact_class": {
          "$ref": "#/$defs/artifact_class"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "retention": {
          "$ref": "#/$defs/retention_class"
        },
        "delete_posture": {
          "$ref": "#/$defs/delete_export_posture"
        },
        "export_posture": {
          "$ref": "#/$defs/delete_export_posture"
        },
        "locality": {
          "$ref": "#/$defs/locality_class"
        },
        "invalidation_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/invalidation_class"
          }
        },
        "availability": {
          "$ref": "#/$defs/availability_class"
        },
        "degraded_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "consumer_flows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/consumer_flow"
          }
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_cross_workspace_memory_by_default",
        "no_cross_tenant_memory_by_default",
        "prompt_result_caches_not_shadow_telemetry",
        "every_durable_class_declares_retention_delete_export",
        "ephemeral_state_separated_from_durable_memory",
        "missing_classes_degrade_to_precise_labels",
        "mixed_retrieval_generations_labeled"
      ],
      "properties": {
        "no_cross_workspace_memory_by_default": {
          "type": "boolean",
          "const": true
        },
        "no_cross_tenant_memory_by_default": {
          "type": "boolean",
          "const": true
        },
        "prompt_result_caches_not_shadow_telemetry": {
          "type": "boolean",
          "const": true
        },
        "every_durable_class_declares_retention_delete_export": {
          "type": "boolean",
          "const": true
        },
        "ephemeral_state_separated_from_durable_memory": {
          "type": "boolean",
          "const": true
        },
        "missing_classes_degrade_to_precise_labels": {
          "type": "boolean",
          "const": true
        },
        "mixed_retrieval_generations_labeled": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "composer_shows_memory_classes",
        "review_shows_memory_classes",
        "docs_browser_shows_memory_classes",
        "agent_flow_shows_memory_classes",
        "support_export_preserves_class_distinctions",
        "unavailable_classes_labeled_precisely"
      ],
      "properties": {
        "composer_shows_memory_classes": {
          "type": "boolean",
          "const": true
        },
        "review_shows_memory_classes": {
          "type": "boolean",
          "const": true
        },
        "docs_browser_shows_memory_classes": {
          "type": "boolean",
          "const": true
        },
        "agent_flow_shows_memory_classes": {
          "type": "boolean",
          "const": true
        },
        "support_export_preserves_class_distinctions": {
          "type": "boolean",
          "const": true
        },
        "unavailable_classes_labeled_precisely": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
