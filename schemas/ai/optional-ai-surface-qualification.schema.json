{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/optional-ai-surface-qualification.schema.json",
  "title": "Aureline optional AI-adjacent surface qualification record",
  "$comment": "Rust owner: aureline_ai::audit_optional_ai_adjacent_surfaces::OptionalAiAdjacentSurfaceAuditPacket.",
  "description": "Boundary schema for the optional AI-adjacent surface qualification audit record. For each optional AI surface family (notebook, voice, browser companion, preview/designer, background automation, and other), the packet records whether the lane carries its own qualification proof or is explicitly labeled below Stable. The packet also records family-specific requirements (notebook kernel/output trust, voice consent/transcript posture, browser-companion scope honesty, preview/designer mutation boundary) and the downgrade automation state. It does not re-derive core AI graduation, route/spend receipts, or mutation evidence. It carries refs, stable class tokens, booleans, counts, and review labels only. It never carries raw prompts, raw provider payloads, endpoint URLs, credentials, or signing-key material. Adding a new enum member or a new optional field is additive-minor; repurposing an existing member is breaking and bumps schema_version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "display_label",
    "policy_epoch_ref",
    "core_ai_graduation_packet_ref",
    "surface_rows",
    "downgrade_automation",
    "propagation_state",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "optional_ai_adjacent_surface_qualification" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "display_label": { "type": "string", "minLength": 1 },
    "policy_epoch_ref": { "type": "string", "minLength": 1 },
    "core_ai_graduation_packet_ref": { "type": "string", "minLength": 1 },
    "surface_rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surface_qualification_row" }
    },
    "downgrade_automation": { "$ref": "#/$defs/downgrade_automation_block" },
    "propagation_state": { "$ref": "#/$defs/propagation_state_block" },
    "source_contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "surface_family_class": {
      "type": "string",
      "enum": [
        "notebook",
        "voice",
        "browser_companion",
        "preview_designer",
        "background_branch_automation",
        "other_adjacent"
      ]
    },
    "surface_qualification_label": {
      "type": "string",
      "enum": [
        "stable",
        "limited",
        "preview",
        "experimental",
        "unsupported"
      ]
    },
    "notebook_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_trust_labeled",
        "kernel_trust_labeled",
        "output_trust_labeled",
        "kernel_state_consistent",
        "debugger_support_labeled",
        "output_sandbox_cues_present",
        "no_generic_ai_affordances"
      ],
      "properties": {
        "document_trust_labeled": { "type": "boolean" },
        "kernel_trust_labeled": { "type": "boolean" },
        "output_trust_labeled": { "type": "boolean" },
        "kernel_state_consistent": {
          "type": "boolean",
          "description": "busy/queued/idle/interrupted state is consistently surfaced"
        },
        "debugger_support_labeled": { "type": "boolean" },
        "output_sandbox_cues_present": { "type": "boolean" },
        "no_generic_ai_affordances": {
          "type": "boolean",
          "description": "no generic AI affordances that imply JupyterLab-class maturity through silence"
        }
      }
    },
    "voice_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "explicit_consent_required",
        "capture_boundary_declared",
        "local_vs_retained_transcript_explicit",
        "disable_path_present",
        "accessibility_safe_fallback_present",
        "not_treated_as_plain_text_input"
      ],
      "properties": {
        "explicit_consent_required": { "type": "boolean" },
        "capture_boundary_declared": { "type": "boolean" },
        "local_vs_retained_transcript_explicit": { "type": "boolean" },
        "disable_path_present": { "type": "boolean" },
        "accessibility_safe_fallback_present": { "type": "boolean" },
        "not_treated_as_plain_text_input": {
          "type": "boolean",
          "description": "voice is not silently treated as just another text input channel"
        }
      }
    },
    "browser_companion_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_limited_to_review_docs_or_inspect",
        "no_native_depth_authority",
        "no_silent_write_back",
        "no_hidden_runtime_mutation",
        "scope_label_present"
      ],
      "properties": {
        "scope_limited_to_review_docs_or_inspect": {
          "type": "boolean",
          "description": "scope is limited to review/docs/light-handoff or source-first inspect modes"
        },
        "no_native_depth_authority": { "type": "boolean" },
        "no_silent_write_back": { "type": "boolean" },
        "no_hidden_runtime_mutation": { "type": "boolean" },
        "scope_label_present": { "type": "boolean" }
      }
    },
    "preview_designer_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_honest",
        "no_native_depth_authority",
        "no_silent_write_back",
        "no_hidden_runtime_mutation",
        "separately_proven_if_write_capable"
      ],
      "properties": {
        "scope_honest": { "type": "boolean" },
        "no_native_depth_authority": { "type": "boolean" },
        "no_silent_write_back": { "type": "boolean" },
        "no_hidden_runtime_mutation": { "type": "boolean" },
        "separately_proven_if_write_capable": {
          "type": "boolean",
          "description": "any write-capable surface carries its own separate proof"
        }
      }
    },
    "surface_qualification_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_family",
        "surface_label",
        "qualification",
        "has_own_qualification_packet",
        "qualification_packet_ref",
        "trust_boundary_explicit",
        "route_evidence_explicit",
        "export_support_parity_explicit",
        "downgrade_rule_explicit",
        "no_stable_inheritance_from_core",
        "visible_below_stable_label",
        "propagated_to_help_about",
        "propagated_to_docs",
        "propagated_to_release_packets",
        "propagated_to_compat_reports"
      ],
      "properties": {
        "surface_family": { "$ref": "#/$defs/surface_family_class" },
        "surface_label": { "type": "string", "minLength": 1 },
        "qualification": { "$ref": "#/$defs/surface_qualification_label" },
        "has_own_qualification_packet": { "type": "boolean" },
        "qualification_packet_ref": { "type": "string" },
        "trust_boundary_explicit": { "type": "boolean" },
        "route_evidence_explicit": { "type": "boolean" },
        "export_support_parity_explicit": { "type": "boolean" },
        "downgrade_rule_explicit": { "type": "boolean" },
        "no_stable_inheritance_from_core": {
          "type": "boolean",
          "description": "this surface does not freeload on core AI graduation proof"
        },
        "visible_below_stable_label": {
          "type": "boolean",
          "description": "a visible narrower-than-stable label is shown in product, docs/help, and release packets (required when qualification != stable)"
        },
        "propagated_to_help_about": { "type": "boolean" },
        "propagated_to_docs": { "type": "boolean" },
        "propagated_to_release_packets": { "type": "boolean" },
        "propagated_to_compat_reports": { "type": "boolean" },
        "notebook_requirements": { "$ref": "#/$defs/notebook_requirements" },
        "voice_requirements": { "$ref": "#/$defs/voice_requirements" },
        "browser_companion_requirements": { "$ref": "#/$defs/browser_companion_requirements" },
        "preview_designer_requirements": { "$ref": "#/$defs/preview_designer_requirements" },
        "known_gaps_label": { "type": "string" }
      }
    },
    "downgrade_trigger_class": {
      "type": "string",
      "enum": [
        "packet_freshness_expired",
        "route_truth_regressed",
        "support_export_parity_missing",
        "trust_boundary_violated",
        "eval_threshold_missed"
      ]
    },
    "downgrade_automation_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "triggers",
        "fires_on_packet_freshness_expiry",
        "fires_on_route_truth_regression",
        "fires_on_support_export_parity_missing",
        "downgrade_target_label",
        "downgrade_propagates_to_product_copy",
        "downgrade_propagates_to_docs_help",
        "downgrade_propagates_to_release_packets",
        "downgrade_propagates_to_compat_reports"
      ],
      "properties": {
        "triggers": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_trigger_class" }
        },
        "fires_on_packet_freshness_expiry": { "type": "boolean" },
        "fires_on_route_truth_regression": { "type": "boolean" },
        "fires_on_support_export_parity_missing": { "type": "boolean" },
        "downgrade_target_label": { "type": "string", "minLength": 1 },
        "downgrade_propagates_to_product_copy": { "type": "boolean" },
        "downgrade_propagates_to_docs_help": { "type": "boolean" },
        "downgrade_propagates_to_release_packets": { "type": "boolean" },
        "downgrade_propagates_to_compat_reports": { "type": "boolean" }
      }
    },
    "propagation_state_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "help_about_surfaces_consume_family_specific_state",
        "docs_consume_family_specific_state",
        "marketplace_consume_family_specific_state",
        "cli_headless_inspect_consume_family_specific_state",
        "support_export_consume_family_specific_state",
        "no_optimistic_available_in_build_collapse"
      ],
      "properties": {
        "help_about_surfaces_consume_family_specific_state": { "type": "boolean" },
        "docs_consume_family_specific_state": { "type": "boolean" },
        "marketplace_consume_family_specific_state": { "type": "boolean" },
        "cli_headless_inspect_consume_family_specific_state": { "type": "boolean" },
        "support_export_consume_family_specific_state": { "type": "boolean" },
        "no_optimistic_available_in_build_collapse": {
          "type": "boolean",
          "description": "no consumer collapses unqualified optional surfaces back into one optimistic 'available in build' stable label"
        }
      }
    }
  }
}
