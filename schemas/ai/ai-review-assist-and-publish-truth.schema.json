{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/ai-review-assist-and-publish-truth.schema.json",
  "title": "Aureline AI review-assist and publish truth packet",
  "$comment": "Rust owner: aureline_ai::ai_review_assist::AiReviewAssistTruthPacket.",
  "description": "Boundary schema for the metadata-only stable AI review-assist truth packet. The packet binds durable finding rows, review-scope selectors, publish-to-review sheets, and resolution-memory rows to one review-pack digest and evidence-packet lineage across desktop, CLI/headless, browser/companion, and support/export lanes. It preserves local-vs-hosted publication truth and downgrades missing provider write access to local, copy, or export actions. It carries ids, refs, closed vocabulary tokens, redaction-aware preview text, and short labels only; raw diffs, raw provider payloads, provider URLs, credentials, prompt text, and secret values stay outside this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "review_workspace_ref",
    "review_pack_digest_ref",
    "display_label",
    "scope_selectors",
    "findings",
    "publish_sheets",
    "resolution_memory",
    "consumer_projections",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "ai_review_assist_truth" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "review_workspace_ref": { "$ref": "#/$defs/non_empty_string" },
    "review_pack_digest_ref": { "$ref": "#/$defs/non_empty_string" },
    "display_label": { "$ref": "#/$defs/non_empty_string" },
    "scope_selectors": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/review_scope_selector" }
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ai_review_finding_row" }
    },
    "publish_sheets": {
      "type": "array",
      "items": { "$ref": "#/$defs/publish_to_review_sheet" }
    },
    "resolution_memory": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/resolution_memory_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "redaction_class_token": { "$ref": "#/$defs/non_empty_string" },
    "minted_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object_id", "evidence_packet_refs", "export_lineage_refs", "export_safe"],
      "properties": {
        "object_id": { "$ref": "#/$defs/non_empty_string" },
        "evidence_packet_refs": { "$ref": "#/$defs/ref_array" },
        "export_lineage_refs": { "$ref": "#/$defs/ref_array" },
        "export_safe": { "type": "boolean", "const": true }
      }
    },
    "scope_class": {
      "type": "string",
      "enum": ["selected_diff", "uncommitted_changes", "hosted_review_object"]
    },
    "scope_freshness_class": {
      "type": "string",
      "enum": ["current", "outdated_diff_changed", "rerun_recommended"]
    },
    "rerun_action": {
      "type": "string",
      "enum": ["not_needed", "rerun_same_review_pack", "compare_changed_scope"]
    },
    "finding_class": {
      "type": "string",
      "enum": [
        "risk_or_bug_concern",
        "missing_test_coverage",
        "dependency_or_security_concern",
        "repo_instruction_check_fired",
        "performance_or_complexity_concern",
        "impact_area_hint"
      ]
    },
    "severity_class": {
      "type": "string",
      "enum": ["high_advisory", "medium_advisory", "low_advisory", "informational"]
    },
    "confidence_class": {
      "type": "string",
      "enum": ["evidence_backed", "inferred", "low_confidence"]
    },
    "instruction_check_source": {
      "type": "string",
      "enum": [
        "repo_instruction_bundle",
        "designated_policy_file",
        "review_pack_required_check",
        "review_pack_advisory_check",
        "local_diagnostic",
        "provider_check_mirror"
      ]
    },
    "resolution_state": {
      "type": "string",
      "enum": ["open", "dismissed", "published", "outdated", "suppressed"]
    },
    "destination_class": {
      "type": "string",
      "enum": [
        "local_only",
        "provider_thread_comment",
        "provider_check_annotation",
        "review_bundle_export",
        "support_export"
      ]
    },
    "provider_write_access": {
      "type": "string",
      "enum": [
        "provider_write_available",
        "missing_provider_write_access",
        "provider_write_blocked_by_policy",
        "not_applicable_local_or_export"
      ]
    },
    "publish_action": {
      "type": "string",
      "enum": [
        "publish_to_destination",
        "copy_only",
        "export_local_packet",
        "keep_local",
        "blocked_provider_write_missing"
      ]
    },
    "attribution_state": {
      "type": "string",
      "enum": [
        "posted_as_user_with_ai_assist_disclosed",
        "kept_local_no_attribution",
        "exported_with_ai_assist_disclosed"
      ]
    },
    "redaction_note": {
      "type": "string",
      "enum": [
        "no_redaction_required",
        "internal_identifier_redacted",
        "credential_handle_redacted",
        "redaction_requires_user_review"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "desktop_review_workspace",
        "cli_headless",
        "browser_companion",
        "support_export"
      ]
    },
    "affected_hunk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_ref", "hunk_ref", "diff_fingerprint_ref"],
      "properties": {
        "file_ref": { "$ref": "#/$defs/non_empty_string" },
        "hunk_ref": { "$ref": "#/$defs/non_empty_string" },
        "diff_fingerprint_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "review_scope_selector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selector_id",
        "scope_class",
        "base_identity_ref",
        "head_identity_ref",
        "review_pack_digest_ref",
        "freshness_class",
        "rerun_action",
        "lineage"
      ],
      "properties": {
        "selector_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_class": { "$ref": "#/$defs/scope_class" },
        "base_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "head_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "hosted_review_object_ref": { "$ref": "#/$defs/non_empty_string" },
        "review_pack_digest_ref": { "$ref": "#/$defs/non_empty_string" },
        "freshness_class": { "$ref": "#/$defs/scope_freshness_class" },
        "rerun_action": { "$ref": "#/$defs/rerun_action" },
        "material_diff_change_ref": { "$ref": "#/$defs/non_empty_string" },
        "lineage": { "$ref": "#/$defs/lineage" }
      }
    },
    "ai_review_finding_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "title",
        "finding_class",
        "severity_class",
        "confidence_class",
        "scope_selector_id",
        "review_pack_digest_ref",
        "instruction_check_source",
        "instruction_check_refs",
        "affected_hunks",
        "lineage",
        "scope_freshness_class",
        "resolution_state"
      ],
      "properties": {
        "finding_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "finding_class": { "$ref": "#/$defs/finding_class" },
        "severity_class": { "$ref": "#/$defs/severity_class" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "scope_selector_id": { "$ref": "#/$defs/non_empty_string" },
        "review_pack_digest_ref": { "$ref": "#/$defs/non_empty_string" },
        "instruction_check_source": { "$ref": "#/$defs/instruction_check_source" },
        "instruction_check_refs": { "$ref": "#/$defs/ref_array" },
        "affected_hunks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/affected_hunk" }
        },
        "lineage": { "$ref": "#/$defs/lineage" },
        "scope_freshness_class": { "$ref": "#/$defs/scope_freshness_class" },
        "resolution_state": { "$ref": "#/$defs/resolution_state" },
        "publish_sheet_id": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "publish_to_review_sheet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publish_sheet_id",
        "finding_id",
        "provider_ref",
        "destination_class",
        "destination_ref",
        "provider_write_access",
        "outbound_text_preview",
        "attribution_state",
        "redaction_note",
        "action_class",
        "fallback_actions",
        "lineage"
      ],
      "properties": {
        "publish_sheet_id": { "$ref": "#/$defs/non_empty_string" },
        "finding_id": { "$ref": "#/$defs/non_empty_string" },
        "provider_ref": { "$ref": "#/$defs/non_empty_string" },
        "destination_class": { "$ref": "#/$defs/destination_class" },
        "destination_ref": { "$ref": "#/$defs/non_empty_string" },
        "provider_write_access": { "$ref": "#/$defs/provider_write_access" },
        "outbound_text_preview": { "$ref": "#/$defs/non_empty_string" },
        "attribution_state": { "$ref": "#/$defs/attribution_state" },
        "redaction_note": { "$ref": "#/$defs/redaction_note" },
        "action_class": { "$ref": "#/$defs/publish_action" },
        "fallback_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/publish_action" }
        },
        "lineage": { "$ref": "#/$defs/lineage" }
      }
    },
    "resolution_memory_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolution_id",
        "finding_id",
        "state",
        "actor_ref",
        "source_ref",
        "timestamp",
        "reopen_lineage_refs",
        "lineage"
      ],
      "properties": {
        "resolution_id": { "$ref": "#/$defs/non_empty_string" },
        "finding_id": { "$ref": "#/$defs/non_empty_string" },
        "state": { "$ref": "#/$defs/resolution_state" },
        "actor_ref": { "$ref": "#/$defs/non_empty_string" },
        "source_ref": { "$ref": "#/$defs/non_empty_string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "reopen_lineage_refs": { "$ref": "#/$defs/ref_array" },
        "predecessor_resolution_id": { "$ref": "#/$defs/non_empty_string" },
        "publish_sheet_id": { "$ref": "#/$defs/non_empty_string" },
        "lineage": { "$ref": "#/$defs/lineage" }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "preserves_scope_identity",
        "preserves_instruction_check_source",
        "preserves_publish_destination_truth",
        "preserves_resolution_memory",
        "preserves_local_copy_export_fallback",
        "export_ref"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/consumer_surface" },
        "preserves_scope_identity": { "type": "boolean", "const": true },
        "preserves_instruction_check_source": { "type": "boolean", "const": true },
        "preserves_publish_destination_truth": { "type": "boolean", "const": true },
        "preserves_resolution_memory": { "type": "boolean", "const": true },
        "preserves_local_copy_export_fallback": { "type": "boolean", "const": true },
        "export_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  }
}
