{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/materialize-the-provider-and-model-registry-local-or-byok-or-managed-mode-disclosure-and-route-inspectors.schema.json",
  "title": "Aureline materialized provider/model route disclosure and inspectors",
  "description": "Export-safe packet materializing the provider/model registry into per-route inspectors. Each route binds its provider, model, claimed qualification, execution mode (local, BYOK, or managed), locality, region, retention, cost disclosure, tool side-effect class, and automation authority, plus a closed set of downgrade rules that narrow the claim. The declared mode must agree with the route's locality, a local route must be fully on-device, and a claimed managed or BYOK route may not hide region, retention, or cost. Raw prompt bodies, raw diffs, raw provider payloads, credentials, raw endpoint URLs, exact token counts, and exact cost amounts never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "disclosure_label",
    "routes",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "materialize_the_provider_and_model_registry_local_or_byok_or_managed_mode_disclosure_and_route_inspectors"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "disclosure_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/route_inspector_row"
      }
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "qualification_class": {
      "enum": ["stable", "beta", "preview", "experimental", "unavailable", "held"]
    },
    "downgrade_trigger": {
      "enum": [
        "proof_stale",
        "policy_blocked",
        "provider_unavailable",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "execution_mode": {
      "enum": ["local", "byok", "managed"]
    },
    "locality": {
      "enum": [
        "on_device_in_process",
        "on_device_local_service",
        "byok_direct_vendor",
        "byok_self_hosted",
        "managed_enterprise_gateway",
        "managed_vendor_hosted"
      ]
    },
    "region": {
      "enum": [
        "on_device_only",
        "single_region_pinned",
        "multi_region_pinned",
        "vendor_default_unpinned",
        "unknown_unverified",
        "policy_blocked"
      ]
    },
    "retention": {
      "enum": [
        "no_retention_local_only",
        "no_retention_promised",
        "bounded_retention_operator_only",
        "bounded_retention_with_export",
        "unbounded_retention_not_trained",
        "unbounded_retention_used_for_training",
        "unknown_unverified",
        "policy_blocked"
      ]
    },
    "cost_disclosure": {
      "enum": [
        "no_cost_local_compute",
        "metered_per_token_disclosed",
        "flat_rate_disclosed",
        "budget_capped_disclosed",
        "unknown_unverified"
      ]
    },
    "tool_side_effect": {
      "enum": [
        "inspect_only",
        "local_reversible_edit",
        "local_destructive_edit",
        "external_reversible_comment",
        "external_irreversible_publish",
        "policy_or_trust_mutation"
      ]
    },
    "automation_authority": {
      "enum": [
        "read_only_no_apply",
        "preview_only_human_apply",
        "scoped_apply_human_approved",
        "signed_recipe_human_approved",
        "background_agent_human_gated_merge"
      ]
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger", "narrowed_to", "auto_enforced", "rationale"],
      "properties": {
        "trigger": { "$ref": "#/$defs/downgrade_trigger" },
        "narrowed_to": { "$ref": "#/$defs/qualification_class" },
        "auto_enforced": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "route_inspector_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_id",
        "provider_id",
        "model_id",
        "claimed_qualification",
        "execution_mode",
        "locality",
        "region",
        "retention",
        "cost_disclosure",
        "tool_side_effect",
        "automation_authority",
        "mode_disclosure_label",
        "downgrade_rules",
        "evidence_packet_refs"
      ],
      "properties": {
        "route_id": { "$ref": "#/$defs/non_empty_string" },
        "provider_id": { "$ref": "#/$defs/non_empty_string" },
        "model_id": { "$ref": "#/$defs/non_empty_string" },
        "claimed_qualification": { "$ref": "#/$defs/qualification_class" },
        "execution_mode": { "$ref": "#/$defs/execution_mode" },
        "locality": { "$ref": "#/$defs/locality" },
        "region": { "$ref": "#/$defs/region" },
        "retention": { "$ref": "#/$defs/retention" },
        "cost_disclosure": { "$ref": "#/$defs/cost_disclosure" },
        "tool_side_effect": { "$ref": "#/$defs/tool_side_effect" },
        "automation_authority": { "$ref": "#/$defs/automation_authority" },
        "mode_disclosure_label": { "$ref": "#/$defs/non_empty_string" },
        "downgrade_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_rule" }
        },
        "evidence_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_freshness_slo_hours", "last_proof_refresh", "auto_narrow_on_stale"],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
