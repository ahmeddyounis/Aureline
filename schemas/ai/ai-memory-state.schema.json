{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/ai-memory-state.schema.json",
  "title": "Aureline stable AI memory-state packet",
  "description": "Export-safe stable projection for AI thread, memory, prompt/result cache, retained evidence, and delete/export truth. The packet carries class labels, refs, policy labels, invalidation reason codes, inventory hashes, and support-safe disclosure fields only; raw prompts, responses, terminal transcripts, credentials, disallowed path contents, raw vectors, and raw provider payloads stay outside this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "display_label",
    "workspace_identity_ref",
    "repo_identity_ref",
    "profile_identity_ref",
    "policy_epoch_ref",
    "provider_model_ref",
    "memory_classes",
    "surface_projections",
    "durable_cache_key_contracts",
    "reusable_memory_fences",
    "delete_export_drills",
    "support_manifest",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "ai_memory_state" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "$ref": "#/$defs/opaque_id" },
    "display_label": { "$ref": "#/$defs/review_label" },
    "workspace_identity_ref": { "$ref": "#/$defs/opaque_id" },
    "repo_identity_ref": { "$ref": "#/$defs/opaque_id" },
    "profile_identity_ref": { "$ref": "#/$defs/opaque_id" },
    "policy_epoch_ref": { "$ref": "#/$defs/opaque_id" },
    "provider_model_ref": { "$ref": "#/$defs/opaque_id" },
    "memory_classes": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/memory_class_row" }
    },
    "surface_projections": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/surface_projection_row" }
    },
    "durable_cache_key_contracts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/durable_cache_key_contract" }
    },
    "reusable_memory_fences": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/reusable_memory_fence" }
    },
    "delete_export_drills": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/delete_export_drill" }
    },
    "support_manifest": { "$ref": "#/$defs/support_manifest" },
    "source_contract_refs": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/repo_ref" }
    },
    "redaction_class_token": { "$ref": "#/$defs/opaque_id" },
    "minted_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$"
    },
    "repo_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_./:-]+$"
    },
    "review_label": {
      "type": "string",
      "minLength": 1
    },
    "ai_state_class": {
      "type": "string",
      "enum": [
        "turn_state",
        "conversation_thread",
        "prompt_result_cache",
        "reusable_repo_facts_summaries",
        "retained_evidence_copy",
        "explicit_saved_memory"
      ]
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "session_workspace",
        "user_workspace_repo",
        "workspace_feature_provider_model",
        "workspace_or_tenant_repo_policy",
        "action_scoped",
        "user_repo_org_explicit"
      ]
    },
    "durability_class": {
      "type": "string",
      "enum": [
        "ephemeral",
        "local_durable",
        "ttl_bounded_cache",
        "derived_regeneratable",
        "evidence_policy_retained",
        "explicitly_saved"
      ]
    },
    "retention_mode": {
      "type": "string",
      "enum": [
        "ephemeral_until_completion",
        "local_thread_until_delete",
        "ttl_bounded_until_invalidated",
        "derived_until_invalidated",
        "evidence_policy_expiry_or_case_close",
        "until_user_or_admin_removes"
      ]
    },
    "sensitivity_tier": {
      "type": "string",
      "enum": [
        "t0_metadata_only",
        "t1_low_risk_derived",
        "t2_code_bearing_bounded",
        "t3_sensitive_secret_adjacent"
      ]
    },
    "owner_policy": {
      "type": "string",
      "enum": [
        "active_user_session",
        "user_workspace_policy",
        "workspace_cache_policy",
        "workspace_fact_policy",
        "evidence_retention_policy",
        "explicit_owner_policy"
      ]
    },
    "delete_posture": {
      "type": "string",
      "enum": [
        "no_durable_state",
        "delete_thread_with_receipt",
        "invalidate_cache_by_key_class",
        "evidence_retention_rules",
        "delete_saved_memory_with_receipt"
      ]
    },
    "export_posture": {
      "type": "string",
      "enum": [
        "not_exportable_ephemeral",
        "user_visible_conversation",
        "inventory_and_hashes_only",
        "provenance_labeled_summary",
        "evidence_packet",
        "explicit_saved_memory_object"
      ]
    },
    "cache_key_component": {
      "type": "string",
      "enum": [
        "workspace_identity",
        "repo_identity",
        "feature_class",
        "provider_model_version",
        "prompt_pack_version",
        "tool_schema_version",
        "policy_epoch",
        "graph_docs_epoch",
        "retention_posture"
      ]
    },
    "invalidation_reason_code": {
      "type": "string",
      "enum": [
        "workspace_identity_changed",
        "repo_identity_changed",
        "org_tenant_profile_changed",
        "workspace_trust_changed",
        "provider_model_version_changed",
        "prompt_pack_changed",
        "tool_schema_changed",
        "policy_epoch_rolled",
        "graph_docs_epoch_changed",
        "retention_posture_changed",
        "delete_request_received"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "thread_header",
        "memory_inspector",
        "delete_export_review",
        "help_about",
        "support_export"
      ]
    },
    "memory_class_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_class",
        "label",
        "scope_class",
        "durability_class",
        "retention_mode",
        "sensitivity_tier",
        "owner_policy",
        "delete_posture",
        "export_posture",
        "invalidation_key_components",
        "invalidation_reason_codes",
        "broader_reuse_requires_policy_label",
        "raw_prompt_response_bodies_excluded_by_default",
        "t3_reusable_memory_forbidden",
        "disclosure_label"
      ],
      "properties": {
        "state_class": { "$ref": "#/$defs/ai_state_class" },
        "label": { "$ref": "#/$defs/review_label" },
        "scope_class": { "$ref": "#/$defs/scope_class" },
        "durability_class": { "$ref": "#/$defs/durability_class" },
        "retention_mode": { "$ref": "#/$defs/retention_mode" },
        "sensitivity_tier": { "$ref": "#/$defs/sensitivity_tier" },
        "owner_policy": { "$ref": "#/$defs/owner_policy" },
        "delete_posture": { "$ref": "#/$defs/delete_posture" },
        "export_posture": { "$ref": "#/$defs/export_posture" },
        "invalidation_key_components": {
          "type": "array",
          "items": { "$ref": "#/$defs/cache_key_component" }
        },
        "invalidation_reason_codes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/invalidation_reason_code" }
        },
        "broader_reuse_requires_policy_label": { "type": "boolean" },
        "raw_prompt_response_bodies_excluded_by_default": { "type": "boolean" },
        "t3_reusable_memory_forbidden": { "type": "boolean" },
        "disclosure_label": { "$ref": "#/$defs/review_label" }
      }
    },
    "surface_projection_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "projection_ref",
        "uses_memory_class_vocabulary",
        "shows_scope_chip",
        "shows_provider_model",
        "shows_retention_mode",
        "shows_saved_memory_owner_policy",
        "discloses_retained_evidence_copy",
        "delete_export_reachable"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "projection_ref": { "$ref": "#/$defs/opaque_id" },
        "uses_memory_class_vocabulary": { "type": "boolean" },
        "shows_scope_chip": { "type": "boolean" },
        "shows_provider_model": { "type": "boolean" },
        "shows_retention_mode": { "type": "boolean" },
        "shows_saved_memory_owner_policy": { "type": "boolean" },
        "discloses_retained_evidence_copy": { "type": "boolean" },
        "delete_export_reachable": { "type": "boolean" }
      }
    },
    "durable_cache_key_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cache_contract_id",
        "state_class",
        "required_components",
        "invalidation_reason_codes",
        "workspace_repo_profile_scoped",
        "delete_request_invalidates_matching_entries",
        "support_export_hashes_only"
      ],
      "properties": {
        "cache_contract_id": { "$ref": "#/$defs/opaque_id" },
        "state_class": { "$ref": "#/$defs/ai_state_class" },
        "required_components": {
          "type": "array",
          "minItems": 9,
          "items": { "$ref": "#/$defs/cache_key_component" }
        },
        "invalidation_reason_codes": {
          "type": "array",
          "minItems": 11,
          "items": { "$ref": "#/$defs/invalidation_reason_code" }
        },
        "workspace_repo_profile_scoped": { "type": "boolean" },
        "delete_request_invalidates_matching_entries": { "type": "boolean" },
        "support_export_hashes_only": { "type": "boolean" }
      }
    },
    "reusable_memory_fence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fence_id",
        "state_class",
        "denies_t3_secret_adjacent",
        "denies_raw_terminal_transcripts",
        "denies_credentials",
        "denies_disallowed_path_contents",
        "retained_copy_requires_reviewed_redaction_packet",
        "policy_ref"
      ],
      "properties": {
        "fence_id": { "$ref": "#/$defs/opaque_id" },
        "state_class": { "$ref": "#/$defs/ai_state_class" },
        "denies_t3_secret_adjacent": { "type": "boolean" },
        "denies_raw_terminal_transcripts": { "type": "boolean" },
        "denies_credentials": { "type": "boolean" },
        "denies_disallowed_path_contents": { "type": "boolean" },
        "retained_copy_requires_reviewed_redaction_packet": { "type": "boolean" },
        "policy_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "delete_export_drill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drill_id",
        "selected_classes",
        "excluded_by_policy",
        "invalidates_matching_durable_caches",
        "retained_copies_labeled",
        "export_before_delete_available",
        "receipt_or_omission_reason_emitted"
      ],
      "properties": {
        "drill_id": { "$ref": "#/$defs/opaque_id" },
        "selected_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ai_state_class" }
        },
        "excluded_by_policy": {
          "type": "array",
          "items": { "$ref": "#/$defs/ai_state_class" }
        },
        "invalidates_matching_durable_caches": { "type": "boolean" },
        "retained_copies_labeled": { "type": "boolean" },
        "export_before_delete_available": { "type": "boolean" },
        "receipt_or_omission_reason_emitted": { "type": "boolean" }
      }
    },
    "support_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_ref",
        "conversation_history_inventory_ref",
        "reusable_facts_inventory_ref",
        "retained_evidence_inventory_ref",
        "cache_inventory_hash_ref",
        "raw_prompt_bodies_excluded",
        "raw_response_bodies_excluded",
        "raw_terminal_transcripts_excluded",
        "credentials_excluded"
      ],
      "properties": {
        "manifest_ref": { "$ref": "#/$defs/opaque_id" },
        "conversation_history_inventory_ref": { "$ref": "#/$defs/opaque_id" },
        "reusable_facts_inventory_ref": { "$ref": "#/$defs/opaque_id" },
        "retained_evidence_inventory_ref": { "$ref": "#/$defs/opaque_id" },
        "cache_inventory_hash_ref": { "$ref": "#/$defs/opaque_id" },
        "raw_prompt_bodies_excluded": { "type": "boolean" },
        "raw_response_bodies_excluded": { "type": "boolean" },
        "raw_terminal_transcripts_excluded": { "type": "boolean" },
        "credentials_excluded": { "type": "boolean" }
      }
    }
  }
}
