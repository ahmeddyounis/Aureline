{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/add-hidden-retention-spill-guards-cross-workspace-or-cross-tenant-memory-fences-cache-policy-filters-and-offline-or-mirr.schema.json",
  "title": "Aureline hidden-retention spill guards, cross-workspace-or-cross-tenant memory fences, cache-policy filters, and offline-or-mirror-safe retrieval fallback truth across claimed M5 profiles",
  "description": "Export-safe packet that, per claimed M5 profile, binds one governed memory or cache artifact to four interlocking truths: a hidden-retention spill guard that keeps a cache content-keyed and lifetime-bounded with telemetry export refused; a cross-workspace-or-cross-tenant memory fence enforced and disclosed; a cache-policy filter that discloses what is narrowed and why; and an offline-or-mirror-safe retrieval fallback whose chain ends in a non-AI terminal and keeps a precise label on every non-primary lane. Raw prompt bodies, cached result bodies, raw embeddings, raw provider payloads, credentials, raw endpoint URLs, exact token counts, and exact cost amounts never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "records_label",
    "rows",
    "guardrails",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "add_hidden_retention_spill_guards_cross_workspace_or_cross_tenant_memory_fences_cache_policy_filters_and_offline_or_mirr"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "records_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "rows": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/row"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "profile": {
      "type": "string",
      "enum": [
        "local_only",
        "byok_direct",
        "managed_hosted",
        "offline_mirror",
        "hybrid_managed"
      ]
    },
    "artifact_class": {
      "type": "string",
      "enum": [
        "ephemeral_turn_state",
        "evictable_derived_cache",
        "prompt_result_cache",
        "reusable_semantic_memory",
        "durable_saved_memory"
      ]
    },
    "retention_class": {
      "type": "string",
      "enum": [
        "session_scoped",
        "content_keyed_bounded",
        "ttl_bounded",
        "durable_consented",
        "none_retained"
      ]
    },
    "spill_state": {
      "type": "string",
      "enum": [
        "guarded",
        "would_spill_blocked",
        "shadow_store_blocked"
      ]
    },
    "recall_scope": {
      "type": "string",
      "enum": [
        "turn",
        "thread",
        "workspace",
        "tenant",
        "org"
      ]
    },
    "fence_state": {
      "type": "string",
      "enum": [
        "fenced",
        "breach_blocked",
        "explicitly_consented"
      ]
    },
    "filter_state": {
      "type": "string",
      "enum": [
        "unfiltered",
        "narrowed",
        "fully_blocked"
      ]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "policy_class",
        "region_gate",
        "retention_floor",
        "tenant_isolation",
        "byok_boundary"
      ]
    },
    "fallback_hop_kind": {
      "type": "string",
      "enum": [
        "managed_primary",
        "byok_direct",
        "workspace_mirror",
        "offline_local_pack",
        "cached_prior_result",
        "non_ai_terminal"
      ]
    },
    "fallback_state": {
      "type": "string",
      "enum": [
        "primary_available",
        "mirror_served",
        "offline_local_served",
        "policy_blocked_degraded",
        "terminal_non_ai"
      ]
    },
    "delete_export_posture": {
      "type": "string",
      "enum": [
        "user_scoped",
        "workspace_scoped",
        "tenant_scoped",
        "org_scoped",
        "not_applicable"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "composer_assist",
        "docs_browser_recall",
        "code_understanding",
        "semantic_search",
        "support_export",
        "managed_offline_report"
      ]
    },
    "spill_guard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "retention_class",
        "content_key_bound",
        "telemetry_export_allowed",
        "spill_state"
      ],
      "properties": {
        "retention_class": {
          "$ref": "#/$defs/retention_class"
        },
        "content_key_bound": {
          "type": "boolean"
        },
        "max_lifetime_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "telemetry_export_allowed": {
          "type": "boolean"
        },
        "spill_state": {
          "$ref": "#/$defs/spill_state"
        }
      }
    },
    "fence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recall_scope",
        "cross_workspace_state",
        "cross_tenant_state",
        "fence_visible"
      ],
      "properties": {
        "recall_scope": {
          "$ref": "#/$defs/recall_scope"
        },
        "cross_workspace_state": {
          "$ref": "#/$defs/fence_state"
        },
        "cross_tenant_state": {
          "$ref": "#/$defs/fence_state"
        },
        "fence_visible": {
          "type": "boolean"
        },
        "consent_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "policy_filter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "filter_state"
      ],
      "properties": {
        "filter_state": {
          "$ref": "#/$defs/filter_state"
        },
        "narrowed_reason": {
          "$ref": "#/$defs/narrow_reason"
        },
        "narrowed_disclosure": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fallback_state",
        "fallback_chain",
        "offline_safe"
      ],
      "properties": {
        "fallback_state": {
          "$ref": "#/$defs/fallback_state"
        },
        "fallback_chain": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/fallback_hop_kind"
          }
        },
        "offline_safe": {
          "type": "boolean"
        },
        "precise_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "profile",
        "artifact_class",
        "label_summary",
        "spill_guard",
        "fence",
        "policy_filter",
        "fallback",
        "delete_posture",
        "export_posture",
        "consumer_surfaces",
        "evidence_refs",
        "source_contract_refs"
      ],
      "properties": {
        "row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "profile": {
          "$ref": "#/$defs/profile"
        },
        "artifact_class": {
          "$ref": "#/$defs/artifact_class"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "spill_guard": {
          "$ref": "#/$defs/spill_guard"
        },
        "fence": {
          "$ref": "#/$defs/fence"
        },
        "policy_filter": {
          "$ref": "#/$defs/policy_filter"
        },
        "fallback": {
          "$ref": "#/$defs/fallback"
        },
        "delete_posture": {
          "$ref": "#/$defs/delete_export_posture"
        },
        "export_posture": {
          "$ref": "#/$defs/delete_export_posture"
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/consumer_surface"
          }
        },
        "degraded_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_cross_workspace_recall_by_default",
        "no_cross_tenant_recall_by_default",
        "prompt_result_caches_are_not_shadow_telemetry",
        "caches_content_keyed_and_lifetime_bounded",
        "policy_filtered_paths_disclose_narrowing",
        "fallback_truth_visible_in_export",
        "spend_route_failures_keep_precise_fallback",
        "every_durable_artifact_declares_delete_export"
      ],
      "properties": {
        "no_cross_workspace_recall_by_default": {
          "type": "boolean",
          "const": true
        },
        "no_cross_tenant_recall_by_default": {
          "type": "boolean",
          "const": true
        },
        "prompt_result_caches_are_not_shadow_telemetry": {
          "type": "boolean",
          "const": true
        },
        "caches_content_keyed_and_lifetime_bounded": {
          "type": "boolean",
          "const": true
        },
        "policy_filtered_paths_disclose_narrowing": {
          "type": "boolean",
          "const": true
        },
        "fallback_truth_visible_in_export": {
          "type": "boolean",
          "const": true
        },
        "spend_route_failures_keep_precise_fallback": {
          "type": "boolean",
          "const": true
        },
        "every_durable_artifact_declares_delete_export": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "composer_shows_fence_and_fallback",
        "docs_browser_shows_policy_narrowing",
        "search_shows_retrieval_fallback_state",
        "support_export_shows_retention_and_fence",
        "managed_offline_shows_fallback_truth",
        "blocked_or_degraded_lanes_labeled_below_current"
      ],
      "properties": {
        "composer_shows_fence_and_fallback": {
          "type": "boolean",
          "const": true
        },
        "docs_browser_shows_policy_narrowing": {
          "type": "boolean",
          "const": true
        },
        "search_shows_retrieval_fallback_state": {
          "type": "boolean",
          "const": true
        },
        "support_export_shows_retention_and_fence": {
          "type": "boolean",
          "const": true
        },
        "managed_offline_shows_fallback_truth": {
          "type": "boolean",
          "const": true
        },
        "blocked_or_degraded_lanes_labeled_below_current": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
