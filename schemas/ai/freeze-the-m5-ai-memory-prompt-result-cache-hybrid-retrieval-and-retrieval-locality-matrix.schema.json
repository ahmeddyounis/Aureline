{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/freeze-the-m5-ai-memory-prompt-result-cache-hybrid-retrieval-and-retrieval-locality-matrix.schema.json",
  "title": "Aureline M5 AI memory, prompt-result-cache, hybrid-retrieval, and retrieval-locality matrix",
  "description": "Export-safe packet freezing the M5 recall qualification for every claimed AI or recall surface. The packet binds each surface to its memory/cache classes, retrieval lanes, locality posture, cache-invalidation classes, delete/export posture, budget/receipt expectation, downgrade triggers, evidence requirements, source contracts, and consumer parity. Raw prompt bodies, cached result bodies, raw embeddings, raw provider payloads, credentials, exact token counts, and exact cost amounts never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "matrix_label",
    "surface_rows",
    "guardrails",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "freeze_m5_ai_memory_prompt_result_cache_hybrid_retrieval_and_retrieval_locality_matrix"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "matrix_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "surface_rows": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "$ref": "#/$defs/surface_row"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "surface": {
      "type": "string",
      "enum": [
        "composer_assist",
        "docs_browser_recall",
        "code_understanding",
        "semantic_search",
        "support_export",
        "managed_offline"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "memory_cache_class": {
      "type": "string",
      "enum": [
        "prompt_result_cache",
        "reusable_semantic_memory",
        "embedding_index",
        "ephemeral_session_state",
        "no_durable_memory"
      ]
    },
    "retrieval_lane": {
      "type": "string",
      "enum": [
        "lexical_keyword",
        "semantic_embedding",
        "hybrid_fusion",
        "graph_traversal",
        "no_retrieval"
      ]
    },
    "locality_posture": {
      "type": "string",
      "enum": [
        "local_device_only",
        "workspace_local",
        "tenant_region_pinned",
        "managed_hosted_region_pinned"
      ]
    },
    "delete_export_posture": {
      "type": "string",
      "enum": [
        "user_deletable_exportable",
        "workspace_deletable_exportable",
        "tenant_deletable_exportable",
        "ephemeral_auto_expire",
        "not_applicable"
      ]
    },
    "budget_receipt_expectation": {
      "type": "string",
      "enum": [
        "route_and_spend_receipt_required",
        "spend_receipt_required",
        "local_no_spend_receipt",
        "budget_capped_with_fallback"
      ]
    },
    "cache_invalidation_class": {
      "type": "string",
      "enum": [
        "ttl_expiry",
        "content_hash_key",
        "policy_epoch_bump",
        "trust_narrowing",
        "embedding_generation_bump",
        "manual_purge"
      ]
    },
    "evidence_requirement": {
      "type": "string",
      "enum": [
        "required",
        "recommended",
        "optional",
        "not_applicable"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "locality_unavailable",
        "embedding_generation_mismatch",
        "stale_hybrid_retrieval",
        "budget_exhausted",
        "delete_export_unverified",
        "provider_unavailable",
        "upstream_dependency_narrowed"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "desktop_composer",
        "docs_browser_companion",
        "search_surface",
        "support_export",
        "diagnostics",
        "managed_offline_report"
      ]
    },
    "surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "qualification",
        "scope_summary",
        "memory_cache_classes",
        "retrieval_lanes",
        "locality_posture",
        "delete_export_posture",
        "budget_receipt_expectation",
        "cache_invalidation_classes",
        "evidence_requirement",
        "required_evidence_packet_refs",
        "downgrade_triggers",
        "source_contract_refs",
        "consumer_surfaces"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/surface"
        },
        "qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "scope_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "memory_cache_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/memory_cache_class"
          }
        },
        "retrieval_lanes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/retrieval_lane"
          }
        },
        "locality_posture": {
          "$ref": "#/$defs/locality_posture"
        },
        "delete_export_posture": {
          "$ref": "#/$defs/delete_export_posture"
        },
        "budget_receipt_expectation": {
          "$ref": "#/$defs/budget_receipt_expectation"
        },
        "cache_invalidation_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/cache_invalidation_class"
          }
        },
        "evidence_requirement": {
          "$ref": "#/$defs/evidence_requirement"
        },
        "required_evidence_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/consumer_surface"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_cross_workspace_recall_by_default",
        "no_cross_tenant_recall_by_default",
        "mixed_generation_embeddings_labeled",
        "stale_hybrid_retrieval_never_current_truth",
        "every_durable_artifact_declares_retention",
        "caches_are_not_shadow_telemetry",
        "spend_or_route_failures_have_precise_fallback"
      ],
      "properties": {
        "no_cross_workspace_recall_by_default": {
          "type": "boolean",
          "const": true
        },
        "no_cross_tenant_recall_by_default": {
          "type": "boolean",
          "const": true
        },
        "mixed_generation_embeddings_labeled": {
          "type": "boolean",
          "const": true
        },
        "stale_hybrid_retrieval_never_current_truth": {
          "type": "boolean",
          "const": true
        },
        "every_durable_artifact_declares_retention": {
          "type": "boolean",
          "const": true
        },
        "caches_are_not_shadow_telemetry": {
          "type": "boolean",
          "const": true
        },
        "spend_or_route_failures_have_precise_fallback": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "composer_shows_memory_and_retrieval",
        "docs_browser_shows_provenance_and_locality",
        "search_shows_retrieval_lanes",
        "support_export_shows_locality_and_receipts",
        "diagnostics_shows_cache_and_budget",
        "managed_offline_shows_locality_truth",
        "unqualified_surfaces_labeled_below_stable"
      ],
      "properties": {
        "composer_shows_memory_and_retrieval": {
          "type": "boolean",
          "const": true
        },
        "docs_browser_shows_provenance_and_locality": {
          "type": "boolean",
          "const": true
        },
        "search_shows_retrieval_lanes": {
          "type": "boolean",
          "const": true
        },
        "support_export_shows_locality_and_receipts": {
          "type": "boolean",
          "const": true
        },
        "diagnostics_shows_cache_and_budget": {
          "type": "boolean",
          "const": true
        },
        "managed_offline_shows_locality_truth": {
          "type": "boolean",
          "const": true
        },
        "unqualified_surfaces_labeled_below_stable": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
