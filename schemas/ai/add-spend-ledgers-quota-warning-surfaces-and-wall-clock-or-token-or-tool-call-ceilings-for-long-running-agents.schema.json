{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/add-spend-ledgers-quota-warning-surfaces-and-wall-clock-or-token-or-tool-call-ceilings-for-long-running-agents.schema.json",
  "title": "Aureline spend ledgers, quota-warning surfaces, and ceilings for long-running agents",
  "description": "Export-safe packet materializing the long-running-agent budget surface into per-run rows. Each row binds the running spend ledger that accrues the run's cost, the quota-warning surface that flags an approaching provider limit before it is hit, and the wall-clock, token, and tool-call ceilings that keep the run bounded. Every claimed run must configure and bound the wall-clock, token, and tool-call ceilings so it can never run unbounded; a reached bounding ceiling must have stopped or paused the run with the run state agreeing; a spend ledger only accumulates and discloses who is charged; an estimate-only ledger may not back a Stable claim; a quota in its warning state must be surfaced; and an exhausted or paused provider quota may not keep claiming Stable. Raw provider endpoints, credential bodies, raw provider payloads, exact token counts, and exact spend amounts never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "catalogue_label",
    "budgets",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "add_spend_ledgers_quota_warning_surfaces_and_wall_clock_or_token_or_tool_call_ceilings_for_long_running_agents"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "catalogue_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "budgets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/agent_budget_row"
      }
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "qualification_class": {
      "enum": ["stable", "beta", "preview", "experimental", "unavailable", "held"]
    },
    "rollback_posture": {
      "enum": [
        "fully_reversible",
        "checkpoint_reversible",
        "evidence_preserved_no_revert",
        "not_applicable"
      ]
    },
    "downgrade_trigger": {
      "enum": [
        "proof_stale",
        "policy_blocked",
        "provider_unavailable",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "route_policy_mode": {
      "enum": ["local", "byok", "managed", "enterprise_gateway"]
    },
    "quota_family": {
      "enum": [
        "per_user_local_unmetered",
        "per_user_byok_vendor_quota",
        "organisation_pooled_quota",
        "enterprise_gateway_pooled_quota",
        "managed_entitlement_quota",
        "free_tier_rate_limited",
        "paid_tier_metered"
      ]
    },
    "quota_state": {
      "enum": [
        "within_limit",
        "warning",
        "exhausted",
        "grace",
        "paused_by_policy",
        "unknown_unverified"
      ]
    },
    "quota_scope": {
      "enum": [
        "per_session",
        "per_user",
        "per_workspace",
        "per_organisation",
        "per_deployment_profile",
        "local_device",
        "enterprise_pool"
      ]
    },
    "cost_band": {
      "enum": [
        "bundled_no_incremental_cost",
        "free_tier_rate_limited",
        "metered_low_band",
        "metered_medium_band",
        "metered_high_band",
        "flat_fee_subscription_band",
        "estimated_unverified_band"
      ]
    },
    "cost_measurement": {
      "enum": ["estimate_band", "actual_measured", "actual_unverified"]
    },
    "charged_disclosure": {
      "enum": [
        "not_charged_local",
        "not_charged_bundled",
        "charged_user_metered",
        "charged_user_subscription",
        "charged_organisation_pooled",
        "charge_unknown_unverified"
      ]
    },
    "ceiling_kind": {
      "enum": [
        "wall_clock",
        "token_budget",
        "tool_call_count",
        "cost_budget",
        "agent_step_count"
      ]
    },
    "ceiling_consumption": {
      "enum": [
        "well_within_limit",
        "approaching_warning",
        "warning_raised",
        "ceiling_reached"
      ]
    },
    "ceiling_enforcement": {
      "enum": [
        "hard_stop_on_reach",
        "soft_prompt_on_reach",
        "advisory_warn_only",
        "unenforced"
      ]
    },
    "ceiling_stop_outcome": {
      "enum": [
        "not_triggered",
        "hard_stopped",
        "paused_awaiting_user",
        "resumed_after_approval",
        "advisory_notice_only"
      ]
    },
    "run_state": {
      "enum": [
        "running",
        "completed_within_budget",
        "stopped_at_ceiling",
        "paused_awaiting_user",
        "budget_exhausted_stopped",
        "cancelled_by_user",
        "cancelled_by_policy"
      ]
    },
    "spend_ledger_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "phase_label", "delta_cost_band", "running_cost_band"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 0 },
        "phase_label": { "$ref": "#/$defs/non_empty_string" },
        "delta_cost_band": { "$ref": "#/$defs/cost_band" },
        "running_cost_band": { "$ref": "#/$defs/cost_band" },
        "notes_label": { "type": "string" }
      }
    },
    "spend_ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "running_cost_band",
        "measurement",
        "charged",
        "budget_owner_label",
        "budget_exhausted",
        "entries",
        "explanation_label"
      ],
      "properties": {
        "running_cost_band": { "$ref": "#/$defs/cost_band" },
        "measurement": { "$ref": "#/$defs/cost_measurement" },
        "charged": { "$ref": "#/$defs/charged_disclosure" },
        "budget_owner_label": { "$ref": "#/$defs/non_empty_string" },
        "budget_exhausted": { "type": "boolean" },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/spend_ledger_entry" }
        },
        "explanation_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "quota_warning_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "state",
        "scope",
        "warning_surfaced",
        "warning_threshold_label",
        "budget_owner_label",
        "explanation_label"
      ],
      "properties": {
        "family": { "$ref": "#/$defs/quota_family" },
        "state": { "$ref": "#/$defs/quota_state" },
        "scope": { "$ref": "#/$defs/quota_scope" },
        "warning_surfaced": { "type": "boolean" },
        "warning_threshold_label": { "$ref": "#/$defs/non_empty_string" },
        "budget_owner_label": { "$ref": "#/$defs/non_empty_string" },
        "explanation_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "agent_ceiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "consumption",
        "enforcement",
        "stop_outcome",
        "limit_label",
        "warning_threshold_label",
        "explanation_label"
      ],
      "properties": {
        "kind": { "$ref": "#/$defs/ceiling_kind" },
        "consumption": { "$ref": "#/$defs/ceiling_consumption" },
        "enforcement": { "$ref": "#/$defs/ceiling_enforcement" },
        "stop_outcome": { "$ref": "#/$defs/ceiling_stop_outcome" },
        "limit_label": { "$ref": "#/$defs/non_empty_string" },
        "warning_threshold_label": { "$ref": "#/$defs/non_empty_string" },
        "explanation_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger", "narrowed_to", "auto_enforced", "rationale"],
      "properties": {
        "trigger": { "$ref": "#/$defs/downgrade_trigger" },
        "narrowed_to": { "$ref": "#/$defs/qualification_class" },
        "auto_enforced": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "agent_budget_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budget_id",
        "agent_run_id",
        "agent_label",
        "resolved_mode",
        "claimed_qualification",
        "run_state",
        "spend_ledger",
        "quota_warning",
        "ceilings",
        "downgrade_rules",
        "rollback_posture",
        "rollback_verified",
        "evidence_packet_refs"
      ],
      "properties": {
        "budget_id": { "$ref": "#/$defs/non_empty_string" },
        "agent_run_id": { "$ref": "#/$defs/non_empty_string" },
        "agent_label": { "$ref": "#/$defs/non_empty_string" },
        "resolved_mode": { "$ref": "#/$defs/route_policy_mode" },
        "claimed_qualification": { "$ref": "#/$defs/qualification_class" },
        "run_state": { "$ref": "#/$defs/run_state" },
        "spend_ledger": { "$ref": "#/$defs/spend_ledger" },
        "quota_warning": { "$ref": "#/$defs/quota_warning_surface" },
        "ceilings": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/agent_ceiling" }
        },
        "downgrade_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_rule" }
        },
        "rollback_posture": { "$ref": "#/$defs/rollback_posture" },
        "rollback_verified": { "type": "boolean" },
        "evidence_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_freshness_slo_hours", "last_proof_refresh", "auto_narrow_on_stale"],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
