{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/implement-signed-and-shared-recipe-packs-safe-automation-graduation-and-preview-first-replay.schema.json",
  "title": "Aureline signed and shared recipe packs, safe automation graduation, and preview-first replay",
  "description": "Export-safe packet shipping user-authored automation into per-pack rows. Each row binds the signature and share-scope posture a signed, shareable recipe pack is distributed under, the automation authority it has graduated to, and a step disclosure for every effect it can produce. A pack carries a content-addressed manifest; a signed pack carries a publisher identity; a pack shared beyond a local workspace must be signed; a managed-channel pack must resolve to a managed or enterprise-gateway mode and carry organization authority. A pack with no authority may disclose no mutating effect; an irreversible publish requires an admin-gated or managed-template authority; a managed-only template authority must run on a managed mode. A mutating step must preview before it is replayed (preview-first replay), carry a real approval gate, and be audited, matching the bar a first-party command is held to; an irreversible external publish must be externally auditable; a declared reversibility must agree with the effect class; a blocked pack may not keep a public qualification; and a pack pending first-use review may not claim Stable. Raw shell fragments, raw filesystem paths, raw endpoint URLs, credential bodies, raw API keys, and OAuth tokens never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "catalogue_label",
    "packs",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "implement_signed_and_shared_recipe_packs_safe_automation_graduation_and_preview_first_replay"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "catalogue_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "packs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/recipe_pack_row"
      }
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "qualification_class": {
      "enum": ["stable", "beta", "preview", "experimental", "unavailable", "held"]
    },
    "downgrade_trigger": {
      "enum": [
        "proof_stale",
        "policy_blocked",
        "provider_unavailable",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "rollback_posture": {
      "enum": [
        "fully_reversible",
        "checkpoint_reversible",
        "evidence_preserved_no_revert",
        "not_applicable"
      ]
    },
    "route_policy_mode": {
      "enum": ["local", "byok", "managed", "enterprise_gateway"]
    },
    "publisher_source_class": {
      "enum": [
        "first_party_native_publisher",
        "signed_extension_publisher",
        "mcp_server_publisher",
        "user_registered_publisher",
        "enterprise_registered_publisher",
        "mocked_test_publisher"
      ]
    },
    "signature_class": {
      "enum": [
        "author_signature",
        "organization_signature_only",
        "managed_only_channel_signature",
        "author_and_organization_signature",
        "unsigned_local_only"
      ]
    },
    "share_scope_class": {
      "enum": [
        "user_scope_local_only",
        "workspace_scope_local_only",
        "organization_managed_channel",
        "portable_profile_export",
        "support_bundle_export"
      ]
    },
    "automation_authority_class": {
      "enum": [
        "inspect_only_no_authority",
        "local_reversible_only",
        "local_with_approval",
        "external_reversible_with_approval",
        "external_irreversible_admin_gated",
        "managed_only_template_authority"
      ]
    },
    "side_effect_class": {
      "enum": [
        "inspect_only",
        "local_reversible_edit",
        "local_destructive_edit",
        "credential_handle_projection",
        "privileged_inspection_attach",
        "external_reversible_comment",
        "external_irreversible_publish",
        "policy_or_trust_mutation",
        "capability_widening",
        "automation_admission_only"
      ]
    },
    "approval_posture_class": {
      "enum": [
        "allowed_without_prompt",
        "allowed_with_one_time_prompt",
        "allowed_with_per_session_prompt",
        "allowed_with_per_invocation_prompt",
        "requires_admin_approval",
        "denied_by_policy",
        "denied_by_workspace_trust",
        "denied_tool_not_admitted"
      ]
    },
    "replay_preview_class": {
      "enum": [
        "full_preview_before_replay",
        "diff_preview_before_replay",
        "dry_run_preview_before_replay",
        "inspect_only_no_preview_needed",
        "preview_unavailable_must_block"
      ]
    },
    "audit_class": {
      "enum": [
        "audited_to_run_record_timeline",
        "audited_to_support_export",
        "audited_local_history_only",
        "not_audited"
      ]
    },
    "reversibility_class": {
      "enum": [
        "no_side_effect",
        "reversible_in_workspace",
        "checkpoint_reversible",
        "irreversible_external_publish"
      ]
    },
    "state_class": {
      "enum": [
        "admitted",
        "pending_first_use_review",
        "policy_blocked",
        "trust_blocked",
        "quarantined_signature",
        "withdrawn"
      ]
    },
    "step_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "side_effect_class",
        "replay_preview",
        "approval_posture",
        "audit",
        "reversibility",
        "disclosure_label"
      ],
      "properties": {
        "side_effect_class": {
          "$ref": "#/$defs/side_effect_class"
        },
        "replay_preview": {
          "$ref": "#/$defs/replay_preview_class"
        },
        "approval_posture": {
          "$ref": "#/$defs/approval_posture_class"
        },
        "audit": {
          "$ref": "#/$defs/audit_class"
        },
        "reversibility": {
          "$ref": "#/$defs/reversibility_class"
        },
        "disclosure_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger", "narrowed_to", "auto_enforced", "rationale"],
      "properties": {
        "trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "narrowed_to": {
          "$ref": "#/$defs/qualification_class"
        },
        "auto_enforced": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    },
    "recipe_pack_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pack_id",
        "pack_label",
        "pack_family_label",
        "pack_version",
        "manifest_content_address",
        "publisher_source_class",
        "signature_class",
        "share_scope_class",
        "resolved_mode",
        "automation_authority_class",
        "state",
        "claimed_qualification",
        "step_disclosures",
        "downgrade_rules",
        "rollback_posture",
        "rollback_verified",
        "evidence_packet_refs",
        "explanation_label"
      ],
      "properties": {
        "pack_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pack_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pack_family_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pack_version": {
          "$ref": "#/$defs/non_empty_string"
        },
        "manifest_content_address": {
          "$ref": "#/$defs/non_empty_string"
        },
        "descriptor_pack_ref": {
          "type": "string"
        },
        "publisher_source_class": {
          "$ref": "#/$defs/publisher_source_class"
        },
        "publisher_identity_ref": {
          "type": "string"
        },
        "signature_class": {
          "$ref": "#/$defs/signature_class"
        },
        "share_scope_class": {
          "$ref": "#/$defs/share_scope_class"
        },
        "resolved_mode": {
          "$ref": "#/$defs/route_policy_mode"
        },
        "automation_authority_class": {
          "$ref": "#/$defs/automation_authority_class"
        },
        "state": {
          "$ref": "#/$defs/state_class"
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "step_disclosures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/step_disclosure"
          }
        },
        "downgrade_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_rule"
          }
        },
        "rollback_posture": {
          "$ref": "#/$defs/rollback_posture"
        },
        "rollback_verified": {
          "type": "boolean"
        },
        "evidence_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "explanation_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
