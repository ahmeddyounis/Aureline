{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/ship-provider-and-model-graduation-packets-rollout-rings-and-kill-switch-or-backout-paths.schema.json",
  "title": "Aureline provider/model graduation packets, rollout rings, and kill-switch or backout paths",
  "description": "Export-safe packet materializing the provider/model graduation surface into per-route rows. Each route binds its provider, model, claimed qualification, current rollout ring, ring progress state, a provider-neutral kill switch, and a backout path, plus a closed set of downgrade rules that narrow the claim. Every route's kill switch must fail closed, a claimed route's kill switch must be armed or fired, a claimed broad-exposure route must carry a verified reversing backout path, a route at general availability must claim Stable, and a kill-switched or backed-out route may not keep claiming Stable. Raw provider endpoints, credential bodies, raw provider payloads, exact spend values, and internal kill-switch tokens never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "catalogue_label",
    "routes",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "ship_provider_and_model_graduation_packets_rollout_rings_and_kill_switch_or_backout_paths"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "catalogue_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/graduation_route_row"
      }
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "qualification_class": {
      "enum": ["stable", "beta", "preview", "experimental", "unavailable", "held"]
    },
    "rollback_posture": {
      "enum": [
        "fully_reversible",
        "checkpoint_reversible",
        "evidence_preserved_no_revert",
        "not_applicable"
      ]
    },
    "downgrade_trigger": {
      "enum": [
        "proof_stale",
        "policy_blocked",
        "provider_unavailable",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "rollout_ring": {
      "enum": ["internal", "canary", "early_access", "broad", "general_availability"]
    },
    "ring_progress_state": {
      "enum": ["pending", "rolling", "held", "complete", "kill_switched", "backed_out"]
    },
    "kill_switch_scope": {
      "enum": ["route_scoped", "model_scoped", "provider_scoped", "global_all_routes"]
    },
    "kill_switch_state": {
      "enum": ["not_armed", "armed", "fired"]
    },
    "kill_switch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "state", "fails_closed", "label"],
      "properties": {
        "scope": { "$ref": "#/$defs/kill_switch_scope" },
        "state": { "$ref": "#/$defs/kill_switch_state" },
        "fails_closed": { "type": "boolean" },
        "label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "backout_path": {
      "type": "object",
      "additionalProperties": false,
      "required": ["posture", "verified", "label"],
      "properties": {
        "posture": { "$ref": "#/$defs/rollback_posture" },
        "verified": { "type": "boolean" },
        "label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger", "narrowed_to", "auto_enforced", "rationale"],
      "properties": {
        "trigger": { "$ref": "#/$defs/downgrade_trigger" },
        "narrowed_to": { "$ref": "#/$defs/qualification_class" },
        "auto_enforced": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "graduation_route_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_id",
        "provider_id",
        "model_id",
        "route_label",
        "claimed_qualification",
        "current_ring",
        "ring_state",
        "kill_switch",
        "backout",
        "downgrade_rules",
        "evidence_packet_refs"
      ],
      "properties": {
        "route_id": { "$ref": "#/$defs/non_empty_string" },
        "provider_id": { "$ref": "#/$defs/non_empty_string" },
        "model_id": { "$ref": "#/$defs/non_empty_string" },
        "route_label": { "$ref": "#/$defs/non_empty_string" },
        "claimed_qualification": { "$ref": "#/$defs/qualification_class" },
        "current_ring": { "$ref": "#/$defs/rollout_ring" },
        "ring_state": { "$ref": "#/$defs/ring_progress_state" },
        "kill_switch": { "$ref": "#/$defs/kill_switch" },
        "backout": { "$ref": "#/$defs/backout_path" },
        "downgrade_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_rule" }
        },
        "evidence_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_freshness_slo_hours", "last_proof_refresh", "auto_narrow_on_stale"],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
