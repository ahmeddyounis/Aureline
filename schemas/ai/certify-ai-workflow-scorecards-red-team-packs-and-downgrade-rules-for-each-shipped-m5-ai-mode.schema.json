{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/certify-ai-workflow-scorecards-red-team-packs-and-downgrade-rules-for-each-shipped-m5-ai-mode.schema.json",
  "title": "Aureline M5 AI mode certification of scorecards, red-team packs, and downgrade rules",
  "description": "Export-safe packet certifying every shipped M5 AI mode. Each mode binds its claimed qualification, a workflow scorecard scored against fixed thresholds, a red-team pack whose required attack vectors must be handled, and a closed set of downgrade rules that narrow the claim. The packet reuses the frozen M5 AI workflow matrix qualification and downgrade vocabularies. Raw prompt bodies, raw diffs, raw provider payloads, credentials, exact token counts, and exact cost amounts never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "certification_label",
    "mode_certifications",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "certify_ai_workflow_scorecards_red_team_packs_and_downgrade_rules_for_each_shipped_m5_ai_mode"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "certification_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "mode_certifications": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "$ref": "#/$defs/mode_certification"
      }
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "mode": {
      "type": "string",
      "enum": [
        "inline_edit",
        "patch_review",
        "explain",
        "debug",
        "test",
        "refactor",
        "branch_or_worktree_agent"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "scorecard_dimension": {
      "type": "string",
      "enum": [
        "evidence_integrity",
        "context_visibility",
        "scope_honesty",
        "approval_gating",
        "rollback_safety",
        "provider_trust_disclosure",
        "omitted_context_disclosure"
      ]
    },
    "scorecard_status": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "red_team_vector": {
      "type": "string",
      "enum": [
        "prompt_injection",
        "tainted_context_exfiltration",
        "scope_escape",
        "self_approved_mutation",
        "worktree_isolation_bypass",
        "unreviewed_apply",
        "credential_leak_in_export",
        "stale_evidence_promotion"
      ]
    },
    "red_team_handling": {
      "type": "string",
      "enum": [
        "blocked",
        "mitigated",
        "not_applicable"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "provider_unavailable",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "scorecard_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension",
        "score",
        "threshold",
        "status"
      ],
      "properties": {
        "dimension": {
          "$ref": "#/$defs/scorecard_dimension"
        },
        "score": {
          "$ref": "#/$defs/score"
        },
        "threshold": {
          "$ref": "#/$defs/score"
        },
        "status": {
          "$ref": "#/$defs/scorecard_status"
        }
      }
    },
    "red_team_scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vector",
        "handling",
        "guard_ref"
      ],
      "properties": {
        "vector": {
          "$ref": "#/$defs/red_team_vector"
        },
        "handling": {
          "$ref": "#/$defs/red_team_handling"
        },
        "guard_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger",
        "narrowed_to",
        "auto_enforced",
        "rationale"
      ],
      "properties": {
        "trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "narrowed_to": {
          "$ref": "#/$defs/qualification_class"
        },
        "auto_enforced": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "mode_certification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "claimed_qualification",
        "scope_summary",
        "scorecard",
        "red_team_pack",
        "downgrade_rules",
        "evidence_packet_refs"
      ],
      "properties": {
        "mode": {
          "$ref": "#/$defs/mode"
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "scope_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "scorecard": {
          "type": "array",
          "minItems": 7,
          "items": {
            "$ref": "#/$defs/scorecard_row"
          }
        },
        "red_team_pack": {
          "type": "array",
          "minItems": 8,
          "items": {
            "$ref": "#/$defs/red_team_scenario"
          }
        },
        "downgrade_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_rule"
          }
        },
        "evidence_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
