{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/tainted_context.schema.json",
  "title": "Aureline AI tainted-context beta support packet",
  "$comment": "Rust owner: aureline_ai::tainted_context::TaintedContextBetaPacket.",
  "description": "Boundary schema for the metadata-only support packet that joins tainted context labels, suspicious-content detector tokens, policy narrowing decisions, explicit approval fences, and surface parity for claimed AI beta rows. The packet contains refs, enum tokens, labels, and audit refs only. It never carries raw prompt bodies, source file bodies, terminal bodies, tool return bodies, provider payloads, endpoint URLs, credentials, raw paths, raw token counts, or billing-account ids.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "display_label",
    "context_snapshot_ref",
    "evidence_packet_ref",
    "retrieval_packet_ref",
    "required_effective_mode_tokens",
    "observed_effective_mode_tokens",
    "source_rows",
    "narrowing_decisions",
    "approval_fences",
    "surface_rows",
    "source_contract_refs",
    "json_export_ref",
    "markdown_summary_ref",
    "policy_context",
    "promotion_gate_class",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "tainted_context_beta_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "$ref": "#/$defs/opaque_ref" },
    "workflow_or_surface_id": { "$ref": "#/$defs/opaque_ref" },
    "display_label": { "$ref": "#/$defs/review_label" },
    "context_snapshot_ref": { "$ref": "#/$defs/opaque_ref" },
    "evidence_packet_ref": { "$ref": "#/$defs/opaque_ref" },
    "retrieval_packet_ref": { "$ref": "#/$defs/opaque_ref" },
    "required_effective_mode_tokens": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/run_mode_class" },
      "allOf": [
        { "contains": { "const": "explain_only" } },
        { "contains": { "const": "local_only" } },
        { "contains": { "const": "preview_only" } },
        { "contains": { "const": "blocked" } }
      ]
    },
    "observed_effective_mode_tokens": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/run_mode_class" },
      "allOf": [
        { "contains": { "const": "explain_only" } },
        { "contains": { "const": "local_only" } },
        { "contains": { "const": "preview_only" } },
        { "contains": { "const": "blocked" } }
      ]
    },
    "source_rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source_row" }
    },
    "narrowing_decisions": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/narrowing_decision" }
    },
    "approval_fences": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/approval_fence" }
    },
    "surface_rows": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/surface_row" }
    },
    "source_contract_refs": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/repo_ref" },
      "allOf": [
        { "contains": { "const": "docs/ai/m3/tainted_context_beta.md" } },
        { "contains": { "const": "schemas/ai/tainted_context.schema.json" } },
        { "contains": { "const": "docs/ai/prompt_injection_and_taint_contract.md" } },
        { "contains": { "const": "docs/ai/context_assembly_contract.md" } }
      ]
    },
    "json_export_ref": { "$ref": "#/$defs/repo_ref" },
    "markdown_summary_ref": { "$ref": "#/$defs/repo_ref" },
    "policy_context": { "$ref": "#/$defs/policy_context" },
    "promotion_gate_class": {
      "type": "string",
      "enum": ["promotable", "blocked_by_truth_drift"]
    },
    "minted_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "://" },
          { "pattern": "[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]" },
          { "pattern": "[Oo][Aa][Uu][Tt][Hh][_-]?[Tt][Oo][Kk][Ee][Nn]" },
          { "pattern": "[Bb][Ee][Aa][Rr][Ee][Rr] " },
          { "pattern": "[Bb][Ii][Ll][Ll][Ii][Nn][Gg]-[Aa][Cc][Cc][Oo][Uu][Nn][Tt]" },
          { "pattern": "[Rr][Aa][Ww][_-]?[Bb][Oo][Dd][Yy]" },
          { "pattern": "[Rr][Aa][Ww][_-]?[Pp][Rr][Oo][Mm][Pp][Tt]" }
        ]
      }
    },
    "repo_ref": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "://" }
    },
    "review_label": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "://" },
          { "pattern": "[Bb][Ee][Aa][Rr][Ee][Rr] " },
          { "pattern": "[Rr][Aa][Ww][_-]?[Pp][Rr][Oo][Mm][Pp][Tt]" }
        ]
      }
    },
    "run_mode_class": {
      "type": "string",
      "enum": ["full_run", "explain_only", "local_only", "preview_only", "blocked"]
    },
    "input_source_class": {
      "type": "string",
      "enum": [
        "repository_workspace_content",
        "workspace_search_result",
        "terminal_command_output",
        "log_capture",
        "tool_call_external_response",
        "mcp_server_response",
        "web_search_result",
        "external_docs_excerpt",
        "connected_provider_payload",
        "extension_proposed_input",
        "user_supplied_paste",
        "ai_prior_turn_response",
        "policy_quarantined_source",
        "unknown_unclassified_source"
      ]
    },
    "taint_class": {
      "type": "string",
      "enum": [
        "trusted_first_party_data",
        "tainted_evidence",
        "policy_quarantined",
        "unknown_must_treat_as_tainted"
      ]
    },
    "origin_locus_class": {
      "type": "string",
      "enum": [
        "local_in_process",
        "local_subprocess_same_device",
        "local_sandboxed_container_same_device",
        "remote_vendor_managed_service",
        "remote_self_hosted_service",
        "enterprise_gateway_brokered_service",
        "extension_provided_locus",
        "unknown_locus_must_be_disclosed"
      ]
    },
    "reason_class": {
      "type": "string",
      "enum": [
        "external_source",
        "runtime_or_tool_output",
        "suspicious_content",
        "imperative_text_detected",
        "authorization_or_widening_attempt",
        "policy_quarantined",
        "unknown_unclassified",
        "partial_or_stale_retrieval"
      ]
    },
    "retrieval_truth_class": {
      "type": "string",
      "enum": ["not_applicable", "promotable", "partial_index", "stale", "provider_unavailable"]
    },
    "policy_narrowing_class": {
      "type": "string",
      "enum": [
        "no_narrowing",
        "narrowed_to_explain_only",
        "narrowed_to_local_only",
        "narrowed_to_preview_only",
        "blocked_by_policy"
      ]
    },
    "approval_requirement_class": {
      "type": "string",
      "enum": [
        "no_approval_required_explain_only",
        "fresh_approval_required_after_tainted_input",
        "preview_requires_approval_before_apply",
        "mutation_blocked_no_approval_path"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "composer",
        "context_inspector",
        "review_workspace",
        "docs_help",
        "support_export",
        "cli"
      ]
    },
    "source_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "segment_ref",
        "input_source_class",
        "taint_class",
        "origin_locus_class",
        "reason_classes",
        "suspicious_finding_count",
        "retrieval_truth_class",
        "fence_ref",
        "fence_strategy_token",
        "usage_constraint_tokens",
        "user_visible_explanation_label",
        "raw_body_forbidden"
      ],
      "properties": {
        "source_ref": { "$ref": "#/$defs/opaque_ref" },
        "segment_ref": { "$ref": "#/$defs/opaque_ref" },
        "input_source_class": { "$ref": "#/$defs/input_source_class" },
        "taint_class": { "$ref": "#/$defs/taint_class" },
        "origin_locus_class": { "$ref": "#/$defs/origin_locus_class" },
        "reason_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reason_class" }
        },
        "suspicious_detector_outcome_token": {
          "type": "string",
          "enum": ["allow", "sanitize", "isolate", "block", "route_to_system_browser"]
        },
        "suspicious_content_tokens": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "bidi_control",
              "invisible_formatting",
              "mixed_script_confusable",
              "whole_script_confusable",
              "raw_rendered_divergence"
            ]
          }
        },
        "suspicious_finding_count": { "type": "integer", "minimum": 0 },
        "retrieval_truth_class": { "$ref": "#/$defs/retrieval_truth_class" },
        "retrieval_truth_label": { "$ref": "#/$defs/review_label" },
        "fence_ref": { "$ref": "#/$defs/opaque_ref" },
        "fence_strategy_token": {
          "type": "string",
          "enum": [
            "instruction_stripped",
            "quoted_as_data_only",
            "summary_only_no_body",
            "metadata_only_no_content",
            "citation_reference_only"
          ]
        },
        "usage_constraint_tokens": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "must_not_gain_tool_permission",
              "must_not_escalate_scope",
              "must_not_mint_citations",
              "must_not_override_instruction_bundle",
              "must_not_publish_externally",
              "must_not_commit_to_repo",
              "must_not_dispatch_branch_agent",
              "must_not_route_to_higher_cost_tier",
              "must_preserve_fence_in_downstream_packet"
            ]
          }
        },
        "user_visible_explanation_label": { "$ref": "#/$defs/review_label" },
        "raw_body_forbidden": { "const": true }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "reason_classes": { "contains": { "const": "suspicious_content" } }
            },
            "required": ["reason_classes"]
          },
          "then": {
            "required": ["suspicious_detector_outcome_token", "suspicious_content_tokens"],
            "properties": {
              "suspicious_finding_count": { "type": "integer", "minimum": 1 },
              "suspicious_content_tokens": { "minItems": 1 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "retrieval_truth_class": {
                "enum": ["partial_index", "stale", "provider_unavailable"]
              }
            },
            "required": ["retrieval_truth_class"]
          },
          "then": { "required": ["retrieval_truth_label"] }
        }
      ]
    },
    "narrowing_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_ref",
        "requested_mode_class",
        "effective_mode_class",
        "policy_narrowing_class",
        "source_refs",
        "narrowed_authority_tokens",
        "approval_fence_ref",
        "approval_requirement_class",
        "user_visible_reason_label"
      ],
      "properties": {
        "decision_ref": { "$ref": "#/$defs/opaque_ref" },
        "requested_mode_class": { "$ref": "#/$defs/run_mode_class" },
        "effective_mode_class": { "$ref": "#/$defs/run_mode_class" },
        "policy_narrowing_class": { "$ref": "#/$defs/policy_narrowing_class" },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "narrowed_authority_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "denied_capability_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "approval_fence_ref": { "$ref": "#/$defs/opaque_ref" },
        "approval_requirement_class": { "$ref": "#/$defs/approval_requirement_class" },
        "user_visible_reason_label": { "$ref": "#/$defs/review_label" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "effective_mode_class": { "const": "blocked" } },
            "required": ["effective_mode_class"]
          },
          "then": {
            "required": ["denied_capability_tokens"],
            "properties": { "denied_capability_tokens": { "minItems": 1 } }
          }
        }
      ]
    },
    "approval_fence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_fence_ref",
        "decision_ref",
        "source_refs",
        "approval_requirement_class",
        "audit_event_refs",
        "blocks_hidden_provider_write",
        "auditable",
        "user_visible_explanation_label"
      ],
      "properties": {
        "approval_fence_ref": { "$ref": "#/$defs/opaque_ref" },
        "decision_ref": { "$ref": "#/$defs/opaque_ref" },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "approval_requirement_class": { "$ref": "#/$defs/approval_requirement_class" },
        "approval_ticket_ref": { "$ref": "#/$defs/opaque_ref" },
        "audit_event_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "prompt_injection_evaluation_ref": { "$ref": "#/$defs/opaque_ref" },
        "blocks_hidden_provider_write": { "const": true },
        "auditable": { "const": true },
        "user_visible_explanation_label": { "$ref": "#/$defs/review_label" }
      }
    },
    "surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "projection_ref",
        "packet_ref",
        "source_refs_visible",
        "narrowing_decision_refs_visible",
        "approval_fence_refs_visible",
        "raw_private_material_excluded",
        "preserves_operator_truth",
        "supports_json_export",
        "supports_markdown_summary"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "projection_ref": { "$ref": "#/$defs/opaque_ref" },
        "packet_ref": { "$ref": "#/$defs/opaque_ref" },
        "source_refs_visible": { "const": true },
        "narrowing_decision_refs_visible": { "const": true },
        "approval_fence_refs_visible": { "const": true },
        "raw_private_material_excluded": { "const": true },
        "preserves_operator_truth": { "const": true },
        "supports_json_export": { "const": true },
        "supports_markdown_summary": { "type": "boolean" }
      }
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_epoch_ref",
        "trust_state",
        "deployment_profile_class",
        "execution_context_ref"
      ],
      "properties": {
        "policy_epoch_ref": { "$ref": "#/$defs/opaque_ref" },
        "trust_state": { "type": "string", "enum": ["trusted", "restricted"] },
        "deployment_profile_class": {
          "type": "string",
          "enum": ["individual_local", "self_hosted", "managed_cloud", "managed_fleet", "air_gapped"]
        },
        "execution_context_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    }
  }
}
