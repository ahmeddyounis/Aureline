{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/certify-local-model-provider-recipe-connector-and-spend-governance-lanes-on-every-claimed-m5-profile.schema.json",
  "title": "Aureline M5 lane certification of local-model, provider, recipe, connector, and spend-governance lanes on every claimed profile",
  "description": "Export-safe packet certifying the local-model, provider, recipe, connector, and spend-governance lanes on every claimed M5 profile. Each lane binds its claimed qualification, the per-profile coverage that says where the lane is claimed across the local-only, BYOK-direct, managed-hosted, offline-mirror, and hybrid-managed families and how each claim discloses provider, model, locality, region, retention, cost owner, tool side-effect class, and automation authority, a disclosure scorecard scored against fixed thresholds, and a closed set of downgrade rules that narrow the claim. The packet reuses the frozen M5 AI workflow matrix qualification and downgrade vocabularies, the routing-policy execution-mode vocabulary, the tool-gateway side-effect vocabulary, and the recipe-pack automation-authority vocabulary. Raw prompt bodies, raw diffs, raw provider payloads, credentials, exact token counts, exact cost amounts, and raw endpoint URLs never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "certification_label",
    "lane_certifications",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "certify_local_model_provider_recipe_connector_and_spend_governance_lanes_on_every_claimed_m5_profile"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "certification_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "lane_certifications": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/lane_certification"
      }
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "lane": {
      "type": "string",
      "enum": [
        "local_model_pack",
        "provider_routing",
        "recipe_automation",
        "external_connector",
        "spend_governance"
      ]
    },
    "profile": {
      "type": "string",
      "enum": [
        "local_only",
        "byok_direct",
        "managed_hosted",
        "offline_mirror",
        "hybrid_managed"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "local",
        "byok",
        "managed",
        "enterprise_gateway"
      ]
    },
    "side_effect_class": {
      "type": "string",
      "enum": [
        "inspect_only",
        "local_reversible_edit",
        "local_destructive_edit",
        "credential_handle_projection",
        "privileged_inspection_attach",
        "external_reversible_comment",
        "external_irreversible_publish",
        "policy_or_trust_mutation",
        "capability_widening",
        "automation_admission_only"
      ]
    },
    "automation_authority_class": {
      "type": "string",
      "enum": [
        "inspect_only_no_authority",
        "local_reversible_only",
        "local_with_approval",
        "external_reversible_with_approval",
        "external_irreversible_admin_gated",
        "managed_only_template_authority"
      ]
    },
    "disclosure_dimension": {
      "type": "string",
      "enum": [
        "provider_identity",
        "model_route",
        "execution_locality",
        "region_residency",
        "retention_posture",
        "cost_budget_owner",
        "tool_side_effect",
        "automation_authority"
      ]
    },
    "disclosure_status": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "provider_unavailable",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "disclosure_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension",
        "score",
        "threshold",
        "status"
      ],
      "properties": {
        "dimension": {
          "$ref": "#/$defs/disclosure_dimension"
        },
        "score": {
          "$ref": "#/$defs/score"
        },
        "threshold": {
          "$ref": "#/$defs/score"
        },
        "status": {
          "$ref": "#/$defs/disclosure_status"
        }
      }
    },
    "profile_coverage_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "claimed_on_profile",
        "profile_qualification",
        "execution_mode",
        "provider_disclosed",
        "model_route_disclosed",
        "region_disclosed",
        "retention_disclosed",
        "cost_owner_disclosed",
        "side_effect_class",
        "automation_authority",
        "managed_claim_within_qualified_family"
      ],
      "properties": {
        "profile": {
          "$ref": "#/$defs/profile"
        },
        "claimed_on_profile": {
          "type": "boolean"
        },
        "profile_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "execution_mode": {
          "$ref": "#/$defs/execution_mode"
        },
        "provider_disclosed": {
          "type": "boolean"
        },
        "model_route_disclosed": {
          "type": "boolean"
        },
        "region_disclosed": {
          "type": "boolean"
        },
        "retention_disclosed": {
          "type": "boolean"
        },
        "cost_owner_disclosed": {
          "type": "boolean"
        },
        "side_effect_class": {
          "$ref": "#/$defs/side_effect_class"
        },
        "automation_authority": {
          "$ref": "#/$defs/automation_authority_class"
        },
        "managed_claim_within_qualified_family": {
          "type": "boolean"
        }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger",
        "narrowed_to",
        "auto_enforced",
        "rationale"
      ],
      "properties": {
        "trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "narrowed_to": {
          "$ref": "#/$defs/qualification_class"
        },
        "auto_enforced": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "lane_certification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane",
        "claimed_qualification",
        "scope_summary",
        "profile_coverage",
        "disclosure_scorecard",
        "downgrade_rules",
        "evidence_packet_refs"
      ],
      "properties": {
        "lane": {
          "$ref": "#/$defs/lane"
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "scope_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "profile_coverage": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "$ref": "#/$defs/profile_coverage_row"
          }
        },
        "disclosure_scorecard": {
          "type": "array",
          "minItems": 8,
          "items": {
            "$ref": "#/$defs/disclosure_row"
          }
        },
        "downgrade_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_rule"
          }
        },
        "evidence_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
