{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/ship-admin-controls-for-provider-allowlists-retention-classes-region-gates-and-model-deprecation.schema.json",
  "title": "Aureline admin controls for provider allowlists, retention classes, region gates, and model deprecation",
  "description": "Export-safe packet carrying operator-set governance over AI providers and models in per-control rows. Each row binds the provider (and, for a model-deprecation control, the model) it governs, a typed directive that says what the control does, the scope and state it is enforced under, the admin authority that set it, and downgrade rules that narrow the claim. Four control families share one row shape: a provider allowlist allows, conditionally allows, denies, or holds a provider; a retention-class floor sets the minimum disclosed retention posture a route may carry; a region gate names the disclosed region posture (and, when pinned, the concrete region tags) a route may run in; a model deprecation moves a named model through its lifecycle and names a migration path. The packet never hides cost, provider, region, retention, or automation authority behind generic language. A control that denies, blocks, or retires what it governs carries a real admin gate, is audited, and is actually live rather than a silent draft while claiming a public qualification. A control blocked by a higher-tier policy, or a provider allowlist still pending review, narrows its claim instead of keeping a Stable, Beta, or Preview label. Every row carries downgrade rules including the proof-stale and provider-unavailable triggers, each narrowing below the claimed qualification. Provider endpoints, credential bodies, raw API keys, OAuth tokens, and raw provider payloads never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "catalogue_label",
    "controls",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "ship_admin_controls_for_provider_allowlists_retention_classes_region_gates_and_model_deprecation"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "catalogue_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/admin_control_row"
      }
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "qualification_class": {
      "enum": ["stable", "beta", "preview", "experimental", "unavailable", "held"]
    },
    "downgrade_trigger": {
      "enum": [
        "proof_stale",
        "policy_blocked",
        "provider_unavailable",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "rollback_posture": {
      "enum": [
        "fully_reversible",
        "checkpoint_reversible",
        "evidence_preserved_no_revert",
        "not_applicable"
      ]
    },
    "execution_mode_class": {
      "enum": ["local", "byok", "managed"]
    },
    "region_class": {
      "enum": [
        "on_device_only",
        "single_region_pinned",
        "multi_region_pinned",
        "vendor_default_unpinned",
        "unknown_unverified",
        "policy_blocked"
      ]
    },
    "retention_class": {
      "enum": [
        "no_retention_local_only",
        "no_retention_promised",
        "bounded_retention_operator_only",
        "bounded_retention_with_export",
        "unbounded_retention_not_trained",
        "unbounded_retention_used_for_training",
        "unknown_unverified",
        "policy_blocked"
      ]
    },
    "approval_posture_class": {
      "enum": [
        "allowed_without_prompt",
        "allowed_with_one_time_prompt",
        "allowed_with_per_session_prompt",
        "allowed_with_per_invocation_prompt",
        "requires_admin_approval",
        "denied_by_policy",
        "denied_by_workspace_trust",
        "denied_tool_not_admitted"
      ]
    },
    "allowlist_decision_class": {
      "enum": [
        "provider_allowed",
        "provider_allowed_with_conditions",
        "provider_denied_by_policy",
        "provider_pending_review"
      ]
    },
    "model_lifecycle_stage_class": {
      "enum": [
        "generally_available",
        "deprecation_announced",
        "deprecated_sunset_scheduled",
        "blocked_new_sessions",
        "retired_removed"
      ]
    },
    "enforcement_scope_class": {
      "enum": [
        "organisation_wide",
        "tenant_scoped",
        "workspace_scoped",
        "deployment_profile_scoped"
      ]
    },
    "enforcement_state_class": {
      "enum": [
        "enforced_active",
        "enforced_monitor_only",
        "staged_pending_activation",
        "rolled_back",
        "superseded_by_newer_control",
        "draft_not_enforced",
        "blocked_by_higher_policy"
      ]
    },
    "provider_allowlist_directive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "decision", "decision_label"],
      "properties": {
        "kind": {
          "const": "provider_allowlist"
        },
        "decision": {
          "$ref": "#/$defs/allowlist_decision_class"
        },
        "decision_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "retention_floor_directive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "required_floor", "denies_below_floor", "floor_label"],
      "properties": {
        "kind": {
          "const": "retention_floor"
        },
        "required_floor": {
          "$ref": "#/$defs/retention_class"
        },
        "denies_below_floor": {
          "type": "boolean"
        },
        "floor_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "region_gate_directive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "allowed_region_posture", "denies_outside_gate", "gate_label"],
      "properties": {
        "kind": {
          "const": "region_gate"
        },
        "allowed_region_posture": {
          "$ref": "#/$defs/region_class"
        },
        "allowed_region_tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "denies_outside_gate": {
          "type": "boolean"
        },
        "gate_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "model_deprecation_directive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "lifecycle_stage", "stage_label"],
      "properties": {
        "kind": {
          "const": "model_deprecation"
        },
        "lifecycle_stage": {
          "$ref": "#/$defs/model_lifecycle_stage_class"
        },
        "sunset_date": {
          "type": "string"
        },
        "replacement_model_ref": {
          "type": "string"
        },
        "migration_path_ref": {
          "type": "string"
        },
        "stage_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "admin_control_directive": {
      "oneOf": [
        {
          "$ref": "#/$defs/provider_allowlist_directive"
        },
        {
          "$ref": "#/$defs/retention_floor_directive"
        },
        {
          "$ref": "#/$defs/region_gate_directive"
        },
        {
          "$ref": "#/$defs/model_deprecation_directive"
        }
      ]
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger", "narrowed_to", "auto_enforced", "rationale"],
      "properties": {
        "trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "narrowed_to": {
          "$ref": "#/$defs/qualification_class"
        },
        "auto_enforced": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    },
    "admin_control_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_id",
        "control_label",
        "control_family_label",
        "target_provider_id",
        "target_provider_label",
        "governed_execution_mode",
        "directive",
        "enforcement_scope",
        "enforcement_state",
        "admin_authority",
        "audited",
        "claimed_qualification",
        "downgrade_rules",
        "rollback_posture",
        "rollback_verified",
        "evidence_packet_refs",
        "explanation_label"
      ],
      "properties": {
        "control_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "control_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "control_family_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_provider_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_provider_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_model_id": {
          "type": "string"
        },
        "governed_execution_mode": {
          "$ref": "#/$defs/execution_mode_class"
        },
        "directive": {
          "$ref": "#/$defs/admin_control_directive"
        },
        "enforcement_scope": {
          "$ref": "#/$defs/enforcement_scope_class"
        },
        "enforcement_state": {
          "$ref": "#/$defs/enforcement_state_class"
        },
        "admin_authority": {
          "$ref": "#/$defs/approval_posture_class"
        },
        "admin_identity_ref": {
          "type": "string"
        },
        "audited": {
          "type": "boolean"
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "downgrade_rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/downgrade_rule"
          }
        },
        "rollback_posture": {
          "$ref": "#/$defs/rollback_posture"
        },
        "rollback_verified": {
          "type": "boolean"
        },
        "evidence_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "explanation_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
