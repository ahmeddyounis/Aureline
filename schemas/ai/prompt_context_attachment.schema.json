{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/prompt_context_attachment.schema.json",
  "title": "Aureline prompt-composer context attachment",
  "$comment": "Rust owner: aureline_ai::prompt_composer::PromptContextAttachment.",
  "description": "Boundary schema for a typed prompt-composer attachment pill. The record preserves stable object identity, source class, freshness, trust, preview/open/remove actions, and keyboard reachability. It carries ids and review labels only; raw prompt text, file bodies, terminal bodies, URLs, provider payloads, and credential material never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "attachment_id",
    "kind",
    "source_class",
    "stable_object_ref",
    "freshness_class",
    "trust_posture",
    "selection_reason",
    "status",
    "context_state",
    "display_label",
    "estimated_byte_size",
    "preview_action_ref",
    "open_action_ref",
    "remove_action_ref",
    "keyboard_reachable",
    "removable"
  ],
  "properties": {
    "attachment_id": { "$ref": "#/$defs/opaque_ref" },
    "kind": { "$ref": "#/$defs/attachment_kind" },
    "source_class": { "$ref": "#/$defs/source_class" },
    "stable_object_ref": { "$ref": "#/$defs/opaque_ref" },
    "freshness_class": { "$ref": "#/$defs/freshness_class" },
    "trust_posture": { "$ref": "#/$defs/trust_posture" },
    "selection_reason": { "$ref": "#/$defs/selection_reason" },
    "status": { "$ref": "#/$defs/attachment_status" },
    "context_state": { "$ref": "#/$defs/context_state" },
    "display_label": { "$ref": "#/$defs/review_label" },
    "estimated_byte_size": { "type": "integer", "minimum": 0 },
    "preview_action_ref": { "$ref": "#/$defs/action_ref" },
    "open_action_ref": { "$ref": "#/$defs/action_ref" },
    "remove_action_ref": { "$ref": "#/$defs/action_ref" },
    "keyboard_reachable": { "const": true },
    "removable": { "const": true }
  },
  "$defs": {
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "://" },
          { "pattern": "[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]" },
          { "pattern": "[Oo][Aa][Uu][Tt][Hh][_-]?[Tt][Oo][Kk][Ee][Nn]" },
          { "pattern": "[Bb][Ee][Aa][Rr][Ee][Rr] " }
        ]
      }
    },
    "review_label": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "://" },
          { "pattern": "[Rr][Aa][Ww]_[Pp][Rr][Oo][Mm][Pp][Tt]" },
          { "pattern": "[Bb][Ee][Aa][Rr][Ee][Rr] " }
        ]
      }
    },
    "action_ref": {
      "type": "string",
      "pattern": "^action:prompt-composer\\.",
      "not": { "pattern": "://" }
    },
    "attachment_kind": {
      "type": "string",
      "enum": [
        "user_supplied_text",
        "user_supplied_file",
        "workspace_slice_bundle",
        "retrieved_document",
        "terminal_log_capture",
        "citation_anchor_bundle",
        "diagnostic_bundle"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "workspace_file_slice",
        "workspace_symbol",
        "workspace_buffer_slice",
        "workspace_search_result",
        "workspace_diagnostics",
        "docs_pack_excerpt",
        "terminal_transcript_excerpt",
        "user_supplied_text",
        "user_supplied_file",
        "citation_anchor_quote"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "stale",
        "changed_since_pin",
        "unverified"
      ]
    },
    "trust_posture": {
      "type": "string",
      "enum": [
        "trusted_first_party",
        "reviewed_derived",
        "unreviewed_derived",
        "untrusted_user_supplied",
        "untrusted_external",
        "untrusted_extension_proposed",
        "policy_quarantined"
      ]
    },
    "selection_reason": {
      "type": "string",
      "enum": [
        "user_pinned",
        "mention_trail",
        "slash_command_requested",
        "search_result_packet",
        "citation_anchor_excerpt",
        "diagnostic_context",
        "terminal_capture_attached",
        "user_pasted_freeform_text"
      ]
    },
    "attachment_status": {
      "type": "string",
      "enum": [
        "live",
        "stale",
        "tainted_outside_fenced_section",
        "over_budget",
        "policy_blocked",
        "out_of_scope"
      ]
    },
    "context_state": {
      "type": "string",
      "enum": [
        "included",
        "pinned",
        "omitted",
        "blocked",
        "stale",
        "tainted",
        "summarized",
        "trimmed",
        "not_requested"
      ]
    }
  }
}
