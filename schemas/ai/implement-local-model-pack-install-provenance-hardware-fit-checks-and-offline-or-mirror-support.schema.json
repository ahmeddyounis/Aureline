{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/implement-local-model-pack-install-provenance-hardware-fit-checks-and-offline-or-mirror-support.schema.json",
  "title": "Aureline local-model pack install, provenance, hardware-fit, and offline/mirror support",
  "description": "Export-safe packet materializing the local-model pack catalogue into per-pack rows. Each pack binds its publisher, model, version, claimed qualification, install state, provenance class, source channel, hardware-fit class, footprint tier, and accelerator requirement, plus a closed set of downgrade rules that narrow the claim. An active-install pack must carry verified provenance and must actually fit the device, a pack whose provenance failed must be held aside, a claimed pack may not hide its hardware fit, and a claimed offline or mirror pack must still carry verified provenance. Raw download URLs, mirror endpoints, credential bodies, raw signature blobs, raw checksums, and exact byte sizes never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "catalogue_label",
    "packs",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "implement_local_model_pack_install_provenance_hardware_fit_checks_and_offline_or_mirror_support"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "catalogue_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "packs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/local_model_pack_row"
      }
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "qualification_class": {
      "enum": ["stable", "beta", "preview", "experimental", "unavailable", "held"]
    },
    "downgrade_trigger": {
      "enum": [
        "proof_stale",
        "policy_blocked",
        "provider_unavailable",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "install_state": {
      "enum": [
        "not_installed",
        "acquiring",
        "installed",
        "verified",
        "quarantined",
        "install_failed",
        "removed"
      ]
    },
    "provenance": {
      "enum": [
        "signed_publisher_verified",
        "signed_key_pinned",
        "checksum_only_unsigned",
        "unverified_source",
        "signature_mismatch",
        "policy_blocked"
      ]
    },
    "source_channel": {
      "enum": [
        "direct_vendor_download",
        "configured_mirror",
        "offline_bundle_import",
        "air_gapped_sideload",
        "local_cache_reuse"
      ]
    },
    "hardware_fit": {
      "enum": [
        "fits_comfortably",
        "fits_constrained",
        "insufficient_memory",
        "insufficient_disk",
        "unsupported_accelerator",
        "unknown_unverified"
      ]
    },
    "footprint_tier": {
      "enum": ["tiny", "small", "medium", "large", "extra_large"]
    },
    "accelerator": {
      "enum": ["cpu_only", "gpu_optional", "gpu_required", "npu_optional"]
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger", "narrowed_to", "auto_enforced", "rationale"],
      "properties": {
        "trigger": { "$ref": "#/$defs/downgrade_trigger" },
        "narrowed_to": { "$ref": "#/$defs/qualification_class" },
        "auto_enforced": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "local_model_pack_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pack_id",
        "model_id",
        "publisher_id",
        "pack_version",
        "claimed_qualification",
        "install_state",
        "provenance",
        "source_channel",
        "hardware_fit",
        "footprint_tier",
        "accelerator",
        "provenance_label",
        "downgrade_rules",
        "evidence_packet_refs"
      ],
      "properties": {
        "pack_id": { "$ref": "#/$defs/non_empty_string" },
        "model_id": { "$ref": "#/$defs/non_empty_string" },
        "publisher_id": { "$ref": "#/$defs/non_empty_string" },
        "pack_version": { "$ref": "#/$defs/non_empty_string" },
        "claimed_qualification": { "$ref": "#/$defs/qualification_class" },
        "install_state": { "$ref": "#/$defs/install_state" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "source_channel": { "$ref": "#/$defs/source_channel" },
        "hardware_fit": { "$ref": "#/$defs/hardware_fit" },
        "footprint_tier": { "$ref": "#/$defs/footprint_tier" },
        "accelerator": { "$ref": "#/$defs/accelerator" },
        "provenance_label": { "$ref": "#/$defs/non_empty_string" },
        "downgrade_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_rule" }
        },
        "evidence_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_freshness_slo_hours", "last_proof_refresh", "auto_narrow_on_stale"],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
