{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/prompt_composer_stabilization.schema.json",
  "title": "Aureline AI prompt composer stabilization packet",
  "$comment": "Rust owner: aureline_ai::stabilize_prompt_composer::PromptComposerStabilizationPacket.",
  "description": "Boundary schema for the metadata-only stabilization packet that promotes the beta prompt-composer conformance lane to the stable line. The packet references the conformance packet by id and adds typed attachment/mention origin-trust-freshness semantics, pinned-but-stale truth, omitted-context inspectability that survives send, forked-thread lineage, compare-answer same-versus-different context truth, context-drift banners, and a thread header that previews what a Remember/Save affordance retains, where it lives, and who can reuse it. It carries refs, state tokens, coarse classes, and review labels only. It never carries raw prompt bodies, source file bodies, provider payloads, endpoint URLs, credentials, raw token counts, exact prices, or billing-account ids.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "display_label",
    "composer_conformance_packet_ref",
    "composer_context_snapshot_ref",
    "composer_session_ref",
    "composer_draft_ref",
    "thread_header",
    "attachment_semantic_rows",
    "pinned_context_rows",
    "omitted_context_review_rows",
    "forked_thread_lineage",
    "compare_answer_rows",
    "context_drift_banners",
    "surface_consistency_rows",
    "source_contract_refs",
    "json_export_ref",
    "markdown_summary_ref",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "prompt_composer_stabilization_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "workflow_or_surface_id": { "type": "string", "minLength": 1 },
    "display_label": { "type": "string", "minLength": 1 },
    "composer_conformance_packet_ref": { "type": "string", "minLength": 1 },
    "composer_context_snapshot_ref": { "type": "string", "minLength": 1 },
    "composer_session_ref": { "type": "string", "minLength": 1 },
    "composer_draft_ref": { "type": "string", "minLength": 1 },
    "thread_header": { "$ref": "#/$defs/thread_header" },
    "attachment_semantic_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/attachment_semantic_row" }
    },
    "pinned_context_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/pinned_context_row" }
    },
    "omitted_context_review_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/omitted_context_review_row" }
    },
    "forked_thread_lineage": { "$ref": "#/$defs/forked_thread_lineage" },
    "compare_answer_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/compare_answer_row" }
    },
    "context_drift_banners": {
      "type": "array",
      "items": { "$ref": "#/$defs/context_drift_banner" }
    },
    "surface_consistency_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_consistency_row" }
    },
    "source_contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "json_export_ref": { "type": "string", "minLength": 1 },
    "markdown_summary_ref": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "freshness_class": {
      "type": "string",
      "enum": ["authoritative_live", "warm_cached", "stale", "changed_since_pin", "unverified"]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "workspace_file_slice",
        "workspace_symbol",
        "workspace_buffer_slice",
        "workspace_search_result",
        "workspace_diagnostics",
        "docs_pack_excerpt",
        "terminal_transcript_excerpt",
        "user_supplied_text",
        "user_supplied_file",
        "citation_anchor_quote"
      ]
    },
    "omission_reason_class": {
      "type": "string",
      "enum": [
        "budget",
        "policy",
        "duplicate",
        "stale",
        "blocked",
        "tainted",
        "scope_excluded",
        "citation_anchor_unavailable"
      ]
    },
    "thread_header": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "thread_id",
        "current_scope_label",
        "provider_label",
        "model_label",
        "retention_mode_class",
        "memory_class_token",
        "save_memory_action_ref",
        "delete_action_ref",
        "export_action_ref",
        "remember_preview"
      ],
      "properties": {
        "thread_id": { "type": "string", "minLength": 1 },
        "current_scope_label": { "type": "string", "minLength": 1 },
        "provider_label": { "type": "string", "minLength": 1 },
        "model_label": { "type": "string", "minLength": 1 },
        "retention_mode_class": {
          "type": "string",
          "enum": ["local_only", "repo_shared", "org_shared", "ephemeral_no_retention"]
        },
        "memory_class_token": { "type": "string", "minLength": 1 },
        "save_memory_action_ref": { "type": "string", "minLength": 1 },
        "delete_action_ref": { "type": "string", "minLength": 1 },
        "export_action_ref": { "type": "string", "minLength": 1 },
        "remember_preview": { "$ref": "#/$defs/remember_preview" }
      }
    },
    "remember_preview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "retained_summary_label",
        "retention_locus_class",
        "reuse_audience_class",
        "memory_class_token",
        "preview_action_ref"
      ],
      "properties": {
        "retained_summary_label": { "type": "string", "minLength": 1 },
        "retention_locus_class": {
          "type": "string",
          "enum": ["local_device", "repo_scoped", "org_scoped"]
        },
        "reuse_audience_class": {
          "type": "string",
          "enum": ["only_me", "repo_collaborators", "org_members", "nobody"]
        },
        "memory_class_token": { "type": "string", "minLength": 1 },
        "preview_action_ref": { "type": "string", "minLength": 1 }
      }
    },
    "attachment_semantic_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attachment_id",
        "stable_object_ref",
        "origin_label",
        "source_class",
        "taint_class",
        "freshness_class",
        "inclusion_posture",
        "keyboard_reachable",
        "screen_reader_label"
      ],
      "properties": {
        "attachment_id": { "type": "string", "minLength": 1 },
        "stable_object_ref": { "type": "string", "minLength": 1 },
        "origin_label": { "type": "string", "minLength": 1 },
        "source_class": {
          "type": "string",
          "enum": [
            "workspace_file",
            "symbol",
            "docs_reference",
            "diagnostic",
            "test_result",
            "terminal_tool_output",
            "external_text"
          ]
        },
        "taint_class": {
          "type": "string",
          "enum": [
            "trusted_first_party",
            "workspace_derived",
            "untrusted_external",
            "tainted_quarantined"
          ]
        },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "inclusion_posture": {
          "type": "string",
          "enum": [
            "included_raw",
            "included_pinned",
            "summarized",
            "trimmed",
            "omitted_inspectable",
            "blocked_quarantined"
          ]
        },
        "keyboard_reachable": { "type": "boolean" },
        "screen_reader_label": { "type": "string", "minLength": 1 }
      }
    },
    "pinned_context_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pin_id",
        "stable_object_ref",
        "display_label",
        "freshness_state",
        "refresh_action_ref",
        "remove_action_ref",
        "blocks_send_until_resolved",
        "keyboard_reachable"
      ],
      "properties": {
        "pin_id": { "type": "string", "minLength": 1 },
        "stable_object_ref": { "type": "string", "minLength": 1 },
        "display_label": { "type": "string", "minLength": 1 },
        "freshness_state": {
          "type": "string",
          "enum": ["pinned_fresh", "pinned_but_stale", "pinned_refreshing"]
        },
        "drift_source": { "$ref": "#/$defs/drift_source_class" },
        "refresh_action_ref": { "type": "string", "minLength": 1 },
        "remove_action_ref": { "type": "string", "minLength": 1 },
        "blocks_send_until_resolved": { "type": "boolean" },
        "keyboard_reachable": { "type": "boolean" }
      }
    },
    "drift_source_class": {
      "type": "string",
      "enum": ["on_disk", "in_git", "live_state", "docs_source", "test_state"]
    },
    "omitted_context_review_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "source_class",
        "omission_reason_class",
        "inspectable_after_send",
        "inspect_action_ref",
        "replay_explains_exclusion",
        "keyboard_reachable"
      ],
      "properties": {
        "source_ref": { "type": "string", "minLength": 1 },
        "source_class": { "$ref": "#/$defs/source_class" },
        "omission_reason_class": { "$ref": "#/$defs/omission_reason_class" },
        "inspectable_after_send": { "type": "boolean" },
        "inspect_action_ref": { "type": "string", "minLength": 1 },
        "replay_explains_exclusion": { "type": "boolean" },
        "keyboard_reachable": { "type": "boolean" }
      }
    },
    "forked_thread_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["thread_id", "is_forked"],
      "properties": {
        "thread_id": { "type": "string", "minLength": 1 },
        "is_forked": { "type": "boolean" },
        "parent_thread_ref": { "type": "string", "minLength": 1 },
        "parent_run_ref": { "type": "string", "minLength": 1 },
        "inherited_context_snapshot_ref": { "type": "string", "minLength": 1 },
        "divergence_point_ref": { "type": "string", "minLength": 1 }
      }
    },
    "compare_answer_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_id",
        "left_run_ref",
        "right_run_ref",
        "left_context_snapshot_ref",
        "right_context_snapshot_ref",
        "context_parity_class",
        "hidden_drift_warning"
      ],
      "properties": {
        "comparison_id": { "type": "string", "minLength": 1 },
        "left_run_ref": { "type": "string", "minLength": 1 },
        "right_run_ref": { "type": "string", "minLength": 1 },
        "left_context_snapshot_ref": { "type": "string", "minLength": 1 },
        "right_context_snapshot_ref": { "type": "string", "minLength": 1 },
        "context_parity_class": {
          "type": "string",
          "enum": [
            "same_context_snapshot",
            "different_context_drift",
            "different_context_intentional"
          ]
        },
        "provider_model_delta_label": { "type": "string", "minLength": 1 },
        "instruction_stack_delta_label": { "type": "string", "minLength": 1 },
        "hidden_drift_warning": { "type": "boolean" }
      }
    },
    "context_drift_banner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "banner_id",
        "drift_source",
        "affected_object_ref",
        "previously_reviewed_snapshot_ref",
        "requires_rereview",
        "explanation_label",
        "keyboard_reachable",
        "screen_reader_label"
      ],
      "properties": {
        "banner_id": { "type": "string", "minLength": 1 },
        "drift_source": { "$ref": "#/$defs/drift_source_class" },
        "affected_object_ref": { "type": "string", "minLength": 1 },
        "previously_reviewed_snapshot_ref": { "type": "string", "minLength": 1 },
        "requires_rereview": { "type": "boolean" },
        "explanation_label": { "type": "string", "minLength": 1 },
        "keyboard_reachable": { "type": "boolean" },
        "screen_reader_label": { "type": "string", "minLength": 1 }
      }
    },
    "surface_consistency_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "attachment_pills_keyboard_reachable",
        "mention_rows_screen_reader_describable",
        "omitted_context_review_reachable",
        "forked_thread_comparison_reachable",
        "context_drift_banner_reachable"
      ],
      "properties": {
        "surface_class": {
          "type": "string",
          "enum": ["editor_attached", "sidebar", "detached"]
        },
        "attachment_pills_keyboard_reachable": { "type": "boolean" },
        "mention_rows_screen_reader_describable": { "type": "boolean" },
        "omitted_context_review_reachable": { "type": "boolean" },
        "forked_thread_comparison_reachable": { "type": "boolean" },
        "context_drift_banner_reachable": { "type": "boolean" }
      }
    }
  }
}
