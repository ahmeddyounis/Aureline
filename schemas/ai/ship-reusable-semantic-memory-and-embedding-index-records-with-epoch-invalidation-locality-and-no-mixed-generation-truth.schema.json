{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/ship-reusable-semantic-memory-and-embedding-index-records-with-epoch-invalidation-locality-and-no-mixed-generation-truth.schema.json",
  "title": "Aureline reusable semantic-memory and embedding-index records with graph/docs/model epoch invalidation, locality, and no-mixed-generation truth",
  "description": "Export-safe packet materializing reusable semantic-memory and embedding-index records. Each record binds its artifact kind (reusable semantic memory, embedding index), graph/docs/model epoch lineage plus embedding generation, the epochs whose bump invalidates it, its retrieval generation state, its local-versus-managed locality cue, its delete and export posture, the recall surfaces that read it, and a precise degraded label. Mixed-generation or stale retrieval never masquerades as current truth. Raw prompt bodies, cached result bodies, raw embeddings, raw provider payloads, credentials, exact token counts, and exact cost amounts never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "records_label",
    "records",
    "guardrails",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "ship_reusable_semantic_memory_and_embedding_index_records_with_epoch_invalidation_locality_and_no_mixed_generation_truth"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "records_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "records": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "artifact_kind": {
      "type": "string",
      "enum": [
        "reusable_semantic_memory",
        "embedding_index"
      ]
    },
    "epoch_kind": {
      "type": "string",
      "enum": [
        "graph",
        "docs",
        "model"
      ]
    },
    "invalidation_trigger": {
      "type": "string",
      "enum": [
        "graph_epoch_bump",
        "docs_epoch_bump",
        "model_epoch_bump",
        "embedding_generation_bump",
        "policy_epoch_bump",
        "content_hash_key",
        "manual_purge"
      ]
    },
    "generation_state": {
      "type": "string",
      "enum": [
        "current",
        "recomputing",
        "invalidated",
        "stale",
        "mixed_blocked"
      ]
    },
    "locality_class": {
      "type": "string",
      "enum": [
        "local_device_only",
        "workspace_mirrored",
        "managed_hosted",
        "policy_blocked"
      ]
    },
    "delete_export_posture": {
      "type": "string",
      "enum": [
        "user_scoped",
        "workspace_scoped",
        "tenant_scoped",
        "org_scoped",
        "not_applicable"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "composer_assist",
        "docs_browser_recall",
        "code_understanding",
        "semantic_search",
        "support_export",
        "managed_offline_report"
      ]
    },
    "epoch_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "graph_epoch",
        "docs_epoch",
        "model_epoch",
        "embedding_generation"
      ],
      "properties": {
        "graph_epoch": {
          "$ref": "#/$defs/non_empty_string"
        },
        "docs_epoch": {
          "$ref": "#/$defs/non_empty_string"
        },
        "model_epoch": {
          "$ref": "#/$defs/non_empty_string"
        },
        "embedding_generation": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "artifact_kind",
        "label_summary",
        "epoch_lineage",
        "bound_epochs",
        "invalidation_triggers",
        "generation_state",
        "mixed_generation_detected",
        "locality",
        "delete_posture",
        "export_posture",
        "consumer_surfaces",
        "evidence_refs",
        "source_contract_refs"
      ],
      "properties": {
        "record_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "artifact_kind": {
          "$ref": "#/$defs/artifact_kind"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "epoch_lineage": {
          "$ref": "#/$defs/epoch_lineage"
        },
        "bound_epochs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/epoch_kind"
          }
        },
        "invalidation_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/invalidation_trigger"
          }
        },
        "generation_state": {
          "$ref": "#/$defs/generation_state"
        },
        "mixed_generation_detected": {
          "type": "boolean"
        },
        "locality": {
          "$ref": "#/$defs/locality_class"
        },
        "delete_posture": {
          "$ref": "#/$defs/delete_export_posture"
        },
        "export_posture": {
          "$ref": "#/$defs/delete_export_posture"
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/consumer_surface"
          }
        },
        "degraded_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_cross_workspace_recall_by_default",
        "no_cross_tenant_recall_by_default",
        "mixed_generation_never_current_truth",
        "invalidated_or_recomputing_lanes_labeled",
        "every_durable_record_declares_delete_export",
        "locality_states_remain_distinct",
        "epoch_bump_invalidates_bound_records"
      ],
      "properties": {
        "no_cross_workspace_recall_by_default": {
          "type": "boolean",
          "const": true
        },
        "no_cross_tenant_recall_by_default": {
          "type": "boolean",
          "const": true
        },
        "mixed_generation_never_current_truth": {
          "type": "boolean",
          "const": true
        },
        "invalidated_or_recomputing_lanes_labeled": {
          "type": "boolean",
          "const": true
        },
        "every_durable_record_declares_delete_export": {
          "type": "boolean",
          "const": true
        },
        "locality_states_remain_distinct": {
          "type": "boolean",
          "const": true
        },
        "epoch_bump_invalidates_bound_records": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "composer_shows_memory_and_generation",
        "docs_browser_shows_provenance_and_locality",
        "search_shows_retrieval_generation",
        "support_export_shows_locality_and_epochs",
        "managed_offline_shows_locality_truth",
        "invalidated_or_recomputing_lanes_labeled_below_current"
      ],
      "properties": {
        "composer_shows_memory_and_generation": {
          "type": "boolean",
          "const": true
        },
        "docs_browser_shows_provenance_and_locality": {
          "type": "boolean",
          "const": true
        },
        "search_shows_retrieval_generation": {
          "type": "boolean",
          "const": true
        },
        "support_export_shows_locality_and_epochs": {
          "type": "boolean",
          "const": true
        },
        "managed_offline_shows_locality_truth": {
          "type": "boolean",
          "const": true
        },
        "invalidated_or_recomputing_lanes_labeled_below_current": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
