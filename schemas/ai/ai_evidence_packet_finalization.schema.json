{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/ai_evidence_packet_finalization.schema.json",
  "title": "Aureline AI evidence packet finalization record",
  "$comment": "Rust owner: aureline_ai::finalize_ai_evidence_packets::AiEvidencePacketFinalization.",
  "description": "Boundary schema for the metadata-only AI evidence packet finalization record. The packet binds the mutation-evidence, run-history, rerun-review, and replay lineages into one export-safe artifact with a stable evidence id, the six stable evidence blocks (intent and requested scope, context inputs, tool and policy decisions, produced diff/write scope, validation and outcome, and rollback/export), right-sized packet classes, an export-safe redaction manifest, a retained-artifact inventory distinct from threads/caches/repo facts/saved memory, replay/rerun lineage with incomplete-replay posture, retrieval-lane provenance, and the AI review-assist branches. It carries refs, state tokens, coarse classes, counts, and review labels only. It never carries raw prompt bodies, source file bodies, provider payloads, raw retrieval vectors or chunks, endpoint URLs, credentials, raw token counts, exact prices, or billing-account ids.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "evidence_id",
    "display_label",
    "origin_class",
    "originating_turn_ref",
    "originating_run_ref",
    "provider_label",
    "model_label",
    "approval_path_label",
    "route_receipt_ref",
    "spend_receipt_ref",
    "intent_scope",
    "context_inputs",
    "tool_policy",
    "diff_write_scope",
    "validation",
    "rollback_export",
    "packet_class_rows",
    "redaction_manifest",
    "retained_artifact_inventory",
    "replay_lineage",
    "evidence_branches",
    "source_contract_refs",
    "json_export_ref",
    "markdown_summary_ref",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "ai_evidence_packet_finalization" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "evidence_id": { "type": "string", "minLength": 1 },
    "display_label": { "type": "string", "minLength": 1 },
    "origin_class": { "$ref": "#/$defs/origin_class" },
    "originating_turn_ref": { "type": "string", "minLength": 1 },
    "originating_run_ref": { "type": "string", "minLength": 1 },
    "branch_agent_job_ref": { "type": "string", "minLength": 1 },
    "replay_action_ref": { "type": "string", "minLength": 1 },
    "provider_label": { "type": "string", "minLength": 1 },
    "model_label": { "type": "string", "minLength": 1 },
    "approval_path_label": { "type": "string", "minLength": 1 },
    "route_receipt_ref": { "type": "string", "minLength": 1 },
    "spend_receipt_ref": { "type": "string", "minLength": 1 },
    "intent_scope": { "$ref": "#/$defs/intent_scope_block" },
    "context_inputs": { "$ref": "#/$defs/context_inputs_block" },
    "tool_policy": { "$ref": "#/$defs/tool_policy_block" },
    "diff_write_scope": { "$ref": "#/$defs/diff_write_scope_block" },
    "validation": { "$ref": "#/$defs/validation_block" },
    "rollback_export": { "$ref": "#/$defs/rollback_export_block" },
    "packet_class_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/packet_class_row" }
    },
    "redaction_manifest": {
      "type": "array",
      "items": { "$ref": "#/$defs/redaction_manifest_row" }
    },
    "retained_artifact_inventory": {
      "type": "array",
      "items": { "$ref": "#/$defs/retained_artifact_row" }
    },
    "replay_lineage": { "$ref": "#/$defs/replay_lineage" },
    "evidence_branches": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_branch_row" }
    },
    "source_contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "json_export_ref": { "type": "string", "minLength": 1 },
    "markdown_summary_ref": { "type": "string", "minLength": 1 },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "origin_class": {
      "type": "string",
      "enum": [
        "originating_turn",
        "agent_run",
        "branch_agent_job",
        "replay_action",
        "rerun_action"
      ]
    },
    "absence_state": {
      "type": "string",
      "enum": ["omitted", "blocked", "summarized", "not_requested"]
    },
    "recall_locality_class": {
      "type": "string",
      "enum": [
        "local_only",
        "managed_cloud",
        "hybrid_local_and_managed",
        "no_recall_used"
      ]
    },
    "retrieval_lane_class": {
      "type": "string",
      "enum": [
        "lexical_search",
        "semantic_recall",
        "graph_navigation",
        "docs_knowledge",
        "history_recall"
      ]
    },
    "reproducibility_impact_class": {
      "type": "string",
      "enum": ["unchanged", "degraded_reproducibility", "replay_blocked"]
    },
    "redaction_reason_class": {
      "type": "string",
      "enum": [
        "secret_material",
        "tainted_external_content",
        "policy_class_exceeds_sink",
        "retention_window_expired",
        "provider_did_not_disclose",
        "user_requested_redaction"
      ]
    },
    "retained_artifact_class": {
      "type": "string",
      "enum": [
        "evidence_retained_by_policy",
        "conversation_thread",
        "prompt_result_cache",
        "reusable_repo_fact",
        "explicit_saved_memory"
      ]
    },
    "replay_posture_class": {
      "type": "string",
      "enum": [
        "reconstructible_full",
        "incomplete_degraded_replay",
        "incomplete_replay_blocked"
      ]
    },
    "evidence_packet_class": {
      "type": "string",
      "enum": [
        "inline_evidence_stub",
        "operator_packet",
        "support_packet",
        "compliance_audit_packet"
      ]
    },
    "validation_outcome_class": {
      "type": "string",
      "enum": [
        "not_run",
        "passed",
        "passed_with_warnings",
        "failed",
        "partial_unreproducible"
      ]
    },
    "outbound_target_class": {
      "type": "string",
      "enum": [
        "stayed_local",
        "copied_to_clipboard",
        "exported_file",
        "published_to_provider_thread",
        "published_to_check_surface",
        "published_to_review_thread"
      ]
    },
    "outbound_redaction_posture_class": {
      "type": "string",
      "enum": ["full_detail_retained", "metadata_only", "redacted_before_outbound"]
    },
    "ai_evidence_branch_class": {
      "type": "string",
      "enum": [
        "candidate_test_proposal",
        "assumption_review",
        "sandbox_validation",
        "ai_review_finding",
        "publish_preview",
        "outbound_review_action"
      ]
    },
    "intent_scope_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent_summary_label",
        "requested_scope_label",
        "intent_class_token",
        "requested_write_scope_label"
      ],
      "properties": {
        "intent_summary_label": { "type": "string", "minLength": 1 },
        "requested_scope_label": { "type": "string", "minLength": 1 },
        "intent_class_token": { "type": "string", "minLength": 1 },
        "requested_write_scope_label": { "type": "string", "minLength": 1 }
      }
    },
    "retrieval_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recall_used",
        "locality_class",
        "retrieval_epoch_ref",
        "participating_lanes",
        "embedder_model_identity_ref",
        "source_count",
        "chunk_or_anchor_count",
        "omitted_candidate_classes",
        "raw_vectors_excluded",
        "raw_chunks_excluded"
      ],
      "properties": {
        "recall_used": { "type": "boolean" },
        "locality_class": { "$ref": "#/$defs/recall_locality_class" },
        "retrieval_epoch_ref": { "type": "string" },
        "participating_lanes": {
          "type": "array",
          "items": { "$ref": "#/$defs/retrieval_lane_class" }
        },
        "embedder_model_identity_ref": { "type": "string" },
        "source_count": { "type": "integer", "minimum": 0 },
        "chunk_or_anchor_count": { "type": "integer", "minimum": 0 },
        "omitted_candidate_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/absence_state" }
        },
        "raw_vectors_excluded": { "type": "boolean" },
        "raw_chunks_excluded": { "type": "boolean" }
      }
    },
    "absence_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_ref", "absence_state", "reason_label", "inspect_action_ref"],
      "properties": {
        "subject_ref": { "type": "string", "minLength": 1 },
        "absence_state": { "$ref": "#/$defs/absence_state" },
        "reason_label": { "type": "string", "minLength": 1 },
        "inspect_action_ref": { "type": "string", "minLength": 1 }
      }
    },
    "context_inputs_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_assembly_ref",
        "context_snapshot_ref",
        "included_source_count",
        "retrieval_provenance",
        "absence_rows"
      ],
      "properties": {
        "context_assembly_ref": { "type": "string", "minLength": 1 },
        "context_snapshot_ref": { "type": "string", "minLength": 1 },
        "included_source_count": { "type": "integer", "minimum": 0 },
        "retrieval_provenance": { "$ref": "#/$defs/retrieval_provenance" },
        "absence_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/absence_row" }
        }
      }
    },
    "tool_policy_decision_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "tool_or_policy_label", "decision_token", "approval_required"],
      "properties": {
        "decision_id": { "type": "string", "minLength": 1 },
        "tool_or_policy_label": { "type": "string", "minLength": 1 },
        "decision_token": { "type": "string", "minLength": 1 },
        "approval_required": { "type": "boolean" },
        "approval_ref": { "type": "string", "minLength": 1 }
      }
    },
    "tool_policy_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_call_lineage_refs",
        "policy_epoch_ref",
        "approval_timeline_ref",
        "decisions"
      ],
      "properties": {
        "tool_call_lineage_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "policy_epoch_ref": { "type": "string", "minLength": 1 },
        "approval_timeline_ref": { "type": "string", "minLength": 1 },
        "decisions": {
          "type": "array",
          "items": { "$ref": "#/$defs/tool_policy_decision_row" }
        }
      }
    },
    "diff_write_scope_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "patch_review_summary_ref",
        "changed_file_count",
        "generated_artifact_count",
        "write_scope_class_label",
        "produced_artifact_refs"
      ],
      "properties": {
        "patch_review_summary_ref": { "type": "string", "minLength": 1 },
        "changed_file_count": { "type": "integer", "minimum": 0 },
        "generated_artifact_count": { "type": "integer", "minimum": 0 },
        "write_scope_class_label": { "type": "string", "minLength": 1 },
        "produced_artifact_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "validation_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation_summary_refs", "validation_outcome_class", "validation_note_label"],
      "properties": {
        "validation_summary_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "validation_outcome_class": { "$ref": "#/$defs/validation_outcome_class" },
        "validation_note_label": { "type": "string", "minLength": 1 }
      }
    },
    "rollback_export_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["json_export_ref", "markdown_summary_ref", "export_lineage_refs"],
      "properties": {
        "rollback_checkpoint_ref": { "type": "string", "minLength": 1 },
        "mutation_journal_ref": { "type": "string", "minLength": 1 },
        "json_export_ref": { "type": "string", "minLength": 1 },
        "markdown_summary_ref": { "type": "string", "minLength": 1 },
        "export_lineage_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "packet_class_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_class",
        "projection_ref",
        "preserves_evidence_id",
        "preserves_redaction_manifest",
        "preserves_rollback_export_refs",
        "preserves_provider_model_identity",
        "preserves_approval_path",
        "preserves_validation_receipts",
        "preserves_write_scope_classes",
        "ui_parity",
        "cli_parity",
        "support_parity"
      ],
      "properties": {
        "packet_class": { "$ref": "#/$defs/evidence_packet_class" },
        "projection_ref": { "type": "string", "minLength": 1 },
        "preserves_evidence_id": { "type": "boolean" },
        "preserves_redaction_manifest": { "type": "boolean" },
        "preserves_rollback_export_refs": { "type": "boolean" },
        "preserves_provider_model_identity": { "type": "boolean" },
        "preserves_approval_path": { "type": "boolean" },
        "preserves_validation_receipts": { "type": "boolean" },
        "preserves_write_scope_classes": { "type": "boolean" },
        "ui_parity": { "type": "boolean" },
        "cli_parity": { "type": "boolean" },
        "support_parity": { "type": "boolean" }
      }
    },
    "redaction_manifest_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redaction_id",
        "subject_ref",
        "reason_class",
        "removed_summary_label",
        "reproducibility_impact",
        "reproducibility_note_label"
      ],
      "properties": {
        "redaction_id": { "type": "string", "minLength": 1 },
        "subject_ref": { "type": "string", "minLength": 1 },
        "reason_class": { "$ref": "#/$defs/redaction_reason_class" },
        "removed_summary_label": { "type": "string", "minLength": 1 },
        "reproducibility_impact": { "$ref": "#/$defs/reproducibility_impact_class" },
        "reproducibility_note_label": { "type": "string" }
      }
    },
    "retained_artifact_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_class",
        "inventory_ref",
        "retained_after_thread_deletion",
        "retained_only_for_evidence_policy",
        "disclosure_label"
      ],
      "properties": {
        "artifact_class": { "$ref": "#/$defs/retained_artifact_class" },
        "inventory_ref": { "type": "string", "minLength": 1 },
        "retained_after_thread_deletion": { "type": "boolean" },
        "retained_only_for_evidence_policy": { "type": "boolean" },
        "disclosure_label": { "type": "string", "minLength": 1 }
      }
    },
    "replay_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_history_entry_ref",
        "approval_timeline_ref",
        "rerun_review_ref",
        "replay_packet_ref",
        "replay_posture",
        "requires_fresh_approval_for_new_tool_calls"
      ],
      "properties": {
        "run_history_entry_ref": { "type": "string", "minLength": 1 },
        "approval_timeline_ref": { "type": "string", "minLength": 1 },
        "rerun_review_ref": { "type": "string", "minLength": 1 },
        "replay_packet_ref": { "type": "string", "minLength": 1 },
        "replay_posture": { "$ref": "#/$defs/replay_posture_class" },
        "incompleteness_reason_label": { "type": "string", "minLength": 1 },
        "requires_fresh_approval_for_new_tool_calls": { "type": "boolean" },
        "cites_original_packet_ref": { "type": "string", "minLength": 1 }
      }
    },
    "evidence_branch_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch_class",
        "branch_subject_ref",
        "validation_status_label",
        "outbound_target_class",
        "outbound_redaction_posture",
        "scope_label",
        "stayed_local"
      ],
      "properties": {
        "branch_class": { "$ref": "#/$defs/ai_evidence_branch_class" },
        "branch_subject_ref": { "type": "string", "minLength": 1 },
        "validation_status_label": { "type": "string", "minLength": 1 },
        "outbound_target_class": { "$ref": "#/$defs/outbound_target_class" },
        "outbound_redaction_posture": { "$ref": "#/$defs/outbound_redaction_posture_class" },
        "scope_label": { "type": "string", "minLength": 1 },
        "stayed_local": { "type": "boolean" }
      }
    }
  }
}
