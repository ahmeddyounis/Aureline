{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/ship-the-external-tool-gateway-and-connector-manifests-with-capability-classes-and-side-effect-disclosure.schema.json",
  "title": "Aureline external-tool gateway connector manifests with capability classes and side-effect disclosure",
  "description": "Export-safe packet shipping the external-tool gateway into per-connector manifest rows. Each row binds the capability classes a governed external connector advertises and a side-effect disclosure for every effect it can produce, plus the provider/locality mode, runtime boundary, network behavior, credential posture, and output-trust posture it runs under. A mutating side effect must preview before it applies, carry a real approval gate, and be audited, matching the bar a first-party command is held to; an irreversible external publish must be externally auditable; a connector whose output crosses the network is tainted by default; a trusted-output posture is allowed only on a signed local boundary; a blocked connector may not keep a public qualification; and a connector pending first-use review may not claim Stable. Raw endpoint URLs, raw spawn commands, credential bodies, raw API keys, OAuth tokens, and raw request/response bodies never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "catalogue_label",
    "connectors",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "ship_the_external_tool_gateway_and_connector_manifests_with_capability_classes_and_side_effect_disclosure"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "catalogue_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "connectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/connector_manifest_row"
      }
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "qualification_class": {
      "enum": ["stable", "beta", "preview", "experimental", "unavailable", "held"]
    },
    "downgrade_trigger": {
      "enum": [
        "proof_stale",
        "policy_blocked",
        "provider_unavailable",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "rollback_posture": {
      "enum": [
        "fully_reversible",
        "checkpoint_reversible",
        "evidence_preserved_no_revert",
        "not_applicable"
      ]
    },
    "route_policy_mode": {
      "enum": ["local", "byok", "managed", "enterprise_gateway"]
    },
    "publisher_source_class": {
      "enum": [
        "first_party_native_publisher",
        "signed_extension_publisher",
        "mcp_server_publisher",
        "user_registered_publisher",
        "enterprise_registered_publisher",
        "mocked_test_publisher"
      ]
    },
    "runtime_boundary_class": {
      "enum": [
        "local_in_process",
        "local_subprocess_same_device",
        "local_sandboxed_container_same_device",
        "local_companion_service_loopback",
        "remote_vendor_managed_service",
        "remote_self_hosted_service",
        "enterprise_gateway_brokered_service",
        "extension_provided_locus",
        "mocked_test_locus"
      ]
    },
    "network_behavior_class": {
      "enum": [
        "no_network_local_only",
        "local_loopback_only",
        "remote_https",
        "remote_grpc_over_tls",
        "remote_mcp_over_streamable_http",
        "extension_mediated_local",
        "extension_mediated_remote",
        "unknown_must_disclose"
      ]
    },
    "credential_posture_class": {
      "enum": [
        "no_credential_local_only",
        "signed_manifest_only",
        "byok_secret_broker",
        "enterprise_gateway_managed",
        "vendor_hosted_first_party_managed",
        "extension_provided_credential",
        "mocked_test_credential",
        "disabled_no_credential"
      ]
    },
    "output_trust_posture_class": {
      "enum": [
        "always_tainted_external_tool_output",
        "always_tainted_remote_service_output",
        "always_tainted_extension_provided_output",
        "tainted_unless_reviewed_then_fenced",
        "trusted_first_party_local_tool_output",
        "trusted_signed_extension_local_tool_output",
        "posture_unknown_requires_fence_by_default"
      ]
    },
    "capability_class": {
      "enum": [
        "inspect_workspace_files",
        "inspect_workspace_symbols",
        "inspect_workspace_diagnostics",
        "inspect_workspace_search",
        "inspect_workspace_graph",
        "edit_workspace_files_reversible",
        "edit_workspace_files_destructive",
        "execute_local_subprocess",
        "fetch_external_documents",
        "fetch_external_data",
        "publish_external_comment",
        "publish_external_artifact",
        "mutate_policy_or_trust",
        "manage_external_resource",
        "synthesize_text",
        "synthesize_code",
        "summarize_evidence",
        "answer_with_citations",
        "unknown_must_disclose"
      ]
    },
    "side_effect_class": {
      "enum": [
        "inspect_only",
        "local_reversible_edit",
        "local_destructive_edit",
        "credential_handle_projection",
        "privileged_inspection_attach",
        "external_reversible_comment",
        "external_irreversible_publish",
        "policy_or_trust_mutation",
        "capability_widening",
        "automation_admission_only"
      ]
    },
    "approval_posture_class": {
      "enum": [
        "allowed_without_prompt",
        "allowed_with_one_time_prompt",
        "allowed_with_per_session_prompt",
        "allowed_with_per_invocation_prompt",
        "requires_admin_approval",
        "denied_by_policy",
        "denied_by_workspace_trust",
        "denied_tool_not_admitted"
      ]
    },
    "preview_class": {
      "enum": [
        "preview_required_before_apply",
        "diff_preview_before_apply",
        "dry_run_preview_before_apply",
        "inspect_only_no_preview_needed",
        "preview_unavailable_must_block"
      ]
    },
    "audit_class": {
      "enum": [
        "audited_to_evidence_timeline",
        "audited_to_support_export",
        "audited_local_history_only",
        "not_audited"
      ]
    },
    "reversibility_class": {
      "enum": [
        "no_side_effect",
        "reversible_in_workspace",
        "checkpoint_reversible",
        "irreversible_external_publish"
      ]
    },
    "state_class": {
      "enum": [
        "admitted",
        "pending_first_use_review",
        "policy_blocked",
        "trust_blocked",
        "quarantined_signature",
        "withdrawn"
      ]
    },
    "side_effect_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "side_effect_class",
        "preview",
        "approval_posture",
        "audit",
        "reversibility",
        "disclosure_label"
      ],
      "properties": {
        "side_effect_class": {
          "$ref": "#/$defs/side_effect_class"
        },
        "preview": {
          "$ref": "#/$defs/preview_class"
        },
        "approval_posture": {
          "$ref": "#/$defs/approval_posture_class"
        },
        "audit": {
          "$ref": "#/$defs/audit_class"
        },
        "reversibility": {
          "$ref": "#/$defs/reversibility_class"
        },
        "disclosure_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger", "narrowed_to", "auto_enforced", "rationale"],
      "properties": {
        "trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "narrowed_to": {
          "$ref": "#/$defs/qualification_class"
        },
        "auto_enforced": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    },
    "connector_manifest_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_id",
        "connector_label",
        "connector_family_label",
        "connector_capability_version",
        "publisher_source_class",
        "resolved_mode",
        "runtime_boundary_class",
        "network_behavior_class",
        "credential_posture_class",
        "output_trust_posture_class",
        "state",
        "claimed_qualification",
        "capability_classes",
        "side_effect_disclosures",
        "downgrade_rules",
        "rollback_posture",
        "rollback_verified",
        "evidence_packet_refs",
        "explanation_label"
      ],
      "properties": {
        "manifest_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "connector_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "connector_family_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "connector_capability_version": {
          "$ref": "#/$defs/non_empty_string"
        },
        "descriptor_ref": {
          "type": "string"
        },
        "publisher_source_class": {
          "$ref": "#/$defs/publisher_source_class"
        },
        "publisher_identity_ref": {
          "type": "string"
        },
        "resolved_mode": {
          "$ref": "#/$defs/route_policy_mode"
        },
        "runtime_boundary_class": {
          "$ref": "#/$defs/runtime_boundary_class"
        },
        "network_behavior_class": {
          "$ref": "#/$defs/network_behavior_class"
        },
        "credential_posture_class": {
          "$ref": "#/$defs/credential_posture_class"
        },
        "output_trust_posture_class": {
          "$ref": "#/$defs/output_trust_posture_class"
        },
        "state": {
          "$ref": "#/$defs/state_class"
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "capability_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/capability_class"
          }
        },
        "side_effect_disclosures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/side_effect_disclosure"
          }
        },
        "downgrade_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_rule"
          }
        },
        "rollback_posture": {
          "$ref": "#/$defs/rollback_posture"
        },
        "rollback_verified": {
          "type": "boolean"
        },
        "evidence_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "explanation_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
