{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/freeze-the-m5-ai-workflow-matrix-for-inline-assist-patch-review-and-branch-or-worktree-agents.schema.json",
  "title": "Aureline M5 AI workflow matrix for inline assist, patch review, and branch or worktree agents",
  "description": "Export-safe packet freezing the M5 depth qualification for three AI workflow lanes. The packet binds each lane to its qualification class, evidence requirements, downgrade triggers, rollback posture, source contracts, and consumer surface parity. Raw prompt bodies, raw diffs, raw provider payloads, credentials, exact token counts, and exact cost amounts never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "matrix_label",
    "lane_rows",
    "security_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "freeze_m5_ai_workflow_matrix_for_inline_assist_patch_review_and_branch_or_worktree_agents"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "matrix_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "lane_rows": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/lane_row"
      }
    },
    "security_review": {
      "$ref": "#/$defs/security_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "lane": {
      "type": "string",
      "enum": [
        "inline_assist",
        "patch_review",
        "branch_or_worktree_agent"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "evidence_requirement": {
      "type": "string",
      "enum": [
        "required",
        "recommended",
        "optional",
        "not_applicable"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "provider_unavailable",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "rollback_posture": {
      "type": "string",
      "enum": [
        "fully_reversible",
        "checkpoint_reversible",
        "evidence_preserved_no_revert",
        "not_applicable"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "desktop_composer",
        "desktop_review_workspace",
        "cli_headless",
        "browser_companion",
        "support_export",
        "diagnostics"
      ]
    },
    "lane_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane",
        "qualification",
        "scope_summary",
        "evidence_requirement",
        "required_evidence_packet_refs",
        "downgrade_triggers",
        "rollback_posture",
        "source_contract_refs",
        "consumer_surfaces"
      ],
      "properties": {
        "lane": {
          "$ref": "#/$defs/lane"
        },
        "qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "scope_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_requirement": {
          "$ref": "#/$defs/evidence_requirement"
        },
        "required_evidence_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "rollback_posture": {
          "$ref": "#/$defs/rollback_posture"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/consumer_surface"
          }
        }
      }
    },
    "security_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_self_approved_mutating_tools",
        "no_worktree_isolation_bypass",
        "preview_approval_required_before_apply",
        "evidence_packets_cite_source_contracts",
        "downgrade_narrows_instead_of_hides",
        "stale_proof_blocks_promotion"
      ],
      "properties": {
        "no_self_approved_mutating_tools": {
          "type": "boolean",
          "const": true
        },
        "no_worktree_isolation_bypass": {
          "type": "boolean",
          "const": true
        },
        "preview_approval_required_before_apply": {
          "type": "boolean",
          "const": true
        },
        "evidence_packets_cite_source_contracts": {
          "type": "boolean",
          "const": true
        },
        "downgrade_narrows_instead_of_hides": {
          "type": "boolean",
          "const": true
        },
        "stale_proof_blocks_promotion": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "desktop_composer_shows_qualification",
        "desktop_review_shows_qualification",
        "cli_headless_shows_qualification",
        "browser_companion_shows_qualification",
        "support_export_shows_qualification",
        "diagnostics_shows_qualification",
        "preview_labs_label_for_unqualified_lanes"
      ],
      "properties": {
        "desktop_composer_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "desktop_review_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "cli_headless_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "browser_companion_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "support_export_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "diagnostics_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "preview_labs_label_for_unqualified_lanes": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
