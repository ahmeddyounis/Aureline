{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/add-recorded-macro-promotion-recipe-insertion-and-headless-safe-result-packets-for-user-automation.schema.json",
  "title": "Aureline recorded-macro promotion, recipe insertion, and headless-safe result packets for user automation",
  "description": "Export-safe packet carrying user-authored automation through its lifecycle in per-macro rows. Each row binds how a recorded macro was captured, the promotion that graduates it into a reusable recipe, how that recipe inserts into a target surface, the headless-safe result it produces when run with no interactive operator, and a step disclosure for every effect it can produce. A capture carries a content-addressed digest; an imported capture names the signed recipe pack it rode. A recorded macro is promoted only behind an explicit, audited gate — there is no silent forward from a macro to a recipe — and a promoted macro names its recipe while an unpromoted one names none. A mutating step previews before it applies interactively, carries a real approval gate, and is audited; an inspect-only step is always headless-safe and a mutating step may never claim the inspect-only headless class; an irreversible external publish can never run unattended headless; a step pre-authorized to run headless still carries a gate and is audited; any step needing interactive confirmation is deferred or blocked fail-closed. Insertion is preview-first, and a headless-target insertion cannot rely on a recurring interactive prompt. The headless result block is content-addressed, reconciles its step counts against the disclosed steps, and its state agrees with whether any step deferred or blocked. A blocked promotion may not keep a public qualification; a macro pending promotion review may not claim Stable. Raw shell fragments, raw filesystem paths, raw endpoint URLs, credential bodies, raw API keys, OAuth tokens, and raw captured buffer bytes never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "catalogue_label",
    "automations",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "add_recorded_macro_promotion_recipe_insertion_and_headless_safe_result_packets_for_user_automation"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "catalogue_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "automations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/user_automation_row"
      }
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "qualification_class": {
      "enum": ["stable", "beta", "preview", "experimental", "unavailable", "held"]
    },
    "downgrade_trigger": {
      "enum": [
        "proof_stale",
        "policy_blocked",
        "provider_unavailable",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "rollback_posture": {
      "enum": [
        "fully_reversible",
        "checkpoint_reversible",
        "evidence_preserved_no_revert",
        "not_applicable"
      ]
    },
    "route_policy_mode": {
      "enum": ["local", "byok", "managed", "enterprise_gateway"]
    },
    "publisher_source_class": {
      "enum": [
        "first_party_native_publisher",
        "signed_extension_publisher",
        "mcp_server_publisher",
        "user_registered_publisher",
        "enterprise_registered_publisher",
        "mocked_test_publisher"
      ]
    },
    "capture_provenance_class": {
      "enum": [
        "recorded_from_user_session",
        "recorded_from_replay_session",
        "imported_from_shared_recipe_pack",
        "synthesized_from_template"
      ]
    },
    "promotion_state_class": {
      "enum": [
        "recorded_pending_review",
        "reviewed_held_not_promoted",
        "promoted_to_recipe",
        "promotion_blocked_policy",
        "promotion_blocked_tainted_capture",
        "promotion_withdrawn"
      ]
    },
    "insertion_target_class": {
      "enum": [
        "composer_prompt_insertion",
        "workspace_document_insertion",
        "command_palette_insertion",
        "automation_queue_insertion",
        "headless_job_insertion"
      ]
    },
    "headless_safety_class": {
      "enum": [
        "headless_safe_inspect_only",
        "headless_safe_preauthorized_policy",
        "headless_deferred_to_interactive",
        "headless_blocked_fail_closed",
        "headless_denied_by_policy"
      ]
    },
    "headless_result_state_class": {
      "enum": [
        "completed_all_steps_safe",
        "completed_with_deferred_steps",
        "blocked_fail_closed",
        "denied_by_policy",
        "partial_then_halted"
      ]
    },
    "side_effect_class": {
      "enum": [
        "inspect_only",
        "local_reversible_edit",
        "local_destructive_edit",
        "credential_handle_projection",
        "privileged_inspection_attach",
        "external_reversible_comment",
        "external_irreversible_publish",
        "policy_or_trust_mutation",
        "capability_widening",
        "automation_admission_only"
      ]
    },
    "approval_posture_class": {
      "enum": [
        "allowed_without_prompt",
        "allowed_with_one_time_prompt",
        "allowed_with_per_session_prompt",
        "allowed_with_per_invocation_prompt",
        "requires_admin_approval",
        "denied_by_policy",
        "denied_by_workspace_trust",
        "denied_tool_not_admitted"
      ]
    },
    "replay_preview_class": {
      "enum": [
        "full_preview_before_replay",
        "diff_preview_before_replay",
        "dry_run_preview_before_replay",
        "inspect_only_no_preview_needed",
        "preview_unavailable_must_block"
      ]
    },
    "audit_class": {
      "enum": [
        "audited_to_run_record_timeline",
        "audited_to_support_export",
        "audited_local_history_only",
        "not_audited"
      ]
    },
    "reversibility_class": {
      "enum": [
        "no_side_effect",
        "reversible_in_workspace",
        "checkpoint_reversible",
        "irreversible_external_publish"
      ]
    },
    "step_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "side_effect_class",
        "headless_safety",
        "interactive_preview",
        "approval_posture",
        "audit",
        "reversibility",
        "disclosure_label"
      ],
      "properties": {
        "side_effect_class": {
          "$ref": "#/$defs/side_effect_class"
        },
        "headless_safety": {
          "$ref": "#/$defs/headless_safety_class"
        },
        "interactive_preview": {
          "$ref": "#/$defs/replay_preview_class"
        },
        "approval_posture": {
          "$ref": "#/$defs/approval_posture_class"
        },
        "audit": {
          "$ref": "#/$defs/audit_class"
        },
        "reversibility": {
          "$ref": "#/$defs/reversibility_class"
        },
        "disclosure_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "promotion_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "promotion_approval", "first_use_review_required"],
      "properties": {
        "state": {
          "$ref": "#/$defs/promotion_state_class"
        },
        "promoted_recipe_ref": {
          "type": "string"
        },
        "recipe_pack_ref": {
          "type": "string"
        },
        "promotion_approval": {
          "$ref": "#/$defs/approval_posture_class"
        },
        "reviewer_identity_ref": {
          "type": "string"
        },
        "first_use_review_required": {
          "type": "boolean"
        }
      }
    },
    "insertion_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_class",
        "preview",
        "approval",
        "insertion_reversible",
        "insertion_label"
      ],
      "properties": {
        "target_class": {
          "$ref": "#/$defs/insertion_target_class"
        },
        "preview": {
          "$ref": "#/$defs/replay_preview_class"
        },
        "approval": {
          "$ref": "#/$defs/approval_posture_class"
        },
        "insertion_reversible": {
          "type": "boolean"
        },
        "insertion_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "headless_result_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "result_content_address",
        "steps_total",
        "steps_completed",
        "steps_deferred",
        "steps_blocked",
        "audit",
        "result_label"
      ],
      "properties": {
        "state": {
          "$ref": "#/$defs/headless_result_state_class"
        },
        "result_content_address": {
          "$ref": "#/$defs/non_empty_string"
        },
        "steps_total": {
          "type": "integer",
          "minimum": 0
        },
        "steps_completed": {
          "type": "integer",
          "minimum": 0
        },
        "steps_deferred": {
          "type": "integer",
          "minimum": 0
        },
        "steps_blocked": {
          "type": "integer",
          "minimum": 0
        },
        "audit": {
          "$ref": "#/$defs/audit_class"
        },
        "result_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger", "narrowed_to", "auto_enforced", "rationale"],
      "properties": {
        "trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "narrowed_to": {
          "$ref": "#/$defs/qualification_class"
        },
        "auto_enforced": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    },
    "user_automation_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "macro_id",
        "macro_label",
        "macro_family_label",
        "macro_version",
        "capture_content_address",
        "capture_provenance",
        "recorded_step_count",
        "publisher_source_class",
        "resolved_mode",
        "promotion",
        "insertion",
        "headless_result",
        "steps",
        "claimed_qualification",
        "downgrade_rules",
        "rollback_posture",
        "rollback_verified",
        "evidence_packet_refs",
        "explanation_label"
      ],
      "properties": {
        "macro_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "macro_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "macro_family_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "macro_version": {
          "$ref": "#/$defs/non_empty_string"
        },
        "capture_content_address": {
          "$ref": "#/$defs/non_empty_string"
        },
        "capture_provenance": {
          "$ref": "#/$defs/capture_provenance_class"
        },
        "recorded_step_count": {
          "type": "integer",
          "minimum": 0
        },
        "publisher_source_class": {
          "$ref": "#/$defs/publisher_source_class"
        },
        "publisher_identity_ref": {
          "type": "string"
        },
        "resolved_mode": {
          "$ref": "#/$defs/route_policy_mode"
        },
        "promotion": {
          "$ref": "#/$defs/promotion_block"
        },
        "insertion": {
          "$ref": "#/$defs/insertion_block"
        },
        "headless_result": {
          "$ref": "#/$defs/headless_result_block"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/step_disclosure"
          }
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "downgrade_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_rule"
          }
        },
        "rollback_posture": {
          "$ref": "#/$defs/rollback_posture"
        },
        "rollback_verified": {
          "type": "boolean"
        },
        "evidence_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "explanation_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
