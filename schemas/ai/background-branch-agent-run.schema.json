{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/background-branch-agent-run.schema.json",
  "title": "Aureline background branch-agent run lifecycle qualification packet",
  "description": "Export-safe packet for M4-exposed background branch-agent or long-running AI automation lanes. The packet binds launch review, active rows, checkpoint rows, re-review drift drills, operator takeover, completion review, cleanup posture, security review, and consumer projection to one stable run id. Raw branch names, worktree paths, diff bodies, logs, provider payloads, URLs, credentials, exact token counts, and exact cost amounts never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "stable_run_id",
    "plan_version",
    "initiator",
    "branch_identity_ref",
    "worktree_identity_ref",
    "base_commit_ref",
    "requested_goal",
    "current_state",
    "current_execution_locus",
    "pending_approvals",
    "evidence_refs",
    "cancellation_posture",
    "cleanup_posture",
    "launch_review",
    "active_run_rows",
    "checkpoint_rows",
    "drift_drills",
    "takeover",
    "completion_review",
    "cleanup_rows",
    "security_review",
    "consumer_projection",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "background_branch_agent_lifecycle_qualification"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "stable_run_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "plan_version": {
      "$ref": "#/$defs/non_empty_string"
    },
    "initiator": {
      "$ref": "#/$defs/non_empty_string"
    },
    "branch_identity_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "worktree_identity_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "base_commit_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "requested_goal": {
      "$ref": "#/$defs/non_empty_string"
    },
    "current_state": {
      "$ref": "#/$defs/run_state"
    },
    "current_execution_locus": {
      "$ref": "#/$defs/execution_locus"
    },
    "pending_approvals": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "evidence_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "cancellation_posture": {
      "$ref": "#/$defs/cancellation_posture"
    },
    "cleanup_posture": {
      "$ref": "#/$defs/cleanup_disposition"
    },
    "launch_review": {
      "$ref": "#/$defs/launch_review"
    },
    "active_run_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/active_run_row"
      }
    },
    "checkpoint_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/checkpoint_row"
      }
    },
    "drift_drills": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/drift_drill_row"
      }
    },
    "takeover": {
      "$ref": "#/$defs/takeover"
    },
    "completion_review": {
      "$ref": "#/$defs/completion_review"
    },
    "cleanup_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/cleanup_row"
      }
    },
    "security_review": {
      "$ref": "#/$defs/security_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "run_state": {
      "type": "string",
      "enum": [
        "planning",
        "collecting_context",
        "editing",
        "validating",
        "awaiting_approval",
        "blocked",
        "failed",
        "ready_for_review",
        "re_review_required",
        "cancelled",
        "operator_takeover"
      ]
    },
    "execution_locus": {
      "type": "string",
      "enum": [
        "local_only_current_worktree_assist",
        "isolated_side_worktree",
        "side_branch_no_worktree",
        "ephemeral_workspace",
        "managed_remote_workspace"
      ]
    },
    "operator_action": {
      "type": "string",
      "enum": [
        "pause",
        "cancel",
        "open_review",
        "take_over_manually",
        "compare_to_base",
        "cherry_pick",
        "rerun_validation",
        "discard_branch",
        "resume_from_checkpoint"
      ]
    },
    "operator_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/operator_action"
      }
    },
    "drift_trigger": {
      "type": "string",
      "enum": [
        "base_branch_advance",
        "provider_model_route_drift",
        "policy_epoch_change",
        "trust_narrowing",
        "boundary_expansion"
      ]
    },
    "cancellation_posture": {
      "type": "string",
      "enum": [
        "compute_stopped_immediately",
        "finishing_safely",
        "continue_until_safe_checkpoint",
        "not_cancelled"
      ]
    },
    "cleanup_disposition": {
      "type": "string",
      "enum": [
        "retain_for_review",
        "preview_delete_available",
        "discarded_after_evidence_retention",
        "retention_blocked"
      ]
    },
    "launch_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_run_id",
        "requested_goal",
        "base_ref",
        "target_identity_ref",
        "tool_connector_classes",
        "approval_gates",
        "estimated_cost_risk_band",
        "secret_scope",
        "stop_conditions"
      ],
      "properties": {
        "stable_run_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "requested_goal": {
          "$ref": "#/$defs/non_empty_string"
        },
        "base_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_identity_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "tool_connector_classes": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "approval_gates": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "estimated_cost_risk_band": {
          "$ref": "#/$defs/non_empty_string"
        },
        "secret_scope": {
          "$ref": "#/$defs/non_empty_string"
        },
        "stop_conditions": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "active_run_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_run_id",
        "elapsed_time_label",
        "current_milestone",
        "environment_assumptions",
        "pending_approvals",
        "operator_actions",
        "execution_locus"
      ],
      "properties": {
        "stable_run_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "elapsed_time_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "current_milestone": {
          "$ref": "#/$defs/run_state"
        },
        "environment_assumptions": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "pending_approvals": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "operator_actions": {
          "$ref": "#/$defs/operator_actions"
        },
        "execution_locus": {
          "$ref": "#/$defs/execution_locus"
        }
      }
    },
    "checkpoint_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_run_id",
        "checkpoint_id",
        "elapsed_time_label",
        "milestone",
        "new_artifact_refs",
        "evidence_refs",
        "pending_approvals",
        "operator_actions",
        "review_artifacts_preserved"
      ],
      "properties": {
        "stable_run_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "checkpoint_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "elapsed_time_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "milestone": {
          "$ref": "#/$defs/run_state"
        },
        "new_artifact_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "pending_approvals": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "operator_actions": {
          "$ref": "#/$defs/operator_actions"
        },
        "review_artifacts_preserved": {
          "const": true
        }
      }
    },
    "drift_drill_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_run_id",
        "trigger",
        "drift_summary",
        "resulting_state",
        "further_writes_blocked",
        "already_produced_artifacts_preserved",
        "requires_re_review_or_takeover",
        "pauses_or_narrows_safely"
      ],
      "properties": {
        "stable_run_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "trigger": {
          "$ref": "#/$defs/drift_trigger"
        },
        "drift_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "resulting_state": {
          "const": "re_review_required"
        },
        "further_writes_blocked": {
          "const": true
        },
        "already_produced_artifacts_preserved": {
          "const": true
        },
        "requires_re_review_or_takeover": {
          "const": true
        },
        "pauses_or_narrows_safely": {
          "const": true
        }
      }
    },
    "takeover": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_run_id",
        "branch_identity_preserved",
        "checkpoint_lineage_preserved",
        "tool_call_history_preserved",
        "validation_receipts_preserved",
        "pending_writes_disclosed",
        "safe_next_step",
        "rerun_options"
      ],
      "properties": {
        "stable_run_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "branch_identity_preserved": {
          "const": true
        },
        "checkpoint_lineage_preserved": {
          "const": true
        },
        "tool_call_history_preserved": {
          "const": true
        },
        "validation_receipts_preserved": {
          "const": true
        },
        "pending_writes_disclosed": {
          "const": true
        },
        "safe_next_step": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rerun_options": {
          "$ref": "#/$defs/operator_actions"
        }
      }
    },
    "completion_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_run_id",
        "diff_summary_ref",
        "validation_summary_ref",
        "evidence_packet_ref",
        "compare_to_base_available",
        "cleanup_options_available",
        "follow_up_actions",
        "self_merge_forbidden",
        "protected_destination_push_forbidden"
      ],
      "properties": {
        "stable_run_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "diff_summary_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "validation_summary_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_packet_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "compare_to_base_available": {
          "const": true
        },
        "cleanup_options_available": {
          "const": true
        },
        "follow_up_actions": {
          "$ref": "#/$defs/operator_actions"
        },
        "self_merge_forbidden": {
          "const": true
        },
        "protected_destination_push_forbidden": {
          "const": true
        }
      }
    },
    "cleanup_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_run_id",
        "disposition",
        "evidence_retention",
        "checkpoint_retention",
        "preview_required_before_delete",
        "review_artifacts_survive_cleanup",
        "support_export_ref"
      ],
      "properties": {
        "stable_run_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "disposition": {
          "$ref": "#/$defs/cleanup_disposition"
        },
        "evidence_retention": {
          "$ref": "#/$defs/non_empty_string"
        },
        "checkpoint_retention": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preview_required_before_delete": {
          "const": true
        },
        "review_artifacts_survive_cleanup": {
          "const": true
        },
        "support_export_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "security_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_self_approved_mutating_tools",
        "no_worktree_isolation_bypass",
        "execution_loci_not_collapsed",
        "local_side_and_managed_loci_distinct",
        "protected_destination_self_push_blocked"
      ],
      "properties": {
        "no_self_approved_mutating_tools": {
          "const": true
        },
        "no_worktree_isolation_bypass": {
          "const": true
        },
        "execution_loci_not_collapsed": {
          "const": true
        },
        "local_side_and_managed_loci_distinct": {
          "const": true
        },
        "protected_destination_self_push_blocked": {
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ui_rows_use_stable_run_id",
        "support_exports_use_stable_run_id",
        "evidence_packets_use_stable_run_id",
        "docs_help_cite_governed_contract",
        "preview_labs_label_for_unqualified_lanes"
      ],
      "properties": {
        "ui_rows_use_stable_run_id": {
          "const": true
        },
        "support_exports_use_stable_run_id": {
          "const": true
        },
        "evidence_packets_use_stable_run_id": {
          "const": true
        },
        "docs_help_cite_governed_contract": {
          "const": true
        },
        "preview_labs_label_for_unqualified_lanes": {
          "const": true
        }
      }
    }
  }
}
