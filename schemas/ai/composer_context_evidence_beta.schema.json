{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/composer_context_evidence_beta.schema.json",
  "title": "Aureline AI composer context evidence beta support packet",
  "$comment": "Rust owner: aureline_ai::composer::beta::ComposerContextEvidenceBetaPacket.",
  "description": "Boundary schema for the metadata-only support packet that joins prompt composer context, retrieval inspector state, mutation evidence, route lineage, and spend receipts for a claimed AI composer beta surface. The packet contains refs, state tokens, labels, and coarse cost classes only. It never carries raw prompt bodies, source file bodies, provider payloads, endpoint URLs, credentials, raw token counts, exact prices, or billing-account ids.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "display_label",
    "composer_context_snapshot_ref",
    "composer_session_ref",
    "turn_draft_ref",
    "request_workspace_ref",
    "context_review_state_token",
    "required_context_state_tokens",
    "observed_context_state_tokens",
    "context_rows",
    "retrieval_packet_ref",
    "retrieval_promotion_state_token",
    "evidence_packet_ref",
    "evidence_packet_state_token",
    "routing_packet_ref",
    "route_receipt_ref",
    "spend_receipt_ref",
    "selected_provider_entry_ref",
    "selected_model_entry_ref",
    "selected_provider_label",
    "selected_model_label",
    "route_origin_token",
    "cost_envelope_token",
    "cost_visibility_token",
    "tool_call_lineage_refs",
    "approval_ticket_refs",
    "apply_outcome_token",
    "spend_receipt_run_state_token",
    "spend_receipt_cost_envelope_token",
    "spend_receipt_cost_visibility_token",
    "spend_receipt_charge_locus_token",
    "surface_rows",
    "source_contract_refs",
    "json_export_ref",
    "markdown_summary_ref",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "composer_context_evidence_beta_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "$ref": "#/$defs/opaque_ref" },
    "workflow_or_surface_id": { "$ref": "#/$defs/opaque_ref" },
    "display_label": { "$ref": "#/$defs/review_label" },
    "composer_context_snapshot_ref": { "$ref": "#/$defs/opaque_ref" },
    "composer_session_ref": { "$ref": "#/$defs/opaque_ref" },
    "turn_draft_ref": { "$ref": "#/$defs/opaque_ref" },
    "request_workspace_ref": { "$ref": "#/$defs/opaque_ref" },
    "context_review_state_token": {
      "type": "string",
      "enum": [
        "ready_to_send",
        "blocked_pending_resolution",
        "budget_review_required",
        "re_review_required"
      ]
    },
    "required_context_state_tokens": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/context_state_token" },
      "contains": { "const": "trimmed" }
    },
    "observed_context_state_tokens": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/context_state_token" },
      "contains": { "const": "trimmed" }
    },
    "context_rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/context_row" }
    },
    "retrieval_packet_ref": { "$ref": "#/$defs/opaque_ref" },
    "retrieval_promotion_state_token": { "const": "promotable" },
    "retrieval_validation_finding_tokens": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_packet_ref": { "$ref": "#/$defs/opaque_ref" },
    "evidence_packet_state_token": {
      "type": "string",
      "enum": ["applied", "rejected"]
    },
    "routing_packet_ref": { "$ref": "#/$defs/opaque_ref" },
    "route_receipt_ref": { "$ref": "#/$defs/opaque_ref" },
    "spend_receipt_ref": { "$ref": "#/$defs/opaque_ref" },
    "selected_provider_entry_ref": { "$ref": "#/$defs/opaque_ref" },
    "selected_model_entry_ref": { "$ref": "#/$defs/opaque_ref" },
    "selected_provider_label": { "$ref": "#/$defs/review_label" },
    "selected_model_label": { "$ref": "#/$defs/review_label" },
    "route_origin_token": { "type": "string", "minLength": 1 },
    "cost_envelope_token": { "$ref": "#/$defs/cost_envelope_token" },
    "cost_visibility_token": { "$ref": "#/$defs/cost_visibility_token" },
    "tool_call_lineage_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/opaque_ref" }
    },
    "approval_ticket_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/opaque_ref" }
    },
    "apply_outcome_token": { "type": "string", "minLength": 1 },
    "spend_receipt_run_state_token": {
      "type": "string",
      "enum": [
        "post_run_completed",
        "post_run_failed",
        "cancelled_by_user",
        "cancelled_by_policy",
        "budget_blocked_refusal",
        "route_blocked_refusal"
      ]
    },
    "spend_receipt_cost_envelope_token": { "$ref": "#/$defs/cost_envelope_token" },
    "spend_receipt_cost_visibility_token": { "$ref": "#/$defs/cost_visibility_token" },
    "spend_receipt_charge_locus_token": {
      "type": "string",
      "enum": [
        "not_charged_local",
        "not_charged_bundled",
        "charged_user_byok_metered",
        "charged_user_byok_subscription",
        "charged_organisation_pooled",
        "charged_organisation_subscription",
        "charge_unknown_unverified",
        "not_charged_run_blocked"
      ]
    },
    "surface_rows": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/surface_row" }
    },
    "source_contract_refs": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/repo_ref" }
    },
    "json_export_ref": { "$ref": "#/$defs/repo_ref" },
    "markdown_summary_ref": { "$ref": "#/$defs/repo_ref" },
    "minted_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "://" },
          { "pattern": "[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]" },
          { "pattern": "[Oo][Aa][Uu][Tt][Hh][_-]?[Tt][Oo][Kk][Ee][Nn]" },
          { "pattern": "[Bb][Ee][Aa][Rr][Ee][Rr] " },
          { "pattern": "[Bb][Ii][Ll][Ll][Ii][Nn][Gg]-[Aa][Cc][Cc][Oo][Uu][Nn][Tt]" }
        ]
      }
    },
    "repo_ref": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "://" }
    },
    "review_label": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "://" },
          { "pattern": "[Rr][Aa][Ww]_[Pp][Rr][Oo][Mm][Pp][Tt]" },
          { "pattern": "[Bb][Ee][Aa][Rr][Ee][Rr] " }
        ]
      }
    },
    "context_state_token": {
      "type": "string",
      "enum": [
        "included",
        "pinned",
        "omitted",
        "blocked",
        "stale",
        "tainted",
        "summarized",
        "trimmed",
        "not_requested"
      ]
    },
    "cost_envelope_token": {
      "type": "string",
      "enum": [
        "bundled_no_incremental_cost",
        "free_tier_rate_limited",
        "metered_per_request_low_volume_band",
        "metered_per_request_medium_volume_band",
        "metered_per_request_high_volume_band",
        "metered_per_token_low_volume_band",
        "metered_per_token_medium_volume_band",
        "metered_per_token_high_volume_band",
        "flat_fee_subscription_band",
        "enterprise_pooled_quota_band",
        "vendor_hosted_entitlement_band",
        "estimated_unverified_band",
        "envelope_unknown_unverified_cost"
      ]
    },
    "cost_visibility_token": {
      "type": "string",
      "enum": [
        "metered_per_request",
        "metered_per_token",
        "flat_fee_subscription",
        "bundled_no_incremental_cost",
        "estimated_unverified",
        "undisclosed_by_provider"
      ]
    },
    "context_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_item_id",
        "group_token",
        "state_token",
        "source_class_token",
        "stable_identity_ref",
        "freshness_token",
        "trust_token",
        "locality_token"
      ],
      "properties": {
        "context_item_id": { "$ref": "#/$defs/opaque_ref" },
        "group_token": { "type": "string", "minLength": 1 },
        "state_token": { "$ref": "#/$defs/context_state_token" },
        "source_class_token": { "type": "string", "minLength": 1 },
        "stable_identity_ref": { "$ref": "#/$defs/opaque_ref" },
        "freshness_token": { "type": "string", "minLength": 1 },
        "trust_token": { "type": "string", "minLength": 1 },
        "locality_token": { "type": "string", "minLength": 1 },
        "omission_reason_token": { "type": "string", "minLength": 1 },
        "source_attachment_ref": { "$ref": "#/$defs/opaque_ref" },
        "source_mention_ref": { "$ref": "#/$defs/opaque_ref" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state_token": {
                "enum": ["omitted", "blocked", "stale", "tainted", "summarized", "trimmed"]
              }
            },
            "required": ["state_token"]
          },
          "then": { "required": ["omission_reason_token"] }
        }
      ]
    },
    "surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "projection_ref",
        "composer_context_snapshot_ref",
        "evidence_packet_ref",
        "route_receipt_ref",
        "spend_receipt_ref",
        "context_state_tokens",
        "preserves_operator_truth",
        "raw_private_material_excluded",
        "supports_json_export",
        "supports_markdown_summary"
      ],
      "properties": {
        "surface_class": {
          "type": "string",
          "enum": [
            "composer",
            "context_inspector",
            "review_workspace",
            "docs_help",
            "support_export",
            "cli"
          ]
        },
        "projection_ref": { "$ref": "#/$defs/opaque_ref" },
        "composer_context_snapshot_ref": { "$ref": "#/$defs/opaque_ref" },
        "evidence_packet_ref": { "$ref": "#/$defs/opaque_ref" },
        "route_receipt_ref": { "$ref": "#/$defs/opaque_ref" },
        "spend_receipt_ref": { "$ref": "#/$defs/opaque_ref" },
        "context_state_tokens": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/context_state_token" },
          "contains": { "const": "trimmed" }
        },
        "preserves_operator_truth": { "const": true },
        "raw_private_material_excluded": { "const": true },
        "supports_json_export": { "const": true },
        "supports_markdown_summary": { "const": true }
      }
    }
  }
}
