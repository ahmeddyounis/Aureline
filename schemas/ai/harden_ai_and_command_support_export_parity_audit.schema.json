{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/harden_ai_and_command_support_export_parity_audit.schema.json",
  "title": "Aureline AI and command support-export parity audit record",
  "$comment": "Rust owner: aureline_commands::harden_ai_and_command_support_export_parity_audit::HardenAiAndCommandSupportExportParityAuditPacket.",
  "description": "Boundary schema for the metadata-only AI and command support-export parity audit record. For one claimed stable row, the packet binds the shared support-export parity contract (preview-record ref, approval-lineage ref, provider/route identity, spend/egress disclosure, tainted-context fence handling, rollback/revert handle ref, and audit-lineage trace on every write-capable surface, with AI and command sharing one descriptor, preview, approval, result, and rollback model and no hidden provider route), the audit-lineage contract (actor identity, invocation surface, policy epoch, provider/route identity, decision ref, outcome, and non-repudiation), the shiproom-inclusion contract (stable proof index, release checklist, support export bundle, and checked artifact-ref validation), and the exportable evidence/rollback lineage. It does not re-derive the descriptor, registry, invocation, result, preview, approval, rollback, or evidence-export models; it binds them by canonical refs. It carries refs, stable class tokens, booleans, counts, and review labels only. It never carries raw prompts, raw command arguments, raw diff bodies, endpoint URLs, credentials, provider payloads, or signing-key material. Adding a new enum member or a new optional field is additive-minor; repurposing an existing member is breaking and bumps schema_version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "display_label",
    "claimed_stable",
    "policy_epoch_ref",
    "contract_refs",
    "export_parity_contract",
    "surface_parity_rows",
    "audit_lineage",
    "shiproom_inclusion",
    "evidence_export",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "harden_ai_command_support_export_parity_audit" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "display_label": { "type": "string", "minLength": 1 },
    "claimed_stable": { "type": "boolean" },
    "policy_epoch_ref": { "type": "string", "minLength": 1 },
    "contract_refs": { "$ref": "#/$defs/stable_contract_refs" },
    "export_parity_contract": { "$ref": "#/$defs/export_parity_contract" },
    "surface_parity_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/support_export_parity_row" }
    },
    "audit_lineage": { "$ref": "#/$defs/audit_lineage_contract" },
    "shiproom_inclusion": { "$ref": "#/$defs/shiproom_inclusion_contract" },
    "evidence_export": { "$ref": "#/$defs/evidence_export_block" },
    "source_contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "support_export_surface_class": {
      "type": "string",
      "enum": [
        "ui_palette_or_menu",
        "keybinding",
        "cli_headless",
        "ai_tool",
        "automation_recipe",
        "deep_link_or_browser_companion",
        "voice"
      ]
    },
    "export_parity_requirement_class": {
      "type": "string",
      "enum": [
        "preview_record_ref",
        "approval_lineage_ref",
        "provider_and_route_identity",
        "spend_and_egress_disclosure",
        "tainted_context_fence_handling",
        "rollback_or_revert_handle_ref",
        "audit_lineage_trace"
      ]
    },
    "audit_lineage_requirement_class": {
      "type": "string",
      "enum": [
        "actor_identity_bound",
        "invocation_surface_recorded",
        "policy_epoch_pinned",
        "provider_route_recorded",
        "decision_ref_traceable",
        "outcome_recorded"
      ]
    },
    "shiproom_inclusion_class": {
      "type": "string",
      "enum": [
        "indexed_in_stable_proof_index",
        "referenced_by_release_checklist",
        "included_in_support_export_bundle",
        "artifact_refs_validated"
      ]
    },
    "surface_qualification_class": {
      "type": "string",
      "enum": ["stable", "beta", "experimental", "not_applicable"]
    },
    "stable_contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "descriptor_schema_ref",
        "registry_entry_schema_ref",
        "registry_seed_ref",
        "invocation_session_schema_ref",
        "result_packet_schema_ref",
        "public_contract_schema_ref",
        "parity_expectation_schema_ref",
        "disabled_reason_vocabulary_ref"
      ],
      "properties": {
        "descriptor_schema_ref": { "type": "string", "minLength": 1 },
        "registry_entry_schema_ref": { "type": "string", "minLength": 1 },
        "registry_seed_ref": { "type": "string", "minLength": 1 },
        "invocation_session_schema_ref": { "type": "string", "minLength": 1 },
        "result_packet_schema_ref": { "type": "string", "minLength": 1 },
        "public_contract_schema_ref": { "type": "string", "minLength": 1 },
        "parity_expectation_schema_ref": { "type": "string", "minLength": 1 },
        "disabled_reason_vocabulary_ref": { "type": "string", "minLength": 1 }
      }
    },
    "support_export_parity_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "descriptor_ref",
        "reachable",
        "carries_preview_record",
        "carries_approval_lineage",
        "carries_provider_route_identity",
        "carries_spend_egress_disclosure",
        "carries_tainted_context_fence",
        "carries_rollback_handle",
        "carries_audit_lineage",
        "no_authority_widening",
        "qualification",
        "claimed_stable"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/support_export_surface_class" },
        "descriptor_ref": { "type": "string", "minLength": 1 },
        "reachable": { "type": "boolean" },
        "carries_preview_record": { "type": "boolean" },
        "carries_approval_lineage": { "type": "boolean" },
        "carries_provider_route_identity": { "type": "boolean" },
        "carries_spend_egress_disclosure": { "type": "boolean" },
        "carries_tainted_context_fence": { "type": "boolean" },
        "carries_rollback_handle": { "type": "boolean" },
        "carries_audit_lineage": { "type": "boolean" },
        "no_authority_widening": { "type": "boolean" },
        "qualification": { "$ref": "#/$defs/surface_qualification_class" },
        "claimed_stable": { "type": "boolean" }
      }
    },
    "export_parity_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "requirements",
        "ai_and_command_share_one_descriptor",
        "ai_and_command_share_one_preview_model",
        "ai_and_command_share_one_approval_model",
        "ai_and_command_share_one_result_model",
        "ai_and_command_share_one_rollback_model",
        "provider_route_explicit_on_every_surface",
        "spend_egress_explicit_on_every_surface",
        "tainted_context_explicit_on_every_surface",
        "no_hidden_provider_route"
      ],
      "properties": {
        "required": { "type": "boolean" },
        "requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/export_parity_requirement_class" }
        },
        "ai_and_command_share_one_descriptor": { "type": "boolean" },
        "ai_and_command_share_one_preview_model": { "type": "boolean" },
        "ai_and_command_share_one_approval_model": { "type": "boolean" },
        "ai_and_command_share_one_result_model": { "type": "boolean" },
        "ai_and_command_share_one_rollback_model": { "type": "boolean" },
        "provider_route_explicit_on_every_surface": { "type": "boolean" },
        "spend_egress_explicit_on_every_surface": { "type": "boolean" },
        "tainted_context_explicit_on_every_surface": { "type": "boolean" },
        "no_hidden_provider_route": { "type": "boolean" }
      }
    },
    "audit_lineage_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "requirements",
        "actor_identity_bound",
        "invocation_surface_recorded",
        "policy_epoch_pinned",
        "provider_route_recorded",
        "decision_ref_traceable",
        "outcome_recorded",
        "non_repudiable",
        "policy_epoch_ref"
      ],
      "properties": {
        "required": { "type": "boolean" },
        "requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/audit_lineage_requirement_class" }
        },
        "actor_identity_bound": { "type": "boolean" },
        "invocation_surface_recorded": { "type": "boolean" },
        "policy_epoch_pinned": { "type": "boolean" },
        "provider_route_recorded": { "type": "boolean" },
        "decision_ref_traceable": { "type": "boolean" },
        "outcome_recorded": { "type": "boolean" },
        "non_repudiable": { "type": "boolean" },
        "policy_epoch_ref": { "type": "string", "minLength": 1 }
      }
    },
    "shiproom_inclusion_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "inclusions",
        "indexed_in_stable_proof_index",
        "referenced_by_release_checklist",
        "included_in_support_export_bundle",
        "artifact_refs_validated",
        "stable_proof_index_ref"
      ],
      "properties": {
        "required": { "type": "boolean" },
        "inclusions": {
          "type": "array",
          "items": { "$ref": "#/$defs/shiproom_inclusion_class" }
        },
        "indexed_in_stable_proof_index": { "type": "boolean" },
        "referenced_by_release_checklist": { "type": "boolean" },
        "included_in_support_export_bundle": { "type": "boolean" },
        "artifact_refs_validated": { "type": "boolean" },
        "stable_proof_index_ref": { "type": "string", "minLength": 1 }
      }
    },
    "evidence_export_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "json_export_ref",
        "markdown_summary_ref",
        "admin_inspector_ref",
        "support_export_ref",
        "rollback_lineage_refs",
        "export_lineage_refs"
      ],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "json_export_ref": { "type": "string", "minLength": 1 },
        "markdown_summary_ref": { "type": "string", "minLength": 1 },
        "admin_inspector_ref": { "type": "string", "minLength": 1 },
        "support_export_ref": { "type": "string", "minLength": 1 },
        "rollback_lineage_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "export_lineage_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
