{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ai/review_scope_selection.schema.json",
  "title": "Aureline AI review-assist scope-selector vocabulary",
  "description": "Boundary schema for the review_scope_selection_record family frozen in docs/ai/review_assist_publish_contract.md. Every AI review-assist run is bound to exactly one review_scope_selection_record naming the analyzed scope (selected_diff_in_local_workspace / uncommitted_changes_in_local_workspace / whole_branch_against_base / hosted_review_object / imported_review_bundle_scope / browser_handoff_token_scope / composite_local_with_provider_overlay_scope), the base/head context (revision pair, branch pair, provider pull/merge request, imported bundle envelope, or browser-handoff packet), the freshness chip on the run, the rerun reason class, and the scope lineage class so a downstream finding can answer 'which scope was analyzed and why this run' without opening any other object. The schema composes with (and does not replace) schemas/vcs/review_workspace.schema.json (review_workspace_source_class, provider_overlay_freshness_class, provider_authority_class), schemas/governance/capability_lifecycle.schema.json (freshness_class, client_scope, redaction_class), and schemas/integration/browser_handoff_packet.schema.json. Raw absolute paths, raw branch / commit URLs, raw provider thread URLs, raw author identity strings, raw diff bodies, raw notebook cell text, raw terminal bytes, raw prompt text, and raw URLs MUST NOT appear on any record emitted against this schema; every such field is an opaque ref. The eventual review-assist crate's Rust types are the schema of record; this file is the cross-tool boundary every non-owning surface reads. Adding a new record kind, scope class, base/head kind, freshness class, rerun reason, scope lineage class, denial reason, or audit-event id is additive-minor and bumps review_scope_selection_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/review_scope_selection_record" },
    { "$ref": "#/$defs/review_scope_selection_audit_event_record" }
  ],
  "$defs": {
    "review_scope_selection_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the review-scope-selection vocabulary. Current value is 1. Bumped only on breaking payload changes; additive-optional fields do not bump this version."
    },

    "record_kind": {
      "type": "string",
      "enum": [
        "review_scope_selection_record",
        "review_scope_selection_audit_event_record"
      ],
      "description": "Discriminator for the concrete payload shape. Every record carries exactly one kind."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests / journal entries / support bundles. Raw absolute paths, raw branch / commit URLs, raw provider thread URLs, raw author identity strings, raw diff bodies, raw notebook cell text, raw terminal bytes, raw prompt text, and raw URLs never appear here."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },

    "reviewable_label": {
      "type": "string",
      "maxLength": 1024,
      "description": "Redaction-aware reviewable label (<= 1024 graphemes). Carries a presentation-only summary for support / audit; never carries the raw payload. Exporters MUST apply broker-owned redaction (ADR-0007) before the value crosses this boundary."
    },

    "client_scope": {
      "type": "string",
      "enum": [
        "desktop_product",
        "cli",
        "companion_surface",
        "remote_agent",
        "sdk_or_api",
        "managed_admin_surface"
      ],
      "description": "Re-exported verbatim from schemas/governance/capability_lifecycle.schema.json (ADR-0011)."
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ],
      "description": "Re-exported verbatim from schemas/governance/capability_lifecycle.schema.json (ADR-0011)."
    },

    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ],
      "description": "Re-exported verbatim from schemas/governance/capability_lifecycle.schema.json (ADR-0011). Used only for the workspace-level freshness chip on the scope row; the per-run material-change posture lives in scope_freshness_class."
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted"]
        },
        "execution_context_id": { "type": "string", "minLength": 1 },
        "workspace_trust_state_class": {
          "type": "string",
          "enum": [
            "trusted",
            "restricted",
            "unset_pending_decision"
          ],
          "description": "Re-exported from ADR-0018."
        }
      },
      "description": "Policy context the scope row was minted under."
    },

    "scope_class": {
      "type": "string",
      "enum": [
        "selected_diff_in_local_workspace",
        "uncommitted_changes_in_local_workspace",
        "whole_branch_against_base",
        "hosted_review_object",
        "imported_review_bundle_scope",
        "browser_handoff_token_scope",
        "composite_local_with_provider_overlay_scope"
      ],
      "description": "Frozen scope class. selected_diff_in_local_workspace is a reviewer-pinned diff range under the local clone; uncommitted_changes_in_local_workspace is the working-tree diff against the index; whole_branch_against_base is the full branch diff; hosted_review_object is a provider-side pull / merge request the workspace overlay binds; imported_review_bundle_scope is a review bundle imported offline (no auto re-fetch); browser_handoff_token_scope is opened through an ADR-0010 browser-handoff packet (read-only, no local mutation); composite_local_with_provider_overlay_scope pairs a local locator with a fetched provider overlay so the run can compare local truth against provider truth."
    },

    "base_head_context_kind": {
      "type": "string",
      "enum": [
        "base_head_revision_pair",
        "base_head_branch_pair",
        "base_head_uncommitted_against_index",
        "base_provider_pull_or_merge_request",
        "base_imported_bundle_envelope",
        "base_browser_handoff_packet"
      ],
      "description": "Frozen base / head context kind. Every scope row carries exactly one kind so the row can answer 'what does base/head mean here' mechanically. base_head_revision_pair pins two revision refs; base_head_branch_pair pins two branch refs; base_head_uncommitted_against_index pins the index against the working tree; base_provider_pull_or_merge_request resolves through the workspace's provider overlay; base_imported_bundle_envelope resolves through the imported-bundle envelope; base_browser_handoff_packet resolves through the browser-handoff packet."
    },

    "scope_freshness_class": {
      "type": "string",
      "enum": [
        "scope_fresh_no_material_change_since_run",
        "scope_warm_minor_unrelated_change_since_run",
        "scope_diff_changed_after_run_outdated",
        "scope_base_or_head_changed_after_run_outdated",
        "scope_provider_overlay_refreshed_rerun_recommended",
        "scope_provider_overlay_unavailable_local_continues",
        "scope_imported_bundle_pinned_no_drift_assessable",
        "scope_browser_handoff_pinned_no_drift_assessable",
        "scope_unverifiable_evaluator_outage_rerun_required"
      ],
      "description": "Frozen per-run freshness class. scope_fresh_no_material_change_since_run is the only state that admits a finding to remain in the open lifecycle without a typed rerun chip; scope_diff_changed_after_run_outdated and scope_base_or_head_changed_after_run_outdated force matching findings into outdated / rerun-recommended / superseded lifecycle; scope_provider_overlay_unavailable_local_continues honours the workspace's provider_overlay_unavailable_local_continues posture; scope_imported_bundle_pinned_no_drift_assessable and scope_browser_handoff_pinned_no_drift_assessable record the pin so a reused result is not painted as freshly-evaluated; scope_unverifiable_evaluator_outage_rerun_required is the outage state."
    },

    "scope_lineage_class": {
      "type": "string",
      "enum": [
        "freshly_minted_no_predecessor",
        "derived_from_prior_scope_diff_changed",
        "derived_from_prior_scope_base_head_changed",
        "derived_from_prior_scope_provider_overlay_refreshed",
        "derived_from_prior_scope_user_widened",
        "derived_from_prior_scope_user_narrowed",
        "derived_from_prior_scope_rerun_no_change",
        "derived_from_prior_scope_policy_or_pack_updated"
      ],
      "description": "Frozen scope-lineage vocabulary. freshly_minted_no_predecessor is the initial-run state and forbids a predecessor_scope_id_ref; every derived_from_* value MUST cite a non-null predecessor_scope_id_ref and pair with the matching rerun_reason_class through an allOf gate."
    },

    "rerun_reason_class": {
      "type": "string",
      "enum": [
        "not_a_rerun_initial_run",
        "user_requested_rerun_no_change",
        "user_widened_scope",
        "user_narrowed_scope",
        "diff_changed_after_run_rerun_required",
        "base_or_head_changed_after_run_rerun_required",
        "provider_overlay_refreshed_rerun_recommended",
        "policy_or_pack_updated_rerun_required",
        "evaluator_outage_rerun_required"
      ],
      "description": "Frozen rerun-reason vocabulary. not_a_rerun_initial_run pairs with scope_lineage_class = freshly_minted_no_predecessor; the seven rerun reasons each pair with a specific scope_lineage_class through an allOf gate so the row remains internally consistent."
    },

    "review_scope_selection_denial_reason": {
      "type": "string",
      "enum": [
        "scope_class_must_match_base_head_context",
        "local_locator_required_for_local_or_composite_scope",
        "provider_overlay_required_for_provider_or_composite_scope",
        "imported_bundle_envelope_required_for_imported_bundle_scope",
        "browser_handoff_packet_required_for_browser_handoff_scope",
        "predecessor_required_for_derived_lineage",
        "predecessor_forbidden_for_freshly_minted_lineage",
        "rerun_reason_must_match_lineage",
        "scope_freshness_must_match_workspace_overlay_freshness",
        "policy_epoch_expired_re_evaluation_required",
        "workspace_trust_unset_or_restricted",
        "review_scope_selection_record_required_field_missing",
        "review_scope_selection_record_unknown_value"
      ],
      "description": "Frozen denial-reason vocabulary on the review_scope_selection audit stream."
    },

    "review_scope_selection_audit_event_id": {
      "type": "string",
      "enum": [
        "review_scope_selection_minted",
        "review_scope_selection_freshness_changed",
        "review_scope_selection_lineage_recorded",
        "review_scope_selection_outdated_after_diff_change",
        "review_scope_selection_outdated_after_base_or_head_change",
        "review_scope_selection_provider_overlay_refreshed",
        "review_scope_selection_archived",
        "review_scope_selection_audit_denial_emitted"
      ],
      "description": "Frozen audit-event ids on the review_scope_selection stream. review_scope_selection_audit_denial_emitted MUST cite a review_scope_selection_denial_reason."
    },

    "local_locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace_id_ref", "branch_or_worktree_ref"],
      "properties": {
        "workspace_id_ref": { "$ref": "#/$defs/opaque_id" },
        "branch_or_worktree_ref": { "$ref": "#/$defs/opaque_id" },
        "head_revision_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      },
      "description": "Local locator mirroring schemas/vcs/review_workspace.schema.json local_locator. Required when scope_class is local / uncommitted / whole-branch / composite."
    },

    "base_head_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_head_context_kind"],
      "properties": {
        "base_head_context_kind": { "$ref": "#/$defs/base_head_context_kind" },
        "base_revision_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Required (non-null) for base_head_revision_pair; null otherwise."
        },
        "head_revision_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Required (non-null) for base_head_revision_pair; null otherwise."
        },
        "base_branch_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Required (non-null) for base_head_branch_pair; null otherwise."
        },
        "head_branch_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Required (non-null) for base_head_branch_pair; null otherwise."
        },
        "provider_object_identity_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Required (non-null) for base_provider_pull_or_merge_request; null otherwise. Opaque ref to the provider-side object identity (pull-request id, merge-request id) the overlay binds; raw URLs never appear here."
        },
        "imported_bundle_envelope_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Required (non-null) for base_imported_bundle_envelope; null otherwise."
        },
        "browser_handoff_packet_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Required (non-null) for base_browser_handoff_packet; null otherwise."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "base_head_context_kind": { "const": "base_head_revision_pair" } },
            "required": ["base_head_context_kind"]
          },
          "then": {
            "required": ["base_revision_id_ref", "head_revision_id_ref"],
            "properties": {
              "base_revision_id_ref": { "$ref": "#/$defs/opaque_id" },
              "head_revision_id_ref": { "$ref": "#/$defs/opaque_id" },
              "base_branch_ref": { "type": "null" },
              "head_branch_ref": { "type": "null" },
              "provider_object_identity_ref": { "type": "null" },
              "imported_bundle_envelope_ref": { "type": "null" },
              "browser_handoff_packet_ref": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": { "base_head_context_kind": { "const": "base_head_branch_pair" } },
            "required": ["base_head_context_kind"]
          },
          "then": {
            "required": ["base_branch_ref", "head_branch_ref"],
            "properties": {
              "base_branch_ref": { "$ref": "#/$defs/opaque_id" },
              "head_branch_ref": { "$ref": "#/$defs/opaque_id" },
              "base_revision_id_ref": { "type": "null" },
              "head_revision_id_ref": { "type": "null" },
              "provider_object_identity_ref": { "type": "null" },
              "imported_bundle_envelope_ref": { "type": "null" },
              "browser_handoff_packet_ref": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": { "base_head_context_kind": { "const": "base_head_uncommitted_against_index" } },
            "required": ["base_head_context_kind"]
          },
          "then": {
            "properties": {
              "base_revision_id_ref": { "type": "null" },
              "head_revision_id_ref": { "type": "null" },
              "base_branch_ref": { "type": "null" },
              "head_branch_ref": { "type": "null" },
              "provider_object_identity_ref": { "type": "null" },
              "imported_bundle_envelope_ref": { "type": "null" },
              "browser_handoff_packet_ref": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": { "base_head_context_kind": { "const": "base_provider_pull_or_merge_request" } },
            "required": ["base_head_context_kind"]
          },
          "then": {
            "required": ["provider_object_identity_ref"],
            "properties": {
              "provider_object_identity_ref": { "$ref": "#/$defs/opaque_id" },
              "base_revision_id_ref": { "type": "null" },
              "head_revision_id_ref": { "type": "null" },
              "base_branch_ref": { "type": "null" },
              "head_branch_ref": { "type": "null" },
              "imported_bundle_envelope_ref": { "type": "null" },
              "browser_handoff_packet_ref": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": { "base_head_context_kind": { "const": "base_imported_bundle_envelope" } },
            "required": ["base_head_context_kind"]
          },
          "then": {
            "required": ["imported_bundle_envelope_ref"],
            "properties": {
              "imported_bundle_envelope_ref": { "$ref": "#/$defs/opaque_id" },
              "base_revision_id_ref": { "type": "null" },
              "head_revision_id_ref": { "type": "null" },
              "base_branch_ref": { "type": "null" },
              "head_branch_ref": { "type": "null" },
              "provider_object_identity_ref": { "type": "null" },
              "browser_handoff_packet_ref": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": { "base_head_context_kind": { "const": "base_browser_handoff_packet" } },
            "required": ["base_head_context_kind"]
          },
          "then": {
            "required": ["browser_handoff_packet_ref"],
            "properties": {
              "browser_handoff_packet_ref": { "$ref": "#/$defs/opaque_id" },
              "base_revision_id_ref": { "type": "null" },
              "head_revision_id_ref": { "type": "null" },
              "base_branch_ref": { "type": "null" },
              "head_branch_ref": { "type": "null" },
              "provider_object_identity_ref": { "type": "null" },
              "imported_bundle_envelope_ref": { "type": "null" }
            }
          }
        }
      ],
      "description": "Base / head context block. Every record carries exactly one base/head kind; the per-kind allOf gate enforces which fields must be non-null."
    },

    "review_scope_selection_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "review_scope_selection_schema_version",
        "review_scope_selection_id",
        "scope_class",
        "review_workspace_id_ref",
        "local_locator",
        "provider_overlay_ref",
        "imported_bundle_envelope_ref",
        "browser_handoff_packet_ref",
        "base_head_context",
        "scope_freshness_class",
        "scope_lineage_class",
        "rerun_reason_class",
        "predecessor_scope_id_ref",
        "policy_context",
        "client_scopes",
        "redaction_class",
        "freshness_class",
        "summary_label",
        "minted_at",
        "updated_at"
      ],
      "properties": {
        "record_kind": { "const": "review_scope_selection_record" },
        "review_scope_selection_schema_version": { "$ref": "#/$defs/review_scope_selection_schema_version" },
        "review_scope_selection_id": { "$ref": "#/$defs/opaque_id" },
        "scope_class": { "$ref": "#/$defs/scope_class" },
        "review_workspace_id_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque ref to the schemas/vcs/review_workspace.schema.json review_workspace_record the scope binds. Required (non-null); a missing ref denies with review_scope_selection_record_required_field_missing."
        },
        "local_locator": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/local_locator" }
          ],
          "description": "Required (non-null) when scope_class is selected_diff_in_local_workspace, uncommitted_changes_in_local_workspace, whole_branch_against_base, or composite_local_with_provider_overlay_scope. Null otherwise."
        },
        "provider_overlay_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Required (non-null) when scope_class is hosted_review_object or composite_local_with_provider_overlay_scope. Null otherwise. Opaque ref to the matching provider_overlay block on the bound review_workspace_record."
        },
        "imported_bundle_envelope_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Required (non-null) when scope_class is imported_review_bundle_scope. Null otherwise."
        },
        "browser_handoff_packet_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Required (non-null) when scope_class is browser_handoff_token_scope. Null otherwise."
        },
        "base_head_context": { "$ref": "#/$defs/base_head_context" },
        "scope_freshness_class": { "$ref": "#/$defs/scope_freshness_class" },
        "scope_lineage_class": { "$ref": "#/$defs/scope_lineage_class" },
        "rerun_reason_class": { "$ref": "#/$defs/rerun_reason_class" },
        "predecessor_scope_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Required (non-null) when scope_lineage_class is one of the derived_from_* values; MUST be null when scope_lineage_class is freshly_minted_no_predecessor."
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "client_scopes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/client_scope" }
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "updated_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "local_locator is required (non-null) when scope_class is selected_diff_in_local_workspace, uncommitted_changes_in_local_workspace, whole_branch_against_base, or composite_local_with_provider_overlay_scope; MUST be null otherwise.",
          "if": {
            "properties": {
              "scope_class": {
                "enum": [
                  "selected_diff_in_local_workspace",
                  "uncommitted_changes_in_local_workspace",
                  "whole_branch_against_base",
                  "composite_local_with_provider_overlay_scope"
                ]
              }
            },
            "required": ["scope_class"]
          },
          "then": {
            "required": ["local_locator"],
            "properties": { "local_locator": { "$ref": "#/$defs/local_locator" } }
          },
          "else": {
            "properties": { "local_locator": { "type": "null" } }
          }
        },
        {
          "description": "provider_overlay_ref is required (non-null) when scope_class is hosted_review_object or composite_local_with_provider_overlay_scope; MUST be null otherwise.",
          "if": {
            "properties": {
              "scope_class": {
                "enum": ["hosted_review_object", "composite_local_with_provider_overlay_scope"]
              }
            },
            "required": ["scope_class"]
          },
          "then": {
            "required": ["provider_overlay_ref"],
            "properties": { "provider_overlay_ref": { "$ref": "#/$defs/opaque_id" } }
          },
          "else": {
            "properties": { "provider_overlay_ref": { "type": "null" } }
          }
        },
        {
          "description": "imported_bundle_envelope_ref is required (non-null) when scope_class is imported_review_bundle_scope; MUST be null otherwise.",
          "if": {
            "properties": { "scope_class": { "const": "imported_review_bundle_scope" } },
            "required": ["scope_class"]
          },
          "then": {
            "required": ["imported_bundle_envelope_ref"],
            "properties": { "imported_bundle_envelope_ref": { "$ref": "#/$defs/opaque_id" } }
          },
          "else": {
