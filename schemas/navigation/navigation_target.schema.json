{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/navigation/navigation_target.schema.json",
  "title": "Aureline navigation target fidelity beta vocabulary",
  "description": "Boundary schema for the beta navigation target model shared by language adapters, search, graph overlays, shell continuity, review packets, AI context, CLI/headless output, and support exports. Records carry typed relation_kind, access_kind, proof_class, confidence, freshness, ambiguity_class, scope_completeness, downgrade reasons, evidence refs, and export-safe summaries only. Raw source bodies, raw absolute paths, raw provider payloads, raw URLs, credentials, and private code snippets must not cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/navigation_target_fidelity_case_record" },
    { "$ref": "#/$defs/navigation_target_fidelity_report_record" }
  ],
  "$defs": {
    "navigation_target_schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "relation_kind": {
      "type": "string",
      "enum": [
        "definition",
        "declaration",
        "implementation",
        "reference",
        "type",
        "call",
        "route-binding",
        "owner-link",
        "doc-link"
      ]
    },
    "access_kind": {
      "type": "string",
      "enum": [
        "read",
        "write",
        "call",
        "inherit",
        "import",
        "export",
        "test-only",
        "generated"
      ]
    },
    "provider_class": {
      "type": "string",
      "enum": [
        "syntax",
        "project_graph",
        "language_server",
        "framework_pack",
        "notebook_adapter",
        "generated_source_bridge",
        "search_index",
        "remote_index",
        "imported_snapshot",
        "runtime_observer",
        "ai_assist"
      ]
    },
    "proof_class": {
      "type": "string",
      "enum": [
        "direct_semantic",
        "indexed_semantic",
        "lexical_fallback",
        "syntax_fallback",
        "imported_evidence",
        "framework_derived",
        "runtime_observed",
        "ai_inferred",
        "unavailable"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "exact",
        "indexed",
        "imported",
        "partial",
        "stale",
        "unavailable",
        "heuristic",
        "workspace_slice_limited"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },
    "ambiguity_class": {
      "type": "string",
      "enum": [
        "unambiguous",
        "ambiguous_needs_selection",
        "multiple_candidates_ranked",
        "drifted_needs_review",
        "missing_target",
        "scope_unavailable"
      ]
    },
    "scope_completeness": {
      "type": "string",
      "enum": [
        "complete_for_declared_scope",
        "partial_for_declared_scope",
        "stale_for_declared_scope",
        "unavailable_for_declared_scope"
      ]
    },
    "generated_or_external_state": {
      "type": "string",
      "enum": [
        "authored_source",
        "generated_source",
        "external_dependency",
        "read_only_source",
        "imported_snapshot"
      ]
    },
    "downgrade_reason": {
      "type": "string",
      "enum": [
        "sparse_workset",
        "policy_limited",
        "missing_provider",
        "provider_unavailable",
        "stale_shard",
        "lexical_fallback_only",
        "syntax_fallback_only",
        "generated_boundary",
        "runtime_or_framework_only",
        "ambiguous_candidates",
        "bookmark_or_history_drift",
        "metadata_only_export"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "editor_ui",
        "cli_headless",
        "ai_context",
        "review_workspace",
        "support_export",
        "graph_overlay",
        "shell_continuity"
      ]
    },
    "hierarchy_edge_kind": {
      "type": "string",
      "enum": [
        "calls",
        "runtime_calls",
        "inherits",
        "implements",
        "overrides",
        "framework_binding",
        "owner",
        "documented_by"
      ]
    },
    "rename_apply_posture": {
      "type": "string",
      "enum": [
        "ready_for_apply_after_preview",
        "blocked_pending_scope_review",
        "blocked_pending_refresh",
        "blocked_pending_policy_or_protected_review",
        "inspect_only_unavailable"
      ]
    },
    "continuity_artifact_kind": {
      "type": "string",
      "enum": ["breadcrumb", "outline", "bookmark", "history", "peek"]
    },
    "continuity_state": {
      "type": "string",
      "enum": [
        "bound",
        "remapped",
        "drifted",
        "missing_target",
        "scope_unavailable",
        "archived"
      ]
    },
    "navigation_promotion_state": {
      "type": "string",
      "enum": ["promotable", "needs_review", "blocked"]
    },
    "navigation_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_id",
        "relation_kind",
        "object_ref",
        "anchor_ref",
        "provider_class",
        "proof_class",
        "confidence",
        "freshness",
        "ambiguity_class",
        "scope_completeness",
        "scope_ref",
        "generated_or_external_state",
        "downgrade_reasons",
        "evidence_refs",
        "summary"
      ],
      "properties": {
        "target_id": { "$ref": "#/$defs/opaque_id" },
        "relation_kind": { "$ref": "#/$defs/relation_kind" },
        "object_ref": { "$ref": "#/$defs/opaque_id" },
        "anchor_ref": { "$ref": "#/$defs/opaque_id" },
        "provider_class": { "$ref": "#/$defs/provider_class" },
        "proof_class": { "$ref": "#/$defs/proof_class" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "ambiguity_class": { "$ref": "#/$defs/ambiguity_class" },
        "scope_completeness": { "$ref": "#/$defs/scope_completeness" },
        "scope_ref": { "$ref": "#/$defs/opaque_id" },
        "generated_or_external_state": { "$ref": "#/$defs/generated_or_external_state" },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason" },
          "uniqueItems": true
        },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "summary": { "$ref": "#/$defs/reviewable_summary" }
      }
    },
    "reference_occurrence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "occurrence_id",
        "target_ref",
        "anchor_ref",
        "access_kind",
        "scope_ref",
        "generated_or_external_state",
        "proof_class",
        "confidence",
        "freshness",
        "scope_completeness",
        "downgrade_reasons",
        "evidence_refs",
        "summary"
      ],
      "properties": {
        "occurrence_id": { "$ref": "#/$defs/opaque_id" },
        "target_ref": { "$ref": "#/$defs/opaque_id" },
        "anchor_ref": { "$ref": "#/$defs/opaque_id" },
        "access_kind": { "$ref": "#/$defs/access_kind" },
        "scope_ref": { "$ref": "#/$defs/opaque_id" },
        "generated_or_external_state": { "$ref": "#/$defs/generated_or_external_state" },
        "proof_class": { "$ref": "#/$defs/proof_class" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "scope_completeness": { "$ref": "#/$defs/scope_completeness" },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason" },
          "uniqueItems": true
        },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "summary": { "$ref": "#/$defs/reviewable_summary" }
      }
    },
    "hierarchy_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_id",
        "source_ref",
        "target_ref",
        "edge_kind",
        "proof_class",
        "depth",
        "scope_completeness",
        "freshness",
        "confidence",
        "runtime_or_framework_evidence_refs",
        "downgrade_reasons",
        "summary"
      ],
      "properties": {
        "edge_id": { "$ref": "#/$defs/opaque_id" },
        "source_ref": { "$ref": "#/$defs/opaque_id" },
        "target_ref": { "$ref": "#/$defs/opaque_id" },
        "edge_kind": { "$ref": "#/$defs/hierarchy_edge_kind" },
        "proof_class": { "$ref": "#/$defs/proof_class" },
        "depth": { "type": "integer", "minimum": 0 },
        "scope_completeness": { "$ref": "#/$defs/scope_completeness" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "runtime_or_framework_evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason" },
          "uniqueItems": true
        },
        "summary": { "$ref": "#/$defs/reviewable_summary" }
      }
    },
    "navigation_target_count_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "changed_count",
        "unresolved_count",
        "generated_count",
        "protected_count",
        "skipped_count"
      ],
      "properties": {
        "changed_count": { "type": "integer", "minimum": 0 },
        "unresolved_count": { "type": "integer", "minimum": 0 },
        "generated_count": { "type": "integer", "minimum": 0 },
        "protected_count": { "type": "integer", "minimum": 0 },
        "skipped_count": { "type": "integer", "minimum": 0 }
      }
    },
    "rename_preview_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rename_preview_id",
        "root_target_ref",
        "candidate_occurrence_refs",
        "blocked_refs",
        "conflict_notes",
        "sparse_or_partial_reasons",
        "generated_scope_notes",
        "count_summary",
        "proof_class",
        "confidence",
        "freshness",
        "scope_completeness",
        "apply_posture",
        "redaction_class",
        "evidence_refs",
        "summary"
      ],
      "properties": {
        "rename_preview_id": { "$ref": "#/$defs/opaque_id" },
        "root_target_ref": { "$ref": "#/$defs/opaque_id" },
        "candidate_occurrence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "blocked_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "conflict_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_summary" }
        },
        "sparse_or_partial_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_summary" }
        },
        "generated_scope_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_summary" }
        },
        "count_summary": { "$ref": "#/$defs/navigation_target_count_summary" },
        "proof_class": { "$ref": "#/$defs/proof_class" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "scope_completeness": { "$ref": "#/$defs/scope_completeness" },
        "apply_posture": { "$ref": "#/$defs/rename_apply_posture" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "summary": { "$ref": "#/$defs/reviewable_summary" }
      }
    },
    "navigation_disambiguation_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "set_id",
        "requested_relation",
        "candidate_target_refs",
        "selection_policy",
        "created_at",
        "ambiguity_class",
        "confidence",
        "freshness",
        "scope_completeness",
        "downgrade_reasons",
        "evidence_refs",
        "summary"
      ],
      "properties": {
        "set_id": { "$ref": "#/$defs/opaque_id" },
        "requested_relation": { "$ref": "#/$defs/relation_kind" },
        "candidate_target_refs": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "selection_policy": { "$ref": "#/$defs/reviewable_summary" },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "ambiguity_class": { "$ref": "#/$defs/ambiguity_class" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "scope_completeness": { "$ref": "#/$defs/scope_completeness" },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason" },
          "uniqueItems": true
        },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "summary": { "$ref": "#/$defs/reviewable_summary" }
      }
    },
    "target_continuity_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "continuity_ref_id",
        "artifact_kind",
        "target_ref",
        "continuity_state",
        "remapped_target_ref",
        "disambiguation_set_ref",
        "downgrade_reasons",
        "summary"
      ],
      "properties": {
        "continuity_ref_id": { "$ref": "#/$defs/opaque_id" },
        "artifact_kind": { "$ref": "#/$defs/continuity_artifact_kind" },
        "target_ref": { "$ref": "#/$defs/opaque_id" },
        "continuity_state": { "$ref": "#/$defs/continuity_state" },
        "remapped_target_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_id" }]
        },
        "disambiguation_set_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_id" }]
        },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason" },
          "uniqueItems": true
        },
        "summary": { "$ref": "#/$defs/reviewable_summary" }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer_surface",
        "projected_target_refs",
        "projected_reference_refs",
        "projected_edge_refs",
        "projected_rename_preview_refs",
        "projected_disambiguation_refs",
        "projected_continuity_refs",
        "redaction_class",
        "includes_relation_kind_labels",
        "includes_access_kind_labels",
        "includes_proof_class_labels",
        "includes_scope_completeness_labels",
        "exports_code_bodies",
        "summary"
      ],
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "projected_target_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_id" } },
        "projected_reference_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_id" } },
        "projected_edge_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_id" } },
        "projected_rename_preview_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_id" } },
        "projected_disambiguation_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_id" } },
        "projected_continuity_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_id" } },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "includes_relation_kind_labels": { "type": "boolean" },
        "includes_access_kind_labels": { "type": "boolean" },
        "includes_proof_class_labels": { "type": "boolean" },
        "includes_scope_completeness_labels": { "type": "boolean" },
        "exports_code_bodies": { "type": "boolean", "const": false },
        "summary": { "$ref": "#/$defs/reviewable_summary" }
      }
    },
    "navigation_target_fidelity_references": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_ref", "doc_ref", "report_ref"],
      "properties": {
        "schema_ref": { "type": "string", "const": "schemas/navigation/navigation_target.schema.json" },
        "doc_ref": { "type": "string", "const": "docs/navigation/m3/navigation_target_beta_contract.md" },
        "report_ref": { "type": "string", "const": "artifacts/navigation/m3/navigation_target_fidelity_report.md" }
      }
    },
    "navigation_target_fidelity_case_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "case_id",
        "title",
        "language_lane",
        "navigation_targets",
        "reference_occurrences",
        "hierarchy_edges",
        "rename_preview_sets",
        "disambiguation_sets",
        "continuity_refs",
        "consumer_projections",
        "expected_downgrade_reasons",
        "references",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "navigation_target_fidelity_case_record" },
        "schema_version": { "$ref": "#/$defs/navigation_target_schema_version" },
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "title": { "$ref": "#/$defs/reviewable_summary" },
        "language_lane": { "$ref": "#/$defs/opaque_id" },
        "navigation_targets": { "type": "array", "items": { "$ref": "#/$defs/navigation_target" } },
        "reference_occurrences": { "type": "array", "items": { "$ref": "#/$defs/reference_occurrence" } },
        "hierarchy_edges": { "type": "array", "items": { "$ref": "#/$defs/hierarchy_edge" } },
        "rename_preview_sets": { "type": "array", "items": { "$ref": "#/$defs/rename_preview_set" } },
        "disambiguation_sets": { "type": "array", "items": { "$ref": "#/$defs/navigation_disambiguation_set" } },
        "continuity_refs": { "type": "array", "items": { "$ref": "#/$defs/target_continuity_ref" } },
        "consumer_projections": { "type": "array", "items": { "$ref": "#/$defs/consumer_projection" } },
        "expected_downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason" },
          "uniqueItems": true
        },
        "references": { "$ref": "#/$defs/navigation_target_fidelity_references" },
        "export_safe_summary": { "$ref": "#/$defs/reviewable_summary" }
      }
    },
    "navigation_target_fidelity_report_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "fixture_ref",
        "language_lane",
        "target_count",
        "reference_occurrence_count",
        "hierarchy_edge_count",
        "rename_preview_count",
        "disambiguation_set_count",
        "continuity_ref_count",
        "consumer_surfaces",
        "promotion_state",
        "summary"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "fixture_ref": { "$ref": "#/$defs/opaque_id" },
        "language_lane": { "$ref": "#/$defs/opaque_id" },
        "target_count": { "type": "integer", "minimum": 0 },
        "reference_occurrence_count": { "type": "integer", "minimum": 0 },
        "hierarchy_edge_count": { "type": "integer", "minimum": 0 },
        "rename_preview_count": { "type": "integer", "minimum": 0 },
        "disambiguation_set_count": { "type": "integer", "minimum": 0 },
        "continuity_ref_count": { "type": "integer", "minimum": 0 },
        "consumer_surfaces": { "type": "array", "items": { "$ref": "#/$defs/consumer_surface" } },
        "promotion_state": { "$ref": "#/$defs/navigation_promotion_state" },
        "summary": { "$ref": "#/$defs/reviewable_summary" }
      }
    },
    "navigation_target_fidelity_violation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "subject_ref", "message"],
      "properties": {
        "check_id": { "$ref": "#/$defs/opaque_id" },
        "subject_ref": { "$ref": "#/$defs/opaque_id" },
        "message": { "$ref": "#/$defs/reviewable_summary" }
      }
    },
    "navigation_target_fidelity_report_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "schema_ref",
        "doc_ref",
        "corpus_ref",
        "report_ref",
        "rows",
        "violations",
        "promotion_state",
        "summary"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "navigation_target_fidelity_report_record" },
        "schema_version": { "$ref": "#/$defs/navigation_target_schema_version" },
        "schema_ref": { "type": "string", "const": "schemas/navigation/navigation_target.schema.json" },
        "doc_ref": { "type": "string", "const": "docs/navigation/m3/navigation_target_beta_contract.md" },
        "corpus_ref": { "type": "string", "const": "fixtures/navigation/m3/target_accuracy" },
        "report_ref": { "type": "string", "const": "artifacts/navigation/m3/navigation_target_fidelity_report.md" },
        "rows": { "type": "array", "items": { "$ref": "#/$defs/navigation_target_fidelity_report_row" } },
        "violations": { "type": "array", "items": { "$ref": "#/$defs/navigation_target_fidelity_violation" } },
        "promotion_state": { "$ref": "#/$defs/navigation_promotion_state" },
        "summary": { "$ref": "#/$defs/reviewable_summary" }
      }
    }
  }
}
