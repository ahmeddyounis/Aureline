{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/navigation/rename_preview.schema.json",
  "title": "Aureline semantic rename-preview packet vocabulary",
  "description": "Boundary schema for rename_preview_record frozen in docs/navigation/semantic_navigation_and_rename_contract.md. A rename preview packet binds a proposed semantic rename to durable semantic result ids, changed/unresolved/generated/protected/skipped counts, affected scopes, shadowed-symbol and alias warnings, checkpoint and rollback refs, provider posture, scope caveats, review/support/AI evidence refs, policy context, and export-safe summaries. Raw replacement text, raw source text, raw diffs, raw paths, raw symbol bodies, raw provider logs, raw URLs, raw hostnames, and raw secret material never cross this boundary. Adding a new completeness class, apply posture, scope class, coverage limit, warning class, checkpoint class, rollback path, provider family, locality, epoch role, redaction class, or evidence field is additive-minor and bumps rename_preview_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/rename_preview_record"
    }
  ],
  "$defs": {
    "rename_preview_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "rename_preview_record"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 640
    },
    "non_negative_int": {
      "type": "integer",
      "minimum": 0
    },
    "preview_completeness_class": {
      "type": "string",
      "enum": [
        "full_workspace_complete",
        "complete_for_requested_scope",
        "partial_due_to_workspace_slice",
        "partial_due_to_index_or_provider",
        "partial_due_to_imported_or_generated_boundaries",
        "stale_requires_refresh",
        "unavailable_blocked"
      ]
    },
    "apply_posture_class": {
      "type": "string",
      "enum": [
        "ready_for_apply_after_preview",
        "blocked_pending_scope_review",
        "blocked_pending_refresh",
        "blocked_pending_policy_or_protected_review",
        "inspect_only_unavailable"
      ]
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "single_file",
        "loaded_slice",
        "active_workset",
        "review_slice",
        "whole_workspace",
        "remote_workspace",
        "imported_snapshot",
        "generated_pair_family",
        "unavailable"
      ]
    },
    "coverage_limit_class": {
      "type": "string",
      "enum": [
        "workspace_slice_limited",
        "semantic_index_partial",
        "provider_unavailable",
        "provider_stale",
        "remote_shard_unreachable",
        "imported_snapshot_unverified",
        "generated_lineage_unresolved",
        "protected_scope_blocked",
        "policy_narrowed",
        "user_excluded_scope"
      ]
    },
    "warning_class": {
      "type": "string",
      "enum": [
        "shadowed_symbol",
        "alias_target_ambiguous",
        "alias_chain_unresolved",
        "generated_reference_would_change",
        "protected_or_read_only_target",
        "stale_provider_epoch",
        "imported_anchor_unverified",
        "workspace_slice_limited",
        "remote_scope_unreachable"
      ]
    },
    "checkpoint_class": {
      "type": "string",
      "enum": [
        "checkpoint_captured",
        "checkpoint_required_not_captured",
        "checkpoint_not_required_inspect_only"
      ]
    },
    "rollback_path_class": {
      "type": "string",
      "enum": [
        "exact_undo_via_local_history_checkpoint",
        "compensating_revert_via_workspace_diff",
        "regenerate_first_then_replay",
        "manual_review_required_no_automatic_path",
        "no_safe_rollback_available"
      ]
    },
    "provider_family": {
      "type": "string",
      "enum": [
        "syntax",
        "project_graph",
        "language_server",
        "framework_pack",
        "notebook_adapter",
        "generated_source_bridge",
        "remote_index",
        "imported_snapshot",
        "ai_assist"
      ]
    },
    "provider_health_class": {
      "type": "string",
      "enum": [
        "ready",
        "warming",
        "degraded",
        "cached_only",
        "policy_blocked",
        "capability_missing",
        "crash_loop_quarantined",
        "unavailable"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },
    "locality_class": {
      "type": "string",
      "enum": [
        "local_in_process",
        "local_sidecar",
        "workspace_remote_agent",
        "managed_service",
        "imported_snapshot"
      ]
    },
    "epoch_role_class": {
      "type": "string",
      "enum": [
        "workspace_scope",
        "graph_snapshot",
        "provider_session",
        "language_project_model",
        "framework_pack_snapshot",
        "generated_lineage",
        "imported_snapshot",
        "remote_index",
        "review_slice",
        "rename_preview"
      ]
    },
    "trust_state": {
      "type": "string",
      "enum": [
        "trusted",
        "restricted"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_epoch",
        "trust_state",
        "execution_context_id"
      ],
      "properties": {
        "policy_epoch": {
          "$ref": "#/$defs/opaque_id"
        },
        "trust_state": {
          "$ref": "#/$defs/trust_state"
        },
        "execution_context_id": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },
    "epoch_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "epoch_role_class",
        "epoch_ref"
      ],
      "properties": {
        "epoch_role_class": {
          "$ref": "#/$defs/epoch_role_class"
        },
        "epoch_ref": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },
    "provider_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "provider_family",
        "provider_display_label",
        "provider_health_class",
        "freshness_class",
        "locality_class",
        "current_epoch_bindings",
        "summary"
      ],
      "properties": {
        "provider_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "provider_family": {
          "$ref": "#/$defs/provider_family"
        },
        "provider_display_label": {
          "$ref": "#/$defs/reviewable_summary"
        },
        "provider_health_class": {
          "$ref": "#/$defs/provider_health_class"
        },
        "freshness_class": {
          "$ref": "#/$defs/freshness_class"
        },
        "locality_class": {
          "$ref": "#/$defs/locality_class"
        },
        "host_identity_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },
    "count_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "changed_count",
        "unresolved_count",
        "generated_count",
        "protected_count",
        "skipped_count",
        "changed_file_count",
        "changed_symbol_count"
      ],
      "properties": {
        "changed_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "unresolved_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "generated_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "protected_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "skipped_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "changed_file_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "changed_symbol_count": {
          "$ref": "#/$defs/non_negative_int"
        }
      }
    },
    "affected_scope_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_scope_class",
        "materialized_scope_class",
        "coverage_limit_classes",
        "affected_result_refs",
        "omitted_result_count",
        "caveat_summary"
      ],
      "properties": {
        "requested_scope_class": {
          "$ref": "#/$defs/scope_class"
        },
        "materialized_scope_class": {
          "$ref": "#/$defs/scope_class"
        },
        "coverage_limit_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/coverage_limit_class"
          },
          "uniqueItems": true
        },
        "affected_result_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_id"
          },
          "uniqueItems": true
        },
        "omitted_result_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "caveat_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },
    "warning_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "warning_class",
        "warning_count",
        "affected_result_refs",
        "summary"
      ],
      "properties": {
        "warning_class": {
          "$ref": "#/$defs/warning_class"
        },
        "warning_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "affected_result_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_id"
          },
          "uniqueItems": true
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },
    "checkpoint_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_class",
        "checkpoint_ref",
        "rollback_ref",
        "rollback_path_class",
        "summary"
      ],
      "properties": {
        "checkpoint_class": {
          "$ref": "#/$defs/checkpoint_class"
        },
        "checkpoint_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "rollback_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "rollback_path_class": {
          "$ref": "#/$defs/rollback_path_class"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },
    "evidence_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "durable_preview_id",
        "source_evidence_refs",
        "scope_caveat_refs"
      ],
      "properties": {
        "durable_preview_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "result_provenance_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "refactor_preview_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "review_packet_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "ai_citation_anchor_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "support_export_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "source_evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_id"
          },
          "uniqueItems": true
        },
        "scope_caveat_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_id"
          },
          "uniqueItems": true
        }
      }
    },
    "rename_preview_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "rename_preview_schema_version",
        "rename_preview_id",
        "target_semantic_result_ref",
        "requested_new_name_ref",
        "preview_completeness_class",
        "apply_posture_class",
        "count_summary",
        "affected_scope_rows",
        "warning_rows",
        "checkpoint_descriptor",
        "provider_snapshot",
        "current_epoch_bindings",
        "evidence_binding",
        "policy_context",
        "redaction_class",
        "captured_at",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": {
          "$ref": "#/$defs/record_kind"
        },
        "rename_preview_schema_version": {
          "$ref": "#/$defs/rename_preview_schema_version"
        },
        "rename_preview_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "target_semantic_result_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "requested_new_name_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "preview_completeness_class": {
          "$ref": "#/$defs/preview_completeness_class"
        },
        "apply_posture_class": {
          "$ref": "#/$defs/apply_posture_class"
        },
        "count_summary": {
          "$ref": "#/$defs/count_summary"
        },
        "affected_scope_rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/affected_scope_row"
          },
          "minItems": 1
        },
        "warning_rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning_row"
          },
          "uniqueItems": true
        },
        "checkpoint_descriptor": {
          "$ref": "#/$defs/checkpoint_descriptor"
        },
        "provider_snapshot": {
          "$ref": "#/$defs/provider_snapshot"
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "evidence_binding": {
          "$ref": "#/$defs/evidence_binding"
        },
        "policy_context": {
          "$ref": "#/$defs/policy_context"
        },
        "redaction_class": {
          "$ref": "#/$defs/redaction_class"
        },
        "captured_at": {
          "$ref": "#/$defs/timestamp"
        },
        "export_safe_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      },
      "allOf": [
        {
          "description": "Full-workspace completeness is reserved for previews that have no unresolved or skipped candidates and no scope-limit rows.",
          "if": {
            "properties": {
              "preview_completeness_class": {
                "const": "full_workspace_complete"
              }
            },
            "required": [
              "preview_completeness_class"
            ]
          },
          "then": {
            "properties": {
              "count_summary": {
                "properties": {
                  "unresolved_count": {
                    "const": 0
                  },
                  "skipped_count": {
                    "const": 0
                  }
                }
              },
              "affected_scope_rows": {
                "not": {
                  "contains": {
                    "properties": {
                      "coverage_limit_classes": {
                        "minItems": 1
                      }
                    },
                    "required": [
                      "coverage_limit_classes"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "description": "A preview that is partial, stale, or unavailable may not be ready for apply without review or refresh.",
          "if": {
            "properties": {
              "preview_completeness_class": {
                "enum": [
                  "partial_due_to_workspace_slice",
                  "partial_due_to_index_or_provider",
                  "partial_due_to_imported_or_generated_boundaries",
                  "stale_requires_refresh",
                  "unavailable_blocked"
                ]
              }
            },
            "required": [
              "preview_completeness_class"
            ]
          },
          "then": {
            "properties": {
              "apply_posture_class": {
                "not": {
                  "const": "ready_for_apply_after_preview"
                }
              }
            }
          }
        },
        {
          "description": "Ready-for-apply previews need a captured checkpoint, a rollback path, and zero unresolved/protected/skipped members.",
          "if": {
            "properties": {
              "apply_posture_class": {
                "const": "ready_for_apply_after_preview"
              }
            },
            "required": [
              "apply_posture_class"
            ]
          },
          "then": {
            "properties": {
              "preview_completeness_class": {
                "enum": [
                  "full_workspace_complete",
                  "complete_for_requested_scope"
                ]
              },
              "count_summary": {
                "properties": {
                  "unresolved_count": {
                    "const": 0
                  },
                  "protected_count": {
                    "const": 0
                  },
                  "skipped_count": {
                    "const": 0
                  }
                }
              },
              "checkpoint_descriptor": {
                "properties": {
                  "checkpoint_class": {
                    "const": "checkpoint_captured"
                  },
                  "rollback_path_class": {
                    "not": {
                      "const": "no_safe_rollback_available"
                    }
                  }
                }
              }
            }
          }
        },
        {
          "description": "Unavailable previews are inspect-only and cannot claim a checkpoint-backed rollback path.",
          "if": {
            "properties": {
              "preview_completeness_class": {
                "const": "unavailable_blocked"
              }
            },
            "required": [
              "preview_completeness_class"
            ]
          },
          "then": {
            "properties": {
              "apply_posture_class": {
                "const": "inspect_only_unavailable"
              },
              "checkpoint_descriptor": {
                "properties": {
                  "checkpoint_class": {
                    "const": "checkpoint_not_required_inspect_only"
                  },
                  "rollback_path_class": {
                    "const": "no_safe_rollback_available"
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
