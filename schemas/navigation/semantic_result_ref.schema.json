{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/navigation/semantic_result_ref.schema.json",
  "title": "Aureline semantic navigation result identity vocabulary",
  "description": "Boundary schema for semantic_result_ref_record frozen in docs/navigation/semantic_navigation_and_rename_contract.md. A semantic result ref is the durable identity that definition, declaration, type-definition, implementation, reference, hierarchy, call-site, alias, imported/generated reference, review, support-export, and AI-citation lanes can all cite. The record carries opaque ids, source-anchor refs, provider posture, scope caveats, confidence, completeness, inline visibility, evidence refs, policy context, and export-safe summaries only. Raw source text, raw paths, raw symbol bodies, raw provider logs, raw URLs, raw hostnames, and raw secret material never cross this boundary. Adding a new identity class, confidence class, completeness class, inline visibility class, source-anchor kind, relation class, provider family, scope class, scope-limit class, locality class, epoch role, redaction class, or evidence binding field is additive-minor and bumps semantic_result_ref_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/semantic_result_ref_record"
    }
  ],
  "$defs": {
    "semantic_result_ref_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "semantic_result_ref_record"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 640
    },
    "non_negative_int": {
      "type": "integer",
      "minimum": 0
    },
    "semantic_result_identity_class": {
      "type": "string",
      "enum": [
        "definition",
        "declaration",
        "type_definition",
        "implementation",
        "reference",
        "hierarchy_parent",
        "hierarchy_child",
        "call_site",
        "symbol_alias",
        "imported_or_generated_reference"
      ],
      "description": "Frozen semantic result identity classes. These are result roles, not UI commands."
    },
    "result_confidence_class": {
      "type": "string",
      "enum": [
        "exact",
        "indexed",
        "imported",
        "partial",
        "stale",
        "unavailable",
        "heuristically_mapped",
        "workspace_slice_limited"
      ],
      "description": "Frozen confidence and truth posture for one semantic result. exact and indexed may be authoritative only when completeness is complete for the declared scope. imported, partial, stale, heuristically_mapped, and workspace_slice_limited require visible caveats. unavailable renders absence without implying an empty exact result set."
    },
    "completeness_class": {
      "type": "string",
      "enum": [
        "complete_for_declared_scope",
        "partial_for_declared_scope",
        "stale_for_declared_scope",
        "unavailable_for_declared_scope"
      ]
    },
    "inline_visibility_class": {
      "type": "string",
      "enum": [
        "inline_authoritative_allowed",
        "inline_caveated_allowed",
        "inline_inspect_only",
        "inline_hidden_requires_scope_or_refresh",
        "inline_unavailable"
      ]
    },
    "source_anchor_kind_class": {
      "type": "string",
      "enum": [
        "workspace_source_anchor",
        "generated_lineage_anchor",
        "imported_snapshot_anchor",
        "provider_overlay_anchor",
        "runtime_observed_anchor",
        "unresolved_anchor"
      ]
    },
    "relation_class": {
      "type": "string",
      "enum": [
        "definition_target",
        "declaration_target",
        "type_definition_target",
        "implementation_target",
        "read_reference",
        "write_reference",
        "call_reference",
        "import_or_export_reference",
        "generated_or_framework_reference",
        "runtime_observed_reference",
        "hierarchy_parent_edge",
        "hierarchy_child_edge",
        "symbol_alias_edge",
        "not_applicable"
      ]
    },
    "provider_family": {
      "type": "string",
      "enum": [
        "syntax",
        "project_graph",
        "language_server",
        "framework_pack",
        "notebook_adapter",
        "generated_source_bridge",
        "search_index",
        "remote_index",
        "imported_snapshot",
        "runtime_observer",
        "ai_assist"
      ]
    },
    "provider_health_class": {
      "type": "string",
      "enum": [
        "ready",
        "warming",
        "degraded",
        "cached_only",
        "policy_blocked",
        "capability_missing",
        "crash_loop_quarantined",
        "unavailable"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "single_file",
        "notebook_cell",
        "loaded_slice",
        "active_workset",
        "review_slice",
        "whole_workspace",
        "remote_workspace",
        "imported_snapshot",
        "unavailable"
      ]
    },
    "scope_limit_class": {
      "type": "string",
      "enum": [
        "single_file_only",
        "active_workset_only",
        "loaded_slice_only",
        "review_slice_only",
        "workspace_slice_only",
        "unloaded_roots_omitted",
        "remote_shard_unreachable",
        "generated_overlay_only",
        "generated_candidates_omitted",
        "imported_snapshot_only",
        "policy_narrowed",
        "provider_unavailable"
      ]
    },
    "locality_class": {
      "type": "string",
      "enum": [
        "local_in_process",
        "local_sidecar",
        "workspace_remote_agent",
        "managed_service",
        "imported_snapshot"
      ]
    },
    "epoch_role_class": {
      "type": "string",
      "enum": [
        "workspace_scope",
        "graph_snapshot",
        "provider_session",
        "language_project_model",
        "framework_pack_snapshot",
        "generated_lineage",
        "imported_snapshot",
        "remote_index",
        "review_slice",
        "ai_context"
      ]
    },
    "trust_state": {
      "type": "string",
      "enum": [
        "trusted",
        "restricted"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_epoch",
        "trust_state",
        "execution_context_id"
      ],
      "properties": {
        "policy_epoch": {
          "$ref": "#/$defs/opaque_id"
        },
        "trust_state": {
          "$ref": "#/$defs/trust_state"
        },
        "execution_context_id": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },
    "epoch_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "epoch_role_class",
        "epoch_ref"
      ],
      "properties": {
        "epoch_role_class": {
          "$ref": "#/$defs/epoch_role_class"
        },
        "epoch_ref": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },
    "source_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_anchor_ref",
        "source_anchor_kind_class",
        "summary"
      ],
      "properties": {
        "source_anchor_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "source_anchor_kind_class": {
          "$ref": "#/$defs/source_anchor_kind_class"
        },
        "canonical_file_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "symbol_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "range_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "generated_lineage_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "imported_snapshot_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },
    "provider_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "provider_family",
        "provider_display_label",
        "provider_health_class",
        "freshness_class",
        "locality_class",
        "current_epoch_bindings",
        "summary"
      ],
      "properties": {
        "provider_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "provider_family": {
          "$ref": "#/$defs/provider_family"
        },
        "provider_display_label": {
          "$ref": "#/$defs/reviewable_summary"
        },
        "provider_health_class": {
          "$ref": "#/$defs/provider_health_class"
        },
        "freshness_class": {
          "$ref": "#/$defs/freshness_class"
        },
        "locality_class": {
          "$ref": "#/$defs/locality_class"
        },
        "host_identity_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },
    "scope_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_scope_class",
        "materialized_scope_class",
        "scope_limit_classes",
        "covered_scope_ref",
        "omitted_scope_ref",
        "caveat_summary"
      ],
      "properties": {
        "requested_scope_class": {
          "$ref": "#/$defs/scope_class"
        },
        "materialized_scope_class": {
          "$ref": "#/$defs/scope_class"
        },
        "scope_limit_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scope_limit_class"
          },
          "uniqueItems": true
        },
        "covered_scope_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "omitted_scope_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "caveat_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },
    "ambiguity_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ambiguous_candidate_count",
        "selected_candidate_count",
        "disambiguation_required",
        "summary"
      ],
      "properties": {
        "ambiguous_candidate_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "selected_candidate_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "disambiguation_required": {
          "type": "boolean"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },
    "evidence_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "durable_result_id",
        "source_evidence_refs",
        "scope_caveat_refs"
      ],
      "properties": {
        "durable_result_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "result_provenance_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "navigation_artifact_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "review_packet_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "ai_citation_anchor_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "support_export_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "source_evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_id"
          },
          "uniqueItems": true
        },
        "scope_caveat_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_id"
          },
          "uniqueItems": true
        }
      }
    },
    "semantic_result_ref_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "semantic_result_ref_schema_version",
        "semantic_result_id",
        "semantic_result_identity_class",
        "relation_class",
        "source_anchor",
        "provider_snapshot",
        "result_confidence_class",
        "completeness_class",
        "inline_visibility_class",
        "scope_descriptor",
        "ambiguity_descriptor",
        "evidence_binding",
        "current_epoch_bindings",
        "policy_context",
        "redaction_class",
        "captured_at",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": {
          "$ref": "#/$defs/record_kind"
        },
        "semantic_result_ref_schema_version": {
          "$ref": "#/$defs/semantic_result_ref_schema_version"
        },
        "semantic_result_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "semantic_result_identity_class": {
          "$ref": "#/$defs/semantic_result_identity_class"
        },
        "relation_class": {
          "$ref": "#/$defs/relation_class"
        },
        "source_anchor": {
          "$ref": "#/$defs/source_anchor"
        },
        "provider_snapshot": {
          "$ref": "#/$defs/provider_snapshot"
        },
        "result_confidence_class": {
          "$ref": "#/$defs/result_confidence_class"
        },
        "completeness_class": {
          "$ref": "#/$defs/completeness_class"
        },
        "inline_visibility_class": {
          "$ref": "#/$defs/inline_visibility_class"
        },
        "scope_descriptor": {
          "$ref": "#/$defs/scope_descriptor"
        },
        "ambiguity_descriptor": {
          "$ref": "#/$defs/ambiguity_descriptor"
        },
        "evidence_binding": {
          "$ref": "#/$defs/evidence_binding"
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "policy_context": {
          "$ref": "#/$defs/policy_context"
        },
        "redaction_class": {
          "$ref": "#/$defs/redaction_class"
        },
        "captured_at": {
          "$ref": "#/$defs/timestamp"
        },
        "export_safe_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      },
      "allOf": [
        {
          "description": "Inline authoritative display is reserved for exact or indexed complete rows.",
          "if": {
            "properties": {
              "inline_visibility_class": {
                "const": "inline_authoritative_allowed"
              }
            },
            "required": [
              "inline_visibility_class"
            ]
          },
          "then": {
            "properties": {
              "result_confidence_class": {
                "enum": [
                  "exact",
                  "indexed"
                ]
              },
              "completeness_class": {
                "const": "complete_for_declared_scope"
              }
            }
          }
        },
        {
          "description": "Unavailable rows render as unavailable and must not masquerade as empty exact result sets.",
          "if": {
            "properties": {
              "result_confidence_class": {
                "const": "unavailable"
              }
            },
            "required": [
              "result_confidence_class"
            ]
          },
          "then": {
            "properties": {
              "completeness_class": {
                "const": "unavailable_for_declared_scope"
              },
              "inline_visibility_class": {
                "const": "inline_unavailable"
              }
            }
          }
        },
        {
          "description": "Imported, partial, stale, heuristic, and slice-limited rows require visible caveats and cannot be authoritative inline.",
          "if": {
            "properties": {
              "result_confidence_class": {
                "enum": [
                  "imported",
                  "partial",
                  "stale",
                  "heuristically_mapped",
                  "workspace_slice_limited"
                ]
              }
            },
            "required": [
              "result_confidence_class"
            ]
          },
          "then": {
            "properties": {
              "inline_visibility_class": {
                "not": {
                  "const": "inline_authoritative_allowed"
                }
              }
            }
          }
        },
        {
          "description": "Imported or generated references must identify an imported snapshot or generated-lineage anchor.",
          "if": {
            "properties": {
              "semantic_result_identity_class": {
                "const": "imported_or_generated_reference"
              }
            },
            "required": [
              "semantic_result_identity_class"
            ]
          },
          "then": {
            "properties": {
              "source_anchor": {
                "properties": {
                  "source_anchor_kind_class": {
                    "enum": [
                      "generated_lineage_anchor",
                      "imported_snapshot_anchor"
                    ]
                  }
                }
              },
              "result_confidence_class": {
                "enum": [
                  "imported",
                  "heuristically_mapped",
                  "partial",
                  "stale"
                ]
              }
            }
          }
        },
        {
          "description": "Hierarchy parent and child results must carry matching relation classes.",
          "if": {
            "properties": {
              "semantic_result_identity_class": {
                "const": "hierarchy_parent"
              }
            },
            "required": [
              "semantic_result_identity_class"
            ]
          },
          "then": {
            "properties": {
              "relation_class": {
                "const": "hierarchy_parent_edge"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "semantic_result_identity_class": {
                "const": "hierarchy_child"
              }
            },
            "required": [
              "semantic_result_identity_class"
            ]
          },
          "then": {
            "properties": {
              "relation_class": {
                "const": "hierarchy_child_edge"
              }
            }
          }
        }
      ]
    }
  }
}
