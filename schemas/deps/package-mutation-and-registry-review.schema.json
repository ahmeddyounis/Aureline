{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/deps/package-mutation-and-registry-review.schema.json",
  "title": "Aureline package mutation and registry review",
  "description": "Schema for the package_mutation_and_registry_review packet. The packet keeps package browser/search, manifest scope, package detail, operation review, registry or mirror auth, grouped update, operation history, CLI/headless, Help, and support-export surfaces aligned.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "surface_contract",
    "ecosystem_classes",
    "operation_classes",
    "search_result_states",
    "source_kinds",
    "dependency_relation_classes",
    "registry_source_classes",
    "credential_modes",
    "registry_freshness_states",
    "registry_reachability_states",
    "lockfile_impact_classes",
    "script_native_build_risk_classes",
    "automation_source_classes",
    "write_postures",
    "claimed_stable_ecosystems",
    "registry_auth_panels",
    "operation_reviews",
    "grouped_update_plans",
    "operation_history",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "package_mutation_and_registry_review" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "surface_contract": { "$ref": "#/$defs/surface_contract" },
    "ecosystem_classes": { "type": "array", "items": { "$ref": "#/$defs/ecosystem_class" } },
    "operation_classes": { "type": "array", "items": { "$ref": "#/$defs/operation_class" } },
    "search_result_states": { "type": "array", "items": { "$ref": "#/$defs/search_result_state" } },
    "source_kinds": { "type": "array", "items": { "$ref": "#/$defs/source_kind" } },
    "dependency_relation_classes": { "type": "array", "items": { "$ref": "#/$defs/dependency_relation_class" } },
    "registry_source_classes": { "type": "array", "items": { "$ref": "#/$defs/registry_source_class" } },
    "credential_modes": { "type": "array", "items": { "$ref": "#/$defs/credential_mode" } },
    "registry_freshness_states": { "type": "array", "items": { "$ref": "#/$defs/registry_freshness_state" } },
    "registry_reachability_states": { "type": "array", "items": { "$ref": "#/$defs/registry_reachability_state" } },
    "lockfile_impact_classes": { "type": "array", "items": { "$ref": "#/$defs/lockfile_impact_class" } },
    "script_native_build_risk_classes": { "type": "array", "items": { "$ref": "#/$defs/script_native_build_risk_class" } },
    "automation_source_classes": { "type": "array", "items": { "$ref": "#/$defs/automation_source_class" } },
    "write_postures": { "type": "array", "items": { "$ref": "#/$defs/write_posture" } },
    "claimed_stable_ecosystems": { "type": "array", "items": { "$ref": "#/$defs/ecosystem_class" } },
    "registry_auth_panels": { "type": "array", "items": { "$ref": "#/$defs/registry_auth_panel" } },
    "operation_reviews": { "type": "array", "items": { "$ref": "#/$defs/operation_review" } },
    "grouped_update_plans": { "type": "array", "items": { "$ref": "#/$defs/grouped_update_plan" } },
    "operation_history": { "type": "array", "items": { "$ref": "#/$defs/operation_history_row" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "nullable_non_empty_string": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/non_empty_string" }]
    },
    "string_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "ecosystem_class": { "type": "string", "enum": ["cargo", "node_pnpm"] },
    "operation_class": { "type": "string", "enum": ["add", "update", "remove", "resolve"] },
    "search_result_state": {
      "type": "string",
      "enum": [
        "results_available",
        "no_results",
        "auth_required",
        "mirror_stale",
        "offline_snapshot_only",
        "unknown_or_stale"
      ]
    },
    "source_kind": {
      "type": "string",
      "enum": [
        "registry",
        "workspace_local",
        "path",
        "vcs",
        "policy_pinned",
        "offline_snapshot_only",
        "unknown_or_stale"
      ]
    },
    "dependency_relation_class": {
      "type": "string",
      "enum": [
        "direct",
        "transitive",
        "workspace_local",
        "path",
        "vcs",
        "policy_pinned",
        "offline_snapshot_only",
        "unknown_or_stale"
      ]
    },
    "registry_source_class": {
      "type": "string",
      "enum": ["public_registry", "private_registry", "enterprise_mirror", "local_cache", "offline_snapshot"]
    },
    "credential_mode": {
      "type": "string",
      "enum": ["anonymous", "os_store", "token", "browser_or_device_sign_in", "policy_inherited"]
    },
    "registry_freshness_state": {
      "type": "string",
      "enum": ["current", "stale", "auth_required", "offline_snapshot_only", "unknown"]
    },
    "registry_reachability_state": {
      "type": "string",
      "enum": ["reachable", "unreachable", "auth_required", "policy_blocked", "offline"]
    },
    "lockfile_impact_class": {
      "type": "string",
      "enum": [
        "direct_bump",
        "security_patch",
        "grouped_refresh",
        "lockfile_refresh_only",
        "major_version_pilot",
        "workspace_wide_convergence"
      ]
    },
    "script_native_build_risk_class": {
      "type": "string",
      "enum": ["none_known", "package_scripts", "native_build", "new_egress", "policy_blocked", "unknown"]
    },
    "automation_source_class": {
      "type": "string",
      "enum": ["manual", "ai_suggested", "automation_suggested"]
    },
    "write_posture": {
      "type": "string",
      "enum": ["inspect_only", "review_required", "apply_blocked", "applied_after_review"]
    },
    "surface_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_browser_surface",
        "workspace_scope_surface",
        "package_detail_surface",
        "operation_review_surface",
        "registry_auth_surface",
        "history_recovery_surface",
        "cli_headless_surface",
        "help_page",
        "support_export_surface"
      ],
      "properties": {
        "package_browser_surface": { "$ref": "#/$defs/non_empty_string" },
        "workspace_scope_surface": { "$ref": "#/$defs/non_empty_string" },
        "package_detail_surface": { "$ref": "#/$defs/non_empty_string" },
        "operation_review_surface": { "$ref": "#/$defs/non_empty_string" },
        "registry_auth_surface": { "$ref": "#/$defs/non_empty_string" },
        "history_recovery_surface": { "$ref": "#/$defs/non_empty_string" },
        "cli_headless_surface": { "$ref": "#/$defs/non_empty_string" },
        "help_page": { "$ref": "#/$defs/non_empty_string" },
        "support_export_surface": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "manifest_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ecosystem", "scope_label", "manifest_path", "registry_auth_ref"],
      "properties": {
        "ecosystem": { "$ref": "#/$defs/ecosystem_class" },
        "scope_label": { "$ref": "#/$defs/non_empty_string" },
        "manifest_path": { "$ref": "#/$defs/non_empty_string" },
        "workspace_member": { "$ref": "#/$defs/nullable_non_empty_string" },
        "lockfile_paths": { "$ref": "#/$defs/string_array" },
        "registry_auth_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "requested": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package_name", "requested_range_or_source", "requested_source_kind"],
      "properties": {
        "package_name": { "$ref": "#/$defs/non_empty_string" },
        "requested_range_or_source": { "$ref": "#/$defs/non_empty_string" },
        "requested_source_kind": { "$ref": "#/$defs/source_kind" }
      }
    },
    "resolved": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_name",
        "resolved_exact_version_or_source",
        "resolved_source_kind",
        "relation_class",
        "source_ref"
      ],
      "properties": {
        "package_name": { "$ref": "#/$defs/non_empty_string" },
        "resolved_exact_version_or_source": { "$ref": "#/$defs/non_empty_string" },
        "resolved_source_kind": { "$ref": "#/$defs/source_kind" },
        "relation_class": { "$ref": "#/$defs/dependency_relation_class" },
        "source_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "registry_auth_panel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_auth_id",
        "ecosystem",
        "source_class",
        "credential_mode",
        "freshness_state",
        "reachability_state",
        "policy_locked",
        "scope",
        "redacted_source_label",
        "raw_secrets_exported",
        "note"
      ],
      "properties": {
        "registry_auth_id": { "$ref": "#/$defs/non_empty_string" },
        "ecosystem": { "$ref": "#/$defs/ecosystem_class" },
        "source_class": { "$ref": "#/$defs/registry_source_class" },
        "credential_mode": { "$ref": "#/$defs/credential_mode" },
        "freshness_state": { "$ref": "#/$defs/registry_freshness_state" },
        "reachability_state": { "$ref": "#/$defs/registry_reachability_state" },
        "policy_locked": { "type": "boolean" },
        "scope": { "$ref": "#/$defs/non_empty_string" },
        "redacted_source_label": { "$ref": "#/$defs/non_empty_string" },
        "raw_secrets_exported": { "type": "boolean", "const": false },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "lockfile_impact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "impact_class",
        "affected_manifests",
        "affected_lockfiles",
        "direct_package_changes",
        "transitive_package_changes",
        "quantified_note"
      ],
      "properties": {
        "impact_class": { "$ref": "#/$defs/lockfile_impact_class" },
        "affected_manifests": { "$ref": "#/$defs/string_array" },
        "affected_lockfiles": { "$ref": "#/$defs/string_array" },
        "direct_package_changes": { "type": "integer", "minimum": 0 },
        "transitive_package_changes": { "type": "integer", "minimum": 0 },
        "quantified_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "script_native_build_risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "risk_class",
        "source_package_refs",
        "required_toolchain_refs",
        "egress_class_refs",
        "policy_allows",
        "note"
      ],
      "properties": {
        "risk_class": { "$ref": "#/$defs/script_native_build_risk_class" },
        "source_package_refs": { "$ref": "#/$defs/string_array" },
        "required_toolchain_refs": { "$ref": "#/$defs/string_array" },
        "egress_class_refs": { "$ref": "#/$defs/string_array" },
        "policy_allows": { "type": "boolean" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "validation_pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation_pack_id", "checks", "required_before_apply", "passed"],
      "properties": {
        "validation_pack_id": { "$ref": "#/$defs/non_empty_string" },
        "checks": { "$ref": "#/$defs/string_array" },
        "required_before_apply": { "type": "boolean" },
        "passed": { "type": "boolean" }
      }
    },
    "rollback_checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkpoint_id", "covered_paths", "rollback_available", "note"],
      "properties": {
        "checkpoint_id": { "$ref": "#/$defs/non_empty_string" },
        "covered_paths": { "$ref": "#/$defs/string_array" },
        "rollback_available": { "type": "boolean" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "operation_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_id",
        "source_class",
        "operation_class",
        "write_posture",
        "search_result_state",
        "manifest_scope",
        "requested",
        "resolved",
        "registry_auth_ref",
        "lockfile_impact",
        "script_native_build_risk",
        "validation_pack",
        "rollback_checkpoint",
        "note"
      ],
      "properties": {
        "operation_id": { "$ref": "#/$defs/non_empty_string" },
        "source_class": { "$ref": "#/$defs/automation_source_class" },
        "operation_class": { "$ref": "#/$defs/operation_class" },
        "write_posture": { "$ref": "#/$defs/write_posture" },
        "search_result_state": { "$ref": "#/$defs/search_result_state" },
        "manifest_scope": { "$ref": "#/$defs/manifest_scope" },
        "requested": { "$ref": "#/$defs/requested" },
        "resolved": { "$ref": "#/$defs/resolved" },
        "registry_auth_ref": { "$ref": "#/$defs/non_empty_string" },
        "lockfile_impact": { "$ref": "#/$defs/lockfile_impact" },
        "script_native_build_risk": { "$ref": "#/$defs/script_native_build_risk" },
        "peer_or_runtime_constraint_shifts": { "$ref": "#/$defs/string_array" },
        "advisory_refs": { "$ref": "#/$defs/string_array" },
        "grouped_update_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
        "validation_pack": { "$ref": "#/$defs/validation_pack" },
        "rollback_checkpoint": { "$ref": "#/$defs/rollback_checkpoint" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "grouped_update_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grouped_update_id",
        "ecosystem",
        "scope_label",
        "operation_refs",
        "reason",
        "lockfile_impact_class",
        "validation_pack_id",
        "checkpoint_id"
      ],
      "properties": {
        "grouped_update_id": { "$ref": "#/$defs/non_empty_string" },
        "ecosystem": { "$ref": "#/$defs/ecosystem_class" },
        "scope_label": { "$ref": "#/$defs/non_empty_string" },
        "operation_refs": { "$ref": "#/$defs/string_array" },
        "reason": { "$ref": "#/$defs/non_empty_string" },
        "lockfile_impact_class": { "$ref": "#/$defs/lockfile_impact_class" },
        "validation_pack_id": { "$ref": "#/$defs/non_empty_string" },
        "checkpoint_id": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "operation_history_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "history_id",
        "operation_ref",
        "timestamp",
        "result_class",
        "recovery_action",
        "support_export_ref"
      ],
      "properties": {
        "history_id": { "$ref": "#/$defs/non_empty_string" },
        "operation_ref": { "$ref": "#/$defs/non_empty_string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "result_class": { "$ref": "#/$defs/non_empty_string" },
        "recovery_action": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_operation_rows",
        "review_required_rows",
        "apply_blocked_rows",
        "automation_suggested_rows",
        "registry_auth_panel_rows",
        "lockfile_impact_rows",
        "script_or_native_build_risk_rows",
        "grouped_update_plan_rows",
        "operation_history_rows"
      ],
      "properties": {
        "total_operation_rows": { "type": "integer", "minimum": 0 },
        "review_required_rows": { "type": "integer", "minimum": 0 },
        "apply_blocked_rows": { "type": "integer", "minimum": 0 },
        "automation_suggested_rows": { "type": "integer", "minimum": 0 },
        "registry_auth_panel_rows": { "type": "integer", "minimum": 0 },
        "lockfile_impact_rows": { "type": "integer", "minimum": 0 },
        "script_or_native_build_risk_rows": { "type": "integer", "minimum": 0 },
        "grouped_update_plan_rows": { "type": "integer", "minimum": 0 },
        "operation_history_rows": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
