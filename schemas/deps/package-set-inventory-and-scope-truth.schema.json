{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/deps/package-set-inventory-and-scope-truth.schema.json",
  "title": "Aureline package-set inventory and scope truth",
  "description": "Schema for the package_set_inventory_and_scope_truth packet. The packet keeps monorepo package-set inventories, dependency trees, and the scope selector aligned across desktop, CLI/headless, and support/export surfaces, holding whole-workspace, selected-manifest, and workset/slice scopes distinct.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "surface_contract",
    "ecosystem_classes",
    "scope_kinds",
    "convergence_states",
    "runtime_classes",
    "dependency_relation_classes",
    "freshness_states",
    "duplicate_conflict_classes",
    "open_escape_kinds",
    "claimed_stable_ecosystems",
    "scope_views",
    "packages",
    "dependency_edges",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "package_set_inventory_and_scope_truth" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "surface_contract": { "$ref": "#/$defs/surface_contract" },
    "ecosystem_classes": { "type": "array", "items": { "$ref": "#/$defs/ecosystem_class" } },
    "scope_kinds": { "type": "array", "items": { "$ref": "#/$defs/scope_kind" } },
    "convergence_states": { "type": "array", "items": { "$ref": "#/$defs/convergence_state" } },
    "runtime_classes": { "type": "array", "items": { "$ref": "#/$defs/runtime_class" } },
    "dependency_relation_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/dependency_relation_class" }
    },
    "freshness_states": { "type": "array", "items": { "$ref": "#/$defs/freshness_state" } },
    "duplicate_conflict_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/duplicate_conflict_class" }
    },
    "open_escape_kinds": { "type": "array", "items": { "$ref": "#/$defs/open_escape_kind" } },
    "claimed_stable_ecosystems": {
      "type": "array",
      "items": { "$ref": "#/$defs/ecosystem_class" }
    },
    "scope_views": { "type": "array", "items": { "$ref": "#/$defs/scope_view" } },
    "packages": { "type": "array", "items": { "$ref": "#/$defs/package_inventory_row" } },
    "dependency_edges": { "type": "array", "items": { "$ref": "#/$defs/dependency_edge_row" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "ecosystem_class": { "enum": ["cargo", "node_pnpm"] },
    "scope_kind": { "enum": ["full_workspace", "selected_manifests", "workset_slice"] },
    "convergence_state": { "enum": ["unique", "converged", "diverged", "conflicted"] },
    "runtime_class": { "enum": ["runtime", "development", "build", "optional"] },
    "dependency_relation_class": {
      "enum": ["direct", "transitive", "workspace_local", "path", "vcs"]
    },
    "freshness_state": {
      "enum": ["live", "mirror_stale", "offline_snapshot_only", "unknown_or_stale"]
    },
    "duplicate_conflict_class": {
      "enum": ["none_known", "duplicate_versions", "version_conflict", "feature_unification"]
    },
    "open_escape_kind": { "enum": ["open_raw", "open_manifest"] },
    "surface_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inventory_surface",
        "dependency_tree_surface",
        "scope_selector_surface",
        "package_detail_surface",
        "cli_headless_surface",
        "help_page",
        "support_export_surface"
      ],
      "properties": {
        "inventory_surface": { "$ref": "#/$defs/non_empty_string" },
        "dependency_tree_surface": { "$ref": "#/$defs/non_empty_string" },
        "scope_selector_surface": { "$ref": "#/$defs/non_empty_string" },
        "package_detail_surface": { "$ref": "#/$defs/non_empty_string" },
        "cli_headless_surface": { "$ref": "#/$defs/non_empty_string" },
        "help_page": { "$ref": "#/$defs/non_empty_string" },
        "support_export_surface": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "manifest_version_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_path",
        "workspace_member",
        "requested_range_or_source",
        "resolved_exact_version_or_source",
        "relation_class",
        "runtime_class"
      ],
      "properties": {
        "manifest_path": { "$ref": "#/$defs/non_empty_string" },
        "workspace_member": { "$ref": "#/$defs/non_empty_string" },
        "requested_range_or_source": { "$ref": "#/$defs/non_empty_string" },
        "resolved_exact_version_or_source": { "$ref": "#/$defs/non_empty_string" },
        "relation_class": { "$ref": "#/$defs/dependency_relation_class" },
        "runtime_class": { "$ref": "#/$defs/runtime_class" }
      }
    },
    "open_escape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target_ref"],
      "properties": {
        "kind": { "$ref": "#/$defs/open_escape_kind" },
        "target_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "package_inventory_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_id",
        "package_name",
        "ecosystem",
        "owner_manifests",
        "convergence_state",
        "declared_versions",
        "resolved_identity_summary",
        "freshness_state",
        "source_label",
        "open_escapes"
      ],
      "properties": {
        "package_id": { "$ref": "#/$defs/non_empty_string" },
        "package_name": { "$ref": "#/$defs/non_empty_string" },
        "ecosystem": { "$ref": "#/$defs/ecosystem_class" },
        "owner_manifests": { "$ref": "#/$defs/string_array" },
        "convergence_state": { "$ref": "#/$defs/convergence_state" },
        "declared_versions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/manifest_version_claim" }
        },
        "resolved_identity_summary": { "$ref": "#/$defs/non_empty_string" },
        "freshness_state": { "$ref": "#/$defs/freshness_state" },
        "source_label": { "$ref": "#/$defs/non_empty_string" },
        "open_escapes": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/open_escape" }
        }
      }
    },
    "dependency_edge_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_id",
        "owner_manifest",
        "from_label",
        "to_package_id",
        "relation_class",
        "runtime_class",
        "duplicate_conflict_class",
        "disclosure_note"
      ],
      "properties": {
        "edge_id": { "$ref": "#/$defs/non_empty_string" },
        "owner_manifest": { "$ref": "#/$defs/non_empty_string" },
        "from_label": { "$ref": "#/$defs/non_empty_string" },
        "to_package_id": { "$ref": "#/$defs/non_empty_string" },
        "relation_class": { "$ref": "#/$defs/dependency_relation_class" },
        "runtime_class": { "$ref": "#/$defs/runtime_class" },
        "duplicate_conflict_class": { "$ref": "#/$defs/duplicate_conflict_class" },
        "disclosure_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "scope_view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_id",
        "scope_kind",
        "scope_label",
        "included_manifests",
        "member_package_ids",
        "loaded_count",
        "matching_count",
        "total_count",
        "virtualized",
        "filter_label",
        "server_side_widening"
      ],
      "properties": {
        "scope_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_kind": { "$ref": "#/$defs/scope_kind" },
        "scope_label": { "$ref": "#/$defs/non_empty_string" },
        "included_manifests": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "member_package_ids": { "$ref": "#/$defs/string_array" },
        "loaded_count": { "type": "integer", "minimum": 0 },
        "matching_count": { "type": "integer", "minimum": 0 },
        "total_count": { "type": "integer", "minimum": 0 },
        "virtualized": { "type": "boolean" },
        "filter_label": { "$ref": "#/$defs/non_empty_string" },
        "server_side_widening": { "const": false }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_view_rows",
        "full_workspace_scope_rows",
        "selected_manifest_scope_rows",
        "workset_slice_scope_rows",
        "package_rows",
        "unique_package_rows",
        "converged_package_rows",
        "diverged_package_rows",
        "conflicted_package_rows",
        "dependency_edge_rows",
        "duplicate_or_conflict_edge_rows",
        "mirror_or_offline_package_rows"
      ],
      "properties": {
        "scope_view_rows": { "type": "integer", "minimum": 0 },
        "full_workspace_scope_rows": { "type": "integer", "minimum": 0 },
        "selected_manifest_scope_rows": { "type": "integer", "minimum": 0 },
        "workset_slice_scope_rows": { "type": "integer", "minimum": 0 },
        "package_rows": { "type": "integer", "minimum": 0 },
        "unique_package_rows": { "type": "integer", "minimum": 0 },
        "converged_package_rows": { "type": "integer", "minimum": 0 },
        "diverged_package_rows": { "type": "integer", "minimum": 0 },
        "conflicted_package_rows": { "type": "integer", "minimum": 0 },
        "dependency_edge_rows": { "type": "integer", "minimum": 0 },
        "duplicate_or_conflict_edge_rows": { "type": "integer", "minimum": 0 },
        "mirror_or_offline_package_rows": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
