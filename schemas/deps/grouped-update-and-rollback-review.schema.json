{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/deps/grouped-update-and-rollback-review.schema.json",
  "title": "Aureline grouped update and rollback review",
  "description": "Schema for the grouped_update_and_rollback_review packet. The packet keeps the pre-apply review of grouped dependency updates honest across desktop, CLI/headless dry run, and support/export surfaces: every plan discloses requested-versus-resolved versions, manifests touched, an estimated lockfile-churn class, conflict cards, native-build/install-script risk, registry/auth source, and a recommended validation pack, and links to a durable rollback checkpoint receipt with revert/open-diff/export-patch recovery actions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "surface_contract",
    "update_plan_classes",
    "lockfile_churn_classes",
    "conflict_classes",
    "script_native_build_risk_classes",
    "registry_source_classes",
    "credential_modes",
    "validation_outcome_classes",
    "review_dispositions",
    "checkpoint_states",
    "recovery_action_kinds",
    "claimed_stable_ecosystems",
    "update_plans",
    "checkpoints",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "grouped_update_and_rollback_review" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "surface_contract": { "$ref": "#/$defs/surface_contract" },
    "update_plan_classes": { "type": "array", "items": { "$ref": "#/$defs/update_plan_class" } },
    "lockfile_churn_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/lockfile_churn_class" }
    },
    "conflict_classes": { "type": "array", "items": { "$ref": "#/$defs/conflict_class" } },
    "script_native_build_risk_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/script_native_build_risk_class" }
    },
    "registry_source_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/registry_source_class" }
    },
    "credential_modes": { "type": "array", "items": { "$ref": "#/$defs/credential_mode" } },
    "validation_outcome_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_outcome_class" }
    },
    "review_dispositions": { "type": "array", "items": { "$ref": "#/$defs/review_disposition" } },
    "checkpoint_states": { "type": "array", "items": { "$ref": "#/$defs/checkpoint_state" } },
    "recovery_action_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/recovery_action_kind" }
    },
    "claimed_stable_ecosystems": {
      "type": "array",
      "items": { "$ref": "#/$defs/ecosystem_class" }
    },
    "update_plans": { "type": "array", "items": { "$ref": "#/$defs/update_plan" } },
    "checkpoints": { "type": "array", "items": { "$ref": "#/$defs/checkpoint" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "ecosystem_class": { "enum": ["cargo", "node_pnpm"] },
    "update_plan_class": {
      "enum": [
        "direct_bump",
        "security_patch",
        "grouped_refresh",
        "lockfile_refresh_only",
        "major_version_pilot",
        "workspace_wide_convergence"
      ]
    },
    "lockfile_churn_class": {
      "enum": ["single_entry", "localized", "moderate", "broad", "workspace_wide"]
    },
    "conflict_class": {
      "enum": [
        "version_conflict",
        "peer_requirement_conflict",
        "duplicate_versions",
        "feature_unification",
        "advisory_or_yank"
      ]
    },
    "script_native_build_risk_class": {
      "enum": ["none_known", "package_scripts", "native_build", "new_egress", "policy_blocked", "unknown"]
    },
    "registry_source_class": {
      "enum": ["public_registry", "private_registry", "enterprise_mirror", "local_cache", "offline_snapshot"]
    },
    "credential_mode": {
      "enum": ["anonymous", "os_store", "token", "browser_or_device_sign_in", "policy_inherited"]
    },
    "validation_outcome_class": {
      "enum": ["not_run", "passed", "failed", "partial", "skipped_by_policy"]
    },
    "review_disposition": {
      "enum": ["pending_review", "reviewed_ready", "blocked_until_resolved", "applied", "rolled_back"]
    },
    "checkpoint_state": {
      "enum": ["captured", "applied_reversible", "partial_recovery_pending", "reverted", "superseded"]
    },
    "recovery_action_kind": { "enum": ["revert", "open_diff", "export_patch"] },
    "surface_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_surface",
        "conflict_card_surface",
        "rollback_surface",
        "cli_dry_run_surface",
        "help_page",
        "support_export_surface"
      ],
      "properties": {
        "review_surface": { "$ref": "#/$defs/non_empty_string" },
        "conflict_card_surface": { "$ref": "#/$defs/non_empty_string" },
        "rollback_surface": { "$ref": "#/$defs/non_empty_string" },
        "cli_dry_run_surface": { "$ref": "#/$defs/non_empty_string" },
        "help_page": { "$ref": "#/$defs/non_empty_string" },
        "support_export_surface": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "package_version_change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_id",
        "package_name",
        "ecosystem",
        "manifest_path",
        "requested_range_or_source",
        "from_resolved_version",
        "to_resolved_version"
      ],
      "properties": {
        "package_id": { "$ref": "#/$defs/non_empty_string" },
        "package_name": { "$ref": "#/$defs/non_empty_string" },
        "ecosystem": { "$ref": "#/$defs/ecosystem_class" },
        "manifest_path": { "$ref": "#/$defs/non_empty_string" },
        "requested_range_or_source": { "$ref": "#/$defs/non_empty_string" },
        "from_resolved_version": { "$ref": "#/$defs/non_empty_string" },
        "to_resolved_version": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "conflict_card": {
      "type": "object",
      "additionalProperties": false,
      "required": ["card_id", "conflict_class", "package_id", "disclosure", "resolution_hint"],
      "properties": {
        "card_id": { "$ref": "#/$defs/non_empty_string" },
        "conflict_class": { "$ref": "#/$defs/conflict_class" },
        "package_id": { "$ref": "#/$defs/non_empty_string" },
        "disclosure": { "$ref": "#/$defs/non_empty_string" },
        "resolution_hint": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "script_native_build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "risk_class",
        "source_package_refs",
        "policy_allows",
        "requires_explicit_ack",
        "disclosure_note"
      ],
      "properties": {
        "risk_class": { "$ref": "#/$defs/script_native_build_risk_class" },
        "source_package_refs": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "policy_allows": { "type": "boolean" },
        "requires_explicit_ack": { "type": "boolean" },
        "disclosure_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "registry_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_class", "credential_mode", "source_label"],
      "properties": {
        "source_class": { "$ref": "#/$defs/registry_source_class" },
        "credential_mode": { "$ref": "#/$defs/credential_mode" },
        "source_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "validation_pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation_pack_id", "recommended_checks", "required_before_apply", "outcome"],
      "properties": {
        "validation_pack_id": { "$ref": "#/$defs/non_empty_string" },
        "recommended_checks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "required_before_apply": { "type": "boolean" },
        "outcome": { "$ref": "#/$defs/validation_outcome_class" }
      }
    },
    "surface_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["desktop", "cli_headless_dry_run", "support_export"],
      "properties": {
        "desktop": { "const": true },
        "cli_headless_dry_run": { "const": true },
        "support_export": { "const": true }
      }
    },
    "update_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_id",
        "plan_class",
        "ecosystem",
        "plan_label",
        "manifests_touched",
        "package_changes",
        "lockfile_churn_class",
        "lockfile_entries_added",
        "lockfile_entries_removed",
        "lockfile_entries_changed",
        "blast_radius_note",
        "conflict_cards",
        "script_native_build",
        "registry_source",
        "validation_pack",
        "review_disposition",
        "surface_parity",
        "checkpoint_id"
      ],
      "properties": {
        "plan_id": { "$ref": "#/$defs/non_empty_string" },
        "plan_class": { "$ref": "#/$defs/update_plan_class" },
        "ecosystem": { "$ref": "#/$defs/ecosystem_class" },
        "plan_label": { "$ref": "#/$defs/non_empty_string" },
        "manifests_touched": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "package_changes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/package_version_change" }
        },
        "lockfile_churn_class": { "$ref": "#/$defs/lockfile_churn_class" },
        "lockfile_entries_added": { "type": "integer", "minimum": 0 },
        "lockfile_entries_removed": { "type": "integer", "minimum": 0 },
        "lockfile_entries_changed": { "type": "integer", "minimum": 0 },
        "blast_radius_note": { "$ref": "#/$defs/non_empty_string" },
        "conflict_cards": { "type": "array", "items": { "$ref": "#/$defs/conflict_card" } },
        "script_native_build": { "$ref": "#/$defs/script_native_build" },
        "registry_source": { "$ref": "#/$defs/registry_source" },
        "validation_pack": { "$ref": "#/$defs/validation_pack" },
        "review_disposition": { "$ref": "#/$defs/review_disposition" },
        "surface_parity": { "$ref": "#/$defs/surface_parity" },
        "checkpoint_id": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "recovery_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target_ref"],
      "properties": {
        "kind": { "$ref": "#/$defs/recovery_action_kind" },
        "target_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_id",
        "plan_id",
        "state",
        "affected_manifests",
        "lockfile_identity_before",
        "lockfile_identity_after",
        "validation_outcome",
        "durable",
        "receipt_label",
        "recovery_actions"
      ],
      "properties": {
        "checkpoint_id": { "$ref": "#/$defs/non_empty_string" },
        "plan_id": { "$ref": "#/$defs/non_empty_string" },
        "state": { "$ref": "#/$defs/checkpoint_state" },
        "affected_manifests": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "lockfile_identity_before": { "$ref": "#/$defs/non_empty_string" },
        "lockfile_identity_after": { "$ref": "#/$defs/non_empty_string" },
        "validation_outcome": { "$ref": "#/$defs/validation_outcome_class" },
        "durable": { "const": true },
        "receipt_label": { "$ref": "#/$defs/non_empty_string" },
        "recovery_actions": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/recovery_action" }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_rows",
        "direct_bump_plans",
        "security_patch_plans",
        "grouped_refresh_plans",
        "lockfile_refresh_only_plans",
        "major_version_pilot_plans",
        "workspace_wide_convergence_plans",
        "plans_with_conflict_cards",
        "plans_with_script_or_native_risk",
        "conflict_card_rows",
        "checkpoint_rows",
        "durable_checkpoint_rows",
        "recovery_pending_checkpoint_rows",
        "reverted_checkpoint_rows"
      ],
      "properties": {
        "plan_rows": { "type": "integer", "minimum": 0 },
        "direct_bump_plans": { "type": "integer", "minimum": 0 },
        "security_patch_plans": { "type": "integer", "minimum": 0 },
        "grouped_refresh_plans": { "type": "integer", "minimum": 0 },
        "lockfile_refresh_only_plans": { "type": "integer", "minimum": 0 },
        "major_version_pilot_plans": { "type": "integer", "minimum": 0 },
        "workspace_wide_convergence_plans": { "type": "integer", "minimum": 0 },
        "plans_with_conflict_cards": { "type": "integer", "minimum": 0 },
        "plans_with_script_or_native_risk": { "type": "integer", "minimum": 0 },
        "conflict_card_rows": { "type": "integer", "minimum": 0 },
        "checkpoint_rows": { "type": "integer", "minimum": 0 },
        "durable_checkpoint_rows": { "type": "integer", "minimum": 0 },
        "recovery_pending_checkpoint_rows": { "type": "integer", "minimum": 0 },
        "reverted_checkpoint_rows": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
