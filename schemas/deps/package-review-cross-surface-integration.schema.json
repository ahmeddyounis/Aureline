{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/deps/package-review-cross-surface-integration.schema.json",
  "title": "Aureline package-review cross-surface integration",
  "description": "Schema for the package_review_cross_surface_integration packet. The packet integrates dependency/package cards into framework-pack health bundles, review workspaces, incident bundles, and companion-safe inspect views. Every card names its host surface and the write authority it carries there; only the desktop workspace may carry full mutation authority, review workspaces may stage but not apply, and framework-pack, incident, companion, and browser-adjacent surfaces stay inspect-only. A card's finding truth separates a live finding (current local analysis) from an imported one, and live findings may only come from a local source with current advisory freshness. Handoff continuity rows bind each cross-surface transition back to a card so package identity, update class, and review state stay stable.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "surface_classes",
    "write_authorities",
    "support_classes",
    "source_labels",
    "advisory_freshness_classes",
    "finding_truths",
    "update_classes",
    "review_states",
    "transition_kinds",
    "ecosystems",
    "manifest_scope_kinds",
    "cards",
    "handoffs",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "package_review_cross_surface_integration" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "surface_classes": { "type": "array", "items": { "$ref": "#/$defs/surface_class" } },
    "write_authorities": { "type": "array", "items": { "$ref": "#/$defs/write_authority" } },
    "support_classes": { "type": "array", "items": { "$ref": "#/$defs/support_class" } },
    "source_labels": { "type": "array", "items": { "$ref": "#/$defs/source_label" } },
    "advisory_freshness_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/advisory_freshness" }
    },
    "finding_truths": { "type": "array", "items": { "$ref": "#/$defs/finding_truth" } },
    "update_classes": { "type": "array", "items": { "$ref": "#/$defs/update_class" } },
    "review_states": { "type": "array", "items": { "$ref": "#/$defs/review_state" } },
    "transition_kinds": { "type": "array", "items": { "$ref": "#/$defs/transition_kind" } },
    "ecosystems": { "type": "array", "items": { "$ref": "#/$defs/ecosystem" } },
    "manifest_scope_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/manifest_scope_kind" }
    },
    "cards": { "type": "array", "items": { "$ref": "#/$defs/card" } },
    "handoffs": { "type": "array", "items": { "$ref": "#/$defs/handoff" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "surface_class": {
      "enum": [
        "desktop_workspace",
        "framework_pack_health",
        "review_workspace",
        "incident_bundle",
        "companion_inspect",
        "browser_handoff"
      ]
    },
    "write_authority": {
      "enum": ["inspect_only", "review_stage", "full_mutation"]
    },
    "support_class": {
      "enum": ["supported", "managed", "community", "unsupported"]
    },
    "source_label": {
      "enum": ["local", "managed", "mirrored", "imported"]
    },
    "advisory_freshness": {
      "enum": ["current", "stale", "snapshot_only", "unknown"]
    },
    "finding_truth": {
      "enum": ["live", "imported"]
    },
    "update_class": {
      "enum": [
        "none",
        "direct_bump",
        "security_patch",
        "grouped_refresh",
        "lockfile_only",
        "major_pilot",
        "workspace_convergence"
      ]
    },
    "review_state": {
      "enum": [
        "not_started",
        "in_review",
        "changes_requested",
        "approved",
        "applied",
        "rolled_back"
      ]
    },
    "transition_kind": {
      "enum": ["desktop_reopen", "browser_handoff", "companion_followup"]
    },
    "ecosystem": {
      "enum": ["cargo", "node_pnpm", "python_pip", "other"]
    },
    "manifest_scope_kind": {
      "enum": ["full_repo", "single_manifest", "slice"]
    },
    "package_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coordinate", "ecosystem", "manifest_path", "scope_kind"],
      "properties": {
        "coordinate": { "$ref": "#/$defs/non_empty_string" },
        "ecosystem": { "$ref": "#/$defs/ecosystem" },
        "manifest_path": { "$ref": "#/$defs/non_empty_string" },
        "scope_kind": { "$ref": "#/$defs/manifest_scope_kind" }
      }
    },
    "card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id",
        "surface",
        "write_authority",
        "package_identity",
        "support_class",
        "source_label",
        "advisory_freshness",
        "finding_truth",
        "update_class",
        "review_state",
        "note"
      ],
      "properties": {
        "card_id": { "$ref": "#/$defs/non_empty_string" },
        "surface": { "$ref": "#/$defs/surface_class" },
        "write_authority": { "$ref": "#/$defs/write_authority" },
        "package_identity": { "$ref": "#/$defs/package_identity" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "source_label": { "$ref": "#/$defs/source_label" },
        "advisory_freshness": { "$ref": "#/$defs/advisory_freshness" },
        "finding_truth": { "$ref": "#/$defs/finding_truth" },
        "update_class": { "$ref": "#/$defs/update_class" },
        "review_state": { "$ref": "#/$defs/review_state" },
        "inspect_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff_id",
        "card_id",
        "transition",
        "from_surface",
        "to_surface",
        "package_identity",
        "update_class",
        "review_state",
        "note"
      ],
      "properties": {
        "handoff_id": { "$ref": "#/$defs/non_empty_string" },
        "card_id": { "$ref": "#/$defs/non_empty_string" },
        "transition": { "$ref": "#/$defs/transition_kind" },
        "from_surface": { "$ref": "#/$defs/surface_class" },
        "to_surface": { "$ref": "#/$defs/surface_class" },
        "package_identity": { "$ref": "#/$defs/package_identity" },
        "update_class": { "$ref": "#/$defs/update_class" },
        "review_state": { "$ref": "#/$defs/review_state" },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_cards",
        "desktop_workspace_cards",
        "framework_pack_health_cards",
        "review_workspace_cards",
        "incident_bundle_cards",
        "companion_inspect_cards",
        "browser_handoff_cards",
        "inspect_only_cards",
        "review_stage_cards",
        "full_mutation_cards",
        "live_finding_cards",
        "imported_finding_cards",
        "total_handoffs",
        "identity_preserving_handoffs"
      ],
      "properties": {
        "total_cards": { "type": "integer", "minimum": 0 },
        "desktop_workspace_cards": { "type": "integer", "minimum": 0 },
        "framework_pack_health_cards": { "type": "integer", "minimum": 0 },
        "review_workspace_cards": { "type": "integer", "minimum": 0 },
        "incident_bundle_cards": { "type": "integer", "minimum": 0 },
        "companion_inspect_cards": { "type": "integer", "minimum": 0 },
        "browser_handoff_cards": { "type": "integer", "minimum": 0 },
        "inspect_only_cards": { "type": "integer", "minimum": 0 },
        "review_stage_cards": { "type": "integer", "minimum": 0 },
        "full_mutation_cards": { "type": "integer", "minimum": 0 },
        "live_finding_cards": { "type": "integer", "minimum": 0 },
        "imported_finding_cards": { "type": "integer", "minimum": 0 },
        "total_handoffs": { "type": "integer", "minimum": 0 },
        "identity_preserving_handoffs": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
