{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/deps/dependency-security-compliance-export-truth.schema.json",
  "title": "Aureline dependency-security-compliance export truth",
  "description": "Schema for the dependency_security_compliance_export_truth packet. The packet ties SBOM references, notices, advisories, suppressions, and review decisions back to exact build, workspace, profile, and evidence-source context. It distinguishes No active findings from No current feed data, preserves suppression actor/reason/scope/expiry/reopen behavior, and produces redaction-safe projections for UI, CLI, support bundles, release packets, and public proof.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "build_context",
    "advisory_source_classes",
    "advisory_freshness_classes",
    "advisory_severity_classes",
    "suppression_states",
    "license_review_postures",
    "notice_sources",
    "export_scopes",
    "lockfile_risk_classes",
    "findings_states",
    "advisory_rows",
    "suppression_rows",
    "license_notice_rows",
    "lockfile_risk_rows",
    "export_scopes_targeted",
    "summary"
  ],
  "properties": {
    "schema_version": { "$ref": "#/$defs/schema_version" },
    "record_kind": { "const": "dependency_security_compliance_export_truth" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "build_context": { "$ref": "#/$defs/build_context" },
    "advisory_source_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/advisory_source_class" }
    },
    "advisory_freshness_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/advisory_freshness_class" }
    },
    "advisory_severity_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/advisory_severity_class" }
    },
    "suppression_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/suppression_state" }
    },
    "license_review_postures": {
      "type": "array",
      "items": { "$ref": "#/$defs/license_review_posture" }
    },
    "notice_sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/notice_source" }
    },
    "export_scopes": {
      "type": "array",
      "items": { "$ref": "#/$defs/export_scope" }
    },
    "lockfile_risk_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/lockfile_risk_class" }
    },
    "findings_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/findings_state" }
    },
    "advisory_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/advisory_row" }
    },
    "suppression_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/suppression_row" }
    },
    "license_notice_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/license_notice_row" }
    },
    "lockfile_risk_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/lockfile_risk_row" }
    },
    "export_scopes_targeted": {
      "type": "array",
      "items": { "$ref": "#/$defs/export_scope" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "non_empty_string": { "type": "string", "minLength": 1 },
    "nullable_non_empty_string": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/non_empty_string" }]
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "build_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["build_id", "workspace_scope_ref", "profile", "lockfile_fingerprint"],
      "properties": {
        "build_id": { "$ref": "#/$defs/non_empty_string" },
        "workspace_scope_ref": { "$ref": "#/$defs/non_empty_string" },
        "profile": { "$ref": "#/$defs/non_empty_string" },
        "lockfile_fingerprint": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "advisory_source_class": {
      "type": "string",
      "enum": [
        "live_public_feed",
        "enterprise_mirror",
        "imported_report",
        "stale_local_cache",
        "offline_bundle"
      ]
    },
    "advisory_freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "stale",
        "missing",
        "mirror_only",
        "feed_outage"
      ]
    },
    "advisory_severity_class": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high",
        "critical",
        "unknown"
      ]
    },
    "suppression_state": {
      "type": "string",
      "enum": [
        "not_suppressed",
        "active_time_bound",
        "expired_reopened",
        "policy_locked"
      ]
    },
    "license_review_posture": {
      "type": "string",
      "enum": [
        "approved",
        "approved_with_notice",
        "review_required",
        "denied_by_policy",
        "unknown_requires_review"
      ]
    },
    "notice_source": {
      "type": "string",
      "enum": [
        "spdx_sbom",
        "human_readable_notice",
        "reuse_compliant",
        "import_manifest",
        "missing"
      ]
    },
    "export_scope": {
      "type": "string",
      "enum": [
        "ui_inspection",
        "cli_headless",
        "support_bundle",
        "release_packet",
        "public_proof"
      ]
    },
    "lockfile_risk_class": {
      "type": "string",
      "enum": [
        "resolved_exact",
        "policy_pinned",
        "out_of_date",
        "unresolved",
        "vulnerable"
      ]
    },
    "findings_state": {
      "type": "string",
      "enum": [
        "no_active_findings",
        "no_current_feed_data",
        "findings_present",
        "feed_outage"
      ]
    },
    "advisory_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "advisory_id",
        "title",
        "source_class",
        "freshness_class",
        "severity_class",
        "findings_state",
        "matched_at",
        "note"
      ],
      "properties": {
        "advisory_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "source_class": { "$ref": "#/$defs/advisory_source_class" },
        "freshness_class": { "$ref": "#/$defs/advisory_freshness_class" },
        "severity_class": { "$ref": "#/$defs/advisory_severity_class" },
        "affected_dependency_refs": { "$ref": "#/$defs/ref_array" },
        "affected_ranges": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "suppression_refs": { "$ref": "#/$defs/ref_array" },
        "findings_state": { "$ref": "#/$defs/findings_state" },
        "matched_at": { "type": "string", "format": "date-time" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "suppression_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suppression_id",
        "title",
        "suppression_state",
        "actor_ref",
        "reason_ref",
        "scoped_to_ref",
        "reopen_on_expiry",
        "note"
      ],
      "properties": {
        "suppression_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "suppression_state": { "$ref": "#/$defs/suppression_state" },
        "actor_ref": { "$ref": "#/$defs/non_empty_string" },
        "reason_ref": { "$ref": "#/$defs/non_empty_string" },
        "scoped_to_ref": { "$ref": "#/$defs/non_empty_string" },
        "expires_at": { "type": "string", "format": "date-time" },
        "reopen_on_expiry": { "type": "boolean" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "suppression_state": { "const": "active_time_bound" } },
            "required": ["suppression_state"]
          },
          "then": { "required": ["expires_at"] }
        }
      ]
    },
    "license_notice_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "package_ref",
        "license_posture",
        "notice_source",
        "note"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "package_ref": { "$ref": "#/$defs/non_empty_string" },
        "license_posture": { "$ref": "#/$defs/license_review_posture" },
        "notice_source": { "$ref": "#/$defs/notice_source" },
        "spdx_expression": { "$ref": "#/$defs/nullable_non_empty_string" },
        "sbom_refs": { "$ref": "#/$defs/ref_array" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "lockfile_risk_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "package_ref",
        "risk_class",
        "note"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "package_ref": { "$ref": "#/$defs/non_empty_string" },
        "risk_class": { "$ref": "#/$defs/lockfile_risk_class" },
        "manifest_requirement": { "$ref": "#/$defs/nullable_non_empty_string" },
        "resolved_version": { "$ref": "#/$defs/nullable_non_empty_string" },
        "advisory_refs": { "$ref": "#/$defs/ref_array" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_advisory_rows",
        "active_advisory_rows",
        "no_active_findings_rows",
        "no_current_feed_data_rows",
        "feed_outage_rows",
        "total_suppression_rows",
        "active_suppression_rows",
        "expired_reopened_rows",
        "total_license_notice_rows",
        "blocking_license_notice_rows",
        "total_lockfile_risk_rows",
        "risky_lockfile_rows"
      ],
      "properties": {
        "total_advisory_rows": { "type": "integer", "minimum": 0 },
        "active_advisory_rows": { "type": "integer", "minimum": 0 },
        "no_active_findings_rows": { "type": "integer", "minimum": 0 },
        "no_current_feed_data_rows": { "type": "integer", "minimum": 0 },
        "feed_outage_rows": { "type": "integer", "minimum": 0 },
        "total_suppression_rows": { "type": "integer", "minimum": 0 },
        "active_suppression_rows": { "type": "integer", "minimum": 0 },
        "expired_reopened_rows": { "type": "integer", "minimum": 0 },
        "total_license_notice_rows": { "type": "integer", "minimum": 0 },
        "blocking_license_notice_rows": { "type": "integer", "minimum": 0 },
        "total_lockfile_risk_rows": { "type": "integer", "minimum": 0 },
        "risky_lockfile_rows": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
