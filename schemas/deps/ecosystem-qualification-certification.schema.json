{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/deps/ecosystem-qualification-certification.schema.json",
  "title": "Aureline ecosystem-qualification certification",
  "description": "Schema for the ecosystem_qualification_certification packet. The packet certifies, for every marketed ecosystem and every qualification lane (dependency intelligence, package review, code quality, imported-scanner maturity), whether the lane carries a current qualification packet and proof corpus of its own. The publication gate derives the maturity that may be published for each row from its declared maturity, certification freshness, blocking reasons, and evidence: a stale, mirror-blocked, scanner-underqualified, or evidence-missing row cannot publish a full certification, and its narrowing action records how the gate narrowed it. One row is required for every (ecosystem, lane) cell so a strong ecosystem never implies maturity on an unrelated one.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "claimed_ecosystems",
    "lanes",
    "maturity_classes",
    "certification_freshness_classes",
    "blocking_reasons",
    "narrowing_actions",
    "support_classes",
    "rows",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "ecosystem_qualification_certification" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "claimed_ecosystems": { "type": "array", "items": { "$ref": "#/$defs/ecosystem" } },
    "lanes": { "type": "array", "items": { "$ref": "#/$defs/lane" } },
    "maturity_classes": { "type": "array", "items": { "$ref": "#/$defs/maturity_class" } },
    "certification_freshness_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/certification_freshness" }
    },
    "blocking_reasons": { "type": "array", "items": { "$ref": "#/$defs/blocking_reason" } },
    "narrowing_actions": { "type": "array", "items": { "$ref": "#/$defs/narrowing_action" } },
    "support_classes": { "type": "array", "items": { "$ref": "#/$defs/support_class" } },
    "rows": { "type": "array", "items": { "$ref": "#/$defs/row" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "ecosystem": {
      "enum": ["cargo", "node_pnpm", "python_pip"]
    },
    "lane": {
      "enum": ["dependency_intelligence", "package_review", "code_quality", "scanner_import"]
    },
    "maturity_class": {
      "enum": ["certified", "provisional", "underqualified", "unsupported"]
    },
    "certification_freshness": {
      "enum": ["current", "stale", "expired", "unknown"]
    },
    "blocking_reason": {
      "enum": [
        "stale",
        "mirror_blocked",
        "scanner_underqualified",
        "missing_package_lockfile_evidence",
        "missing_corpus"
      ]
    },
    "narrowing_action": {
      "enum": [
        "none",
        "narrow_to_provisional",
        "narrow_to_underqualified",
        "withhold_from_publication"
      ]
    },
    "support_class": {
      "enum": ["supported", "managed", "community", "unsupported"]
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "ecosystem",
        "lane",
        "declared_maturity",
        "published_maturity",
        "certification_freshness",
        "support_class",
        "narrowing_action",
        "qualification_packet_ref",
        "corpus_ref",
        "note"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "ecosystem": { "$ref": "#/$defs/ecosystem" },
        "lane": { "$ref": "#/$defs/lane" },
        "declared_maturity": { "$ref": "#/$defs/maturity_class" },
        "published_maturity": { "$ref": "#/$defs/maturity_class" },
        "certification_freshness": { "$ref": "#/$defs/certification_freshness" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "narrowing_action": { "$ref": "#/$defs/narrowing_action" },
        "blocking_reasons": { "type": "array", "items": { "$ref": "#/$defs/blocking_reason" } },
        "qualification_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "corpus_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows",
        "claimed_ecosystem_count",
        "lane_count",
        "certified_rows",
        "provisional_rows",
        "underqualified_rows",
        "unsupported_rows",
        "promotable_rows",
        "narrowed_rows",
        "withheld_rows",
        "current_freshness_rows",
        "rows_with_blocking_reasons"
      ],
      "properties": {
        "total_rows": { "type": "integer", "minimum": 0 },
        "claimed_ecosystem_count": { "type": "integer", "minimum": 0 },
        "lane_count": { "type": "integer", "minimum": 0 },
        "certified_rows": { "type": "integer", "minimum": 0 },
        "provisional_rows": { "type": "integer", "minimum": 0 },
        "underqualified_rows": { "type": "integer", "minimum": 0 },
        "unsupported_rows": { "type": "integer", "minimum": 0 },
        "promotable_rows": { "type": "integer", "minimum": 0 },
        "narrowed_rows": { "type": "integer", "minimum": 0 },
        "withheld_rows": { "type": "integer", "minimum": 0 },
        "current_freshness_rows": { "type": "integer", "minimum": 0 },
        "rows_with_blocking_reasons": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
