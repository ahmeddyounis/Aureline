{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/graph/topology_surface.schema.json",
  "title": "Aureline graph understanding topology surface packet",
  "description": "Boundary schema for the graph understanding UI projection emitted by the topology, impact explorer, and cited explainer surface layer. The packet reuses graph node ids, graph edge ids, the shared scope vocabulary, the controlled impact-reason vocabulary, freshness/provenance disclosures, and explicit export actions so canvas, list/table, CLI/headless, support, and review packet views stay in parity.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "surface_id",
    "workspace_id",
    "workspace_graph_id",
    "scope_class",
    "canvas_nodes",
    "canvas_edges",
    "node_table_rows",
    "edge_table_rows",
    "relation_legend",
    "freshness_provenance_strip",
    "open_evidence_actions",
    "export_actions"
  ],
  "additionalProperties": true,
  "properties": {
    "record_kind": { "const": "topology_surface_record" },
    "schema_version": { "const": 1 },
    "surface_id": { "$ref": "#/$defs/opaque_id" },
    "workspace_id": { "$ref": "#/$defs/opaque_id" },
    "workspace_graph_id": { "$ref": "#/$defs/opaque_id" },
    "scope_class": { "$ref": "#/$defs/scope_vocabulary_class" },
    "canvas_nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/topology_node_row" }
    },
    "canvas_edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/topology_edge_row" }
    },
    "node_table_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/topology_node_row" },
      "description": "Must contain one row with matching identity, freshness, confidence, and selection state for every canvas node."
    },
    "edge_table_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/topology_edge_row" },
      "description": "Must contain one row with matching identity, provenance, confidence, relation class, and selection state for every canvas edge."
    },
    "relation_legend": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/relation_legend_entry" }
    },
    "filter_state": {
      "type": "array",
      "items": { "$ref": "#/$defs/filter_state_entry" }
    },
    "freshness_provenance_strip": {
      "$ref": "#/$defs/freshness_provenance_strip"
    },
    "open_source_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_action" }
    },
    "open_evidence_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surface_action" }
    },
    "export_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surface_action" }
    },
    "cluster_disclosures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cluster_id", "count", "category", "omitted_classes", "scope_note", "freshness_note"],
        "additionalProperties": true,
        "properties": {
          "cluster_id": { "$ref": "#/$defs/opaque_id" },
          "count": { "type": "integer", "minimum": 0 },
          "category": { "type": "string", "minLength": 1 },
          "omitted_classes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "scope_note": { "$ref": "#/$defs/redaction_aware_text" },
          "freshness_note": { "$ref": "#/$defs/redaction_aware_text" }
        }
      }
    }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for logs, exports, and support packets."
    },
    "redaction_aware_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "scope_vocabulary_class": {
      "type": "string",
      "enum": [
        "current_repo",
        "selected_workset",
        "full_workspace",
        "remote_cache",
        "outside_current_scope"
      ],
      "description": "Shared scope vocabulary for topology maps, impact explorers, AI context inspectors, and review-side semantic hints."
    },
    "relation_legend_class": {
      "type": "string",
      "enum": [
        "exact_structural_edge",
        "build_runtime_relation",
        "ownership_policy_relation",
        "coverage_test_relation",
        "generated_derived_relation",
        "heuristic_summary_relation"
      ]
    },
    "selection_state": {
      "type": "string",
      "enum": ["not_selected", "selected"]
    },
    "disclosure_state": {
      "type": "string",
      "enum": [
        "partial_graph",
        "imported_fact",
        "parser_only_fallback",
        "policy_hidden",
        "remote_cache",
        "outside_current_scope",
        "generated_or_heuristic"
      ]
    },
    "controlled_impact_reason_class": {
      "type": "string",
      "enum": [
        "exact_edge",
        "shared_target",
        "ownership_rule",
        "generated_linkage",
        "heuristic_similarity",
        "policy_coupling"
      ],
      "description": "Minimum controlled impact-reason vocabulary used consistently in UI, CLI/headless, exports, and support packets."
    },
    "topology_node_row": {
      "type": "object",
      "required": ["node_id", "node_class", "display_label", "freshness", "confidence", "selection_state"],
      "additionalProperties": false,
      "properties": {
        "node_id": { "$ref": "#/$defs/opaque_id" },
        "node_class": { "type": "string", "minLength": 1 },
        "display_label": { "$ref": "#/$defs/redaction_aware_text" },
        "freshness": { "type": "string", "minLength": 1 },
        "confidence": { "type": "string", "minLength": 1 },
        "selection_state": { "$ref": "#/$defs/selection_state" }
      }
    },
    "topology_edge_row": {
      "type": "object",
      "required": [
        "edge_id",
        "edge_class",
        "from_node_id",
        "to_node_id",
        "relation_class",
        "evidence_state",
        "freshness",
        "confidence",
        "selection_state"
      ],
      "additionalProperties": false,
      "properties": {
        "edge_id": { "$ref": "#/$defs/opaque_id" },
        "edge_class": { "type": "string", "minLength": 1 },
        "from_node_id": { "$ref": "#/$defs/opaque_id" },
        "to_node_id": { "$ref": "#/$defs/opaque_id" },
        "relation_class": { "$ref": "#/$defs/relation_legend_class" },
        "evidence_state": { "type": "string", "minLength": 1 },
        "freshness": { "type": "string", "minLength": 1 },
        "confidence": { "type": "string", "minLength": 1 },
        "selection_state": { "$ref": "#/$defs/selection_state" }
      }
    },
    "relation_legend_entry": {
      "type": "object",
      "required": ["relation_class", "edge_classes", "description"],
      "additionalProperties": false,
      "properties": {
        "relation_class": { "$ref": "#/$defs/relation_legend_class" },
        "edge_classes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "description": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "filter_state_entry": {
      "type": "object",
      "required": ["filter_id", "filter_class", "engaged", "selected_values"],
      "additionalProperties": false,
      "properties": {
        "filter_id": { "$ref": "#/$defs/opaque_id" },
        "filter_class": { "type": "string", "minLength": 1 },
        "engaged": { "type": "boolean" },
        "selected_values": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "freshness_provenance_strip": {
      "type": "object",
      "required": ["graph_epoch", "scope_class", "scope_id", "readiness", "provenance_note", "disclosures"],
      "additionalProperties": false,
      "properties": {
        "graph_epoch": { "$ref": "#/$defs/opaque_id" },
        "scope_class": { "$ref": "#/$defs/scope_vocabulary_class" },
        "scope_id": { "$ref": "#/$defs/opaque_id" },
        "readiness": { "type": "string", "minLength": 1 },
        "provenance_note": { "$ref": "#/$defs/redaction_aware_text" },
        "disclosures": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/disclosure_state" }
        }
      }
    },
    "surface_action": {
      "type": "object",
      "required": ["action_id", "action_class", "subject_ref", "preserves_scope"],
      "additionalProperties": false,
      "properties": {
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "action_class": { "type": "string", "minLength": 1 },
        "subject_ref": { "$ref": "#/$defs/opaque_id" },
        "preserves_scope": { "type": "boolean" }
      }
    }
  }
}
