{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/graph/m5-ownership-and-contracts.schema.json",
  "title": "Aureline M5 ownership-and-contracts packet",
  "description": "Schema for the m5_ownership_and_contracts_packet. The packet carries the honest answer the M5 graph surfaces give to 'who owns this, and what kind of source produced that answer?', keeping curated first-party metadata distinct from policy-derived ownership, imported provider metadata, and heuristic inference. Each descriptor records the subject it attaches to (in the shared topology identity space), its distinct human role (owner, reviewer, maintainer, support contact, or change-control link), its source class, a party label, a visibility scope, freshness, confidence, an optional source reason, an optional change-control link url, the descriptor ids it supersedes, and an export-safe permalink that embeds the canonical descriptor id. A non-curated descriptor must carry a source_reason; a change-control descriptor must carry a change_control_url and no other role may; an inferred or imported descriptor may not supersede a curated or policy-derived descriptor. One consumer binding per surface (review hint, explainer card, onboarding context, AI ownership suggestion, support export) carries the same answer beyond one panel render, is stamped with the active scope snapshot, preserves source-class labels, and may not carry a descriptor more restricted than its visibility ceiling; the support-export binding must carry every export-safe descriptor and no private one. The packet binds upstream to the canonical graph-depth governance matrix, the workset-scope packet, and the topology-identity packet it reuses. The summary counts must equal the recomputed counts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "governance_matrix_ref",
    "scope_packet_ref",
    "topology_packet_ref",
    "conformance_ref",
    "release_evidence_ref",
    "help_surface_ref",
    "docs_badge_ref",
    "support_export_ref",
    "source_classes",
    "roles",
    "visibilities",
    "consumer_surfaces",
    "active_scope",
    "descriptors",
    "consumer_bindings",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_ownership_and_contracts_packet" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "governance_matrix_ref": { "const": "artifacts/graph/m5/m5-graph-governance.json" },
    "scope_packet_ref": { "const": "artifacts/graph/m5/m5-workset-scope.json" },
    "topology_packet_ref": { "const": "artifacts/graph/m5/m5-topology-identity.json" },
    "conformance_ref": { "$ref": "#/$defs/non_empty_string" },
    "release_evidence_ref": { "$ref": "#/$defs/non_empty_string" },
    "help_surface_ref": { "$ref": "#/$defs/non_empty_string" },
    "docs_badge_ref": { "$ref": "#/$defs/non_empty_string" },
    "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
    "source_classes": { "type": "array", "items": { "$ref": "#/$defs/source_class" } },
    "roles": { "type": "array", "items": { "$ref": "#/$defs/role" } },
    "visibilities": { "type": "array", "items": { "$ref": "#/$defs/visibility" } },
    "consumer_surfaces": { "type": "array", "items": { "$ref": "#/$defs/consumer_surface" } },
    "active_scope": { "$ref": "#/$defs/active_scope" },
    "descriptors": { "type": "array", "items": { "$ref": "#/$defs/descriptor" } },
    "consumer_bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/consumer_binding" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "source_class": {
      "enum": ["curated", "policy_derived", "imported", "heuristic"]
    },
    "role": {
      "enum": ["owner", "reviewer", "maintainer", "support_contact", "change_control"]
    },
    "visibility": {
      "enum": ["public", "internal", "private"]
    },
    "consumer_surface": {
      "enum": [
        "review_hint",
        "explainer_card",
        "onboarding_context",
        "ai_ownership_suggestion",
        "support_export"
      ]
    },
    "node_kind": {
      "enum": [
        "file",
        "directory",
        "symbol",
        "module",
        "doc",
        "ownership",
        "provider_resource",
        "workset_scope"
      ]
    },
    "active_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_id", "scope_id", "taken_as_of", "scope_mode"],
      "properties": {
        "snapshot_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_id": { "$ref": "#/$defs/non_empty_string" },
        "taken_as_of": { "type": "string", "format": "date" },
        "scope_mode": { "enum": ["full", "sparse"] }
      }
    },
    "descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "descriptor_id",
        "subject_id",
        "subject_kind",
        "role",
        "source_class",
        "party_label",
        "visibility",
        "freshness",
        "confidence",
        "export_permalink"
      ],
      "properties": {
        "descriptor_id": { "$ref": "#/$defs/non_empty_string" },
        "subject_id": { "$ref": "#/$defs/non_empty_string" },
        "subject_kind": { "$ref": "#/$defs/node_kind" },
        "role": { "$ref": "#/$defs/role" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "source_reason": { "$ref": "#/$defs/non_empty_string" },
        "party_label": { "$ref": "#/$defs/non_empty_string" },
        "visibility": { "$ref": "#/$defs/visibility" },
        "freshness": { "$ref": "#/$defs/non_empty_string" },
        "confidence": { "$ref": "#/$defs/non_empty_string" },
        "change_control_url": { "$ref": "#/$defs/non_empty_string" },
        "supersedes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "export_permalink": { "$ref": "#/$defs/non_empty_string" }
      },
      "allOf": [
        {
          "comment": "A non-curated descriptor must carry an explicit source_reason.",
          "if": {
            "properties": {
              "source_class": { "enum": ["policy_derived", "imported", "heuristic"] }
            }
          },
          "then": { "required": ["source_reason"] }
        },
        {
          "comment": "A change-control descriptor must carry a change_control_url.",
          "if": {
            "properties": { "role": { "const": "change_control" } }
          },
          "then": { "required": ["change_control_url"] }
        }
      ]
    },
    "consumer_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "surface",
        "snapshot_id",
        "scope_id",
        "max_visibility",
        "preserves_source_labels",
        "carries_descriptor_ids",
        "consumer_ref",
        "note"
      ],
      "properties": {
        "binding_id": { "$ref": "#/$defs/non_empty_string" },
        "surface": { "$ref": "#/$defs/consumer_surface" },
        "snapshot_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_id": { "$ref": "#/$defs/non_empty_string" },
        "max_visibility": { "$ref": "#/$defs/visibility" },
        "preserves_source_labels": { "type": "boolean" },
        "carries_descriptor_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "consumer_ref": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "descriptor_count",
        "consumer_binding_count",
        "surface_count",
        "curated_count",
        "policy_derived_count",
        "imported_count",
        "heuristic_count",
        "owner_count",
        "reviewer_count",
        "maintainer_count",
        "support_contact_count",
        "change_control_count",
        "public_count",
        "internal_count",
        "private_count",
        "export_safe_descriptor_count",
        "descriptors_with_source_reason",
        "supersedes_link_count"
      ],
      "properties": {
        "descriptor_count": { "type": "integer", "minimum": 0 },
        "consumer_binding_count": { "type": "integer", "minimum": 0 },
        "surface_count": { "type": "integer", "minimum": 0 },
        "curated_count": { "type": "integer", "minimum": 0 },
        "policy_derived_count": { "type": "integer", "minimum": 0 },
        "imported_count": { "type": "integer", "minimum": 0 },
        "heuristic_count": { "type": "integer", "minimum": 0 },
        "owner_count": { "type": "integer", "minimum": 0 },
        "reviewer_count": { "type": "integer", "minimum": 0 },
        "maintainer_count": { "type": "integer", "minimum": 0 },
        "support_contact_count": { "type": "integer", "minimum": 0 },
        "change_control_count": { "type": "integer", "minimum": 0 },
        "public_count": { "type": "integer", "minimum": 0 },
        "internal_count": { "type": "integer", "minimum": 0 },
        "private_count": { "type": "integer", "minimum": 0 },
        "export_safe_descriptor_count": { "type": "integer", "minimum": 0 },
        "descriptors_with_source_reason": { "type": "integer", "minimum": 0 },
        "supersedes_link_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
