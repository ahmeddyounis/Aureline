{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/graph/m5-explainer-and-architecture-maps.schema.json",
  "title": "Aureline M5 explainer-and-architecture-maps packet",
  "description": "Schema for the m5_explainer_and_architecture_maps_packet. The packet carries the honest answer the M5 graph surfaces give to 'what is this part of the workspace, and what backs that explanation?', keeping generated prose distinct from curated and imported explanations. Each snapshot records the topology subject it explains (in the shared topology identity space), a generated-versus-curated source class, freshness and confidence cues, a visibility scope, the citation ids that back it (a snapshot must cite at least one), the navigation affordances it offers (the keyboard, list/table, and screen-reader paths are required so a map is never canvas-only), the open follow-up action ids it surfaces, and an export-safe permalink that embeds the canonical snapshot id. Each citation points at a file, symbol, doc pack, ADR, curated note, or graph object. One consumer binding per surface (onboarding tour, review explainer, docs browser, AI context inspector, support export) carries the same snapshot beyond one panel render, is stamped with the active scope snapshot, preserves source-class labels, and may not carry a snapshot more restricted than its visibility ceiling; the support-export binding must carry every export-safe snapshot and no private one. The packet binds upstream to the canonical graph-depth governance matrix, the workset-scope packet, and the topology-identity packet it reuses. The summary counts must equal the recomputed counts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "governance_matrix_ref",
    "scope_packet_ref",
    "topology_packet_ref",
    "conformance_ref",
    "release_evidence_ref",
    "help_surface_ref",
    "docs_badge_ref",
    "support_export_ref",
    "source_classes",
    "citation_kinds",
    "navigation_affordances",
    "follow_up_action_classes",
    "visibilities",
    "consumer_surfaces",
    "active_scope",
    "citations",
    "follow_up_actions",
    "snapshots",
    "consumer_bindings",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_explainer_and_architecture_maps_packet" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "governance_matrix_ref": { "const": "artifacts/graph/m5/m5-graph-governance.json" },
    "scope_packet_ref": { "const": "artifacts/graph/m5/m5-workset-scope.json" },
    "topology_packet_ref": { "const": "artifacts/graph/m5/m5-topology-identity.json" },
    "conformance_ref": { "$ref": "#/$defs/non_empty_string" },
    "release_evidence_ref": { "$ref": "#/$defs/non_empty_string" },
    "help_surface_ref": { "$ref": "#/$defs/non_empty_string" },
    "docs_badge_ref": { "$ref": "#/$defs/non_empty_string" },
    "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
    "source_classes": { "type": "array", "items": { "$ref": "#/$defs/source_class" } },
    "citation_kinds": { "type": "array", "items": { "$ref": "#/$defs/citation_kind" } },
    "navigation_affordances": {
      "type": "array",
      "items": { "$ref": "#/$defs/navigation_affordance" }
    },
    "follow_up_action_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/follow_up_action_class" }
    },
    "visibilities": { "type": "array", "items": { "$ref": "#/$defs/visibility" } },
    "consumer_surfaces": { "type": "array", "items": { "$ref": "#/$defs/consumer_surface" } },
    "active_scope": { "$ref": "#/$defs/active_scope" },
    "citations": { "type": "array", "items": { "$ref": "#/$defs/citation" } },
    "follow_up_actions": { "type": "array", "items": { "$ref": "#/$defs/follow_up_action" } },
    "snapshots": { "type": "array", "items": { "$ref": "#/$defs/snapshot" } },
    "consumer_bindings": { "type": "array", "items": { "$ref": "#/$defs/consumer_binding" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "source_class": { "enum": ["curated", "imported", "generated"] },
    "citation_kind": {
      "enum": ["file", "symbol", "doc_pack", "adr", "curated_note", "graph_object"]
    },
    "navigation_affordance": {
      "enum": ["canvas", "keyboard", "list_table", "screen_reader"]
    },
    "follow_up_action_class": {
      "enum": [
        "open_cited_source",
        "open_architecture_map",
        "refresh_stale_snapshot",
        "widen_scope",
        "request_curated_review"
      ]
    },
    "visibility": { "enum": ["public", "internal", "private"] },
    "consumer_surface": {
      "enum": [
        "onboarding_tour",
        "review_explainer",
        "docs_browser",
        "ai_context_inspector",
        "support_export"
      ]
    },
    "node_kind": {
      "enum": [
        "file",
        "directory",
        "symbol",
        "module",
        "doc",
        "ownership",
        "provider_resource",
        "workset_scope"
      ]
    },
    "active_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_id", "scope_id", "taken_as_of", "scope_mode"],
      "properties": {
        "snapshot_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_id": { "$ref": "#/$defs/non_empty_string" },
        "taken_as_of": { "type": "string", "format": "date" },
        "scope_mode": { "enum": ["full", "sparse"] }
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "citation_id",
        "kind",
        "target_ref",
        "display_label",
        "freshness",
        "confidence",
        "export_permalink"
      ],
      "properties": {
        "citation_id": { "$ref": "#/$defs/non_empty_string" },
        "kind": { "$ref": "#/$defs/citation_kind" },
        "target_ref": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "freshness": { "$ref": "#/$defs/non_empty_string" },
        "confidence": { "$ref": "#/$defs/non_empty_string" },
        "export_permalink": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "follow_up_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_class", "subject_ref", "label"],
      "properties": {
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "action_class": { "$ref": "#/$defs/follow_up_action_class" },
        "subject_ref": { "$ref": "#/$defs/non_empty_string" },
        "label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_id",
        "subject_id",
        "subject_kind",
        "title",
        "prose_ref",
        "source_class",
        "freshness",
        "confidence",
        "visibility",
        "cited_ids",
        "navigation_affordances",
        "export_permalink"
      ],
      "properties": {
        "snapshot_id": { "$ref": "#/$defs/non_empty_string" },
        "subject_id": { "$ref": "#/$defs/non_empty_string" },
        "subject_kind": { "$ref": "#/$defs/node_kind" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "prose_ref": { "$ref": "#/$defs/non_empty_string" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "freshness": { "$ref": "#/$defs/non_empty_string" },
        "confidence": { "$ref": "#/$defs/non_empty_string" },
        "visibility": { "$ref": "#/$defs/visibility" },
        "cited_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "navigation_affordances": {
          "type": "array",
          "items": { "$ref": "#/$defs/navigation_affordance" },
          "allOf": [
            { "contains": { "const": "keyboard" } },
            { "contains": { "const": "list_table" } },
            { "contains": { "const": "screen_reader" } }
          ]
        },
        "follow_up_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "export_permalink": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "consumer_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "surface",
        "snapshot_id",
        "scope_id",
        "max_visibility",
        "preserves_source_labels",
        "carries_snapshot_ids",
        "consumer_ref",
        "note"
      ],
      "properties": {
        "binding_id": { "$ref": "#/$defs/non_empty_string" },
        "surface": { "$ref": "#/$defs/consumer_surface" },
        "snapshot_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_id": { "$ref": "#/$defs/non_empty_string" },
        "max_visibility": { "$ref": "#/$defs/visibility" },
        "preserves_source_labels": { "type": "boolean" },
        "carries_snapshot_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "consumer_ref": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_count",
        "citation_count",
        "follow_up_action_count",
        "consumer_binding_count",
        "surface_count",
        "curated_count",
        "imported_count",
        "generated_count",
        "public_count",
        "internal_count",
        "private_count",
        "export_safe_snapshot_count",
        "cited_snapshot_count",
        "accessible_snapshot_count",
        "file_citation_count",
        "symbol_citation_count",
        "doc_pack_citation_count",
        "adr_citation_count",
        "curated_note_citation_count",
        "graph_object_citation_count",
        "citation_ref_link_count",
        "follow_up_ref_link_count"
      ],
      "properties": {
        "snapshot_count": { "type": "integer", "minimum": 0 },
        "citation_count": { "type": "integer", "minimum": 0 },
        "follow_up_action_count": { "type": "integer", "minimum": 0 },
        "consumer_binding_count": { "type": "integer", "minimum": 0 },
        "surface_count": { "type": "integer", "minimum": 0 },
        "curated_count": { "type": "integer", "minimum": 0 },
        "imported_count": { "type": "integer", "minimum": 0 },
        "generated_count": { "type": "integer", "minimum": 0 },
        "public_count": { "type": "integer", "minimum": 0 },
        "internal_count": { "type": "integer", "minimum": 0 },
        "private_count": { "type": "integer", "minimum": 0 },
        "export_safe_snapshot_count": { "type": "integer", "minimum": 0 },
        "cited_snapshot_count": { "type": "integer", "minimum": 0 },
        "accessible_snapshot_count": { "type": "integer", "minimum": 0 },
        "file_citation_count": { "type": "integer", "minimum": 0 },
        "symbol_citation_count": { "type": "integer", "minimum": 0 },
        "doc_pack_citation_count": { "type": "integer", "minimum": 0 },
        "adr_citation_count": { "type": "integer", "minimum": 0 },
        "curated_note_citation_count": { "type": "integer", "minimum": 0 },
        "graph_object_citation_count": { "type": "integer", "minimum": 0 },
        "citation_ref_link_count": { "type": "integer", "minimum": 0 },
        "follow_up_ref_link_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
