{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/graph/m5-graph-governance.schema.json",
  "title": "Aureline M5 graph-governance matrix",
  "description": "Schema for the m5_graph_governance_matrix packet. The packet aggregates the stable-line graph-truth lanes into one qualification report, freezing one governance row per claimed M5 code-understanding depth lane (workset-scope, graph-topology, impact-query, ownership-source, architecture-explainer, graph-freshness, navigation-recall). Each row governs its lane against the canonical graph-truth packet it draws evidence from and records the owner, how much of the workspace the lane knows (full-workspace, workset, hot-set, unscoped), how fresh the graph is (fresh, lagging, stale, expired), how exact its relations are (exact, resolved, approximate, unresolved), and how its prose and edges are backed (curated, cited, generated, uncited); it surfaces the impact-result class (no-impact, in-scope-impact, out-of-scope, policy-limited) with hidden-result and out-of-scope counts so impact answers stay distinct, the supported scope or slice labels, caveats, stale or narrowing fields, stable topology node and edge identity namespaces, the source packet, a machine-readable governance receipt, and release-evidence, help-surface, docs-badge, and support-export refs so those surfaces ingest the same packet rather than parallel spreadsheets. A non-inheriting governance gate derives the depth claim that may be published: a workset, hot-set, or unscoped slice, a stale or expired graph, approximate or unresolved relations, or generated or uncited explanation cannot publish an authoritative claim, and the governance decision records whether the gate published, qualified to a slice, marked provisional, or withheld it. A lane never implies whole-workspace certainty over a slice, one row is required per claimed lane so no lane inherits an authoritative claim, and the recorded published claim, decision, and downgrade reasons must equal the recomputed gate decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "topology_identity_scheme",
    "lanes",
    "depth_claims",
    "scope_modes",
    "graph_freshness_states",
    "relation_fidelities",
    "evidence_backings",
    "impact_result_classes",
    "downgrade_paths",
    "downgrade_reasons",
    "governance_decisions",
    "lane_rows",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_graph_governance_matrix" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "topology_identity_scheme": { "$ref": "#/$defs/non_empty_string" },
    "lanes": { "type": "array", "items": { "$ref": "#/$defs/lane" } },
    "depth_claims": { "type": "array", "items": { "$ref": "#/$defs/depth_claim" } },
    "scope_modes": { "type": "array", "items": { "$ref": "#/$defs/scope_mode" } },
    "graph_freshness_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/graph_freshness" }
    },
    "relation_fidelities": {
      "type": "array",
      "items": { "$ref": "#/$defs/relation_fidelity" }
    },
    "evidence_backings": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_backing" }
    },
    "impact_result_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/impact_result_class" }
    },
    "downgrade_paths": { "type": "array", "items": { "$ref": "#/$defs/downgrade_path" } },
    "downgrade_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/downgrade_reason" }
    },
    "governance_decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/governance_decision" }
    },
    "lane_rows": { "type": "array", "items": { "$ref": "#/$defs/lane_row" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "lane": {
      "enum": [
        "workset_scope",
        "graph_topology",
        "impact_query",
        "ownership_source",
        "architecture_explainer",
        "graph_freshness",
        "navigation_recall"
      ]
    },
    "depth_claim": {
      "enum": ["authoritative", "scope_qualified", "provisional", "withheld"]
    },
    "scope_mode": {
      "enum": ["full_workspace", "workset", "hot_set", "unscoped"]
    },
    "graph_freshness": {
      "enum": ["fresh", "lagging", "stale", "expired"]
    },
    "relation_fidelity": {
      "enum": ["exact", "resolved", "approximate", "unresolved"]
    },
    "evidence_backing": {
      "enum": ["curated", "cited", "generated", "uncited"]
    },
    "impact_result_class": {
      "enum": ["no_impact", "in_scope_impact", "out_of_scope", "policy_limited"]
    },
    "downgrade_path": {
      "enum": [
        "widen_scope",
        "reindex",
        "resolve_relations",
        "cite_or_curate",
        "withhold_claim",
        "none"
      ]
    },
    "downgrade_reason": {
      "enum": [
        "scope_narrowed",
        "stale_graph",
        "approximate_relations",
        "uncited_explanation"
      ]
    },
    "governance_decision": {
      "enum": ["publish", "qualify_scope", "mark_provisional", "withhold"]
    },
    "lane_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_id",
        "lane",
        "owner",
        "scope_mode",
        "graph_freshness",
        "relation_fidelity",
        "evidence_backing",
        "impact_result_class",
        "hidden_result_count",
        "out_of_scope_count",
        "node_id_namespace",
        "edge_id_namespace",
        "declared_claim",
        "published_claim",
        "governance_decision",
        "downgrade_path",
        "packet_ref",
        "conformance_ref",
        "evidence_ref",
        "governance_receipt_ref",
        "release_evidence_ref",
        "help_surface_ref",
        "docs_badge_ref",
        "support_export_ref",
        "note"
      ],
      "properties": {
        "lane_id": { "$ref": "#/$defs/non_empty_string" },
        "lane": { "$ref": "#/$defs/lane" },
        "owner": { "$ref": "#/$defs/non_empty_string" },
        "scope_mode": { "$ref": "#/$defs/scope_mode" },
        "graph_freshness": { "$ref": "#/$defs/graph_freshness" },
        "relation_fidelity": { "$ref": "#/$defs/relation_fidelity" },
        "evidence_backing": { "$ref": "#/$defs/evidence_backing" },
        "impact_result_class": { "$ref": "#/$defs/impact_result_class" },
        "hidden_result_count": { "type": "integer", "minimum": 0 },
        "out_of_scope_count": { "type": "integer", "minimum": 0 },
        "node_id_namespace": { "$ref": "#/$defs/non_empty_string" },
        "edge_id_namespace": { "$ref": "#/$defs/non_empty_string" },
        "declared_claim": { "$ref": "#/$defs/depth_claim" },
        "published_claim": { "$ref": "#/$defs/depth_claim" },
        "governance_decision": { "$ref": "#/$defs/governance_decision" },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason" }
        },
        "downgrade_path": { "$ref": "#/$defs/downgrade_path" },
        "supported_scopes": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "caveats": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "stale_or_missing_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "conformance_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "governance_receipt_ref": { "$ref": "#/$defs/non_empty_string" },
        "release_evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "help_surface_ref": { "$ref": "#/$defs/non_empty_string" },
        "docs_badge_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_lanes",
        "lane_count",
        "authoritative_lanes",
        "scope_qualified_lanes",
        "provisional_lanes",
        "withheld_lanes",
        "publish_decisions",
        "qualify_scope_decisions",
        "mark_provisional_decisions",
        "withhold_decisions",
        "downgraded_lanes",
        "scope_sensitive_lanes",
        "stale_graph_lanes",
        "generated_explanation_lanes",
        "lanes_with_downgrade_reasons",
        "lanes_with_hidden_results",
        "lanes_with_out_of_scope_results"
      ],
      "properties": {
        "total_lanes": { "type": "integer", "minimum": 0 },
        "lane_count": { "type": "integer", "minimum": 0 },
        "authoritative_lanes": { "type": "integer", "minimum": 0 },
        "scope_qualified_lanes": { "type": "integer", "minimum": 0 },
        "provisional_lanes": { "type": "integer", "minimum": 0 },
        "withheld_lanes": { "type": "integer", "minimum": 0 },
        "publish_decisions": { "type": "integer", "minimum": 0 },
        "qualify_scope_decisions": { "type": "integer", "minimum": 0 },
        "mark_provisional_decisions": { "type": "integer", "minimum": 0 },
        "withhold_decisions": { "type": "integer", "minimum": 0 },
        "downgraded_lanes": { "type": "integer", "minimum": 0 },
        "scope_sensitive_lanes": { "type": "integer", "minimum": 0 },
        "stale_graph_lanes": { "type": "integer", "minimum": 0 },
        "generated_explanation_lanes": { "type": "integer", "minimum": 0 },
        "lanes_with_downgrade_reasons": { "type": "integer", "minimum": 0 },
        "lanes_with_hidden_results": { "type": "integer", "minimum": 0 },
        "lanes_with_out_of_scope_results": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
