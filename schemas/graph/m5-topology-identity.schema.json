{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/graph/m5-topology-identity.schema.json",
  "title": "Aureline M5 topology-identity packet",
  "description": "Schema for the m5_topology_identity_packet. The packet carries the stable topology node and edge identities every M5 code-understanding surface points at, so the same graph object survives canvas, list, table, breadcrumb, review, and support/export views without lossy translation. Each node identity records a stable node id, a kind, a label/path, namespace and workspace refs, freshness, confidence, a source class, contract badges, and an export-safe permalink that embeds the canonical id. Each edge identity adds a relation fidelity (exact, approximate, imported, partial, stale, or blocked); every non-exact edge must carry an explicit fidelity_reason so presentation never implies stronger certainty than the graph. One surface binding per surface resolves only ids declared in the packet, is stamped with the active scope snapshot, and never lets the canvas own an identity a non-canvas accessible view cannot resolve. The packet binds upstream to the canonical graph-depth governance matrix and the workset-scope packet it extends and exports release-evidence, help-surface, docs-badge, and support-export refs so those surfaces narrow from one packet. The summary counts must equal the recomputed counts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "governance_matrix_ref",
    "scope_packet_ref",
    "conformance_ref",
    "release_evidence_ref",
    "help_surface_ref",
    "docs_badge_ref",
    "support_export_ref",
    "node_kinds",
    "edge_kinds",
    "relation_fidelities",
    "source_classes",
    "surfaces",
    "contract_badges",
    "active_scope",
    "nodes",
    "edges",
    "surface_bindings",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_topology_identity_packet" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "governance_matrix_ref": { "const": "artifacts/graph/m5/m5-graph-governance.json" },
    "scope_packet_ref": { "const": "artifacts/graph/m5/m5-workset-scope.json" },
    "conformance_ref": { "$ref": "#/$defs/non_empty_string" },
    "release_evidence_ref": { "$ref": "#/$defs/non_empty_string" },
    "help_surface_ref": { "$ref": "#/$defs/non_empty_string" },
    "docs_badge_ref": { "$ref": "#/$defs/non_empty_string" },
    "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
    "node_kinds": { "type": "array", "items": { "$ref": "#/$defs/node_kind" } },
    "edge_kinds": { "type": "array", "items": { "$ref": "#/$defs/edge_kind" } },
    "relation_fidelities": {
      "type": "array",
      "items": { "$ref": "#/$defs/relation_fidelity" }
    },
    "source_classes": { "type": "array", "items": { "$ref": "#/$defs/source_class" } },
    "surfaces": { "type": "array", "items": { "$ref": "#/$defs/surface" } },
    "contract_badges": { "type": "array", "items": { "$ref": "#/$defs/contract_badge" } },
    "active_scope": { "$ref": "#/$defs/active_scope" },
    "nodes": { "type": "array", "items": { "$ref": "#/$defs/node" } },
    "edges": { "type": "array", "items": { "$ref": "#/$defs/edge" } },
    "surface_bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_binding" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "node_kind": {
      "enum": [
        "file",
        "directory",
        "symbol",
        "module",
        "doc",
        "ownership",
        "provider_resource",
        "workset_scope"
      ]
    },
    "edge_kind": {
      "enum": [
        "imports",
        "calls",
        "contains",
        "impacts",
        "owned_by",
        "references",
        "depends_on"
      ]
    },
    "relation_fidelity": {
      "enum": ["exact", "approximate", "imported", "partial", "stale", "blocked"]
    },
    "source_class": {
      "enum": ["indexed", "imported", "inferred", "provider", "annotation"]
    },
    "surface": {
      "enum": [
        "map_canvas",
        "list",
        "table",
        "breadcrumb",
        "explainer",
        "review",
        "support_export"
      ]
    },
    "contract_badge": {
      "enum": [
        "stable_identity",
        "export_safe_permalink",
        "scope_bound",
        "freshness_labeled",
        "confidence_labeled",
        "source_labeled"
      ]
    },
    "active_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_id", "scope_id", "taken_as_of", "scope_mode"],
      "properties": {
        "snapshot_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_id": { "$ref": "#/$defs/non_empty_string" },
        "taken_as_of": { "type": "string", "format": "date" },
        "scope_mode": { "enum": ["full", "sparse"] }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "kind",
        "display_label",
        "namespace_ref",
        "workspace_ref",
        "freshness",
        "confidence",
        "source_class",
        "contract_badges",
        "export_permalink"
      ],
      "properties": {
        "node_id": { "$ref": "#/$defs/non_empty_string" },
        "kind": { "$ref": "#/$defs/node_kind" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "namespace_ref": { "$ref": "#/$defs/non_empty_string" },
        "workspace_ref": { "$ref": "#/$defs/non_empty_string" },
        "freshness": { "$ref": "#/$defs/non_empty_string" },
        "confidence": { "$ref": "#/$defs/non_empty_string" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "contract_badges": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/contract_badge" }
        },
        "export_permalink": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_id",
        "kind",
        "from_node_id",
        "to_node_id",
        "relation_fidelity",
        "freshness",
        "confidence",
        "source_class",
        "contract_badges",
        "export_permalink"
      ],
      "properties": {
        "edge_id": { "$ref": "#/$defs/non_empty_string" },
        "kind": { "$ref": "#/$defs/edge_kind" },
        "from_node_id": { "$ref": "#/$defs/non_empty_string" },
        "to_node_id": { "$ref": "#/$defs/non_empty_string" },
        "relation_fidelity": { "$ref": "#/$defs/relation_fidelity" },
        "fidelity_reason": { "$ref": "#/$defs/non_empty_string" },
        "freshness": { "$ref": "#/$defs/non_empty_string" },
        "confidence": { "$ref": "#/$defs/non_empty_string" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "contract_badges": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/contract_badge" }
        },
        "export_permalink": { "$ref": "#/$defs/non_empty_string" }
      },
      "allOf": [
        {
          "comment": "A non-exact edge must carry an explicit fidelity_reason.",
          "if": {
            "properties": {
              "relation_fidelity": {
                "enum": ["approximate", "imported", "partial", "stale", "blocked"]
              }
            }
          },
          "then": { "required": ["fidelity_reason"] }
        }
      ]
    },
    "surface_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "surface",
        "is_canvas",
        "snapshot_id",
        "scope_id",
        "resolves_node_ids",
        "resolves_edge_ids",
        "consumer_ref",
        "note"
      ],
      "properties": {
        "binding_id": { "$ref": "#/$defs/non_empty_string" },
        "surface": { "$ref": "#/$defs/surface" },
        "is_canvas": { "type": "boolean" },
        "snapshot_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_id": { "$ref": "#/$defs/non_empty_string" },
        "resolves_node_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "resolves_edge_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "consumer_ref": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_count",
        "edge_count",
        "surface_binding_count",
        "surface_count",
        "canvas_surface_count",
        "non_canvas_surface_count",
        "exact_edge_count",
        "approximate_edge_count",
        "imported_edge_count",
        "partial_edge_count",
        "stale_edge_count",
        "blocked_edge_count",
        "labeled_nonexact_edge_count",
        "nodes_with_permalink",
        "edges_with_permalink"
      ],
      "properties": {
        "node_count": { "type": "integer", "minimum": 0 },
        "edge_count": { "type": "integer", "minimum": 0 },
        "surface_binding_count": { "type": "integer", "minimum": 0 },
        "surface_count": { "type": "integer", "minimum": 0 },
        "canvas_surface_count": { "type": "integer", "minimum": 0 },
        "non_canvas_surface_count": { "type": "integer", "minimum": 0 },
        "exact_edge_count": { "type": "integer", "minimum": 0 },
        "approximate_edge_count": { "type": "integer", "minimum": 0 },
        "imported_edge_count": { "type": "integer", "minimum": 0 },
        "partial_edge_count": { "type": "integer", "minimum": 0 },
        "stale_edge_count": { "type": "integer", "minimum": 0 },
        "blocked_edge_count": { "type": "integer", "minimum": 0 },
        "labeled_nonexact_edge_count": { "type": "integer", "minimum": 0 },
        "nodes_with_permalink": { "type": "integer", "minimum": 0 },
        "edges_with_permalink": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
