{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/graph/m5-impact-query.schema.json",
  "title": "Aureline M5 impact-query packet",
  "description": "Schema for the m5_impact_query_packet. The packet carries the honest answer a change-impact or architecture-explorer query returns, keeping no-impact distinct from unknown, out-of-scope, policy-limited, provider-unavailable, and stale-graph states. Each query result records the subject ids it reasons about, the affected objects it includes (in the shared topology identity space, each with a relation-fidelity evidence class), an included count, an out-of-scope count, a policy-hidden count, an evidence-class summary, freshness, confidence, a result class, an explicit empty-result reason, the remediation actions a narrowed answer offers, and an export-safe permalink that embeds the canonical query id. A non-in-scope result must carry an empty_reason; a no-impact result may not hide out-of-scope or policy-limited objects; an affected object with a non-exact evidence class must carry an evidence_reason. One consumer binding per surface (impact panel, refactor planning, review explanation, topology card, support export) carries the same answer beyond one panel render, is stamped with the active scope snapshot, and the support-export binding must carry every declared query. The packet binds upstream to the canonical graph-depth governance matrix, the workset-scope packet, and the topology-identity packet it reuses. The summary counts must equal the recomputed counts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "governance_matrix_ref",
    "scope_packet_ref",
    "topology_packet_ref",
    "conformance_ref",
    "release_evidence_ref",
    "help_surface_ref",
    "docs_badge_ref",
    "support_export_ref",
    "result_classes",
    "evidence_classes",
    "remediation_actions",
    "consumer_surfaces",
    "active_scope",
    "queries",
    "consumer_bindings",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_impact_query_packet" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "governance_matrix_ref": { "const": "artifacts/graph/m5/m5-graph-governance.json" },
    "scope_packet_ref": { "const": "artifacts/graph/m5/m5-workset-scope.json" },
    "topology_packet_ref": { "const": "artifacts/graph/m5/m5-topology-identity.json" },
    "conformance_ref": { "$ref": "#/$defs/non_empty_string" },
    "release_evidence_ref": { "$ref": "#/$defs/non_empty_string" },
    "help_surface_ref": { "$ref": "#/$defs/non_empty_string" },
    "docs_badge_ref": { "$ref": "#/$defs/non_empty_string" },
    "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
    "result_classes": { "type": "array", "items": { "$ref": "#/$defs/result_class" } },
    "evidence_classes": { "type": "array", "items": { "$ref": "#/$defs/evidence_class" } },
    "remediation_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/remediation_action" }
    },
    "consumer_surfaces": { "type": "array", "items": { "$ref": "#/$defs/consumer_surface" } },
    "active_scope": { "$ref": "#/$defs/active_scope" },
    "queries": { "type": "array", "items": { "$ref": "#/$defs/query" } },
    "consumer_bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/consumer_binding" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "result_class": {
      "enum": [
        "in_scope_impact",
        "no_impact",
        "unknown",
        "out_of_scope",
        "policy_limited",
        "provider_unavailable",
        "stale_graph"
      ]
    },
    "evidence_class": {
      "enum": ["exact", "approximate", "imported", "partial", "stale", "blocked"]
    },
    "remediation_action": {
      "enum": [
        "widen_scope",
        "refresh_index",
        "connect_provider",
        "request_policy_access",
        "resolve_relations",
        "none"
      ]
    },
    "consumer_surface": {
      "enum": [
        "impact_panel",
        "refactor_planning",
        "review_explanation",
        "topology_card",
        "support_export"
      ]
    },
    "node_kind": {
      "enum": [
        "file",
        "directory",
        "symbol",
        "module",
        "doc",
        "ownership",
        "provider_resource",
        "workset_scope"
      ]
    },
    "active_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_id", "scope_id", "taken_as_of", "scope_mode"],
      "properties": {
        "snapshot_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_id": { "$ref": "#/$defs/non_empty_string" },
        "taken_as_of": { "type": "string", "format": "date" },
        "scope_mode": { "enum": ["full", "sparse"] }
      }
    },
    "affected_object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "kind",
        "display_label",
        "evidence_class",
        "freshness",
        "confidence",
        "export_permalink"
      ],
      "properties": {
        "node_id": { "$ref": "#/$defs/non_empty_string" },
        "kind": { "$ref": "#/$defs/node_kind" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "evidence_class": { "$ref": "#/$defs/evidence_class" },
        "evidence_reason": { "$ref": "#/$defs/non_empty_string" },
        "freshness": { "$ref": "#/$defs/non_empty_string" },
        "confidence": { "$ref": "#/$defs/non_empty_string" },
        "export_permalink": { "$ref": "#/$defs/non_empty_string" }
      },
      "allOf": [
        {
          "comment": "A non-exact affected object must carry an explicit evidence_reason.",
          "if": {
            "properties": {
              "evidence_class": {
                "enum": ["approximate", "imported", "partial", "stale", "blocked"]
              }
            }
          },
          "then": { "required": ["evidence_reason"] }
        }
      ]
    },
    "evidence_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exact", "approximate", "imported", "partial", "stale", "blocked"],
      "properties": {
        "exact": { "type": "integer", "minimum": 0 },
        "approximate": { "type": "integer", "minimum": 0 },
        "imported": { "type": "integer", "minimum": 0 },
        "partial": { "type": "integer", "minimum": 0 },
        "stale": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 }
      }
    },
    "query": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query_id",
        "subject_ids",
        "subject_kind",
        "query_label",
        "result_class",
        "included_objects",
        "included_count",
        "out_of_scope_count",
        "hidden_count",
        "freshness",
        "confidence",
        "evidence_summary",
        "remediation_actions",
        "export_permalink"
      ],
      "properties": {
        "query_id": { "$ref": "#/$defs/non_empty_string" },
        "subject_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "subject_kind": { "$ref": "#/$defs/node_kind" },
        "query_label": { "$ref": "#/$defs/non_empty_string" },
        "result_class": { "$ref": "#/$defs/result_class" },
        "included_objects": {
          "type": "array",
          "items": { "$ref": "#/$defs/affected_object" }
        },
        "included_count": { "type": "integer", "minimum": 0 },
        "out_of_scope_count": { "type": "integer", "minimum": 0 },
        "hidden_count": { "type": "integer", "minimum": 0 },
        "freshness": { "$ref": "#/$defs/non_empty_string" },
        "confidence": { "$ref": "#/$defs/non_empty_string" },
        "evidence_summary": { "$ref": "#/$defs/evidence_summary" },
        "empty_reason": { "$ref": "#/$defs/non_empty_string" },
        "remediation_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/remediation_action" }
        },
        "export_permalink": { "$ref": "#/$defs/non_empty_string" }
      },
      "allOf": [
        {
          "comment": "Every non-in-scope result must carry an explicit empty_reason.",
          "if": {
            "properties": {
              "result_class": {
                "enum": [
                  "no_impact",
                  "unknown",
                  "out_of_scope",
                  "policy_limited",
                  "provider_unavailable",
                  "stale_graph"
                ]
              }
            }
          },
          "then": { "required": ["empty_reason"] }
        }
      ]
    },
    "consumer_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "surface",
        "snapshot_id",
        "scope_id",
        "carries_query_ids",
        "consumer_ref",
        "note"
      ],
      "properties": {
        "binding_id": { "$ref": "#/$defs/non_empty_string" },
        "surface": { "$ref": "#/$defs/consumer_surface" },
        "snapshot_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_id": { "$ref": "#/$defs/non_empty_string" },
        "carries_query_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "consumer_ref": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query_count",
        "consumer_binding_count",
        "surface_count",
        "in_scope_impact_count",
        "no_impact_count",
        "unknown_count",
        "out_of_scope_query_count",
        "policy_limited_count",
        "provider_unavailable_count",
        "stale_graph_count",
        "total_included_objects",
        "total_out_of_scope_objects",
        "total_hidden_objects",
        "queries_with_remediation",
        "queries_with_empty_reason"
      ],
      "properties": {
        "query_count": { "type": "integer", "minimum": 0 },
        "consumer_binding_count": { "type": "integer", "minimum": 0 },
        "surface_count": { "type": "integer", "minimum": 0 },
        "in_scope_impact_count": { "type": "integer", "minimum": 0 },
        "no_impact_count": { "type": "integer", "minimum": 0 },
        "unknown_count": { "type": "integer", "minimum": 0 },
        "out_of_scope_query_count": { "type": "integer", "minimum": 0 },
        "policy_limited_count": { "type": "integer", "minimum": 0 },
        "provider_unavailable_count": { "type": "integer", "minimum": 0 },
        "stale_graph_count": { "type": "integer", "minimum": 0 },
        "total_included_objects": { "type": "integer", "minimum": 0 },
        "total_out_of_scope_objects": { "type": "integer", "minimum": 0 },
        "total_hidden_objects": { "type": "integer", "minimum": 0 },
        "queries_with_remediation": { "type": "integer", "minimum": 0 },
        "queries_with_empty_reason": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
