{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/graph/semantic-workspace-graph.schema.json",
  "title": "Aureline stable semantic workspace graph contract packet",
  "description": "Stable boundary schema for the semantic workspace graph object model, query-family contract, invalidation events, consumer bindings, topology reuse proof, and support reconstruction packet.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workspace_id",
    "generated_at",
    "stable_query_families",
    "objects",
    "query_handles",
    "invalidation_events",
    "consumer_action_bindings",
    "topology_reuse",
    "support_reconstruction",
    "promotion_state"
  ],
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "semantic_graph_object_model_and_query_contract_packet"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "stable_query_families": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "$ref": "#/$defs/stable_query_family"
      },
      "uniqueItems": true
    },
    "objects": {
      "type": "array",
      "minItems": 6,
      "items": {
        "$ref": "#/$defs/stable_graph_object"
      }
    },
    "query_handles": {
      "type": "array",
      "minItems": 7,
      "items": {
        "$ref": "#/$defs/query_handle"
      }
    },
    "promotion_state": {
      "type": "string",
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    }
  },
  "$defs": {
    "stable_query_family": {
      "type": "string",
      "enum": [
        "lookup",
        "neighborhood",
        "explain-why",
        "impact",
        "ownership",
        "diff-between-snapshots",
        "path-to-evidence"
      ]
    },
    "object_kind": {
      "type": "string",
      "enum": [
        "workspace_root_workset",
        "file_document",
        "symbol_api",
        "relationship_edge",
        "docs_knowledge",
        "operational_artifact"
      ]
    },
    "freshness_state": {
      "type": "string",
      "enum": [
        "live",
        "stale",
        "warming",
        "partial_scope",
        "cached",
        "provider_unavailable"
      ]
    },
    "confidence_tier": {
      "type": "string",
      "enum": [
        "immediate_lexical",
        "structural",
        "semantic",
        "verified_runtime",
        "user_curated",
        "inferred",
        "withheld"
      ]
    },
    "visibility_scope": {
      "type": "string",
      "enum": [
        "current_root",
        "selected_workset",
        "full_workspace",
        "remote_cache",
        "outside_current_scope",
        "policy_limited"
      ]
    },
    "retention_class": {
      "type": "string",
      "enum": [
        "durable_workspace",
        "session_scoped",
        "exportable_snapshot",
        "managed_replica",
        "ephemeral_projection",
        "withheld"
      ]
    },
    "producer_identity": {
      "type": "object",
      "required": ["producer_id", "producer_kind", "producer_version"],
      "properties": {
        "producer_id": { "type": "string", "minLength": 1 },
        "producer_kind": { "type": "string", "minLength": 1 },
        "producer_version": { "type": "string", "minLength": 1 }
      }
    },
    "stable_graph_object": {
      "type": "object",
      "required": [
        "object_id",
        "object_kind",
        "schema_version",
        "producer",
        "freshness_timestamp",
        "freshness",
        "confidence",
        "visibility_scope",
        "retention_class",
        "provenance_refs",
        "evidence_refs"
      ],
      "properties": {
        "object_id": { "type": "string", "minLength": 1 },
        "object_kind": { "$ref": "#/$defs/object_kind" },
        "schema_version": { "type": "integer", "minimum": 1 },
        "producer": { "$ref": "#/$defs/producer_identity" },
        "freshness_timestamp": { "type": "string", "minLength": 1 },
        "freshness": { "$ref": "#/$defs/freshness_state" },
        "confidence": { "$ref": "#/$defs/confidence_tier" },
        "visibility_scope": { "$ref": "#/$defs/visibility_scope" },
        "retention_class": { "$ref": "#/$defs/retention_class" },
        "provenance_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "source_object_id": { "type": "string" },
        "target_object_id": { "type": "string" },
        "visible_truth_label": { "type": "string" }
      }
    },
    "query_handle": {
      "type": "object",
      "required": [
        "query_handle_id",
        "query_family",
        "scope_ref",
        "snapshot_epoch",
        "delta_sequence",
        "producer",
        "freshness",
        "confidence",
        "object_refs",
        "evidence_refs"
      ],
      "properties": {
        "query_handle_id": { "type": "string", "minLength": 1 },
        "query_family": { "$ref": "#/$defs/stable_query_family" },
        "scope_ref": { "type": "string", "minLength": 1 },
        "snapshot_epoch": { "type": "string", "minLength": 1 },
        "delta_sequence": { "type": "integer" },
        "producer": { "$ref": "#/$defs/producer_identity" },
        "freshness": { "$ref": "#/$defs/freshness_state" },
        "confidence": { "$ref": "#/$defs/confidence_tier" },
        "object_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "visible_truth_label": { "type": "string" }
      }
    }
  }
}
