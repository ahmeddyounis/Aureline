{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/graph/m5-workset-scope.schema.json",
  "title": "Aureline M5 workset-scope descriptor packet",
  "description": "Schema for the m5_workset_scope_packet. The packet carries the single active workset-scope snapshot every M5 code-understanding surface binds to so slice boundaries stay visible and durable. It records one active snapshot (a stable snapshot id, an as-of date, and the canonical workset-scope descriptor it bounds: scope id, scope class, included roots or repos, full/sparse mode, local/managed source, index coverage, and hidden-result count), the explicit and suggested scope-change actions that widen or narrow the slice, and one consumer binding per M5 code-understanding surface (docs recall, topology view, architecture explainer, review explanation, onboarding tour, AI context assembly). A widen action and any suggestion must be reviewable so a graph-backed feature never silently broadens past the active slice; a binding may only claim whole-workspace knowledge when the active descriptor is full; and every binding is stamped with the active snapshot id and scope id so support export and replay can reconstruct the slice the user queried. The packet binds upstream to the canonical graph-depth governance matrix and scope-provenance truth packet it extends and exports release-evidence, help-surface, docs-badge, and support-export refs so those surfaces narrow from one packet. The summary counts must equal the recomputed counts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "governance_matrix_ref",
    "source_packet_ref",
    "conformance_ref",
    "release_evidence_ref",
    "help_surface_ref",
    "docs_badge_ref",
    "support_export_ref",
    "consumer_surfaces",
    "scope_modes",
    "scope_sources",
    "change_directions",
    "change_actuations",
    "active_snapshot",
    "scope_change_actions",
    "consumer_bindings",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_workset_scope_packet" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "governance_matrix_ref": { "const": "artifacts/graph/m5/m5-graph-governance.json" },
    "source_packet_ref": {
      "const": "artifacts/search/m4/scope_provenance_truth_packet.json"
    },
    "conformance_ref": { "$ref": "#/$defs/non_empty_string" },
    "release_evidence_ref": { "$ref": "#/$defs/non_empty_string" },
    "help_surface_ref": { "$ref": "#/$defs/non_empty_string" },
    "docs_badge_ref": { "$ref": "#/$defs/non_empty_string" },
    "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
    "consumer_surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/consumer_surface" }
    },
    "scope_modes": { "type": "array", "items": { "$ref": "#/$defs/scope_mode" } },
    "scope_sources": { "type": "array", "items": { "$ref": "#/$defs/scope_source" } },
    "change_directions": {
      "type": "array",
      "items": { "$ref": "#/$defs/change_direction" }
    },
    "change_actuations": {
      "type": "array",
      "items": { "$ref": "#/$defs/change_actuation" }
    },
    "active_snapshot": { "$ref": "#/$defs/snapshot" },
    "scope_change_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/scope_change_action" }
    },
    "consumer_bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/consumer_binding" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "consumer_surface": {
      "enum": [
        "docs_recall",
        "topology_view",
        "architecture_explainer",
        "review_explanation",
        "onboarding_tour",
        "ai_context_assembly"
      ]
    },
    "scope_mode": { "enum": ["full", "sparse"] },
    "scope_source": { "enum": ["local", "managed"] },
    "change_direction": { "enum": ["widen", "narrow"] },
    "change_actuation": { "enum": ["explicit", "suggested"] },
    "index_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "covered_node_count",
        "covered_edge_count",
        "not_loaded_count",
        "coverage_state"
      ],
      "properties": {
        "covered_node_count": { "type": "integer", "minimum": 0 },
        "covered_edge_count": { "type": "integer", "minimum": 0 },
        "not_loaded_count": { "type": "integer", "minimum": 0 },
        "coverage_state": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_id",
        "scope_class",
        "included_roots_or_repos",
        "scope_mode",
        "hidden_result_count",
        "index_coverage",
        "scope_source"
      ],
      "properties": {
        "scope_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_class": { "$ref": "#/$defs/non_empty_string" },
        "included_roots_or_repos": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "scope_mode": { "$ref": "#/$defs/scope_mode" },
        "hidden_result_count": { "type": "integer", "minimum": 0 },
        "index_coverage": { "$ref": "#/$defs/index_coverage" },
        "scope_source": { "$ref": "#/$defs/scope_source" }
      }
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_id", "taken_as_of", "descriptor"],
      "properties": {
        "snapshot_id": { "$ref": "#/$defs/non_empty_string" },
        "taken_as_of": { "type": "string", "format": "date" },
        "descriptor": { "$ref": "#/$defs/descriptor" }
      }
    },
    "scope_change_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "direction",
        "actuation",
        "target_scope_id",
        "requires_review",
        "summary"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "direction": { "$ref": "#/$defs/change_direction" },
        "actuation": { "$ref": "#/$defs/change_actuation" },
        "target_scope_id": { "$ref": "#/$defs/non_empty_string" },
        "requires_review": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "consumer_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "surface",
        "snapshot_id",
        "scope_id",
        "implies_full_workspace",
        "consumer_ref",
        "note"
      ],
      "properties": {
        "binding_id": { "$ref": "#/$defs/non_empty_string" },
        "surface": { "$ref": "#/$defs/consumer_surface" },
        "snapshot_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_id": { "$ref": "#/$defs/non_empty_string" },
        "implies_full_workspace": { "type": "boolean" },
        "consumer_ref": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_bindings",
        "surface_count",
        "total_actions",
        "widen_actions",
        "narrow_actions",
        "explicit_actions",
        "suggested_actions",
        "reviewable_actions",
        "bindings_implying_full_workspace",
        "active_scope_is_sparse",
        "hidden_result_count",
        "not_loaded_count"
      ],
      "properties": {
        "total_bindings": { "type": "integer", "minimum": 0 },
        "surface_count": { "type": "integer", "minimum": 0 },
        "total_actions": { "type": "integer", "minimum": 0 },
        "widen_actions": { "type": "integer", "minimum": 0 },
        "narrow_actions": { "type": "integer", "minimum": 0 },
        "explicit_actions": { "type": "integer", "minimum": 0 },
        "suggested_actions": { "type": "integer", "minimum": 0 },
        "reviewable_actions": { "type": "integer", "minimum": 0 },
        "bindings_implying_full_workspace": { "type": "integer", "minimum": 0 },
        "active_scope_is_sparse": { "type": "boolean" },
        "hidden_result_count": { "type": "integer", "minimum": 0 },
        "not_loaded_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
