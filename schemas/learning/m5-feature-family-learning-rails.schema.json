{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/learning/m5-feature-family-learning-rails.schema.json",
  "title": "Aureline M5 feature-family learning rails",
  "description": "Boundary schema for the M5 feature-family learning manifest. For each claimed M5 depth family — notebook, request_workspace, database_workspace, profiler_trace, docs_browser, preview, template_scaffold, companion, sync_offboarding — one learning bundle binds the family's glossary pack, guided tour package, contextual help cards, optional exercise rail, and progress snapshot (each a guided-learning qualification record from schemas/learning/guided-learning-contracts.schema.json) together with an explicit offline/mirror parity posture and an in-product-command-backed guarantee. The bundle verdict is the strictest verdict across its members folded with the mirror-parity and command-backed guardrails; the manifest carries the narrowest overall verdict so one under-qualified family narrows the published M5 learnability posture rather than inheriting an adjacent green row. Raw pack bodies, raw URLs, raw absolute paths, and raw credential material MUST NOT appear; the schema carries opaque ids, typed vocabulary, and short privacy-safe labels only. Adding a new record_kind or family is additive-minor; repurposing an existing value is breaking.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/contextual_help_card_record" },
    { "$ref": "#/$defs/m5_family_learning_bundle_record" },
    { "$ref": "#/$defs/m5_feature_family_learning_manifest_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for M5 feature-family learning records. Current value is 1. Bumped only on breaking payload changes."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable identifier. Raw URLs, raw absolute paths, and raw secret material MUST NOT appear."
    },
    "opaque_id_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_id" }
    },
    "qualification_verdict": {
      "type": "string",
      "enum": ["qualified_stable", "narrowed_preview", "narrowed_beta", "absent"],
      "description": "Derived lifecycle verdict for a learnability surface or bundle."
    },
    "explain_apply_class": {
      "type": "string",
      "enum": ["fully_separated", "apply_requires_approval", "read_only", "conflated"]
    },
    "m5_learning_surface_family": {
      "type": "string",
      "enum": [
        "notebook",
        "request_workspace",
        "database_workspace",
        "profiler_trace",
        "docs_browser",
        "preview",
        "template_scaffold",
        "companion",
        "sync_offboarding"
      ],
      "description": "One M5 depth feature family that exposes learnability assets."
    },
    "mirror_parity_posture": {
      "type": "object",
      "description": "Offline and mirror-aware availability posture. Local-only, air-gapped, and mirrored profiles must surface learning state with an explicit freshness label instead of silently dead-linking.",
      "required": [
        "available_offline",
        "available_on_mirror",
        "freshness_label",
        "explicit_freshness_disclosed",
        "silent_dead_link_on_stale"
      ],
      "additionalProperties": false,
      "properties": {
        "available_offline": { "type": "boolean" },
        "available_on_mirror": { "type": "boolean" },
        "freshness_label": {
          "type": "string",
          "enum": [
            "live_authoritative",
            "cached_disclosed",
            "mirror_synced_disclosed",
            "local_only_disclosed",
            "stale_disclosed"
          ]
        },
        "explicit_freshness_disclosed": { "type": "boolean" },
        "silent_dead_link_on_stale": {
          "type": "boolean",
          "const": false,
          "description": "A learning bundle MUST NOT show a silent dead link when stale or offline."
        },
        "narrowing_reason": { "type": ["string", "null"] }
      }
    },
    "guided_learning_record": {
      "type": "object",
      "description": "A guided-learning qualification record (glossary pack, tour package, exercise rail, or progress snapshot) defined by schemas/learning/guided-learning-contracts.schema.json. Validated structurally here; the authoritative shape lives in that schema.",
      "required": ["record_kind", "schema_version", "record_id", "verdict"],
      "properties": {
        "record_kind": { "type": "string" },
        "schema_version": { "type": "integer" },
        "record_id": { "$ref": "#/$defs/opaque_id" },
        "verdict": { "$ref": "#/$defs/qualification_verdict" }
      }
    },
    "contextual_help_card_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "record_id",
        "generated_at",
        "family",
        "card_ref",
        "lifecycle_label",
        "citation",
        "offline",
        "explain_apply_class",
        "accessibility",
        "command_backed",
        "verdict"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "contextual_help_card_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "record_id": { "$ref": "#/$defs/opaque_id" },
        "generated_at": { "type": "string" },
        "family": { "$ref": "#/$defs/m5_learning_surface_family" },
        "card_ref": { "$ref": "#/$defs/opaque_id" },
        "lifecycle_label": { "type": "string" },
        "citation": { "type": "object" },
        "offline": { "type": "object" },
        "explain_apply_class": { "$ref": "#/$defs/explain_apply_class" },
        "accessibility": { "type": "object" },
        "command_backed": {
          "type": "boolean",
          "description": "Every actionable affordance on the card reuses a real command id rather than a tutorial-only shortcut."
        },
        "verdict": { "$ref": "#/$defs/qualification_verdict" },
        "narrowing_reasons": { "type": "array", "items": { "type": "string" } },
        "evidence_fixture_refs": { "$ref": "#/$defs/opaque_id_array" }
      }
    },
    "m5_family_learning_bundle_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "family",
        "claimed",
        "in_product_command_backed_path",
        "glossary_pack",
        "tour_package",
        "progress_snapshot",
        "mirror_parity",
        "verdict"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": { "type": "string", "const": "m5_family_learning_bundle_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "family": { "$ref": "#/$defs/m5_learning_surface_family" },
        "claimed": { "type": "boolean" },
        "in_product_command_backed_path": {
          "type": "boolean",
          "description": "Whether the family exposes an in-product, command-backed learning path (not AI-chat- or browser-handoff-only)."
        },
        "glossary_pack": { "$ref": "#/$defs/guided_learning_record" },
        "tour_package": { "$ref": "#/$defs/guided_learning_record" },
        "contextual_help_cards": {
          "type": "array",
          "items": { "$ref": "#/$defs/contextual_help_card_record" }
        },
        "exercise_rail": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/guided_learning_record" }]
        },
        "progress_snapshot": { "$ref": "#/$defs/guided_learning_record" },
        "mirror_parity": { "$ref": "#/$defs/mirror_parity_posture" },
        "verdict": { "$ref": "#/$defs/qualification_verdict" },
        "narrowing_reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "m5_feature_family_learning_manifest_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "manifest_id",
        "generated_at",
        "contract_refs",
        "family_bundles",
        "overall_verdict"
      ],
      "additionalProperties": false,
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "m5_feature_family_learning_manifest_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "manifest_id": { "$ref": "#/$defs/opaque_id" },
        "generated_at": { "type": "string" },
        "contract_refs": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "family_bundles": {
          "type": "array",
          "items": { "$ref": "#/$defs/m5_family_learning_bundle_record" }
        },
        "overall_verdict": { "$ref": "#/$defs/qualification_verdict" },
        "overall_narrowing_reasons": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
