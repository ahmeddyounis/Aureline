{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/state_root_certification_lineage.schema.json",
  "title": "Aureline state-root certification lineage",
  "description": "Boundary schema for the governed, export-safe state-root certification lineage record. The record certifies the storage-discipline surfaces, cache-governance inspector, and state-root audit views Aureline ships on a claimed stable profile. It is projected verbatim from the live StateRootCertificationInputs envelope. It proves resource-class coverage, audit-surface coverage, storage-class taxonomy / audit-finding honesty, restore-provenance / encoding / trust-state / lineage-ref preservation, no-silent-rerun honesty, audit-transaction-id and finding-code pinning, audit-surface reachability / disclosure honesty, support-export honesty, claimed-profile honesty, and pre-action inspection-hook honesty. Raw payload bytes are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "state_root_certification_lineage_schema_version",
    "schema_ref",
    "posture_id",
    "workspace_ref",
    "corpus_ref",
    "claimed_profile",
    "producer_attribution",
    "resource_class_coverage",
    "audit_surface_coverage",
    "audit_honesty",
    "preservation",
    "no_silent_rerun",
    "audit_transaction_pinning",
    "audit_surface_reachability",
    "support_export_honesty",
    "inspection_hooks",
    "stable_qualification",
    "raw_payload_excluded",
    "summary"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": { "const": "state_root_certification_lineage_record" },
    "state_root_certification_lineage_schema_version": { "type": "integer", "const": 1 },
    "schema_ref": { "const": "schemas/workspace/state_root_certification_lineage.schema.json" },
    "posture_id": { "$ref": "#/$defs/non_empty_string" },
    "workspace_ref": { "$ref": "#/$defs/non_empty_string" },
    "corpus_ref": { "$ref": "#/$defs/non_empty_string" },
    "claimed_profile": { "$ref": "#/$defs/claimed_stable_profile" },
    "producer_attribution": { "$ref": "#/$defs/producer_attribution_summary" },
    "resource_class_coverage": { "$ref": "#/$defs/resource_class_coverage_summary" },
    "audit_surface_coverage": { "$ref": "#/$defs/audit_surface_coverage_summary" },
    "audit_honesty": { "$ref": "#/$defs/audit_honesty_summary" },
    "preservation": { "$ref": "#/$defs/preservation_summary" },
    "no_silent_rerun": { "$ref": "#/$defs/no_silent_rerun_summary" },
    "audit_transaction_pinning": { "$ref": "#/$defs/audit_transaction_pinning_summary" },
    "audit_surface_reachability": { "$ref": "#/$defs/audit_surface_reachability_summary" },
    "support_export_honesty": { "$ref": "#/$defs/support_export_honesty_summary" },
    "inspection_hooks": {
      "type": "array",
      "items": { "$ref": "#/$defs/inspection_hook" }
    },
    "stable_qualification": { "$ref": "#/$defs/stable_qualification" },
    "raw_payload_excluded": { "const": true },
    "summary": { "type": "string", "minLength": 1, "maxLength": 700 }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "state_root_resource_kind": {
      "type": "string",
      "enum": [
        "persistent_state_envelope",
        "workspace_state_root",
        "profile_root",
        "recent_work_root",
        "local_history_root",
        "restore_checkpoint_root",
        "cache_governance_root",
        "prebuild_cache_root",
        "mutation_journal_root"
      ]
    },
    "audit_surface_kind": {
      "type": "string",
      "enum": [
        "storage_discipline_overview",
        "cache_governance_inspector",
        "state_root_audit_panel",
        "cleanup_inventory_audit",
        "eviction_rule_audit",
        "headless_audit_cli",
        "support_export_audit_section"
      ]
    },
    "audit_finding_class": {
      "type": "string",
      "enum": [
        "audit_clean",
        "audit_clean_with_disclosure",
        "audit_dirty_with_disclosure",
        "audit_inconclusive_held",
        "audit_refused_unsafe"
      ]
    },
    "audit_rerun_posture": {
      "type": "string",
      "enum": [
        "explicit_user_action_required",
        "terminal_no_further_run",
        "silent_rerun_permitted"
      ]
    },
    "audit_redaction_class": {
      "type": "string",
      "enum": [
        "metadata_only",
        "redacted_with_disclosure",
        "excluded_by_policy"
      ]
    },
    "claimed_stable_profile": {
      "type": "string",
      "enum": [
        "stable_default",
        "stable_support_export",
        "stable_restricted_mode",
        "narrowed_below_stable"
      ]
    },
    "support_export_posture": {
      "type": "string",
      "enum": ["metadata_safe_export", "held_record"]
    },
    "inspection_hook_class": {
      "type": "string",
      "enum": [
        "inspect_state_root",
        "compare_before_cleanup",
        "preview_cleanup",
        "preview_repair",
        "rollback_cleanup",
        "rollback_repair",
        "export_before_cleanup",
        "export_before_repair"
      ]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "corpus_empty",
        "required_resource_class_missing",
        "required_audit_surface_missing",
        "storage_class_ref_missing",
        "audit_disclosure_missing",
        "redaction_disclosure_missing",
        "cleanup_precondition_missing",
        "rerun_silent_forbidden",
        "commit_action_metadata_missing",
        "restore_provenance_not_preserved",
        "encoding_fidelity_not_preserved",
        "trust_state_not_preserved",
        "lineage_refs_not_preserved",
        "audit_transaction_id_not_pinned",
        "finding_code_missing",
        "audit_surface_unreachable",
        "audit_surface_disclosure_gap",
        "inspection_hook_unavailable",
        "support_export_fields_dropped",
        "support_export_redaction_unsafe",
        "claimed_profile_not_stable",
        "producer_attribution_incomplete",
        "lineage_export_unsafe"
      ]
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qualified", "level", "narrow_reasons"],
      "properties": {
        "qualified": { "type": "boolean" },
        "level": { "type": "string", "enum": ["stable", "narrowed_below_stable"] },
        "narrow_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason" }
        }
      }
    },
    "producer_attribution_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_ref",
        "schema_version",
        "integrity_hash",
        "captured_at",
        "producer_attribution_complete"
      ],
      "properties": {
        "producer_ref": { "type": "string" },
        "schema_version": { "type": "integer", "const": 1 },
        "integrity_hash": { "type": "string" },
        "captured_at": { "type": "string" },
        "producer_attribution_complete": { "type": "boolean" }
      }
    },
    "resource_audit_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resource_id",
        "resource_class",
        "resource_ref",
        "storage_class_ref",
        "audit_finding",
        "audit_transaction_id",
        "finding_code",
        "preserves_restore_provenance",
        "preserves_encoding_fidelity",
        "preserves_trust_state",
        "preserves_lineage_refs",
        "rerun_posture",
        "mutates_state",
        "commit_action_id",
        "commit_disclosure_id",
        "cleanup_surface_refs",
        "inspection_hook_refs",
        "redaction_class",
        "support_export_posture",
        "is_required"
      ],
      "properties": {
        "resource_id": { "$ref": "#/$defs/non_empty_string" },
        "resource_class": { "$ref": "#/$defs/state_root_resource_kind" },
        "resource_ref": { "$ref": "#/$defs/non_empty_string" },
        "storage_class_ref": { "type": "string" },
        "audit_finding": { "$ref": "#/$defs/audit_finding_class" },
        "audit_disclosure_ref": { "type": ["string", "null"] },
        "audit_transaction_id": { "type": "string" },
        "finding_code": { "type": "string" },
        "preserves_restore_provenance": { "type": "boolean" },
        "preserves_encoding_fidelity": { "type": "boolean" },
        "preserves_trust_state": { "type": "boolean" },
        "preserves_lineage_refs": { "type": "boolean" },
        "rerun_posture": { "$ref": "#/$defs/audit_rerun_posture" },
        "mutates_state": { "type": "boolean" },
        "commit_action_id": { "type": "string" },
        "commit_disclosure_id": { "type": "string" },
        "cleanup_surface_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inspection_hook_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "redaction_class": { "$ref": "#/$defs/audit_redaction_class" },
        "redaction_disclosure_ref": { "type": ["string", "null"] },
        "support_export_posture": { "$ref": "#/$defs/support_export_posture" },
        "is_required": { "type": "boolean" }
      }
    },
    "audit_surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audit_surface_id",
        "label",
        "audit_surface_kind",
        "reachable",
        "preserves_lineage_refs",
        "preserves_trust_state",
        "discloses_non_clean_findings",
        "is_required"
      ],
      "properties": {
        "audit_surface_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "type": "string" },
        "audit_surface_kind": { "$ref": "#/$defs/audit_surface_kind" },
        "reachable": { "type": "boolean" },
        "preserves_lineage_refs": { "type": "boolean" },
        "preserves_trust_state": { "type": "boolean" },
        "discloses_non_clean_findings": { "type": "boolean" },
        "is_required": { "type": "boolean" }
      }
    },
    "resource_class_coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resource_audit_rows", "all_required_resource_classes_present"],
      "properties": {
        "resource_audit_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/resource_audit_row" }
        },
        "all_required_resource_classes_present": { "type": "boolean" }
      }
    },
    "audit_surface_coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["audit_surface_rows", "all_required_audit_surfaces_present"],
      "properties": {
        "audit_surface_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/audit_surface_row" }
        },
        "all_required_audit_surfaces_present": { "type": "boolean" }
      }
    },
    "audit_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_rows_pin_storage_class_ref",
        "all_audit_disclosures_present",
        "all_redaction_disclosures_present",
        "all_dirty_rows_have_cleanup_precondition"
      ],
      "properties": {
        "all_rows_pin_storage_class_ref": { "type": "boolean" },
        "all_audit_disclosures_present": { "type": "boolean" },
        "all_redaction_disclosures_present": { "type": "boolean" },
        "all_dirty_rows_have_cleanup_precondition": { "type": "boolean" }
      }
    },
    "preservation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_rows_preserve_restore_provenance",
        "all_rows_preserve_encoding_fidelity",
        "all_rows_preserve_trust_state",
        "all_rows_preserve_lineage_refs"
      ],
      "properties": {
        "all_rows_preserve_restore_provenance": { "type": "boolean" },
        "all_rows_preserve_encoding_fidelity": { "type": "boolean" },
        "all_rows_preserve_trust_state": { "type": "boolean" },
        "all_rows_preserve_lineage_refs": { "type": "boolean" }
      }
    },
    "no_silent_rerun_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_rows_safe_rerun_posture",
        "all_mutating_rows_have_commit_metadata"
      ],
      "properties": {
        "all_rows_safe_rerun_posture": { "type": "boolean" },
        "all_mutating_rows_have_commit_metadata": { "type": "boolean" }
      }
    },
    "audit_transaction_pinning_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_rows_pin_audit_transaction_id",
        "all_rows_pin_finding_code"
      ],
      "properties": {
        "all_rows_pin_audit_transaction_id": { "type": "boolean" },
        "all_rows_pin_finding_code": { "type": "boolean" }
      }
    },
    "audit_surface_reachability_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_required_surfaces_reachable",
        "all_required_surfaces_disclose_non_clean",
        "all_required_surfaces_preserve_lineage_refs",
        "all_required_surfaces_preserve_trust_state"
      ],
      "properties": {
        "all_required_surfaces_reachable": { "type": "boolean" },
        "all_required_surfaces_disclose_non_clean": { "type": "boolean" },
        "all_required_surfaces_preserve_lineage_refs": { "type": "boolean" },
        "all_required_surfaces_preserve_trust_state": { "type": "boolean" }
      }
    },
    "support_export_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_rows_preserve_fields",
        "all_rows_exclude_raw_secrets",
        "all_rows_exclude_raw_artifact_bytes",
        "all_rows_exclude_approval_tickets",
        "all_rows_exclude_delegated_credentials",
        "all_rows_exclude_live_authority_handles"
      ],
      "properties": {
        "all_rows_preserve_fields": { "type": "boolean" },
        "all_rows_exclude_raw_secrets": { "type": "boolean" },
        "all_rows_exclude_raw_artifact_bytes": { "type": "boolean" },
        "all_rows_exclude_approval_tickets": { "type": "boolean" },
        "all_rows_exclude_delegated_credentials": { "type": "boolean" },
        "all_rows_exclude_live_authority_handles": { "type": "boolean" }
      }
    },
    "inspection_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hook_class", "action_id", "label", "available", "disclosure"],
      "properties": {
        "hook_class": { "$ref": "#/$defs/inspection_hook_class" },
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "available": { "type": "boolean" },
        "disclosure": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  }
}
