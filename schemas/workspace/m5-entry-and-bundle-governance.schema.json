{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/m5-entry-and-bundle-governance.schema.json",
  "title": "Aureline M5 workflow-bundle and project-entry governance matrix",
  "description": "Schema for the m5_entry_and_bundle_governance_matrix packet. The packet aggregates the stable-line entry and bundle lanes into one qualification report, freezing one governance row per claimed M5 switching/entry depth lane (workflow-bundle, source-acquisition, project-open, project-import, session-resume, recent-work, workspace-admission). Each row is pinned to one distinct entry verb (clone, open, import, resume, install) and to the canonical entry-truth packet it draws evidence from, and records the owner, bundle class, locator type, how trusted the source is (first-party, trusted-remote, unverified-remote, untrusted), how confidently the archetype was detected (confirmed, probable, mixed, undetected), whether expected roots resolved (resolved, single-root-assumed, probable-multi-root, missing), how faithfully it restores prior state (exact, partial, degraded, unavailable), whether its bundle scorecard is current (current, aging, stale, missing), and whether its entry topology is supported (supported, degraded-support, experimental, unsupported); it surfaces the first-useful-work setup-queue class (ready, setup-later, blocked-on-setup, missing-root) with deferred-setup and missing-root counts so routing answers stay distinct, the supported scope or slice labels, caveats, stale or narrowing fields, stable workspace-root and bundle identity namespaces, the source packet, a machine-readable governance receipt, and release-evidence, help-surface, docs-badge, and support-export refs so those surfaces ingest the same packet rather than parallel spreadsheets. A non-inheriting governance gate derives the assurance label that may be published: an unverified source, a probable or mixed archetype, missing roots, a partial restore, a stale bundle scorecard, or an unsupported entry topology cannot publish a verified label, and the admission outcome records whether the gate admitted the lane at full trust, admitted it bounded, admitted it pending retest, or refused it. Probable or mixed workspace detection never silently widens trust, one row is required per claimed lane so no lane inherits a verified label, and the recorded published label, admission outcome, and downgrade reasons must equal the recomputed gate decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "workspace_identity_scheme",
    "lanes",
    "entry_verbs",
    "bundle_classes",
    "locator_types",
    "assurance_labels",
    "source_trust_states",
    "archetype_confidence_states",
    "root_resolution_states",
    "restore_fidelities",
    "bundle_scorecard_states",
    "entry_topology_support_states",
    "setup_queue_classes",
    "downgrade_paths",
    "downgrade_reasons",
    "admission_outcomes",
    "lane_rows",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_entry_and_bundle_governance_matrix" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "workspace_identity_scheme": { "$ref": "#/$defs/non_empty_string" },
    "lanes": { "type": "array", "items": { "$ref": "#/$defs/lane" } },
    "entry_verbs": { "type": "array", "items": { "$ref": "#/$defs/entry_verb" } },
    "bundle_classes": { "type": "array", "items": { "$ref": "#/$defs/bundle_class" } },
    "locator_types": { "type": "array", "items": { "$ref": "#/$defs/locator_type" } },
    "assurance_labels": { "type": "array", "items": { "$ref": "#/$defs/assurance" } },
    "source_trust_states": { "type": "array", "items": { "$ref": "#/$defs/source_trust" } },
    "archetype_confidence_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/archetype_confidence" }
    },
    "root_resolution_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/root_resolution" }
    },
    "restore_fidelities": {
      "type": "array",
      "items": { "$ref": "#/$defs/restore_fidelity" }
    },
    "bundle_scorecard_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/bundle_scorecard" }
    },
    "entry_topology_support_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry_topology_support" }
    },
    "setup_queue_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/setup_queue_class" }
    },
    "downgrade_paths": { "type": "array", "items": { "$ref": "#/$defs/downgrade_path" } },
    "downgrade_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/downgrade_reason" }
    },
    "admission_outcomes": {
      "type": "array",
      "items": { "$ref": "#/$defs/admission_outcome" }
    },
    "lane_rows": { "type": "array", "items": { "$ref": "#/$defs/lane_row" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "lane": {
      "enum": [
        "workflow_bundle",
        "source_acquisition",
        "project_open",
        "project_import",
        "session_resume",
        "recent_work",
        "workspace_admission"
      ]
    },
    "entry_verb": {
      "enum": ["clone", "open", "import", "resume", "install"]
    },
    "bundle_class": {
      "enum": [
        "launch_bundle",
        "framework_pack",
        "template_bundle",
        "imported_handoff_bundle",
        "org_managed_bundle",
        "no_bundle"
      ]
    },
    "locator_type": {
      "enum": [
        "local_path",
        "git_remote",
        "archive_import",
        "tool_migration",
        "recent_handle",
        "not_applicable"
      ]
    },
    "assurance": {
      "enum": ["verified", "bounded", "retest_pending", "withheld"]
    },
    "source_trust": {
      "enum": ["first_party", "trusted_remote", "unverified_remote", "untrusted"]
    },
    "archetype_confidence": {
      "enum": ["confirmed", "probable", "mixed", "undetected"]
    },
    "root_resolution": {
      "enum": ["resolved", "single_root_assumed", "probable_multi_root", "missing"]
    },
    "restore_fidelity": {
      "enum": ["exact", "partial", "degraded", "unavailable"]
    },
    "bundle_scorecard": {
      "enum": ["current", "aging", "stale", "missing"]
    },
    "entry_topology_support": {
      "enum": ["supported", "degraded_support", "experimental", "unsupported"]
    },
    "setup_queue_class": {
      "enum": ["ready", "setup_later", "blocked_on_setup", "missing_root"]
    },
    "downgrade_path": {
      "enum": [
        "verify_source",
        "confirm_archetype",
        "resolve_roots",
        "repair_restore",
        "refresh_bundle_scorecard",
        "request_topology_support",
        "withhold_claim",
        "none"
      ]
    },
    "downgrade_reason": {
      "enum": [
        "unverified_source",
        "probable_or_mixed_detection",
        "missing_roots",
        "partial_restore",
        "stale_bundle_scorecard",
        "unsupported_entry_topology"
      ]
    },
    "admission_outcome": {
      "enum": ["admit_full", "admit_bounded", "admit_retest", "refuse"]
    },
    "lane_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_id",
        "lane",
        "entry_verb",
        "bundle_class",
        "locator_type",
        "owner",
        "source_trust",
        "archetype_confidence",
        "root_resolution",
        "restore_fidelity",
        "bundle_scorecard",
        "entry_topology_support",
        "setup_queue_class",
        "deferred_setup_count",
        "missing_root_count",
        "root_id_namespace",
        "bundle_id_namespace",
        "declared_assurance",
        "published_assurance",
        "admission_outcome",
        "downgrade_path",
        "packet_ref",
        "conformance_ref",
        "evidence_ref",
        "governance_receipt_ref",
        "release_evidence_ref",
        "help_surface_ref",
        "docs_badge_ref",
        "support_export_ref",
        "note"
      ],
      "properties": {
        "lane_id": { "$ref": "#/$defs/non_empty_string" },
        "lane": { "$ref": "#/$defs/lane" },
        "entry_verb": { "$ref": "#/$defs/entry_verb" },
        "bundle_class": { "$ref": "#/$defs/bundle_class" },
        "locator_type": { "$ref": "#/$defs/locator_type" },
        "owner": { "$ref": "#/$defs/non_empty_string" },
        "source_trust": { "$ref": "#/$defs/source_trust" },
        "archetype_confidence": { "$ref": "#/$defs/archetype_confidence" },
        "root_resolution": { "$ref": "#/$defs/root_resolution" },
        "restore_fidelity": { "$ref": "#/$defs/restore_fidelity" },
        "bundle_scorecard": { "$ref": "#/$defs/bundle_scorecard" },
        "entry_topology_support": { "$ref": "#/$defs/entry_topology_support" },
        "setup_queue_class": { "$ref": "#/$defs/setup_queue_class" },
        "deferred_setup_count": { "type": "integer", "minimum": 0 },
        "missing_root_count": { "type": "integer", "minimum": 0 },
        "root_id_namespace": { "$ref": "#/$defs/non_empty_string" },
        "bundle_id_namespace": { "$ref": "#/$defs/non_empty_string" },
        "declared_assurance": { "$ref": "#/$defs/assurance" },
        "published_assurance": { "$ref": "#/$defs/assurance" },
        "admission_outcome": { "$ref": "#/$defs/admission_outcome" },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason" }
        },
        "downgrade_path": { "$ref": "#/$defs/downgrade_path" },
        "supported_scopes": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "caveats": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "stale_or_missing_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "conformance_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "governance_receipt_ref": { "$ref": "#/$defs/non_empty_string" },
        "release_evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "help_surface_ref": { "$ref": "#/$defs/non_empty_string" },
        "docs_badge_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_lanes",
        "lane_count",
        "verified_lanes",
        "bounded_lanes",
        "retest_pending_lanes",
        "withheld_lanes",
        "admit_full_decisions",
        "admit_bounded_decisions",
        "admit_retest_decisions",
        "refuse_decisions",
        "downgraded_lanes",
        "trust_sensitive_lanes",
        "probable_or_mixed_lanes",
        "stale_bundle_lanes",
        "unsupported_topology_lanes",
        "lanes_with_downgrade_reasons",
        "lanes_with_deferred_setup",
        "lanes_with_missing_roots"
      ],
      "properties": {
        "total_lanes": { "type": "integer", "minimum": 0 },
        "lane_count": { "type": "integer", "minimum": 0 },
        "verified_lanes": { "type": "integer", "minimum": 0 },
        "bounded_lanes": { "type": "integer", "minimum": 0 },
        "retest_pending_lanes": { "type": "integer", "minimum": 0 },
        "withheld_lanes": { "type": "integer", "minimum": 0 },
        "admit_full_decisions": { "type": "integer", "minimum": 0 },
        "admit_bounded_decisions": { "type": "integer", "minimum": 0 },
        "admit_retest_decisions": { "type": "integer", "minimum": 0 },
        "refuse_decisions": { "type": "integer", "minimum": 0 },
        "downgraded_lanes": { "type": "integer", "minimum": 0 },
        "trust_sensitive_lanes": { "type": "integer", "minimum": 0 },
        "probable_or_mixed_lanes": { "type": "integer", "minimum": 0 },
        "stale_bundle_lanes": { "type": "integer", "minimum": 0 },
        "unsupported_topology_lanes": { "type": "integer", "minimum": 0 },
        "lanes_with_downgrade_reasons": { "type": "integer", "minimum": 0 },
        "lanes_with_deferred_setup": { "type": "integer", "minimum": 0 },
        "lanes_with_missing_roots": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
