{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/local_history_export_replay_lineage.schema.json",
  "title": "Aureline local-history export/replay packet and compare-to-disk lineage",
  "description": "Boundary schema for the governed, export-safe local-history export/replay lineage record. The record proves how local-history export packets and their replay/compare-to-disk flows preserve source fidelity, restore provenance, encoding/newline class, integrity hashes, and no-rerun semantics across crashes, migrations, external changes, and policy-bound workflows. It is projected verbatim from the live LocalHistoryExportReplayInputs envelope. It proves packet-kind coverage, replay-path coverage, compare-to-disk honesty, body-export safety, encoding/newline fidelity preservation, restore-provenance preservation, no-silent-rerun honesty, integrity-hash pinning, support-export honesty, and pre-action inspection-hook honesty. Raw payload bytes are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "local_history_export_replay_lineage_schema_version",
    "schema_ref",
    "posture_id",
    "workspace_ref",
    "corpus_ref",
    "producer_attribution",
    "packet_coverage",
    "replay_path_coverage",
    "compare_to_disk_honesty",
    "body_export_safety",
    "encoding_fidelity",
    "restore_provenance",
    "no_silent_rerun",
    "integrity_hash_pinning",
    "support_export_honesty",
    "inspection_hooks",
    "stable_qualification",
    "raw_payload_excluded",
    "summary"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": { "const": "local_history_export_replay_lineage_record" },
    "local_history_export_replay_lineage_schema_version": { "type": "integer", "const": 1 },
    "schema_ref": { "const": "schemas/workspace/local_history_export_replay_lineage.schema.json" },
    "posture_id": { "$ref": "#/$defs/non_empty_string" },
    "workspace_ref": { "$ref": "#/$defs/non_empty_string" },
    "corpus_ref": { "$ref": "#/$defs/non_empty_string" },
    "producer_attribution": { "$ref": "#/$defs/producer_attribution_summary" },
    "packet_coverage": { "$ref": "#/$defs/packet_coverage_summary" },
    "replay_path_coverage": { "$ref": "#/$defs/replay_path_coverage_summary" },
    "compare_to_disk_honesty": { "$ref": "#/$defs/compare_to_disk_honesty_summary" },
    "body_export_safety": { "$ref": "#/$defs/body_export_safety_summary" },
    "encoding_fidelity": { "$ref": "#/$defs/encoding_fidelity_summary" },
    "restore_provenance": { "$ref": "#/$defs/restore_provenance_summary" },
    "no_silent_rerun": { "$ref": "#/$defs/no_silent_rerun_summary" },
    "integrity_hash_pinning": { "$ref": "#/$defs/integrity_hash_pinning_summary" },
    "support_export_honesty": { "$ref": "#/$defs/support_export_honesty_summary" },
    "inspection_hooks": {
      "type": "array",
      "items": { "$ref": "#/$defs/inspection_hook" }
    },
    "stable_qualification": { "$ref": "#/$defs/stable_qualification" },
    "raw_payload_excluded": { "const": true },
    "summary": { "type": "string", "minLength": 1, "maxLength": 700 }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "export_packet_kind": {
      "type": "string",
      "enum": [
        "local_history_entry_export",
        "local_history_group_export",
        "restore_checkpoint_export",
        "compare_to_disk_diff_export",
        "support_bundle_local_history_section",
        "replay_input_envelope",
        "replay_output_envelope"
      ]
    },
    "replay_path_kind": {
      "type": "string",
      "enum": [
        "restore_from_packet",
        "compare_to_disk_replay",
        "entry_inspect_replay",
        "group_inspect_replay",
        "support_bundle_replay"
      ]
    },
    "compare_to_disk_state": {
      "type": "string",
      "enum": [
        "in_sync_with_packet",
        "disk_modified_since_packet",
        "packet_decoded_recovered",
        "packet_redacted",
        "compare_unavailable_remote_only",
        "local_only_packet"
      ]
    },
    "body_availability_class": {
      "type": "string",
      "enum": [
        "metadata_only",
        "body_object_ref_with_disclosure",
        "raw_body_with_disclosure",
        "body_excluded_by_policy"
      ]
    },
    "replay_rerun_posture": {
      "type": "string",
      "enum": [
        "explicit_user_action_required",
        "terminal_no_further_run",
        "silent_rerun_permitted"
      ]
    },
    "encoding_fidelity_class": {
      "type": "string",
      "enum": [
        "utf8_lf",
        "utf8_crlf",
        "utf8_bom_lf",
        "utf8_bom_crlf",
        "non_utf8_declared_encoding",
        "binary_safe"
      ]
    },
    "support_export_posture": {
      "type": "string",
      "enum": ["metadata_safe_export", "held_record"]
    },
    "inspection_hook_class": {
      "type": "string",
      "enum": [
        "inspect_packet",
        "compare_before_replay",
        "preview_replay",
        "export_packet",
        "rollback_replay",
        "repair_packet"
      ]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "corpus_empty",
        "required_packet_kind_missing",
        "required_replay_path_kind_missing",
        "replay_references_unknown_packet",
        "compare_to_disk_state_missing",
        "disk_modified_silently_treated_as_clean",
        "body_override_disclosure_missing",
        "body_raw_by_default",
        "replay_rerun_silent_forbidden",
        "replay_commit_action_metadata_missing",
        "encoding_fidelity_not_preserved",
        "restore_provenance_not_preserved",
        "integrity_hash_not_pinned",
        "inspection_hook_unavailable",
        "support_export_fields_dropped",
        "support_export_redaction_unsafe",
        "producer_attribution_incomplete",
        "lineage_export_unsafe"
      ]
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qualified", "level", "narrow_reasons"],
      "properties": {
        "qualified": { "type": "boolean" },
        "level": { "type": "string", "enum": ["stable", "narrowed_below_stable"] },
        "narrow_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason" }
        }
      }
    },
    "producer_attribution_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_ref",
        "schema_version",
        "integrity_hash",
        "captured_at",
        "producer_attribution_complete"
      ],
      "properties": {
        "producer_ref": { "type": "string" },
        "schema_version": { "type": "integer", "const": 1 },
        "integrity_hash": { "type": "string" },
        "captured_at": { "type": "string" },
        "producer_attribution_complete": { "type": "boolean" }
      }
    },
    "packet_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_kind",
        "packet_ref",
        "body_availability_class",
        "encoding_fidelity_class",
        "encoding_preserved",
        "newline_preserved",
        "bom_preserved",
        "restore_of_ref",
        "mutation_journal_ref",
        "actor_class",
        "integrity_hash",
        "support_export_posture",
        "is_required"
      ],
      "properties": {
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "packet_kind": { "$ref": "#/$defs/export_packet_kind" },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "body_availability_class": { "$ref": "#/$defs/body_availability_class" },
        "body_override_disclosure_ref": { "type": ["string", "null"] },
        "encoding_fidelity_class": { "$ref": "#/$defs/encoding_fidelity_class" },
        "encoding_preserved": { "type": "boolean" },
        "newline_preserved": { "type": "boolean" },
        "bom_preserved": { "type": "boolean" },
        "restore_of_ref": { "type": "string" },
        "mutation_journal_ref": { "type": "string" },
        "actor_class": { "type": "string" },
        "integrity_hash": { "type": "string" },
        "support_export_posture": { "$ref": "#/$defs/support_export_posture" },
        "is_required": { "type": "boolean" }
      }
    },
    "replay_path_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replay_path_id",
        "label",
        "replay_path_kind",
        "packet_id",
        "discloses_disk_modified_state",
        "rerun_posture",
        "commit_action_id",
        "commit_disclosure_id",
        "preserves_encoding_fidelity",
        "preserves_restore_provenance",
        "verifies_integrity_hash",
        "support_export_posture",
        "mutates_workspace",
        "is_compare_to_disk",
        "is_required"
      ],
      "properties": {
        "replay_path_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "type": "string" },
        "replay_path_kind": { "$ref": "#/$defs/replay_path_kind" },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "compare_to_disk_state": {
          "oneOf": [
            { "$ref": "#/$defs/compare_to_disk_state" },
            { "type": "null" }
          ]
        },
        "discloses_disk_modified_state": { "type": "boolean" },
        "rerun_posture": { "$ref": "#/$defs/replay_rerun_posture" },
        "commit_action_id": { "type": "string" },
        "commit_disclosure_id": { "type": "string" },
        "preserves_encoding_fidelity": { "type": "boolean" },
        "preserves_restore_provenance": { "type": "boolean" },
        "verifies_integrity_hash": { "type": "boolean" },
        "support_export_posture": { "$ref": "#/$defs/support_export_posture" },
        "mutates_workspace": { "type": "boolean" },
        "is_compare_to_disk": { "type": "boolean" },
        "is_required": { "type": "boolean" }
      }
    },
    "packet_coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_rows", "all_required_packet_kinds_present"],
      "properties": {
        "packet_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/packet_row" }
        },
        "all_required_packet_kinds_present": { "type": "boolean" }
      }
    },
    "replay_path_coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["replay_path_rows", "all_required_replay_path_kinds_present"],
      "properties": {
        "replay_path_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/replay_path_row" }
        },
        "all_required_replay_path_kinds_present": { "type": "boolean" }
      }
    },
    "compare_to_disk_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compare_to_disk_path_count",
        "all_compare_paths_have_state",
        "no_disk_modified_silently_clean"
      ],
      "properties": {
        "compare_to_disk_path_count": { "type": "integer", "minimum": 0 },
        "all_compare_paths_have_state": { "type": "boolean" },
        "no_disk_modified_silently_clean": { "type": "boolean" }
      }
    },
    "body_export_safety_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_overrides_have_disclosure", "no_raw_body_by_default"],
      "properties": {
        "all_overrides_have_disclosure": { "type": "boolean" },
        "no_raw_body_by_default": { "type": "boolean" }
      }
    },
    "encoding_fidelity_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_packets_preserve_encoding",
        "all_packets_preserve_newline",
        "all_packets_preserve_bom",
        "all_replays_preserve_encoding_fidelity"
      ],
      "properties": {
        "all_packets_preserve_encoding": { "type": "boolean" },
        "all_packets_preserve_newline": { "type": "boolean" },
        "all_packets_preserve_bom": { "type": "boolean" },
        "all_replays_preserve_encoding_fidelity": { "type": "boolean" }
      }
    },
    "restore_provenance_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_packets_carry_restore_of_ref",
        "all_packets_carry_mutation_journal_ref",
        "all_packets_carry_actor_class",
        "all_replays_preserve_restore_provenance"
      ],
      "properties": {
        "all_packets_carry_restore_of_ref": { "type": "boolean" },
        "all_packets_carry_mutation_journal_ref": { "type": "boolean" },
        "all_packets_carry_actor_class": { "type": "boolean" },
        "all_replays_preserve_restore_provenance": { "type": "boolean" }
      }
    },
    "no_silent_rerun_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_replays_safe_rerun_posture",
        "all_mutating_replays_have_commit_metadata"
      ],
      "properties": {
        "all_replays_safe_rerun_posture": { "type": "boolean" },
        "all_mutating_replays_have_commit_metadata": { "type": "boolean" }
      }
    },
    "integrity_hash_pinning_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_packets_pin_integrity_hash",
        "all_replays_verify_integrity_hash"
      ],
      "properties": {
        "all_packets_pin_integrity_hash": { "type": "boolean" },
        "all_replays_verify_integrity_hash": { "type": "boolean" }
      }
    },
    "support_export_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_rows_preserve_fields",
        "all_rows_exclude_raw_secrets",
        "all_rows_exclude_raw_body_bytes",
        "all_rows_exclude_approval_tickets",
        "all_rows_exclude_delegated_credentials",
        "all_rows_exclude_live_authority_handles"
      ],
      "properties": {
        "all_rows_preserve_fields": { "type": "boolean" },
        "all_rows_exclude_raw_secrets": { "type": "boolean" },
        "all_rows_exclude_raw_body_bytes": { "type": "boolean" },
        "all_rows_exclude_approval_tickets": { "type": "boolean" },
        "all_rows_exclude_delegated_credentials": { "type": "boolean" },
        "all_rows_exclude_live_authority_handles": { "type": "boolean" }
      }
    },
    "inspection_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hook_class", "action_id", "label", "available", "disclosure"],
      "properties": {
        "hook_class": { "$ref": "#/$defs/inspection_hook_class" },
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "available": { "type": "boolean" },
        "disclosure": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  }
}
