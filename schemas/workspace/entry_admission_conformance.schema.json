{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/entry_admission_conformance.schema.json",
  "title": "Aureline project-entry and workspace-admission conformance corpus",
  "description": "Boundary schema for the M3 project-entry and workspace-admission conformance corpus. It validates both the corpus manifest (the single source of truth that pins, per drill, the entry truth the built ProjectEntryReviewRecord must reproduce) and the per-drill request fixtures replayed by the aureline-qe harness. Open, Clone, Import, Add root, Restore, recent-work reopen, OS open, CLI open, and high-authority deep-link rows stay distinct, reviewable, and honest about resulting mode, source-labelled access, first landing surface, destination collision, readiness grouping, and deferred work.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/corpus_manifest" },
    { "$ref": "#/$defs/entry_review_request_fixture" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "opaque_id": { "type": "string", "minLength": 1 },
    "redaction_aware_text": { "type": "string", "minLength": 1, "maxLength": 2048 },
    "source_surface": {
      "type": "string",
      "enum": [
        "start_center",
        "command_palette",
        "drag_and_drop",
        "system_file_association",
        "deep_link",
        "cli_headless",
        "workspace_switcher"
      ]
    },
    "entry_verb": {
      "type": "string",
      "enum": [
        "open",
        "clone",
        "import",
        "add_root",
        "restore",
        "resume",
        "start_from_snapshot"
      ]
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "local_file",
        "local_folder",
        "local_repo_root",
        "workspace_manifest",
        "workset_manifest",
        "remote_repository",
        "ssh_workspace",
        "container_workspace",
        "devcontainer_workspace",
        "managed_cloud_workspace",
        "portable_state_package",
        "handoff_packet",
        "competitor_config_root",
        "template_or_prebuild_snapshot",
        "review_or_work_item_deep_link",
        "recovery_checkpoint"
      ]
    },
    "resulting_mode": {
      "type": "string",
      "enum": [
        "single_file",
        "folder",
        "repo_root",
        "workspace_candidate",
        "workspace_with_roots",
        "workset_slice",
        "inspect_only",
        "clone_then_review",
        "clone_then_open",
        "clone_then_add",
        "clone_only",
        "extract_then_review",
        "compare_before_restore",
        "apply_to_active_workspace",
        "open_prebuild_with_setup_actions",
        "open_prebuild_minimal",
        "resume_live_session",
        "restore_last_session",
        "restore_from_checkpoint"
      ]
    },
    "review_sheet_kind": {
      "type": "string",
      "enum": [
        "open_local_target",
        "open_workspace_manifest",
        "clone_repository",
        "add_root",
        "import_artifact",
        "restore_state"
      ]
    },
    "source_access_class": {
      "type": "string",
      "enum": [
        "direct_online",
        "mirror_first",
        "offline_snapshot",
        "air_gapped_media",
        "local_filesystem"
      ]
    },
    "first_useful_entry_source": {
      "type": "string",
      "enum": [
        "single_file_open",
        "folder_or_repo_open",
        "repository_clone",
        "review_or_incident_deep_link",
        "restore_last_session",
        "imported_state_or_handoff_packet"
      ]
    },
    "landing_surface": {
      "type": "string",
      "enum": [
        "file_editor_with_root_cues",
        "explorer_plus_readme_or_changed_files",
        "post_clone_handoff",
        "linked_review_incident_or_work_item",
        "restored_layout_with_placeholders",
        "import_compare_or_restore_sheet",
        "generic_shell_with_diagnostics",
        "nested_root_choice_sheet"
      ]
    },
    "admission_action": {
      "type": "string",
      "enum": [
        "open",
        "import",
        "add_root",
        "clone_here",
        "split",
        "copy",
        "move",
        "clone_only",
        "clone_and_review",
        "clone_and_open",
        "clone_and_add",
        "reuse_existing",
        "add_existing_as_root",
        "clone_elsewhere",
        "reveal_target",
        "inspect_only",
        "open_minimal",
        "set_up_later",
        "cancel"
      ]
    },
    "collision_class": {
      "type": "string",
      "enum": [
        "no_collision",
        "existing_path_non_empty",
        "existing_repo_root",
        "nested_repository",
        "existing_worktree",
        "existing_workspace_manifest",
        "duplicate_clone_target",
        "destination_blocked_by_policy"
      ]
    },
    "deferred_work_class": {
      "type": "string",
      "enum": [
        "trust_grant",
        "dependency_restore",
        "task_execution",
        "hook_execution",
        "extension_or_bundle_install",
        "state_rehydration",
        "durable_promotion",
        "runtime_attach",
        "credential_admission"
      ]
    },
    "import_write_behavior_class": {
      "type": "string",
      "enum": [
        "inspect_only_no_write",
        "write_to_labelled_staging",
        "write_to_reviewed_destination",
        "apply_to_active_workspace",
        "restore_after_compare"
      ]
    },
    "tamper": {
      "type": "string",
      "enum": [
        "clone_grants_trust",
        "clone_exposes_credentials",
        "import_writes_before_review",
        "import_inspect_advertises_write",
        "collision_skips_explicit_choice",
        "surface_parity_drift",
        "failure_repair_drops_inputs",
        "route_auto_trust",
        "route_auto_install",
        "review_sheet_mismatch"
      ]
    },
    "entry_review_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_surface",
        "entry_verb",
        "target_kind",
        "resulting_mode",
        "target_specifier"
      ],
      "properties": {
        "source_surface": { "$ref": "#/$defs/source_surface" },
        "entry_verb": { "$ref": "#/$defs/entry_verb" },
        "target_kind": { "$ref": "#/$defs/target_kind" },
        "resulting_mode": { "$ref": "#/$defs/resulting_mode" },
        "target_specifier": { "$ref": "#/$defs/redaction_aware_text" },
        "destination": { "$ref": "#/$defs/redaction_aware_text" },
        "active_workspace_label": { "$ref": "#/$defs/redaction_aware_text" },
        "network_route_label": { "$ref": "#/$defs/redaction_aware_text" },
        "clone_options": { "type": "object" },
        "import_options": { "type": "object" },
        "destination_facts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "previously_cloned_target_ref": { "$ref": "#/$defs/opaque_id" },
            "policy_blocked": { "type": "boolean" }
          }
        },
        "failed_diagnostic_text": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "entry_review_request_fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "request"],
      "properties": {
        "$schema": { "type": "string" },
        "kind": { "const": "project_entry_review_request" },
        "request": { "$ref": "#/$defs/entry_review_request" }
      }
    },
    "positive_expect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_sheet_kind",
        "source_access_class",
        "first_useful_entry_source",
        "landing_surface",
        "resulting_mode",
        "primary_next_action",
        "blocking_now_count",
        "recommended_soon_count",
        "optional_later_count"
      ],
      "properties": {
        "review_sheet_kind": { "$ref": "#/$defs/review_sheet_kind" },
        "source_access_class": { "$ref": "#/$defs/source_access_class" },
        "first_useful_entry_source": { "$ref": "#/$defs/first_useful_entry_source" },
        "landing_surface": { "$ref": "#/$defs/landing_surface" },
        "resulting_mode": { "$ref": "#/$defs/resulting_mode" },
        "primary_next_action": { "$ref": "#/$defs/admission_action" },
        "collision_class": {
          "oneOf": [{ "$ref": "#/$defs/collision_class" }, { "type": "null" }]
        },
        "collision_requires_explicit_choice": { "type": "boolean" },
        "blocking_now_count": { "type": "integer", "minimum": 0 },
        "recommended_soon_count": { "type": "integer", "minimum": 0 },
        "optional_later_count": { "type": "integer", "minimum": 0 },
        "deferred_work_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/deferred_work_class" }
        },
        "import_inspect_only": { "type": "boolean" },
        "import_write_behavior_class": { "$ref": "#/$defs/import_write_behavior_class" },
        "redacted_marker_absent": { "type": "string", "minLength": 1 }
      }
    },
    "positive_drill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["drill_id", "fixture", "row_label", "expect"],
      "properties": {
        "drill_id": { "$ref": "#/$defs/opaque_id" },
        "fixture": { "type": "string", "minLength": 1 },
        "row_label": { "$ref": "#/$defs/redaction_aware_text" },
        "expect": { "$ref": "#/$defs/positive_expect" }
      }
    },
    "negative_drill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["drill_id", "fixture", "row_label", "tamper", "expected_failure_substring"],
      "properties": {
        "drill_id": { "$ref": "#/$defs/opaque_id" },
        "fixture": { "type": "string", "minLength": 1 },
        "row_label": { "$ref": "#/$defs/redaction_aware_text" },
        "tamper": { "$ref": "#/$defs/tamper" },
        "expected_failure_substring": { "$ref": "#/$defs/redaction_aware_text" },
        "covers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "corpus_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "corpus_id",
        "schema_version",
        "description",
        "positive_drills",
        "negative_drills"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "corpus_id": { "$ref": "#/$defs/opaque_id" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "description": { "type": "string", "minLength": 1 },
        "boundary": {
          "type": "object",
          "additionalProperties": true
        },
        "positive_drills": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/positive_drill" }
        },
        "negative_drills": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/negative_drill" }
        }
      }
    }
  }
}
