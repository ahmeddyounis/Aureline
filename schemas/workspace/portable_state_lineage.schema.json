{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/portable_state_lineage.schema.json",
  "title": "Aureline portable-state lineage",
  "description": "Boundary schema for the governed, export-safe portable-state lineage record. The record finalizes portable-state export/import, the remembered-state inspector, and restore-provenance labeling into one record per posture. It is projected verbatim from the live PortableStateAlphaPackage. It proves state-class separation (workspace authority / window topology / profile defaults / machine-local hints all distinct), restore-provenance fidelity (Exact / Compatible / LayoutOnly / RecoveredDrafts / EvidenceOnly), exclusion / redaction honesty, and no-rerun guardrails for non-live panes. Raw payload bytes are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "portable_state_lineage_schema_version",
    "schema_ref",
    "posture_id",
    "package_ref",
    "manifest_ref",
    "workspace_ref",
    "producer_attribution",
    "state_class_separation",
    "restore_provenance",
    "exclusion_honesty",
    "no_rerun_honesty",
    "remembered_state_inspector",
    "inspection_hooks",
    "stable_qualification",
    "raw_payload_excluded",
    "summary"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": { "const": "portable_state_lineage_record" },
    "portable_state_lineage_schema_version": { "type": "integer", "const": 1 },
    "schema_ref": { "const": "schemas/workspace/portable_state_lineage.schema.json" },
    "posture_id": { "$ref": "#/$defs/non_empty_string" },
    "package_ref": { "$ref": "#/$defs/non_empty_string" },
    "manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "workspace_ref": { "$ref": "#/$defs/non_empty_string" },
    "producer_attribution": { "$ref": "#/$defs/producer_attribution_summary" },
    "state_class_separation": { "$ref": "#/$defs/state_class_separation_summary" },
    "restore_provenance": { "$ref": "#/$defs/restore_provenance_summary" },
    "exclusion_honesty": { "$ref": "#/$defs/exclusion_honesty_summary" },
    "no_rerun_honesty": { "$ref": "#/$defs/no_rerun_honesty_summary" },
    "remembered_state_inspector": { "$ref": "#/$defs/remembered_state_inspector" },
    "inspection_hooks": {
      "type": "array",
      "items": { "$ref": "#/$defs/inspection_hook" }
    },
    "stable_qualification": { "$ref": "#/$defs/stable_qualification" },
    "raw_payload_excluded": { "const": true },
    "summary": { "type": "string", "minLength": 1, "maxLength": 700 }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "serialized_state_class": {
      "type": "string",
      "enum": [
        "workspace_authority",
        "window_topology",
        "profile_defaults",
        "machine_local_hints",
        "local_session_context"
      ]
    },
    "persistence_classification": {
      "type": "string",
      "enum": ["local_only", "portable", "shared", "machine_local"]
    },
    "restore_candidate_class": {
      "type": "string",
      "enum": ["exact_restore", "compatible_restore", "layout_only", "excluded"]
    },
    "restore_fidelity_class": {
      "type": "string",
      "enum": ["exact", "compatible", "layout_only", "recovered_drafts", "evidence_only"]
    },
    "surface_restore_posture": {
      "type": "string",
      "enum": ["live", "context_only", "placeholder_only", "excluded"]
    },
    "remembered_state_action_kind": {
      "type": "string",
      "enum": ["inspect", "export", "clear", "compare"]
    },
    "inspection_hook_class": {
      "type": "string",
      "enum": [
        "inspect_inspector",
        "inspect_export_review",
        "inspect_restore_provenance",
        "compare_before_apply",
        "rollback_checkpoint",
        "export",
        "clear"
      ]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "package_validator_failed",
        "state_classes_incomplete",
        "machine_local_hints_misclassified",
        "redaction_rule_missing",
        "machine_local_exclusions_not_reviewed",
        "machine_local_exclusion_reason_missing",
        "topology_adjustment_unverified",
        "topology_adjustment_lost_pane_ids",
        "placeholder_missing_no_rerun_guardrail",
        "inspection_hook_unavailable",
        "producer_attribution_incomplete",
        "lineage_export_unsafe"
      ]
    },
    "redaction_rule_class": {
      "type": "string",
      "enum": [
        "raw_secret_material_excluded",
        "approval_ticket_excluded",
        "delegated_credential_excluded",
        "live_authority_handle_excluded",
        "machine_unique_handle_excluded",
        "state_root_excluded",
        "raw_path_excluded",
        "raw_host_excluded",
        "raw_command_line_excluded",
        "raw_log_excluded",
        "raw_source_content_excluded",
        "provider_payload_excluded"
      ]
    },
    "machine_local_exclusion_reason": {
      "type": "string",
      "enum": [
        "contains_secret_material",
        "contains_live_handle",
        "credential_store_only",
        "machine_unique_handle",
        "state_root_only",
        "display_hint_best_effort_only",
        "local_absolute_path",
        "policy_excludes_export"
      ]
    },
    "producer_attribution_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_ref",
        "schema_version",
        "integrity_hash",
        "created_at",
        "producer_attribution_complete"
      ],
      "properties": {
        "producer_ref": { "type": "string" },
        "schema_version": { "type": "integer" },
        "integrity_hash": { "type": "string" },
        "created_at": { "type": "string" },
        "producer_attribution_complete": { "type": "boolean" }
      }
    },
    "portable_state_lineage_class_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class_id",
        "class_kind",
        "classification",
        "restore_candidate",
        "export_allowed",
        "clear_allowed",
        "pane_count",
        "linked_profile_artifact_refs",
        "schema_version"
      ],
      "properties": {
        "class_id": { "$ref": "#/$defs/non_empty_string" },
        "class_kind": { "$ref": "#/$defs/serialized_state_class" },
        "classification": { "$ref": "#/$defs/persistence_classification" },
        "restore_candidate": { "$ref": "#/$defs/restore_candidate_class" },
        "export_allowed": { "type": "boolean" },
        "clear_allowed": { "type": "boolean" },
        "pane_count": { "type": "integer", "minimum": 0 },
        "linked_profile_artifact_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "schema_version": { "type": "integer" }
      }
    },
    "state_class_separation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class_rows",
        "workspace_authority_present",
        "window_topology_present",
        "profile_defaults_present",
        "machine_local_hints_present",
        "machine_local_hints_classified_correctly",
        "machine_local_hints_not_exported_as_body"
      ],
      "properties": {
        "class_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/portable_state_lineage_class_row" }
        },
        "workspace_authority_present": { "type": "boolean" },
        "window_topology_present": { "type": "boolean" },
        "profile_defaults_present": { "type": "boolean" },
        "machine_local_hints_present": { "type": "boolean" },
        "machine_local_hints_classified_correctly": { "type": "boolean" },
        "machine_local_hints_not_exported_as_body": { "type": "boolean" }
      }
    },
    "restore_provenance_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "restore_fidelity_class",
        "source_snapshot_refs",
        "restore_provenance_refs",
        "live_pane_count",
        "context_only_pane_count",
        "placeholder_only_pane_count",
        "topology_adjustments_recorded",
        "all_adjustments_visible_bounds_verified",
        "all_adjustments_preserve_pane_ids",
        "placeholder_summary_covers_required_postures"
      ],
      "properties": {
        "restore_fidelity_class": { "$ref": "#/$defs/restore_fidelity_class" },
        "source_snapshot_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "restore_provenance_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "live_pane_count": { "type": "integer", "minimum": 0 },
        "context_only_pane_count": { "type": "integer", "minimum": 0 },
        "placeholder_only_pane_count": { "type": "integer", "minimum": 0 },
        "topology_adjustments_recorded": { "type": "boolean" },
        "all_adjustments_visible_bounds_verified": { "type": "boolean" },
        "all_adjustments_preserve_pane_ids": { "type": "boolean" },
        "placeholder_summary_covers_required_postures": { "type": "boolean" }
      }
    },
    "exclusion_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redaction_rules",
        "redaction_rules_complete",
        "machine_local_exclusions_reviewed",
        "machine_local_exclusion_reasons",
        "machine_local_exclusion_reasons_complete",
        "machine_local_exclusion_count",
        "paths_and_hosts_excluded"
      ],
      "properties": {
        "redaction_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/redaction_rule_class" }
        },
        "redaction_rules_complete": { "type": "boolean" },
        "machine_local_exclusions_reviewed": { "type": "boolean" },
        "machine_local_exclusion_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/machine_local_exclusion_reason" }
        },
        "machine_local_exclusion_reasons_complete": { "type": "boolean" },
        "machine_local_exclusion_count": { "type": "integer", "minimum": 0 },
        "paths_and_hosts_excluded": { "type": "boolean" }
      }
    },
    "no_rerun_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_non_live_panes_no_rerun_guarded",
        "all_placeholder_panes_offer_safe_actions",
        "remembered_state_actions_complete"
      ],
      "properties": {
        "all_non_live_panes_no_rerun_guarded": { "type": "boolean" },
        "all_placeholder_panes_offer_safe_actions": { "type": "boolean" },
        "remembered_state_actions_complete": { "type": "boolean" }
      }
    },
    "remembered_state_inspector_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_ref",
        "state_class",
        "classification",
        "schema_version",
        "last_written_at",
        "restore_candidate",
        "actions"
      ],
      "properties": {
        "artifact_ref": { "type": "string" },
        "state_class": { "$ref": "#/$defs/serialized_state_class" },
        "classification": { "$ref": "#/$defs/persistence_classification" },
        "schema_version": { "type": "integer" },
        "last_written_at": { "type": "string" },
        "restore_candidate": { "$ref": "#/$defs/restore_candidate_class" },
        "stable_pane_id": { "type": "string" },
        "pane_restore_posture": { "$ref": "#/$defs/surface_restore_posture" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/remembered_state_action_kind" }
        },
        "local_only_reason": { "type": "string" }
      }
    },
    "remembered_state_inspector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package_id", "schema_version", "rows"],
      "properties": {
        "package_id": { "type": "string" },
        "schema_version": { "type": "integer" },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/remembered_state_inspector_row" }
        }
      }
    },
    "inspection_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hook_class", "action_id", "label", "available", "disclosure"],
      "properties": {
        "hook_class": { "$ref": "#/$defs/inspection_hook_class" },
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "available": { "type": "boolean" },
        "disclosure": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qualified", "level", "narrow_reasons"],
      "properties": {
        "qualified": { "type": "boolean" },
        "level": { "type": "string", "enum": ["stable", "narrowed_below_stable"] },
        "narrow_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason" },
          "uniqueItems": true
        }
      }
    }
  }
}
