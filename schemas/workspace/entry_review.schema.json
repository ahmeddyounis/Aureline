{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/entry_review.schema.json",
  "title": "Aureline project entry review and admission checkpoint record",
  "description": "Boundary schema for workspace project-entry review records and fixture cases. The record joins the resolved entry verb, verb-specific review sheet, destination collision review, post-entry handoff card, failed-attempt repair state, cross-surface parity rows, the admission review packet, and the post-entry admission checkpoint route. Clone, import, add-root, open-workspace, and restore remain distinct before writes, trust changes, setup, or state rehydration.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/project_entry_review_record" },
    { "$ref": "#/$defs/entry_review_case_record" }
  ],
  "$defs": {
    "entry_review_schema_version": {
      "type": "integer",
      "const": 1
    },
    "entry_review_case_schema_version": {
      "type": "integer",
      "const": 1
    },
    "redaction_aware_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "source_surface": {
      "type": "string",
      "enum": [
        "start_center",
        "command_palette",
        "drag_and_drop",
        "system_file_association",
        "deep_link",
        "cli_headless",
        "workspace_switcher"
      ]
    },
    "entry_verb": {
      "type": "string",
      "enum": [
        "open",
        "clone",
        "import",
        "add_root",
        "restore",
        "resume",
        "start_from_snapshot"
      ]
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "local_file",
        "local_folder",
        "local_repo_root",
        "workspace_manifest",
        "workset_manifest",
        "remote_repository",
        "ssh_workspace",
        "container_workspace",
        "devcontainer_workspace",
        "managed_cloud_workspace",
        "portable_state_package",
        "handoff_packet",
        "competitor_config_root",
        "template_or_prebuild_snapshot",
        "review_or_work_item_deep_link",
        "recovery_checkpoint"
      ]
    },
    "resulting_mode": {
      "type": "string",
      "enum": [
        "single_file",
        "folder",
        "repo_root",
        "workspace_candidate",
        "workspace_with_roots",
        "workset_slice",
        "inspect_only",
        "clone_then_review",
        "clone_then_open",
        "clone_then_add",
        "clone_only",
        "extract_then_review",
        "compare_before_restore",
        "apply_to_active_workspace",
        "open_prebuild_with_setup_actions",
        "open_prebuild_minimal",
        "resume_live_session",
        "restore_last_session",
        "restore_from_checkpoint"
      ]
    },
    "admission_action": {
      "type": "string",
      "enum": [
        "open",
        "import",
        "add_root",
        "clone_here",
        "split",
        "copy",
        "move",
        "clone_only",
        "clone_and_review",
        "clone_and_open",
        "clone_and_add",
        "reuse_existing",
        "add_existing_as_root",
        "clone_elsewhere",
        "reveal_target",
        "inspect_only",
        "open_minimal",
        "set_up_later",
        "cancel"
      ]
    },
    "review_sheet_kind": {
      "type": "string",
      "enum": [
        "open_local_target",
        "open_workspace_manifest",
        "clone_repository",
        "add_root",
        "import_artifact",
        "restore_state"
      ]
    },
    "source_access_class": {
      "type": "string",
      "enum": [
        "direct_online",
        "mirror_first",
        "offline_snapshot",
        "air_gapped_media",
        "local_filesystem"
      ]
    },
    "first_useful_entry_source": {
      "type": "string",
      "enum": [
        "single_file_open",
        "folder_or_repo_open",
        "repository_clone",
        "review_or_incident_deep_link",
        "restore_last_session",
        "imported_state_or_handoff_packet"
      ]
    },
    "landing_surface": {
      "type": "string",
      "enum": [
        "file_editor_with_root_cues",
        "explorer_plus_readme_or_changed_files",
        "post_clone_handoff",
        "linked_review_incident_or_work_item",
        "restored_layout_with_placeholders",
        "import_compare_or_restore_sheet",
        "generic_shell_with_diagnostics",
        "nested_root_choice_sheet"
      ]
    },
    "clone_depth_class": {
      "type": "string",
      "enum": [
        "full_history",
        "shallow_depth",
        "partial_clone_filtered",
        "mirror_first",
        "offline_bundle"
      ]
    },
    "ref_choice": {
      "type": "string",
      "enum": [
        "default_branch",
        "user_selected_branch",
        "user_selected_ref",
        "unresolved_until_remote_query"
      ]
    },
    "submodule_posture": {
      "type": "string",
      "enum": [
        "not_requested",
        "detect_only",
        "user_requested"
      ]
    },
    "lfs_posture": {
      "type": "string",
      "enum": [
        "not_requested",
        "detect_only",
        "user_requested_hydration"
      ]
    },
    "cleanup_posture": {
      "type": "string",
      "enum": [
        "no_cleanup_required",
        "retain_labelled_staging",
        "cleanup_after_reviewed_success",
        "manual_cleanup_may_be_required"
      ]
    },
    "lossy_mapping_class": {
      "type": "string",
      "enum": [
        "no_lossy_mapping",
        "lossy_with_review",
        "schema_migrated_compatible",
        "competitor_mapping_partial",
        "manual_review_required",
        "unknown_until_inspection"
      ]
    },
    "collision_class": {
      "type": "string",
      "enum": [
        "no_collision",
        "existing_path_non_empty",
        "existing_repo_root",
        "nested_repository",
        "existing_worktree",
        "existing_workspace_manifest",
        "duplicate_clone_target",
        "destination_blocked_by_policy"
      ]
    },
    "project_entry_review_record": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "record_kind",
        "entry_review_schema_version",
        "entry_review_id",
        "source_surface",
        "entry_verb",
        "target_kind",
        "resulting_mode",
        "vocabulary_review",
        "review_sheet",
        "post_entry_handoff_card",
        "failure_repair_state",
        "surface_parity",
        "admission_review_packet",
        "admission_checkpoint_route",
        "summary"
      ],
      "properties": {
        "record_kind": { "const": "project_entry_review_record" },
        "entry_review_schema_version": { "$ref": "#/$defs/entry_review_schema_version" },
        "entry_review_id": { "$ref": "#/$defs/opaque_id" },
        "source_surface": { "$ref": "#/$defs/source_surface" },
        "entry_verb": { "$ref": "#/$defs/entry_verb" },
        "target_kind": { "$ref": "#/$defs/target_kind" },
        "resulting_mode": { "$ref": "#/$defs/resulting_mode" },
        "vocabulary_review": { "$ref": "#/$defs/vocabulary_review" },
        "review_sheet": { "$ref": "#/$defs/review_sheet" },
        "destination_collision_review": { "$ref": "#/$defs/destination_collision_review" },
        "post_entry_handoff_card": { "$ref": "#/$defs/post_entry_handoff_card" },
        "failure_repair_state": { "$ref": "#/$defs/failure_repair_state" },
        "surface_parity": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_parity" }
        },
        "admission_review_packet": {
          "type": "object",
          "description": "AdmissionReviewPacket serialized by aureline-workspace."
        },
        "admission_checkpoint_route": {
          "type": "object",
          "description": "AdmissionCheckpointRouteRecord serialized by aureline-workspace."
        },
        "summary": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "vocabulary_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_access_class",
        "source_label",
        "trust_label",
        "destination_label",
        "write_scope_label",
        "next_step_label"
      ],
      "properties": {
        "source_access_class": { "$ref": "#/$defs/source_access_class" },
        "source_label": { "$ref": "#/$defs/redaction_aware_text" },
        "trust_label": { "$ref": "#/$defs/redaction_aware_text" },
        "destination_label": { "$ref": "#/$defs/redaction_aware_text" },
        "write_scope_label": { "$ref": "#/$defs/redaction_aware_text" },
        "next_step_label": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "review_sheet": {
      "type": "object",
      "additionalProperties": true,
      "required": ["review_sheet_kind"],
      "properties": {
        "review_sheet_kind": { "$ref": "#/$defs/review_sheet_kind" },
        "open_review": { "type": "object" },
        "open_workspace_review": { "type": "object" },
        "clone_review": { "type": "object" },
        "add_root_review": { "type": "object" },
        "import_review": { "type": "object" },
        "restore_review": { "type": "object" }
      }
    },
    "destination_collision_review": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "collision_class",
        "existing_target_label",
        "requires_explicit_choice",
        "safe_actions",
        "summary"
      ],
      "properties": {
        "collision_class": { "$ref": "#/$defs/collision_class" },
        "existing_target_label": { "$ref": "#/$defs/redaction_aware_text" },
        "requires_explicit_choice": { "type": "boolean" },
        "explicit_overwrite_required": { "type": "boolean" },
        "safe_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "reuse_existing",
              "add_existing_as_root",
              "clone_elsewhere",
              "reveal",
              "inspect_only",
              "cancel"
            ]
          }
        },
        "previously_cloned_target_ref": { "$ref": "#/$defs/opaque_id" },
        "summary": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "post_entry_handoff_card": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "handoff_card_id",
        "target_label",
        "not_yet_done",
        "primary_next_action",
        "safe_alternate_actions",
        "export_or_share_state_available",
        "summary"
      ],
      "properties": {
        "handoff_card_id": { "$ref": "#/$defs/opaque_id" },
        "target_label": { "$ref": "#/$defs/redaction_aware_text" },
        "not_yet_done": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "trust_grant",
              "dependency_restore",
              "task_execution",
              "hook_execution",
              "extension_or_bundle_install",
              "state_rehydration",
              "durable_promotion",
              "runtime_attach",
              "credential_admission"
            ]
          }
        },
        "primary_next_action": { "$ref": "#/$defs/admission_action" },
        "safe_alternate_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/admission_action" }
        },
        "export_or_share_state_available": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "failure_repair_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "typed_source_input_preserved",
        "chosen_destination_preserved",
        "redacted_diagnostics_preserved",
        "source_input_label",
        "destination_label",
        "redacted_diagnostic_summary",
        "repair_actions"
      ],
      "properties": {
        "typed_source_input_preserved": { "type": "boolean", "const": true },
        "chosen_destination_preserved": { "type": "boolean", "const": true },
        "redacted_diagnostics_preserved": { "type": "boolean", "const": true },
        "source_input_label": { "$ref": "#/$defs/redaction_aware_text" },
        "destination_label": { "$ref": "#/$defs/redaction_aware_text" },
        "redacted_diagnostic_summary": { "$ref": "#/$defs/redaction_aware_text" },
        "repair_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/admission_action" }
        }
      }
    },
    "surface_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_surface",
        "entry_verb",
        "target_kind",
        "resulting_mode",
        "review_requirement",
        "same_review_model",
        "summary"
      ],
      "properties": {
        "source_surface": { "$ref": "#/$defs/source_surface" },
        "entry_verb": { "$ref": "#/$defs/entry_verb" },
        "target_kind": { "$ref": "#/$defs/target_kind" },
        "resulting_mode": { "$ref": "#/$defs/resulting_mode" },
        "review_requirement": {
          "type": "string",
          "enum": [
            "target_review_required",
            "trust_review_required",
            "destination_collision_review_required",
            "import_compare_required",
            "restore_review_required",
            "deep_link_intent_review_required",
            "no_review_required"
          ]
        },
        "same_review_model": { "type": "boolean", "const": true },
        "summary": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "entry_review_case_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "entry_review_case_schema_version",
        "case_id",
        "request",
        "expect"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "record_kind": { "const": "entry_review_case_record" },
        "entry_review_case_schema_version": { "$ref": "#/$defs/entry_review_case_schema_version" },
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "request": { "$ref": "#/$defs/entry_review_case_request" },
        "expect": { "$ref": "#/$defs/entry_review_case_expectation" }
      }
    },
    "entry_review_case_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_surface",
        "entry_verb",
        "target_kind",
        "resulting_mode",
        "target_specifier"
      ],
      "properties": {
        "source_surface": { "$ref": "#/$defs/source_surface" },
        "entry_verb": { "$ref": "#/$defs/entry_verb" },
        "target_kind": { "$ref": "#/$defs/target_kind" },
        "resulting_mode": { "$ref": "#/$defs/resulting_mode" },
        "target_specifier": { "$ref": "#/$defs/redaction_aware_text" },
        "destination": { "$ref": "#/$defs/redaction_aware_text" },
        "active_workspace_label": { "$ref": "#/$defs/redaction_aware_text" },
        "network_route_label": { "$ref": "#/$defs/redaction_aware_text" },
        "clone_options": { "$ref": "#/$defs/clone_options" },
        "import_options": { "$ref": "#/$defs/import_options" },
        "destination_facts": { "$ref": "#/$defs/destination_facts" },
        "failed_diagnostic_text": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "clone_options": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch_or_ref_label",
        "ref_choice",
        "clone_depth_class",
        "submodule_posture",
        "lfs_posture"
      ],
      "properties": {
        "branch_or_ref_label": { "$ref": "#/$defs/redaction_aware_text" },
        "ref_choice": { "$ref": "#/$defs/ref_choice" },
        "clone_depth_class": { "$ref": "#/$defs/clone_depth_class" },
        "partial_filter_label": { "$ref": "#/$defs/redaction_aware_text" },
        "submodule_posture": { "$ref": "#/$defs/submodule_posture" },
        "lfs_posture": { "$ref": "#/$defs/lfs_posture" },
        "post_clone_action": { "$ref": "#/$defs/admission_action" }
      }
    },
    "import_options": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_or_version_label",
        "lossy_mapping_class",
        "machine_local_exclusions",
        "cleanup_posture"
      ],
      "properties": {
        "schema_or_version_label": { "$ref": "#/$defs/redaction_aware_text" },
        "lossy_mapping_class": { "$ref": "#/$defs/lossy_mapping_class" },
        "machine_local_exclusions": {
          "type": "array",
          "items": { "$ref": "#/$defs/redaction_aware_text" }
        },
        "cleanup_posture": { "$ref": "#/$defs/cleanup_posture" }
      }
    },
    "destination_facts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "previously_cloned_target_ref": { "$ref": "#/$defs/opaque_id" },
        "policy_blocked": { "type": "boolean" }
      }
    },
    "entry_review_case_expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_sheet_kind",
        "source_access_class",
        "first_useful_entry_source",
        "landing_surface",
        "primary_next_action"
      ],
      "properties": {
        "review_sheet_kind": { "$ref": "#/$defs/review_sheet_kind" },
        "collision_class": { "$ref": "#/$defs/collision_class" },
        "source_access_class": { "$ref": "#/$defs/source_access_class" },
        "first_useful_entry_source": { "$ref": "#/$defs/first_useful_entry_source" },
        "landing_surface": { "$ref": "#/$defs/landing_surface" },
        "primary_next_action": { "$ref": "#/$defs/admission_action" }
      }
    }
  }
}
