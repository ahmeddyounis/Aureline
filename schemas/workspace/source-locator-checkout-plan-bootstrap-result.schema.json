{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/source-locator-checkout-plan-bootstrap-result.schema.json",
  "title": "Aureline stable project-entry acquisition truth",
  "description": "Stable M4 contract binding source-locator, checkout-plan, bootstrap credential descriptor, bootstrap result, and individually attributable bootstrap-queue items. This packet is shared by desktop, CLI/headless, deep-link, restore, diagnostics, Help/About, migration, and support-export paths so clone/open/import/add-root/restore outcomes preserve provenance, partial authority, mirror/offline posture, resumability, and remaining setup work without serializing raw secrets or raw unredacted paths.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "schema_ref",
    "surface",
    "source_locator",
    "checkout_plan",
    "credential_descriptor",
    "bootstrap_result",
    "bootstrap_queue",
    "review_required_before_acquisition",
    "default_support_export_safe"
  ],
  "properties": {
    "record_kind": { "const": "source_locator_checkout_plan_bootstrap_result_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "schema_ref": { "const": "schemas/workspace/source-locator-checkout-plan-bootstrap-result.schema.json" },
    "surface": { "$ref": "#/$defs/acquisition_surface" },
    "source_locator": { "$ref": "#/$defs/source_locator" },
    "checkout_plan": { "$ref": "#/$defs/checkout_plan" },
    "credential_descriptor": { "$ref": "#/$defs/credential_descriptor" },
    "bootstrap_result": { "$ref": "#/$defs/bootstrap_result" },
    "bootstrap_queue": {
      "type": "array",
      "items": { "$ref": "#/$defs/bootstrap_queue_item" }
    },
    "review_required_before_acquisition": { "type": "boolean" },
    "default_support_export_safe": { "type": "boolean", "const": true }
  },
  "$defs": {
    "opaque_ref": { "type": "string", "minLength": 1 },
    "acquisition_surface": {
      "type": "string",
      "enum": ["start_center", "command_palette", "deep_link", "cli_headless", "policy_guided_deployment", "support"]
    },
    "locator_kind": {
      "type": "string",
      "enum": ["local_folder", "local_file", "workspace_file_manifest", "workset_manifest", "repo_url", "mirror_or_proxy_repo", "snapshot_archive", "template", "prebuild_snapshot", "live_resume_target", "handoff_packet", "portable_state_package", "recovery_checkpoint", "review_or_work_item_deep_link"]
    },
    "transport_class": {
      "type": "string",
      "enum": ["local_filesystem", "https", "ssh", "git_protocol", "sftp", "mirror", "proxy", "air_gapped_media", "aureline_remote", "managed_cloud", "devcontainer_runtime", "container_runtime", "file_upload", "deep_link_handoff", "other"]
    },
    "auth_mode": {
      "type": "string",
      "enum": ["ssh_agent", "pat_handle", "oauth_handle", "device_code_handle", "managed_session_ticket", "connected_provider_ticket", "anonymous", "inherit_local_identity", "none", "other"]
    },
    "trust_seed_hint": {
      "type": "string",
      "enum": ["continuous_with_previous_acquisition", "new_signer_first_seen", "signer_changed_trust_on_first_use", "signer_changed_review_required", "signer_rotation_preauthorized", "unsigned", "signature_missing", "signature_mismatch", "not_applicable"]
    },
    "source_locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_locator_ref", "locator_kind", "canonical_target_ref", "forge_or_mirror_class", "trust_seed_hint"],
      "properties": {
        "source_locator_ref": { "$ref": "#/$defs/opaque_ref" },
        "locator_kind": { "$ref": "#/$defs/locator_kind" },
        "canonical_target_ref": { "$ref": "#/$defs/opaque_ref" },
        "forge_or_mirror_class": { "type": "string", "enum": ["local", "forge", "mirror", "proxy", "offline_media", "managed_workspace", "imported_artifact", "deep_link"] },
        "protocol": { "$ref": "#/$defs/transport_class" },
        "target_ref_intent": { "type": "string", "minLength": 1 },
        "auth_source_class": { "$ref": "#/$defs/auth_mode" },
        "trust_seed_hint": { "$ref": "#/$defs/trust_seed_hint" }
      }
    },
    "checkout_mode": {
      "type": "string",
      "enum": ["full_checkout", "partial_clone", "sparse_checkout", "shallow_history", "archive_extract", "live_attach", "not_applicable"]
    },
    "checkout_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkout_plan_ref", "destination_ref", "checkout_mode", "clone_depth_filter", "submodule_mode", "lfs_mode", "estimated_cost_band"],
      "properties": {
        "checkout_plan_ref": { "$ref": "#/$defs/opaque_ref" },
        "destination_ref": { "$ref": "#/$defs/opaque_ref" },
        "checkout_mode": { "$ref": "#/$defs/checkout_mode" },
        "clone_depth_filter": { "type": "string", "enum": ["full_history", "shallow_depth", "partial_filter", "sparse_profile", "not_applicable"] },
        "depth_or_filter_label": { "type": "string" },
        "sparse_profile_ref": { "$ref": "#/$defs/opaque_ref" },
        "submodule_mode": { "type": "string", "enum": ["not_present", "init_pending", "init_partial", "init_complete", "init_failed"] },
        "lfs_mode": { "type": "string", "enum": ["not_present", "pointer_only", "hydrate_pending", "hydrate_partial", "hydrate_complete", "hydrate_failed"] },
        "estimated_cost_band": { "type": "string", "enum": ["local_no_fetch", "metered_fetch", "large_fetch_or_hydrate", "live_attach", "unknown"] },
        "resumability_token": { "$ref": "#/$defs/opaque_ref" },
        "policy_or_mirror_constraints": { "type": "array", "items": { "$ref": "#/$defs/opaque_ref" } }
      }
    },
    "credential_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delegated_auth_mode", "host_key_or_tls_posture", "offline_fallback_rule", "reauth_required", "raw_secret_present"],
      "properties": {
        "delegated_auth_mode": { "type": "string", "enum": ["no_credentials_needed", "local_identity_inherited", "handle_present_not_yet_used", "browser_or_device_handoff_pending", "provider_ticket_required", "reauth_required", "unknown"] },
        "auth_source_class": { "$ref": "#/$defs/auth_mode" },
        "credential_handle_ref": { "$ref": "#/$defs/opaque_ref" },
        "approval_ticket_ref": { "$ref": "#/$defs/opaque_ref" },
        "proxy_or_mirror_route_ref": { "$ref": "#/$defs/opaque_ref" },
        "host_key_or_tls_posture": { "type": "string", "enum": ["verified", "inherited_local", "review_required", "not_applicable", "unknown"] },
        "offline_fallback_rule": { "type": "string", "enum": ["not_needed", "use_current_bundle", "refresh_mirror_required", "fail_closed"] },
        "reauth_required": { "type": "boolean" },
        "raw_secret_present": { "type": "boolean", "const": false }
      }
    },
    "bootstrap_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome_lineage", "completion_state", "resulting_roots", "warnings", "evidence_refs", "next_step_queue_refs", "trust_stage", "partial_authority"],
      "properties": {
        "outcome_lineage": { "type": "array", "minItems": 1, "items": { "type": "string", "enum": ["opened", "acquired", "mirrored", "imported", "resumed", "partially_acquired", "deep_link_pending", "policy_blocked"] } },
        "completion_state": { "type": "string", "enum": ["not_started", "in_progress", "interrupted", "completed", "aborted", "partial_authority"] },
        "resulting_roots": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/resulting_root" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_ref" } },
        "next_step_queue_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_ref" } },
        "trust_stage": { "type": "string" },
        "partial_authority": { "type": "boolean" }
      }
    },
    "resulting_root": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root_ref", "authority_class", "browse_safe_only"],
      "properties": {
        "root_ref": { "$ref": "#/$defs/opaque_ref" },
        "root_class": { "type": "string" },
        "authority_class": { "type": "string", "enum": ["full_authority", "partial_read_only", "imported_read_only", "virtual_authority"] },
        "browse_safe_only": { "type": "boolean" }
      }
    },
    "bootstrap_queue_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_ref", "item_kind", "scope_ref", "approval_state", "resumable", "evidence_ref", "cancelable", "reviewable"],
      "properties": {
        "item_ref": { "$ref": "#/$defs/opaque_ref" },
        "item_kind": { "type": "string" },
        "scope_ref": { "$ref": "#/$defs/opaque_ref" },
        "approval_state": { "type": "string", "enum": ["approved_or_complete", "awaiting_trust_admission", "awaiting_policy", "awaiting_user_action", "policy_blocked", "blocked_recoverable", "cancelled", "reviewable"] },
        "resumable": { "type": "boolean" },
        "evidence_ref": { "$ref": "#/$defs/opaque_ref" },
        "expiry_ref": { "$ref": "#/$defs/opaque_ref" },
        "cancelable": { "type": "boolean" },
        "reviewable": { "type": "boolean" }
      }
    }
  }
}
