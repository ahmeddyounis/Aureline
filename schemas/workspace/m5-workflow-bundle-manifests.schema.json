{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/m5-workflow-bundle-manifests.schema.json",
  "title": "Aureline M5 workflow-bundle manifests packet",
  "description": "Schema for the m5_workflow_bundle_manifests_packet. The packet carries one or more versioned workflow-bundle manifests per M5 launch wedge. Each manifest captures the minimum cohesive experience for a named persona, stack, and archetype as a single diffable component list spanning extension sets, profile and layout and settings presets, task/launch/debug recipes, docs and tour packs, template and scaffold references, and migration mappings. Each component records its lifecycle stage (stable, preview, labs, policy-gated, mirror-only, or bounded-platform); any non-stable component is review-gated and rolled up into the manifest's dependency markers, and a manifest depending on a non-stable capability must disclose it. Every manifest and component stays diffable, and opaque binary bundle state is forbidden; manifests are mirrorable and export-safe. A draft manifest may only claim a local-draft certification target, only a certified target presents as certified, every wedge must be covered, and the summary must equal the recomputed summary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "bundle_identity_scheme",
    "wedges",
    "component_kinds",
    "lifecycle_stages",
    "certification_targets",
    "publication_states",
    "manifests",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_workflow_bundle_manifests_packet" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "bundle_identity_scheme": { "$ref": "#/$defs/non_empty_string" },
    "wedges": { "type": "array", "items": { "$ref": "#/$defs/wedge" } },
    "component_kinds": { "type": "array", "items": { "$ref": "#/$defs/component_kind" } },
    "lifecycle_stages": { "type": "array", "items": { "$ref": "#/$defs/lifecycle_stage" } },
    "certification_targets": {
      "type": "array",
      "items": { "$ref": "#/$defs/certification_target" }
    },
    "publication_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/publication_state" }
    },
    "manifests": { "type": "array", "items": { "$ref": "#/$defs/manifest" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "wedge": {
      "enum": [
        "notebook_workspace",
        "data_and_api_workspace",
        "profiler_workspace",
        "framework_pack_workspace",
        "docs_workspace",
        "companion_workspace",
        "sync_handoff_workspace",
        "local_folder_workspace"
      ]
    },
    "component_kind": {
      "enum": [
        "extension",
        "profile_preset",
        "layout_preset",
        "settings_preset",
        "task_recipe",
        "launch_recipe",
        "debug_recipe",
        "docs_pack",
        "tour_pack",
        "template_ref",
        "scaffold_ref",
        "migration_mapping"
      ]
    },
    "lifecycle_stage": {
      "enum": [
        "stable",
        "preview",
        "labs",
        "policy_gated",
        "mirror_only",
        "bounded_platform"
      ]
    },
    "certification_target": {
      "enum": [
        "certified",
        "managed_approved",
        "community_reviewed",
        "imported_pending_review",
        "local_draft"
      ]
    },
    "publication_state": {
      "enum": ["draft", "published", "deprecated"]
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_kind",
        "component_id",
        "lifecycle_stage",
        "requires_review",
        "diffable",
        "label",
        "component_ref"
      ],
      "properties": {
        "component_kind": { "$ref": "#/$defs/component_kind" },
        "component_id": { "$ref": "#/$defs/non_empty_string" },
        "lifecycle_stage": { "$ref": "#/$defs/lifecycle_stage" },
        "requires_review": { "type": "boolean" },
        "diffable": { "const": true },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "component_ref": { "$ref": "#/$defs/non_empty_string" },
        "migration_from": { "$ref": "#/$defs/non_empty_string" },
        "migration_to": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_id",
        "bundle_version",
        "wedge",
        "persona",
        "stack",
        "archetype",
        "publication_state",
        "certification_target",
        "components",
        "dependency_markers",
        "discloses_non_stable_dependencies",
        "diffable",
        "mirrorable",
        "export_safe",
        "opaque_binary_state",
        "manifest_provenance_ref",
        "certification_evidence_ref",
        "migration_provenance_ref",
        "owner",
        "start_center_ref",
        "migration_center_ref",
        "bundle_detail_ref",
        "diagnostics_ref",
        "support_export_ref",
        "help_surface_ref",
        "release_evidence_ref",
        "note"
      ],
      "properties": {
        "bundle_id": { "$ref": "#/$defs/non_empty_string" },
        "bundle_version": { "$ref": "#/$defs/non_empty_string" },
        "wedge": { "$ref": "#/$defs/wedge" },
        "persona": { "$ref": "#/$defs/non_empty_string" },
        "stack": { "$ref": "#/$defs/non_empty_string" },
        "archetype": { "$ref": "#/$defs/non_empty_string" },
        "publication_state": { "$ref": "#/$defs/publication_state" },
        "certification_target": { "$ref": "#/$defs/certification_target" },
        "components": { "type": "array", "items": { "$ref": "#/$defs/component" } },
        "dependency_markers": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_stage" }
        },
        "discloses_non_stable_dependencies": { "type": "boolean" },
        "diffable": { "const": true },
        "mirrorable": { "const": true },
        "export_safe": { "const": true },
        "opaque_binary_state": { "const": false },
        "manifest_provenance_ref": { "$ref": "#/$defs/non_empty_string" },
        "certification_evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "migration_provenance_ref": { "$ref": "#/$defs/non_empty_string" },
        "owner": { "$ref": "#/$defs/non_empty_string" },
        "caveats": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "start_center_ref": { "$ref": "#/$defs/non_empty_string" },
        "migration_center_ref": { "$ref": "#/$defs/non_empty_string" },
        "bundle_detail_ref": { "$ref": "#/$defs/non_empty_string" },
        "diagnostics_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
        "help_surface_ref": { "$ref": "#/$defs/non_empty_string" },
        "release_evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_manifests",
        "manifest_count",
        "certified_target_manifests",
        "managed_approved_target_manifests",
        "community_reviewed_target_manifests",
        "imported_pending_review_target_manifests",
        "local_draft_target_manifests",
        "published_manifests",
        "draft_manifests",
        "deprecated_manifests",
        "manifests_with_non_stable_dependencies",
        "manifests_disclosing_non_stable",
        "total_components",
        "extension_components",
        "recipe_components",
        "docs_or_tour_components",
        "template_or_scaffold_components",
        "migration_mapping_components",
        "non_stable_components",
        "review_required_components"
      ],
      "properties": {
        "total_manifests": { "type": "integer", "minimum": 0 },
        "manifest_count": { "type": "integer", "minimum": 0 },
        "certified_target_manifests": { "type": "integer", "minimum": 0 },
        "managed_approved_target_manifests": { "type": "integer", "minimum": 0 },
        "community_reviewed_target_manifests": { "type": "integer", "minimum": 0 },
        "imported_pending_review_target_manifests": { "type": "integer", "minimum": 0 },
        "local_draft_target_manifests": { "type": "integer", "minimum": 0 },
        "published_manifests": { "type": "integer", "minimum": 0 },
        "draft_manifests": { "type": "integer", "minimum": 0 },
        "deprecated_manifests": { "type": "integer", "minimum": 0 },
        "manifests_with_non_stable_dependencies": { "type": "integer", "minimum": 0 },
        "manifests_disclosing_non_stable": { "type": "integer", "minimum": 0 },
        "total_components": { "type": "integer", "minimum": 0 },
        "extension_components": { "type": "integer", "minimum": 0 },
        "recipe_components": { "type": "integer", "minimum": 0 },
        "docs_or_tour_components": { "type": "integer", "minimum": 0 },
        "template_or_scaffold_components": { "type": "integer", "minimum": 0 },
        "migration_mapping_components": { "type": "integer", "minimum": 0 },
        "non_stable_components": { "type": "integer", "minimum": 0 },
        "review_required_components": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
