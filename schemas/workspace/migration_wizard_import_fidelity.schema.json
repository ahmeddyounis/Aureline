{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/migration_wizard_import_fidelity.schema.json",
  "title": "Aureline migration-wizard import-fidelity packet (workspace lane)",
  "description": "Boundary schema for the stabilized migration-wizard import-fidelity contract. Every imported setting, keybinding, snippet, theme, and workflow hint from VS Code / Code-OSS, JetBrains family, Vim / Neovim, and Emacs maps to an Aureline-native record with an explicit outcome label: exact, translated, partial, shimmed, or unsupported. Rollback checkpoints and diagnostics are preserved when mapping fails.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "migration_session_ref",
    "fidelity_record",
    "editor_launch_paths",
    "commands",
    "support_export",
    "inspection",
    "consumer_surfaces"
  ],
  "properties": {
    "record_kind": { "const": "workspace_migration_wizard_import_fidelity_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "migration_session_ref": { "type": "string", "minLength": 1 },
    "fidelity_record": { "$ref": "#/$defs/fidelity_record" },
    "editor_launch_paths": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/editor_launch_path_record" }
    },
    "commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/command_record" }
    },
    "support_export": { "$ref": "#/$defs/support_export_packet" },
    "inspection": { "$ref": "#/$defs/inspection_record" },
    "consumer_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["migration_center", "entry_surface", "first_run_wizard", "support_export", "audit_lane", "cli_inspector"] }
    }
  },
  "$defs": {
    "opaque_id": { "type": "string", "minLength": 1 },
    "non_empty_string": { "type": "string", "minLength": 1 },
    "reviewable_sentence": { "type": "string", "minLength": 1, "maxLength": 512 },
    "source_editor": {
      "type": "string",
      "enum": ["vs_code_code_oss", "jetbrains_family", "vim_neovim", "emacs"]
    },
    "import_target_family": {
      "type": "string",
      "enum": [
        "settings",
        "keybindings",
        "snippets",
        "tasks",
        "launch_configs",
        "themes",
        "compatible_extensions",
        "selected_run_debug_configs",
        "project_roots",
        "code_style_hints",
        "modal_editing_profiles",
        "command_aliases",
        "clipboard_search_defaults",
        "syntax_bundles",
        "project_defaults",
        "selected_build_task_hints",
        "workspace_metadata"
      ]
    },
    "outcome_label": {
      "type": "string",
      "enum": ["exact", "translated", "partial", "shimmed", "unsupported"]
    },
    "launch_path_state": {
      "type": "string",
      "enum": ["preview_pending", "preview_approved", "checkpoint_pending", "checkpoint_captured", "applied", "validated", "rolled_back", "aborted"]
    },
    "checkpoint_state": {
      "type": "string",
      "enum": ["none_required", "captured_ready", "captured_pending", "restored", "expired", "missing_blocks_apply"]
    },
    "command_class": {
      "type": "string",
      "enum": ["preview", "approve", "capture_checkpoint", "apply", "validate", "rollback", "abort", "review_diagnostics"]
    },
    "diagnostic_reason_class": {
      "type": "string",
      "enum": ["no_semantic_equivalent", "ambiguous_mapping", "secret_material_excluded", "policy_locked", "capability_missing", "version_mismatch", "corrupted_source", "partial_schema_match"]
    },
    "diagnostic_action_class": {
      "type": "string",
      "enum": ["manual_review", "use_bridge", "use_native_alternative", "skip_and_continue", "rollback_and_repair", "contact_support"]
    },
    "fidelity_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_id", "migration_session_ref", "source_editor", "overall_outcome", "target_families", "rollback_checkpoint_ref"],
      "properties": {
        "record_id": { "$ref": "#/$defs/opaque_id" },
        "migration_session_ref": { "$ref": "#/$defs/opaque_id" },
        "source_editor": { "$ref": "#/$defs/source_editor" },
        "overall_outcome": { "$ref": "#/$defs/outcome_label" },
        "target_families": {
          "type": "array",
          "items": { "$ref": "#/$defs/import_target_family" }
        },
        "rollback_checkpoint_ref": { "$ref": "#/$defs/opaque_id" },
        "validation_state": {
          "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
        }
      }
    },
    "editor_launch_path_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_id", "source_editor", "source_editor_label", "launch_path_state", "rollback_checkpoint", "selected_target_families", "outcome_breakdown", "requires_browser_handoff", "requires_manual_review", "actionable"],
      "properties": {
        "record_id": { "$ref": "#/$defs/opaque_id" },
        "source_editor": { "$ref": "#/$defs/source_editor" },
        "source_editor_label": { "$ref": "#/$defs/non_empty_string" },
        "launch_path_state": { "$ref": "#/$defs/launch_path_state" },
        "rollback_checkpoint": { "$ref": "#/$defs/rollback_checkpoint_record" },
        "selected_target_families": {
          "type": "array",
          "items": { "$ref": "#/$defs/import_target_family" }
        },
        "outcome_breakdown": {
          "type": "array",
          "items": { "$ref": "#/$defs/target_family_outcome" }
        },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/import_mapping_diagnostic_record" }
        },
        "requires_browser_handoff": { "type": "boolean" },
        "requires_manual_review": { "type": "boolean" },
        "actionable": { "type": "boolean" }
      }
    },
    "rollback_checkpoint_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkpoint_id", "checkpoint_state", "source_editor", "auto_restore_available"],
      "properties": {
        "checkpoint_id": { "$ref": "#/$defs/opaque_id" },
        "checkpoint_state": { "$ref": "#/$defs/checkpoint_state" },
        "source_editor": { "$ref": "#/$defs/source_editor" },
        "captured_at": {
          "oneOf": [{ "type": "null" }, { "type": "string", "format": "date-time" }]
        },
        "expires_at": {
          "oneOf": [{ "type": "null" }, { "type": "string", "format": "date-time" }]
        },
        "checkpoint_artifact_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_id" }]
        },
        "auto_restore_available": { "type": "boolean" }
      }
    },
    "target_family_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_family", "exact_count", "translated_count", "partial_count", "shimmed_count", "unsupported_count", "total_count"],
      "properties": {
        "target_family": { "$ref": "#/$defs/import_target_family" },
        "exact_count": { "type": "integer", "minimum": 0 },
        "translated_count": { "type": "integer", "minimum": 0 },
        "partial_count": { "type": "integer", "minimum": 0 },
        "shimmed_count": { "type": "integer", "minimum": 0 },
        "unsupported_count": { "type": "integer", "minimum": 0 },
        "total_count": { "type": "integer", "minimum": 0 }
      }
    },
    "import_mapping_diagnostic_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["diagnostic_id", "source_editor", "import_target_family", "source_item_id", "outcome_label", "message", "fallback_available"],
      "properties": {
        "diagnostic_id": { "$ref": "#/$defs/opaque_id" },
        "source_editor": { "$ref": "#/$defs/source_editor" },
        "import_target_family": { "$ref": "#/$defs/import_target_family" },
        "source_item_id": { "$ref": "#/$defs/non_empty_string" },
        "outcome_label": { "$ref": "#/$defs/outcome_label" },
        "reason_class": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/diagnostic_reason_class" }]
        },
        "message": { "$ref": "#/$defs/reviewable_sentence" },
        "suggested_action": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/diagnostic_action_class" }]
        },
        "fallback_available": { "type": "boolean" },
        "compatibility_scorecard_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_id" }]
        }
      }
    },
    "command_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_id", "command_class", "target_editor", "available"],
      "properties": {
        "command_id": { "$ref": "#/$defs/opaque_id" },
        "command_class": { "$ref": "#/$defs/command_class" },
        "target_editor": { "$ref": "#/$defs/non_empty_string" },
        "available": { "type": "boolean" },
        "unavailable_reason": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/reviewable_sentence" }]
        },
        "side_effects": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "support_export_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "record_kind", "packet_id", "generated_at", "editor_summaries", "overall_outcome_summary", "consumer_surfaces", "raw_source_profile_paths_export_allowed", "raw_source_profile_bodies_export_allowed", "secret_bearing_values_export_allowed"],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "record_kind": { "const": "workspace_migration_wizard_import_fidelity_support_export_packet" },
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "generated_at": { "type": "string", "format": "date-time" },
        "editor_summaries": {
          "type": "array",
          "items": { "$ref": "#/$defs/editor_launch_path_summary" }
        },
        "overall_outcome_summary": { "$ref": "#/$defs/non_empty_string" },
        "consumer_surfaces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "raw_source_profile_paths_export_allowed": { "type": "boolean", "const": false },
        "raw_source_profile_bodies_export_allowed": { "type": "boolean", "const": false },
        "secret_bearing_values_export_allowed": { "type": "boolean", "const": false }
      }
    },
    "editor_launch_path_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_editor", "source_editor_label", "launch_path_state", "checkpoint_state", "overall_outcome", "diagnostic_count", "manual_review_count"],
      "properties": {
        "source_editor": { "$ref": "#/$defs/source_editor" },
        "source_editor_label": { "$ref": "#/$defs/non_empty_string" },
        "launch_path_state": { "type": "string", "minLength": 1 },
        "checkpoint_state": { "type": "string", "minLength": 1 },
        "overall_outcome": { "type": "string", "minLength": 1 },
        "diagnostic_count": { "type": "integer", "minimum": 0 },
        "manual_review_count": { "type": "integer", "minimum": 0 }
      }
    },
    "inspection_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_id", "previewable", "checkpoint_ready", "applied", "validated", "rolled_back", "aborted", "manual_review_required", "browser_handoff_required", "unsupported_encountered", "partial_encountered", "shimmed_encountered", "editor_launch_path_count", "available_command_count", "diagnostic_count", "consumer_surfaces"],
      "properties": {
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "previewable": { "type": "boolean" },
        "checkpoint_ready": { "type": "boolean" },
        "applied": { "type": "boolean" },
        "validated": { "type": "boolean" },
        "rolled_back": { "type": "boolean" },
        "aborted": { "type": "boolean" },
        "manual_review_required": { "type": "boolean" },
        "browser_handoff_required": { "type": "boolean" },
        "unsupported_encountered": { "type": "boolean" },
        "partial_encountered": { "type": "boolean" },
        "shimmed_encountered": { "type": "boolean" },
        "editor_launch_path_count": { "type": "integer", "minimum": 0 },
        "available_command_count": { "type": "integer", "minimum": 0 },
        "diagnostic_count": { "type": "integer", "minimum": 0 },
        "consumer_surfaces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
