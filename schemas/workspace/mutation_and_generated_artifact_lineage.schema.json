{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/mutation_and_generated_artifact_lineage.schema.json",
  "title": "Aureline mutation-journal and generated-artifact lineage",
  "description": "Boundary schema for the governed, export-safe mutation / generated-artifact lineage record. The record proves how Aureline tracks mutations across editor, formatter, AI, build, lockfile, and preview paths and how it labels the generated and mirrored artifacts those paths produce. It is projected verbatim from the live MutationAndGeneratedArtifactInputs envelope. It proves mutation-path coverage, generated-artifact coverage, canonical-lineage truth (source ref, generator identity, output digest), drift truth, edit-posture honesty (only round-trip-safe artifact classes may declare round_trip_safe; diverged-from-generator artifacts reference override + recovery disclosures), labeling-surface coverage across tree/breadcrumb/search/review/AI-context/save/support, mutation no-rerun honesty (privileged paths declare explicit_user_action_required or terminal_no_further_run with action + disclosure ids), and support-export honesty. Raw payload bytes are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "mutation_and_generated_artifact_lineage_schema_version",
    "schema_ref",
    "posture_id",
    "workspace_ref",
    "corpus_ref",
    "producer_attribution",
    "mutation_path_coverage",
    "generated_artifact_coverage",
    "canonical_lineage_truth",
    "drift_truth",
    "edit_posture_honesty",
    "labeling_surface_coverage",
    "mutation_no_rerun_honesty",
    "support_export_honesty",
    "inspection_hooks",
    "stable_qualification",
    "raw_payload_excluded",
    "summary"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": { "const": "mutation_and_generated_artifact_lineage_record" },
    "mutation_and_generated_artifact_lineage_schema_version": { "type": "integer", "const": 1 },
    "schema_ref": { "const": "schemas/workspace/mutation_and_generated_artifact_lineage.schema.json" },
    "posture_id": { "$ref": "#/$defs/non_empty_string" },
    "workspace_ref": { "$ref": "#/$defs/non_empty_string" },
    "corpus_ref": { "$ref": "#/$defs/non_empty_string" },
    "producer_attribution": { "$ref": "#/$defs/producer_attribution_summary" },
    "mutation_path_coverage": { "$ref": "#/$defs/mutation_path_coverage_summary" },
    "generated_artifact_coverage": { "$ref": "#/$defs/generated_artifact_coverage_summary" },
    "canonical_lineage_truth": { "$ref": "#/$defs/canonical_lineage_truth_summary" },
    "drift_truth": { "$ref": "#/$defs/drift_truth_summary" },
    "edit_posture_honesty": { "$ref": "#/$defs/edit_posture_honesty_summary" },
    "labeling_surface_coverage": { "$ref": "#/$defs/labeling_surface_coverage_summary" },
    "mutation_no_rerun_honesty": { "$ref": "#/$defs/mutation_no_rerun_honesty_summary" },
    "support_export_honesty": { "$ref": "#/$defs/support_export_honesty_summary" },
    "inspection_hooks": {
      "type": "array",
      "items": { "$ref": "#/$defs/inspection_hook" }
    },
    "stable_qualification": { "$ref": "#/$defs/stable_qualification" },
    "raw_payload_excluded": { "const": true },
    "summary": { "type": "string", "minLength": 1, "maxLength": 700 }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "mutation_path_kind": {
      "type": "string",
      "enum": [
        "editor",
        "formatter",
        "ai_apply",
        "build_runner",
        "lockfile_resolver",
        "preview_runtime"
      ]
    },
    "generated_artifact_kind": {
      "type": "string",
      "enum": [
        "build_output",
        "generated_source_sibling",
        "structured_lockfile",
        "notebook_output",
        "preview_snapshot",
        "design_snapshot",
        "mirrored_doc_artifact",
        "mirrored_schema_artifact",
        "mirrored_model_artifact",
        "mirrored_registry_artifact"
      ]
    },
    "default_edit_posture_class": {
      "type": "string",
      "enum": [
        "block_writes_default",
        "round_trip_safe",
        "diverged_from_generator"
      ]
    },
    "drift_state_class": {
      "type": "string",
      "enum": [
        "in_sync",
        "drifted_from_generator",
        "regeneration_pending",
        "unknown_drift"
      ]
    },
    "labeling_surface_kind": {
      "type": "string",
      "enum": [
        "tree",
        "breadcrumb",
        "search",
        "review",
        "ai_context",
        "save",
        "support"
      ]
    },
    "mutation_no_rerun_posture": {
      "type": "string",
      "enum": [
        "explicit_user_action_required",
        "deterministic_replay_after_checkpoint",
        "terminal_no_further_run"
      ]
    },
    "mutation_support_export_posture": {
      "type": "string",
      "enum": ["metadata_safe_export", "held_record"]
    },
    "inspection_hook_class": {
      "type": "string",
      "enum": [
        "inspect_lineage",
        "compare_canonical",
        "regenerate",
        "export_before_override",
        "rollback_override",
        "export",
        "repair"
      ]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "corpus_empty",
        "required_mutation_path_missing",
        "required_generated_artifact_class_missing",
        "canonical_source_ref_missing",
        "generator_identity_missing",
        "output_digest_missing",
        "drift_disclosure_missing",
        "edit_posture_unsafe_default",
        "diverged_disclosure_missing",
        "labeling_surface_missing",
        "mutation_no_rerun_posture_unsafe",
        "explicit_action_metadata_missing",
        "inspection_hook_unavailable",
        "support_export_fields_dropped",
        "support_export_redaction_unsafe",
        "producer_attribution_incomplete",
        "lineage_export_unsafe"
      ]
    },
    "producer_attribution_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_ref",
        "schema_version",
        "integrity_hash",
        "captured_at",
        "producer_attribution_complete"
      ],
      "properties": {
        "producer_ref": { "type": "string" },
        "schema_version": { "type": "integer" },
        "integrity_hash": { "type": "string" },
        "captured_at": { "type": "string" },
        "producer_attribution_complete": { "type": "boolean" }
      }
    },
    "mutation_path_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_id",
        "title",
        "path_kind",
        "journal_entry_id",
        "no_rerun_posture",
        "commit_action_id",
        "commit_disclosure_id",
        "touches_privileged_surface",
        "canonical_touches_privileged_surface",
        "privileged_surface_matches",
        "support_export_posture",
        "is_required"
      ],
      "properties": {
        "path_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "type": "string" },
        "path_kind": { "$ref": "#/$defs/mutation_path_kind" },
        "journal_entry_id": { "type": "string" },
        "no_rerun_posture": { "$ref": "#/$defs/mutation_no_rerun_posture" },
        "commit_action_id": { "type": "string" },
        "commit_disclosure_id": { "type": "string" },
        "touches_privileged_surface": { "type": "boolean" },
        "canonical_touches_privileged_surface": { "type": "boolean" },
        "privileged_surface_matches": { "type": "boolean" },
        "support_export_posture": { "$ref": "#/$defs/mutation_support_export_posture" },
        "is_required": { "type": "boolean" }
      }
    },
    "generated_artifact_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "title",
        "artifact_kind",
        "canonical_source_ref",
        "generator_identity",
        "output_digest",
        "drift_state",
        "default_edit_posture",
        "override_disclosure_id",
        "recovery_guidance_disclosure_id",
        "labeled_in_surfaces",
        "missing_labeling_surfaces",
        "supports_round_trip_safe_editing",
        "support_export_posture",
        "is_required"
      ],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "type": "string" },
        "artifact_kind": { "$ref": "#/$defs/generated_artifact_kind" },
        "canonical_source_ref": { "type": "string" },
        "generator_identity": { "type": "string" },
        "output_digest": { "type": "string" },
        "drift_state": { "$ref": "#/$defs/drift_state_class" },
        "default_edit_posture": { "$ref": "#/$defs/default_edit_posture_class" },
        "override_disclosure_id": { "type": "string" },
        "recovery_guidance_disclosure_id": { "type": "string" },
        "labeled_in_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/labeling_surface_kind" },
          "uniqueItems": true
        },
        "missing_labeling_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/labeling_surface_kind" },
          "uniqueItems": true
        },
        "supports_round_trip_safe_editing": { "type": "boolean" },
        "support_export_posture": { "$ref": "#/$defs/mutation_support_export_posture" },
        "is_required": { "type": "boolean" }
      }
    },
    "mutation_path_coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mutation_path_rows", "all_required_paths_present"],
      "properties": {
        "mutation_path_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/mutation_path_row" }
        },
        "all_required_paths_present": { "type": "boolean" }
      }
    },
    "generated_artifact_coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_artifact_rows", "all_required_artifact_classes_present"],
      "properties": {
        "generated_artifact_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/generated_artifact_row" }
        },
        "all_required_artifact_classes_present": { "type": "boolean" }
      }
    },
    "canonical_lineage_truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_artifacts_have_canonical_source_ref",
        "all_artifacts_have_generator_identity",
        "all_artifacts_have_output_digest"
      ],
      "properties": {
        "all_artifacts_have_canonical_source_ref": { "type": "boolean" },
        "all_artifacts_have_generator_identity": { "type": "boolean" },
        "all_artifacts_have_output_digest": { "type": "boolean" }
      }
    },
    "drift_truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["drifted_artifact_count", "all_drifted_artifacts_have_disclosure"],
      "properties": {
        "drifted_artifact_count": { "type": "integer", "minimum": 0 },
        "all_drifted_artifacts_have_disclosure": { "type": "boolean" }
      }
    },
    "edit_posture_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_round_trip_safe_claims_supported",
        "diverged_artifact_count",
        "all_diverged_artifacts_have_disclosures"
      ],
      "properties": {
        "all_round_trip_safe_claims_supported": { "type": "boolean" },
        "diverged_artifact_count": { "type": "integer", "minimum": 0 },
        "all_diverged_artifacts_have_disclosures": { "type": "boolean" }
      }
    },
    "labeling_surface_coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_artifacts_labeled_on_required_surfaces"],
      "properties": {
        "all_artifacts_labeled_on_required_surfaces": { "type": "boolean" }
      }
    },
    "mutation_no_rerun_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_privileged_paths_safe", "all_explicit_paths_have_metadata"],
      "properties": {
        "all_privileged_paths_safe": { "type": "boolean" },
        "all_explicit_paths_have_metadata": { "type": "boolean" }
      }
    },
    "support_export_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_rows_preserve_fields",
        "all_rows_redact_raw_secrets",
        "all_rows_exclude_approval_tickets",
        "all_rows_exclude_delegated_credentials",
        "all_rows_exclude_live_authority_handles"
      ],
      "properties": {
        "all_rows_preserve_fields": { "type": "boolean" },
        "all_rows_redact_raw_secrets": { "type": "boolean" },
        "all_rows_exclude_approval_tickets": { "type": "boolean" },
        "all_rows_exclude_delegated_credentials": { "type": "boolean" },
        "all_rows_exclude_live_authority_handles": { "type": "boolean" }
      }
    },
    "inspection_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hook_class", "action_id", "label", "available", "disclosure"],
      "properties": {
        "hook_class": { "$ref": "#/$defs/inspection_hook_class" },
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "available": { "type": "boolean" },
        "disclosure": { "type": "string" }
      }
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qualified", "level", "narrow_reasons"],
      "properties": {
        "qualified": { "type": "boolean" },
        "level": {
          "type": "string",
          "enum": ["stable", "narrowed_below_stable"]
        },
        "narrow_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason" }
        }
      }
    }
  }
}
