{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/entry_hardening_lineage.schema.json",
  "title": "Aureline entry hardening lineage",
  "description": "Boundary schema for the governed, export-safe entry hardening lineage record. The record finalizes verb truth, target-kind / topology truth, durable post-entry checkpoints, side-effect posture, failure-repair truth, and cross-surface parity for Open / Clone / Import / Add root / Restore / Resume into one record per posture. It is projected from a live ProjectEntryReviewRecord. Raw source bytes and typed inputs are excluded; the record only carries redaction-aware labels.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "entry_hardening_lineage_schema_version",
    "schema_ref",
    "posture_id",
    "entry_review_ref",
    "admission_review_ref",
    "admission_checkpoint_ref",
    "verb_truth",
    "target_kind_truth",
    "durable_checkpoint",
    "side_effect_posture",
    "failure_repair_truth",
    "surface_parity_truth",
    "inspection_hooks",
    "stable_qualification",
    "raw_payload_excluded",
    "summary"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": { "const": "entry_hardening_lineage_record" },
    "entry_hardening_lineage_schema_version": { "type": "integer", "const": 1 },
    "schema_ref": { "const": "schemas/workspace/entry_hardening_lineage.schema.json" },
    "posture_id": { "$ref": "#/$defs/non_empty_string" },
    "entry_review_ref": { "$ref": "#/$defs/non_empty_string" },
    "admission_review_ref": { "$ref": "#/$defs/non_empty_string" },
    "admission_checkpoint_ref": { "$ref": "#/$defs/non_empty_string" },
    "verb_truth": { "$ref": "#/$defs/verb_truth_summary" },
    "target_kind_truth": { "$ref": "#/$defs/target_kind_truth_summary" },
    "durable_checkpoint": { "$ref": "#/$defs/durable_checkpoint_summary" },
    "side_effect_posture": { "$ref": "#/$defs/side_effect_posture" },
    "failure_repair_truth": { "$ref": "#/$defs/failure_repair_truth" },
    "surface_parity_truth": { "$ref": "#/$defs/surface_parity_truth" },
    "inspection_hooks": {
      "type": "array",
      "items": { "$ref": "#/$defs/inspection_hook" }
    },
    "stable_qualification": { "$ref": "#/$defs/stable_qualification" },
    "raw_payload_excluded": { "const": true },
    "summary": { "$ref": "#/$defs/short_sentence" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "short_sentence": { "type": "string", "minLength": 1, "maxLength": 700 },
    "entry_verb": {
      "type": "string",
      "enum": [
        "open",
        "clone",
        "import",
        "add_root",
        "restore",
        "resume",
        "start_from_snapshot"
      ]
    },
    "resulting_mode": {
      "type": "string",
      "enum": [
        "single_file",
        "folder",
        "repo_root",
        "workspace_candidate",
        "workspace_with_roots",
        "workset_slice",
        "inspect_only",
        "clone_then_review",
        "clone_then_open",
        "clone_then_add",
        "clone_only",
        "extract_then_review",
        "compare_before_restore",
        "apply_to_active_workspace",
        "open_prebuild_with_setup_actions",
        "open_prebuild_minimal",
        "resume_live_session",
        "restore_last_session",
        "restore_from_checkpoint"
      ]
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "local_file",
        "local_folder",
        "local_repo_root",
        "remote_repository",
        "workspace_manifest",
        "workset_manifest",
        "portable_state_package",
        "handoff_packet",
        "competitor_config_root",
        "template_or_prebuild_snapshot",
        "recovery_checkpoint",
        "managed_cloud_workspace",
        "ssh_workspace",
        "container_workspace",
        "devcontainer_workspace",
        "review_or_work_item_deep_link"
      ]
    },
    "admission_source_surface": {
      "type": "string",
      "enum": [
        "start_center",
        "command_palette",
        "drag_and_drop",
        "system_file_association",
        "deep_link",
        "cli_headless",
        "workspace_switcher"
      ]
    },
    "review_sheet_kind": {
      "type": "string",
      "enum": [
        "open_local_target",
        "open_workspace_manifest",
        "clone_repository",
        "add_root",
        "import_artifact",
        "restore_state"
      ]
    },
    "destination_collision_class": {
      "type": "string",
      "enum": [
        "no_collision",
        "existing_path_non_empty",
        "existing_repo_root",
        "nested_repository",
        "existing_worktree",
        "existing_workspace_manifest",
        "duplicate_clone_target",
        "destination_blocked_by_policy"
      ]
    },
    "topology_class": {
      "type": "string",
      "enum": [
        "durable_open",
        "acquired_not_fetched",
        "opened_sparse",
        "pointer_only",
        "nested_child",
        "parent_root",
        "imported_packet",
        "inspect_only_staging",
        "restore_target"
      ]
    },
    "deferred_work_class": {
      "type": "string",
      "enum": [
        "trust_grant",
        "dependency_restore",
        "task_execution",
        "hook_execution",
        "extension_or_bundle_install",
        "state_rehydration",
        "durable_promotion",
        "runtime_attach",
        "credential_admission"
      ]
    },
    "readiness_task_class": {
      "type": "string"
    },
    "admission_action": {
      "type": "string",
      "enum": [
        "open",
        "import",
        "add_root",
        "clone_here",
        "split",
        "copy",
        "move",
        "clone_only",
        "clone_and_review",
        "clone_and_open",
        "clone_and_add",
        "reuse_existing",
        "add_existing_as_root",
        "clone_elsewhere",
        "reveal_target",
        "inspect_only",
        "open_minimal",
        "set_up_later",
        "cancel"
      ]
    },
    "inspection_hook_class": {
      "type": "string",
      "enum": [
        "review_entry",
        "inspect_collision",
        "inspect_handoff",
        "inspect_failure_repair",
        "export"
      ]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "review_sheet_mismatch",
        "clone_grants_trust_silently",
        "clone_runs_setup_silently",
        "import_writes_before_review",
        "import_rehydrates_before_review",
        "workspace_manifest_upgrades_silently",
        "destination_collision_no_explicit_choice",
        "handoff_missing_continuity_paths",
        "failure_repair_loses_state",
        "failure_repair_leaks_secret",
        "surface_parity_drift",
        "deep_link_intent_review_missing",
        "inspection_hook_unavailable",
        "lineage_export_unsafe"
      ]
    },
    "verb_truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_verb",
        "target_kind",
        "resulting_mode",
        "source_surface",
        "review_sheet_kind",
        "verb_stays_distinct",
        "sheet_matches_verb"
      ],
      "properties": {
        "entry_verb": { "$ref": "#/$defs/entry_verb" },
        "target_kind": { "$ref": "#/$defs/target_kind" },
        "resulting_mode": { "$ref": "#/$defs/resulting_mode" },
        "source_surface": { "$ref": "#/$defs/admission_source_surface" },
        "review_sheet_kind": { "$ref": "#/$defs/review_sheet_kind" },
        "verb_stays_distinct": { "type": "boolean" },
        "sheet_matches_verb": { "type": "boolean" }
      }
    },
    "target_kind_truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "topology_class",
        "destination_collision_class",
        "explicit_choice_required_when_colliding",
        "non_durable_staging_labelled",
        "resulting_mode_is_distinct_outcome",
        "topology_consistent_with_verb",
        "summary"
      ],
      "properties": {
        "topology_class": { "$ref": "#/$defs/topology_class" },
        "destination_collision_class": { "$ref": "#/$defs/destination_collision_class" },
        "explicit_choice_required_when_colliding": { "type": "boolean" },
        "non_durable_staging_labelled": { "type": "boolean" },
        "resulting_mode_is_distinct_outcome": { "type": "boolean" },
        "topology_consistent_with_verb": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "durable_checkpoint_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "admission_checkpoint_id",
        "handoff_card_id",
        "deferred_work",
        "blocking_now_tasks",
        "recommended_soon_tasks",
        "optional_later_tasks",
        "primary_next_action",
        "safe_alternate_actions",
        "set_up_later_offered",
        "open_minimal_offered",
        "cancel_offered",
        "export_or_share_state_available"
      ],
      "properties": {
        "admission_checkpoint_id": { "$ref": "#/$defs/non_empty_string" },
        "handoff_card_id": { "$ref": "#/$defs/non_empty_string" },
        "deferred_work": {
          "type": "array",
          "items": { "$ref": "#/$defs/deferred_work_class" }
        },
        "blocking_now_tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/readiness_task_class" }
        },
        "recommended_soon_tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/readiness_task_class" }
        },
        "optional_later_tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/readiness_task_class" }
        },
        "primary_next_action": { "$ref": "#/$defs/admission_action" },
        "safe_alternate_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/admission_action" }
        },
        "set_up_later_offered": { "type": "boolean" },
        "open_minimal_offered": { "type": "boolean" },
        "cancel_offered": { "type": "boolean" },
        "export_or_share_state_available": { "type": "boolean" }
      }
    },
    "side_effect_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clone_never_grants_trust",
        "dependency_restore_deferred",
        "task_execution_deferred",
        "no_durable_write_before_review",
        "no_state_rehydration_before_review",
        "silent_workspace_upgrade_forbidden",
        "dropped_meaning_disclosed",
        "deferred_work_classes"
      ],
      "properties": {
        "clone_never_grants_trust": { "type": "boolean" },
        "dependency_restore_deferred": { "type": "boolean" },
        "task_execution_deferred": { "type": "boolean" },
        "no_durable_write_before_review": { "type": "boolean" },
        "no_state_rehydration_before_review": { "type": "boolean" },
        "silent_workspace_upgrade_forbidden": { "type": "boolean" },
        "dropped_meaning_disclosed": { "type": "boolean" },
        "deferred_work_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/deferred_work_class" }
        }
      }
    },
    "failure_repair_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "typed_source_input_preserved",
        "chosen_destination_preserved",
        "redacted_diagnostics_preserved",
        "source_input_redacted",
        "repair_actions_present",
        "repair_actions"
      ],
      "properties": {
        "typed_source_input_preserved": { "type": "boolean" },
        "chosen_destination_preserved": { "type": "boolean" },
        "redacted_diagnostics_preserved": { "type": "boolean" },
        "source_input_redacted": { "type": "boolean" },
        "repair_actions_present": { "type": "boolean" },
        "repair_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/admission_action" }
        }
      }
    },
    "surface_parity_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "covered_surfaces",
        "all_surfaces_preserve_verb",
        "all_surfaces_preserve_mode",
        "all_surfaces_preserve_target_kind",
        "same_review_model_on_all",
        "deep_link_surface_covered",
        "deep_link_intent_review_present"
      ],
      "properties": {
        "covered_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/admission_source_surface" }
        },
        "all_surfaces_preserve_verb": { "type": "boolean" },
        "all_surfaces_preserve_mode": { "type": "boolean" },
        "all_surfaces_preserve_target_kind": { "type": "boolean" },
        "same_review_model_on_all": { "type": "boolean" },
        "deep_link_surface_covered": { "type": "boolean" },
        "deep_link_intent_review_present": { "type": "boolean" }
      }
    },
    "inspection_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hook_class", "action_id", "label", "available", "disclosure"],
      "properties": {
        "hook_class": { "$ref": "#/$defs/inspection_hook_class" },
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "available": { "type": "boolean" },
        "disclosure": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qualified", "level", "narrow_reasons"],
      "properties": {
        "qualified": { "type": "boolean" },
        "level": { "type": "string", "enum": ["stable", "narrowed_below_stable"] },
        "narrow_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason" }
        }
      }
    }
  }
}
