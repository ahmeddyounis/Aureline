{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/warm_start_choice.schema.json",
  "title": "Aureline warm-start choice card, page, and support-export record",
  "description": "Boundary schema for the beta warm-start choice contract shared by the Start Center, the workspace switcher, CLI/headless entry review, docs/help, and support export. A warm-start choice card describes — before any networked or trust-widening side effect occurs — what each entry path will do: resume a live workspace, start from a snapshot, clone fresh, open minimal, set up later, or use a template. The card's safest next action always resolves to a local-safe lane; open-minimal and set-up-later stay same-weight on local-first cards; a stale snapshot can never be presented as a live resume; and a lane that reaches the network, attaches managed/remote runtime, or widens trust may never advertise a local-safe side-effect class. Raw secrets, raw credentials, raw environment values, and raw command lines never cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/warm_start_choice_page_record" },
    { "$ref": "#/$defs/warm_start_choice_card_record" },
    { "$ref": "#/$defs/warm_start_choice_support_export_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the warm-start choice family. Additive enum or optional-field changes bump this value; repurposing an existing value is breaking."
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "shell:start_center_warm_start_choice_beta:v1"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, support-safe identifier. Raw paths, URLs with credentials, and secret values never appear here."
    },
    "fingerprint_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, support-safe fingerprint reference (e.g. a digest). Raw content bodies never appear here."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 320,
      "description": "Short sentence safe for UI, CLI, support bundles, and audit logs."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "surface_class": {
      "type": "string",
      "enum": ["start_center", "workspace_switcher"]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "workspace_template",
        "prebuild_snapshot",
        "live_workspace",
        "remote_repository",
        "local_folder"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "certified",
        "supported",
        "limited",
        "experimental",
        "community",
        "unsupported"
      ]
    },
    "runtime_or_host_model": {
      "type": "string",
      "enum": [
        "local_host",
        "devcontainer",
        "managed_cloud_workspace",
        "ssh_workspace"
      ]
    },
    "path_class": {
      "type": "string",
      "enum": [
        "resume_live_workspace",
        "start_from_snapshot",
        "clone_fresh",
        "open_minimal",
        "set_up_later",
        "use_template"
      ]
    },
    "availability": {
      "type": "string",
      "enum": [
        "available",
        "available_after_review",
        "requires_reauth",
        "unavailable_stale_snapshot",
        "blocked_by_policy"
      ]
    },
    "side_effect_class": {
      "type": "string",
      "enum": [
        "no_side_effect",
        "local_read_only",
        "local_setup",
        "network_egress",
        "managed_attach",
        "trust_widening"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": ["fresh", "cached", "stale", "invalidated", "unverified"]
    },
    "age_class": {
      "type": "string",
      "enum": [
        "within_hours",
        "within_days",
        "within_weeks",
        "beyond_review_window"
      ]
    },
    "setup_location_class": {
      "type": "string",
      "enum": [
        "no_setup",
        "local_host",
        "devcontainer",
        "managed_cloud",
        "ssh_host"
      ]
    },
    "choice_lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_class",
        "path_token",
        "label",
        "summary",
        "availability",
        "availability_token",
        "side_effect_class",
        "side_effect_token",
        "requires_trust_grant",
        "requires_network",
        "runs_setup_tasks",
        "materializes_remote_work",
        "same_weight_local_path"
      ],
      "properties": {
        "path_class": { "$ref": "#/$defs/path_class" },
        "path_token": { "$ref": "#/$defs/path_class" },
        "label": { "type": "string", "minLength": 1 },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "availability": { "$ref": "#/$defs/availability" },
        "availability_token": { "$ref": "#/$defs/availability" },
        "side_effect_class": { "$ref": "#/$defs/side_effect_class" },
        "side_effect_token": { "$ref": "#/$defs/side_effect_class" },
        "requires_trust_grant": { "type": "boolean" },
        "requires_network": { "type": "boolean" },
        "runs_setup_tasks": { "type": "boolean" },
        "materializes_remote_work": { "type": "boolean" },
        "same_weight_local_path": { "type": "boolean" },
        "invalidation_reason": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "snapshot_facts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "source_class_token",
        "fingerprint_ref",
        "freshness",
        "freshness_token",
        "age_class",
        "age_token",
        "captured_at",
        "stale_must_not_render_as_live_resume"
      ],
      "properties": {
        "source_class": { "$ref": "#/$defs/source_class" },
        "source_class_token": { "$ref": "#/$defs/source_class" },
        "fingerprint_ref": { "$ref": "#/$defs/fingerprint_ref" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "freshness_token": { "$ref": "#/$defs/freshness" },
        "age_class": { "$ref": "#/$defs/age_class" },
        "age_token": { "$ref": "#/$defs/age_class" },
        "captured_at": { "$ref": "#/$defs/timestamp" },
        "invalidation_reason": { "$ref": "#/$defs/opaque_id" },
        "stale_must_not_render_as_live_resume": { "const": true }
      }
    },
    "side_effect_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network_egress",
        "extension_installs",
        "setup_tasks",
        "trust_prompt",
        "managed_or_remote_attach",
        "notes"
      ],
      "properties": {
        "network_egress": { "type": "boolean" },
        "extension_installs": { "type": "boolean" },
        "setup_tasks": { "type": "boolean" },
        "trust_prompt": { "type": "boolean" },
        "managed_or_remote_attach": { "type": "boolean" },
        "notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_sentence" }
        }
      }
    },
    "environment_starter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "setup_location_class",
        "setup_location_token",
        "downloads_involved",
        "extensions_involved",
        "tasks_involved",
        "trust_prompt_involved",
        "bypass_route_ids",
        "defer_route_ids",
        "summary"
      ],
      "properties": {
        "setup_location_class": { "$ref": "#/$defs/setup_location_class" },
        "setup_location_token": { "$ref": "#/$defs/setup_location_class" },
        "downloads_involved": { "type": "boolean" },
        "extensions_involved": { "type": "boolean" },
        "tasks_involved": { "type": "boolean" },
        "trust_prompt_involved": { "type": "boolean" },
        "bypass_route_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "defer_route_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "warm_start_choice_card_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "card_id",
        "surface_origin",
        "surface_origin_token",
        "display_label",
        "summary",
        "source_class",
        "source_class_token",
        "support_class",
        "support_class_token",
        "runtime_or_host_model",
        "runtime_or_host_model_token",
        "local_first",
        "expected_setup_actions",
        "side_effects",
        "environment_starter",
        "choice_lanes",
        "safest_next_action",
        "safest_next_action_token",
        "default_widens_trust",
        "default_runs_networked_work",
        "honesty_marker_present"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "warm_start_choice_card_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "card_id": { "$ref": "#/$defs/opaque_id" },
        "surface_origin": { "$ref": "#/$defs/surface_class" },
        "surface_origin_token": { "$ref": "#/$defs/surface_class" },
        "display_label": { "type": "string", "minLength": 1 },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "source_class_token": { "$ref": "#/$defs/source_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "support_class_token": { "$ref": "#/$defs/support_class" },
        "runtime_or_host_model": { "$ref": "#/$defs/runtime_or_host_model" },
        "runtime_or_host_model_token": {
          "$ref": "#/$defs/runtime_or_host_model"
        },
        "local_first": { "type": "boolean" },
        "expected_setup_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_sentence" }
        },
        "snapshot": { "$ref": "#/$defs/snapshot_facts" },
        "side_effects": { "$ref": "#/$defs/side_effect_summary" },
        "environment_starter": { "$ref": "#/$defs/environment_starter" },
        "choice_lanes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/choice_lane" }
        },
        "safest_next_action": { "$ref": "#/$defs/path_class" },
        "safest_next_action_token": { "$ref": "#/$defs/path_class" },
        "default_widens_trust": { "const": false },
        "default_runs_networked_work": { "const": false },
        "honesty_marker_present": { "type": "boolean" }
      }
    },
    "warm_start_choice_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_card_count",
        "template_card_count",
        "live_resume_card_count",
        "snapshot_card_count",
        "clone_fresh_card_count",
        "local_first_card_count",
        "stale_snapshot_card_count",
        "revalidation_required_card_count",
        "honesty_marker_card_count"
      ],
      "properties": {
        "total_card_count": { "type": "integer", "minimum": 0 },
        "template_card_count": { "type": "integer", "minimum": 0 },
        "live_resume_card_count": { "type": "integer", "minimum": 0 },
        "snapshot_card_count": { "type": "integer", "minimum": 0 },
        "clone_fresh_card_count": { "type": "integer", "minimum": 0 },
        "local_first_card_count": { "type": "integer", "minimum": 0 },
        "stale_snapshot_card_count": { "type": "integer", "minimum": 0 },
        "revalidation_required_card_count": { "type": "integer", "minimum": 0 },
        "honesty_marker_card_count": { "type": "integer", "minimum": 0 }
      }
    },
    "warm_start_choice_page_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "page_label",
        "contract_ref",
        "notice",
        "consuming_surfaces",
        "cards",
        "summary",
        "open_minimal_same_weight_on_local_first",
        "set_up_later_same_weight_on_local_first",
        "honesty_marker_present"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "warm_start_choice_page_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "page_label": { "type": "string", "minLength": 1 },
        "contract_ref": { "type": "string", "minLength": 1 },
        "notice": { "type": "string", "minLength": 1 },
        "consuming_surfaces": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "start_center",
              "workspace_switcher",
              "cli_headless_entry_review",
              "docs_help",
              "support_export"
            ]
          }
        },
        "cards": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/warm_start_choice_card_record" }
        },
        "summary": { "$ref": "#/$defs/warm_start_choice_summary" },
        "open_minimal_same_weight_on_local_first": { "const": true },
        "set_up_later_same_weight_on_local_first": { "const": true },
        "honesty_marker_present": { "type": "boolean" }
      }
    },
    "warm_start_choice_support_export_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "export_id",
        "exported_at",
        "page",
        "card_ids",
        "raw_secret_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "warm_start_choice_support_export_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "export_id": { "$ref": "#/$defs/opaque_id" },
        "exported_at": { "$ref": "#/$defs/timestamp" },
        "page": { "$ref": "#/$defs/warm_start_choice_page_record" },
        "card_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "raw_secret_material_excluded": { "const": true }
      }
    }
  }
}
