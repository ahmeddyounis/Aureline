{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/restricted_mode_ux_lineage.schema.json",
  "title": "Aureline restricted-mode UX lineage",
  "description": "Boundary schema for the governed, export-safe restricted-mode UX lineage record. The record finalizes the user-facing restricted-mode experience and the explainability surfaces that ride on top of workspace-trust gating. It is projected verbatim from the live RestrictedModeUxInputs envelope. It proves surface coverage (status_bar / editor_chrome / command_palette / action_menu / help_about / support_export), explainability truth (every restricted-mode surface ships an explanation id), escape-path honesty (every non-stay escape has an action id and grant_trust escapes carry a disclosure), read-only affordance truth (read-only-tier surfaces expose only read-only-safe affordances), claimed-tier truth (no stable_full claim in a restricted or pending workspace), accessibility truth (keyboard, screen reader, IME/grapheme/bidi, zoom/high contrast, reduced motion), and support-export honesty (restricted-mode fields preserved; raw secrets / approval tickets / delegated credentials / live authority handles redacted). Raw payload bytes are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "restricted_mode_ux_lineage_schema_version",
    "schema_ref",
    "posture_id",
    "workspace_ref",
    "corpus_ref",
    "posture",
    "producer_attribution",
    "surface_coverage",
    "explainability_truth",
    "escape_path_honesty",
    "read_only_affordance_truth",
    "claimed_tier_truth",
    "accessibility_truth",
    "support_export_honesty",
    "inspection_hooks",
    "stable_qualification",
    "raw_payload_excluded",
    "summary"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": { "const": "restricted_mode_ux_lineage_record" },
    "restricted_mode_ux_lineage_schema_version": { "type": "integer", "const": 1 },
    "schema_ref": { "const": "schemas/workspace/restricted_mode_ux_lineage.schema.json" },
    "posture_id": { "$ref": "#/$defs/non_empty_string" },
    "workspace_ref": { "$ref": "#/$defs/non_empty_string" },
    "corpus_ref": { "$ref": "#/$defs/non_empty_string" },
    "posture": { "$ref": "#/$defs/restricted_mode_posture" },
    "producer_attribution": { "$ref": "#/$defs/producer_attribution_summary" },
    "surface_coverage": { "$ref": "#/$defs/surface_coverage_summary" },
    "explainability_truth": { "$ref": "#/$defs/explainability_truth_summary" },
    "escape_path_honesty": { "$ref": "#/$defs/escape_path_honesty_summary" },
    "read_only_affordance_truth": { "$ref": "#/$defs/read_only_affordance_truth_summary" },
    "claimed_tier_truth": { "$ref": "#/$defs/claimed_tier_truth_summary" },
    "accessibility_truth": { "$ref": "#/$defs/accessibility_truth_summary" },
    "support_export_honesty": { "$ref": "#/$defs/support_export_honesty_summary" },
    "inspection_hooks": {
      "type": "array",
      "items": { "$ref": "#/$defs/inspection_hook" }
    },
    "stable_qualification": { "$ref": "#/$defs/stable_qualification" },
    "raw_payload_excluded": { "const": true },
    "summary": { "type": "string", "minLength": 1, "maxLength": 700 }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "restricted_mode_surface_kind": {
      "type": "string",
      "enum": [
        "status_bar",
        "editor_chrome",
        "command_palette",
        "action_menu",
        "help_about",
        "support_export"
      ]
    },
    "restricted_mode_posture": {
      "type": "string",
      "enum": ["trusted", "restricted", "pending_evaluation"]
    },
    "restriction_reason_class": {
      "type": "string",
      "enum": [
        "workspace_restricted",
        "workspace_pending_evaluation",
        "surface_read_only",
        "credential_store_restricted",
        "policy_block",
        "post_entry_staging_restricted"
      ]
    },
    "escape_path_class": {
      "type": "string",
      "enum": [
        "grant_trust",
        "repair_workspace",
        "leave_workspace",
        "stay_read_only",
        "contact_support"
      ]
    },
    "restricted_affordance_class": {
      "type": "string",
      "enum": [
        "inspect_only",
        "copy_to_clipboard",
        "navigate_only",
        "view_diff_only",
        "blocked_with_explanation",
        "allow_read_only_no_mutation"
      ]
    },
    "claimed_stable_tier": {
      "type": "string",
      "enum": ["stable_full", "stable_read_only", "narrowed_below_stable"]
    },
    "accessibility_posture_class": {
      "type": "string",
      "enum": [
        "keyboard_only",
        "screen_reader",
        "ime_grapheme_bidi",
        "zoom_high_contrast",
        "reduced_motion"
      ]
    },
    "support_export_posture": {
      "type": "string",
      "enum": ["local_only", "metadata_safe_export", "held_record"]
    },
    "inspection_hook_class": {
      "type": "string",
      "enum": [
        "inspect_restriction",
        "review_escape_path",
        "compare_unrestricted",
        "rollback_grant",
        "export",
        "repair"
      ]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "corpus_empty",
        "required_restricted_surface_missing",
        "explanation_missing",
        "grant_trust_escape_undisclosed",
        "escape_path_action_missing",
        "read_only_claim_exposes_mutation",
        "claimed_full_in_restricted_posture",
        "affordances_empty",
        "accessibility_posture_missing",
        "inspection_hook_unavailable",
        "support_export_fields_dropped",
        "support_export_redaction_unsafe",
        "support_export_posture_unsafe",
        "producer_attribution_incomplete",
        "lineage_export_unsafe"
      ]
    },
    "producer_attribution_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_ref",
        "schema_version",
        "integrity_hash",
        "captured_at",
        "producer_attribution_complete"
      ],
      "properties": {
        "producer_ref": { "type": "string" },
        "schema_version": { "type": "integer" },
        "integrity_hash": { "type": "string" },
        "captured_at": { "type": "string" },
        "producer_attribution_complete": { "type": "boolean" }
      }
    },
    "restricted_mode_surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "restriction_reason",
        "has_explanation",
        "escape_path",
        "has_escape_action",
        "has_escape_disclosure",
        "affordances",
        "affordances_read_only_safe",
        "declared_tier",
        "derived_tier",
        "tier_matches",
        "touches_credential_store",
        "accessibility_postures",
        "accessibility_complete",
        "support_export_posture"
      ],
      "properties": {
        "surface_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "type": "string" },
        "surface_kind": { "$ref": "#/$defs/restricted_mode_surface_kind" },
        "restriction_reason": { "$ref": "#/$defs/restriction_reason_class" },
        "has_explanation": { "type": "boolean" },
        "escape_path": { "$ref": "#/$defs/escape_path_class" },
        "has_escape_action": { "type": "boolean" },
        "has_escape_disclosure": { "type": "boolean" },
        "affordances": {
          "type": "array",
          "items": { "$ref": "#/$defs/restricted_affordance_class" }
        },
        "affordances_read_only_safe": { "type": "boolean" },
        "declared_tier": { "$ref": "#/$defs/claimed_stable_tier" },
        "derived_tier": { "$ref": "#/$defs/claimed_stable_tier" },
        "tier_matches": { "type": "boolean" },
        "touches_credential_store": { "type": "boolean" },
        "accessibility_postures": {
          "type": "array",
          "items": { "$ref": "#/$defs/accessibility_posture_class" }
        },
        "accessibility_complete": { "type": "boolean" },
        "support_export_posture": { "$ref": "#/$defs/support_export_posture" }
      }
    },
    "surface_coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_rows", "all_required_surfaces_present"],
      "properties": {
        "surface_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/restricted_mode_surface_row" }
        },
        "all_required_surfaces_present": { "type": "boolean" }
      }
    },
    "explainability_truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_surfaces_have_explanation", "distinct_restriction_reasons"],
      "properties": {
        "all_surfaces_have_explanation": { "type": "boolean" },
        "distinct_restriction_reasons": { "type": "integer", "minimum": 0 }
      }
    },
    "escape_path_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_escape_paths_have_action",
        "all_grant_trust_escapes_disclosed",
        "grant_trust_escape_count"
      ],
      "properties": {
        "all_escape_paths_have_action": { "type": "boolean" },
        "all_grant_trust_escapes_disclosed": { "type": "boolean" },
        "grant_trust_escape_count": { "type": "integer", "minimum": 0 }
      }
    },
    "read_only_affordance_truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_read_only_surfaces_safe",
        "read_only_surface_count",
        "all_surfaces_have_affordances"
      ],
      "properties": {
        "all_read_only_surfaces_safe": { "type": "boolean" },
        "read_only_surface_count": { "type": "integer", "minimum": 0 },
        "all_surfaces_have_affordances": { "type": "boolean" }
      }
    },
    "claimed_tier_truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["no_full_claim_in_restricted_posture", "all_tiers_match_derived"],
      "properties": {
        "no_full_claim_in_restricted_posture": { "type": "boolean" },
        "all_tiers_match_derived": { "type": "boolean" }
      }
    },
    "accessibility_truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_surfaces_accessibility_complete", "surfaces_missing_postures"],
      "properties": {
        "all_surfaces_accessibility_complete": { "type": "boolean" },
        "surfaces_missing_postures": { "type": "integer", "minimum": 0 }
      }
    },
    "support_export_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_surfaces_preserve_fields",
        "all_surfaces_redact_raw_secrets",
        "all_surfaces_exclude_approval_tickets",
        "all_surfaces_exclude_delegated_credentials",
        "all_surfaces_exclude_live_authority_handles",
        "all_credential_surfaces_have_safe_posture"
      ],
      "properties": {
        "all_surfaces_preserve_fields": { "type": "boolean" },
        "all_surfaces_redact_raw_secrets": { "type": "boolean" },
        "all_surfaces_exclude_approval_tickets": { "type": "boolean" },
        "all_surfaces_exclude_delegated_credentials": { "type": "boolean" },
        "all_surfaces_exclude_live_authority_handles": { "type": "boolean" },
        "all_credential_surfaces_have_safe_posture": { "type": "boolean" }
      }
    },
    "inspection_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hook_class", "action_id", "label", "available", "disclosure"],
      "properties": {
        "hook_class": { "$ref": "#/$defs/inspection_hook_class" },
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "available": { "type": "boolean" },
        "disclosure": { "type": "string" }
      }
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qualified", "level", "narrow_reasons"],
      "properties": {
        "qualified": { "type": "boolean" },
        "level": {
          "type": "string",
          "enum": ["stable", "narrowed_below_stable"]
        },
        "narrow_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason" }
        }
      }
    }
  }
}
