{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/schema_migration_and_repair_lineage.schema.json",
  "title": "Aureline schema-migration and repair lineage",
  "description": "Boundary schema for the governed, export-safe schema-migration and repair lineage record. The record proves how schema migrations and repair flows for workspace, profile, and persistent-state artifacts preserve source fidelity, restore provenance, encoding/newline class, trust state, lineage, and no-rerun semantics across crashes, schema upgrades, corrupt artifacts, and policy-bound workflows. It is projected verbatim from the live SchemaMigrationAndRepairInputs envelope. It proves artifact-class coverage, repair-flow coverage, schema-version pinning, migration- and repair-outcome honesty, restore-provenance / encoding / trust-state preservation, no-silent-rerun honesty, repair-transaction-id and finding-code pinning, support-export honesty, and pre-action inspection-hook honesty. Raw payload bytes are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_migration_and_repair_lineage_schema_version",
    "schema_ref",
    "posture_id",
    "workspace_ref",
    "corpus_ref",
    "producer_attribution",
    "artifact_class_coverage",
    "repair_flow_coverage",
    "schema_version_pinning",
    "outcome_honesty",
    "preservation",
    "no_silent_rerun",
    "repair_transaction_pinning",
    "support_export_honesty",
    "inspection_hooks",
    "stable_qualification",
    "raw_payload_excluded",
    "summary"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": { "const": "schema_migration_and_repair_lineage_record" },
    "schema_migration_and_repair_lineage_schema_version": { "type": "integer", "const": 1 },
    "schema_ref": { "const": "schemas/workspace/schema_migration_and_repair_lineage.schema.json" },
    "posture_id": { "$ref": "#/$defs/non_empty_string" },
    "workspace_ref": { "$ref": "#/$defs/non_empty_string" },
    "corpus_ref": { "$ref": "#/$defs/non_empty_string" },
    "producer_attribution": { "$ref": "#/$defs/producer_attribution_summary" },
    "artifact_class_coverage": { "$ref": "#/$defs/artifact_class_coverage_summary" },
    "repair_flow_coverage": { "$ref": "#/$defs/repair_flow_coverage_summary" },
    "schema_version_pinning": { "$ref": "#/$defs/schema_version_pinning_summary" },
    "outcome_honesty": { "$ref": "#/$defs/outcome_honesty_summary" },
    "preservation": { "$ref": "#/$defs/preservation_summary" },
    "no_silent_rerun": { "$ref": "#/$defs/no_silent_rerun_summary" },
    "repair_transaction_pinning": { "$ref": "#/$defs/repair_transaction_pinning_summary" },
    "support_export_honesty": { "$ref": "#/$defs/support_export_honesty_summary" },
    "inspection_hooks": {
      "type": "array",
      "items": { "$ref": "#/$defs/inspection_hook" }
    },
    "stable_qualification": { "$ref": "#/$defs/stable_qualification" },
    "raw_payload_excluded": { "const": true },
    "summary": { "type": "string", "minLength": 1, "maxLength": 700 }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "artifact_class_kind": {
      "type": "string",
      "enum": [
        "workspace_state_artifact",
        "profile_artifact",
        "recent_work_registry",
        "local_history_corpus",
        "restore_checkpoint",
        "persistent_state_envelope",
        "prebuild_cache_artifact",
        "mutation_journal_artifact"
      ]
    },
    "schema_compatibility_class": {
      "type": "string",
      "enum": [
        "current_schema",
        "older_supported_schema",
        "older_unsupported_requires_repair",
        "newer_unknown_schema_refused",
        "corrupt_artifact"
      ]
    },
    "migration_outcome": {
      "type": "string",
      "enum": [
        "no_migration_needed",
        "forward_migrated_lossless",
        "forward_migrated_lossy_with_disclosure",
        "migration_refused_unsafe",
        "migration_awaiting_user_review",
        "compat_report_only"
      ]
    },
    "repair_flow_kind": {
      "type": "string",
      "enum": [
        "inspect_repair",
        "rebuild_derived_store",
        "rehydrate_from_packet",
        "quarantine_corrupt_artifact",
        "restore_from_checkpoint",
        "manual_repair_handoff"
      ]
    },
    "repair_outcome": {
      "type": "string",
      "enum": [
        "repair_succeeded_lossless",
        "repair_succeeded_lossy_with_disclosure",
        "repair_refused_unsafe",
        "repair_awaiting_user_action",
        "repair_quarantined"
      ]
    },
    "rerun_posture": {
      "type": "string",
      "enum": [
        "explicit_user_action_required",
        "terminal_no_further_run",
        "silent_rerun_permitted"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_only",
        "redacted_with_disclosure",
        "excluded_by_policy"
      ]
    },
    "support_export_posture": {
      "type": "string",
      "enum": ["metadata_safe_export", "held_record"]
    },
    "inspection_hook_class": {
      "type": "string",
      "enum": [
        "inspect_artifact",
        "compare_before_migration",
        "preview_migration",
        "preview_repair",
        "rollback_migration",
        "rollback_repair",
        "export_before_migration",
        "export_before_repair"
      ]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "corpus_empty",
        "required_artifact_class_missing",
        "required_repair_flow_kind_missing",
        "repair_references_unknown_artifact",
        "schema_version_unpinned",
        "migration_disclosure_missing",
        "repair_disclosure_missing",
        "redaction_disclosure_missing",
        "rerun_silent_forbidden",
        "commit_action_metadata_missing",
        "restore_provenance_not_preserved",
        "encoding_fidelity_not_preserved",
        "trust_state_not_preserved",
        "no_rerun_semantics_not_preserved",
        "repair_transaction_id_not_pinned",
        "finding_code_missing",
        "inspection_hook_unavailable",
        "support_export_fields_dropped",
        "support_export_redaction_unsafe",
        "producer_attribution_incomplete",
        "lineage_export_unsafe"
      ]
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qualified", "level", "narrow_reasons"],
      "properties": {
        "qualified": { "type": "boolean" },
        "level": { "type": "string", "enum": ["stable", "narrowed_below_stable"] },
        "narrow_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason" }
        }
      }
    },
    "producer_attribution_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_ref",
        "schema_version",
        "integrity_hash",
        "captured_at",
        "producer_attribution_complete"
      ],
      "properties": {
        "producer_ref": { "type": "string" },
        "schema_version": { "type": "integer", "const": 1 },
        "integrity_hash": { "type": "string" },
        "captured_at": { "type": "string" },
        "producer_attribution_complete": { "type": "boolean" }
      }
    },
    "migration_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_class",
        "artifact_ref",
        "schema_compatibility_class",
        "from_schema_version",
        "to_schema_version",
        "migration_outcome",
        "repair_transaction_id",
        "finding_code",
        "preserves_restore_provenance",
        "preserves_encoding_fidelity",
        "preserves_trust_state",
        "preserves_no_rerun_semantics",
        "rerun_posture",
        "commit_action_id",
        "commit_disclosure_id",
        "redaction_class",
        "support_export_posture",
        "mutates_state",
        "is_required"
      ],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/non_empty_string" },
        "artifact_class": { "$ref": "#/$defs/artifact_class_kind" },
        "artifact_ref": { "$ref": "#/$defs/non_empty_string" },
        "schema_compatibility_class": { "$ref": "#/$defs/schema_compatibility_class" },
        "from_schema_version": { "type": "integer", "minimum": 0 },
        "to_schema_version": { "type": "integer", "minimum": 0 },
        "migration_outcome": { "$ref": "#/$defs/migration_outcome" },
        "migration_disclosure_ref": { "type": ["string", "null"] },
        "repair_transaction_id": { "type": "string" },
        "finding_code": { "type": "string" },
        "preserves_restore_provenance": { "type": "boolean" },
        "preserves_encoding_fidelity": { "type": "boolean" },
        "preserves_trust_state": { "type": "boolean" },
        "preserves_no_rerun_semantics": { "type": "boolean" },
        "rerun_posture": { "$ref": "#/$defs/rerun_posture" },
        "commit_action_id": { "type": "string" },
        "commit_disclosure_id": { "type": "string" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "redaction_disclosure_ref": { "type": ["string", "null"] },
        "support_export_posture": { "$ref": "#/$defs/support_export_posture" },
        "mutates_state": { "type": "boolean" },
        "is_required": { "type": "boolean" }
      }
    },
    "repair_flow_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repair_flow_id",
        "label",
        "repair_flow_kind",
        "artifact_id",
        "repair_outcome",
        "repair_transaction_id",
        "finding_code",
        "preserves_restore_provenance",
        "preserves_encoding_fidelity",
        "preserves_trust_state",
        "preserves_no_rerun_semantics",
        "rerun_posture",
        "commit_action_id",
        "commit_disclosure_id",
        "redaction_class",
        "support_export_posture",
        "mutates_state",
        "is_required"
      ],
      "properties": {
        "repair_flow_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "type": "string" },
        "repair_flow_kind": { "$ref": "#/$defs/repair_flow_kind" },
        "artifact_id": { "$ref": "#/$defs/non_empty_string" },
        "repair_outcome": { "$ref": "#/$defs/repair_outcome" },
        "repair_disclosure_ref": { "type": ["string", "null"] },
        "repair_transaction_id": { "type": "string" },
        "finding_code": { "type": "string" },
        "preserves_restore_provenance": { "type": "boolean" },
        "preserves_encoding_fidelity": { "type": "boolean" },
        "preserves_trust_state": { "type": "boolean" },
        "preserves_no_rerun_semantics": { "type": "boolean" },
        "rerun_posture": { "$ref": "#/$defs/rerun_posture" },
        "commit_action_id": { "type": "string" },
        "commit_disclosure_id": { "type": "string" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "redaction_disclosure_ref": { "type": ["string", "null"] },
        "support_export_posture": { "$ref": "#/$defs/support_export_posture" },
        "mutates_state": { "type": "boolean" },
        "is_required": { "type": "boolean" }
      }
    },
    "artifact_class_coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["migration_rows", "all_required_artifact_classes_present"],
      "properties": {
        "migration_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/migration_row" }
        },
        "all_required_artifact_classes_present": { "type": "boolean" }
      }
    },
    "repair_flow_coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repair_flow_rows", "all_required_repair_flow_kinds_present"],
      "properties": {
        "repair_flow_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/repair_flow_row" }
        },
        "all_required_repair_flow_kinds_present": { "type": "boolean" }
      }
    },
    "schema_version_pinning_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_migrations_pin_from_schema",
        "all_migrations_pin_to_schema",
        "all_migrations_no_downgrade"
      ],
      "properties": {
        "all_migrations_pin_from_schema": { "type": "boolean" },
        "all_migrations_pin_to_schema": { "type": "boolean" },
        "all_migrations_no_downgrade": { "type": "boolean" }
      }
    },
    "outcome_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_migration_disclosures_present",
        "all_repair_disclosures_present",
        "all_redaction_disclosures_present"
      ],
      "properties": {
        "all_migration_disclosures_present": { "type": "boolean" },
        "all_repair_disclosures_present": { "type": "boolean" },
        "all_redaction_disclosures_present": { "type": "boolean" }
      }
    },
    "preservation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_rows_preserve_restore_provenance",
        "all_rows_preserve_encoding_fidelity",
        "all_rows_preserve_trust_state",
        "all_rows_preserve_no_rerun_semantics"
      ],
      "properties": {
        "all_rows_preserve_restore_provenance": { "type": "boolean" },
        "all_rows_preserve_encoding_fidelity": { "type": "boolean" },
        "all_rows_preserve_trust_state": { "type": "boolean" },
        "all_rows_preserve_no_rerun_semantics": { "type": "boolean" }
      }
    },
    "no_silent_rerun_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_rows_safe_rerun_posture",
        "all_mutating_rows_have_commit_metadata"
      ],
      "properties": {
        "all_rows_safe_rerun_posture": { "type": "boolean" },
        "all_mutating_rows_have_commit_metadata": { "type": "boolean" }
      }
    },
    "repair_transaction_pinning_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_rows_pin_repair_transaction_id",
        "all_rows_pin_finding_code"
      ],
      "properties": {
        "all_rows_pin_repair_transaction_id": { "type": "boolean" },
        "all_rows_pin_finding_code": { "type": "boolean" }
      }
    },
    "support_export_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_rows_preserve_fields",
        "all_rows_exclude_raw_secrets",
        "all_rows_exclude_raw_artifact_bytes",
        "all_rows_exclude_approval_tickets",
        "all_rows_exclude_delegated_credentials",
        "all_rows_exclude_live_authority_handles"
      ],
      "properties": {
        "all_rows_preserve_fields": { "type": "boolean" },
        "all_rows_exclude_raw_secrets": { "type": "boolean" },
        "all_rows_exclude_raw_artifact_bytes": { "type": "boolean" },
        "all_rows_exclude_approval_tickets": { "type": "boolean" },
        "all_rows_exclude_delegated_credentials": { "type": "boolean" },
        "all_rows_exclude_live_authority_handles": { "type": "boolean" }
      }
    },
    "inspection_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hook_class", "action_id", "label", "available", "disclosure"],
      "properties": {
        "hook_class": { "$ref": "#/$defs/inspection_hook_class" },
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "available": { "type": "boolean" },
        "disclosure": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  }
}
