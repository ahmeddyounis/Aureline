{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/workflow_bundle_review.schema.json",
  "title": "Aureline workflow-bundle review packet",
  "description": "Workspace-owned boundary schema for workflow-bundle detail, install/update diff review, drift and local-override review, remove/rollback review, certification truth, mirror/offline posture, diagnostics, CLI/headless, and support export parity. The packet composes governed workflow-bundle manifest, change-preview, and drift-row artifacts into one support-safe review record before durable install, update, rebase, remove, or rollback. Raw paths, raw settings values, raw user content, raw secrets, raw extension binaries, and signing material never cross this boundary.",
  "type": "object",
  "$ref": "#/$defs/workflow_bundle_review_beta_record",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "bundle_class": {
      "type": "string",
      "enum": [
        "launch_bundle",
        "imported_user_bundle",
        "org_approved_bundle",
        "design_partner_bundle",
        "local_draft_bundle"
      ]
    },
    "bundle_source_class": {
      "type": "string",
      "enum": [
        "certified",
        "managed_approved",
        "community",
        "imported",
        "local_draft"
      ]
    },
    "bundle_status_class": {
      "type": "string",
      "enum": [
        "certified_current",
        "certified_retest_pending",
        "managed_approved_current",
        "community_reviewed",
        "community_unreviewed",
        "imported_pending_review",
        "local_draft",
        "deprecated_or_archived",
        "retest_needed",
        "status_unknown"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "officially_supported",
        "community_supported",
        "experimental",
        "legacy_deprecated",
        "unsupported",
        "support_unknown"
      ]
    },
    "effective_badge_class": {
      "type": "string",
      "enum": [
        "certified",
        "managed_approved",
        "community",
        "imported",
        "local_draft",
        "retest_pending",
        "limited",
        "status_unknown"
      ]
    },
    "evidence_freshness_class": {
      "type": "string",
      "enum": [
        "fresh_current",
        "aging_within_window",
        "stale_past_window",
        "imported_evidence",
        "evidence_unknown"
      ]
    },
    "certification_state_class": {
      "type": "string",
      "enum": [
        "certified_current",
        "managed_approved_current",
        "community_unverified",
        "imported_pending_review",
        "local_draft",
        "retest_pending",
        "evidence_stale",
        "status_unknown"
      ]
    },
    "support_claim_class": {
      "type": "string",
      "enum": [
        "stable_launch_wedge_claim",
        "managed_org_claim",
        "community_no_certification_claim",
        "imported_pending_review_claim",
        "local_draft_no_claim",
        "limited_retest_pending_claim"
      ]
    },
    "change_axis": {
      "type": "string",
      "enum": [
        "extension_set",
        "profile_preset",
        "surface_preset",
        "settings_or_token",
        "task_recipe",
        "launch_recipe",
        "debug_recipe",
        "template_or_scaffold_ref",
        "docs_pack",
        "tour_pack",
        "glossary_pack",
        "migration_mapping",
        "certification_target",
        "evidence_link",
        "trust_or_permission",
        "compatibility_or_runtime",
        "side_effect"
      ]
    },
    "change_kind": {
      "type": "string",
      "enum": [
        "added",
        "removed",
        "changed",
        "revision_bumped",
        "unchanged_visible",
        "preserved_local",
        "blocked_pending_review",
        "skipped_no_op"
      ]
    },
    "ownership_class": {
      "type": "string",
      "enum": [
        "bundle_owned",
        "user_owned",
        "shared_user_overlay_on_bundle",
        "mixed_unknown_provenance"
      ]
    },
    "safe_to_remove_class": {
      "type": "string",
      "enum": [
        "safe_to_remove_no_user_data",
        "safe_to_remove_user_overlay_preserved",
        "review_required_user_data_co_resident",
        "not_safe_to_remove_user_owned",
        "not_safe_to_remove_policy_locked"
      ]
    },
    "review_action_id": {
      "type": "string",
      "enum": [
        "review.compare",
        "review.confirm",
        "review.cancel",
        "review.set_up_later",
        "review.inspect_change_source",
        "review.create_rollback_checkpoint"
      ]
    },
    "resolve_action_id": {
      "type": "string",
      "enum": [
        "resolve.keep_local",
        "resolve.adopt_bundle",
        "resolve.compare",
        "resolve.rebase_to_bundle",
        "resolve.ignore_this_drift"
      ]
    },
    "action_rendered_state": {
      "type": "string",
      "enum": [
        "enabled",
        "visible_disabled",
        "hidden_not_applicable",
        "preflight_pending"
      ]
    },
    "rollback_linkage_class": {
      "type": "string",
      "enum": [
        "single_attributable_workspace_checkpoint",
        "single_attributable_profile_checkpoint",
        "single_attributable_user_checkpoint",
        "single_appearance_checkpoint_only_for_visual",
        "paired_workspace_and_appearance_checkpoint",
        "non_reversible_with_justification",
        "non_reversible_pending_review"
      ]
    },
    "rollback_path_class": {
      "type": "string",
      "enum": [
        "single_checkpoint_revert",
        "surface_reload_then_revert",
        "full_restart_then_revert",
        "manual_recovery_only",
        "not_reversible"
      ]
    },
    "drift_subject_granularity_class": {
      "type": "string",
      "enum": [
        "field",
        "package",
        "task",
        "component",
        "certification_evidence",
        "mirror_or_offline_pack"
      ]
    },
    "mirror_offline_posture_class": {
      "type": "string",
      "enum": [
        "live_origin_only",
        "live_or_mirror",
        "mirror_only",
        "signed_offline_bundle",
        "offline_no_bundle",
        "packaging_posture_unknown"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "start_center",
        "bundle_detail",
        "cli_headless",
        "diagnostics",
        "support_export",
        "docs_workspace"
      ]
    },
    "bundle_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_id",
        "bundle_revision",
        "bundle_class",
        "bundle_source_class",
        "bundle_status_class",
        "support_class",
        "signer_source_class",
        "signer_ref",
        "manifest_ref",
        "manifest_digest_ref",
        "compatible_aureline_range",
        "channel"
      ],
      "properties": {
        "bundle_id": { "$ref": "#/$defs/opaque_id" },
        "bundle_revision": { "type": "integer", "minimum": 1 },
        "bundle_revision_semver": { "$ref": "#/$defs/opaque_id" },
        "bundle_class": { "$ref": "#/$defs/bundle_class" },
        "bundle_source_class": { "$ref": "#/$defs/bundle_source_class" },
        "bundle_status_class": { "$ref": "#/$defs/bundle_status_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "signer_source_class": { "$ref": "#/$defs/opaque_id" },
        "signer_ref": { "$ref": "#/$defs/opaque_id" },
        "manifest_ref": { "$ref": "#/$defs/opaque_id" },
        "manifest_digest_ref": { "$ref": "#/$defs/opaque_id" },
        "compatible_aureline_range": { "$ref": "#/$defs/opaque_id" },
        "channel": { "$ref": "#/$defs/opaque_id" },
        "imported_source_ref": { "$ref": "#/$defs/opaque_id" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "bundle_class": { "const": "imported_user_bundle" }
            }
          },
          "then": {
            "required": ["imported_source_ref"]
          }
        }
      ]
    },
    "source_class_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_class", "display_label", "caveat_ref"],
      "properties": {
        "source_class": { "$ref": "#/$defs/bundle_source_class" },
        "display_label": { "$ref": "#/$defs/opaque_id" },
        "caveat_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "content_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_ref",
        "item_class",
        "ownership_class",
        "source_class",
        "summary_ref",
        "revision_ref",
        "mirrorable",
        "disclosure_required"
      ],
      "properties": {
        "item_ref": { "$ref": "#/$defs/opaque_id" },
        "item_class": { "$ref": "#/$defs/opaque_id" },
        "ownership_class": { "$ref": "#/$defs/ownership_class" },
        "source_class": { "$ref": "#/$defs/bundle_source_class" },
        "summary_ref": { "$ref": "#/$defs/opaque_id" },
        "revision_ref": { "$ref": "#/$defs/opaque_id" },
        "mirrorable": { "type": "boolean" },
        "disclosure_required": { "const": true }
      }
    },
    "detail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "extension_sets",
        "presets",
        "task_launch_debug_recipes",
        "docs_tour_packs",
        "template_refs",
        "migration_mappings",
        "certification_targets"
      ],
      "properties": {
        "extension_sets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/content_item" }
        },
        "presets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/content_item" }
        },
        "task_launch_debug_recipes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/content_item" }
        },
        "docs_tour_packs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/content_item" }
        },
        "template_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/content_item" }
        },
        "migration_mappings": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/content_item" }
        },
        "certification_targets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/content_item" }
        }
      }
    },
    "certification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_badge_class",
        "evidence_freshness_class",
        "certification_state_class",
        "effective_badge_class",
        "support_claim_class",
        "compatibility_evidence_refs",
        "retest_required"
      ],
      "properties": {
        "source_badge_class": { "$ref": "#/$defs/bundle_source_class" },
        "evidence_freshness_class": { "$ref": "#/$defs/evidence_freshness_class" },
        "certification_state_class": { "$ref": "#/$defs/certification_state_class" },
        "effective_badge_class": { "$ref": "#/$defs/effective_badge_class" },
        "support_claim_class": { "$ref": "#/$defs/support_claim_class" },
        "reference_workspace_ref": { "$ref": "#/$defs/opaque_id" },
        "compatibility_evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "retest_required": { "type": "boolean" }
      }
    },
    "diff_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "change_axis",
        "change_kind",
        "subject_kind",
        "subject_ref",
        "ownership_class",
        "disclosure_required",
        "keyboard_reachable"
      ],
      "properties": {
        "change_axis": { "$ref": "#/$defs/change_axis" },
        "change_kind": { "$ref": "#/$defs/change_kind" },
        "subject_kind": { "$ref": "#/$defs/opaque_id" },
        "subject_ref": { "$ref": "#/$defs/opaque_id" },
        "ownership_class": { "$ref": "#/$defs/ownership_class" },
        "before_ref": { "$ref": "#/$defs/opaque_id" },
        "after_ref": { "$ref": "#/$defs/opaque_id" },
        "local_override_ref": { "$ref": "#/$defs/opaque_id" },
        "routes_through_preview_ref": { "$ref": "#/$defs/opaque_id" },
        "disclosure_required": { "const": true },
        "keyboard_reachable": { "const": true }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "change_kind": { "const": "preserved_local" }
            }
          },
          "then": {
            "required": ["local_override_ref"]
          }
        }
      ]
    },
    "review_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "rendered_state", "keyboard_reachable"],
      "properties": {
        "action_id": { "$ref": "#/$defs/review_action_id" },
        "rendered_state": { "$ref": "#/$defs/action_rendered_state" },
        "destination_ref": { "$ref": "#/$defs/opaque_id" },
        "disabled_reason_code": { "$ref": "#/$defs/opaque_id" },
        "keyboard_reachable": { "const": true }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "rendered_state": { "const": "visible_disabled" }
            }
          },
          "then": {
            "required": ["disabled_reason_code"]
          }
        }
      ]
    },
    "rollback_checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "linkage_class",
        "rollback_path_class",
        "restorable_axes",
        "attributable_to_review"
      ],
      "properties": {
        "linkage_class": { "$ref": "#/$defs/rollback_linkage_class" },
        "rollback_path_class": { "$ref": "#/$defs/rollback_path_class" },
        "checkpoint_ref": { "$ref": "#/$defs/opaque_id" },
        "restorable_axes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "attributable_to_review": { "const": true }
      }
    },
    "side_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "side_effect_class",
        "scope_class",
        "summary_ref",
        "reversible_in_rollback"
      ],
      "properties": {
        "side_effect_class": { "$ref": "#/$defs/opaque_id" },
        "scope_class": { "$ref": "#/$defs/opaque_id" },
        "summary_ref": { "$ref": "#/$defs/opaque_id" },
        "reversible_in_rollback": { "type": "boolean" }
      }
    },
    "install_update_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_state_class",
        "preview_refs",
        "diff_entries",
        "actions",
        "rollback_checkpoint",
        "side_effects"
      ],
      "properties": {
        "review_state_class": { "$ref": "#/$defs/opaque_id" },
        "preview_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "diff_entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/diff_entry" },
          "allOf": [
            { "contains": { "properties": { "change_axis": { "const": "extension_set" } }, "required": ["change_axis"] } },
            { "contains": { "properties": { "change_axis": { "const": "profile_preset" } }, "required": ["change_axis"] } },
            { "contains": { "properties": { "change_axis": { "const": "surface_preset" } }, "required": ["change_axis"] } },
            { "contains": { "properties": { "change_axis": { "const": "settings_or_token" } }, "required": ["change_axis"] } },
            { "contains": { "properties": { "change_axis": { "const": "task_recipe" } }, "required": ["change_axis"] } },
            { "contains": { "properties": { "change_axis": { "const": "launch_recipe" } }, "required": ["change_axis"] } },
            { "contains": { "properties": { "change_axis": { "const": "debug_recipe" } }, "required": ["change_axis"] } },
            { "contains": { "properties": { "change_axis": { "const": "docs_pack" } }, "required": ["change_axis"] } },
            { "contains": { "properties": { "change_axis": { "const": "tour_pack" } }, "required": ["change_axis"] } },
            { "contains": { "properties": { "change_axis": { "const": "template_or_scaffold_ref" } }, "required": ["change_axis"] } },
            { "contains": { "properties": { "change_axis": { "const": "migration_mapping" } }, "required": ["change_axis"] } },
            { "contains": { "properties": { "change_axis": { "const": "certification_target" } }, "required": ["change_axis"] } }
          ]
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/review_action" }
        },
        "rollback_checkpoint": { "$ref": "#/$defs/rollback_checkpoint" },
        "side_effects": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/side_effect" }
        }
      }
    },
    "resolve_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "rendered_state", "keyboard_reachable"],
      "properties": {
        "action_id": { "$ref": "#/$defs/resolve_action_id" },
        "rendered_state": { "$ref": "#/$defs/action_rendered_state" },
        "destination_ref": { "$ref": "#/$defs/opaque_id" },
        "disabled_reason_code": { "$ref": "#/$defs/opaque_id" },
        "keyboard_reachable": { "const": true }
      },
      "allOf": [
        {
          "if": {
            "allOf": [
              {
                "properties": {
                  "action_id": {
                    "enum": ["resolve.adopt_bundle", "resolve.rebase_to_bundle"]
                  }
                }
              },
              {
                "properties": {
                  "rendered_state": { "const": "enabled" }
                }
              }
            ]
          },
          "then": {
            "required": ["destination_ref"],
            "properties": {
              "destination_ref": { "pattern": "bundle_change_preview" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "rendered_state": { "const": "visible_disabled" }
            }
          },
          "then": {
            "required": ["disabled_reason_code"]
          }
        }
      ]
    },
    "drift_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drift_state_class",
        "drift_axis",
        "subject_granularity_class",
        "subject_ref",
        "asset_ownership_class",
        "claim_narrowing_class",
        "resolve_actions"
      ],
      "properties": {
        "drift_state_class": { "$ref": "#/$defs/opaque_id" },
        "drift_axis": { "$ref": "#/$defs/change_axis" },
        "subject_granularity_class": { "$ref": "#/$defs/drift_subject_granularity_class" },
        "subject_ref": { "$ref": "#/$defs/opaque_id" },
        "asset_ownership_class": { "$ref": "#/$defs/ownership_class" },
        "claim_narrowing_class": { "$ref": "#/$defs/opaque_id" },
        "preserved_local_override_ref": { "$ref": "#/$defs/opaque_id" },
        "resolve_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/resolve_action" },
          "contains": {
            "properties": {
              "action_id": { "const": "resolve.compare" }
            },
            "required": ["action_id"]
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "drift_state_class": { "const": "local_override" }
            }
          },
          "then": {
            "required": ["preserved_local_override_ref"]
          }
        }
      ]
    },
    "drift_override_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drift_state_class",
        "field_package_task_granular",
        "drift_entries"
      ],
      "properties": {
        "drift_state_class": { "$ref": "#/$defs/opaque_id" },
        "field_package_task_granular": { "const": true },
        "drift_entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/drift_entry" }
        }
      }
    },
    "removable_asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_ref",
        "asset_kind",
        "ownership_class",
        "safe_to_remove_class",
        "review_required",
        "explicit_reviewed"
      ],
      "properties": {
        "asset_ref": { "$ref": "#/$defs/opaque_id" },
        "asset_kind": { "$ref": "#/$defs/opaque_id" },
        "ownership_class": { "$ref": "#/$defs/ownership_class" },
        "safe_to_remove_class": { "$ref": "#/$defs/safe_to_remove_class" },
        "review_required": { "type": "boolean" },
        "explicit_reviewed": { "const": true }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "ownership_class": { "const": "user_owned" }
            }
          },
          "then": {
            "properties": {
              "safe_to_remove_class": { "const": "not_safe_to_remove_user_owned" }
            }
          }
        }
      ]
    },
    "retained_override": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "override_ref",
        "retained_class",
        "target_scope_class"
      ],
      "properties": {
        "override_ref": { "$ref": "#/$defs/opaque_id" },
        "retained_class": { "$ref": "#/$defs/opaque_id" },
        "target_scope_class": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "remove_rollback_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_state_class",
        "remove_review_ref",
        "rollback_target_ref",
        "rollback_checkpoint_ref",
        "removable_assets",
        "retained_local_overrides",
        "actions"
      ],
      "properties": {
        "review_state_class": { "$ref": "#/$defs/opaque_id" },
        "remove_review_ref": { "$ref": "#/$defs/opaque_id" },
        "rollback_target_ref": { "$ref": "#/$defs/opaque_id" },
        "rollback_checkpoint_ref": { "$ref": "#/$defs/opaque_id" },
        "removable_assets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/removable_asset" }
        },
        "retained_local_overrides": {
          "type": "array",
          "items": { "$ref": "#/$defs/retained_override" }
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/review_action" }
        }
      }
    },
    "mirror_offline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "posture_class",
        "source_registry_ref",
        "signer_ref",
        "compatible_aureline_range",
        "retest_needed_preserved",
        "offline_restore_review_ref"
      ],
      "properties": {
        "posture_class": { "$ref": "#/$defs/mirror_offline_posture_class" },
        "source_registry_ref": { "$ref": "#/$defs/opaque_id" },
        "mirror_ref": { "$ref": "#/$defs/opaque_id" },
        "offline_pack_ref": { "$ref": "#/$defs/opaque_id" },
        "signer_ref": { "$ref": "#/$defs/opaque_id" },
        "compatible_aureline_range": { "$ref": "#/$defs/opaque_id" },
        "retest_needed_preserved": { "type": "boolean" },
        "offline_restore_review_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_packet_refs",
        "diagnostics_refs",
        "cli_headless_refs",
        "raw_secret_export_allowed",
        "raw_user_content_export_allowed",
        "raw_paths_export_allowed",
        "redaction_class"
      ],
      "properties": {
        "export_packet_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "diagnostics_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "cli_headless_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "raw_secret_export_allowed": { "const": false },
        "raw_user_content_export_allowed": { "const": false },
        "raw_paths_export_allowed": { "const": false },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "providers_recommended_only",
        "remote_modes_recommended_only",
        "templates_recommended_only",
        "workspace_trust_widened",
        "network_egress_widened_without_review",
        "policy_scope_widened_without_review",
        "approval_defaults_widened_without_review"
      ],
      "properties": {
        "providers_recommended_only": { "const": true },
        "remote_modes_recommended_only": { "const": true },
        "templates_recommended_only": { "const": true },
        "workspace_trust_widened": { "const": false },
        "network_egress_widened_without_review": { "const": false },
        "policy_scope_widened_without_review": { "const": false },
        "approval_defaults_widened_without_review": { "const": false }
      }
    },
    "review_invariants": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diff_before_apply",
        "rollback_reviewed",
        "removal_preserves_user_assets",
        "cli_headless_parity",
        "diagnostics_export_parity",
        "offline_mirror_truth_preserved",
        "no_hidden_imperative_hooks",
        "no_raw_secret_injection"
      ],
      "properties": {
        "diff_before_apply": { "const": true },
        "rollback_reviewed": { "const": true },
        "removal_preserves_user_assets": { "const": true },
        "cli_headless_parity": { "const": true },
        "diagnostics_export_parity": { "const": true },
        "offline_mirror_truth_preserved": { "const": true },
        "no_hidden_imperative_hooks": { "const": true },
        "no_raw_secret_injection": { "const": true }
      }
    },
    "workflow_bundle_review_beta_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "review_id",
        "minted_at",
        "bundle_identity",
        "source_class_legend",
        "detail",
        "certification",
        "install_update_review",
        "drift_override_review",
        "remove_rollback_review",
        "mirror_offline",
        "support_export",
        "consumer_surfaces",
        "guardrails",
        "review_invariants"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "record_kind": { "const": "workflow_bundle_review_beta_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "review_id": { "$ref": "#/$defs/opaque_id" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "bundle_identity": { "$ref": "#/$defs/bundle_identity" },
        "source_class_legend": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/source_class_disclosure" },
          "allOf": [
            { "contains": { "properties": { "source_class": { "const": "certified" } }, "required": ["source_class"] } },
            { "contains": { "properties": { "source_class": { "const": "managed_approved" } }, "required": ["source_class"] } },
            { "contains": { "properties": { "source_class": { "const": "community" } }, "required": ["source_class"] } },
            { "contains": { "properties": { "source_class": { "const": "imported" } }, "required": ["source_class"] } },
            { "contains": { "properties": { "source_class": { "const": "local_draft" } }, "required": ["source_class"] } }
          ]
        },
        "detail": { "$ref": "#/$defs/detail" },
        "certification": { "$ref": "#/$defs/certification" },
        "install_update_review": { "$ref": "#/$defs/install_update_review" },
        "drift_override_review": { "$ref": "#/$defs/drift_override_review" },
        "remove_rollback_review": { "$ref": "#/$defs/remove_rollback_review" },
        "mirror_offline": { "$ref": "#/$defs/mirror_offline" },
        "support_export": { "$ref": "#/$defs/support_export" },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/consumer_surface" },
          "allOf": [
            { "contains": { "const": "start_center" } },
            { "contains": { "const": "cli_headless" } },
            { "contains": { "const": "diagnostics" } },
            { "contains": { "const": "support_export" } }
          ]
        },
        "guardrails": { "$ref": "#/$defs/guardrails" },
        "review_invariants": { "$ref": "#/$defs/review_invariants" }
      }
    }
  }
}
