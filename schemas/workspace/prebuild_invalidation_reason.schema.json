{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/prebuild_invalidation_reason.schema.json",
  "title": "Aureline prebuild invalidation reason and bundle record",
  "description": "Boundary schema for typed prebuild invalidation reasons. These records explain why a cached prebuild, warm-start artifact, snapshot, or claimed resume path is valid, stale, partially reusable, or denied. They make dependency drift, environment mismatch, policy and trust drift, secret-handle changes, stale indexes, missing artifacts, freshness expiry, and false live-resume claims inspectable without raw secrets or machine-specific residue.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/prebuild_invalidation_reason_record" },
    { "$ref": "#/$defs/prebuild_invalidation_bundle_record" }
  ],
  "$defs": {
    "prebuild_invalidation_reason_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this invalidation reason family. Additive enum or optional-field changes bump this value; repurposing an existing value is breaking."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "prebuild_invalidation_reason_record",
        "prebuild_invalidation_bundle_record"
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe to log and export. Raw paths, secret values, URLs with credentials, and raw payload bodies never appear here."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 320,
      "description": "Short sentence safe for UI, CLI, support bundles, and audit logs. Raw secrets and raw residue never appear."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "reason_category": {
      "type": "string",
      "enum": [
        "source",
        "dependencies",
        "environment",
        "toolchain",
        "platform_host",
        "policy_trust",
        "feature_entitlement",
        "secrets_credentials",
        "ports_routes",
        "indexes_caches",
        "artifact_presence",
        "freshness",
        "entry_path_claim",
        "residue",
        "schema"
      ]
    },
    "reason_class": {
      "type": "string",
      "enum": [
        "source_revision_mismatch",
        "source_tree_digest_mismatch",
        "submodule_lfs_sparse_posture_changed",
        "dependency_lock_drift",
        "environment_capsule_hash_mismatch",
        "workspace_template_digest_mismatch",
        "base_image_or_host_identity_mismatch",
        "platform_arch_mismatch",
        "host_class_mismatch",
        "critical_toolchain_digest_mismatch",
        "package_manager_lock_mismatch",
        "extension_lock_digest_mismatch",
        "policy_epoch_changed",
        "policy_bundle_ref_changed",
        "trust_state_changed",
        "sandbox_profile_changed",
        "egress_posture_changed",
        "feature_flag_digest_changed",
        "entitlement_snapshot_expired",
        "secret_handle_set_changed",
        "credential_revalidation_required",
        "trust_store_changed",
        "port_binding_conflict",
        "route_or_target_identity_mismatch",
        "index_epoch_stale",
        "index_schema_mismatch",
        "cache_artifact_missing",
        "prebuild_artifact_missing",
        "provenance_manifest_missing",
        "freshness_window_expired",
        "claimed_warm_start_without_warm_evidence",
        "claimed_live_resume_without_live_session",
        "stale_snapshot_claimed_as_live_resume",
        "materialization_record_missing",
        "non_portable_residue_detected",
        "schema_version_unsupported",
        "unknown_must_rebuild"
      ]
    },
    "reuse_effect": {
      "type": "string",
      "enum": [
        "allow_reuse",
        "allow_reuse_after_revalidation",
        "partial_warm_only",
        "rebuild_required",
        "clone_fresh_required",
        "resume_live_denied",
        "support_packet_blocked_until_labeled"
      ]
    },
    "required_revalidation_class": {
      "type": "string",
      "enum": [
        "none",
        "credentials",
        "ports",
        "indexes",
        "policy",
        "trust",
        "feature_flags",
        "source",
        "environment",
        "toolchain",
        "host",
        "schema",
        "redaction_review"
      ]
    },
    "user_disclosure_class": {
      "type": "string",
      "enum": [
        "no_user_notice_required",
        "show_prebuild_reused",
        "show_revalidation_required",
        "show_partial_warm_reuse",
        "show_rebuild_required",
        "show_clone_fresh_required",
        "show_resume_denied_snapshot_available",
        "show_support_export_redaction_block"
      ]
    },
    "reuse_outcome_class": {
      "type": "string",
      "enum": [
        "reuse_allowed",
        "reuse_after_revalidation",
        "partial_warm_reuse_only",
        "rebuild_required",
        "clone_fresh_required",
        "resume_live_denied"
      ]
    },
    "support_packet_label_class": {
      "type": "string",
      "enum": [
        "valid_prebuild",
        "stale_prebuild",
        "partial_warm_prebuild",
        "rebuild_required",
        "clone_fresh_required",
        "resume_live_denied_snapshot_only",
        "redaction_review_required"
      ]
    },
    "snapshot_live_resume_status": {
      "type": "string",
      "enum": [
        "not_live_resume_claim",
        "live_resume_validated",
        "live_resume_denied_snapshot_only"
      ]
    },
    "comparison_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_field_ref", "current_field_ref"],
      "properties": {
        "candidate_field_ref": { "$ref": "#/$defs/opaque_id" },
        "current_field_ref": { "$ref": "#/$defs/opaque_id" },
        "expected_ref": { "type": ["string", "null"] },
        "observed_ref": { "type": ["string", "null"] },
        "evidence_ref": { "type": ["string", "null"] }
      }
    },
    "prebuild_invalidation_reason_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "prebuild_invalidation_reason_schema_version",
        "reason_id",
        "fingerprint_ref",
        "detected_at",
        "reason_class",
        "reason_category",
        "comparison_refs",
        "reuse_effect",
        "required_revalidations",
        "user_disclosure_class",
        "stale_snapshot_live_resume_guard",
        "support_summary"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "$schema": { "type": "string" },
        "record_kind": { "const": "prebuild_invalidation_reason_record" },
        "prebuild_invalidation_reason_schema_version": { "$ref": "#/$defs/prebuild_invalidation_reason_schema_version" },
        "reason_id": { "$ref": "#/$defs/opaque_id" },
        "fingerprint_ref": { "$ref": "#/$defs/opaque_id" },
        "detected_at": { "$ref": "#/$defs/timestamp" },
        "reason_class": { "$ref": "#/$defs/reason_class" },
        "reason_category": { "$ref": "#/$defs/reason_category" },
        "comparison_refs": { "$ref": "#/$defs/comparison_refs" },
        "reuse_effect": { "$ref": "#/$defs/reuse_effect" },
        "required_revalidations": {
          "type": "array",
          "items": { "$ref": "#/$defs/required_revalidation_class" },
          "uniqueItems": true,
          "minItems": 1
        },
        "user_disclosure_class": { "$ref": "#/$defs/user_disclosure_class" },
        "stale_snapshot_live_resume_guard": {
          "type": "boolean",
          "const": true,
          "description": "Always true: stale snapshots and invalidated prebuilds must not be labeled as live resume."
        },
        "support_summary": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "reason_class": {
                "enum": [
                  "claimed_live_resume_without_live_session",
                  "stale_snapshot_claimed_as_live_resume"
                ]
              }
            },
            "required": ["reason_class"]
          },
          "then": {
            "properties": {
              "reason_category": { "const": "entry_path_claim" },
              "reuse_effect": { "const": "resume_live_denied" },
              "user_disclosure_class": { "const": "show_resume_denied_snapshot_available" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "reason_class": {
                "enum": [
                  "secret_handle_set_changed",
                  "credential_revalidation_required",
                  "trust_store_changed"
                ]
              }
            },
            "required": ["reason_class"]
          },
          "then": {
            "properties": {
              "reason_category": { "const": "secrets_credentials" }
            }
          }
        }
      ]
    },
    "prebuild_invalidation_bundle_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "prebuild_invalidation_reason_schema_version",
        "bundle_id",
        "candidate_fingerprint_ref",
        "current_fingerprint_ref",
        "created_at",
        "reason_refs",
        "final_reuse_outcome",
        "required_revalidations",
        "snapshot_live_resume_status",
        "support_packet_label",
        "support_summary"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "$schema": { "type": "string" },
        "record_kind": { "const": "prebuild_invalidation_bundle_record" },
        "prebuild_invalidation_reason_schema_version": { "$ref": "#/$defs/prebuild_invalidation_reason_schema_version" },
        "bundle_id": { "$ref": "#/$defs/opaque_id" },
        "candidate_fingerprint_ref": { "$ref": "#/$defs/opaque_id" },
        "current_fingerprint_ref": { "$ref": "#/$defs/opaque_id" },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "reason_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "embedded_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/prebuild_invalidation_reason_record" }
        },
        "final_reuse_outcome": { "$ref": "#/$defs/reuse_outcome_class" },
        "required_revalidations": {
          "type": "array",
          "items": { "$ref": "#/$defs/required_revalidation_class" },
          "uniqueItems": true
        },
        "snapshot_live_resume_status": { "$ref": "#/$defs/snapshot_live_resume_status" },
        "support_packet_label": { "$ref": "#/$defs/support_packet_label_class" },
        "support_summary": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "snapshot_live_resume_status": { "const": "live_resume_denied_snapshot_only" }
            },
            "required": ["snapshot_live_resume_status"]
          },
          "then": {
            "properties": {
              "final_reuse_outcome": { "const": "resume_live_denied" },
              "support_packet_label": { "const": "resume_live_denied_snapshot_only" }
            }
          }
        }
      ]
    }
  }
}
