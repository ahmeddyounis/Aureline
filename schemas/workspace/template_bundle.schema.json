{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/template_bundle.schema.json",
  "title": "Aureline workspace-template bundle (alpha)",
  "description": "Boundary schema for the alpha workspace-template bundle frozen in docs/workspace/m3/template_bundle_alpha.md. The bundle is the pre-execution review record that Start Center, CLI / headless entry, docs, and support packets read before a template is used. It binds one signed template-manifest reference and projects source class, support class, target runtime, side-effect classes, trust posture, and open-without-starter bypass routes. Every bundle keeps bypass continuity at equal weight with apply, blocks raw secret / command / URL export, and claims the review invariants reviewed_before_use, inspectable_before_execution, and no_writes_before_review. Adding a new closed value is additive-minor and bumps schema_version; repurposing an existing value is breaking.",
  "type": "object",
  "$ref": "#/$defs/workspace_template_bundle_alpha_record",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable identifier safe to log, safe in support bundles, and safe on RPC. Raw paths, raw URLs, raw secrets never appear here."
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source_class": {
      "type": "string",
      "enum": [
        "first_party",
        "team_managed",
        "community",
        "local_only",
        "mirror_cached",
        "uncertified"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "officially_supported",
        "community_supported",
        "experimental",
        "legacy_deprecated",
        "unsupported",
        "support_unknown"
      ]
    },
    "runtime_scope_class": {
      "type": "string",
      "enum": [
        "local_only",
        "local_with_devcontainer",
        "local_with_container",
        "remote_image_required",
        "managed_cloud_required",
        "mixed_local_and_remote",
        "not_declared"
      ]
    },
    "host_boundary_class": {
      "type": "string",
      "enum": [
        "host_local_device_only",
        "host_local_with_devcontainer_attached",
        "host_local_with_container_attached",
        "host_remote_image_required",
        "host_managed_workspace_required",
        "host_mixed_local_and_remote",
        "host_boundary_unknown_requires_review"
      ]
    },
    "network_egress_class": {
      "type": "string",
      "enum": [
        "no_network_egress_required",
        "egress_to_first_party_origin_only",
        "egress_to_team_managed_mirror_only",
        "egress_to_community_origin_user_review_required",
        "egress_to_managed_workspace_envelope_only",
        "egress_envelope_unknown_requires_review"
      ]
    },
    "extension_install_class": {
      "type": "string",
      "enum": [
        "no_extension_install_required",
        "first_party_extension_install_required",
        "organization_curated_extension_install_required",
        "marketplace_extension_install_user_review_required",
        "managed_only_channel_extension_install_required",
        "extension_install_review_required_signature_unverified",
        "extension_install_class_unknown_requires_review"
      ]
    },
    "remote_provisioning_class": {
      "type": "string",
      "enum": [
        "no_remote_provisioning_required",
        "devcontainer_attach_required",
        "container_attach_required",
        "remote_image_required",
        "managed_workspace_required",
        "mixed_local_and_remote_provisioning_required",
        "remote_provisioning_unknown_requires_review"
      ]
    },
    "managed_service_class": {
      "type": "string",
      "enum": [
        "no_managed_service_required",
        "managed_workspace_envelope_required",
        "managed_only_channel_invocation_required",
        "third_party_connected_provider_required",
        "first_party_managed_service_required",
        "managed_service_class_unknown_requires_review"
      ]
    },
    "credential_provisioning_class": {
      "type": "string",
      "enum": [
        "no_credential_provisioning_required",
        "secret_broker_handle_required",
        "credential_provisioning_step_required",
        "remote_attach_handshake_required",
        "credential_provisioning_class_unknown_requires_review"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "start_center",
        "cli_headless_entry",
        "docs_workspace",
        "support_export"
      ]
    },
    "bypass_route_id": {
      "type": "string",
      "enum": [
        "bypass.open_folder_without_starter",
        "bypass.open_workspace_without_starter",
        "bypass.clone_repository_without_starter",
        "bypass.create_empty_workspace",
        "bypass.open_prebuild_minimal",
        "bypass.set_up_later",
        "bypass.continue_without_starter"
      ]
    },
    "bypass_continuity_class": {
      "type": "string",
      "const": "equal_weight_with_apply"
    },
    "source_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "source_distribution_class",
        "signature_state",
        "publisher_label",
        "trust_root_ref"
      ],
      "properties": {
        "source_class": { "$ref": "#/$defs/source_class" },
        "source_distribution_class": { "$ref": "#/$defs/non_empty_string" },
        "signature_state": { "$ref": "#/$defs/non_empty_string" },
        "publisher_label": { "$ref": "#/$defs/non_empty_string" },
        "trust_root_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "support_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["support_class", "lifecycle_class"],
      "properties": {
        "support_class": { "$ref": "#/$defs/support_class" },
        "lifecycle_class": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "target_runtime_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_scope_class",
        "host_boundary_class",
        "supported_ecosystems",
        "supported_platforms"
      ],
      "properties": {
        "runtime_scope_class": { "$ref": "#/$defs/runtime_scope_class" },
        "host_boundary_class": { "$ref": "#/$defs/host_boundary_class" },
        "supported_ecosystems": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "supported_platforms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "side_effect_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_network_egress_class",
        "required_extension_install_class",
        "required_remote_provisioning_class",
        "required_managed_service_class",
        "required_credential_provisioning_class",
        "declared_hook_count",
        "declared_setup_task_count",
        "side_effect_notes"
      ],
      "properties": {
        "required_network_egress_class": {
          "$ref": "#/$defs/network_egress_class"
        },
        "required_extension_install_class": {
          "$ref": "#/$defs/extension_install_class"
        },
        "required_remote_provisioning_class": {
          "$ref": "#/$defs/remote_provisioning_class"
        },
        "required_managed_service_class": {
          "$ref": "#/$defs/managed_service_class"
        },
        "required_credential_provisioning_class": {
          "$ref": "#/$defs/credential_provisioning_class"
        },
        "declared_hook_count": { "type": "integer", "minimum": 0 },
        "declared_setup_task_count": { "type": "integer", "minimum": 0 },
        "side_effect_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_sentence" }
        }
      }
    },
    "trust_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust_posture_class",
        "egress_posture_class",
        "trust_notes"
      ],
      "properties": {
        "trust_posture_class": { "$ref": "#/$defs/non_empty_string" },
        "egress_posture_class": { "$ref": "#/$defs/non_empty_string" },
        "trust_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_sentence" }
        }
      }
    },
    "bypass_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "open_without_starter_route_ids",
        "bypass_continuity_class"
      ],
      "properties": {
        "open_without_starter_route_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/bypass_route_id" }
        },
        "bypass_continuity_class": {
          "$ref": "#/$defs/bypass_continuity_class"
        },
        "bypass_guidance": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      }
    },
    "support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_packet_refs",
        "raw_secret_export_allowed",
        "raw_command_export_allowed",
        "raw_url_export_allowed",
        "redaction_class"
      ],
      "properties": {
        "export_packet_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "raw_secret_export_allowed": { "const": false },
        "raw_command_export_allowed": { "const": false },
        "raw_url_export_allowed": { "const": false },
        "redaction_class": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "review_invariants": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewed_before_use",
        "inspectable_before_execution",
        "no_writes_before_review"
      ],
      "properties": {
        "reviewed_before_use": { "const": true },
        "inspectable_before_execution": { "const": true },
        "no_writes_before_review": { "const": true }
      }
    },
    "workspace_template_bundle_alpha_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "bundle_id",
        "bound_template_manifest_ref",
        "bound_template_id",
        "bound_template_version",
        "display_label",
        "summary",
        "source_review",
        "support_review",
        "target_runtime_review",
        "side_effect_review",
        "trust_review",
        "bypass_review",
        "consumer_surfaces",
        "support_export",
        "review_invariants",
        "minted_at"
      ],
      "properties": {
        "record_kind": { "const": "workspace_template_bundle_alpha_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "bundle_id": { "$ref": "#/$defs/opaque_id" },
        "bound_template_manifest_ref": { "$ref": "#/$defs/opaque_id" },
        "bound_template_id": { "$ref": "#/$defs/opaque_id" },
        "bound_template_version": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "source_review": { "$ref": "#/$defs/source_review" },
        "support_review": { "$ref": "#/$defs/support_review" },
        "target_runtime_review": {
          "$ref": "#/$defs/target_runtime_review"
        },
        "side_effect_review": { "$ref": "#/$defs/side_effect_review" },
        "trust_review": { "$ref": "#/$defs/trust_review" },
        "bypass_review": { "$ref": "#/$defs/bypass_review" },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/consumer_surface" },
          "contains": { "const": "start_center" }
        },
        "support_export": { "$ref": "#/$defs/support_export" },
        "review_invariants": { "$ref": "#/$defs/review_invariants" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "managed_cloud_required runtime scope must declare managed-workspace provisioning, a managed-service class, and network egress.",
          "if": {
            "properties": {
              "target_runtime_review": {
                "properties": {
                  "runtime_scope_class": { "const": "managed_cloud_required" }
                }
              }
            }
          },
          "then": {
            "properties": {
              "target_runtime_review": {
                "properties": {
                  "host_boundary_class": {
                    "const": "host_managed_workspace_required"
                  }
                }
              },
              "side_effect_review": {
                "properties": {
                  "required_remote_provisioning_class": {
                    "const": "managed_workspace_required"
                  },
                  "required_managed_service_class": {
                    "enum": [
                      "managed_workspace_envelope_required",
                      "managed_only_channel_invocation_required",
                      "first_party_managed_service_required",
                      "third_party_connected_provider_required"
                    ]
                  },
                  "required_network_egress_class": {
                    "not": { "const": "no_network_egress_required" }
                  }
                }
              }
            }
          }
        },
        {
          "description": "local_only runtime scope keeps host boundary local-device and forbids remote / managed side effects.",
          "if": {
            "properties": {
              "target_runtime_review": {
                "properties": {
                  "runtime_scope_class": { "const": "local_only" }
                }
              }
            }
          },
          "then": {
            "properties": {
              "target_runtime_review": {
                "properties": {
                  "host_boundary_class": {
                    "enum": [
                      "host_local_device_only",
                      "host_boundary_unknown_requires_review"
                    ]
                  }
                }
              },
              "side_effect_review": {
                "properties": {
                  "required_remote_provisioning_class": {
                    "enum": [
                      "no_remote_provisioning_required",
                      "remote_provisioning_unknown_requires_review"
                    ]
                  },
                  "required_managed_service_class": {
                    "enum": [
                      "no_managed_service_required",
                      "managed_service_class_unknown_requires_review"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "description": "community / uncertified source classes must carry at least one trust note.",
          "if": {
            "properties": {
              "source_review": {
                "properties": {
                  "source_class": {
                    "enum": ["community", "uncertified"]
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "trust_review": {
                "properties": {
                  "trust_notes": { "minItems": 1 }
                }
              }
            }
          }
        }
      ]
    }
  }
}
