        },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "archetype_detection_schema_version": { "$ref": "#/$defs/archetype_detection_schema_version" },
        "admission_record_id": { "$ref": "#/$defs/opaque_id" },
        "emitted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "detection": { "$ref": "#/$defs/detection_section" },
        "recommendations": {
          "type": "array",
          "items": { "$ref": "#/$defs/recommendation" }
        },
        "policy": { "$ref": "#/$defs/policy_section" },
        "user_choice": { "$ref": "#/$defs/user_choice_section" },
        "readiness": { "$ref": "#/$defs/readiness_section" },
        "admission_checkpoint": { "$ref": "#/$defs/admission_checkpoint" },
        "first_useful_route": { "$ref": "#/$defs/first_useful_route" }
      },
      "description": "One post-entry archetype-detection and first-useful-work routing record."
    }
  }
