{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/m5-source-acquisition-review.schema.json",
  "title": "Aureline M5 source-acquisition review packet",
  "description": "Schema for the m5_source_acquisition_review_packet. The packet carries one inspectable review sheet per M5 starter family, each covering a single source-acquisition action and keeping clone, open, import, and resume as distinct verbs that are never silently rewritten. Each sheet records the source kind, host or mirror class, protocol, checkout mode, target path, expected cost band, and trust stage that the action will use, and discloses them before any irreversible network or disk action runs. Each sheet surfaces topology cues — nested repository, submodule, shallow or sparse checkout, LFS pointer, interrupted bootstrap, or omitted data — as explicit states with a one-step recovery or widen action, so a partial, sparse, shallow, LFS, or interrupted entry stays visible and recoverable rather than looking like missing data; a cue that applies must offer a recovery, and a cue that blocks first-useful-work must be recoverable. Each sheet previews follow-up setup-queue items — submodule init, LFS hydrate, docs import, package-restore suggestion, index warm-up, or bundle recommendation — with a run posture and an explicit runs_implicitly guard that is always false, so a follow-up is shown without being run. Each sheet carries source-locator and checkout-plan provenance refs so diagnostics and support exports can reconstruct which locator and checkout plan Aureline used, plus diagnostics, support-export, help-surface, docs-badge, and release-evidence refs so those surfaces ingest the same packet. The recorded review requirement must equal the gate's recomputed value, the recorded verb must be canonical for the source kind, and the summary must equal the recomputed summary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "locator_identity_scheme",
    "entry_verbs",
    "starter_families",
    "source_kinds",
    "host_or_mirror_classes",
    "protocols",
    "checkout_modes",
    "cost_bands",
    "trust_stages",
    "topology_cue_kinds",
    "topology_cue_states",
    "recovery_actions",
    "follow_up_kinds",
    "follow_up_postures",
    "sheets",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_source_acquisition_review_packet" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "locator_identity_scheme": { "$ref": "#/$defs/non_empty_string" },
    "entry_verbs": { "type": "array", "items": { "$ref": "#/$defs/entry_verb" } },
    "starter_families": { "type": "array", "items": { "$ref": "#/$defs/starter_family" } },
    "source_kinds": { "type": "array", "items": { "$ref": "#/$defs/source_kind" } },
    "host_or_mirror_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/host_or_mirror_class" }
    },
    "protocols": { "type": "array", "items": { "$ref": "#/$defs/protocol" } },
    "checkout_modes": { "type": "array", "items": { "$ref": "#/$defs/checkout_mode" } },
    "cost_bands": { "type": "array", "items": { "$ref": "#/$defs/cost_band" } },
    "trust_stages": { "type": "array", "items": { "$ref": "#/$defs/trust_stage" } },
    "topology_cue_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/topology_cue_kind" }
    },
    "topology_cue_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/topology_cue_state" }
    },
    "recovery_actions": { "type": "array", "items": { "$ref": "#/$defs/recovery_action" } },
    "follow_up_kinds": { "type": "array", "items": { "$ref": "#/$defs/follow_up_kind" } },
    "follow_up_postures": {
      "type": "array",
      "items": { "$ref": "#/$defs/follow_up_posture" }
    },
    "sheets": { "type": "array", "items": { "$ref": "#/$defs/sheet" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "entry_verb": { "enum": ["clone", "open", "import", "resume"] },
    "starter_family": {
      "enum": [
        "template_starter",
        "framework_pack_starter",
        "remote_clone_starter",
        "sync_handoff",
        "companion_handoff",
        "migration_import",
        "session_resume",
        "local_folder_open"
      ]
    },
    "source_kind": {
      "enum": [
        "local_folder",
        "template_or_prebuild",
        "remote_repository",
        "mirror_or_proxy_repository",
        "imported_archive",
        "handoff_bundle",
        "live_resume_session"
      ]
    },
    "host_or_mirror_class": {
      "enum": [
        "local_filesystem",
        "forge_host",
        "mirror",
        "proxy",
        "offline_media",
        "managed_workspace",
        "imported_artifact",
        "not_applicable"
      ]
    },
    "protocol": {
      "enum": [
        "https",
        "ssh",
        "git_protocol",
        "file_local",
        "mirror_protocol",
        "proxy_protocol",
        "air_gapped_media",
        "not_applicable"
      ]
    },
    "checkout_mode": {
      "enum": [
        "full_checkout",
        "shallow_history",
        "partial_clone",
        "sparse_checkout",
        "archive_extract",
        "live_attach",
        "not_applicable"
      ]
    },
    "cost_band": {
      "enum": ["local_no_fetch", "light_fetch", "moderate_fetch", "heavy_fetch", "very_heavy_fetch"]
    },
    "trust_stage": {
      "enum": [
        "first_party_trusted",
        "trusted_continuation",
        "review_required",
        "untrusted_browse_only"
      ]
    },
    "topology_cue_kind": {
      "enum": [
        "nested_repo",
        "submodule",
        "shallow_history",
        "sparse_checkout",
        "lfs_pointer",
        "interrupted_bootstrap",
        "omitted_data"
      ]
    },
    "topology_cue_state": {
      "enum": ["active", "pending", "partial", "not_present"]
    },
    "recovery_action": {
      "enum": [
        "init_submodules",
        "hydrate_lfs",
        "widen_sparse_scope",
        "unshallow_history",
        "resume_bootstrap",
        "fetch_omitted_data",
        "review_nested_repo",
        "none"
      ]
    },
    "follow_up_kind": {
      "enum": [
        "submodule_init",
        "lfs_hydrate",
        "docs_import",
        "package_restore_suggestion",
        "index_warm_up",
        "bundle_recommendation"
      ]
    },
    "follow_up_posture": {
      "enum": ["deferred", "awaiting_user_action", "awaiting_trust_admission", "suggested"]
    },
    "topology_cue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cue_kind",
        "state",
        "detail_label",
        "recovery_action",
        "recoverable",
        "blocks_first_useful_work"
      ],
      "properties": {
        "cue_kind": { "$ref": "#/$defs/topology_cue_kind" },
        "state": { "$ref": "#/$defs/topology_cue_state" },
        "detail_label": { "$ref": "#/$defs/non_empty_string" },
        "recovery_action": { "$ref": "#/$defs/recovery_action" },
        "recoverable": { "type": "boolean" },
        "blocks_first_useful_work": { "type": "boolean" }
      }
    },
    "follow_up_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_kind",
        "run_posture",
        "runs_implicitly",
        "one_step_action_label",
        "scope_ref",
        "evidence_ref"
      ],
      "properties": {
        "item_kind": { "$ref": "#/$defs/follow_up_kind" },
        "run_posture": { "$ref": "#/$defs/follow_up_posture" },
        "runs_implicitly": { "const": false },
        "one_step_action_label": { "$ref": "#/$defs/non_empty_string" },
        "scope_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "sheet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sheet_id",
        "starter_family",
        "entry_verb",
        "source_kind",
        "host_or_mirror_class",
        "protocol",
        "checkout_mode",
        "target_path_ref",
        "expected_cost_band",
        "trust_stage",
        "review_required_before_acquisition",
        "verb_locked",
        "local_copy_present",
        "source_locator_ref",
        "checkout_plan_ref",
        "owner",
        "topology_cues",
        "follow_up_queue",
        "diagnostics_ref",
        "support_export_ref",
        "help_surface_ref",
        "docs_badge_ref",
        "release_evidence_ref",
        "note"
      ],
      "properties": {
        "sheet_id": { "$ref": "#/$defs/non_empty_string" },
        "starter_family": { "$ref": "#/$defs/starter_family" },
        "entry_verb": { "$ref": "#/$defs/entry_verb" },
        "source_kind": { "$ref": "#/$defs/source_kind" },
        "host_or_mirror_class": { "$ref": "#/$defs/host_or_mirror_class" },
        "protocol": { "$ref": "#/$defs/protocol" },
        "checkout_mode": { "$ref": "#/$defs/checkout_mode" },
        "target_path_ref": { "$ref": "#/$defs/non_empty_string" },
        "expected_cost_band": { "$ref": "#/$defs/cost_band" },
        "trust_stage": { "$ref": "#/$defs/trust_stage" },
        "review_required_before_acquisition": { "type": "boolean" },
        "verb_locked": { "type": "boolean" },
        "local_copy_present": { "type": "boolean" },
        "source_locator_ref": { "$ref": "#/$defs/non_empty_string" },
        "checkout_plan_ref": { "$ref": "#/$defs/non_empty_string" },
        "owner": { "$ref": "#/$defs/non_empty_string" },
        "topology_cues": { "type": "array", "items": { "$ref": "#/$defs/topology_cue" } },
        "follow_up_queue": { "type": "array", "items": { "$ref": "#/$defs/follow_up_item" } },
        "caveats": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "diagnostics_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
        "help_surface_ref": { "$ref": "#/$defs/non_empty_string" },
        "docs_badge_ref": { "$ref": "#/$defs/non_empty_string" },
        "release_evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_sheets",
        "sheet_count",
        "clone_sheets",
        "open_sheets",
        "import_sheets",
        "resume_sheets",
        "sheets_requiring_review",
        "sheets_with_active_topology_cues",
        "sheets_with_blocking_cues",
        "sheets_with_deferred_follow_ups",
        "total_topology_cues",
        "total_follow_up_items",
        "recoverable_cue_count",
        "verb_locked_sheets",
        "local_copy_present_sheets"
      ],
      "properties": {
        "total_sheets": { "type": "integer", "minimum": 0 },
        "sheet_count": { "type": "integer", "minimum": 0 },
        "clone_sheets": { "type": "integer", "minimum": 0 },
        "open_sheets": { "type": "integer", "minimum": 0 },
        "import_sheets": { "type": "integer", "minimum": 0 },
        "resume_sheets": { "type": "integer", "minimum": 0 },
        "sheets_requiring_review": { "type": "integer", "minimum": 0 },
        "sheets_with_active_topology_cues": { "type": "integer", "minimum": 0 },
        "sheets_with_blocking_cues": { "type": "integer", "minimum": 0 },
        "sheets_with_deferred_follow_ups": { "type": "integer", "minimum": 0 },
        "total_topology_cues": { "type": "integer", "minimum": 0 },
        "total_follow_up_items": { "type": "integer", "minimum": 0 },
        "recoverable_cue_count": { "type": "integer", "minimum": 0 },
        "verb_locked_sheets": { "type": "integer", "minimum": 0 },
        "local_copy_present_sheets": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
