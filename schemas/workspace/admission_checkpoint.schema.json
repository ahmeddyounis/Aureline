            },
            "required": ["admission_card_class"]
          },
          "then": {
            "properties": {
              "blocked_reason_classes": { "type": "array", "minItems": 1 }
            },
            "required": ["blocked_reason_classes"]
          }
        },
        {
          "description": "policy_narrowing_card MUST list at least one referenced_policy_block_ref.",
          "if": {
            "properties": {
              "admission_card_class": { "const": "policy_narrowing_card" }
            },
            "required": ["admission_card_class"]
          },
          "then": {
            "properties": {
              "referenced_policy_block_refs": { "type": "array", "minItems": 1 }
            },
            "required": ["referenced_policy_block_refs"]
          }
        },
        {
          "description": "prerequisite_repair_card MUST cite blocked_reason_class blocked_by_missing_prerequisite.",
          "if": {
            "properties": {
              "admission_card_class": { "const": "prerequisite_repair_card" }
            },
            "required": ["admission_card_class"]
          },
          "then": {
            "properties": {
              "blocked_reason_classes": {
                "type": "array",
                "contains": { "const": "blocked_by_missing_prerequisite" }
              }
            },
            "required": ["blocked_reason_classes"]
          }
        },
        {
          "description": "deployment_profile_card MUST cite blocked_reason_class blocked_by_deployment_profile.",
          "if": {
            "properties": {
              "admission_card_class": { "const": "deployment_profile_card" }
            },
            "required": ["admission_card_class"]
          },
          "then": {
            "properties": {
              "blocked_reason_classes": {
                "type": "array",
                "contains": { "const": "blocked_by_deployment_profile" }
              }
            },
            "required": ["blocked_reason_classes"]
          }
        },
        {
          "description": "continue_without_card MUST carry a bypass_action.",
          "if": {
            "properties": {
              "admission_card_class": { "const": "continue_without_card" }
            },
            "required": ["admission_card_class"]
          },
          "then": {
            "required": ["bypass_action"]
          }
        }
      ],
      "description": "One admission card. The shell renders one card per non-empty bucket plus typed cards for policy narrowing, prerequisite repair, deployment profile lock, deferred setup, and the continue-without fallback."
    },
