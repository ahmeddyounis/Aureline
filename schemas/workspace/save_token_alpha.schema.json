{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/save_token_alpha.schema.json",
  "title": "Aureline workspace filesystem identity alpha fixture",
  "description": "Protected alpha fixture shape for canonical filesystem identity, alias inspection, save-token review, external-change compare, and shared editor/Git/restore identity references. The VFS Rust types remain the implementation schema of record; this schema keeps workspace fixtures reviewable and prevents downstream lanes from inventing a parallel save-token model.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "case_id", "title", "input", "expected"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "type": "integer", "const": 1 },
    "case_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "input": { "$ref": "#/$defs/input" },
    "expected": { "$ref": "#/$defs/expected" }
  },
  "$defs": {
    "string_or_null": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_id",
        "root_id",
        "root_class",
        "trust_state",
        "presentation_uri",
        "canonical_uri",
        "logical_uri",
        "display_label",
        "normalization_form",
        "strongest_token_base",
        "initial_generation",
        "initial_content",
        "local_content",
        "external_content_after_open",
        "permission_writable",
        "permission_mode",
        "permission_owner",
        "permission_group",
        "read_only",
        "policy_constrained",
        "review_required_before_save",
        "review_required_before_rename",
        "case_sensitivity",
        "symlink_escape_policy",
        "observed_at",
        "aliases",
        "presentation_alias_kind",
        "presentation_resolution_chain"
      ],
      "properties": {
        "workspace_id": { "type": "string", "minLength": 1 },
        "root_id": { "type": "string", "minLength": 1 },
        "root_class": {
          "type": "string",
          "enum": [
            "local_posix_like",
            "local_windows_like",
            "remote_agent_mount",
            "container_mount",
            "virtual_generated_document",
            "archive_like_view"
          ]
        },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted", "pending_evaluation"]
        },
        "presentation_uri": { "type": "string", "minLength": 1 },
        "canonical_uri": { "type": "string", "minLength": 1 },
        "logical_uri": { "type": "string", "minLength": 1 },
        "display_label": { "type": "string", "minLength": 1 },
        "normalization_form": {
          "type": "string",
          "enum": ["none", "nfc", "nfd", "mixed_observed"]
        },
        "strongest_token_base": { "type": "string", "minLength": 1 },
        "initial_generation": { "type": "integer", "minimum": 0 },
        "initial_content": { "type": "string" },
        "local_content": { "type": "string" },
        "external_content_after_open": { "$ref": "#/$defs/string_or_null" },
        "permission_writable": { "type": "boolean" },
        "permission_mode": { "type": "string", "minLength": 1 },
        "permission_owner": { "$ref": "#/$defs/string_or_null" },
        "permission_group": { "$ref": "#/$defs/string_or_null" },
        "read_only": { "type": "boolean" },
        "policy_constrained": { "type": "boolean" },
        "review_required_before_save": { "type": "boolean" },
        "review_required_before_rename": { "type": "boolean" },
        "case_sensitivity": {
          "type": "string",
          "enum": ["sensitive", "insensitive_preserving", "insensitive_non_preserving"]
        },
        "symlink_escape_policy": {
          "type": "string",
          "enum": ["allow", "warn", "block"]
        },
        "observed_at": { "type": "string", "minLength": 1 },
        "aliases": {
          "type": "array",
          "items": { "$ref": "#/$defs/alias" }
        },
        "presentation_alias_kind": {
          "oneOf": [
            { "$ref": "#/$defs/alias_kind" },
            { "type": "null" }
          ]
        },
        "presentation_resolution_chain": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "alias": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alias_uri", "alias_kind", "resolution_chain"],
      "properties": {
        "alias_uri": { "type": "string", "minLength": 1 },
        "alias_kind": { "$ref": "#/$defs/alias_kind" },
        "resolution_chain": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "alias_kind": {
      "type": "string",
      "enum": [
        "symlink",
        "junction",
        "hardlink_sibling",
        "case_only_variant",
        "unicode_normalization_variant",
        "remote_alias",
        "bind_mount_alias",
        "container_mount_alias",
        "archive_inner_alias"
      ]
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "filesystem_identity_ref",
        "shared_flow_refs",
        "path_truth_class",
        "alias_count",
        "distinct_alias_kinds",
        "writes_to_canonical_uri",
        "save_token_kind",
        "save_token_value",
        "compare_outcome",
        "blocking_save_outcome",
        "observed_generation_token_value",
        "review_required",
        "silent_overwrite_forbidden",
        "diff_availability",
        "diff_hunks",
        "external_line_changes",
        "local_line_changes",
        "resolution_actions"
      ],
      "properties": {
        "filesystem_identity_ref": { "type": "string", "minLength": 1 },
        "shared_flow_refs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "editor_file_identity_ref",
            "git_file_identity_ref",
            "restore_file_identity_ref",
            "mutation_file_identity_ref"
          ],
          "properties": {
            "editor_file_identity_ref": { "type": "string", "minLength": 1 },
            "git_file_identity_ref": { "type": "string", "minLength": 1 },
            "restore_file_identity_ref": { "type": "string", "minLength": 1 },
            "mutation_file_identity_ref": { "type": "string", "minLength": 1 }
          }
        },
        "path_truth_class": { "type": "string", "minLength": 1 },
        "alias_count": { "type": "integer", "minimum": 0 },
        "distinct_alias_kinds": {
          "type": "array",
          "items": { "$ref": "#/$defs/alias_kind" }
        },
        "writes_to_canonical_uri": { "type": "string", "minLength": 1 },
        "save_token_kind": { "type": "string", "minLength": 1 },
        "save_token_value": { "type": "string", "minLength": 1 },
        "compare_outcome": {
          "type": "string",
          "enum": [
            "unchanged",
            "external_change_detected",
            "save_conflict",
            "wrong_target_prevented",
            "current_bytes_unavailable"
          ]
        },
        "blocking_save_outcome": { "$ref": "#/$defs/string_or_null" },
        "observed_generation_token_value": { "$ref": "#/$defs/string_or_null" },
        "review_required": { "type": "boolean" },
        "silent_overwrite_forbidden": { "type": "boolean" },
        "diff_availability": {
          "type": "string",
          "enum": ["not_needed", "available", "binary_only", "current_bytes_unavailable"]
        },
        "diff_hunks": { "type": "integer", "minimum": 0 },
        "external_line_changes": { "type": "integer", "minimum": 0 },
        "local_line_changes": { "type": "integer", "minimum": 0 },
        "resolution_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "write",
              "compare",
              "reload_external",
              "merge",
              "save_as",
              "recompare",
              "open_alias_details",
              "cancel"
            ]
          }
        }
      }
    }
  }
}
