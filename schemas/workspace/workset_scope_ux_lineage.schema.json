{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/workset_scope_ux_lineage.schema.json",
  "title": "Aureline workset, sparse-scope, and policy-limited-view UX lineage",
  "description": "Boundary schema for the governed, export-safe workset / scope UX lineage record. The record proves how named worksets, sparse slices, and policy-limited views surface across workspace UX so the user can always distinguish `outside current slice`, `omitted path`, and `policy hidden` content from `no result`, and so that widening from a sparse or partial view to a fuller checkout/workset preserves root identity, query/session continuity, and restore provenance instead of creating a second ambiguous workspace truth. It is projected verbatim from the live WorksetScopeUxInputs envelope. It proves scope-class coverage, surface coverage, outside-vs-omitted distinction, hidden-result disclosure, slice-ref propagation into deep-link and export flows, widen-preview truth (hidden-result counts, omitted-root classes, fetch/deepen implications, blame/history/search consequences disclosed before apply), widen-preservation truth (root identity, query/session continuity, restore provenance preserved across widens), policy-limited disclosure (narrowing cause present, admin/license never expose hidden member list), readiness truth, and support-export honesty. Raw payload bytes are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "workset_scope_ux_lineage_schema_version",
    "schema_ref",
    "posture_id",
    "workspace_ref",
    "corpus_ref",
    "producer_attribution",
    "scope_coverage",
    "surface_coverage",
    "outside_marker_honesty",
    "hidden_result_disclosure",
    "slice_ref_propagation",
    "widen_preview_truth",
    "widen_preservation_truth",
    "policy_limited_disclosure",
    "readiness_truth",
    "support_export_honesty",
    "inspection_hooks",
    "stable_qualification",
    "raw_payload_excluded",
    "summary"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": { "const": "workset_scope_ux_lineage_record" },
    "workset_scope_ux_lineage_schema_version": { "type": "integer", "const": 1 },
    "schema_ref": { "const": "schemas/workspace/workset_scope_ux_lineage.schema.json" },
    "posture_id": { "$ref": "#/$defs/non_empty_string" },
    "workspace_ref": { "$ref": "#/$defs/non_empty_string" },
    "corpus_ref": { "$ref": "#/$defs/non_empty_string" },
    "producer_attribution": { "$ref": "#/$defs/producer_attribution_summary" },
    "scope_coverage": { "$ref": "#/$defs/scope_coverage_summary" },
    "surface_coverage": { "$ref": "#/$defs/surface_coverage_summary" },
    "outside_marker_honesty": { "$ref": "#/$defs/outside_marker_honesty_summary" },
    "hidden_result_disclosure": { "$ref": "#/$defs/hidden_result_disclosure_summary" },
    "slice_ref_propagation": { "$ref": "#/$defs/slice_ref_propagation_summary" },
    "widen_preview_truth": { "$ref": "#/$defs/widen_preview_truth_summary" },
    "widen_preservation_truth": { "$ref": "#/$defs/widen_preservation_truth_summary" },
    "policy_limited_disclosure": { "$ref": "#/$defs/policy_limited_disclosure_summary" },
    "readiness_truth": { "$ref": "#/$defs/readiness_truth_summary" },
    "support_export_honesty": { "$ref": "#/$defs/support_export_honesty_summary" },
    "inspection_hooks": {
      "type": "array",
      "items": { "$ref": "#/$defs/inspection_hook" }
    },
    "stable_qualification": { "$ref": "#/$defs/stable_qualification" },
    "raw_payload_excluded": { "const": true },
    "summary": { "type": "string", "minLength": 1, "maxLength": 700 }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "scope_kind": {
      "type": "string",
      "enum": [
        "selected_workset",
        "sparse_slice",
        "policy_limited_view",
        "full_workspace",
        "current_repo"
      ]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "workset_switcher",
        "scope_chip",
        "search",
        "tree",
        "graph",
        "review",
        "support_export",
        "refactor_scope_footer",
        "ai_context_inspector",
        "export_scope_footer",
        "deep_link_dispatcher"
      ]
    },
    "narrowing_cause": {
      "type": "string",
      "enum": [
        "admin_policy",
        "trust_policy",
        "license_or_export_control",
        "remote_unavailable",
        "index_not_built",
        "user_muted"
      ]
    },
    "readiness_state": {
      "type": "string",
      "enum": ["cold", "warming", "warm", "partial", "ready"]
    },
    "widen_action_class": {
      "type": "string",
      "enum": [
        "widen_to_full_workspace",
        "widen_with_review",
        "narrow_to_current_repo",
        "keep_current_scope",
        "reveal_hidden_results_admin_only"
      ]
    },
    "widen_preservation_posture": {
      "type": "string",
      "enum": [
        "preserves_identity_and_continuity",
        "preserved_after_review_with_disclosure",
        "creates_new_workspace_truth"
      ]
    },
    "support_export_posture": {
      "type": "string",
      "enum": ["metadata_safe_export", "held_record"]
    },
    "inspection_hook_class": {
      "type": "string",
      "enum": [
        "inspect_scope",
        "compare_before_widen",
        "preview_widen",
        "export_scope",
        "rollback_widen",
        "repair_scope"
      ]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "corpus_empty",
        "required_scope_class_missing",
        "required_surface_kind_missing",
        "surface_references_unknown_scope",
        "widen_preview_references_unknown_scope",
        "outside_marker_missing",
        "omitted_marker_missing",
        "policy_hidden_marker_missing",
        "hidden_result_count_not_disclosed",
        "slice_ref_not_propagated_into_deep_links",
        "slice_ref_not_propagated_into_export",
        "widen_preview_field_missing",
        "widen_loses_root_identity",
        "widen_loses_query_session_continuity",
        "widen_loses_restore_provenance",
        "policy_limited_narrowing_cause_missing",
        "policy_admin_hidden_list_exposed",
        "readiness_hidden_count_unknown",
        "apply_action_metadata_missing",
        "inspection_hook_unavailable",
        "support_export_fields_dropped",
        "support_export_redaction_unsafe",
        "producer_attribution_incomplete",
        "lineage_export_unsafe"
      ]
    },
    "producer_attribution_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_ref",
        "schema_version",
        "integrity_hash",
        "captured_at",
        "producer_attribution_complete"
      ],
      "properties": {
        "producer_ref": { "type": "string" },
        "schema_version": { "type": "integer" },
        "integrity_hash": { "type": "string" },
        "captured_at": { "type": "string" },
        "producer_attribution_complete": { "type": "boolean" }
      }
    },
    "scope_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_id",
        "workset_ref",
        "workset_name",
        "scope_class",
        "root_refs",
        "excluded_root_classes",
        "hidden_member_list_visible",
        "readiness_state",
        "hidden_result_count_known",
        "widen_actions_offered",
        "support_export_posture",
        "is_required"
      ],
      "properties": {
        "scope_id": { "$ref": "#/$defs/non_empty_string" },
        "workset_ref": { "type": "string" },
        "workset_name": { "type": "string" },
        "scope_class": { "$ref": "#/$defs/scope_kind" },
        "root_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excluded_root_classes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "policy_limitation_ref": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        },
        "narrowing_cause": {
          "anyOf": [{ "$ref": "#/$defs/narrowing_cause" }, { "type": "null" }]
        },
        "hidden_member_list_visible": { "type": "boolean" },
        "readiness_state": { "$ref": "#/$defs/readiness_state" },
        "hidden_result_count_known": { "type": "boolean" },
        "hidden_result_count": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "widen_actions_offered": {
          "type": "array",
          "items": { "$ref": "#/$defs/widen_action_class" }
        },
        "support_export_posture": { "$ref": "#/$defs/support_export_posture" },
        "is_required": { "type": "boolean" }
      }
    },
    "surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "scope_id",
        "shows_outside_current_slice",
        "shows_omitted_path",
        "shows_policy_hidden",
        "discloses_hidden_result_count",
        "carries_slice_ref_into_deep_links",
        "carries_slice_ref_into_export",
        "is_result_bearing",
        "is_export_propagating",
        "support_export_posture",
        "is_required"
      ],
      "properties": {
        "surface_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "type": "string" },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "scope_id": { "type": "string" },
        "shows_outside_current_slice": { "type": "boolean" },
        "shows_omitted_path": { "type": "boolean" },
        "shows_policy_hidden": { "type": "boolean" },
        "discloses_hidden_result_count": { "type": "boolean" },
        "carries_slice_ref_into_deep_links": { "type": "boolean" },
        "carries_slice_ref_into_export": { "type": "boolean" },
        "is_result_bearing": { "type": "boolean" },
        "is_export_propagating": { "type": "boolean" },
        "support_export_posture": { "$ref": "#/$defs/support_export_posture" },
        "is_required": { "type": "boolean" }
      }
    },
    "widen_preview_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_id",
        "base_scope_id",
        "candidate_scope_id",
        "previews_hidden_result_count",
        "previews_omitted_root_classes",
        "previews_fetch_deepen_implications",
        "previews_blame_history_search_consequences",
        "preserves_root_identity",
        "preserves_query_session_continuity",
        "preserves_restore_provenance",
        "preservation_posture",
        "apply_action_id",
        "apply_disclosure_id",
        "support_export_posture"
      ],
      "properties": {
        "preview_id": { "$ref": "#/$defs/non_empty_string" },
        "base_scope_id": { "type": "string" },
        "candidate_scope_id": { "type": "string" },
        "previews_hidden_result_count": { "type": "boolean" },
        "previews_omitted_root_classes": { "type": "boolean" },
        "previews_fetch_deepen_implications": { "type": "boolean" },
        "previews_blame_history_search_consequences": { "type": "boolean" },
        "preserves_root_identity": { "type": "boolean" },
        "preserves_query_session_continuity": { "type": "boolean" },
        "preserves_restore_provenance": { "type": "boolean" },
        "preservation_posture": { "$ref": "#/$defs/widen_preservation_posture" },
        "apply_action_id": { "type": "string" },
        "apply_disclosure_id": { "type": "string" },
        "support_export_posture": { "$ref": "#/$defs/support_export_posture" }
      }
    },
    "scope_coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_rows", "all_required_scope_classes_present"],
      "properties": {
        "scope_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/scope_row" }
        },
        "all_required_scope_classes_present": { "type": "boolean" }
      }
    },
    "surface_coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_rows", "all_required_surface_kinds_present"],
      "properties": {
        "surface_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_row" }
        },
        "all_required_surface_kinds_present": { "type": "boolean" }
      }
    },
    "outside_marker_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_result_bearing_surfaces_show_outside_current_slice",
        "all_result_bearing_surfaces_show_omitted_path",
        "all_result_bearing_surfaces_show_policy_hidden"
      ],
      "properties": {
        "all_result_bearing_surfaces_show_outside_current_slice": { "type": "boolean" },
        "all_result_bearing_surfaces_show_omitted_path": { "type": "boolean" },
        "all_result_bearing_surfaces_show_policy_hidden": { "type": "boolean" }
      }
    },
    "hidden_result_disclosure_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_surfaces_disclose_hidden_count"],
      "properties": {
        "all_surfaces_disclose_hidden_count": { "type": "boolean" }
      }
    },
    "slice_ref_propagation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_surfaces_carry_slice_ref_into_deep_links",
        "all_export_propagating_surfaces_carry_slice_ref_into_export"
      ],
      "properties": {
        "all_surfaces_carry_slice_ref_into_deep_links": { "type": "boolean" },
        "all_export_propagating_surfaces_carry_slice_ref_into_export": { "type": "boolean" }
      }
    },
    "widen_preview_truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "widen_preview_rows",
        "all_previews_have_required_fields",
        "all_previews_have_apply_action_metadata"
      ],
      "properties": {
        "widen_preview_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/widen_preview_row" }
        },
        "all_previews_have_required_fields": { "type": "boolean" },
        "all_previews_have_apply_action_metadata": { "type": "boolean" }
      }
    },
    "widen_preservation_truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_widens_preserve_root_identity",
        "all_widens_preserve_query_session_continuity",
        "all_widens_preserve_restore_provenance",
        "all_preservation_postures_safe"
      ],
      "properties": {
        "all_widens_preserve_root_identity": { "type": "boolean" },
        "all_widens_preserve_query_session_continuity": { "type": "boolean" },
        "all_widens_preserve_restore_provenance": { "type": "boolean" },
        "all_preservation_postures_safe": { "type": "boolean" }
      }
    },
    "policy_limited_disclosure_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_limited_scope_count",
        "all_policy_limited_have_narrowing_cause",
        "no_admin_or_license_policy_exposes_hidden_list"
      ],
      "properties": {
        "policy_limited_scope_count": { "type": "integer", "minimum": 0 },
        "all_policy_limited_have_narrowing_cause": { "type": "boolean" },
        "no_admin_or_license_policy_exposes_hidden_list": { "type": "boolean" }
      }
    },
    "readiness_truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_ready_scopes_disclose_hidden_count_known"],
      "properties": {
        "all_ready_scopes_disclose_hidden_count_known": { "type": "boolean" }
      }
    },
    "support_export_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_rows_preserve_fields",
        "all_rows_redact_raw_secrets",
        "all_rows_exclude_approval_tickets",
        "all_rows_exclude_delegated_credentials",
        "all_rows_exclude_live_authority_handles",
        "all_rows_exclude_admin_hidden_list"
      ],
      "properties": {
        "all_rows_preserve_fields": { "type": "boolean" },
        "all_rows_redact_raw_secrets": { "type": "boolean" },
        "all_rows_exclude_approval_tickets": { "type": "boolean" },
        "all_rows_exclude_delegated_credentials": { "type": "boolean" },
        "all_rows_exclude_live_authority_handles": { "type": "boolean" },
        "all_rows_exclude_admin_hidden_list": { "type": "boolean" }
      }
    },
    "inspection_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hook_class", "action_id", "label", "available", "disclosure"],
      "properties": {
        "hook_class": { "$ref": "#/$defs/inspection_hook_class" },
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "available": { "type": "boolean" },
        "disclosure": { "type": "string" }
      }
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qualified", "level", "narrow_reasons"],
      "properties": {
        "qualified": { "type": "boolean" },
        "level": {
          "type": "string",
          "enum": ["stable", "narrowed_below_stable"]
        },
        "narrow_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason" }
        }
      }
    }
  }
}
