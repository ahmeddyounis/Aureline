{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/m5-bundle-scorecards.schema.json",
  "title": "Aureline M5 bundle scorecards packet",
  "description": "Schema for the m5_bundle_scorecards_packet. The packet carries one machine-readable compatibility scorecard per claimed M5 launch bundle. Each scorecard scores a workflow-bundle manifest version and records supported platforms, bundle dependencies with lifecycle markers, imported-versus-native confidence, certified reference-workspace linkage, and current evidence freshness. From the claimed class, the confidence, and the freshness it computes an effective class that can never out-rank any of them, so imported or approximate bundle behavior cannot inherit native or certified language by inertia and public copy narrows automatically when proof is weak, stale, or bounded. Every scorecard joins to the workflow-bundle manifest, the compatibility-scorecard packet, the archetype-certification packet, and a certified reference workspace, and binds the same object to start center, migration center, help/About, release center, docs/help, support export, and diagnostics. Every wedge must be covered and the summary must equal the recomputed summary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "scorecard_identity_scheme",
    "wedges",
    "bundle_classes",
    "confidence_levels",
    "freshness_levels",
    "platform_classes",
    "dependency_lifecycle_stages",
    "scorecards",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_bundle_scorecards_packet" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "scorecard_identity_scheme": { "$ref": "#/$defs/non_empty_string" },
    "wedges": { "type": "array", "items": { "$ref": "#/$defs/wedge" } },
    "bundle_classes": { "type": "array", "items": { "$ref": "#/$defs/bundle_class" } },
    "confidence_levels": { "type": "array", "items": { "$ref": "#/$defs/confidence" } },
    "freshness_levels": { "type": "array", "items": { "$ref": "#/$defs/freshness" } },
    "platform_classes": { "type": "array", "items": { "$ref": "#/$defs/platform" } },
    "dependency_lifecycle_stages": {
      "type": "array",
      "items": { "$ref": "#/$defs/lifecycle_stage" }
    },
    "scorecards": { "type": "array", "items": { "$ref": "#/$defs/scorecard" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "wedge": {
      "enum": [
        "notebook_workspace",
        "data_and_api_workspace",
        "profiler_workspace",
        "framework_pack_workspace",
        "docs_workspace",
        "companion_workspace",
        "sync_handoff_workspace",
        "local_folder_workspace"
      ]
    },
    "bundle_class": {
      "enum": ["certified", "probable", "community", "imported", "preview", "local_draft"]
    },
    "confidence": {
      "enum": ["native", "bridged", "approximated", "unverified"]
    },
    "freshness": {
      "enum": ["fresh", "aging", "stale", "missing"]
    },
    "platform": {
      "enum": ["linux", "macos", "windows", "web"]
    },
    "lifecycle_stage": {
      "enum": [
        "stable",
        "preview",
        "labs",
        "policy_gated",
        "mirror_only",
        "bounded_platform"
      ]
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dependency_id", "lifecycle_stage", "label", "dependency_ref"],
      "properties": {
        "dependency_id": { "$ref": "#/$defs/non_empty_string" },
        "lifecycle_stage": { "$ref": "#/$defs/lifecycle_stage" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "dependency_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "scorecard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scorecard_id",
        "bundle_id",
        "wedge",
        "source_manifest_version",
        "claimed_class",
        "effective_class",
        "imported_vs_native_confidence",
        "evidence_freshness",
        "supported_platforms",
        "platform_bounded",
        "bundle_dependencies",
        "presents_as_certified",
        "manifest_ref",
        "compatibility_scorecard_ref",
        "archetype_cert_ref",
        "reference_workspace_ref",
        "owner",
        "start_center_ref",
        "migration_center_ref",
        "help_about_ref",
        "release_center_ref",
        "docs_help_ref",
        "support_export_ref",
        "diagnostics_ref",
        "note"
      ],
      "properties": {
        "scorecard_id": { "$ref": "#/$defs/non_empty_string" },
        "bundle_id": { "$ref": "#/$defs/non_empty_string" },
        "wedge": { "$ref": "#/$defs/wedge" },
        "source_manifest_version": { "$ref": "#/$defs/non_empty_string" },
        "claimed_class": { "$ref": "#/$defs/bundle_class" },
        "effective_class": { "$ref": "#/$defs/bundle_class" },
        "imported_vs_native_confidence": { "$ref": "#/$defs/confidence" },
        "evidence_freshness": { "$ref": "#/$defs/freshness" },
        "supported_platforms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/platform" }
        },
        "platform_bounded": { "type": "boolean" },
        "bundle_dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependency" }
        },
        "presents_as_certified": { "type": "boolean" },
        "manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "compatibility_scorecard_ref": { "$ref": "#/$defs/non_empty_string" },
        "archetype_cert_ref": { "$ref": "#/$defs/non_empty_string" },
        "reference_workspace_ref": { "$ref": "#/$defs/non_empty_string" },
        "owner": { "$ref": "#/$defs/non_empty_string" },
        "caveats": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "start_center_ref": { "$ref": "#/$defs/non_empty_string" },
        "migration_center_ref": { "$ref": "#/$defs/non_empty_string" },
        "help_about_ref": { "$ref": "#/$defs/non_empty_string" },
        "release_center_ref": { "$ref": "#/$defs/non_empty_string" },
        "docs_help_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
        "diagnostics_ref": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_scorecards",
        "claimed_certified",
        "claimed_probable",
        "claimed_community",
        "claimed_imported",
        "claimed_preview",
        "claimed_local_draft",
        "effective_certified",
        "effective_probable",
        "effective_community",
        "effective_imported",
        "effective_preview",
        "effective_local_draft",
        "presents_as_certified",
        "downgraded_scorecards",
        "platform_bounded_scorecards",
        "stale_or_missing_evidence",
        "non_native_confidence",
        "scorecards_with_non_stable_dependencies",
        "total_dependencies",
        "non_stable_dependencies"
      ],
      "properties": {
        "total_scorecards": { "type": "integer", "minimum": 0 },
        "claimed_certified": { "type": "integer", "minimum": 0 },
        "claimed_probable": { "type": "integer", "minimum": 0 },
        "claimed_community": { "type": "integer", "minimum": 0 },
        "claimed_imported": { "type": "integer", "minimum": 0 },
        "claimed_preview": { "type": "integer", "minimum": 0 },
        "claimed_local_draft": { "type": "integer", "minimum": 0 },
        "effective_certified": { "type": "integer", "minimum": 0 },
        "effective_probable": { "type": "integer", "minimum": 0 },
        "effective_community": { "type": "integer", "minimum": 0 },
        "effective_imported": { "type": "integer", "minimum": 0 },
        "effective_preview": { "type": "integer", "minimum": 0 },
        "effective_local_draft": { "type": "integer", "minimum": 0 },
        "presents_as_certified": { "type": "integer", "minimum": 0 },
        "downgraded_scorecards": { "type": "integer", "minimum": 0 },
        "platform_bounded_scorecards": { "type": "integer", "minimum": 0 },
        "stale_or_missing_evidence": { "type": "integer", "minimum": 0 },
        "non_native_confidence": { "type": "integer", "minimum": 0 },
        "scorecards_with_non_stable_dependencies": { "type": "integer", "minimum": 0 },
        "total_dependencies": { "type": "integer", "minimum": 0 },
        "non_stable_dependencies": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
