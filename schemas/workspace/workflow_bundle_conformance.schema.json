{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/workflow_bundle_conformance.schema.json",
  "title": "Aureline workflow-bundle lifecycle conformance corpus manifest",
  "description": "Single-source-of-truth manifest for the M3 workflow-bundle lifecycle conformance, interoperability, certification-freshness, and failure / recovery drill corpus replayed by `cargo test -p aureline-qe --test workflow_bundle_lifecycle_conformance`. Every positive drill names a fixture and pins the workflow-bundle truth it must reproduce against the aureline-workspace::bundles::WorkflowBundleReviewRecord boundary; every negative drill names a fixture whose validation MUST fail with an error whose message contains expected_failure_substring. The fixtures carry only the scenario records — they do not restate these expectations, so there is exactly one place to read and audit the pinned truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "corpus_id",
    "schema_version",
    "description",
    "positive_drills",
    "negative_drills"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "corpus_id": { "$ref": "#/$defs/non_empty_string" },
    "schema_version": { "type": "integer", "const": 1 },
    "description": { "$ref": "#/$defs/non_empty_string" },
    "boundary": { "$ref": "#/$defs/boundary" },
    "positive_drills": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/positive_drill" }
    },
    "negative_drills": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/negative_drill" }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runtime_model": { "$ref": "#/$defs/non_empty_string" },
        "record_schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "certification_matrix_ref": { "$ref": "#/$defs/non_empty_string" },
        "compatibility_report_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "source_class": {
      "type": "string",
      "enum": ["certified", "managed_approved", "community", "imported", "local_draft"]
    },
    "bundle_class": {
      "type": "string",
      "enum": [
        "launch_bundle",
        "imported_user_bundle",
        "org_approved_bundle",
        "design_partner_bundle",
        "local_draft_bundle"
      ]
    },
    "effective_badge_class": {
      "type": "string",
      "enum": [
        "certified",
        "managed_approved",
        "community",
        "imported",
        "local_draft",
        "retest_pending",
        "limited",
        "status_unknown"
      ]
    },
    "mirror_posture_class": {
      "type": "string",
      "enum": [
        "live_origin_only",
        "live_or_mirror",
        "mirror_only",
        "signed_offline_bundle",
        "offline_no_bundle",
        "packaging_posture_unknown"
      ]
    },
    "positive_drill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drill_id",
        "fixture",
        "kind",
        "source_class",
        "bundle_class",
        "lifecycle_flows",
        "expected_bundle_class",
        "expected_source_class",
        "expected_status_class",
        "expected_support_class",
        "expected_effective_badge_class",
        "expected_support_claim_class",
        "expected_evidence_freshness_class",
        "expected_certification_state_class",
        "expected_retest_required",
        "expected_mirror_posture_class",
        "expected_required_diff_axes_complete",
        "expected_guardrails_pass",
        "expected_raw_export_allowed",
        "expected_drift_entry_count",
        "expected_removable_asset_count",
        "expected_retained_override_count",
        "expected_review_actions_present",
        "expected_resolve_actions_present",
        "expected_preserves_user_owned_assets",
        "expected_rollback_restores_bundle_owned",
        "expected_capability_dependency_markers",
        "expected_lifecycle_sensitive_dependencies"
      ],
      "properties": {
        "drill_id": { "$ref": "#/$defs/non_empty_string" },
        "fixture": { "$ref": "#/$defs/non_empty_string" },
        "kind": { "type": "string", "const": "workflow_bundle_review" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "bundle_class": { "$ref": "#/$defs/bundle_class" },
        "lifecycle_flows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "expected_bundle_class": { "$ref": "#/$defs/bundle_class" },
        "expected_source_class": { "$ref": "#/$defs/source_class" },
        "expected_status_class": { "$ref": "#/$defs/non_empty_string" },
        "expected_support_class": { "$ref": "#/$defs/non_empty_string" },
        "expected_effective_badge_class": { "$ref": "#/$defs/effective_badge_class" },
        "expected_support_claim_class": { "$ref": "#/$defs/non_empty_string" },
        "expected_evidence_freshness_class": { "$ref": "#/$defs/non_empty_string" },
        "expected_certification_state_class": { "$ref": "#/$defs/non_empty_string" },
        "expected_retest_required": { "type": "boolean" },
        "expected_mirror_posture_class": { "$ref": "#/$defs/mirror_posture_class" },
        "expected_required_diff_axes_complete": { "type": "boolean" },
        "expected_guardrails_pass": { "type": "boolean" },
        "expected_raw_export_allowed": { "type": "boolean", "const": false },
        "expected_drift_entry_count": { "type": "integer", "minimum": 0 },
        "expected_removable_asset_count": { "type": "integer", "minimum": 1 },
        "expected_retained_override_count": { "type": "integer", "minimum": 0 },
        "expected_review_actions_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "expected_resolve_actions_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "expected_preserves_user_owned_assets": { "type": "boolean" },
        "expected_rollback_restores_bundle_owned": { "type": "boolean" },
        "expected_capability_dependency_markers": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "expected_lifecycle_sensitive_dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "negative_drill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["drill_id", "fixture", "kind", "expected_failure_substring"],
      "properties": {
        "drill_id": { "$ref": "#/$defs/non_empty_string" },
        "fixture": { "$ref": "#/$defs/non_empty_string" },
        "kind": { "type": "string", "const": "workflow_bundle_review" },
        "expected_failure_substring": { "$ref": "#/$defs/non_empty_string" },
        "covers": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    }
  }
}
