{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/trust_gating_lineage.schema.json",
  "title": "Aureline trust-gating lineage",
  "description": "Boundary schema for the governed, export-safe trust-gating lineage record. The record finalizes workspace-trust gating across tasks, terminal, debug, AI apply, and privileged extensions, projected verbatim from the live TrustGatingInputs envelope. It proves privileged-surface coverage (tasks / terminal / debug / ai_apply / privileged_extension), gate-decision truth (the decision matches the workspace trust posture), no-silent-execution honesty (a grant requires an explicit user action and a disclosure), override-route honesty (every non-none override has an action id and a disclosure), and support-export honesty (gating fields preserved, raw secrets / approval tickets / delegated credentials / live authority handles redacted). Raw payload bytes are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "trust_gating_lineage_schema_version",
    "schema_ref",
    "posture_id",
    "workspace_ref",
    "corpus_ref",
    "workspace_trust_posture",
    "producer_attribution",
    "surface_coverage",
    "gate_decision_truth",
    "silent_execution_honesty",
    "override_route_honesty",
    "support_export_honesty",
    "inspection_hooks",
    "stable_qualification",
    "raw_payload_excluded",
    "summary"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": { "const": "trust_gating_lineage_record" },
    "trust_gating_lineage_schema_version": { "type": "integer", "const": 1 },
    "schema_ref": { "const": "schemas/workspace/trust_gating_lineage.schema.json" },
    "posture_id": { "$ref": "#/$defs/non_empty_string" },
    "workspace_ref": { "$ref": "#/$defs/non_empty_string" },
    "corpus_ref": { "$ref": "#/$defs/non_empty_string" },
    "workspace_trust_posture": { "$ref": "#/$defs/workspace_trust_posture" },
    "producer_attribution": { "$ref": "#/$defs/producer_attribution_summary" },
    "surface_coverage": { "$ref": "#/$defs/surface_coverage_summary" },
    "gate_decision_truth": { "$ref": "#/$defs/gate_decision_truth_summary" },
    "silent_execution_honesty": { "$ref": "#/$defs/silent_execution_honesty_summary" },
    "override_route_honesty": { "$ref": "#/$defs/override_route_honesty_summary" },
    "support_export_honesty": { "$ref": "#/$defs/support_export_honesty_summary" },
    "inspection_hooks": {
      "type": "array",
      "items": { "$ref": "#/$defs/inspection_hook" }
    },
    "stable_qualification": { "$ref": "#/$defs/stable_qualification" },
    "raw_payload_excluded": { "const": true },
    "summary": { "type": "string", "minLength": 1, "maxLength": 700 }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "trust_surface_kind": {
      "type": "string",
      "enum": ["tasks", "terminal", "debug", "ai_apply", "privileged_extension"]
    },
    "workspace_trust_posture": {
      "type": "string",
      "enum": ["trusted", "restricted", "pending_evaluation"]
    },
    "gate_decision_class": {
      "type": "string",
      "enum": [
        "allow_unconditional",
        "allow_after_explicit_grant",
        "allow_read_only",
        "block_pending_trust_decision",
        "block_until_repair"
      ]
    },
    "silent_execution_posture": {
      "type": "string",
      "enum": [
        "cannot_fire_silently",
        "explicit_user_action_required",
        "read_only_no_mutation"
      ]
    },
    "override_route_class": {
      "type": "string",
      "enum": [
        "none",
        "disclosed_one_time",
        "disclosed_session",
        "disclosed_with_audit"
      ]
    },
    "support_export_posture": {
      "type": "string",
      "enum": ["local_only", "metadata_safe_export", "held_record"]
    },
    "inspection_hook_class": {
      "type": "string",
      "enum": [
        "inspect_trust_grant",
        "review_grant_scope",
        "compare_workspace_trust",
        "rollback_grant",
        "export",
        "repair"
      ]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "corpus_empty",
        "required_trust_surface_missing",
        "restricted_workspace_allows_unconditional",
        "pending_workspace_allows_execution",
        "unconditional_allow_without_trusted_posture",
        "silent_grant_without_disclosure",
        "override_route_undisclosed",
        "read_only_missing_posture",
        "inspection_hook_unavailable",
        "support_export_fields_dropped",
        "support_export_redaction_unsafe",
        "support_export_posture_unsafe",
        "producer_attribution_incomplete",
        "lineage_export_unsafe"
      ]
    },
    "producer_attribution_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_ref",
        "schema_version",
        "integrity_hash",
        "captured_at",
        "producer_attribution_complete"
      ],
      "properties": {
        "producer_ref": { "type": "string" },
        "schema_version": { "type": "integer" },
        "integrity_hash": { "type": "string" },
        "captured_at": { "type": "string" },
        "producer_attribution_complete": { "type": "boolean" }
      }
    },
    "trust_gating_surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "derived_gate_decision",
        "declared_gate_decision",
        "gate_decision_matches",
        "silent_execution_posture",
        "explicit_user_action_required",
        "has_disclosure",
        "has_override_route",
        "override_has_disclosure",
        "touches_credential_store",
        "support_export_posture"
      ],
      "properties": {
        "surface_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "type": "string" },
        "surface_kind": { "$ref": "#/$defs/trust_surface_kind" },
        "derived_gate_decision": { "$ref": "#/$defs/gate_decision_class" },
        "declared_gate_decision": { "$ref": "#/$defs/gate_decision_class" },
        "gate_decision_matches": { "type": "boolean" },
        "silent_execution_posture": { "$ref": "#/$defs/silent_execution_posture" },
        "explicit_user_action_required": { "type": "boolean" },
        "has_disclosure": { "type": "boolean" },
        "has_override_route": { "type": "boolean" },
        "override_has_disclosure": { "type": "boolean" },
        "touches_credential_store": { "type": "boolean" },
        "support_export_posture": { "$ref": "#/$defs/support_export_posture" }
      }
    },
    "surface_coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_rows", "all_required_surfaces_present"],
      "properties": {
        "surface_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/trust_gating_surface_row" }
        },
        "all_required_surfaces_present": { "type": "boolean" }
      }
    },
    "gate_decision_truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allow_unconditional_count",
        "allow_after_explicit_grant_count",
        "allow_read_only_count",
        "block_pending_trust_decision_count",
        "block_until_repair_count",
        "no_unconditional_allow_outside_trusted",
        "restricted_workspace_blocks_or_routes_every_surface",
        "pending_workspace_blocks_or_routes_every_surface"
      ],
      "properties": {
        "allow_unconditional_count": { "type": "integer", "minimum": 0 },
        "allow_after_explicit_grant_count": { "type": "integer", "minimum": 0 },
        "allow_read_only_count": { "type": "integer", "minimum": 0 },
        "block_pending_trust_decision_count": { "type": "integer", "minimum": 0 },
        "block_until_repair_count": { "type": "integer", "minimum": 0 },
        "no_unconditional_allow_outside_trusted": { "type": "boolean" },
        "restricted_workspace_blocks_or_routes_every_surface": { "type": "boolean" },
        "pending_workspace_blocks_or_routes_every_surface": { "type": "boolean" }
      }
    },
    "silent_execution_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_grant_surfaces_require_explicit_user_action",
        "all_grant_surfaces_reference_disclosure",
        "all_read_only_surfaces_declare_no_mutation_posture"
      ],
      "properties": {
        "all_grant_surfaces_require_explicit_user_action": { "type": "boolean" },
        "all_grant_surfaces_reference_disclosure": { "type": "boolean" },
        "all_read_only_surfaces_declare_no_mutation_posture": { "type": "boolean" }
      }
    },
    "override_route_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_override_routes_disclosed", "override_route_count"],
      "properties": {
        "all_override_routes_disclosed": { "type": "boolean" },
        "override_route_count": { "type": "integer", "minimum": 0 }
      }
    },
    "support_export_honesty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_surfaces_preserve_gating_fields",
        "all_surfaces_redact_raw_secrets",
        "all_surfaces_exclude_approval_tickets",
        "all_surfaces_exclude_delegated_credentials",
        "all_surfaces_exclude_live_authority_handles",
        "all_credential_surfaces_have_safe_posture"
      ],
      "properties": {
        "all_surfaces_preserve_gating_fields": { "type": "boolean" },
        "all_surfaces_redact_raw_secrets": { "type": "boolean" },
        "all_surfaces_exclude_approval_tickets": { "type": "boolean" },
        "all_surfaces_exclude_delegated_credentials": { "type": "boolean" },
        "all_surfaces_exclude_live_authority_handles": { "type": "boolean" },
        "all_credential_surfaces_have_safe_posture": { "type": "boolean" }
      }
    },
    "inspection_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hook_class", "action_id", "label", "available", "disclosure"],
      "properties": {
        "hook_class": { "$ref": "#/$defs/inspection_hook_class" },
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "available": { "type": "boolean" },
        "disclosure": { "type": "string" }
      }
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qualified", "level", "narrow_reasons"],
      "properties": {
        "qualified": { "type": "boolean" },
        "level": {
          "type": "string",
          "enum": ["stable", "narrowed_below_stable"]
        },
        "narrow_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason" }
        }
      }
    }
  }
}
