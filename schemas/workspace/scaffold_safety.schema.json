{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workspace/scaffold_safety.schema.json",
  "title": "Aureline scaffold-safety projection record",
  "description": "Cross-surface beta projection that binds one template / generator descriptor, one scaffold plan, and zero-or-one scaffold run into the single record every starter / scaffold surface, command-palette generator row, generator-preview sheet, AI-assisted generation path, extension-provided generator, CLI / headless creation path, and support exporter reads so they all agree, before any file is written, on the template provenance, the file / dependency / task impact, the declared hook / network / registry / remote-image / dependency side effects, the create-empty / set-up-later / rollback handoffs, and the guardrails that keep generated projects plain, attributable workspace content. The projection quotes the three boundary records and adds typed predicates; it never mints new descriptor / plan / run vocabulary. Boundary contracts: /schemas/workspace/template_generator_descriptor.schema.json, /schemas/workspace/scaffold_plan.schema.json, /schemas/workspace/scaffold_run.schema.json. Produced by ScaffoldSafetyBetaProjection::project in aureline-workspace.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/scaffold_safety_record" }
  ],
  "$defs": {
    "scaffold_safety_schema_version": {
      "type": "integer",
      "const": 1
    },

    "opaque_id": { "type": "string", "minLength": 1 },

    "redaction_aware_text": { "type": "string", "maxLength": 1024 },

    "surface": {
      "type": "string",
      "enum": [
        "start_center",
        "command_palette",
        "generator_preview",
        "ai_assist",
        "extension",
        "cli_headless",
        "support"
      ],
      "description": "Closed surface set that consumes the projection."
    },

    "provider_class": {
      "type": "string",
      "enum": [
        "first_party",
        "partner_signed",
        "community_signed",
        "repo_local",
        "ad_hoc",
        "ai_assisted",
        "extension_provided"
      ]
    },

    "signature_state": {
      "type": "string",
      "enum": ["signed_verified", "signed_unverified", "unsigned", "signature_missing", "signature_mismatch"]
    },

    "generation_kind": {
      "type": "string",
      "enum": ["project_template", "file_or_component_generator", "multi_file_scaffold", "update_migration_generator"]
    },

    "generation_verb": {
      "type": "string",
      "enum": ["create_project", "generate_into_existing", "update_regenerate"]
    },

    "trust_expectation_class": {
      "type": "string",
      "enum": [
        "no_elevation",
        "workspace_trust_required",
        "network_trust_required",
        "credential_access_required",
        "privileged_execution_required"
      ]
    },

    "egress_posture_class": {
      "type": "string",
      "enum": ["no_egress", "registry_fetch", "remote_image_pull", "git_fetch", "arbitrary_network"]
    },

    "scaffold_side_effect_class": {
      "type": "string",
      "enum": ["hook", "network", "registry", "remote_image", "dependency"]
    },

    "setup_choice_class": {
      "type": "string",
      "enum": ["create_empty", "set_up_later", "full_scaffold", "scaffold_without_dependency_restore"]
    },

    "rollback_boundary_class": {
      "type": "string",
      "enum": ["checkpoint", "delete_generated_files", "git_initial_commit", "manual_only"]
    },

    "scaffold_outcome_class": {
      "type": "string",
      "enum": ["succeeded", "partially_applied", "failed_rolled_back", "failed_left_in_place", "cancelled"]
    },

    "honesty_label": {
      "type": "string",
      "enum": [
        "unsigned_template",
        "signature_mismatch",
        "ai_assisted_generation",
        "extension_provided_generation",
        "hooks_declared",
        "network_egress_declared",
        "registry_access_declared",
        "remote_image_pull_declared",
        "dependency_restore_declared",
        "writes_into_existing_project",
        "set_up_later_available",
        "create_empty_available",
        "policy_constrained",
        "partial_rollback"
      ],
      "description": "Closed honesty-label set the surface renders verbatim alongside a scaffold / generation row."
    },

    "file_impact_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create_count", "modify_count", "delete_count", "directory_count"],
      "properties": {
        "create_count": { "type": "integer", "minimum": 0 },
        "modify_count": { "type": "integer", "minimum": 0 },
        "delete_count": { "type": "integer", "minimum": 0 },
        "directory_count": { "type": "integer", "minimum": 0 }
      }
    },

    "declared_side_effect_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classes", "all_declared_before_execution", "all_attributable_after_rollback"],
      "properties": {
        "classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/scaffold_side_effect_class" },
          "uniqueItems": true
        },
        "all_declared_before_execution": { "type": "boolean" },
        "all_attributable_after_rollback": { "type": "boolean" }
      }
    },

    "setup_handoff_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "choices",
        "create_empty_available",
        "set_up_later_available",
        "rollback_boundary",
        "rollback_automatic"
      ],
      "properties": {
        "choices": {
          "type": "array",
          "items": { "$ref": "#/$defs/setup_choice_class" },
          "uniqueItems": true
        },
        "create_empty_available": { "type": "boolean" },
        "set_up_later_available": { "type": "boolean" },
        "rollback_boundary": { "$ref": "#/$defs/rollback_boundary_class" },
        "rollback_automatic": { "type": "boolean" }
      }
    },

    "scaffold_run_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scaffold_run_ref",
        "outcome_class",
        "created_artifact_count",
        "modified_artifact_count",
        "undeclared_actions_blocked",
        "plain_file_authority",
        "no_hidden_project_database",
        "generated_lineage_ref"
      ],
      "properties": {
        "scaffold_run_ref": { "$ref": "#/$defs/opaque_id" },
        "outcome_class": { "$ref": "#/$defs/scaffold_outcome_class" },
        "created_artifact_count": { "type": "integer", "minimum": 0 },
        "modified_artifact_count": { "type": "integer", "minimum": 0 },
        "undeclared_actions_blocked": { "type": "boolean" },
        "plain_file_authority": { "type": "boolean" },
        "no_hidden_project_database": { "type": "boolean" },
        "generated_lineage_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },

    "scaffold_safety_guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_writes_before_review",
        "side_effects_declared_before_execution",
        "side_effects_attributable_after_rollback",
        "no_undeclared_hooks_or_bootstrap",
        "generated_output_is_plain_workspace_content",
        "rollback_boundary_visible",
        "ai_extension_uses_governed_surface"
      ],
      "properties": {
        "no_writes_before_review": { "type": "boolean" },
        "side_effects_declared_before_execution": { "type": "boolean" },
        "side_effects_attributable_after_rollback": { "type": "boolean" },
        "no_undeclared_hooks_or_bootstrap": { "type": "boolean" },
        "generated_output_is_plain_workspace_content": { "type": "boolean" },
        "rollback_boundary_visible": { "type": "boolean" },
        "ai_extension_uses_governed_surface": { "type": "boolean" }
      },
      "description": "Typed guardrail predicates the projection guarantees, each mapping to a guardrail or acceptance criterion in the scaffold-safety spec."
    },

    "scaffold_safety_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "scaffold_safety_schema_version",
        "surface",
        "descriptor_ref",
        "scaffold_plan_ref",
        "template_or_generator_id",
        "version",
        "provider_class",
        "signature_state",
        "generation_kind",
        "generation_verb",
        "trust_expectation",
        "egress_posture",
        "supported_ecosystems",
        "supported_archetypes",
        "required_parameter_count",
        "resolved_parameter_count",
        "declared_hook_count",
        "file_impact",
        "declared_side_effects",
        "remote_implication_count",
        "setup_handoff",
        "honesty_labels",
        "guardrails"
      ],
      "properties": {
        "record_kind": { "const": "scaffold_safety_record" },
        "scaffold_safety_schema_version": { "$ref": "#/$defs/scaffold_safety_schema_version" },
        "surface": { "$ref": "#/$defs/surface" },

        "descriptor_ref": { "$ref": "#/$defs/opaque_id" },
        "scaffold_plan_ref": { "$ref": "#/$defs/opaque_id" },
        "scaffold_run_ref": { "$ref": "#/$defs/opaque_id" },

        "template_or_generator_id": { "$ref": "#/$defs/opaque_id" },
        "version": { "$ref": "#/$defs/redaction_aware_text" },
        "provider_class": { "$ref": "#/$defs/provider_class" },
        "signature_state": { "$ref": "#/$defs/signature_state" },
        "generation_kind": { "$ref": "#/$defs/generation_kind" },
        "generation_verb": { "$ref": "#/$defs/generation_verb" },
        "trust_expectation": { "$ref": "#/$defs/trust_expectation_class" },
        "egress_posture": { "$ref": "#/$defs/egress_posture_class" },

        "supported_ecosystems": {
          "type": "array",
          "items": { "$ref": "#/$defs/redaction_aware_text" }
        },
        "supported_archetypes": {
          "type": "array",
          "items": { "$ref": "#/$defs/redaction_aware_text" }
        },

        "required_parameter_count": { "type": "integer", "minimum": 0 },
        "resolved_parameter_count": { "type": "integer", "minimum": 0 },
        "declared_hook_count": { "type": "integer", "minimum": 0 },

        "file_impact": { "$ref": "#/$defs/file_impact_summary" },
        "declared_side_effects": { "$ref": "#/$defs/declared_side_effect_summary" },
        "remote_implication_count": { "type": "integer", "minimum": 0 },
        "setup_handoff": { "$ref": "#/$defs/setup_handoff_summary" },

        "run_summary": { "$ref": "#/$defs/scaffold_run_summary" },

        "honesty_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/honesty_label" },
          "uniqueItems": true
        },
        "guardrails": { "$ref": "#/$defs/scaffold_safety_guardrails" }
      },
      "description": "One scaffold-safety projection record. Read by every scaffold / generation surface so they agree, before any file is written, about template provenance, scaffold-plan impact, declared side effects, setup / rollback handoffs, and generated-project health."
    }
  }
}
