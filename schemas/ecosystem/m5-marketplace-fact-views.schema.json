{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ecosystem/m5-marketplace-fact-views.schema.json",
  "title": "Aureline M5 marketplace fact-views",
  "description": "Schema for the m5_marketplace_fact_views packet. The packet projects the M5 ecosystem install-governance truth into the marketplace presentation layer: source-aware result rows, per-listing detail fact grids, and side-by-side compare views. Every view exposes the same fact set — package kind, source class, lifecycle state, support class, evidence freshness, runtime origin, bridge/native state, and mirror/private-registry posture — and a discovery channel, so the same information architecture holds across the public registry, an enterprise mirror, a private registry, and manual import. Each row's disclosure level and reasons are recomputed from its facts: reduced provenance (a community/unverified source, an unsigned runtime, or a manual import), mirrored/private distribution, non-current evidence, narrowed support, or a non-native runtime widens disclosure, and a mirror/private/manual listing keeps every backing ref a first-party listing carries rather than collapsing fields. Every detail grid and compare-view entry must reproduce its source row's facts exactly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "package_kinds",
    "source_classes",
    "support_classes",
    "runtime_origins",
    "lifecycle_states",
    "evidence_freshness_classes",
    "bridge_native_states",
    "mirror_postures",
    "discovery_channels",
    "disclosure_levels",
    "disclosure_reasons",
    "result_rows",
    "detail_grids",
    "compare_views",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_marketplace_fact_views" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "package_kinds": { "type": "array", "items": { "$ref": "#/$defs/package_kind" } },
    "source_classes": { "type": "array", "items": { "$ref": "#/$defs/source_class" } },
    "support_classes": { "type": "array", "items": { "$ref": "#/$defs/support_class" } },
    "runtime_origins": { "type": "array", "items": { "$ref": "#/$defs/runtime_origin" } },
    "lifecycle_states": { "type": "array", "items": { "$ref": "#/$defs/lifecycle_state" } },
    "evidence_freshness_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_freshness" }
    },
    "bridge_native_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/bridge_native_state" }
    },
    "mirror_postures": { "type": "array", "items": { "$ref": "#/$defs/mirror_posture" } },
    "discovery_channels": { "type": "array", "items": { "$ref": "#/$defs/discovery_channel" } },
    "disclosure_levels": { "type": "array", "items": { "$ref": "#/$defs/disclosure_level" } },
    "disclosure_reasons": { "type": "array", "items": { "$ref": "#/$defs/disclosure_reason" } },
    "result_rows": { "type": "array", "items": { "$ref": "#/$defs/result_row" } },
    "detail_grids": { "type": "array", "items": { "$ref": "#/$defs/detail_grid" } },
    "compare_views": { "type": "array", "items": { "$ref": "#/$defs/compare_view" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "package_kind": {
      "enum": [
        "first_party_framework_pack",
        "docs_pack",
        "local_model_pack",
        "signed_recipe_pack",
        "template_artifact",
        "bridge_backed_package",
        "side_loaded_package",
        "mirrored_registry_variant"
      ]
    },
    "source_class": {
      "enum": ["first_party", "verified_partner", "community", "unverified"]
    },
    "support_class": {
      "enum": ["fully_supported", "best_effort_supported", "community_supported", "unsupported"]
    },
    "runtime_origin": {
      "enum": [
        "first_party_signed",
        "partner_signed",
        "community_signed",
        "bridge_runtime",
        "local_model_runtime",
        "unsigned_side_loaded"
      ]
    },
    "lifecycle_state": {
      "enum": [
        "available",
        "installed",
        "update_available",
        "disabled",
        "quarantined",
        "rolled_back",
        "retired"
      ]
    },
    "evidence_freshness": {
      "enum": ["current", "stale", "expired", "unknown"]
    },
    "bridge_native_state": {
      "enum": ["native", "bridge_backed", "local_model_hosted"]
    },
    "mirror_posture": {
      "enum": ["direct_first_party", "enterprise_mirrored", "private_registry", "manually_imported"]
    },
    "discovery_channel": {
      "enum": ["public_registry", "enterprise_mirror", "private_registry", "manual_import"]
    },
    "disclosure_level": {
      "enum": ["standard", "caution", "heightened"]
    },
    "disclosure_reason": {
      "enum": [
        "reduced_provenance",
        "mirrored_or_private_distribution",
        "evidence_not_current",
        "support_narrowed",
        "non_native_runtime"
      ]
    },
    "fact_fields": {
      "type": "object",
      "properties": {
        "package_kind": { "$ref": "#/$defs/package_kind" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness" },
        "runtime_origin": { "$ref": "#/$defs/runtime_origin" },
        "bridge_native_state": { "$ref": "#/$defs/bridge_native_state" },
        "mirror_posture": { "$ref": "#/$defs/mirror_posture" },
        "discovery_channel": { "$ref": "#/$defs/discovery_channel" },
        "disclosure_level": { "$ref": "#/$defs/disclosure_level" },
        "disclosure_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/disclosure_reason" }
        }
      }
    },
    "result_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "listing_ref",
        "display_label",
        "governance_family_ref",
        "package_kind",
        "source_class",
        "lifecycle_state",
        "support_class",
        "evidence_freshness",
        "runtime_origin",
        "bridge_native_state",
        "mirror_posture",
        "discovery_channel",
        "disclosure_level",
        "summary"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "listing_ref": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "governance_family_ref": { "$ref": "#/$defs/non_empty_string" },
        "package_kind": { "$ref": "#/$defs/package_kind" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness" },
        "runtime_origin": { "$ref": "#/$defs/runtime_origin" },
        "bridge_native_state": { "$ref": "#/$defs/bridge_native_state" },
        "mirror_posture": { "$ref": "#/$defs/mirror_posture" },
        "discovery_channel": { "$ref": "#/$defs/discovery_channel" },
        "disclosure_level": { "$ref": "#/$defs/disclosure_level" },
        "disclosure_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/disclosure_reason" }
        },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "detail_grid": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grid_id",
        "row_ref",
        "display_label",
        "package_kind",
        "source_class",
        "lifecycle_state",
        "support_class",
        "evidence_freshness",
        "runtime_origin",
        "bridge_native_state",
        "mirror_posture",
        "discovery_channel",
        "disclosure_level",
        "provenance_ref",
        "permission_manifest_ref",
        "compatibility_ref",
        "activation_budget_ref",
        "rollback_ref",
        "support_export_ref",
        "summary"
      ],
      "properties": {
        "grid_id": { "$ref": "#/$defs/non_empty_string" },
        "row_ref": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "package_kind": { "$ref": "#/$defs/package_kind" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness" },
        "runtime_origin": { "$ref": "#/$defs/runtime_origin" },
        "bridge_native_state": { "$ref": "#/$defs/bridge_native_state" },
        "mirror_posture": { "$ref": "#/$defs/mirror_posture" },
        "discovery_channel": { "$ref": "#/$defs/discovery_channel" },
        "disclosure_level": { "$ref": "#/$defs/disclosure_level" },
        "disclosure_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/disclosure_reason" }
        },
        "provenance_ref": { "$ref": "#/$defs/non_empty_string" },
        "permission_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "compatibility_ref": { "$ref": "#/$defs/non_empty_string" },
        "activation_budget_ref": { "$ref": "#/$defs/non_empty_string" },
        "rollback_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "compare_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_ref",
        "display_label",
        "package_kind",
        "source_class",
        "lifecycle_state",
        "support_class",
        "evidence_freshness",
        "runtime_origin",
        "bridge_native_state",
        "mirror_posture",
        "discovery_channel",
        "disclosure_level"
      ],
      "properties": {
        "row_ref": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "package_kind": { "$ref": "#/$defs/package_kind" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness" },
        "runtime_origin": { "$ref": "#/$defs/runtime_origin" },
        "bridge_native_state": { "$ref": "#/$defs/bridge_native_state" },
        "mirror_posture": { "$ref": "#/$defs/mirror_posture" },
        "discovery_channel": { "$ref": "#/$defs/discovery_channel" },
        "disclosure_level": { "$ref": "#/$defs/disclosure_level" },
        "disclosure_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/disclosure_reason" }
        }
      }
    },
    "compare_view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["compare_id", "title", "compared_row_refs", "entries", "summary"],
      "properties": {
        "compare_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "compared_row_refs": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "entries": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/compare_entry" }
        },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_result_rows",
        "total_detail_grids",
        "total_compare_views",
        "standard_disclosure_rows",
        "caution_disclosure_rows",
        "heightened_disclosure_rows",
        "widened_disclosure_rows",
        "mirrored_or_private_rows",
        "manual_import_rows",
        "non_native_runtime_rows",
        "not_current_evidence_rows",
        "narrowed_support_rows",
        "distinct_package_kinds",
        "distinct_discovery_channels"
      ],
      "properties": {
        "total_result_rows": { "type": "integer", "minimum": 0 },
        "total_detail_grids": { "type": "integer", "minimum": 0 },
        "total_compare_views": { "type": "integer", "minimum": 0 },
        "standard_disclosure_rows": { "type": "integer", "minimum": 0 },
        "caution_disclosure_rows": { "type": "integer", "minimum": 0 },
        "heightened_disclosure_rows": { "type": "integer", "minimum": 0 },
        "widened_disclosure_rows": { "type": "integer", "minimum": 0 },
        "mirrored_or_private_rows": { "type": "integer", "minimum": 0 },
        "manual_import_rows": { "type": "integer", "minimum": 0 },
        "non_native_runtime_rows": { "type": "integer", "minimum": 0 },
        "not_current_evidence_rows": { "type": "integer", "minimum": 0 },
        "narrowed_support_rows": { "type": "integer", "minimum": 0 },
        "distinct_package_kinds": { "type": "integer", "minimum": 0 },
        "distinct_discovery_channels": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
