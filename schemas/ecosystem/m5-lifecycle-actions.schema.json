{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ecosystem/m5-lifecycle-actions.schema.json",
  "title": "Aureline M5 lifecycle actions",
  "description": "Schema for the m5_lifecycle_actions packet. The packet freezes disable-for-workspace, disable-globally, uninstall, rollback, quarantine, re-enable, and registry-status transitions (revoked, yanked, deprecated, publisher-transferred) for marketed M5 artifact families as distinct reviewed actions. Each record names what already-open views and background work do (keep running temporarily, stop immediately, or convert to placeholders at the next activation boundary), which user-owned data classes survive an uninstall or disable, and the last-known-good rollback target with its compatibility note. Each record's review-reason set and action disposition are recomputed from its facts: a reactive trigger forces at least review_required, an unconsented removal of protected user-owned data or an irreversible rollback blocks the action, and a clean user-initiated disable stays proceed_allowed. Workspace- and global-scope disables are bound to their scope, and every offered action carries the record's scope.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "package_kinds",
    "scopes",
    "rollback_postures",
    "action_kinds",
    "triggers",
    "lifecycle_statuses",
    "continuity_dispositions",
    "data_classes",
    "data_dispositions",
    "rollback_compatibilities",
    "review_reasons",
    "action_dispositions",
    "records",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_lifecycle_actions" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "package_kinds": { "type": "array", "items": { "$ref": "#/$defs/package_kind" } },
    "scopes": { "type": "array", "items": { "$ref": "#/$defs/scope" } },
    "rollback_postures": { "type": "array", "items": { "$ref": "#/$defs/rollback_posture" } },
    "action_kinds": { "type": "array", "items": { "$ref": "#/$defs/action_kind" } },
    "triggers": { "type": "array", "items": { "$ref": "#/$defs/trigger" } },
    "lifecycle_statuses": { "type": "array", "items": { "$ref": "#/$defs/lifecycle_status" } },
    "continuity_dispositions": {
      "type": "array",
      "items": { "$ref": "#/$defs/continuity_disposition" }
    },
    "data_classes": { "type": "array", "items": { "$ref": "#/$defs/data_class" } },
    "data_dispositions": { "type": "array", "items": { "$ref": "#/$defs/data_disposition" } },
    "rollback_compatibilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/rollback_compatibility" }
    },
    "review_reasons": { "type": "array", "items": { "$ref": "#/$defs/review_reason" } },
    "action_dispositions": {
      "type": "array",
      "items": { "$ref": "#/$defs/action_disposition" }
    },
    "records": { "type": "array", "items": { "$ref": "#/$defs/record" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "package_kind": {
      "enum": [
        "first_party_framework_pack",
        "docs_pack",
        "local_model_pack",
        "signed_recipe_pack",
        "template_artifact",
        "bridge_backed_package",
        "side_loaded_package",
        "mirrored_registry_variant"
      ]
    },
    "scope": { "enum": ["workspace", "profile", "global"] },
    "rollback_posture": {
      "enum": [
        "reversible_verified",
        "reversible_unverified",
        "compensating_only",
        "irreversible",
        "not_applicable"
      ]
    },
    "action_kind": {
      "enum": [
        "disable_workspace",
        "disable_global",
        "uninstall",
        "rollback",
        "quarantine",
        "reenable",
        "apply_registry_status"
      ]
    },
    "trigger": {
      "enum": [
        "user_initiated",
        "crash_loop",
        "integrity_failure",
        "performance_budget_exceeded",
        "moderation",
        "policy",
        "revocation",
        "yank",
        "deprecation",
        "publisher_transfer"
      ]
    },
    "lifecycle_status": {
      "enum": [
        "active",
        "disabled_workspace",
        "disabled_global",
        "uninstalled",
        "rolled_back",
        "quarantined",
        "revoked",
        "yanked",
        "deprecated",
        "publisher_transferred"
      ]
    },
    "continuity_disposition": {
      "enum": [
        "keeps_running_temporarily",
        "stops_immediately",
        "converts_to_placeholder_at_next_activation",
        "not_applicable"
      ]
    },
    "data_class": {
      "enum": [
        "user_recipes",
        "docs_pack_content",
        "local_history",
        "rollback_checkpoints",
        "workspace_settings",
        "cached_indexes",
        "model_weights",
        "generated_placeholders"
      ]
    },
    "data_disposition": {
      "enum": ["retained", "removed_with_explicit_consent", "regenerable_cache"]
    },
    "rollback_compatibility": {
      "enum": ["clean", "requires_recompat", "state_loss_possible", "not_reversible", "not_applicable"]
    },
    "review_reason": {
      "enum": [
        "unconsented_protected_data_removal",
        "rollback_not_reversible",
        "automated_health_trigger",
        "moderation_or_policy_trigger",
        "registry_status_trigger",
        "publisher_transfer_trigger",
        "open_work_disruption",
        "irreversible_action",
        "rollback_not_risk_free",
        "disclosed_protected_data_removal"
      ]
    },
    "action_disposition": {
      "enum": ["proceed_allowed", "review_required", "blocked"]
    },
    "retained_state_impact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data_class", "disposition", "note_ref"],
      "properties": {
        "data_class": { "$ref": "#/$defs/data_class" },
        "disposition": { "$ref": "#/$defs/data_disposition" },
        "note_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "rollback_note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rollback_compatibility", "rollback_posture"],
      "properties": {
        "rollback_compatibility": { "$ref": "#/$defs/rollback_compatibility" },
        "rollback_posture": { "$ref": "#/$defs/rollback_posture" },
        "last_known_good_ref": { "$ref": "#/$defs/non_empty_string" },
        "retained_state_note_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "offered_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_kind", "scope", "action_ref", "enabled"],
      "properties": {
        "action_kind": { "$ref": "#/$defs/action_kind" },
        "scope": { "$ref": "#/$defs/scope" },
        "action_ref": { "$ref": "#/$defs/non_empty_string" },
        "enabled": { "type": "boolean" }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "listing_ref",
        "display_label",
        "governance_family_ref",
        "package_kind",
        "action_kind",
        "scope",
        "trigger",
        "resulting_status",
        "continuity",
        "destructive_consent_captured",
        "rollback",
        "restorable",
        "action_disposition",
        "summary"
      ],
      "properties": {
        "record_id": { "$ref": "#/$defs/non_empty_string" },
        "listing_ref": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "governance_family_ref": { "$ref": "#/$defs/non_empty_string" },
        "package_kind": { "$ref": "#/$defs/package_kind" },
        "action_kind": { "$ref": "#/$defs/action_kind" },
        "scope": { "$ref": "#/$defs/scope" },
        "trigger": { "$ref": "#/$defs/trigger" },
        "resulting_status": { "$ref": "#/$defs/lifecycle_status" },
        "continuity": { "$ref": "#/$defs/continuity_disposition" },
        "contributed_surface_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "retained_state": {
          "type": "array",
          "items": { "$ref": "#/$defs/retained_state_impact" }
        },
        "destructive_consent_captured": { "type": "boolean" },
        "rollback": { "$ref": "#/$defs/rollback_note" },
        "restorable": { "type": "boolean" },
        "restore_path_ref": { "$ref": "#/$defs/non_empty_string" },
        "offered_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/offered_action" }
        },
        "review_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/review_reason" }
        },
        "action_disposition": { "$ref": "#/$defs/action_disposition" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_records",
        "proceed_allowed_records",
        "review_required_records",
        "blocked_records",
        "workspace_disable_records",
        "global_disable_records",
        "uninstall_records",
        "rollback_records",
        "quarantine_records",
        "reenable_records",
        "registry_status_records",
        "reactive_trigger_records",
        "placeholder_conversion_records",
        "protected_data_preserved_records",
        "disclosed_protected_removal_records",
        "restorable_records",
        "distinct_package_kinds"
      ],
      "properties": {
        "total_records": { "type": "integer", "minimum": 0 },
        "proceed_allowed_records": { "type": "integer", "minimum": 0 },
        "review_required_records": { "type": "integer", "minimum": 0 },
        "blocked_records": { "type": "integer", "minimum": 0 },
        "workspace_disable_records": { "type": "integer", "minimum": 0 },
        "global_disable_records": { "type": "integer", "minimum": 0 },
        "uninstall_records": { "type": "integer", "minimum": 0 },
        "rollback_records": { "type": "integer", "minimum": 0 },
        "quarantine_records": { "type": "integer", "minimum": 0 },
        "reenable_records": { "type": "integer", "minimum": 0 },
        "registry_status_records": { "type": "integer", "minimum": 0 },
        "reactive_trigger_records": { "type": "integer", "minimum": 0 },
        "placeholder_conversion_records": { "type": "integer", "minimum": 0 },
        "protected_data_preserved_records": { "type": "integer", "minimum": 0 },
        "disclosed_protected_removal_records": { "type": "integer", "minimum": 0 },
        "restorable_records": { "type": "integer", "minimum": 0 },
        "distinct_package_kinds": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
