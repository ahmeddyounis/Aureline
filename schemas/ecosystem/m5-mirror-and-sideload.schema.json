{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ecosystem/m5-mirror-and-sideload.schema.json",
  "title": "Aureline M5 mirror, private-registry, and side-load review",
  "description": "Schema for the m5_mirror_and_sideload packet. The packet proves the M5 install-review story holds the same in mirrored, private-registry, manual-import, and air-gapped lanes as in the public registry. Each review packet reproduces the full public-registry install-review fact set — package identity, source class, compatibility, permission, runtime origin, lifecycle, activation budget, and rollback — and adds the continuity facts these lanes make visible: publisher transfer, signing-root and namespace continuity, maintenance/orphan state, mirror freshness, and provenance level. A packet's review disposition and continuity-signal set are recomputed from its facts: a permission expansion, an unsupported target, an incomplete rollback, a quarantine, a changed signing root, a discontinuous namespace, an unmaintained package, an unverified publisher transfer, or unverifiable provenance force a blocked disposition, and every packet carries the full backing-ref set so manual-import and air-gapped reviews stay export-safe. Enterprise policy filters gate the families by publisher, signing root, runtime origin, capability class, network class, support class, bridge state, and activation-budget band; each evaluation's gate decision is the stronger of the matched filter effect and the packet's own review disposition, so policy can tighten but never loosen admission.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "package_kinds",
    "source_classes",
    "acquisition_channels",
    "mirror_postures",
    "support_classes",
    "runtime_origins",
    "bridge_native_states",
    "network_classes",
    "lifecycle_states",
    "evidence_freshness_classes",
    "compatibility_labels",
    "permission_manifest_states",
    "activation_budget_bands",
    "rollback_postures",
    "publisher_transfer_states",
    "signing_root_continuities",
    "namespace_states",
    "maintenance_states",
    "mirror_freshness_classes",
    "provenance_levels",
    "capability_classes",
    "continuity_signals",
    "review_dispositions",
    "policy_dimensions",
    "policy_effects",
    "policy_gate_decisions",
    "review_packets",
    "policy_filters",
    "policy_evaluations",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_mirror_and_sideload" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "package_kinds": { "type": "array", "items": { "$ref": "#/$defs/package_kind" } },
    "source_classes": { "type": "array", "items": { "$ref": "#/$defs/source_class" } },
    "acquisition_channels": { "type": "array", "items": { "$ref": "#/$defs/acquisition_channel" } },
    "mirror_postures": { "type": "array", "items": { "$ref": "#/$defs/mirror_posture" } },
    "support_classes": { "type": "array", "items": { "$ref": "#/$defs/support_class" } },
    "runtime_origins": { "type": "array", "items": { "$ref": "#/$defs/runtime_origin" } },
    "bridge_native_states": { "type": "array", "items": { "$ref": "#/$defs/bridge_native_state" } },
    "network_classes": { "type": "array", "items": { "$ref": "#/$defs/network_class" } },
    "lifecycle_states": { "type": "array", "items": { "$ref": "#/$defs/lifecycle_state" } },
    "evidence_freshness_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_freshness" }
    },
    "compatibility_labels": { "type": "array", "items": { "$ref": "#/$defs/compatibility_label" } },
    "permission_manifest_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/permission_manifest_state" }
    },
    "activation_budget_bands": {
      "type": "array",
      "items": { "$ref": "#/$defs/activation_budget_band" }
    },
    "rollback_postures": { "type": "array", "items": { "$ref": "#/$defs/rollback_posture" } },
    "publisher_transfer_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/publisher_transfer_state" }
    },
    "signing_root_continuities": {
      "type": "array",
      "items": { "$ref": "#/$defs/signing_root_continuity" }
    },
    "namespace_states": { "type": "array", "items": { "$ref": "#/$defs/namespace_state" } },
    "maintenance_states": { "type": "array", "items": { "$ref": "#/$defs/maintenance_state" } },
    "mirror_freshness_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/mirror_freshness" }
    },
    "provenance_levels": { "type": "array", "items": { "$ref": "#/$defs/provenance_level" } },
    "capability_classes": { "type": "array", "items": { "$ref": "#/$defs/capability_class" } },
    "continuity_signals": { "type": "array", "items": { "$ref": "#/$defs/continuity_signal" } },
    "review_dispositions": { "type": "array", "items": { "$ref": "#/$defs/review_disposition" } },
    "policy_dimensions": { "type": "array", "items": { "$ref": "#/$defs/policy_dimension" } },
    "policy_effects": { "type": "array", "items": { "$ref": "#/$defs/policy_effect" } },
    "policy_gate_decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/policy_gate_decision" }
    },
    "review_packets": { "type": "array", "items": { "$ref": "#/$defs/review_packet" } },
    "policy_filters": { "type": "array", "items": { "$ref": "#/$defs/policy_filter" } },
    "policy_evaluations": { "type": "array", "items": { "$ref": "#/$defs/policy_evaluation" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "package_kind": {
      "enum": [
        "first_party_framework_pack",
        "docs_pack",
        "local_model_pack",
        "signed_recipe_pack",
        "template_artifact",
        "bridge_backed_package",
        "side_loaded_package",
        "mirrored_registry_variant"
      ]
    },
    "source_class": {
      "enum": ["first_party", "verified_partner", "community", "unverified"]
    },
    "acquisition_channel": {
      "enum": [
        "public_registry",
        "enterprise_mirror",
        "private_registry",
        "manual_import",
        "air_gapped_import"
      ]
    },
    "mirror_posture": {
      "enum": ["direct_first_party", "enterprise_mirrored", "private_registry", "manually_imported"]
    },
    "support_class": {
      "enum": ["fully_supported", "best_effort_supported", "community_supported", "unsupported"]
    },
    "runtime_origin": {
      "enum": [
        "first_party_signed",
        "partner_signed",
        "community_signed",
        "bridge_runtime",
        "local_model_runtime",
        "unsigned_side_loaded"
      ]
    },
    "bridge_native_state": {
      "enum": ["native", "bridge_backed", "local_model_hosted"]
    },
    "network_class": {
      "enum": ["offline", "local_only", "scoped_network", "open_network"]
    },
    "lifecycle_state": {
      "enum": [
        "available",
        "installed",
        "update_available",
        "disabled",
        "quarantined",
        "rolled_back",
        "retired"
      ]
    },
    "evidence_freshness": {
      "enum": ["current", "stale", "expired", "unknown"]
    },
    "compatibility_label": {
      "enum": [
        "compatible",
        "degraded_compatible",
        "compatibility_bridge_required",
        "unsupported_on_target"
      ]
    },
    "permission_manifest_state": {
      "enum": ["unchanged", "reduced", "additive_disclosed", "expanded_unreviewed", "not_applicable"]
    },
    "activation_budget_band": {
      "enum": [
        "healthy_under_budget",
        "approaching_ceiling",
        "over_budget",
        "budget_unknown",
        "not_applicable"
      ]
    },
    "rollback_posture": {
      "enum": [
        "reversible_verified",
        "reversible_unverified",
        "compensating_only",
        "irreversible",
        "not_applicable"
      ]
    },
    "publisher_transfer_state": {
      "enum": [
        "same_publisher",
        "transferred_verified",
        "transferred_unverified",
        "publisher_unknown",
        "not_applicable"
      ]
    },
    "signing_root_continuity": {
      "enum": ["continuous", "rotated_disclosed", "root_changed", "unsigned", "not_applicable"]
    },
    "namespace_state": {
      "enum": ["stable", "renamed", "orphaned", "reclaimed", "not_applicable"]
    },
    "maintenance_state": {
      "enum": ["actively_maintained", "maintenance_reduced", "unmaintained", "orphaned"]
    },
    "mirror_freshness": {
      "enum": [
        "direct_upstream",
        "mirror_current",
        "mirror_lagging",
        "mirror_stale",
        "mirror_unknown"
      ]
    },
    "provenance_level": {
      "enum": ["full_attested", "signed_no_attestation", "checksum_only", "unverifiable"]
    },
    "capability_class": {
      "enum": [
        "filesystem_read",
        "filesystem_write",
        "network_access",
        "process_spawn",
        "clipboard_access",
        "secrets_read",
        "telemetry_emit",
        "model_inference",
        "workspace_settings_write",
        "background_execution"
      ]
    },
    "continuity_signal": {
      "enum": [
        "evidence_not_current",
        "mirror_stale",
        "publisher_transferred_verified",
        "maintenance_reduced",
        "provenance_reduced",
        "non_native_runtime",
        "support_narrowed",
        "activation_budget_exceeded",
        "publisher_discontinuous",
        "signing_root_changed",
        "namespace_discontinuous",
        "unmaintained",
        "provenance_unverifiable",
        "permission_expansion_unreviewed",
        "compatibility_unsupported",
        "rollback_incomplete",
        "quarantined"
      ]
    },
    "review_disposition": {
      "enum": ["proceed", "review_required", "blocked"]
    },
    "policy_dimension": {
      "enum": [
        "publisher",
        "signing_root",
        "runtime_origin",
        "capability_class",
        "network_class",
        "support_class",
        "bridge_state",
        "activation_budget_band"
      ]
    },
    "policy_effect": {
      "enum": ["allow", "require_approval", "block"]
    },
    "policy_gate_decision": {
      "enum": ["allowed", "approval_required", "blocked"]
    },
    "review_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_id",
        "display_label",
        "governance_family_ref",
        "package_kind",
        "source_class",
        "acquisition_channel",
        "mirror_posture",
        "publisher_ref",
        "signing_root_ref",
        "namespace_ref",
        "lifecycle_state",
        "support_class",
        "evidence_freshness",
        "runtime_origin",
        "bridge_native_state",
        "network_class",
        "compatibility_label",
        "permission_manifest_state",
        "activation_budget_band",
        "rollback_posture",
        "publisher_transfer_state",
        "signing_root_continuity",
        "namespace_state",
        "maintenance_state",
        "mirror_freshness",
        "provenance_level",
        "review_disposition",
        "provenance_ref",
        "permission_manifest_ref",
        "compatibility_ref",
        "activation_budget_ref",
        "rollback_ref",
        "publisher_continuity_ref",
        "support_export_ref",
        "summary"
      ],
      "properties": {
        "review_id": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "governance_family_ref": { "$ref": "#/$defs/non_empty_string" },
        "package_kind": { "$ref": "#/$defs/package_kind" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "acquisition_channel": { "$ref": "#/$defs/acquisition_channel" },
        "mirror_posture": { "$ref": "#/$defs/mirror_posture" },
        "publisher_ref": { "$ref": "#/$defs/non_empty_string" },
        "signing_root_ref": { "$ref": "#/$defs/non_empty_string" },
        "namespace_ref": { "$ref": "#/$defs/non_empty_string" },
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness" },
        "runtime_origin": { "$ref": "#/$defs/runtime_origin" },
        "bridge_native_state": { "$ref": "#/$defs/bridge_native_state" },
        "network_class": { "$ref": "#/$defs/network_class" },
        "compatibility_label": { "$ref": "#/$defs/compatibility_label" },
        "permission_manifest_state": { "$ref": "#/$defs/permission_manifest_state" },
        "activation_budget_band": { "$ref": "#/$defs/activation_budget_band" },
        "rollback_posture": { "$ref": "#/$defs/rollback_posture" },
        "publisher_transfer_state": { "$ref": "#/$defs/publisher_transfer_state" },
        "signing_root_continuity": { "$ref": "#/$defs/signing_root_continuity" },
        "namespace_state": { "$ref": "#/$defs/namespace_state" },
        "maintenance_state": { "$ref": "#/$defs/maintenance_state" },
        "mirror_freshness": { "$ref": "#/$defs/mirror_freshness" },
        "provenance_level": { "$ref": "#/$defs/provenance_level" },
        "capability_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/capability_class" }
        },
        "review_disposition": { "$ref": "#/$defs/review_disposition" },
        "continuity_signals": {
          "type": "array",
          "items": { "$ref": "#/$defs/continuity_signal" }
        },
        "provenance_ref": { "$ref": "#/$defs/non_empty_string" },
        "permission_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "compatibility_ref": { "$ref": "#/$defs/non_empty_string" },
        "activation_budget_ref": { "$ref": "#/$defs/non_empty_string" },
        "rollback_ref": { "$ref": "#/$defs/non_empty_string" },
        "publisher_continuity_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "policy_filter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filter_id", "display_label", "dimension", "match_values", "effect", "rationale"],
      "properties": {
        "filter_id": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "dimension": { "$ref": "#/$defs/policy_dimension" },
        "match_values": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "effect": { "$ref": "#/$defs/policy_effect" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "policy_evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evaluation_id",
        "review_ref",
        "strongest_effect",
        "gate_decision",
        "summary"
      ],
      "properties": {
        "evaluation_id": { "$ref": "#/$defs/non_empty_string" },
        "review_ref": { "$ref": "#/$defs/non_empty_string" },
        "matched_filter_refs": { "$ref": "#/$defs/string_array" },
        "strongest_effect": { "$ref": "#/$defs/policy_effect" },
        "gate_decision": { "$ref": "#/$defs/policy_gate_decision" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_review_packets",
        "total_policy_filters",
        "total_policy_evaluations",
        "proceed_packets",
        "review_required_packets",
        "blocked_packets",
        "mirrored_or_private_packets",
        "side_loaded_packets",
        "publisher_discontinuity_packets",
        "provenance_reduced_packets",
        "allowed_evaluations",
        "approval_required_evaluations",
        "blocked_evaluations",
        "distinct_package_kinds",
        "distinct_acquisition_channels"
      ],
      "properties": {
        "total_review_packets": { "type": "integer", "minimum": 0 },
        "total_policy_filters": { "type": "integer", "minimum": 0 },
        "total_policy_evaluations": { "type": "integer", "minimum": 0 },
        "proceed_packets": { "type": "integer", "minimum": 0 },
        "review_required_packets": { "type": "integer", "minimum": 0 },
        "blocked_packets": { "type": "integer", "minimum": 0 },
        "mirrored_or_private_packets": { "type": "integer", "minimum": 0 },
        "side_loaded_packets": { "type": "integer", "minimum": 0 },
        "publisher_discontinuity_packets": { "type": "integer", "minimum": 0 },
        "provenance_reduced_packets": { "type": "integer", "minimum": 0 },
        "allowed_evaluations": { "type": "integer", "minimum": 0 },
        "approval_required_evaluations": { "type": "integer", "minimum": 0 },
        "blocked_evaluations": { "type": "integer", "minimum": 0 },
        "distinct_package_kinds": { "type": "integer", "minimum": 0 },
        "distinct_acquisition_channels": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
