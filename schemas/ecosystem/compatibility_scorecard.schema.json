{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ecosystem/compatibility_scorecard.schema.json",
  "title": "Aureline ecosystem compatibility scorecard",
  "description": "Machine-readable compatibility scorecards and cross-surface consumer projections for imported extensions, bridge classes, workflow bundles, and reference-workspace backed ecosystem claims. Marketplace, migration, bundle-detail, support-export, and release-claim surfaces project from the same canonical row so parity band, freshness, evidence source, and reference-workspace lineage cannot drift into hand-maintained prose.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "scorecard_revision",
    "source_schema_refs",
    "rows",
    "consumer_claims",
    "inspection",
    "summary_label"
  ],
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "ecosystem_compatibility_scorecard_packet"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "scorecard_revision": {
      "type": "integer",
      "minimum": 1
    },
    "source_schema_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "contains": {
        "const": "schemas/ecosystem/compatibility_scorecard.schema.json"
      }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/row"
      }
    },
    "consumer_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "inspection": {
      "$ref": "#/$defs/inspection"
    },
    "summary_label": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "parity_band": {
      "type": "string",
      "enum": ["stable", "limited", "preview", "retest_pending", "unsupported"]
    },
    "bridge_parity": {
      "type": "string",
      "enum": ["exact", "partial", "approximate", "unsupported", "not_applicable"]
    },
    "freshness": {
      "type": "string",
      "enum": ["current", "aging", "stale", "expired", "missing"]
    },
    "evidence_source": {
      "type": "string",
      "enum": [
        "reference_workspace_report",
        "archetype_certification",
        "bridge_matrix",
        "conformance_suite",
        "migration_fixture"
      ]
    },
    "certification_state": {
      "type": "string",
      "enum": ["current", "expired", "missing", "not_required"]
    },
    "known_gap_state": {
      "type": "string",
      "enum": ["none", "disclosed", "unknown"]
    },
    "downgrade_rule": {
      "type": "string",
      "enum": [
        "evidence_freshness_expired",
        "evidence_missing",
        "bridge_parity_narrowed",
        "bridge_unsupported",
        "reference_workspace_certification_expired",
        "reference_workspace_certification_missing",
        "known_gap_disclosed",
        "known_gap_unknown"
      ]
    },
    "downgrade_state": {
      "type": "string",
      "enum": [
        "none",
        "freshness_expired",
        "bridge_narrowed",
        "reference_workspace_narrowed",
        "known_gap_narrowed",
        "unsupported"
      ]
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "row_id",
        "claimed_surface_class",
        "subject_class",
        "subject_ref",
        "subject_label",
        "claimed_parity_band_class",
        "effective_parity_band_class",
        "bridge_parity_class",
        "freshness_class",
        "evidence_source_class",
        "evidence_source_ref",
        "supported_deployment_profile_refs",
        "supported_runtime_profile_refs",
        "reference_workspace_ids",
        "reference_workspace_lineage_refs",
        "reference_workspace_certification_state_class",
        "known_gap_state_class",
        "known_gap_refs",
        "downgrade_rule_classes",
        "downgrade_state_class",
        "downgrade_reasons",
        "linked_bundle_refs",
        "linked_handoff_bundle_refs",
        "summary_label"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "ecosystem_compatibility_scorecard_row"
        },
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "row_id": {
          "type": "string",
          "minLength": 1
        },
        "claimed_surface_class": {
          "type": "string",
          "enum": [
            "imported_extension_claim",
            "compatibility_bridge_claim",
            "workflow_bundle_claim",
            "reference_workspace_claim"
          ]
        },
        "subject_class": {
          "type": "string",
          "enum": [
            "imported_extension",
            "bridge_class",
            "workflow_bundle",
            "reference_workspace"
          ]
        },
        "subject_ref": {
          "type": "string",
          "minLength": 1
        },
        "subject_label": {
          "type": "string",
          "minLength": 1
        },
        "claimed_parity_band_class": {
          "$ref": "#/$defs/parity_band"
        },
        "effective_parity_band_class": {
          "$ref": "#/$defs/parity_band"
        },
        "bridge_parity_class": {
          "$ref": "#/$defs/bridge_parity"
        },
        "freshness_class": {
          "$ref": "#/$defs/freshness"
        },
        "evidence_source_class": {
          "$ref": "#/$defs/evidence_source"
        },
        "evidence_source_ref": {
          "type": "string",
          "minLength": 1
        },
        "supported_deployment_profile_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "supported_runtime_profile_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reference_workspace_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reference_workspace_lineage_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reference_workspace_certification_state_class": {
          "$ref": "#/$defs/certification_state"
        },
        "known_gap_state_class": {
          "$ref": "#/$defs/known_gap_state"
        },
        "known_gap_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "downgrade_rule_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/downgrade_rule"
          }
        },
        "downgrade_state_class": {
          "$ref": "#/$defs/downgrade_state"
        },
        "downgrade_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/downgrade_rule"
          }
        },
        "replacement_guidance_ref": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "migration_guidance_ref": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "linked_bundle_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "linked_handoff_bundle_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "summary_label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "claim_id",
        "consumer_surface_class",
        "row_ref",
        "subject_class",
        "subject_ref",
        "effective_parity_band_class",
        "freshness_class",
        "evidence_source_class",
        "supported_deployment_profile_refs",
        "supported_runtime_profile_refs",
        "reference_workspace_ids",
        "reference_workspace_lineage_refs",
        "downgrade_state_class",
        "known_gap_state_class",
        "linked_bundle_refs",
        "linked_handoff_bundle_refs",
        "summary_label"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "ecosystem_compatibility_claim_projection"
        },
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "claim_id": {
          "type": "string",
          "minLength": 1
        },
        "consumer_surface_class": {
          "type": "string",
          "enum": [
            "marketplace_card",
            "migration_center_report",
            "bridge_detail_view",
            "bundle_detail_view",
            "support_export",
            "release_claim_manifest"
          ]
        },
        "row_ref": {
          "type": "string",
          "minLength": 1
        },
        "subject_class": {
          "type": "string",
          "enum": [
            "imported_extension",
            "bridge_class",
            "workflow_bundle",
            "reference_workspace"
          ]
        },
        "subject_ref": {
          "type": "string",
          "minLength": 1
        },
        "effective_parity_band_class": {
          "$ref": "#/$defs/parity_band"
        },
        "freshness_class": {
          "$ref": "#/$defs/freshness"
        },
        "evidence_source_class": {
          "$ref": "#/$defs/evidence_source"
        },
        "supported_deployment_profile_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "supported_runtime_profile_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reference_workspace_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reference_workspace_lineage_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "downgrade_state_class": {
          "$ref": "#/$defs/downgrade_state"
        },
        "known_gap_state_class": {
          "$ref": "#/$defs/known_gap_state"
        },
        "replacement_guidance_ref": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "migration_guidance_ref": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "linked_bundle_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "linked_handoff_bundle_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "summary_label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "inspection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "row_count",
        "consumer_claim_count",
        "stable_row_count",
        "narrowed_row_count",
        "retest_pending_row_count",
        "all_consumer_claims_row_backed",
        "stable_rows_reference_workspace_backed",
        "protected_surface_coverage_complete"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "ecosystem_compatibility_scorecard_inspection"
        },
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "row_count": {
          "type": "integer",
          "minimum": 0
        },
        "consumer_claim_count": {
          "type": "integer",
          "minimum": 0
        },
        "stable_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "narrowed_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "retest_pending_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "all_consumer_claims_row_backed": {
          "type": "boolean"
        },
        "stable_rows_reference_workspace_backed": {
          "type": "boolean"
        },
        "protected_surface_coverage_complete": {
          "type": "boolean"
        }
      }
    }
  }
}
