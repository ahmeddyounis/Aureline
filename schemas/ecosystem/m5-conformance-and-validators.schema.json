{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ecosystem/m5-conformance-and-validators.schema.json",
  "title": "Aureline M5 conformance scorecards, validators, and reference-workspace linkage",
  "description": "Schema for the m5_conformance_and_validators packet. The packet makes the new M5 artifact families certifiable through the same conformance, compatibility, and reference-workspace evidence model that governs stable extension claims. Each scorecard carries one conformance label from the stable native/bridge/partial/unsupported/retest_pending vocabulary, a compatibility label against the target, the owner/archetype/reference-workspace linkage a support claim rides on, and the validator diagnostics an author must clear — each with a stable code, severity, domain, message, and remediation. A scorecard's certification signals, certification disposition, and effective support class are recomputed from its facts: stale or unknown evidence, a missing owner, an unlinked archetype, an unlinked reference workspace, a missing conformance or compatibility ref, a validator failure, a retest-pending label, or an unsupported label each force an uncertified disposition whose effective support class collapses to unsupported, so a first-party or bridge-backed family cannot publish a support claim without a current, owned, evidence-linked scorecard. Marketplace badges, docs badges, release evidence, and support exports consume the same scorecard and validator vocabulary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "package_kinds",
    "runtime_origins",
    "support_classes",
    "compatibility_labels",
    "evidence_freshness_classes",
    "conformance_labels",
    "validator_severities",
    "validator_domains",
    "certification_signals",
    "certification_dispositions",
    "scorecards",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_conformance_and_validators" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "package_kinds": { "type": "array", "items": { "$ref": "#/$defs/package_kind" } },
    "runtime_origins": { "type": "array", "items": { "$ref": "#/$defs/runtime_origin" } },
    "support_classes": { "type": "array", "items": { "$ref": "#/$defs/support_class" } },
    "compatibility_labels": { "type": "array", "items": { "$ref": "#/$defs/compatibility_label" } },
    "evidence_freshness_classes": { "type": "array", "items": { "$ref": "#/$defs/evidence_freshness" } },
    "conformance_labels": { "type": "array", "items": { "$ref": "#/$defs/conformance_label" } },
    "validator_severities": { "type": "array", "items": { "$ref": "#/$defs/validator_severity" } },
    "validator_domains": { "type": "array", "items": { "$ref": "#/$defs/validator_domain" } },
    "certification_signals": { "type": "array", "items": { "$ref": "#/$defs/certification_signal" } },
    "certification_dispositions": { "type": "array", "items": { "$ref": "#/$defs/certification_disposition" } },
    "scorecards": { "type": "array", "items": { "$ref": "#/$defs/scorecard" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "package_kind": {
      "enum": [
        "first_party_framework_pack",
        "docs_pack",
        "local_model_pack",
        "signed_recipe_pack",
        "template_artifact",
        "bridge_backed_package",
        "side_loaded_package",
        "mirrored_registry_variant"
      ]
    },
    "runtime_origin": {
      "enum": [
        "first_party_signed",
        "partner_signed",
        "community_signed",
        "bridge_runtime",
        "local_model_runtime",
        "unsigned_side_loaded"
      ]
    },
    "support_class": {
      "enum": [
        "fully_supported",
        "best_effort_supported",
        "community_supported",
        "unsupported"
      ]
    },
    "compatibility_label": {
      "enum": [
        "compatible",
        "degraded_compatible",
        "compatibility_bridge_required",
        "unsupported_on_target"
      ]
    },
    "evidence_freshness": { "enum": ["current", "stale", "expired", "unknown"] },
    "conformance_label": {
      "enum": ["native", "bridge", "partial", "unsupported", "retest_pending"]
    },
    "validator_severity": { "enum": ["info", "warning", "error"] },
    "validator_domain": {
      "enum": [
        "schema",
        "capability",
        "compatibility",
        "permission",
        "provenance",
        "reference_workspace",
        "activation_budget",
        "metadata"
      ]
    },
    "certification_signal": {
      "enum": [
        "non_native_runtime",
        "validator_warning",
        "evidence_not_current",
        "owner_missing",
        "archetype_unlinked",
        "reference_workspace_unlinked",
        "conformance_evidence_missing",
        "validator_failure",
        "retest_pending",
        "unsupported"
      ]
    },
    "certification_disposition": {
      "enum": ["certified", "conditionally_certified", "uncertified"]
    },
    "validator_diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "domain", "severity", "message", "remediation", "evidence_ref"],
      "properties": {
        "code": { "$ref": "#/$defs/non_empty_string" },
        "domain": { "$ref": "#/$defs/validator_domain" },
        "severity": { "$ref": "#/$defs/validator_severity" },
        "message": { "$ref": "#/$defs/non_empty_string" },
        "remediation": { "$ref": "#/$defs/non_empty_string" },
        "evidence_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "scorecard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scorecard_id",
        "display_label",
        "governance_family_ref",
        "package_kind",
        "runtime_origin",
        "conformance_label",
        "compatibility_label",
        "claimed_support_class",
        "effective_support_class",
        "evidence_freshness",
        "certification_disposition",
        "support_export_ref",
        "summary"
      ],
      "properties": {
        "scorecard_id": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "governance_family_ref": { "$ref": "#/$defs/non_empty_string" },
        "package_kind": { "$ref": "#/$defs/package_kind" },
        "runtime_origin": { "$ref": "#/$defs/runtime_origin" },
        "conformance_label": { "$ref": "#/$defs/conformance_label" },
        "compatibility_label": { "$ref": "#/$defs/compatibility_label" },
        "claimed_support_class": { "$ref": "#/$defs/support_class" },
        "effective_support_class": { "$ref": "#/$defs/support_class" },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness" },
        "owner_ref": { "type": "string" },
        "archetype_ref": { "type": "string" },
        "reference_workspace_refs": { "type": "array", "items": { "type": "string" } },
        "conformance_ref": { "type": "string" },
        "compatibility_ref": { "type": "string" },
        "validator_diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/validator_diagnostic" }
        },
        "certification_signals": {
          "type": "array",
          "items": { "$ref": "#/$defs/certification_signal" }
        },
        "certification_disposition": { "$ref": "#/$defs/certification_disposition" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_scorecards",
        "certified_scorecards",
        "conditionally_certified_scorecards",
        "uncertified_scorecards",
        "native_scorecards",
        "bridge_scorecards",
        "partial_scorecards",
        "retest_pending_scorecards",
        "unsupported_scorecards",
        "evidence_backed_scorecards",
        "scorecards_with_validator_failures",
        "scorecards_with_validator_warnings",
        "total_validator_diagnostics",
        "distinct_package_kinds"
      ],
      "properties": {
        "total_scorecards": { "type": "integer", "minimum": 0 },
        "certified_scorecards": { "type": "integer", "minimum": 0 },
        "conditionally_certified_scorecards": { "type": "integer", "minimum": 0 },
        "uncertified_scorecards": { "type": "integer", "minimum": 0 },
        "native_scorecards": { "type": "integer", "minimum": 0 },
        "bridge_scorecards": { "type": "integer", "minimum": 0 },
        "partial_scorecards": { "type": "integer", "minimum": 0 },
        "retest_pending_scorecards": { "type": "integer", "minimum": 0 },
        "unsupported_scorecards": { "type": "integer", "minimum": 0 },
        "evidence_backed_scorecards": { "type": "integer", "minimum": 0 },
        "scorecards_with_validator_failures": { "type": "integer", "minimum": 0 },
        "scorecards_with_validator_warnings": { "type": "integer", "minimum": 0 },
        "total_validator_diagnostics": { "type": "integer", "minimum": 0 },
        "distinct_package_kinds": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
