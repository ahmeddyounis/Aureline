{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ecosystem/m5-install-review.schema.json",
  "title": "Aureline M5 install/update review sheets",
  "description": "Schema for the m5_install_review packet. The packet freezes one reviewed change model per install or update of a marketed M5 artifact family. Each review sheet compares a package's current effective revision (absent for a fresh install) with the proposed one and makes every change explicit on one surface: permission/capability deltas marked required-versus-optional and direct-versus-transitive; runtime-origin and host-class changes; publisher transfer, signing-root continuity, and namespace/orphan state; a compatibility-floor change computed from the current and proposed compatibility labels; restart/reattach and open-work implications; and a rollback plan with a checkpoint handle and current-package fallback route. Each sheet's review-trigger set and commit disposition are recomputed from its facts: widened permissions, a changed publisher, or a changed runtime origin force at least unified_review_required, and a regression to an unsupported target blocks the commit. Workspace-, profile-, and global-scope actions stay visibly distinct: every action carries the sheet's scope.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "package_kinds",
    "source_classes",
    "runtime_origins",
    "support_classes",
    "compatibility_labels",
    "rollback_postures",
    "change_kinds",
    "scopes",
    "host_classes",
    "capability_requirements",
    "capability_origins",
    "capability_changes",
    "publisher_transfer_states",
    "signing_root_continuities",
    "namespace_states",
    "restart_impacts",
    "open_work_impacts",
    "compatibility_floor_changes",
    "review_triggers",
    "commit_dispositions",
    "review_action_kinds",
    "review_sheets",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_install_review" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "package_kinds": { "type": "array", "items": { "$ref": "#/$defs/package_kind" } },
    "source_classes": { "type": "array", "items": { "$ref": "#/$defs/source_class" } },
    "runtime_origins": { "type": "array", "items": { "$ref": "#/$defs/runtime_origin" } },
    "support_classes": { "type": "array", "items": { "$ref": "#/$defs/support_class" } },
    "compatibility_labels": {
      "type": "array",
      "items": { "$ref": "#/$defs/compatibility_label" }
    },
    "rollback_postures": { "type": "array", "items": { "$ref": "#/$defs/rollback_posture" } },
    "change_kinds": { "type": "array", "items": { "$ref": "#/$defs/change_kind" } },
    "scopes": { "type": "array", "items": { "$ref": "#/$defs/scope" } },
    "host_classes": { "type": "array", "items": { "$ref": "#/$defs/host_class" } },
    "capability_requirements": {
      "type": "array",
      "items": { "$ref": "#/$defs/capability_requirement" }
    },
    "capability_origins": { "type": "array", "items": { "$ref": "#/$defs/capability_origin" } },
    "capability_changes": { "type": "array", "items": { "$ref": "#/$defs/capability_change" } },
    "publisher_transfer_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/publisher_transfer_state" }
    },
    "signing_root_continuities": {
      "type": "array",
      "items": { "$ref": "#/$defs/signing_root_continuity" }
    },
    "namespace_states": { "type": "array", "items": { "$ref": "#/$defs/namespace_state" } },
    "restart_impacts": { "type": "array", "items": { "$ref": "#/$defs/restart_impact" } },
    "open_work_impacts": { "type": "array", "items": { "$ref": "#/$defs/open_work_impact" } },
    "compatibility_floor_changes": {
      "type": "array",
      "items": { "$ref": "#/$defs/compatibility_floor_change" }
    },
    "review_triggers": { "type": "array", "items": { "$ref": "#/$defs/review_trigger" } },
    "commit_dispositions": {
      "type": "array",
      "items": { "$ref": "#/$defs/commit_disposition" }
    },
    "review_action_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/review_action_kind" }
    },
    "review_sheets": { "type": "array", "items": { "$ref": "#/$defs/review_sheet" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "package_kind": {
      "enum": [
        "first_party_framework_pack",
        "docs_pack",
        "local_model_pack",
        "signed_recipe_pack",
        "template_artifact",
        "bridge_backed_package",
        "side_loaded_package",
        "mirrored_registry_variant"
      ]
    },
    "source_class": {
      "enum": ["first_party", "verified_partner", "community", "unverified"]
    },
    "runtime_origin": {
      "enum": [
        "first_party_signed",
        "partner_signed",
        "community_signed",
        "bridge_runtime",
        "local_model_runtime",
        "unsigned_side_loaded"
      ]
    },
    "support_class": {
      "enum": ["fully_supported", "best_effort_supported", "community_supported", "unsupported"]
    },
    "compatibility_label": {
      "enum": ["compatible", "degraded_compatible", "compatibility_bridge_required", "unsupported_on_target"]
    },
    "rollback_posture": {
      "enum": [
        "reversible_verified",
        "reversible_unverified",
        "compensating_only",
        "irreversible",
        "not_applicable"
      ]
    },
    "change_kind": {
      "enum": ["install", "update", "reinstall", "downgrade"]
    },
    "scope": {
      "enum": ["workspace", "profile", "global"]
    },
    "host_class": {
      "enum": ["local", "managed_workspace", "remote_host", "container"]
    },
    "capability_requirement": {
      "enum": ["required", "optional"]
    },
    "capability_origin": {
      "enum": ["direct", "transitive"]
    },
    "capability_change": {
      "enum": ["added", "removed", "unchanged", "widened", "narrowed"]
    },
    "publisher_transfer_state": {
      "enum": [
        "same_publisher",
        "transferred_verified",
        "transferred_unverified",
        "publisher_unknown",
        "not_applicable"
      ]
    },
    "signing_root_continuity": {
      "enum": ["continuous", "rotated_disclosed", "root_changed", "unsigned", "not_applicable"]
    },
    "namespace_state": {
      "enum": ["stable", "renamed", "orphaned", "reclaimed", "not_applicable"]
    },
    "restart_impact": {
      "enum": ["no_restart", "reattach_required", "host_restart_required", "app_restart_required"]
    },
    "open_work_impact": {
      "enum": ["no_impact", "background_reindex", "open_editors_affected", "active_session_interrupted"]
    },
    "compatibility_floor_change": {
      "enum": ["unchanged", "relaxed", "regressed", "regressed_to_unsupported", "initial"]
    },
    "review_trigger": {
      "enum": [
        "permissions_widened",
        "publisher_discontinuity",
        "runtime_origin_changed",
        "host_class_changed",
        "compatibility_floor_regressed",
        "compatibility_unsupported",
        "restart_or_reattach_required",
        "open_work_impacted",
        "rollback_not_established"
      ]
    },
    "commit_disposition": {
      "enum": ["one_click_allowed", "unified_review_required", "blocked"]
    },
    "review_action_kind": {
      "enum": [
        "commit",
        "create_rollback_checkpoint",
        "fall_back_to_current",
        "disable_in_scope",
        "retry",
        "cancel"
      ]
    },
    "package_revision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "revision_ref",
        "version_label",
        "runtime_origin",
        "host_class",
        "source_class",
        "publisher_ref",
        "signing_root_ref",
        "namespace_ref",
        "compatibility_label",
        "support_class"
      ],
      "properties": {
        "revision_ref": { "$ref": "#/$defs/non_empty_string" },
        "version_label": { "$ref": "#/$defs/non_empty_string" },
        "runtime_origin": { "$ref": "#/$defs/runtime_origin" },
        "host_class": { "$ref": "#/$defs/host_class" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "publisher_ref": { "$ref": "#/$defs/non_empty_string" },
        "signing_root_ref": { "$ref": "#/$defs/non_empty_string" },
        "namespace_ref": { "$ref": "#/$defs/non_empty_string" },
        "compatibility_label": { "$ref": "#/$defs/compatibility_label" },
        "support_class": { "$ref": "#/$defs/support_class" }
      }
    },
    "capability_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability_ref", "display_label", "requirement", "origin", "change"],
      "properties": {
        "capability_ref": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "requirement": { "$ref": "#/$defs/capability_requirement" },
        "origin": { "$ref": "#/$defs/capability_origin" },
        "change": { "$ref": "#/$defs/capability_change" }
      }
    },
    "rollback_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_handle_ref",
        "rollback_posture",
        "fallback_package_ref",
        "checkpoint_created"
      ],
      "properties": {
        "checkpoint_handle_ref": { "type": "string" },
        "rollback_posture": { "$ref": "#/$defs/rollback_posture" },
        "fallback_package_ref": { "type": "string" },
        "checkpoint_created": { "type": "boolean" }
      }
    },
    "review_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_kind", "scope", "action_ref", "enabled"],
      "properties": {
        "action_kind": { "$ref": "#/$defs/review_action_kind" },
        "scope": { "$ref": "#/$defs/scope" },
        "action_ref": { "$ref": "#/$defs/non_empty_string" },
        "enabled": { "type": "boolean" }
      }
    },
    "review_sheet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sheet_id",
        "listing_ref",
        "display_label",
        "governance_family_ref",
        "package_kind",
        "change_kind",
        "scope",
        "proposed",
        "publisher_transfer",
        "signing_root_continuity",
        "namespace_state",
        "restart_impact",
        "open_work_impact",
        "compatibility_floor_change",
        "rollback",
        "commit_disposition",
        "summary"
      ],
      "properties": {
        "sheet_id": { "$ref": "#/$defs/non_empty_string" },
        "listing_ref": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "governance_family_ref": { "$ref": "#/$defs/non_empty_string" },
        "package_kind": { "$ref": "#/$defs/package_kind" },
        "change_kind": { "$ref": "#/$defs/change_kind" },
        "scope": { "$ref": "#/$defs/scope" },
        "current": { "$ref": "#/$defs/package_revision" },
        "proposed": { "$ref": "#/$defs/package_revision" },
        "capability_deltas": {
          "type": "array",
          "items": { "$ref": "#/$defs/capability_delta" }
        },
        "publisher_transfer": { "$ref": "#/$defs/publisher_transfer_state" },
        "signing_root_continuity": { "$ref": "#/$defs/signing_root_continuity" },
        "namespace_state": { "$ref": "#/$defs/namespace_state" },
        "restart_impact": { "$ref": "#/$defs/restart_impact" },
        "open_work_impact": { "$ref": "#/$defs/open_work_impact" },
        "compatibility_floor_change": { "$ref": "#/$defs/compatibility_floor_change" },
        "rollback": { "$ref": "#/$defs/rollback_plan" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/review_action" }
        },
        "review_triggers": {
          "type": "array",
          "items": { "$ref": "#/$defs/review_trigger" }
        },
        "commit_disposition": { "$ref": "#/$defs/commit_disposition" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_sheets",
        "one_click_allowed_sheets",
        "unified_review_required_sheets",
        "blocked_sheets",
        "permission_widening_sheets",
        "transitive_widening_sheets",
        "publisher_discontinuity_sheets",
        "runtime_origin_change_sheets",
        "host_class_change_sheets",
        "compatibility_regression_sheets",
        "restart_or_reattach_sheets",
        "open_work_impact_sheets",
        "rollback_unestablished_sheets",
        "workspace_scope_sheets",
        "profile_scope_sheets",
        "global_scope_sheets",
        "distinct_package_kinds"
      ],
      "properties": {
        "total_sheets": { "type": "integer", "minimum": 0 },
        "one_click_allowed_sheets": { "type": "integer", "minimum": 0 },
        "unified_review_required_sheets": { "type": "integer", "minimum": 0 },
        "blocked_sheets": { "type": "integer", "minimum": 0 },
        "permission_widening_sheets": { "type": "integer", "minimum": 0 },
        "transitive_widening_sheets": { "type": "integer", "minimum": 0 },
        "publisher_discontinuity_sheets": { "type": "integer", "minimum": 0 },
        "runtime_origin_change_sheets": { "type": "integer", "minimum": 0 },
        "host_class_change_sheets": { "type": "integer", "minimum": 0 },
        "compatibility_regression_sheets": { "type": "integer", "minimum": 0 },
        "restart_or_reattach_sheets": { "type": "integer", "minimum": 0 },
        "open_work_impact_sheets": { "type": "integer", "minimum": 0 },
        "rollback_unestablished_sheets": { "type": "integer", "minimum": 0 },
        "workspace_scope_sheets": { "type": "integer", "minimum": 0 },
        "profile_scope_sheets": { "type": "integer", "minimum": 0 },
        "global_scope_sheets": { "type": "integer", "minimum": 0 },
        "distinct_package_kinds": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
