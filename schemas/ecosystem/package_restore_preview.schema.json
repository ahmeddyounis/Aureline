{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ecosystem/package_restore_preview.schema.json",
  "title": "Aureline package restore-preview boundary",
  "description": "Boundary schema for package_restore_preview records. Restore previews preserve package identity, artifact digest, source class, host compatibility, permission digest, lock state, and revocation or yank truth before install, update, import, reuse, or restore-from-checkpoint flows run. Public registry, approved mirror, offline bundle, local archive, installed copy, and quarantined installed copy remain distinct source classes even when they resolve to identical package sets. Raw registry URLs, hostnames, absolute paths, package bodies, lockfile bodies, artifact bytes, tokens, certificate material, and signing-key material never appear in this record.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "package_restore_preview_schema_version",
    "restore_preview_id",
    "package_manager_family",
    "package_id",
    "package_version",
    "artifact_digest",
    "source_class",
    "compatible_host_range",
    "permission_digest",
    "lock_state",
    "revocation_yank_status",
    "artifact_identity",
    "source_lineage",
    "restore_action",
    "reproducibility_export_linkage",
    "generated_at",
    "redaction_class",
    "narrative_refs"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": {
      "type": "string",
      "const": "package_restore_preview"
    },
    "package_restore_preview_schema_version": {
      "$ref": "#/$defs/schema_version"
    },
    "restore_preview_id": {
      "$ref": "#/$defs/opaque_id"
    },
    "package_manager_family": {
      "$ref": "#/$defs/package_manager_family"
    },
    "package_id": {
      "$ref": "#/$defs/package_id"
    },
    "package_version": {
      "$ref": "#/$defs/non_empty_string"
    },
    "requested_requirement": {
      "$ref": "#/$defs/nullable_non_empty_string"
    },
    "artifact_digest": {
      "$ref": "#/$defs/content_address"
    },
    "source_class": {
      "$ref": "#/$defs/package_source_class"
    },
    "compatible_host_range": {
      "$ref": "#/$defs/compatible_host_range"
    },
    "permission_digest": {
      "$ref": "#/$defs/permission_digest"
    },
    "lock_state": {
      "$ref": "#/$defs/lock_state"
    },
    "revocation_yank_status": {
      "$ref": "#/$defs/revocation_yank_status"
    },
    "artifact_identity": {
      "$ref": "#/$defs/artifact_identity"
    },
    "source_lineage": {
      "$ref": "#/$defs/source_lineage"
    },
    "restore_action": {
      "$ref": "#/$defs/restore_action"
    },
    "reproducibility_export_linkage": {
      "$ref": "#/$defs/reproducibility_export_linkage"
    },
    "generated_at": {
      "$ref": "#/$defs/monotonic_timestamp"
    },
    "redaction_class": {
      "$ref": "#/$defs/redaction_class"
    },
    "narrative_refs": {
      "$ref": "#/$defs/ref_array"
    },
    "notes": {
      "$ref": "#/$defs/nullable_reviewable_sentence"
    }
  },
  "allOf": [
    {
      "description": "Approved mirror restores must link the mirror-promotion row that proves whether the mirror preserved artifact identity.",
      "if": {
        "properties": {
          "source_class": {
            "const": "approved_mirror"
          }
        },
        "required": [
          "source_class"
        ]
      },
      "then": {
        "properties": {
          "source_lineage": {
            "properties": {
              "source_refs": {
                "properties": {
                  "mirror_promotion_row_ref": {
                    "not": {
                      "type": "null"
                    }
                  }
                },
                "required": [
                  "mirror_promotion_row_ref"
                ]
              }
            },
            "required": [
              "source_refs"
            ]
          }
        }
      }
    },
    {
      "description": "Offline-bundle restores must link the offline continuity card that explains bundle freshness and included trust metadata.",
      "if": {
        "properties": {
          "source_class": {
            "const": "offline_bundle"
          }
        },
        "required": [
          "source_class"
        ]
      },
      "then": {
        "properties": {
          "source_lineage": {
            "properties": {
              "source_refs": {
                "properties": {
                  "offline_continuity_card_ref": {
                    "not": {
                      "type": "null"
                    }
                  }
                },
                "required": [
                  "offline_continuity_card_ref"
                ]
              }
            },
            "required": [
              "source_refs"
            ]
          }
        }
      }
    },
    {
      "description": "Local-archive restores must preserve the import row instead of appearing as a public registry restore.",
      "if": {
        "properties": {
          "source_class": {
            "const": "local_archive"
          }
        },
        "required": [
          "source_class"
        ]
      },
      "then": {
        "properties": {
          "source_lineage": {
            "properties": {
              "source_refs": {
                "properties": {
                  "local_archive_import_ref": {
                    "not": {
                      "type": "null"
                    }
                  }
                },
                "required": [
                  "local_archive_import_ref"
                ]
              }
            },
            "required": [
              "source_refs"
            ]
          }
        }
      }
    },
    {
      "description": "Quarantined installed copies are provenance records only; restore must block and cite the installed-copy ref.",
      "if": {
        "properties": {
          "source_class": {
            "const": "quarantined_installed_copy"
          }
        },
        "required": [
          "source_class"
        ]
      },
      "then": {
        "properties": {
          "source_lineage": {
            "properties": {
              "source_refs": {
                "properties": {
                  "installed_copy_ref": {
                    "not": {
                      "type": "null"
                    }
                  }
                },
                "required": [
                  "installed_copy_ref"
                ]
              }
            },
            "required": [
              "source_refs"
            ]
          },
          "restore_action": {
            "properties": {
              "preview_outcome_class": {
                "const": "blocked_revoked_or_quarantined"
              }
            },
            "required": [
              "preview_outcome_class"
            ]
          }
        }
      }
    },
    {
      "description": "Repackaged or unknown identity cannot proceed as an unchanged package restore.",
      "if": {
        "properties": {
          "artifact_identity": {
            "properties": {
              "identity_class": {
                "enum": [
                  "repackaged_identity_blocked",
                  "identity_unknown_blocked"
                ]
              }
            },
            "required": [
              "identity_class"
            ]
          }
        },
        "required": [
          "artifact_identity"
        ]
      },
      "then": {
        "properties": {
          "restore_action": {
            "properties": {
              "preview_outcome_class": {
                "enum": [
                  "blocked_identity_changed",
                  "blocked_freshness_unknown"
                ]
              }
            },
            "required": [
              "preview_outcome_class"
            ]
          }
        }
      }
    },
    {
      "description": "Revoked, publisher-quarantined, or artifact-quarantined rows must block restore.",
      "if": {
        "properties": {
          "revocation_yank_status": {
            "properties": {
              "status_class": {
                "enum": [
                  "revoked",
                  "publisher_quarantined",
                  "artifact_quarantined"
                ]
              }
            },
            "required": [
              "status_class"
            ]
          }
        },
        "required": [
          "revocation_yank_status"
        ]
      },
      "then": {
        "properties": {
          "restore_action": {
            "properties": {
              "preview_outcome_class": {
                "const": "blocked_revoked_or_quarantined"
              }
            },
            "required": [
              "preview_outcome_class"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_non_empty_string": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/non_empty_string"
        }
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$",
      "description": "Opaque stable id safe for logs, support exports, admin exports, and review packets."
    },
    "nullable_opaque_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/opaque_id"
        }
      ]
    },
    "ref_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "opaque_ref_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/opaque_id"
      },
      "uniqueItems": true
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Review-safe sentence. Raw URLs, hostnames, paths, package bodies, lockfile bodies, and secrets are forbidden."
    },
    "nullable_reviewable_sentence": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/reviewable_sentence"
        }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "digest_algorithm": {
      "type": "string",
      "enum": [
        "sha256",
        "sha384",
        "sha512",
        "blake3"
      ]
    },
    "content_address": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "digest_algorithm",
        "digest_hex"
      ],
      "properties": {
        "digest_algorithm": {
          "$ref": "#/$defs/digest_algorithm"
        },
        "digest_hex": {
          "type": "string",
          "pattern": "^[0-9a-f]+$",
          "minLength": 32
        },
        "digest_size_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "package_manager_family": {
      "type": "string",
      "enum": [
        "cargo",
        "npm",
        "pnpm",
        "yarn",
        "bun",
        "pip",
        "uv",
        "poetry",
        "go_modules",
        "maven",
        "gradle",
        "bundler",
        "nuget",
        "system_package_manager",
        "mixed_workspace",
        "package_manager_unknown_requires_review"
      ]
    },
    "package_source_class": {
      "type": "string",
      "enum": [
        "public_registry",
        "approved_mirror",
        "private_registry",
        "offline_bundle",
        "local_archive",
        "installed_copy",
        "quarantined_installed_copy"
      ],
      "description": "Restore-source class. This normalized vocabulary preserves source truth across package managers and cross-walks to package-action registry source classes."
    },
    "package_id": {
      "type": "string",
      "minLength": 1,
      "description": "Package coordinate or ecosystem-qualified id. Raw registry URL, absolute path, or host name is forbidden."
    },
    "host_range_class": {
      "type": "string",
      "enum": [
        "any_supported_host",
        "declared_host_range",
        "narrowed_by_policy",
        "incompatible_blocked",
        "unknown_requires_probe"
      ]
    },
    "compatible_host_range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "host_range_class",
        "host_family_refs",
        "platform_range_refs",
        "host_version_requirement",
        "compatibility_evidence_ref"
      ],
      "properties": {
        "host_range_class": {
          "$ref": "#/$defs/host_range_class"
        },
        "host_family_refs": {
          "$ref": "#/$defs/opaque_ref_array"
        },
        "platform_range_refs": {
          "$ref": "#/$defs/opaque_ref_array"
        },
        "host_version_requirement": {
          "$ref": "#/$defs/non_empty_string"
        },
        "compatibility_evidence_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        }
      }
    },
    "permission_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "digest_algorithm",
        "digest_hex",
        "permission_model_ref",
        "effective_permission_summary_ref"
      ],
      "properties": {
        "digest_algorithm": {
          "$ref": "#/$defs/digest_algorithm"
        },
        "digest_hex": {
          "type": "string",
          "pattern": "^[0-9a-f]+$",
          "minLength": 32
        },
        "permission_model_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        },
        "effective_permission_summary_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        }
      },
      "description": "Digest of the declared permission set or an explicit empty-set digest for package families without package permissions."
    },
    "lock_state_class": {
      "type": "string",
      "enum": [
        "not_locked_first_resolve",
        "locked_exact_artifact",
        "locked_version_digest_drift",
        "locked_source_class_drift",
        "locked_blocked_by_policy",
        "installed_without_lock_entry"
      ]
    },
    "lock_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lock_state_class",
        "lockfile_ref",
        "lockfile_entry_ref",
        "lockfile_digest",
        "resolver_identity_ref"
      ],
      "properties": {
        "lock_state_class": {
          "$ref": "#/$defs/lock_state_class"
        },
        "lockfile_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        },
        "lockfile_entry_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        },
        "lockfile_digest": {
          "$ref": "#/$defs/content_address"
        },
        "resolver_identity_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        },
        "source_class_locked_in_file": {
          "$ref": "#/$defs/package_source_class"
        }
      }
    },
    "revocation_yank_status_class": {
      "type": "string",
      "enum": [
        "active_not_yanked",
        "yanked_not_revoked",
        "revoked",
        "publisher_quarantined",
        "artifact_quarantined",
        "unknown_requires_refresh"
      ]
    },
    "status_source_class": {
      "type": "string",
      "enum": [
        "live_registry",
        "approved_mirror_snapshot",
        "offline_bundle_snapshot",
        "local_archive_attestation",
        "installed_copy_audit",
        "unknown"
      ]
    },
    "revocation_yank_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status_class",
        "status_source_class",
        "checked_at",
        "evidence_ref"
      ],
      "properties": {
        "status_class": {
          "$ref": "#/$defs/revocation_yank_status_class"
        },
        "status_source_class": {
          "$ref": "#/$defs/status_source_class"
        },
        "checked_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        },
        "evidence_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        },
        "repair_affordance_label": {
          "$ref": "#/$defs/nullable_reviewable_sentence"
        }
      }
    },
    "artifact_identity_class": {
      "type": "string",
      "enum": [
        "origin_artifact",
        "mirrored_same_artifact",
        "offline_bundle_same_artifact",
        "local_archive_attested_artifact",
        "installed_copy_reuse",
        "repackaged_identity_blocked",
        "identity_unknown_blocked"
      ]
    },
    "artifact_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity_class",
        "expected_origin_digest",
        "same_artifact_as_origin",
        "artifact_identity_evidence_ref"
      ],
      "properties": {
        "identity_class": {
          "$ref": "#/$defs/artifact_identity_class"
        },
        "expected_origin_digest": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/content_address"
            }
          ]
        },
        "same_artifact_as_origin": {
          "type": "boolean"
        },
        "artifact_identity_evidence_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        }
      }
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_source_record_ref",
        "mirror_promotion_row_ref",
        "offline_continuity_card_ref",
        "local_archive_import_ref",
        "installed_copy_ref",
        "support_bundle_ref"
      ],
      "properties": {
        "registry_source_record_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        },
        "mirror_promotion_row_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        },
        "offline_continuity_card_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        },
        "local_archive_import_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        },
        "installed_copy_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        },
        "support_bundle_ref": {
          "$ref": "#/$defs/nullable_opaque_id"
        }
      }
    },
    "source_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "original_source_class",
        "current_source_class",
        "source_class_preserved",
        "source_refs"
      ],
      "properties": {
        "original_source_class": {
          "$ref": "#/$defs/package_source_class"
        },
        "current_source_class": {
          "$ref": "#/$defs/package_source_class"
        },
        "source_class_preserved": {
          "type": "boolean",
          "const": true
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        }
      }
    },
    "restore_outcome_class": {
      "type": "string",
      "enum": [
        "install_allowed",
        "reuse_allowed",
        "prompt_user_trust_decision",
        "prompt_admin_policy_exception",
        "blocked_revoked_or_quarantined",
        "blocked_yanked_by_policy",
        "blocked_identity_changed",
        "blocked_lock_source_drift",
        "blocked_freshness_unknown"
      ]
    },
    "restore_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_outcome_class",
        "prompt_refs",
        "block_reason_refs",
        "repair_affordance_label"
      ],
      "properties": {
        "preview_outcome_class": {
          "$ref": "#/$defs/restore_outcome_class"
        },
        "prompt_refs": {
          "$ref": "#/$defs/opaque_ref_array"
        },
        "block_reason_refs": {
          "$ref": "#/$defs/opaque_ref_array"
        },
        "repair_affordance_label": {
          "$ref": "#/$defs/nullable_reviewable_sentence"
        }
      }
    },
    "export_scope_class": {
      "type": "string",
      "enum": [
        "support_export",
        "admin_export",
        "reproducibility_capsule",
        "offboarding_package",
        "local_review_only"
      ]
    },
    "reproducibility_export_linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_set_ref",
        "deterministic_package_set_digest",
        "source_class_truth_preserved",
        "export_scope",
        "support_export_refs",
        "admin_export_refs"
      ],
      "properties": {
        "package_set_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "deterministic_package_set_digest": {
          "$ref": "#/$defs/content_address"
        },
        "source_class_truth_preserved": {
          "type": "boolean",
          "const": true
        },
        "export_scope": {
          "$ref": "#/$defs/export_scope_class"
        },
        "support_export_refs": {
          "$ref": "#/$defs/opaque_ref_array"
        },
        "admin_export_refs": {
          "$ref": "#/$defs/opaque_ref_array"
        }
      }
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    }
  }
}
