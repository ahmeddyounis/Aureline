{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ecosystem/m5-ecosystem-install-governance-matrix.schema.json",
  "title": "Aureline M5 ecosystem install-governance matrix",
  "description": "Schema for the m5_ecosystem_install_governance_matrix packet. The packet freezes one governance row per marketed M5 artifact family (first-party framework pack, docs pack, local-model pack, signed recipe pack, template artifact, bridge-backed package, side-loaded package, mirrored/private-registry variant). Each row names its runtime origin, declared support class, compatibility label, permission-manifest state, activation-budget band, lifecycle state, evidence freshness, and rollback posture. A non-inheriting promotion gate derives the support class that may be published: a family with unverified provenance, stale evidence, an unreviewed permission expansion, an exceeded activation budget, an unsupported target, an incomplete rollback, or an active quarantine cannot publish full support, and its promotion decision records whether the gate promoted, narrowed to best-effort or community support, or failed promotion. One row is required per claimed family so a signed first-party pack never lends trust to a side-loaded package or mirrored variant, and the recorded published support class, decision, and narrowing reasons must equal the recomputed gate decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "artifact_families",
    "support_classes",
    "runtime_origins",
    "compatibility_labels",
    "permission_manifest_states",
    "activation_budget_bands",
    "lifecycle_states",
    "evidence_freshness_classes",
    "rollback_postures",
    "narrowing_reasons",
    "promotion_decisions",
    "families",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_ecosystem_install_governance_matrix" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "artifact_families": { "type": "array", "items": { "$ref": "#/$defs/artifact_family" } },
    "support_classes": { "type": "array", "items": { "$ref": "#/$defs/support_class" } },
    "runtime_origins": { "type": "array", "items": { "$ref": "#/$defs/runtime_origin" } },
    "compatibility_labels": {
      "type": "array",
      "items": { "$ref": "#/$defs/compatibility_label" }
    },
    "permission_manifest_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/permission_manifest_state" }
    },
    "activation_budget_bands": {
      "type": "array",
      "items": { "$ref": "#/$defs/activation_budget_band" }
    },
    "lifecycle_states": { "type": "array", "items": { "$ref": "#/$defs/lifecycle_state" } },
    "evidence_freshness_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_freshness" }
    },
    "rollback_postures": { "type": "array", "items": { "$ref": "#/$defs/rollback_posture" } },
    "narrowing_reasons": { "type": "array", "items": { "$ref": "#/$defs/narrowing_reason" } },
    "promotion_decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/promotion_decision" }
    },
    "families": { "type": "array", "items": { "$ref": "#/$defs/family" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "artifact_family": {
      "enum": [
        "first_party_framework_pack",
        "docs_pack",
        "local_model_pack",
        "signed_recipe_pack",
        "template_artifact",
        "bridge_backed_package",
        "side_loaded_package",
        "mirrored_registry_variant"
      ]
    },
    "support_class": {
      "enum": ["fully_supported", "best_effort_supported", "community_supported", "unsupported"]
    },
    "runtime_origin": {
      "enum": [
        "first_party_signed",
        "partner_signed",
        "community_signed",
        "bridge_runtime",
        "local_model_runtime",
        "unsigned_side_loaded"
      ]
    },
    "compatibility_label": {
      "enum": [
        "compatible",
        "degraded_compatible",
        "compatibility_bridge_required",
        "unsupported_on_target"
      ]
    },
    "permission_manifest_state": {
      "enum": ["unchanged", "reduced", "additive_disclosed", "expanded_unreviewed", "not_applicable"]
    },
    "activation_budget_band": {
      "enum": [
        "healthy_under_budget",
        "approaching_ceiling",
        "over_budget",
        "budget_unknown",
        "not_applicable"
      ]
    },
    "lifecycle_state": {
      "enum": [
        "available",
        "installed",
        "update_available",
        "disabled",
        "quarantined",
        "rolled_back",
        "retired"
      ]
    },
    "evidence_freshness": {
      "enum": ["current", "stale", "expired", "unknown"]
    },
    "rollback_posture": {
      "enum": [
        "reversible_verified",
        "reversible_unverified",
        "compensating_only",
        "irreversible",
        "not_applicable"
      ]
    },
    "narrowing_reason": {
      "enum": [
        "provenance_unverified",
        "evidence_stale",
        "permission_expansion_unreviewed",
        "activation_budget_exceeded",
        "compatibility_unsupported",
        "rollback_incomplete",
        "quarantined"
      ]
    },
    "promotion_decision": {
      "enum": ["promote", "narrow_to_best_effort", "narrow_to_community", "fail_promotion"]
    },
    "family": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_id",
        "artifact_family",
        "runtime_origin",
        "declared_support_class",
        "published_support_class",
        "compatibility_label",
        "permission_manifest_state",
        "activation_budget_band",
        "lifecycle_state",
        "evidence_freshness",
        "rollback_posture",
        "promotion_decision",
        "provenance_ref",
        "permission_manifest_ref",
        "activation_budget_ref",
        "compatibility_ref",
        "rollback_ref",
        "support_export_ref",
        "note"
      ],
      "properties": {
        "family_id": { "$ref": "#/$defs/non_empty_string" },
        "artifact_family": { "$ref": "#/$defs/artifact_family" },
        "runtime_origin": { "$ref": "#/$defs/runtime_origin" },
        "declared_support_class": { "$ref": "#/$defs/support_class" },
        "published_support_class": { "$ref": "#/$defs/support_class" },
        "compatibility_label": { "$ref": "#/$defs/compatibility_label" },
        "permission_manifest_state": { "$ref": "#/$defs/permission_manifest_state" },
        "activation_budget_band": { "$ref": "#/$defs/activation_budget_band" },
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness" },
        "rollback_posture": { "$ref": "#/$defs/rollback_posture" },
        "promotion_decision": { "$ref": "#/$defs/promotion_decision" },
        "narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        },
        "provenance_ref": { "$ref": "#/$defs/non_empty_string" },
        "permission_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "activation_budget_ref": { "$ref": "#/$defs/non_empty_string" },
        "compatibility_ref": { "$ref": "#/$defs/non_empty_string" },
        "rollback_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_families",
        "family_count",
        "fully_supported_families",
        "best_effort_families",
        "community_supported_families",
        "unsupported_families",
        "promotable_families",
        "narrowed_families",
        "failed_promotion_families",
        "current_freshness_families",
        "over_budget_families",
        "provenance_unverified_families",
        "quarantined_families",
        "families_with_narrowing_reasons"
      ],
      "properties": {
        "total_families": { "type": "integer", "minimum": 0 },
        "family_count": { "type": "integer", "minimum": 0 },
        "fully_supported_families": { "type": "integer", "minimum": 0 },
        "best_effort_families": { "type": "integer", "minimum": 0 },
        "community_supported_families": { "type": "integer", "minimum": 0 },
        "unsupported_families": { "type": "integer", "minimum": 0 },
        "promotable_families": { "type": "integer", "minimum": 0 },
        "narrowed_families": { "type": "integer", "minimum": 0 },
        "failed_promotion_families": { "type": "integer", "minimum": 0 },
        "current_freshness_families": { "type": "integer", "minimum": 0 },
        "over_budget_families": { "type": "integer", "minimum": 0 },
        "provenance_unverified_families": { "type": "integer", "minimum": 0 },
        "quarantined_families": { "type": "integer", "minimum": 0 },
        "families_with_narrowing_reasons": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
