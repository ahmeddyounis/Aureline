{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aureline.dev/routes/exposure_matrix.schema.json",
  "title": "Aureline route exposure matrix",
  "description": "Boundary schema for the beta route/exposure matrix. The matrix is the shared origin, target, route, exposure, approval-reuse, reapproval-trigger, privacy-consequence, and browser/system handoff vocabulary consumed by Help/About, service health, diagnostics, release evidence, and support-safe exports. Raw URLs, raw provider payloads, raw tokens, raw callback bodies, raw absolute paths, and raw user identifiers never appear; rows carry opaque refs and export-safe labels only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "matrix_id",
    "status",
    "as_of",
    "owner_dri",
    "schema_ref",
    "source_refs",
    "vocabularies",
    "rows",
    "validation_contract"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "route_exposure_matrix"
    },
    "matrix_id": {
      "type": "string",
      "pattern": "^route_exposure\\.matrix\\.[a-z0-9_.:-]+$"
    },
    "status": {
      "type": "string",
      "enum": ["seeded", "draft", "ratified"]
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "owner_dri": {
      "$ref": "#/$defs/non_empty_string"
    },
    "schema_ref": {
      "type": "string",
      "const": "schemas/routes/exposure_matrix.schema.json"
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "vocabularies": {
      "$ref": "#/$defs/vocabularies"
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/route_exposure_row"
      },
      "uniqueItems": true
    },
    "validation_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_origin_classes",
        "required_consumer_surfaces",
        "claimed_handoff_register_ref",
        "provider_route_support_export_ref",
        "release_matrix_ref",
        "support_audit_ref",
        "ux_doc_ref"
      ],
      "properties": {
        "required_origin_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/origin_class"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "required_consumer_surfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/consumer_surface_class"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "claimed_handoff_register_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "provider_route_support_export_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "release_matrix_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "support_audit_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "ux_doc_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "origin_class": {
      "type": "string",
      "enum": [
        "local_desktop",
        "remote_helper",
        "managed_workspace",
        "browser_companion",
        "provider_linked_context",
        "embedded_docs_help_webview",
        "headless_cli"
      ]
    },
    "action_origin_class": {
      "type": "string",
      "enum": [
        "user_keystroke_local",
        "user_voice_or_gesture_local",
        "cli_invocation_local",
        "ai_tool_call_local",
        "ai_tool_call_managed",
        "recipe_or_automation_local",
        "extension_host_local",
        "remote_agent_request",
        "managed_control_plane_request",
        "provider_callback_inbound",
        "webhook_inbound",
        "scheduled_trigger",
        "supervisor_repair_origin",
        "import_or_restore_session",
        "unknown_origin_class"
      ]
    },
    "target_class": {
      "type": "string",
      "enum": [
        "local_host_target",
        "user_mode_sandbox_target",
        "container_local_target",
        "devcontainer_target",
        "remote_ssh_target",
        "remote_agent_target",
        "managed_workspace_target",
        "notebook_kernel_local_target",
        "notebook_kernel_remote_target",
        "ai_sandbox_target",
        "connected_provider_target",
        "embedded_webview_target",
        "system_browser_target",
        "native_os_callback_target",
        "publish_release_target",
        "tunnel_exposed_target",
        "bridged_helper_target",
        "unknown_target_class"
      ]
    },
    "action_route_class": {
      "type": "string",
      "enum": [
        "in_process_route",
        "local_rpc_route",
        "remote_rpc_route",
        "managed_control_plane_route",
        "remote_agent_attach_route",
        "approval_gated_route",
        "browser_handoff_route",
        "embedded_webview_route",
        "native_callback_route",
        "provider_webhook_return_route",
        "publish_pipeline_route",
        "tunnel_exposed_route",
        "mirror_or_private_registry_route",
        "bridged_helper_route",
        "heuristic_unknown_route"
      ]
    },
    "action_exposure_class": {
      "type": "string",
      "enum": [
        "no_side_effect_local_read",
        "local_only_mutation",
        "workspace_visible_mutation",
        "provider_visible_mutation",
        "publicly_visible_publish",
        "cross_tenant_visible",
        "third_party_callback_visible",
        "browser_session_visible",
        "tunnel_exposed_public",
        "exposure_unknown_requires_review"
      ]
    },
    "route_change_reason_code": {
      "type": "string",
      "enum": [
        "canonical_no_route_change",
        "route_escalated_to_approval_required",
        "route_escalated_to_browser_handoff",
        "route_escalated_to_publish_pipeline",
        "route_escalated_to_tunnel_exposure",
        "route_changed_target_unreachable",
        "route_changed_target_reassigned",
        "route_changed_policy_narrowed",
        "route_changed_authority_escalation",
        "route_changed_wrong_target_detected",
        "route_changed_approval_withdrawn",
        "route_changed_freshness_floor_unmet",
        "route_changed_host_mismatch",
        "route_unknown_requires_review"
      ]
    },
    "approval_reuse_class": {
      "type": "string",
      "enum": [
        "not_required_read_only",
        "reuse_same_target_policy_privacy",
        "reuse_until_expiry_same_host",
        "force_reapproval_on_boundary_change",
        "force_reapproval_every_launch",
        "not_reusable_provider_side_effect"
      ]
    },
    "reapproval_trigger_class": {
      "type": "string",
      "enum": [
        "target_identity_changed",
        "trust_posture_changed",
        "policy_epoch_changed",
        "host_or_domain_changed",
        "privacy_consequence_changed",
        "provider_scope_changed",
        "approval_expired",
        "freshness_floor_unmet",
        "route_exposure_widened"
      ]
    },
    "privacy_consequence_class": {
      "type": "string",
      "enum": [
        "no_new_data_exposure",
        "workspace_metadata_visible",
        "provider_object_visible",
        "browser_session_visible",
        "public_or_share_link_visible",
        "support_metadata_only",
        "third_party_callback_visible"
      ]
    },
    "browser_handoff_class": {
      "type": "string",
      "enum": [
        "no_browser_handoff",
        "system_browser_required",
        "system_browser_fallback_available",
        "embedded_webview_boundary",
        "browser_companion_to_desktop",
        "provider_callback_return",
        "blocked_by_policy"
      ]
    },
    "consumer_surface_class": {
      "type": "string",
      "enum": [
        "help_about",
        "service_health",
        "diagnostics",
        "support_export",
        "docs_help",
        "release_packet",
        "ux_docs"
      ]
    },
    "vocabularies": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin_class",
        "action_origin_class",
        "target_class",
        "action_route_class",
        "action_exposure_class",
        "route_change_reason_code",
        "approval_reuse_class",
        "reapproval_trigger_class",
        "privacy_consequence_class",
        "browser_handoff_class",
        "consumer_surface_class"
      ],
      "properties": {
        "origin_class": {
          "$ref": "#/$defs/token_list"
        },
        "action_origin_class": {
          "$ref": "#/$defs/token_list"
        },
        "target_class": {
          "$ref": "#/$defs/token_list"
        },
        "action_route_class": {
          "$ref": "#/$defs/token_list"
        },
        "action_exposure_class": {
          "$ref": "#/$defs/token_list"
        },
        "route_change_reason_code": {
          "$ref": "#/$defs/token_list"
        },
        "approval_reuse_class": {
          "$ref": "#/$defs/token_list"
        },
        "reapproval_trigger_class": {
          "$ref": "#/$defs/token_list"
        },
        "privacy_consequence_class": {
          "$ref": "#/$defs/token_list"
        },
        "browser_handoff_class": {
          "$ref": "#/$defs/token_list"
        },
        "consumer_surface_class": {
          "$ref": "#/$defs/token_list"
        }
      }
    },
    "token_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "uniqueItems": true
    },
    "route_exposure_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "title",
        "claimed_beta_surface_refs",
        "route_refs",
        "source_artifact_refs",
        "origin",
        "target",
        "route",
        "exposure",
        "approval",
        "handoff",
        "support_export",
        "promotion_guard"
      ],
      "properties": {
        "row_id": {
          "type": "string",
          "pattern": "^route-exposure:[a-z0-9_.:-]+$"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "claimed_beta_surface_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        },
        "route_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        },
        "provider_route_resolution_row_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        },
        "source_artifact_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        },
        "origin": {
          "type": "object",
          "additionalProperties": false,
          "required": ["origin_class", "action_origin_class", "traffic_origin_label"],
          "properties": {
            "origin_class": {
              "$ref": "#/$defs/origin_class"
            },
            "action_origin_class": {
              "$ref": "#/$defs/action_origin_class"
            },
            "traffic_origin_label": {
              "$ref": "#/$defs/non_empty_string"
            }
          }
        },
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "target_class",
            "target_identity_ref",
            "workspace_identity_ref",
            "environment_identity_ref"
          ],
          "properties": {
            "target_class": {
              "$ref": "#/$defs/target_class"
            },
            "target_identity_ref": {
              "$ref": "#/$defs/non_empty_string"
            },
            "workspace_identity_ref": {
              "$ref": "#/$defs/non_empty_string"
            },
            "environment_identity_ref": {
              "$ref": "#/$defs/non_empty_string"
            }
          }
        },
        "route": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action_route_class",
            "route_choice",
            "route_change_reason_code",
            "authority_source_ref"
          ],
          "properties": {
            "action_route_class": {
              "$ref": "#/$defs/action_route_class"
            },
            "route_choice": {
              "$ref": "#/$defs/non_empty_string"
            },
            "route_change_reason_code": {
              "$ref": "#/$defs/route_change_reason_code"
            },
            "authority_source_ref": {
              "$ref": "#/$defs/non_empty_string"
            }
          }
        },
        "exposure": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action_exposure_class",
            "exposure_label",
            "privacy_consequence_class",
            "privacy_consequence_summary"
          ],
          "properties": {
            "action_exposure_class": {
              "$ref": "#/$defs/action_exposure_class"
            },
            "exposure_label": {
              "$ref": "#/$defs/non_empty_string"
            },
            "privacy_consequence_class": {
              "$ref": "#/$defs/privacy_consequence_class"
            },
            "privacy_consequence_summary": {
              "$ref": "#/$defs/non_empty_string"
            }
          }
        },
        "approval": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "approval_reuse_class",
            "approval_reuse_allowed",
            "reapproval_trigger_classes",
            "reapproval_summary"
          ],
          "properties": {
            "approval_reuse_class": {
              "$ref": "#/$defs/approval_reuse_class"
            },
            "approval_reuse_allowed": {
              "type": "boolean"
            },
            "reapproval_trigger_classes": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/reapproval_trigger_class"
              },
              "uniqueItems": true
            },
            "approval_ticket_ref": {
              "$ref": "#/$defs/non_empty_string"
            },
            "reapproval_summary": {
              "$ref": "#/$defs/non_empty_string"
            }
          }
        },
        "handoff": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "browser_handoff_class",
            "system_browser_required",
            "destination_class",
            "handoff_summary"
          ],
          "properties": {
            "browser_handoff_class": {
              "$ref": "#/$defs/browser_handoff_class"
            },
            "browser_handoff_packet_ref": {
              "$ref": "#/$defs/non_empty_string"
            },
            "system_browser_required": {
              "type": "boolean"
            },
            "destination_class": {
              "$ref": "#/$defs/non_empty_string"
            },
            "return_anchor_ref": {
              "$ref": "#/$defs/non_empty_string"
            },
            "handoff_summary": {
              "$ref": "#/$defs/non_empty_string"
            }
          }
        },
        "support_export": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "support_item_id",
            "projection_ref",
            "consumer_surfaces",
            "parity_required",
            "raw_url_export_allowed",
            "raw_token_export_allowed",
            "raw_provider_payload_export_allowed"
          ],
          "properties": {
            "support_item_id": {
              "$ref": "#/$defs/non_empty_string"
            },
            "projection_ref": {
              "$ref": "#/$defs/non_empty_string"
            },
            "consumer_surfaces": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/consumer_surface_class"
              },
              "minItems": 1,
              "uniqueItems": true
            },
            "parity_required": {
              "type": "boolean"
            },
            "raw_url_export_allowed": {
              "type": "boolean",
              "const": false
            },
            "raw_token_export_allowed": {
              "type": "boolean",
              "const": false
            },
            "raw_provider_payload_export_allowed": {
              "type": "boolean",
              "const": false
            }
          }
        },
        "promotion_guard": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "high_risk",
            "uncategorized_high_risk_gap",
            "beta_promotion_blocking_when_unknown",
            "drift_check_subject_refs"
          ],
          "properties": {
            "high_risk": {
              "type": "boolean"
            },
            "uncategorized_high_risk_gap": {
              "type": "boolean",
              "const": false
            },
            "beta_promotion_blocking_when_unknown": {
              "type": "boolean"
            },
            "drift_check_subject_refs": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/non_empty_string"
              },
              "uniqueItems": true
            }
          }
        }
      }
    }
  }
}
