{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/companion/companion-notification-triage-review-queues-and-ci-status-cards-with-desktop-handoff.schema.json",
  "title": "Aureline companion notification triage, review queues, and CI-status cards with exact desktop handoff",
  "description": "Export-safe packet for the read-only browser/mobile companion triage surface. It projects three sections — notification triage, review queues, and CI-status cards — each inheriting qualification from a frozen M5 companion-matrix lane, and gives every item an exact desktop handoff. The companion never authors edits: notifications are read-only and review-queue authority is approve/defer or escalate-only. Degraded state (relay unavailable, stale proof, inactive host, narrowed trust, narrowed upstream lane, unresolved handoff) is labeled rather than hidden. Credential bodies, raw provider payloads, and raw event bodies never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "surface_label",
    "projected_surfaces",
    "section_qualifications",
    "notification_triage",
    "review_queue",
    "ci_status_cards",
    "handoff_contract",
    "locality_disclosure",
    "security_review",
    "consumer_projection",
    "proof_freshness",
    "degraded_labels",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "companion_notification_triage_review_queues_and_ci_status_cards_with_desktop_handoff"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "surface_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "projected_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/consumer_surface"
      }
    },
    "section_qualifications": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/section_qualification"
      }
    },
    "notification_triage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/notification_item"
      }
    },
    "review_queue": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/review_item"
      }
    },
    "ci_status_cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ci_status_card"
      }
    },
    "handoff_contract": {
      "$ref": "#/$defs/handoff_contract"
    },
    "locality_disclosure": {
      "$ref": "#/$defs/locality_disclosure"
    },
    "security_review": {
      "$ref": "#/$defs/security_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "degraded_labels": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/degraded_reason"
      }
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "section": {
      "type": "string",
      "enum": [
        "notification_triage",
        "review_queue",
        "ci_status_cards"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "rollout_stage": {
      "type": "string",
      "enum": [
        "internal_only",
        "early_access",
        "staged_rollout",
        "general_availability",
        "withheld"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "evidence_packet_invalid",
        "policy_blocked",
        "provider_unavailable",
        "admin_continuity_required",
        "residency_or_encryption_unverified",
        "incident_attribution_missing",
        "sync_inspection_unavailable",
        "companion_scope_expansion_unqualified",
        "offboarding_strands_local_work",
        "trust_narrowing",
        "upstream_dependency_narrowed"
      ]
    },
    "rollback_posture": {
      "type": "string",
      "enum": [
        "local_core_continues_no_remote_state",
        "companion_read_only_narrow_scope",
        "staged_reversible_via_rollout",
        "sync_reconciles_to_local_core",
        "offboarding_export_preserves_local_work",
        "evidence_preserved_no_revert",
        "not_applicable"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "desktop_companion_panel",
        "browser_companion",
        "mobile_companion",
        "incident_workspace",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "notification_category": {
      "type": "string",
      "enum": [
        "build",
        "review",
        "agent",
        "incident",
        "sync"
      ]
    },
    "triage_priority": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "normal",
        "low"
      ]
    },
    "triage_state": {
      "type": "string",
      "enum": [
        "unread",
        "triaged",
        "snoozed",
        "dismissed",
        "escalated_to_desktop"
      ]
    },
    "review_kind": {
      "type": "string",
      "enum": [
        "agent_change",
        "diff_review",
        "comment_thread",
        "approval_request"
      ]
    },
    "review_queue_state": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "deferred",
        "escalated_to_desktop"
      ]
    },
    "decision_authority": {
      "type": "string",
      "enum": [
        "approve_or_defer",
        "escalate_only"
      ]
    },
    "ci_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "running",
        "queued",
        "canceled",
        "stale"
      ]
    },
    "card_freshness": {
      "type": "string",
      "enum": [
        "live",
        "cached",
        "stale"
      ]
    },
    "handoff_target": {
      "type": "string",
      "enum": [
        "file_location",
        "review_panel",
        "ci_pipeline",
        "incident_workspace",
        "agent_session"
      ]
    },
    "handoff_resolution": {
      "type": "string",
      "enum": [
        "exact",
        "approximate",
        "unresolved"
      ]
    },
    "degraded_reason": {
      "type": "string",
      "enum": [
        "relay_unavailable",
        "proof_stale",
        "host_session_inactive",
        "trust_narrowed",
        "upstream_matrix_narrowed",
        "handoff_target_unresolved"
      ]
    },
    "desktop_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "deep_link_ref",
        "resolution",
        "requires_active_host"
      ],
      "properties": {
        "target": {
          "$ref": "#/$defs/handoff_target"
        },
        "deep_link_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "resolution": {
          "$ref": "#/$defs/handoff_resolution"
        },
        "requires_active_host": {
          "type": "boolean"
        }
      }
    },
    "section_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section",
        "qualification",
        "rollout_stage",
        "matrix_lane_ref",
        "downgrade_triggers",
        "rollback_posture"
      ],
      "properties": {
        "section": {
          "$ref": "#/$defs/section"
        },
        "qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "rollout_stage": {
          "$ref": "#/$defs/rollout_stage"
        },
        "matrix_lane_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "rollback_posture": {
          "$ref": "#/$defs/rollback_posture"
        }
      }
    },
    "notification_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "category",
        "priority",
        "triage_state",
        "headline",
        "source_event_ref",
        "read_only",
        "handoff"
      ],
      "properties": {
        "item_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "category": {
          "$ref": "#/$defs/notification_category"
        },
        "priority": {
          "$ref": "#/$defs/triage_priority"
        },
        "triage_state": {
          "$ref": "#/$defs/triage_state"
        },
        "headline": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_event_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "handoff": {
          "$ref": "#/$defs/desktop_handoff"
        }
      }
    },
    "review_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "review_kind",
        "queue_state",
        "decision_authority",
        "summary",
        "evidence_ref",
        "handoff"
      ],
      "properties": {
        "item_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "review_kind": {
          "$ref": "#/$defs/review_kind"
        },
        "queue_state": {
          "$ref": "#/$defs/review_queue_state"
        },
        "decision_authority": {
          "$ref": "#/$defs/decision_authority"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "handoff": {
          "$ref": "#/$defs/desktop_handoff"
        }
      }
    },
    "ci_status_card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id",
        "pipeline_label",
        "status",
        "freshness",
        "failing_check_count",
        "handoff"
      ],
      "properties": {
        "card_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pipeline_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "status": {
          "$ref": "#/$defs/ci_status"
        },
        "freshness": {
          "$ref": "#/$defs/card_freshness"
        },
        "failing_check_count": {
          "type": "integer",
          "minimum": 0
        },
        "handoff": {
          "$ref": "#/$defs/desktop_handoff"
        }
      }
    },
    "handoff_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exact_target_required",
        "read_only_companion",
        "host_authoritative",
        "no_payload_bodies"
      ],
      "properties": {
        "exact_target_required": { "type": "boolean", "const": true },
        "read_only_companion": { "type": "boolean", "const": true },
        "host_authoritative": { "type": "boolean", "const": true },
        "no_payload_bodies": { "type": "boolean", "const": true }
      }
    },
    "locality_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stays_local",
        "staged",
        "requires_provider_or_admin_continuity"
      ],
      "properties": {
        "stays_local": {
          "$ref": "#/$defs/non_empty_string"
        },
        "staged": {
          "$ref": "#/$defs/non_empty_string"
        },
        "requires_provider_or_admin_continuity": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "security_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "companion_read_only",
        "no_editor_authority_on_companion",
        "host_stays_authoritative",
        "exact_desktop_handoff_preserved",
        "no_payload_bodies_in_export",
        "degraded_state_labeled",
        "downgrade_narrows_instead_of_hides",
        "locality_disclosed"
      ],
      "properties": {
        "companion_read_only": { "type": "boolean", "const": true },
        "no_editor_authority_on_companion": { "type": "boolean", "const": true },
        "host_stays_authoritative": { "type": "boolean", "const": true },
        "exact_desktop_handoff_preserved": { "type": "boolean", "const": true },
        "no_payload_bodies_in_export": { "type": "boolean", "const": true },
        "degraded_state_labeled": { "type": "boolean", "const": true },
        "downgrade_narrows_instead_of_hides": { "type": "boolean", "const": true },
        "locality_disclosed": { "type": "boolean", "const": true }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "browser_companion_shows_triage",
        "mobile_companion_shows_triage",
        "desktop_panel_shows_handoff_target",
        "support_export_shows_state",
        "diagnostics_shows_degraded_labels",
        "preview_labs_label_for_unqualified_sections"
      ],
      "properties": {
        "browser_companion_shows_triage": { "type": "boolean", "const": true },
        "mobile_companion_shows_triage": { "type": "boolean", "const": true },
        "desktop_panel_shows_handoff_target": { "type": "boolean", "const": true },
        "support_export_shows_state": { "type": "boolean", "const": true },
        "diagnostics_shows_degraded_labels": { "type": "boolean", "const": true },
        "preview_labs_label_for_unqualified_sections": { "type": "boolean", "const": true }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
