{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/companion/freeze-the-m5-companion-incident-sync-and-offboarding-matrix-with-staged-rollout-lanes.schema.json",
  "title": "Aureline M5 companion, incident, sync, residency, and offboarding matrix with staged rollout lanes",
  "description": "Export-safe packet freezing the M5 depth qualification for eight lanes across five domains: companion (notification, review follow-up, session follow, bounded light-edit), incident workspaces, managed sync, customer-managed-key/E2EE residency, and offboarding continuity. Each lane binds a qualification class, staged rollout stage, an explicit locality disclosure of what stays local, what is staged, and what requires provider or admin continuity, evidence requirements, downgrade triggers, rollback posture, source contracts, and consumer surface parity. Credential bodies, raw provider payloads, and raw sync record contents never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "matrix_label",
    "lane_rows",
    "security_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "freeze_m5_companion_incident_sync_and_offboarding_matrix_with_staged_rollout_lanes"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "matrix_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "lane_rows": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/lane_row"
      }
    },
    "security_review": {
      "$ref": "#/$defs/security_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "domain": {
      "type": "string",
      "enum": [
        "companion",
        "incident",
        "sync",
        "residency",
        "offboarding"
      ]
    },
    "lane": {
      "type": "string",
      "enum": [
        "companion_notification",
        "companion_review",
        "companion_session_follow",
        "companion_light_edit",
        "incident_workspace",
        "managed_sync",
        "residency_encryption",
        "offboarding_continuity"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "rollout_stage": {
      "type": "string",
      "enum": [
        "internal_only",
        "early_access",
        "staged_rollout",
        "general_availability",
        "withheld"
      ]
    },
    "evidence_requirement": {
      "type": "string",
      "enum": [
        "required",
        "recommended",
        "optional",
        "not_applicable"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "evidence_packet_invalid",
        "policy_blocked",
        "provider_unavailable",
        "admin_continuity_required",
        "residency_or_encryption_unverified",
        "incident_attribution_missing",
        "sync_inspection_unavailable",
        "companion_scope_expansion_unqualified",
        "offboarding_strands_local_work",
        "trust_narrowing",
        "upstream_dependency_narrowed"
      ]
    },
    "rollback_posture": {
      "type": "string",
      "enum": [
        "local_core_continues_no_remote_state",
        "companion_read_only_narrow_scope",
        "staged_reversible_via_rollout",
        "sync_reconciles_to_local_core",
        "offboarding_export_preserves_local_work",
        "evidence_preserved_no_revert",
        "not_applicable"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "desktop_companion_panel",
        "browser_companion",
        "mobile_companion",
        "incident_workspace",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "locality_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stays_local",
        "staged",
        "requires_provider_or_admin_continuity"
      ],
      "properties": {
        "stays_local": {
          "$ref": "#/$defs/non_empty_string"
        },
        "staged": {
          "$ref": "#/$defs/non_empty_string"
        },
        "requires_provider_or_admin_continuity": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "lane_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane",
        "domain",
        "qualification",
        "rollout_stage",
        "scope_summary",
        "locality_disclosure",
        "evidence_requirement",
        "required_evidence_packet_refs",
        "downgrade_triggers",
        "rollback_posture",
        "source_contract_refs",
        "consumer_surfaces"
      ],
      "properties": {
        "lane": {
          "$ref": "#/$defs/lane"
        },
        "domain": {
          "$ref": "#/$defs/domain"
        },
        "qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "rollout_stage": {
          "$ref": "#/$defs/rollout_stage"
        },
        "scope_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "locality_disclosure": {
          "$ref": "#/$defs/locality_disclosure"
        },
        "evidence_requirement": {
          "$ref": "#/$defs/evidence_requirement"
        },
        "required_evidence_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "rollback_posture": {
          "$ref": "#/$defs/rollback_posture"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/consumer_surface"
          }
        }
      }
    },
    "security_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "companions_stay_narrow",
        "no_hidden_control_plane",
        "no_second_flagship_implied",
        "incident_packets_attributable",
        "managed_sync_inspectable",
        "residency_and_e2ee_claims_provable",
        "offboarding_never_strands_local_work",
        "locality_disclosed_per_row",
        "no_credential_bodies_in_export",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "companions_stay_narrow": { "type": "boolean", "const": true },
        "no_hidden_control_plane": { "type": "boolean", "const": true },
        "no_second_flagship_implied": { "type": "boolean", "const": true },
        "incident_packets_attributable": { "type": "boolean", "const": true },
        "managed_sync_inspectable": { "type": "boolean", "const": true },
        "residency_and_e2ee_claims_provable": { "type": "boolean", "const": true },
        "offboarding_never_strands_local_work": { "type": "boolean", "const": true },
        "locality_disclosed_per_row": { "type": "boolean", "const": true },
        "no_credential_bodies_in_export": { "type": "boolean", "const": true },
        "downgrade_narrows_instead_of_hides": { "type": "boolean", "const": true },
        "stale_or_underqualified_blocks_promotion": { "type": "boolean", "const": true }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "desktop_companion_shows_qualification",
        "browser_companion_shows_qualification",
        "mobile_companion_shows_qualification",
        "incident_workspace_shows_qualification",
        "cli_headless_shows_qualification",
        "support_export_shows_qualification",
        "diagnostics_shows_qualification",
        "help_about_shows_qualification",
        "preview_labs_label_for_unqualified_lanes"
      ],
      "properties": {
        "desktop_companion_shows_qualification": { "type": "boolean", "const": true },
        "browser_companion_shows_qualification": { "type": "boolean", "const": true },
        "mobile_companion_shows_qualification": { "type": "boolean", "const": true },
        "incident_workspace_shows_qualification": { "type": "boolean", "const": true },
        "cli_headless_shows_qualification": { "type": "boolean", "const": true },
        "support_export_shows_qualification": { "type": "boolean", "const": true },
        "diagnostics_shows_qualification": { "type": "boolean", "const": true },
        "help_about_shows_qualification": { "type": "boolean", "const": true },
        "preview_labs_label_for_unqualified_lanes": { "type": "boolean", "const": true }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
