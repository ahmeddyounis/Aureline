{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/companion/certify-companion-incident-sync-residency-encryption-and-offboarding-lanes-on-every-marketed-m5-profile.schema.json",
  "title": "Aureline M5 companion, incident, sync, residency, encryption, and offboarding lane certification on every marketed M5 profile",
  "description": "Export-safe packet certifying each of the eight frozen companion-matrix lanes — companion notification, review follow-up, session follow, bounded light-edit, incident workspaces, managed sync, residency/encryption, and offboarding continuity — on every marketed M5 profile (local-solo, team-managed, enterprise-managed, browser-companion, mobile-companion, air-gapped-offline). Every claim is bound to the frozen matrix as its ceiling: a lane is never certified greener than the matrix admits, so no surface stays greener than this packet. A managed lane is never certified on a profile without a managed plane, a relay-bound companion lane is never certified on an air-gapped profile, the local-first incident and offboarding lanes stay certified even air-gapped, every certified row discloses what stays local and what requires provider or admin continuity, user-owned local work is never stranded, stale or unknown freshness is labeled rather than shown as live, and a closed set of downgrade rules narrows rather than hides on stale proof, an unverified residency or encryption claim, an unavailable provider or admin plane, or a narrowed upstream matrix lane. Credential bodies, raw provider payloads, and raw sync record contents never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "certification_label",
    "lane_certifications",
    "security_review",
    "consumer_projection",
    "proof_freshness",
    "degraded_labels",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "certify_companion_incident_sync_residency_encryption_and_offboarding_lanes_on_every_marketed_m5_profile"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "certification_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "lane_certifications": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/lane_certification"
      }
    },
    "security_review": {
      "$ref": "#/$defs/security_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "degraded_labels": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/degraded_reason"
      }
    },
    "source_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "$ref": "#/$defs/non_empty_string"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "qualification_class": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "experimental", "unavailable", "held"]
    },
    "rollout_stage": {
      "type": "string",
      "enum": [
        "internal_only",
        "early_access",
        "staged_rollout",
        "general_availability",
        "withheld"
      ]
    },
    "matrix_lane": {
      "type": "string",
      "enum": [
        "companion_notification",
        "companion_review",
        "companion_session_follow",
        "companion_light_edit",
        "incident_workspace",
        "managed_sync",
        "residency_encryption",
        "offboarding_continuity"
      ]
    },
    "matrix_domain": {
      "type": "string",
      "enum": ["companion", "incident", "sync", "residency", "offboarding"]
    },
    "marketed_profile": {
      "type": "string",
      "enum": [
        "local_solo",
        "team_managed",
        "enterprise_managed",
        "browser_companion",
        "mobile_companion",
        "air_gapped_offline"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": ["fresh", "stale", "unknown"]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "evidence_packet_invalid",
        "policy_blocked",
        "provider_unavailable",
        "admin_continuity_required",
        "residency_or_encryption_unverified",
        "incident_attribution_missing",
        "sync_inspection_unavailable",
        "companion_scope_expansion_unqualified",
        "offboarding_strands_local_work",
        "trust_narrowing",
        "upstream_dependency_narrowed"
      ]
    },
    "degraded_reason": {
      "type": "string",
      "enum": [
        "proof_stale",
        "evidence_invalid",
        "provider_unavailable",
        "admin_continuity_required",
        "residency_or_encryption_unverified",
        "upstream_matrix_narrowed",
        "freshness_downgraded_to_stale"
      ]
    },
    "locality_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stays_local", "staged", "requires_provider_or_admin_continuity"],
      "properties": {
        "stays_local": { "$ref": "#/$defs/non_empty_string" },
        "staged": { "$ref": "#/$defs/non_empty_string" },
        "requires_provider_or_admin_continuity": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "profile_certification_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "certified_on_profile",
        "profile_qualification",
        "rollout_stage",
        "locality_disclosure",
        "requires_provider_or_admin_continuity",
        "local_core_continuity_preserved",
        "freshness",
        "freshness_label_shown"
      ],
      "properties": {
        "profile": { "$ref": "#/$defs/marketed_profile" },
        "certified_on_profile": { "type": "boolean" },
        "profile_qualification": { "$ref": "#/$defs/qualification_class" },
        "rollout_stage": { "$ref": "#/$defs/rollout_stage" },
        "locality_disclosure": { "$ref": "#/$defs/locality_disclosure" },
        "requires_provider_or_admin_continuity": { "type": "boolean" },
        "local_core_continuity_preserved": { "type": "boolean" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "freshness_label_shown": { "type": "boolean" }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger", "narrowed_to", "auto_enforced", "rationale"],
      "properties": {
        "trigger": { "$ref": "#/$defs/downgrade_trigger" },
        "narrowed_to": { "$ref": "#/$defs/qualification_class" },
        "auto_enforced": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "lane_certification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane",
        "domain",
        "claimed_qualification",
        "matrix_baseline_qualification",
        "scope_summary",
        "profile_coverage",
        "downgrade_rules",
        "evidence_packet_refs"
      ],
      "properties": {
        "lane": { "$ref": "#/$defs/matrix_lane" },
        "domain": { "$ref": "#/$defs/matrix_domain" },
        "claimed_qualification": { "$ref": "#/$defs/qualification_class" },
        "matrix_baseline_qualification": { "$ref": "#/$defs/qualification_class" },
        "scope_summary": { "$ref": "#/$defs/non_empty_string" },
        "profile_coverage": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": { "$ref": "#/$defs/profile_certification_row" }
        },
        "downgrade_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_rule" }
        },
        "evidence_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "security_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_lane_greener_than_matrix",
        "companions_stay_narrow",
        "incident_packets_attributable",
        "managed_sync_inspectable",
        "residency_and_e2ee_claims_provable",
        "offboarding_never_strands_local_work",
        "locality_disclosed_per_profile",
        "no_managed_claim_without_managed_plane",
        "no_hidden_control_plane",
        "no_credential_bodies_in_export",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "no_lane_greener_than_matrix": { "type": "boolean" },
        "companions_stay_narrow": { "type": "boolean" },
        "incident_packets_attributable": { "type": "boolean" },
        "managed_sync_inspectable": { "type": "boolean" },
        "residency_and_e2ee_claims_provable": { "type": "boolean" },
        "offboarding_never_strands_local_work": { "type": "boolean" },
        "locality_disclosed_per_profile": { "type": "boolean" },
        "no_managed_claim_without_managed_plane": { "type": "boolean" },
        "no_hidden_control_plane": { "type": "boolean" },
        "no_credential_bodies_in_export": { "type": "boolean" },
        "downgrade_narrows_instead_of_hides": { "type": "boolean" },
        "stale_or_underqualified_blocks_promotion": { "type": "boolean" }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "desktop_companion_shows_certification",
        "browser_companion_shows_certification",
        "mobile_companion_shows_certification",
        "incident_workspace_shows_certification",
        "cli_headless_shows_certification",
        "support_export_shows_certification",
        "diagnostics_shows_certification",
        "help_about_shows_certification",
        "unqualified_rows_labeled"
      ],
      "properties": {
        "desktop_companion_shows_certification": { "type": "boolean" },
        "browser_companion_shows_certification": { "type": "boolean" },
        "mobile_companion_shows_certification": { "type": "boolean" },
        "incident_workspace_shows_certification": { "type": "boolean" },
        "cli_headless_shows_certification": { "type": "boolean" },
        "support_export_shows_certification": { "type": "boolean" },
        "diagnostics_shows_certification": { "type": "boolean" },
        "help_about_shows_certification": { "type": "boolean" },
        "unqualified_rows_labeled": { "type": "boolean" }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": { "type": "integer", "minimum": 1 },
        "last_proof_refresh": { "$ref": "#/$defs/non_empty_string" },
        "auto_narrow_on_stale": { "type": "boolean" }
      }
    }
  }
}
