  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "surface_label",
    "projected_surfaces",
    "surface_qualifications",
    "session_follow",
    "incident_awareness",
    "bounded_light_edit",
    "scope_contract",
    "stale_state_honesty",
    "locality_disclosure",
    "security_review",
    "consumer_projection",
    "proof_freshness",
    "degraded_labels",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
