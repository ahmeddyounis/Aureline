{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/io/save_guarantee_class.schema.json",
  "title": "Aureline save guarantee class boundary",
  "description": "Schema for save guarantee class definition records frozen in docs/io/save_target_token_and_write_guarantee_contract.md. The guarantee class is the user-visible and export-visible promise around a save target: whether Aureline can atomically replace it, must write in place under review, can use a remote conditional revision, must block for read-only or policy state, or cannot prove capability safely. Raw file contents, provider payloads, credentials, secrets, and unredacted absolute paths do not cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/save_guarantee_class_definition_record" },
    { "$ref": "#/$defs/save_guarantee_class_catalog_record" }
  ],
  "$defs": {
    "save_guarantee_class_schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 900,
      "description": "Plain-language copy safe for UI, CLI, logs, and support export. It must not include raw file bodies, secrets, credentials, or unredacted provider payloads."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "save_guarantee_class_definition_record",
        "save_guarantee_class_catalog_record"
      ]
    },
    "save_guarantee_class_id": {
      "type": "string",
      "enum": [
        "atomic_replace_preferred",
        "in_place_write_with_review",
        "remote_conditional_write",
        "read_only_mount",
        "policy_blocked",
        "capability_uncertain"
      ]
    },
    "write_mode": {
      "type": "string",
      "enum": [
        "atomic_replace",
        "in_place_write",
        "conditional_remote_write",
        "blocked",
        "capability_uncertain"
      ]
    },
    "compare_policy_class": {
      "type": "string",
      "enum": [
        "generation_token_required",
        "remote_precondition_required",
        "reviewed_in_place_compare_required",
        "blocked_before_compare",
        "capability_refresh_required"
      ]
    },
    "checkpoint_class": {
      "type": "string",
      "enum": [
        "not_required_no_write",
        "recovery_journal",
        "local_history_checkpoint",
        "workspace_checkpoint_group",
        "provider_revision_checkpoint",
        "metadata_only_checkpoint",
        "unavailable_blocks"
      ]
    },
    "rollback_class": {
      "type": "string",
      "enum": [
        "no_mutation",
        "exact_restore",
        "checkpoint_restore",
        "provider_revision_restore",
        "compensating_write",
        "metadata_only_review",
        "manual_recovery_required",
        "unavailable_blocks"
      ]
    },
    "guarantee_action": {
      "type": "string",
      "enum": [
        "write",
        "recompare",
        "open_diff",
        "reopen_review",
        "block",
        "save_as",
        "export_patch",
        "request_approval",
        "open_details",
        "cancel"
      ]
    },
    "required_export_field": {
      "type": "string",
      "enum": [
        "packet_id",
        "token_id",
        "presentation_path",
        "logical_workspace_identity",
        "canonical_object_identity",
        "strongest_generation_token",
        "permission_snapshot",
        "write_mode",
        "save_guarantee_class",
        "compare_before_write_result",
        "observed_generation_token",
        "conflict_state",
        "wrong_target_prevention",
        "diff_ref",
        "review_ref",
        "checkpoint_ref",
        "rollback_class",
        "policy_decision_ref",
        "provider_revision_ref",
        "route_or_session_ref",
        "mount_graph_hash",
        "capability_gap_reason",
        "redaction_policy"
      ]
    },
    "required_ui_copy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status_line",
        "review_title",
        "review_body",
        "cli_summary",
        "support_summary"
      ],
      "properties": {
        "status_line": { "$ref": "#/$defs/reviewable_sentence" },
        "review_title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "review_body": { "$ref": "#/$defs/reviewable_sentence" },
        "cli_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "support_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "checkpoint_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_checkpoint_class",
        "rollback_class",
        "checkpoint_required_before_write",
        "user_visible_summary"
      ],
      "properties": {
        "minimum_checkpoint_class": { "$ref": "#/$defs/checkpoint_class" },
        "rollback_class": { "$ref": "#/$defs/rollback_class" },
        "checkpoint_required_before_write": { "type": "boolean" },
        "user_visible_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "save_guarantee_class_definition_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "save_guarantee_class_schema_version",
        "guarantee_class",
        "permitted_write_modes",
        "compare_policy_class",
        "required_ui_copy",
        "required_export_fields",
        "checkpoint_requirements",
        "default_actions",
        "may_write_without_review",
        "degraded_visible_before_write"
      ],
      "properties": {
        "record_kind": { "const": "save_guarantee_class_definition_record" },
        "save_guarantee_class_schema_version": {
          "$ref": "#/$defs/save_guarantee_class_schema_version"
        },
        "guarantee_class": { "$ref": "#/$defs/save_guarantee_class_id" },
        "permitted_write_modes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/write_mode" }
        },
        "compare_policy_class": { "$ref": "#/$defs/compare_policy_class" },
        "required_ui_copy": { "$ref": "#/$defs/required_ui_copy" },
        "required_export_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/required_export_field" }
        },
        "checkpoint_requirements": {
          "$ref": "#/$defs/checkpoint_requirements"
        },
        "default_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/guarantee_action" }
        },
        "may_write_without_review": { "type": "boolean" },
        "degraded_visible_before_write": { "type": "boolean" },
        "support_export_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "save_guarantee_class_catalog_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "save_guarantee_class_schema_version",
        "catalog_id",
        "definitions"
      ],
      "properties": {
        "record_kind": { "const": "save_guarantee_class_catalog_record" },
        "save_guarantee_class_schema_version": {
          "$ref": "#/$defs/save_guarantee_class_schema_version"
        },
        "catalog_id": { "$ref": "#/$defs/non_empty_string" },
        "definitions": {
          "type": "array",
          "minItems": 6,
          "items": {
            "$ref": "#/$defs/save_guarantee_class_definition_record"
          }
        }
      }
    }
  }
}
