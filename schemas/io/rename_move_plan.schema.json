{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/io/rename_move_plan.schema.json",
  "title": "Aureline rename and move review plan",
  "description": "Boundary schema for rename_move_plan_record frozen in docs/io/rename_move_review_contract.md. The plan is emitted before a risky rename, move, copy, cross-root transfer, alias detach, or recompute action can mutate durable state. It carries current and proposed presentation paths, logical workspace identity, canonical-object implications, root capability context, review triggers, policy and trust boundary notes, rollback posture, next safe action, parity requirements, and support/export fields. Raw file bodies, raw provider payloads, credentials, secrets, and unredacted paths outside the workspace root do not cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/rename_move_plan_record" }
  ],
  "$defs": {
    "io_rename_move_plan_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "rename_move_plan_record"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "oneOf": [
        { "$ref": "#/$defs/non_empty_string" },
        { "type": "null" }
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 900
    },
    "trust_state": {
      "type": "string",
      "enum": [
        "trusted",
        "restricted",
        "pending_evaluation"
      ]
    },
    "initiating_surface": {
      "type": "string",
      "enum": [
        "file_tree",
        "breadcrumb",
        "refactor_rename",
        "import_or_migration",
        "save_conflict",
        "quick_open",
        "command_palette",
        "cli",
        "automation",
        "extension_host",
        "ai_apply_review"
      ]
    },
    "operation_intent": {
      "type": "string",
      "enum": [
        "rename",
        "move",
        "rename_and_move",
        "copy",
        "transfer",
        "detach_alias",
        "recompute_only"
      ]
    },
    "root_class": {
      "type": "string",
      "enum": [
        "local_posix_like",
        "local_windows_like",
        "remote_agent_mount",
        "container_mount",
        "cloud_backed_sync_root",
        "mirrored_sync_root",
        "virtual_generated_document",
        "archive_like_view",
        "unknown"
      ]
    },
    "normalization_form": {
      "type": "string",
      "enum": [
        "none",
        "nfc",
        "nfd",
        "mixed_observed"
      ]
    },
    "case_sensitivity": {
      "type": "string",
      "enum": [
        "sensitive",
        "insensitive_preserving",
        "insensitive_non_preserving"
      ]
    },
    "identity_token_kind": {
      "type": "string",
      "enum": [
        "file_id_generation",
        "device_inode_generation",
        "windows_object_id",
        "provider_object_id_revision",
        "remote_revision_token",
        "etag",
        "cloud_version_id",
        "mirror_digest_generation",
        "logical_document_id_source_refs",
        "content_hash_only",
        "unavailable"
      ]
    },
    "identity_token_strength": {
      "type": "string",
      "enum": [
        "exact",
        "conditional",
        "heuristic",
        "missing"
      ]
    },
    "alias_kind": {
      "type": "string",
      "enum": [
        "symlink",
        "junction",
        "hardlink_sibling",
        "case_only_variant",
        "unicode_normalization_variant",
        "remote_alias",
        "bind_mount_alias",
        "container_mount_alias",
        "archive_inner_alias",
        "cloud_sync_alias",
        "mirror_alias",
        "generated_companion"
      ]
    },
    "cross_root_transfer_class": {
      "type": "string",
      "enum": [
        "same_root",
        "same_authority_cross_root",
        "local_to_remote",
        "remote_to_local",
        "remote_to_remote_same_provider",
        "remote_to_remote_different_provider",
        "container_boundary",
        "cloud_or_mirror_boundary",
        "archive_or_virtual_boundary",
        "generated_companion_boundary",
        "unsupported_unknown"
      ]
    },
    "required_capability_check": {
      "type": "string",
      "enum": [
        "case_fold_capability",
        "unicode_normalization_capability",
        "canonical_identity_refresh",
        "cross_root_transfer_capability",
        "remote_precondition",
        "mirror_freshness",
        "symlink_or_junction_boundary",
        "generated_relation_authority",
        "rollback_checkpoint_available",
        "policy_epoch",
        "trust_boundary"
      ]
    },
    "canonical_effect_class": {
      "type": "string",
      "enum": [
        "preserves_canonical_object",
        "creates_new_canonical_object",
        "rebinds_alias_to_existing_object",
        "detaches_alias_to_new_authority",
        "changes_generated_companion_relation",
        "ambiguous_same_path_different_object",
        "unknown_until_recompute",
        "blocked_no_mutation"
      ]
    },
    "object_relation_after": {
      "type": "string",
      "enum": [
        "same_object_new_presentation",
        "new_object_new_presentation",
        "same_path_different_object",
        "alias_detached_new_authority",
        "generated_companion_relinked",
        "copy_created_source_preserved",
        "unknown_until_recompute",
        "blocked_no_mutation"
      ]
    },
    "risk_class": {
      "type": "string",
      "enum": [
        "case_only_rename_on_insensitive_root",
        "unicode_normalization_change",
        "symlink_escape",
        "junction_escape",
        "cross_root_transfer",
        "generated_companion_relation",
        "same_path_different_object",
        "canonical_object_drift",
        "alias_set_non_empty",
        "root_capability_degraded",
        "policy_or_trust_boundary",
        "remote_revision_drift",
        "mirror_freshness_lag",
        "read_only_or_virtual_target",
        "rollback_unavailable",
        "capability_unknown",
        "imported_or_migration_boundary",
        "save_conflict_reconciliation"
      ]
    },
    "review_surface_class": {
      "type": "string",
      "enum": [
        "rename_move_review_sheet",
        "refactor_preview_packet",
        "import_diff_preview_packet",
        "save_conflict_review",
        "path_truth_alias_inspector",
        "cli_review_packet",
        "no_review_required"
      ]
    },
    "boundary_class": {
      "type": "string",
      "enum": [
        "policy_scope_change",
        "trust_state_change",
        "root_authority_change",
        "remote_provider_boundary",
        "mirror_freshness_boundary",
        "generated_lineage_boundary",
        "symlink_or_junction_escape_policy",
        "credential_or_egress_boundary",
        "read_only_or_virtual_boundary",
        "none"
      ]
    },
    "checkpoint_class": {
      "type": "string",
      "enum": [
        "not_required_no_write",
        "recovery_journal",
        "local_history_checkpoint",
        "workspace_checkpoint_group",
        "provider_revision_checkpoint",
        "metadata_only_checkpoint",
        "unavailable_blocks"
      ]
    },
    "rollback_class": {
      "type": "string",
      "enum": [
        "no_mutation",
        "exact_restore",
        "checkpoint_restore",
        "provider_revision_restore",
        "compensating_write",
        "detach_alias_no_body_change",
        "regenerate_from_canonical_source",
        "metadata_only_review",
        "manual_recovery_required",
        "unavailable_blocks"
      ]
    },
    "safe_action": {
      "type": "string",
      "enum": [
        "rename_in_place",
        "copy_then_review",
        "detach_alias",
        "block_and_explain",
        "recompute_against_current_root_capabilities",
        "open_review_diff",
        "request_approval",
        "save_as",
        "cancel"
      ]
    },
    "mutation_authority": {
      "type": "string",
      "enum": [
        "writes_after_review",
        "writes_without_review",
        "copy_only_until_review",
        "no_write_recomputes_only",
        "no_write_blocked",
        "metadata_only"
      ]
    },
    "parity_surface": {
      "type": "string",
      "enum": [
        "file_tree",
        "breadcrumb",
        "refactor_rename",
        "import_migration_tool",
        "save_conflict_review",
        "quick_open",
        "command_palette",
        "cli",
        "automation",
        "support_export"
      ]
    },
    "saved_packet_field": {
      "type": "string",
      "enum": [
        "plan_id",
        "operation_intent",
        "current_presentation_path",
        "proposed_presentation_path",
        "logical_workspace_identity",
        "current_canonical_object",
        "proposed_canonical_effect",
        "capability_context",
        "review_gate",
        "policy_trust_boundary_notes",
        "rollback_posture",
        "next_safe_action",
        "silent_best_effort_forbidden",
        "parity_requirements",
        "redaction_policy"
      ]
    },
    "presentation_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri",
        "display_label",
        "root_badge"
      ],
      "properties": {
        "uri": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "root_badge": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "logical_workspace_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_id",
        "root_id",
        "logical_uri",
        "trust_state",
        "policy_scope"
      ],
      "properties": {
        "workspace_id": { "$ref": "#/$defs/non_empty_string" },
        "root_id": { "$ref": "#/$defs/non_empty_string" },
        "logical_uri": { "$ref": "#/$defs/non_empty_string" },
        "trust_state": { "$ref": "#/$defs/trust_state" },
        "policy_scope": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "identity_token": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value",
        "strength"
      ],
      "properties": {
        "kind": { "$ref": "#/$defs/identity_token_kind" },
        "value": { "$ref": "#/$defs/nullable_string" },
        "strength": { "$ref": "#/$defs/identity_token_strength" }
      }
    },
    "alias_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alias_uri",
        "alias_kind",
        "resolution_chain"
      ],
      "properties": {
        "alias_uri": { "$ref": "#/$defs/non_empty_string" },
        "alias_kind": { "$ref": "#/$defs/alias_kind" },
        "resolution_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "canonical_object_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_uri",
        "root_class",
        "normalization_form",
        "object_identity_token",
        "fallback_identity_tokens",
        "alias_set"
      ],
      "properties": {
        "canonical_uri": { "$ref": "#/$defs/non_empty_string" },
        "root_class": { "$ref": "#/$defs/root_class" },
        "normalization_form": { "$ref": "#/$defs/normalization_form" },
        "object_identity_token": { "$ref": "#/$defs/identity_token" },
        "fallback_identity_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/identity_token" }
        },
        "alias_set": {
          "type": "array",
          "items": { "$ref": "#/$defs/alias_entry" }
        }
      }
    },
    "proposed_canonical_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effect_class",
        "object_relation_after",
        "canonical_uri_after",
        "identity_token_after",
        "implication_summary"
      ],
      "properties": {
        "effect_class": { "$ref": "#/$defs/canonical_effect_class" },
        "object_relation_after": { "$ref": "#/$defs/object_relation_after" },
        "canonical_uri_after": { "$ref": "#/$defs/nullable_string" },
        "identity_token_after": { "$ref": "#/$defs/identity_token" },
        "implication_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "root_capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root_id",
        "root_class",
        "case_sensitivity",
        "unicode_normalization",
        "supports_atomic_rename",
        "supports_in_place_rename",
        "supports_copy_delete_transfer",
        "supports_conditional_remote_move",
        "supports_alias_detach",
        "supports_generated_relation_update",
        "identity_token_strength",
        "watcher_state",
        "read_only",
        "policy_constrained",
        "symlink_escape_policy"
      ],
      "properties": {
        "root_id": { "$ref": "#/$defs/non_empty_string" },
        "root_class": { "$ref": "#/$defs/root_class" },
        "case_sensitivity": { "$ref": "#/$defs/case_sensitivity" },
        "unicode_normalization": { "$ref": "#/$defs/normalization_form" },
        "supports_atomic_rename": { "type": "boolean" },
        "supports_in_place_rename": { "type": "boolean" },
        "supports_copy_delete_transfer": { "type": "boolean" },
        "supports_conditional_remote_move": { "type": "boolean" },
        "supports_alias_detach": { "type": "boolean" },
        "supports_generated_relation_update": { "type": "boolean" },
        "identity_token_strength": { "$ref": "#/$defs/identity_token_strength" },
        "watcher_state": {
          "type": "string",
          "enum": [
            "exact",
            "degraded",
            "unsupported"
          ]
        },
        "read_only": { "type": "boolean" },
        "policy_constrained": { "type": "boolean" },
        "symlink_escape_policy": {
          "type": "string",
          "enum": [
            "allow",
            "warn",
            "block",
            "unknown"
          ]
        }
      }
    },
    "capability_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_root",
        "target_root",
        "same_root",
        "cross_root_transfer_class",
        "required_capability_checks",
        "recompute_required_before_apply"
      ],
      "properties": {
        "source_root": { "$ref": "#/$defs/root_capabilities" },
        "target_root": { "$ref": "#/$defs/root_capabilities" },
        "same_root": { "type": "boolean" },
        "cross_root_transfer_class": {
          "$ref": "#/$defs/cross_root_transfer_class"
        },
        "required_capability_checks": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/required_capability_check" }
        },
        "recompute_required_before_apply": { "type": "boolean" }
      }
    },
    "review_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_required",
        "reviewer_blocking",
        "review_surface_class",
        "review_reason_codes",
        "preview_ref",
        "review_ref",
        "stale_plan_blocks_apply"
      ],
      "properties": {
        "review_required": { "type": "boolean" },
        "reviewer_blocking": { "type": "boolean" },
        "review_surface_class": { "$ref": "#/$defs/review_surface_class" },
        "review_reason_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/risk_class" }
        },
        "preview_ref": { "$ref": "#/$defs/nullable_string" },
        "review_ref": { "$ref": "#/$defs/nullable_string" },
        "stale_plan_blocks_apply": { "type": "boolean" }
      }
    },
    "policy_trust_boundary_note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "boundary_class",
        "summary",
        "policy_decision_ref"
      ],
      "properties": {
        "boundary_class": { "$ref": "#/$defs/boundary_class" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "policy_decision_ref": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "rollback_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_class",
        "rollback_class",
        "checkpoint_ref",
        "journal_ref",
        "rollback_summary"
      ],
      "properties": {
        "checkpoint_class": { "$ref": "#/$defs/checkpoint_class" },
        "rollback_class": { "$ref": "#/$defs/rollback_class" },
        "checkpoint_ref": { "$ref": "#/$defs/nullable_string" },
        "journal_ref": { "$ref": "#/$defs/nullable_string" },
        "rollback_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "next_safe_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "mutation_authority",
        "requires_user_confirmation",
        "action_summary",
        "followup_refs"
      ],
      "properties": {
        "action": { "$ref": "#/$defs/safe_action" },
        "mutation_authority": { "$ref": "#/$defs/mutation_authority" },
        "requires_user_confirmation": { "type": "boolean" },
        "action_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "followup_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action": { "const": "block_and_explain" }
            },
            "required": ["action"]
          },
          "then": {
            "properties": {
              "mutation_authority": { "const": "no_write_blocked" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "recompute_against_current_root_capabilities"
              }
            },
            "required": ["action"]
          },
          "then": {
            "properties": {
              "mutation_authority": { "const": "no_write_recomputes_only" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": { "const": "copy_then_review" }
            },
            "required": ["action"]
          },
          "then": {
            "properties": {
              "mutation_authority": { "const": "copy_only_until_review" }
            }
          }
        }
      ]
    },
    "parity_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vocabulary_version",
        "surfaces",
        "required_shared_fields",
        "one_vocabulary_for_all_surfaces",
        "no_surface_local_fallbacks"
      ],
      "properties": {
        "vocabulary_version": {
          "type": "integer",
          "const": 1
        },
        "surfaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/parity_surface" }
        },
        "required_shared_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/saved_packet_field" }
        },
        "one_vocabulary_for_all_surfaces": {
          "type": "boolean",
          "const": true
        },
        "no_surface_local_fallbacks": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_family",
        "redaction_policy",
        "diagnostic_summary",
        "saved_packet_fields",
        "parity_signature"
      ],
      "properties": {
        "packet_family": {
          "type": "string",
          "const": "io.rename_move_plan"
        },
        "redaction_policy": { "$ref": "#/$defs/non_empty_string" },
        "diagnostic_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "saved_packet_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/saved_packet_field" }
        },
        "parity_signature": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name",
        "scenario",
        "expected_next_safe_action"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/reviewable_sentence" },
        "fixture_class": { "$ref": "#/$defs/non_empty_string" },
        "expected_next_safe_action": { "$ref": "#/$defs/safe_action" }
      }
    },
    "rename_move_plan_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "io_rename_move_plan_schema_version",
        "plan_id",
        "emitted_at",
        "initiating_surface",
        "operation_intent",
        "current_presentation_path",
        "proposed_presentation_path",
        "logical_workspace_identity",
        "current_canonical_object",
        "proposed_canonical_effect",
        "capability_context",
        "review_gate",
        "policy_trust_boundary_notes",
        "rollback_posture",
        "next_safe_action",
        "silent_best_effort_forbidden",
        "parity_requirements",
        "support_export"
      ],
      "properties": {
        "fixture_metadata": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "io_rename_move_plan_schema_version": {
          "$ref": "#/$defs/io_rename_move_plan_schema_version"
        },
        "plan_id": { "$ref": "#/$defs/non_empty_string" },
        "emitted_at": { "$ref": "#/$defs/timestamp" },
        "initiating_surface": { "$ref": "#/$defs/initiating_surface" },
        "operation_intent": { "$ref": "#/$defs/operation_intent" },
        "current_presentation_path": { "$ref": "#/$defs/presentation_path" },
        "proposed_presentation_path": { "$ref": "#/$defs/presentation_path" },
        "logical_workspace_identity": {
          "$ref": "#/$defs/logical_workspace_identity"
        },
        "current_canonical_object": {
          "$ref": "#/$defs/canonical_object_identity"
        },
        "proposed_canonical_effect": {
          "$ref": "#/$defs/proposed_canonical_effect"
        },
        "capability_context": { "$ref": "#/$defs/capability_context" },
        "review_gate": { "$ref": "#/$defs/review_gate" },
        "policy_trust_boundary_notes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/policy_trust_boundary_note" }
        },
        "rollback_posture": { "$ref": "#/$defs/rollback_posture" },
        "next_safe_action": { "$ref": "#/$defs/next_safe_action" },
        "silent_best_effort_forbidden": {
          "type": "boolean",
          "const": true
        },
        "parity_requirements": { "$ref": "#/$defs/parity_requirements" },
        "support_export": { "$ref": "#/$defs/support_export" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "review_gate": {
                "properties": {
                  "review_reason_codes": {
                    "contains": {
                      "enum": [
                        "case_only_rename_on_insensitive_root",
                        "unicode_normalization_change",
                        "symlink_escape",
                        "junction_escape",
                        "cross_root_transfer",
                        "generated_companion_relation",
                        "same_path_different_object",
                        "canonical_object_drift",
                        "policy_or_trust_boundary",
                        "mirror_freshness_lag"
                      ]
                    }
                  }
                },
                "required": ["review_reason_codes"]
              },
              "next_safe_action": {
                "properties": {
                  "action": {
                    "not": {
                      "enum": [
                        "block_and_explain",
                        "recompute_against_current_root_capabilities"
                      ]
                    }
                  }
                },
                "required": ["action"]
              }
            },
            "required": ["review_gate", "next_safe_action"]
          },
          "then": {
            "properties": {
              "review_gate": {
                "properties": {
                  "review_required": { "const": true }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "capability_context": {
                "properties": {
                  "cross_root_transfer_class": {
                    "not": { "const": "same_root" }
                  }
                },
                "required": ["cross_root_transfer_class"]
              }
            },
            "required": ["capability_context"]
          },
          "then": {
            "properties": {
              "review_gate": {
                "properties": {
                  "review_reason_codes": {
                    "contains": { "const": "cross_root_transfer" }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
