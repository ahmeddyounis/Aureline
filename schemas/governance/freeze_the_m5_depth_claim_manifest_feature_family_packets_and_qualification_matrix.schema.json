{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/freeze_the_m5_depth_claim_manifest_feature_family_packets_and_qualification_matrix.schema.json",
  "title": "M5 Depth-Claim Manifest, Feature-Family Packets, and Qualification Matrix",
  "description": "Canonical typed manifest that freezes one M5 feature-family packet per feature family, each binding the family to its stable depth claim and a qualification matrix of one cell per qualification dimension. Downstream docs, Help/About, and support surfaces ingest this directly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "manifest_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "lifecycle_labels",
    "family_kinds",
    "qualification_dimensions",
    "qualification_states",
    "packet_states",
    "narrowing_reasons",
    "stop_rule_actions",
    "launch_cutline",
    "release_blocking_family_refs",
    "stop_rules",
    "rows",
    "promotion",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version of the manifest."
    },
    "record_kind": {
      "type": "string",
      "const": "freeze_m5_depth_claim_manifest_feature_family_packets_and_qualification_matrix"
    },
    "manifest_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "overview_page": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "type": "string", "minLength": 1 },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
      }
    },
    "family_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/family_kind" }
    },
    "qualification_dimensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/qualification_dimension" }
    },
    "qualification_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/qualification_state" }
    },
    "packet_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/packet_state" }
    },
    "narrowing_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/narrowing_reason" }
    },
    "stop_rule_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/stop_rule_action" }
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_family_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stop_rule" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/family_packet" }
    },
    "promotion": { "$ref": "#/$defs/promotion_record" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "family_kind": {
      "type": "string",
      "enum": [
        "notebook",
        "data_rich",
        "ai_adjacent",
        "framework",
        "review",
        "companion",
        "managed_depth"
      ]
    },
    "qualification_dimension": {
      "type": "string",
      "enum": [
        "scorecard",
        "compatibility",
        "proof_freshness",
        "lineage",
        "locale_parity",
        "support_packet",
        "accessibility",
        "downgrade_automation"
      ]
    },
    "qualification_state": {
      "type": "string",
      "enum": ["qualified", "incomplete", "stale", "waived", "missing"]
    },
    "packet_state": {
      "type": "string",
      "enum": [
        "qualified",
        "incomplete",
        "stale",
        "on_waiver",
        "lineage_missing",
        "locale_drifted",
        "support_lagging"
      ]
    },
    "narrowing_reason": {
      "type": "string",
      "enum": [
        "scorecard_incomplete",
        "compatibility_missing",
        "proof_packet_missing",
        "proof_packet_stale",
        "lineage_missing",
        "locale_parity_drifted",
        "support_packet_lagging",
        "accessibility_unsigned",
        "downgrade_automation_missing",
        "waiver_expired",
        "owner_signoff_missing"
      ]
    },
    "stop_rule_action": {
      "type": "string",
      "enum": [
        "hold_promotion",
        "narrow_label",
        "complete_scorecard",
        "refresh_compatibility_packet",
        "refresh_proof_packet",
        "refresh_lineage",
        "refresh_locale_pack",
        "refresh_support_packet",
        "sign_accessibility",
        "define_downgrade_automation",
        "request_owner_signoff"
      ]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "type": "string", "const": "stable" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "type": "string", "enum": ["lts", "stable"] }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "type": "string", "enum": ["beta", "preview", "withdrawn"] }
        },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "stop_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_promotion",
        "rationale"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "trigger_reason": { "$ref": "#/$defs/narrowing_reason" },
        "applies_to_labels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
          }
        },
        "default_action": { "$ref": "#/$defs/stop_rule_action" },
        "blocks_promotion": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "freshness_slo",
        "slo_state"
      ],
      "properties": {
        "packet_id": { "type": "string", "minLength": 1 },
        "packet_ref": { "type": "string", "minLength": 1 },
        "proof_index_ref": { "type": "string", "minLength": 1 },
        "captured_at": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "format": "date" }
          ]
        },
        "freshness_slo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
          "properties": {
            "target_max_age_days": { "type": "integer", "minimum": 1 },
            "warn_within_days": { "type": "integer", "minimum": 0 },
            "slo_register_ref": { "type": "string", "minLength": 1 }
          }
        },
        "slo_state": {
          "type": "string",
          "enum": ["current", "due_for_refresh", "breached", "missing"]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "qualification_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "state", "evidence_ref"],
      "properties": {
        "dimension": { "$ref": "#/$defs/qualification_dimension" },
        "state": { "$ref": "#/$defs/qualification_state" },
        "evidence_ref": { "type": "string" }
      }
    },
    "family_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "family_kind",
        "family_ref",
        "family_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "packet_state",
        "qualification_matrix",
        "proof_packet",
        "owner_signoff",
        "published_label",
        "rationale"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "family_kind": { "$ref": "#/$defs/family_kind" },
        "family_ref": { "type": "string", "minLength": 1 },
        "family_summary": { "type": "string", "minLength": 1 },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "type": "string", "minLength": 1 },
        "claim_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "packet_state": { "$ref": "#/$defs/packet_state" },
        "qualification_matrix": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/qualification_cell" }
        },
        "proof_packet": { "$ref": "#/$defs/proof_packet" },
        "waiver": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["waiver_ref", "expires_at", "reason"],
              "properties": {
                "waiver_ref": { "type": "string", "minLength": 1 },
                "expires_at": { "type": "string", "format": "date" },
                "reason": { "type": "string", "minLength": 1 }
              }
            }
          ]
        },
        "owner_signoff": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner_ref", "signed_off"],
          "properties": {
            "owner_ref": { "type": "string", "minLength": 1 },
            "signed_off": { "type": "boolean" },
            "signed_at": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "format": "date" }
              ]
            }
          }
        },
        "active_narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        },
        "published_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "publication_destinations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "promotion_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_claim_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blocking_claim_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "total_claims",
        "entries_qualified",
        "entries_narrowed",
        "entries_on_active_waiver",
        "entries_with_lineage_gap",
        "entries_with_locale_gap",
        "entries_with_support_gap",
        "release_blocking_total",
        "release_blocking_qualified",
        "release_blocking_narrowed",
        "notebook_entries",
        "data_rich_entries",
        "ai_adjacent_entries",
        "framework_entries",
        "review_entries",
        "companion_entries",
        "managed_depth_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_narrowing_reasons",
        "total_qualification_cells",
        "cells_qualified",
        "cells_incomplete",
        "cells_stale",
        "cells_waived",
        "cells_missing",
        "rules_firing"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "entries_qualified": { "type": "integer", "minimum": 0 },
        "entries_narrowed": { "type": "integer", "minimum": 0 },
        "entries_on_active_waiver": { "type": "integer", "minimum": 0 },
        "entries_with_lineage_gap": { "type": "integer", "minimum": 0 },
        "entries_with_locale_gap": { "type": "integer", "minimum": 0 },
        "entries_with_support_gap": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_qualified": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "notebook_entries": { "type": "integer", "minimum": 0 },
        "data_rich_entries": { "type": "integer", "minimum": 0 },
        "ai_adjacent_entries": { "type": "integer", "minimum": 0 },
        "framework_entries": { "type": "integer", "minimum": 0 },
        "review_entries": { "type": "integer", "minimum": 0 },
        "companion_entries": { "type": "integer", "minimum": 0 },
        "managed_depth_entries": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_active_narrowing_reasons": { "type": "integer", "minimum": 0 },
        "total_qualification_cells": { "type": "integer", "minimum": 0 },
        "cells_qualified": { "type": "integer", "minimum": 0 },
        "cells_incomplete": { "type": "integer", "minimum": 0 },
        "cells_stale": { "type": "integer", "minimum": 0 },
        "cells_waived": { "type": "integer", "minimum": 0 },
        "cells_missing": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
