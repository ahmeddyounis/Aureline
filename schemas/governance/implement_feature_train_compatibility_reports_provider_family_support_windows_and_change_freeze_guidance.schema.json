{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/implement_feature_train_compatibility_reports_provider_family_support_windows_and_change_freeze_guidance.schema.json",
  "title": "Feature-Train Compatibility Reports, Provider-Family Support Windows, and Change-Freeze Guidance",
  "description": "Canonical typed register that freezes one feature-train lane per train channel, each binding the train to its stable claim, a compatibility-report scorecard of one cell per dimension, the disclosed provider-family support window, an owner-manifest sign-off, and an explicit change-freeze guidance record. Downstream docs, Help/About, and support surfaces ingest this directly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "manifest_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "lifecycle_labels",
    "train_channels",
    "compatibility_dimensions",
    "dimension_grades",
    "train_states",
    "narrowing_reasons",
    "stop_rule_actions",
    "freeze_triggers",
    "freeze_states",
    "trust_tiers",
    "launch_cutline",
    "release_blocking_train_refs",
    "stop_rules",
    "rows",
    "promotion",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version of the register."
    },
    "record_kind": {
      "type": "string",
      "const": "implement_feature_train_compatibility_reports_provider_family_support_windows_and_change_freeze_guidance"
    },
    "manifest_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "overview_page": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "type": "string", "minLength": 1 },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
      }
    },
    "train_channels": {
      "type": "array",
      "items": { "$ref": "#/$defs/train_channel" }
    },
    "compatibility_dimensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/compatibility_dimension" }
    },
    "dimension_grades": {
      "type": "array",
      "items": { "$ref": "#/$defs/dimension_grade" }
    },
    "train_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/train_state" }
    },
    "narrowing_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/narrowing_reason" }
    },
    "stop_rule_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/stop_rule_action" }
    },
    "freeze_triggers": {
      "type": "array",
      "items": { "$ref": "#/$defs/freeze_trigger" }
    },
    "freeze_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/freeze_state" }
    },
    "trust_tiers": {
      "type": "array",
      "items": { "$ref": "#/$defs/trust_tier" }
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_train_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stop_rule" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/feature_train_lane" }
    },
    "promotion": { "$ref": "#/$defs/promotion_record" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "train_channel": {
      "type": "string",
      "enum": [
        "core_platform",
        "ai_assistant",
        "collaboration",
        "extensions"
      ]
    },
    "compatibility_dimension": {
      "type": "string",
      "enum": [
        "forward_compatibility",
        "backward_compatibility",
        "schema_versioning",
        "provider_support_window",
        "deprecation_policy",
        "change_freeze_adherence"
      ]
    },
    "dimension_grade": {
      "type": "string",
      "enum": ["pass", "partial", "fail", "waived", "missing"]
    },
    "train_state": {
      "type": "string",
      "enum": [
        "certified",
        "compatibility_broken",
        "stale",
        "on_waiver",
        "freeze_undefined",
        "owner_unsigned"
      ]
    },
    "narrowing_reason": {
      "type": "string",
      "enum": [
        "compatibility_dimension_failed",
        "compatibility_dimension_missing",
        "proof_packet_missing",
        "proof_packet_stale",
        "owner_manifest_unsigned",
        "freeze_plan_unverified",
        "change_freeze_undefined",
        "waiver_expired"
      ]
    },
    "stop_rule_action": {
      "type": "string",
      "enum": [
        "hold_promotion",
        "narrow_label",
        "remediate_compatibility",
        "refresh_proof_packet",
        "request_owner_signoff",
        "verify_freeze_plan",
        "define_change_freeze",
        "renew_waiver"
      ]
    },
    "freeze_trigger": {
      "type": "string",
      "enum": ["proof_stale", "compatibility_broken", "owner_revoked", "manual"]
    },
    "freeze_state": {
      "type": "string",
      "enum": ["defined", "unverified", "undefined"]
    },
    "trust_tier": {
      "type": "string",
      "enum": ["first_party", "verified_partner", "community", "untrusted"]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "type": "string", "const": "stable" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "type": "string", "enum": ["lts", "stable"] }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "type": "string", "enum": ["beta", "preview", "withdrawn"] }
        },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "stop_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_promotion",
        "rationale"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "trigger_reason": { "$ref": "#/$defs/narrowing_reason" },
        "applies_to_labels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
          }
        },
        "default_action": { "$ref": "#/$defs/stop_rule_action" },
        "blocks_promotion": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "freshness_slo",
        "slo_state"
      ],
      "properties": {
        "packet_id": { "type": "string", "minLength": 1 },
        "packet_ref": { "type": "string", "minLength": 1 },
        "proof_index_ref": { "type": "string", "minLength": 1 },
        "captured_at": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "format": "date" }
          ]
        },
        "freshness_slo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
          "properties": {
            "target_max_age_days": { "type": "integer", "minimum": 1 },
            "warn_within_days": { "type": "integer", "minimum": 0 },
            "slo_register_ref": { "type": "string", "minLength": 1 }
          }
        },
        "slo_state": {
          "type": "string",
          "enum": ["current", "due_for_refresh", "breached", "missing"]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "compatibility_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "grade", "evidence_ref"],
      "properties": {
        "dimension": { "$ref": "#/$defs/compatibility_dimension" },
        "grade": { "$ref": "#/$defs/dimension_grade" },
        "evidence_ref": { "type": "string" }
      }
    },
    "provider_support_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_family_ref", "baseline_ref", "trust_tier", "eol_disclosed"],
      "properties": {
        "provider_family_ref": { "type": "string", "minLength": 1 },
        "baseline_ref": { "type": "string", "minLength": 1 },
        "trust_tier": { "$ref": "#/$defs/trust_tier" },
        "supported_version_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "eol_disclosed": { "type": "boolean" }
      }
    },
    "change_freeze_guidance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "guidance_ref",
        "freeze_plan_ref",
        "trigger",
        "target_floor",
        "state",
        "freeze_verified"
      ],
      "properties": {
        "guidance_ref": { "type": "string", "minLength": 1 },
        "freeze_plan_ref": { "type": "string", "minLength": 1 },
        "trigger": { "$ref": "#/$defs/freeze_trigger" },
        "target_floor": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "state": { "$ref": "#/$defs/freeze_state" },
        "freeze_verified": { "type": "boolean" }
      }
    },
    "feature_train_lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "train_channel",
        "train_ref",
        "train_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "train_state",
        "scorecard",
        "support_window",
        "change_freeze",
        "proof_packet",
        "owner_signoff",
        "published_label",
        "rationale"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "train_channel": { "$ref": "#/$defs/train_channel" },
        "train_ref": { "type": "string", "minLength": 1 },
        "train_summary": { "type": "string", "minLength": 1 },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "type": "string", "minLength": 1 },
        "claim_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "train_state": { "$ref": "#/$defs/train_state" },
        "scorecard": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/compatibility_cell" }
        },
        "support_window": { "$ref": "#/$defs/provider_support_window" },
        "change_freeze": { "$ref": "#/$defs/change_freeze_guidance" },
        "proof_packet": { "$ref": "#/$defs/proof_packet" },
        "waiver": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["waiver_ref", "expires_at", "reason"],
              "properties": {
                "waiver_ref": { "type": "string", "minLength": 1 },
                "expires_at": { "type": "string", "format": "date" },
                "reason": { "type": "string", "minLength": 1 }
              }
            }
          ]
        },
        "owner_signoff": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner_ref", "signed_off"],
          "properties": {
            "owner_ref": { "type": "string", "minLength": 1 },
            "signed_off": { "type": "boolean" },
            "signed_at": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "format": "date" }
              ]
            }
          }
        },
        "active_narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        },
        "published_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "publication_destinations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "promotion_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_claim_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blocking_claim_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "total_claims",
        "entries_certified",
        "entries_narrowed",
        "entries_on_active_waiver",
        "entries_with_dimension_gap",
        "entries_with_owner_gap",
        "entries_with_freeze_gap",
        "entries_eol_undisclosed",
        "release_blocking_total",
        "release_blocking_certified",
        "release_blocking_narrowed",
        "core_platform_entries",
        "ai_assistant_entries",
        "collaboration_entries",
        "extensions_entries",
        "first_party_entries",
        "verified_partner_entries",
        "community_entries",
        "untrusted_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_narrowing_reasons",
        "total_compatibility_cells",
        "cells_pass",
        "cells_partial",
        "cells_fail",
        "cells_waived",
        "cells_missing",
        "rules_firing"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "entries_certified": { "type": "integer", "minimum": 0 },
        "entries_narrowed": { "type": "integer", "minimum": 0 },
        "entries_on_active_waiver": { "type": "integer", "minimum": 0 },
        "entries_with_dimension_gap": { "type": "integer", "minimum": 0 },
        "entries_with_owner_gap": { "type": "integer", "minimum": 0 },
        "entries_with_freeze_gap": { "type": "integer", "minimum": 0 },
        "entries_eol_undisclosed": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_certified": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "core_platform_entries": { "type": "integer", "minimum": 0 },
        "ai_assistant_entries": { "type": "integer", "minimum": 0 },
        "collaboration_entries": { "type": "integer", "minimum": 0 },
        "extensions_entries": { "type": "integer", "minimum": 0 },
        "first_party_entries": { "type": "integer", "minimum": 0 },
        "verified_partner_entries": { "type": "integer", "minimum": 0 },
        "community_entries": { "type": "integer", "minimum": 0 },
        "untrusted_entries": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_active_narrowing_reasons": { "type": "integer", "minimum": 0 },
        "total_compatibility_cells": { "type": "integer", "minimum": 0 },
        "cells_pass": { "type": "integer", "minimum": 0 },
        "cells_partial": { "type": "integer", "minimum": 0 },
        "cells_fail": { "type": "integer", "minimum": 0 },
        "cells_waived": { "type": "integer", "minimum": 0 },
        "cells_missing": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
