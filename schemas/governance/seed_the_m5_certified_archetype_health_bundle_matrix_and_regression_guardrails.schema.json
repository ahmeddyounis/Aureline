{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "M5CertifiedArchetypeHealthBundleMatrix",
  "description": "Schema for the M5 certified-archetype health-bundle matrix and regression guardrails.",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "matrix_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "certified_reference_workspaces_ref",
    "lifecycle_labels",
    "archetype_kinds",
    "bundle_kinds",
    "indicator_states",
    "bundle_states",
    "gap_reasons",
    "guardrail_actions",
    "launch_cutline",
    "release_blocking_archetype_refs",
    "stop_rules",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1
    },
    "record_kind": {
      "type": "string",
      "const": "seed_the_m5_certified_archetype_health_bundle_matrix_and_regression_guardrails"
    },
    "matrix_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "overview_page": {
      "type": "string",
      "minLength": 1
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "claim_manifest_ref": {
      "type": "string",
      "minLength": 1
    },
    "certified_reference_workspaces_ref": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "lts",
          "stable",
          "beta",
          "preview",
          "withdrawn"
        ]
      }
    },
    "archetype_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "notebook",
          "data_rich",
          "ai_adjacent",
          "framework",
          "review",
          "companion",
          "managed_depth"
        ]
      }
    },
    "bundle_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "test_coverage",
          "benchmark_health",
          "compatibility_health",
          "dependency_health",
          "security_posture",
          "accessibility_health",
          "localization_health"
        ]
      }
    },
    "indicator_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "green",
          "yellow",
          "red",
          "missing"
        ]
      }
    },
    "bundle_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "healthy",
          "degraded",
          "regressed",
          "missing",
          "on_waiver"
        ]
      }
    },
    "gap_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "health_indicator_red",
          "health_indicator_missing",
          "health_bundle_stale",
          "health_bundle_missing",
          "benchmark_regression_detected",
          "compatibility_surface_regressed",
          "security_scan_failed",
          "accessibility_signoff_incomplete",
          "waiver_expired",
          "owner_signoff_missing"
        ]
      }
    },
    "guardrail_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "hold_publication",
          "narrow_label",
          "refresh_health_bundle",
          "request_owner_signoff",
          "recapture_benchmarks",
          "re_run_security_scan"
        ]
      }
    },
    "launch_cutline": {
      "type": "object",
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": {
          "type": "string",
          "enum": [
            "lts",
            "stable",
            "beta",
            "preview",
            "withdrawn"
          ]
        },
        "above_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "release_blocking_archetype_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stop_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "title",
          "trigger_reason",
          "applies_to_labels",
          "default_action",
          "blocks_publication",
          "rationale"
        ],
        "properties": {
          "rule_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "trigger_reason": {
            "type": "string",
            "enum": [
              "health_indicator_red",
              "health_indicator_missing",
              "health_bundle_stale",
              "health_bundle_missing",
              "benchmark_regression_detected",
              "compatibility_surface_regressed",
              "security_scan_failed",
              "accessibility_signoff_incomplete",
              "waiver_expired",
              "owner_signoff_missing"
            ]
          },
          "applies_to_labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "default_action": {
            "type": "string",
            "enum": [
              "hold_publication",
              "narrow_label",
              "refresh_health_bundle",
              "request_owner_signoff",
              "recapture_benchmarks",
              "re_run_security_scan"
            ]
          },
          "blocks_publication": {
            "type": "boolean"
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entry_id",
          "title",
          "archetype_kind",
          "surface_ref",
          "surface_summary",
          "release_blocking",
          "claim_ref",
          "claim_label",
          "health_bundle",
          "bundle_state",
          "proof_packet",
          "owner_signoff",
          "active_gap_reasons",
          "published_label",
          "rationale"
        ],
        "properties": {
          "entry_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "archetype_kind": {
            "type": "string",
            "enum": [
              "notebook",
              "data_rich",
              "ai_adjacent",
              "framework",
              "review",
              "companion",
              "managed_depth"
            ]
          },
          "surface_ref": {
            "type": "string",
            "minLength": 1
          },
          "surface_summary": {
            "type": "string",
            "minLength": 1
          },
          "release_blocking": {
            "type": "boolean"
          },
          "claim_ref": {
            "type": "string",
            "minLength": 1
          },
          "claim_label": {
            "type": "string",
            "enum": [
              "lts",
              "stable",
              "beta",
              "preview",
              "withdrawn"
            ]
          },
          "health_bundle": {
            "type": "object",
            "required": [
              "bundle_id",
              "bundle_version",
              "bundle_kind",
              "indicators"
            ],
            "properties": {
              "bundle_id": {
                "type": "string",
                "minLength": 1
              },
              "bundle_version": {
                "type": "integer",
                "minimum": 1
              },
              "bundle_kind": {
                "type": "string",
                "enum": [
                  "test_coverage",
                  "benchmark_health",
                  "compatibility_health",
                  "dependency_health",
                  "security_posture",
                  "accessibility_health",
                  "localization_health"
                ]
              },
              "indicators": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "indicator_id",
                    "title",
                    "indicator_kind",
                    "required",
                    "state",
                    "rationale"
                  ],
                  "properties": {
                    "indicator_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "title": {
                      "type": "string",
                      "minLength": 1
                    },
                    "indicator_kind": {
                      "type": "string",
                      "enum": [
                        "unit_test_pass_rate",
                        "integration_test_pass_rate",
                        "benchmark_regression",
                        "compatibility_surface_coverage",
                        "dependency_freshness",
                        "security_scan_clean",
                        "accessibility_signoff_coverage"
                      ]
                    },
                    "required": {
                      "type": "boolean"
                    },
                    "state": {
                      "type": "string",
                      "enum": [
                        "green",
                        "yellow",
                        "red",
                        "missing"
                      ]
                    },
                    "rationale": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          },
          "bundle_state": {
            "type": "string",
            "enum": [
              "healthy",
              "degraded",
              "regressed",
              "missing",
              "on_waiver"
            ]
          },
          "proof_packet": {
            "type": "object",
            "required": [
              "packet_id",
              "packet_ref",
              "proof_index_ref",
              "freshness_slo",
              "slo_state"
            ],
            "properties": {
              "packet_id": {
                "type": "string",
                "minLength": 1
              },
              "packet_ref": {
                "type": "string",
                "minLength": 1
              },
              "proof_index_ref": {
                "type": "string",
                "minLength": 1
              },
              "captured_at": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "freshness_slo": {
                "type": "object",
                "required": [
                  "target_max_age_days",
                  "warn_within_days",
                  "slo_register_ref"
                ],
                "properties": {
                  "target_max_age_days": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "warn_within_days": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "slo_register_ref": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "slo_state": {
                "type": "string",
                "enum": [
                  "current",
                  "due_for_refresh",
                  "breached",
                  "missing"
                ]
              },
              "evidence_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "waiver": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "waiver_ref",
              "expires_at",
              "reason"
            ],
            "properties": {
              "waiver_ref": {
                "type": "string",
                "minLength": 1
              },
              "expires_at": {
                "type": "string",
                "format": "date"
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "owner_signoff": {
            "type": "object",
            "required": [
              "owner_ref",
              "signed_off"
            ],
            "properties": {
              "owner_ref": {
                "type": "string",
                "minLength": 1
              },
              "signed_off": {
                "type": "boolean"
              },
              "signed_at": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "active_gap_reasons": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "health_indicator_red",
                "health_indicator_missing",
                "health_bundle_stale",
                "health_bundle_missing",
                "benchmark_regression_detected",
                "compatibility_surface_regressed",
                "security_scan_failed",
                "accessibility_signoff_incomplete",
                "waiver_expired",
                "owner_signoff_missing"
              ]
            }
          },
          "published_label": {
            "type": "string",
            "enum": [
              "lts",
              "stable",
              "beta",
              "preview",
              "withdrawn"
            ]
          },
          "publication_destinations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "publication": {
      "type": "object",
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_claim_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "proceed",
            "hold"
          ]
        },
        "blocking_rule_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking_claim_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total_entries",
        "total_claims",
        "entries_holding_stable",
        "entries_narrowed",
        "entries_on_active_waiver",
        "entries_owner_blocked",
        "release_blocking_total",
        "release_blocking_holding",
        "release_blocking_narrowed",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "indicators_green",
        "indicators_yellow",
        "indicators_red",
        "indicators_missing",
        "total_active_gap_reasons",
        "rules_firing"
      ]
    }
  }
}