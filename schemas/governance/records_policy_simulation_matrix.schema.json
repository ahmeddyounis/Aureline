{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/records_policy_simulation_matrix.schema.json",
  "title": "Records, deletion, chronology, and policy simulation matrix",
  "description": "Schema for the records_policy_simulation_matrix packet. The packet freezes one governed row per durable managed/provider/support artifact family, naming the governing record class, local-versus-managed authority boundary, delete/export honesty posture, chronology contract, policy-simulation coverage, proof freshness, and the consumer surfaces that must ingest the packet directly. The packet is metadata-only and carries no raw payloads, secrets, or durable content bodies.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "matrix_id",
    "shared_contract_ref",
    "as_of",
    "status",
    "overview_page",
    "artifact_summary_ref",
    "consumer_bindings",
    "artifact_families",
    "consumer_surfaces",
    "chronology_classes",
    "proof_freshness_states",
    "qualification_states",
    "gap_reasons",
    "release_blocking_family_refs",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "record_kind": {
      "const": "records_policy_simulation_matrix"
    },
    "matrix_id": {
      "type": "string",
      "minLength": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "minLength": 1
    },
    "as_of": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "overview_page": {
      "type": "string",
      "minLength": 1
    },
    "artifact_summary_ref": {
      "type": "string",
      "minLength": 1
    },
    "consumer_bindings": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["surface_class", "consumer_ref", "projection_rule"],
        "properties": {
          "surface_class": {
            "enum": ["product", "cli_headless", "help_docs", "support_export", "release_evidence"]
          },
          "consumer_ref": {
            "type": "string",
            "minLength": 1
          },
          "projection_rule": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "artifact_families": {
      "type": "array",
      "minItems": 8,
      "items": {
        "enum": [
          "ai_evidence_packet",
          "provider_linked_work_item",
          "companion_continuity_packet",
          "incident_support_packet",
          "sync_mirror_ledger",
          "offboarding_record",
          "browser_handoff_manifest",
          "support_export_packet"
        ]
      }
    },
    "consumer_surfaces": {
      "type": "array",
      "minItems": 5,
      "items": {
        "enum": ["product", "cli_headless", "help_docs", "support_export", "release_evidence"]
      }
    },
    "chronology_classes": {
      "type": "array",
      "minItems": 3,
      "items": {
        "enum": ["live", "imported", "reconstructed"]
      }
    },
    "proof_freshness_states": {
      "type": "array",
      "items": {
        "enum": ["current", "stale", "missing"]
      }
    },
    "qualification_states": {
      "type": "array",
      "items": {
        "enum": ["stable", "needs_review"]
      }
    },
    "gap_reasons": {
      "type": "array",
      "items": {
        "enum": [
          "managed_delete_overclaimed",
          "managed_export_overclaimed",
          "managed_hold_overclaimed",
          "chronology_contract_incomplete",
          "policy_simulation_missing",
          "remembered_decision_revalidation_missing",
          "proof_stale",
          "proof_missing",
          "consumer_coverage_missing"
        ]
      }
    },
    "release_blocking_family_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rows": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entry_id",
          "title",
          "artifact_family",
          "release_blocking",
          "record_class_id",
          "authority_boundary",
          "local_truth_authority",
          "managed_copy_posture",
          "local_owner_ref",
          "managed_owner_ref",
          "claims_managed_hold",
          "claims_managed_export",
          "claims_managed_delete",
          "delete_state",
          "export_state",
          "chronology_contract",
          "policy_contract",
          "proof_ref",
          "proof_freshness",
          "published_qualification",
          "active_gap_reasons",
          "docs_refs",
          "rationale"
        ],
        "properties": {
          "entry_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "artifact_family": {
            "enum": [
              "ai_evidence_packet",
              "provider_linked_work_item",
              "companion_continuity_packet",
              "incident_support_packet",
              "sync_mirror_ledger",
              "offboarding_record",
              "browser_handoff_manifest",
              "support_export_packet"
            ]
          },
          "release_blocking": { "type": "boolean" },
          "record_class_id": { "type": "string", "minLength": 1 },
          "authority_boundary": {
            "enum": ["local_only", "managed_only", "local_and_managed"]
          },
          "local_truth_authority": { "type": "string", "minLength": 1 },
          "managed_copy_posture": { "type": "string", "minLength": 1 },
          "local_owner_ref": { "type": "string", "minLength": 1 },
          "managed_owner_ref": { "type": "string", "minLength": 1 },
          "claims_managed_hold": { "type": "boolean" },
          "claims_managed_export": { "type": "boolean" },
          "claims_managed_delete": { "type": "boolean" },
          "delete_state": { "type": "string", "minLength": 1 },
          "export_state": { "type": "string", "minLength": 1 },
          "chronology_contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "absolute_time_required",
              "local_context_required",
              "source_required",
              "actor_lineage_required",
              "chronology_classes"
            ],
            "properties": {
              "absolute_time_required": { "type": "boolean" },
              "local_context_required": { "type": "boolean" },
              "source_required": { "type": "boolean" },
              "actor_lineage_required": { "type": "boolean" },
              "chronology_classes": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "enum": ["live", "imported", "reconstructed"]
                }
              }
            }
          },
          "policy_contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "policy_owner_ref",
              "policy_simulation_required",
              "exception_preview_required",
              "remembered_decision_revalidation_required",
              "required_reapproval_trigger_tokens"
            ],
            "properties": {
              "policy_owner_ref": { "type": "string", "minLength": 1 },
              "policy_simulation_required": { "type": "boolean" },
              "exception_preview_required": { "type": "boolean" },
              "remembered_decision_revalidation_required": { "type": "boolean" },
              "required_reapproval_trigger_tokens": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "proof_ref": { "type": "string", "minLength": 1 },
          "proof_freshness": { "enum": ["current", "stale", "missing"] },
          "published_qualification": { "enum": ["stable", "needs_review"] },
          "active_gap_reasons": {
            "type": "array",
            "items": {
              "enum": [
                "managed_delete_overclaimed",
                "managed_export_overclaimed",
                "managed_hold_overclaimed",
                "chronology_contract_incomplete",
                "policy_simulation_missing",
                "remembered_decision_revalidation_missing",
                "proof_stale",
                "proof_missing",
                "consumer_coverage_missing"
              ]
            }
          },
          "docs_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publication_gate", "decision", "blocking_row_ids", "rationale"],
      "properties": {
        "publication_gate": { "type": "string", "minLength": 1 },
        "decision": { "enum": ["proceed", "hold"] },
        "blocking_row_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows",
        "total_families",
        "release_blocking_rows",
        "stable_rows",
        "needs_review_rows",
        "proof_current_rows",
        "proof_stale_rows",
        "proof_missing_rows",
        "total_active_gap_reasons",
        "consumer_binding_count"
      ],
      "properties": {
        "total_rows": { "type": "integer", "minimum": 0 },
        "total_families": { "type": "integer", "minimum": 0 },
        "release_blocking_rows": { "type": "integer", "minimum": 0 },
        "stable_rows": { "type": "integer", "minimum": 0 },
        "needs_review_rows": { "type": "integer", "minimum": 0 },
        "proof_current_rows": { "type": "integer", "minimum": 0 },
        "proof_stale_rows": { "type": "integer", "minimum": 0 },
        "proof_missing_rows": { "type": "integer", "minimum": 0 },
        "total_active_gap_reasons": { "type": "integer", "minimum": 0 },
        "consumer_binding_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
