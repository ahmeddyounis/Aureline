{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/requirement_register.schema.json",
  "title": "Canonical requirement register",
  "description": "Machine-readable register of canonical requirement ids and the alias crosswalks that milestone packets, scorecards, waivers, CI, docs, and release evidence cite. The canonical requirement id is the only binding identity. Aliases and local labels remain non-authoritative references that must resolve back to one or more canonical rows in this register.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "register_id",
    "scope",
    "owners",
    "canonical_rules",
    "source_documents",
    "requirement_rows",
    "crosswalk_rows"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "register_id": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seed_focus",
        "default_milestone_language",
        "status_vocabulary",
        "verification_class_vocabulary"
      ],
      "properties": {
        "seed_focus": {
          "type": "string",
          "minLength": 1,
          "description": "Narrative summary of the current seed scope."
        },
        "default_milestone_language": {
          "$ref": "#/$defs/milestone_slug"
        },
        "status_vocabulary": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/requirement_status" }
        },
        "verification_class_vocabulary": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/verification_class" }
        }
      }
    },
    "owners": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_owner", "evidence_owner", "approving_forums"],
      "properties": {
        "primary_owner": {
          "type": "string",
          "minLength": 1
        },
        "evidence_owner": {
          "type": "string",
          "minLength": 1
        },
        "approving_forums": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "canonical_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id_pattern",
        "citation_rule",
        "alias_rule",
        "non_requirement_label_rule"
      ],
      "properties": {
        "id_pattern": {
          "type": "string",
          "minLength": 1
        },
        "citation_rule": {
          "type": "string",
          "minLength": 1
        },
        "alias_rule": {
          "type": "string",
          "minLength": 1
        },
        "non_requirement_label_rule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_documents": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source_document" }
    },
    "requirement_rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/requirement_row" }
    },
    "crosswalk_rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/crosswalk_row" }
    }
  },
  "$defs": {
    "requirement_id": {
      "type": "string",
      "pattern": "^[A-Z0-9]+-[A-Z0-9]+-[0-9]{3}$",
      "description": "Canonical requirement id using the PRD's <CLASS>-<DOMAIN>-<NNN> pattern."
    },
    "milestone_slug": {
      "type": "string",
      "enum": [
        "foundations",
        "prototype",
        "alpha",
        "first_beta",
        "stable_v1",
        "feature_train_v1",
        "major_v2"
      ]
    },
    "requirement_class": {
      "type": "string",
      "enum": [
        "FR",
        "LANG",
        "PERF",
        "REL",
        "SEC",
        "A11Y",
        "ECOS",
        "AI",
        "OPS",
        "GOV",
        "ARCH",
        "TOOL",
        "CERT",
        "ENT",
        "REPO",
        "COMP"
      ]
    },
    "requirement_status": {
      "type": "string",
      "enum": [
        "proposed",
        "approved",
        "in_progress",
        "implemented",
        "verified",
        "waived",
        "deprecated",
        "removed"
      ]
    },
    "verification_class": {
      "type": "string",
      "enum": [
        "BENCH",
        "CONF",
        "RELTEST",
        "SECREV",
        "A11YTEST",
        "UXVAL",
        "OPSVAL",
        "DOCVAL"
      ]
    },
    "source_document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doc_ref", "purpose"],
      "properties": {
        "doc_ref": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doc_ref", "anchor", "note"],
      "properties": {
        "doc_ref": {
          "type": "string",
          "minLength": 1
        },
        "anchor": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "requirement_alias": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alias_id", "alias_kind", "source_ref", "note"],
      "properties": {
        "alias_id": {
          "type": "string",
          "minLength": 1
        },
        "alias_kind": {
          "type": "string",
          "enum": [
            "spec_local_requirement_id",
            "legacy_requirement_id",
            "superseded_requirement_id"
          ]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "requirement_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "summary",
        "requirement_class",
        "target_milestones",
        "verification_classes",
        "primary_owner",
        "evidence_owner",
        "status",
        "source_anchors",
        "primary_evidence_refs",
        "aliases"
      ],
      "properties": {
        "requirement_id": { "$ref": "#/$defs/requirement_id" },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "requirement_class": { "$ref": "#/$defs/requirement_class" },
        "target_milestones": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/milestone_slug" }
        },
        "verification_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/verification_class" }
        },
        "primary_owner": {
          "type": "string",
          "minLength": 1
        },
        "evidence_owner": {
          "type": "string",
          "minLength": 1
        },
        "status": { "$ref": "#/$defs/requirement_status" },
        "status_note": {
          "type": "string"
        },
        "owning_lanes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_anchors": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source_anchor" }
        },
        "primary_evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "aliases": {
          "type": "array",
          "items": { "$ref": "#/$defs/requirement_alias" }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "crosswalk_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_label",
        "local_label_kind",
        "source_ref",
        "canonical_requirement_ids",
        "mapping_rule"
      ],
      "properties": {
        "local_label": {
          "type": "string",
          "minLength": 1
        },
        "local_label_kind": {
          "type": "string",
          "enum": [
            "milestone_exit_item",
            "scorecard_call",
            "contract_family",
            "packet_label",
            "fitness_row",
            "spec_local_requirement_id"
          ]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "canonical_requirement_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/requirement_id" }
        },
        "mapping_rule": {
          "type": "string",
          "enum": [
            "direct_alias",
            "many_to_many_coverage",
            "supporting_metric",
            "supporting_packet",
            "superseded_name",
            "taxonomy_normalization"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
