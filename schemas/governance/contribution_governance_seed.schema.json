{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/contribution_governance_seed.schema.json",
  "title": "Aureline M1 contribution-governance seed envelope",
  "description": "Boundary schema for artifacts/governance/contribution_governance_seed.yaml. The envelope pins the canonical row vocabulary at contribution_governance_seed_row.schema.json, the import-record register the seed companions, the required control coverage, the row vocabularies (control / artifact-kind / enforcement / lifecycle / consumer classes), and the named external refs the validation lane resolves. Rows themselves conform to contribution_governance_seed_row.schema.json; the envelope cannot relax that contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "matrix_id",
    "owner_dri",
    "overview_page",
    "row_schema_ref",
    "import_record_register_ref",
    "build_identity_ref",
    "validation_lane_ref",
    "control_class_vocabulary",
    "artifact_kind_class_vocabulary",
    "enforcement_class_vocabulary",
    "lifecycle_state_class_vocabulary",
    "contribution_governance_consumer_class_vocabulary",
    "required_control_class_coverage",
    "rows"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": ["seeded", "stabilising", "stable"]
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "matrix_id": {
      "type": "string",
      "const": "m1_contribution_governance_seed"
    },
    "owner_dri": {
      "type": "string",
      "pattern": "^@[a-zA-Z0-9_-]+$"
    },
    "overview_page": {
      "type": "string",
      "minLength": 1
    },
    "row_schema_ref": {
      "type": "string",
      "const": "schemas/governance/contribution_governance_seed_row.schema.json"
    },
    "import_record_register_ref": {
      "type": "string",
      "const": "artifacts/governance/import_record_seed.yaml"
    },
    "build_identity_ref": {
      "type": "string",
      "minLength": 1
    },
    "validation_lane_ref": {
      "type": "string",
      "minLength": 1
    },
    "control_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 6,
      "items": { "type": "string", "minLength": 1 }
    },
    "artifact_kind_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 6,
      "items": { "type": "string", "minLength": 1 }
    },
    "enforcement_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": { "type": "string", "minLength": 1 }
    },
    "lifecycle_state_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "contribution_governance_consumer_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "failure_drill_id_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_control_class_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 6,
      "items": {
        "type": "string",
        "enum": [
          "signoff_dco",
          "license_metadata",
          "third_party_import_record",
          "public_interface_versioning",
          "deprecation_packet_template",
          "repo_hygiene_scaffold"
        ]
      },
      "description": "Required control-class coverage for the M1 seed. All six control families MUST appear with at least one row."
    },
    "control_class_to_artifact_kind_class": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signoff_dco",
        "license_metadata",
        "third_party_import_record",
        "public_interface_versioning",
        "deprecation_packet_template",
        "repo_hygiene_scaffold"
      ],
      "properties": {
        "signoff_dco": { "const": "developer_certificate_contract" },
        "license_metadata": { "const": "spdx_license_metadata_policy" },
        "third_party_import_record": { "const": "third_party_import_register" },
        "public_interface_versioning": { "const": "public_interface_versioning_policy" },
        "deprecation_packet_template": { "const": "deprecation_packet_template" },
        "repo_hygiene_scaffold": { "const": "repo_hygiene_scaffolding" }
      }
    },
    "control_class_to_enforcement_class": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signoff_dco",
        "license_metadata",
        "third_party_import_record",
        "public_interface_versioning",
        "deprecation_packet_template",
        "repo_hygiene_scaffold"
      ],
      "properties": {
        "signoff_dco": { "const": "ci_required" },
        "license_metadata": { "const": "repo_hygiene_required" },
        "third_party_import_record": { "const": "repo_hygiene_required" },
        "public_interface_versioning": { "const": "release_review_required" },
        "deprecation_packet_template": { "const": "contributor_documentation" },
        "repo_hygiene_scaffold": { "const": "contributor_documentation" }
      }
    },
    "rows": {
      "type": "array",
      "minItems": 6,
      "items": {
        "$ref": "contribution_governance_seed_row.schema.json"
      }
    }
  }
}
