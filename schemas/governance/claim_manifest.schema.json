{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/claim_manifest.schema.json",
  "title": "Aureline public-truth claim manifest",
  "description": "Boundary schema for the public-truth claim manifest packet and its reusable claim_row records. A claim row binds one canonical public statement to requirement ids, evidence packets, lifecycle and support-window state, docs/help/service-health destinations, known-limit or exclusion notes, exact-build or version-skew anchors, and launch-wedge or certified-archetype refs so docs, release packets, Help/About, service health, support exports, CLI/help, evaluation artifacts, marketplace-style discovery, and public-proof packets do not invent contradictory copy. Missing, stale, or narrower-than-claim evidence forces a downgraded effective posture rather than silent optimism.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/claim_manifest_packet" },
    { "$ref": "#/$defs/claim_row" }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "ref_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "requirement_id": {
      "type": "string",
      "pattern": "^[A-Z]+-[A-Z0-9]+-[0-9]{3}$"
    },
    "requirement_id_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/requirement_id"
      }
    },
    "claim_row_id": {
      "type": "string",
      "pattern": "^claim_row:[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "description": "Stable claim-row id safe to quote across docs, release packets, support exports, CLI/help, and proof packets."
    },
    "claim_family": {
      "type": "string",
      "enum": [
        "boundary_truth",
        "exact_build_identity",
        "benchmark_publication",
        "docs_freshness",
        "version_skew_truth",
        "launch_wedge",
        "certified_archetype"
      ]
    },
    "claim_posture": {
      "type": "string",
      "enum": [
        "claim_bearing",
        "experimental",
        "limited",
        "policy_disabled",
        "replacement_grade",
        "seed_only",
        "withdrawn"
      ],
      "description": "Effective public-truth posture. claim_bearing is the normal publishable case; the remaining values narrow or withdraw the claim explicitly."
    },
    "support_window_state": {
      "type": "string",
      "enum": [
        "current",
        "narrowed",
        "expired",
        "not_applicable"
      ]
    },
    "evidence_kind": {
      "type": "string",
      "enum": [
        "boundary_manifest_row",
        "release_evidence_packet",
        "compatibility_report",
        "benchmark_publication_pack",
        "exact_build_identity_record",
        "docs_help_truth_record",
        "migration_notice_pack",
        "known_limit_note",
        "certified_archetype_report",
        "evaluation_artifact",
        "support_export_projection"
      ]
    },
    "evidence_result_status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "mixed",
        "waived",
        "seed_only",
        "needs_review",
        "blocked",
        "not_applicable"
      ]
    },
    "freshness_expectation": {
      "type": "string",
      "enum": [
        "must_be_current",
        "may_be_warm_cached",
        "seed_only_allowed",
        "not_applicable"
      ]
    },
    "link_requirement": {
      "type": "string",
      "enum": [
        "required",
        "advisory"
      ]
    },
    "narrower_than_claim_mode": {
      "type": "string",
      "enum": [
        "downgrade_claim",
        "route_only",
        "fail_closed"
      ]
    },
    "binding_status": {
      "type": "string",
      "enum": [
        "required",
        "optional",
        "not_applicable",
        "must_not_claim"
      ]
    },
    "projection_kind": {
      "type": "string",
      "enum": [
        "verbatim_claim",
        "narrowed_summary",
        "status_badge_only",
        "repair_only",
        "known_limit_link_only",
        "packet_reference_only"
      ]
    },
    "stale_behavior": {
      "type": "string",
      "enum": [
        "downgrade_to_limited",
        "downgrade_to_experimental",
        "hide_claim_and_route_to_repair",
        "show_known_limit_only"
      ]
    },
    "copy_field": {
      "type": "string",
      "enum": [
        "headline",
        "claim_text",
        "experimental_text",
        "limited_text",
        "policy_disabled_text",
        "replacement_text",
        "stale_text"
      ]
    },
    "channel_id": {
      "type": "string",
      "enum": [
        "docs_site",
        "migration_notes",
        "help_about",
        "service_health",
        "support_export",
        "release_packet",
        "release_notes",
        "cli_help",
        "evaluation_artifact",
        "marketplace_discovery",
        "public_proof_packet"
      ]
    },
    "projection_field": {
      "type": "string",
      "enum": [
        "claim_row_id",
        "effective_claim_posture",
        "headline",
        "requirement_ids",
        "compatibility_row_refs",
        "version_skew_register_refs",
        "boundary_manifest_refs",
        "exact_build_identity_refs",
        "known_limit_refs",
        "exclusion_note_refs",
        "launch_bundle_refs",
        "certified_archetype_refs",
        "evidence_links",
        "support_window_state",
        "service_health_state"
      ]
    },
    "projection_field_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/projection_field"
      }
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "required_evidence_missing",
        "required_evidence_stale",
        "required_evidence_narrower_than_claim",
        "docs_version_mismatch",
        "docs_freshness_floor_unmet",
        "known_limit_missing",
        "compatibility_row_degraded",
        "support_window_expired",
        "policy_disabled",
        "replacement_available"
      ]
    },
    "route_channel": {
      "type": "string",
      "enum": [
        "docs_site",
        "migration_notes",
        "help_about",
        "service_health",
        "support_export",
        "release_packet",
        "release_notes",
        "cli_help",
        "evaluation_artifact",
        "marketplace_discovery",
        "public_proof_packet",
        "repair_hook"
      ]
    },
    "canonical_copy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headline",
        "claim_text",
        "experimental_text",
        "limited_text",
        "policy_disabled_text",
        "replacement_text",
        "stale_text"
      ],
      "properties": {
        "headline": { "$ref": "#/$defs/non_empty_string" },
        "claim_text": { "$ref": "#/$defs/non_empty_string" },
        "experimental_text": { "$ref": "#/$defs/non_empty_string" },
        "limited_text": { "$ref": "#/$defs/non_empty_string" },
        "policy_disabled_text": { "$ref": "#/$defs/non_empty_string" },
        "replacement_text": { "$ref": "#/$defs/non_empty_string" },
        "stale_text": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "claim_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_channels",
        "deployment_profiles",
        "client_scopes"
      ],
      "properties": {
        "release_channels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "evidence_packet_header.schema.json#/$defs/channel_context"
          }
        },
        "deployment_profiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "evidence_packet_header.schema.json#/$defs/deployment_context"
          }
        },
        "client_scopes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "capability_lifecycle.schema.json#/$defs/client_scope"
          }
        }
      }
    },
    "lifecycle_support": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lifecycle_state",
        "support_class",
        "support_window_state",
        "support_window_ref",
        "replacement_claim_row_ref"
      ],
      "properties": {
        "lifecycle_state": {
          "$ref": "capability_lifecycle.schema.json#/$defs/lifecycle_state"
        },
        "support_class": {
          "$ref": "capability_lifecycle.schema.json#/$defs/support_class"
        },
        "support_window_state": {
          "$ref": "#/$defs/support_window_state"
        },
        "support_window_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "replacement_claim_row_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/claim_row_id" }
          ]
        }
      }
    },
    "claim_evidence_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_evidence_id",
        "evidence_kind",
        "packet_ref",
        "evidence_id_refs",
        "freshness_expectation",
        "minimum_result_status",
        "link_requirement",
        "known_limit_ref",
        "narrower_than_claim_mode",
        "note"
      ],
      "properties": {
        "claim_evidence_id": {
          "type": "string",
          "pattern": "^claim_evidence:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
        },
        "evidence_kind": {
          "$ref": "#/$defs/evidence_kind"
        },
        "packet_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_id_refs": {
          "type": "array",
          "items": {
            "$ref": "evidence_packet_header.schema.json#/$defs/evidence_id"
          }
        },
        "freshness_expectation": {
          "$ref": "#/$defs/freshness_expectation"
        },
        "minimum_result_status": {
          "$ref": "#/$defs/evidence_result_status"
        },
        "link_requirement": {
          "$ref": "#/$defs/link_requirement"
        },
        "known_limit_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/non_empty_string" }
          ]
        },
        "narrower_than_claim_mode": {
          "$ref": "#/$defs/narrower_than_claim_mode"
        },
        "note": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "channel_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_status",
        "surface_ref",
        "projection_kind",
        "copy_field",
        "required_projection_fields",
        "required_known_limit_refs",
        "minimum_version_match_state",
        "minimum_freshness_class",
        "service_health_state_when_current",
        "service_health_state_when_downgraded",
        "stale_behavior",
        "notes"
      ],
      "properties": {
        "binding_status": {
          "$ref": "#/$defs/binding_status"
        },
        "surface_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "projection_kind": {
          "$ref": "#/$defs/projection_kind"
        },
        "copy_field": {
          "$ref": "#/$defs/copy_field"
        },
        "required_projection_fields": {
          "$ref": "#/$defs/projection_field_array"
        },
        "required_known_limit_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "minimum_version_match_state": {
          "oneOf": [
            { "const": "not_applicable" },
            { "$ref": "../docs/help_status_badge.schema.json#/$defs/version_match_state" }
          ]
        },
        "minimum_freshness_class": {
          "oneOf": [
            { "const": "not_applicable" },
            { "$ref": "../docs/help_status_badge.schema.json#/$defs/freshness_class" }
          ]
        },
        "service_health_state_when_current": {
          "oneOf": [
            { "const": "not_applicable" },
            { "$ref": "../docs/help_status_badge.schema.json#/$defs/service_contract_state" }
          ]
        },
        "service_health_state_when_downgraded": {
          "oneOf": [
            { "const": "not_applicable" },
            { "$ref": "../docs/help_status_badge.schema.json#/$defs/service_contract_state" }
          ]
        },
        "stale_behavior": {
          "$ref": "#/$defs/stale_behavior"
        },
        "notes": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "channel_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "docs_site",
        "migration_notes",
        "help_about",
        "service_health",
        "support_export",
        "release_packet",
        "release_notes",
        "cli_help",
        "evaluation_artifact",
        "marketplace_discovery",
        "public_proof_packet"
      ],
      "properties": {
        "docs_site": { "$ref": "#/$defs/channel_binding" },
        "migration_notes": { "$ref": "#/$defs/channel_binding" },
        "help_about": { "$ref": "#/$defs/channel_binding" },
        "service_health": { "$ref": "#/$defs/channel_binding" },
        "support_export": { "$ref": "#/$defs/channel_binding" },
        "release_packet": { "$ref": "#/$defs/channel_binding" },
        "release_notes": { "$ref": "#/$defs/channel_binding" },
        "cli_help": { "$ref": "#/$defs/channel_binding" },
        "evaluation_artifact": { "$ref": "#/$defs/channel_binding" },
        "marketplace_discovery": { "$ref": "#/$defs/channel_binding" },
        "public_proof_packet": { "$ref": "#/$defs/channel_binding" }
      }
    },
    "claim_failure_mode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger",
        "downgrade_to",
        "route_channels",
        "notes"
      ],
      "properties": {
        "trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "downgrade_to": {
          "$ref": "#/$defs/claim_posture"
        },
        "route_channels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/route_channel"
          }
        },
        "notes": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "downgrade_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fail_closed",
        "required_known_limit_refs",
        "required_exclusion_note_refs",
        "failure_modes"
      ],
      "properties": {
        "fail_closed": {
          "type": "boolean"
        },
        "required_known_limit_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "required_exclusion_note_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "failure_modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/claim_failure_mode"
          }
        }
      }
    },
    "claim_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "claim_row_id",
        "claim_family",
        "canonical_copy",
        "requirement_ids",
        "source_anchor_refs",
        "compatibility_row_refs",
        "version_skew_register_refs",
        "boundary_manifest_refs",
        "exact_build_identity_refs",
        "launch_bundle_refs",
        "certified_archetype_refs",
        "claim_scope",
        "lifecycle_support",
        "declared_claim_posture",
        "effective_claim_posture",
        "active_downgrade_reasons",
        "evidence_links",
        "known_limit_refs",
        "exclusion_note_refs",
        "channel_bindings",
        "downgrade_policy",
        "notes"
      ],
      "properties": {
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "record_kind": {
          "type": "string",
          "const": "claim_row"
        },
        "claim_row_id": {
          "$ref": "#/$defs/claim_row_id"
        },
        "claim_family": {
          "$ref": "#/$defs/claim_family"
        },
        "canonical_copy": {
          "$ref": "#/$defs/canonical_copy"
        },
        "requirement_ids": {
          "$ref": "#/$defs/requirement_id_array"
        },
        "source_anchor_refs": {
          "allOf": [
            { "$ref": "#/$defs/ref_array" },
            { "minItems": 1 }
          ]
        },
        "compatibility_row_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^compat_row:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
          }
        },
        "version_skew_register_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^skew_register:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
          }
        },
        "boundary_manifest_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "exact_build_identity_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "launch_bundle_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "certified_archetype_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "claim_scope": {
          "$ref": "#/$defs/claim_scope"
        },
        "lifecycle_support": {
          "$ref": "#/$defs/lifecycle_support"
        },
        "declared_claim_posture": {
          "$ref": "#/$defs/claim_posture"
        },
        "effective_claim_posture": {
          "$ref": "#/$defs/claim_posture"
        },
        "active_downgrade_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "evidence_links": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/claim_evidence_link"
          }
        },
        "known_limit_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "exclusion_note_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "channel_bindings": {
          "$ref": "#/$defs/channel_bindings"
        },
        "downgrade_policy": {
          "$ref": "#/$defs/downgrade_policy"
        },
        "notes": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "channel_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel_id",
        "owner_lane",
        "description",
        "primary_surface_ref"
      ],
      "properties": {
        "channel_id": {
          "$ref": "#/$defs/channel_id"
        },
        "owner_lane": {
          "$ref": "#/$defs/non_empty_string"
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "primary_surface_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "stale_claim_failure_mode_catalog_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "failure_mode_id",
        "trigger",
        "default_downgrade_to",
        "default_route_channels",
        "description"
      ],
      "properties": {
        "failure_mode_id": {
          "type": "string",
          "pattern": "^claim_failure:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
        },
        "trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "default_downgrade_to": {
          "$ref": "#/$defs/claim_posture"
        },
        "default_route_channels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/route_channel"
          }
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "claim_manifest_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "manifest_id",
        "title",
        "manifest_schema_ref",
        "governance_packet",
        "shared_header",
        "publication_channels",
        "stale_claim_failure_modes",
        "claim_rows",
        "notes"
      ],
      "properties": {
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "record_kind": {
          "type": "string",
          "const": "claim_manifest_packet"
        },
        "manifest_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "manifest_schema_ref": {
          "type": "string",
          "const": "schemas/governance/claim_manifest.schema.json"
        },
        "governance_packet": {
          "$ref": "governance_packet.schema.json"
        },
        "shared_header": {
          "$ref": "evidence_packet_header.schema.json"
        },
        "publication_channels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/channel_definition"
          }
        },
        "stale_claim_failure_modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/stale_claim_failure_mode_catalog_entry"
          }
        },
        "claim_rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/claim_row"
          }
        },
        "notes": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "allOf": [
        {
          "properties": {
            "governance_packet": {
              "type": "object",
              "properties": {
                "packet_family": {
                  "const": "claim_manifest"
                }
              },
              "required": ["packet_family"]
            }
          }
        },
        {
          "properties": {
            "shared_header": {
              "type": "object",
              "properties": {
                "packet_family": {
                  "const": "claim_manifest"
                }
              },
              "required": ["packet_family"]
            }
          }
        }
      ]
    }
  }
}
