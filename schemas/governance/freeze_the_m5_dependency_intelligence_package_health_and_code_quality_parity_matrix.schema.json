{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/freeze_the_m5_dependency_intelligence_package_health_and_code_quality_parity_matrix.schema.json",
  "title": "M5 Dependency-Intelligence, Package-Health, and Code-Quality Parity Matrix",
  "description": "Canonical typed matrix that freezes M5 dependency/package and code-quality lane claims, claim classes, deployment-profile postures, compatibility/downgrade rules, scorecards, and hard/soft dependency edges. Downstream docs, Help/About, and support surfaces ingest this directly instead of restating status by hand.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "matrix_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "lifecycle_labels",
    "lane_kinds",
    "claim_classes",
    "deployment_profiles",
    "scorecard_states",
    "gap_reasons",
    "stop_rule_actions",
    "launch_cutline",
    "release_blocking_lane_refs",
    "stop_rules",
    "rows",
    "dependencies",
    "promotion",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version of the matrix."
    },
    "record_kind": {
      "type": "string",
      "const": "freeze_m5_dependency_quality_parity_matrix"
    },
    "matrix_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "overview_page": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "type": "string", "minLength": 1 },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
      }
    },
    "lane_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "dependency_intelligence",
          "package_mutation",
          "package_health",
          "quality_profile",
          "scanner_import",
          "live_quality",
          "cli_headless_parity"
        ]
      }
    },
    "claim_classes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "marketed_depth",
          "foundation_parity",
          "imported_visibility",
          "advisory_only"
        ]
      }
    },
    "deployment_profiles": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["local_only", "mirrored", "managed", "browser_handoff"]
      }
    },
    "scorecard_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "complete",
          "incomplete",
          "stale",
          "on_waiver",
          "blocked",
          "rollback_missing"
        ]
      }
    },
    "gap_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "proof_packet_missing",
          "proof_packet_stale",
          "compatibility_report_missing",
          "compatibility_report_stale",
          "admin_policy_missing",
          "rollback_path_missing",
          "upstream_lane_narrowed",
          "waiver_expired",
          "owner_signoff_missing"
        ]
      }
    },
    "stop_rule_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "hold_promotion",
          "narrow_label",
          "refresh_proof_packet",
          "refresh_compatibility_report",
          "staff_admin_policy",
          "define_rollback_path",
          "request_owner_signoff"
        ]
      }
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_lane_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stop_rule" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/lane_row" }
    },
    "dependencies": {
      "type": "array",
      "items": { "$ref": "#/$defs/dependency_edge" }
    },
    "promotion": { "$ref": "#/$defs/promotion_record" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "type": "string", "const": "stable" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "type": "string", "enum": ["lts", "stable"] }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["beta", "preview", "withdrawn"]
          }
        },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "freshness_slo",
        "slo_state"
      ],
      "properties": {
        "packet_id": { "type": "string", "minLength": 1 },
        "packet_ref": { "type": "string", "minLength": 1 },
        "proof_index_ref": { "type": "string", "minLength": 1 },
        "captured_at": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "format": "date" }
          ]
        },
        "freshness_slo": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "target_max_age_days",
            "warn_within_days",
            "slo_register_ref"
          ],
          "properties": {
            "target_max_age_days": { "type": "integer", "minimum": 1 },
            "warn_within_days": { "type": "integer", "minimum": 0 },
            "slo_register_ref": { "type": "string", "minLength": 1 }
          }
        },
        "slo_state": {
          "type": "string",
          "enum": ["current", "due_for_refresh", "breached", "missing"]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stop_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_promotion",
        "rationale"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "trigger_reason": {
          "type": "string",
          "enum": [
            "proof_packet_missing",
            "proof_packet_stale",
            "compatibility_report_missing",
            "compatibility_report_stale",
            "admin_policy_missing",
            "rollback_path_missing",
            "upstream_lane_narrowed",
            "waiver_expired",
            "owner_signoff_missing"
          ]
        },
        "applies_to_labels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
          }
        },
        "default_action": {
          "type": "string",
          "enum": [
            "hold_promotion",
            "narrow_label",
            "refresh_proof_packet",
            "refresh_compatibility_report",
            "staff_admin_policy",
            "define_rollback_path",
            "request_owner_signoff"
          ]
        },
        "blocks_promotion": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "lane_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "lane_kind",
        "surface_ref",
        "surface_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "claim_class",
        "deployment_profile",
        "compatibility_downgrade_rule",
        "scorecard_state",
        "scorecard",
        "proof_packet",
        "owner_signoff",
        "published_label",
        "rationale"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "lane_kind": {
          "type": "string",
          "enum": [
            "dependency_intelligence",
            "package_mutation",
            "package_health",
            "quality_profile",
            "scanner_import",
            "live_quality",
            "cli_headless_parity"
          ]
        },
        "surface_ref": { "type": "string", "minLength": 1 },
        "surface_summary": { "type": "string", "minLength": 1 },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "type": "string", "minLength": 1 },
        "claim_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "claim_class": {
          "type": "string",
          "enum": [
            "marketed_depth",
            "foundation_parity",
            "imported_visibility",
            "advisory_only"
          ]
        },
        "deployment_profile": {
          "type": "string",
          "enum": ["local_only", "mirrored", "managed", "browser_handoff"]
        },
        "compatibility_downgrade_rule": { "type": "string", "minLength": 1 },
        "scorecard_state": {
          "type": "string",
          "enum": [
            "complete",
            "incomplete",
            "stale",
            "on_waiver",
            "blocked",
            "rollback_missing"
          ]
        },
        "scorecard": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "proof_packet_ref",
            "compatibility_report_ref",
            "admin_policy_ref",
            "rollback_path_ref"
          ],
          "properties": {
            "proof_packet_ref": { "type": "string" },
            "compatibility_report_ref": { "type": "string" },
            "admin_policy_ref": { "type": "string" },
            "rollback_path_ref": { "type": "string" }
          }
        },
        "proof_packet": { "$ref": "#/$defs/proof_packet" },
        "waiver": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["waiver_ref", "expires_at", "reason"],
              "properties": {
                "waiver_ref": { "type": "string", "minLength": 1 },
                "expires_at": { "type": "string", "format": "date" },
                "reason": { "type": "string", "minLength": 1 }
              }
            }
          ]
        },
        "owner_signoff": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner_ref", "signed_off"],
          "properties": {
            "owner_ref": { "type": "string", "minLength": 1 },
            "signed_off": { "type": "boolean" },
            "signed_at": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "format": "date" }
              ]
            }
          }
        },
        "active_gap_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "proof_packet_missing",
              "proof_packet_stale",
              "compatibility_report_missing",
              "compatibility_report_stale",
              "admin_policy_missing",
              "rollback_path_missing",
              "upstream_lane_narrowed",
              "waiver_expired",
              "owner_signoff_missing"
            ]
          }
        },
        "published_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "upstream_lane_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "downstream_lane_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "publication_destinations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "dependency_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_id",
        "from_lane",
        "to_lane",
        "dependency_kind",
        "rationale"
      ],
      "properties": {
        "edge_id": { "type": "string", "minLength": 1 },
        "from_lane": { "type": "string", "minLength": 1 },
        "to_lane": { "type": "string", "minLength": 1 },
        "dependency_kind": { "type": "string", "enum": ["hard", "soft"] },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "promotion_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_claim_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blocking_claim_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "total_claims",
        "entries_holding_stable",
        "entries_narrowed",
        "entries_on_active_waiver",
        "entries_blocked",
        "entries_rollback_missing",
        "release_blocking_total",
        "release_blocking_holding",
        "release_blocking_narrowed",
        "dependency_intelligence_entries",
        "package_mutation_entries",
        "package_health_entries",
        "quality_profile_entries",
        "scanner_import_entries",
        "live_quality_entries",
        "cli_headless_parity_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_gap_reasons",
        "rules_firing",
        "hard_dependency_edges",
        "soft_dependency_edges"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "entries_holding_stable": { "type": "integer", "minimum": 0 },
        "entries_narrowed": { "type": "integer", "minimum": 0 },
        "entries_on_active_waiver": { "type": "integer", "minimum": 0 },
        "entries_blocked": { "type": "integer", "minimum": 0 },
        "entries_rollback_missing": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_holding": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "dependency_intelligence_entries": { "type": "integer", "minimum": 0 },
        "package_mutation_entries": { "type": "integer", "minimum": 0 },
        "package_health_entries": { "type": "integer", "minimum": 0 },
        "quality_profile_entries": { "type": "integer", "minimum": 0 },
        "scanner_import_entries": { "type": "integer", "minimum": 0 },
        "live_quality_entries": { "type": "integer", "minimum": 0 },
        "cli_headless_parity_entries": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_active_gap_reasons": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 },
        "hard_dependency_edges": { "type": "integer", "minimum": 0 },
        "soft_dependency_edges": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
