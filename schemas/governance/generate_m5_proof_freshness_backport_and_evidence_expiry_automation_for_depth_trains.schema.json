{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/generate_m5_proof_freshness_backport_and_evidence_expiry_automation_for_depth_trains.schema.json",
  "title": "M5 Depth-Train Automation Register",
  "description": "Canonical typed register that automates M5 depth-lane proof-freshness, backport eligibility, and evidence expiry. Downstream docs, Help/About, and support surfaces ingest this directly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "register_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "feature_train_matrix_ref",
    "lifecycle_labels",
    "lane_kinds",
    "automation_states",
    "gap_reasons",
    "stop_rule_actions",
    "backport_kinds",
    "evidence_kinds",
    "launch_cutline",
    "release_blocking_lane_refs",
    "stop_rules",
    "rows",
    "promotion",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version of the register."
    },
    "record_kind": {
      "type": "string",
      "const": "generate_m5_proof_freshness_backport_and_evidence_expiry_automation_for_depth_trains"
    },
    "register_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "overview_page": {
      "type": "string",
      "minLength": 1
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "claim_manifest_ref": {
      "type": "string",
      "minLength": 1
    },
    "feature_train_matrix_ref": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
      }
    },
    "lane_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "notebook",
          "data_rich",
          "ai_adjacent",
          "framework",
          "review",
          "companion",
          "managed_depth"
        ]
      }
    },
    "automation_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "complete",
          "incomplete",
          "stale",
          "on_waiver",
          "blocked",
          "rule_missing"
        ]
      }
    },
    "gap_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "proof_packet_missing",
          "proof_packet_stale",
          "evidence_expired",
          "evidence_missing",
          "backport_window_closed",
          "backport_policy_missing",
          "compatibility_report_stale",
          "rollback_path_stale",
          "waiver_expired",
          "owner_signoff_missing"
        ]
      }
    },
    "stop_rule_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "hold_promotion",
          "narrow_label",
          "refresh_proof_packet",
          "refresh_evidence",
          "extend_backport_window",
          "define_backport_policy",
          "request_owner_signoff"
        ]
      }
    },
    "backport_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "security_only",
          "critical_fix",
          "feature_backport",
          "policy_exempt"
        ]
      }
    },
    "evidence_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "proof_packet",
          "compatibility_report",
          "admin_policy",
          "rollback_path",
          "benchmark_result"
        ]
      }
    },
    "launch_cutline": {
      "$ref": "#/$defs/launch_cutline"
    },
    "release_blocking_lane_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stop_rule" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/lane_row" }
    },
    "promotion": {
      "$ref": "#/$defs/promotion_record"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": {
          "type": "string",
          "const": "stable"
        },
        "above_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["lts", "stable"]
          }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["beta", "preview", "withdrawn"]
          }
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stop_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_promotion",
        "rationale"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "trigger_reason": {
          "type": "string",
          "enum": [
            "proof_packet_missing",
            "proof_packet_stale",
            "evidence_expired",
            "evidence_missing",
            "backport_window_closed",
            "backport_policy_missing",
            "compatibility_report_stale",
            "rollback_path_stale",
            "waiver_expired",
            "owner_signoff_missing"
          ]
        },
        "applies_to_labels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
          }
        },
        "default_action": {
          "type": "string",
          "enum": [
            "hold_promotion",
            "narrow_label",
            "refresh_proof_packet",
            "refresh_evidence",
            "extend_backport_window",
            "define_backport_policy",
            "request_owner_signoff"
          ]
        },
        "blocks_promotion": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "lane_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "lane_kind",
        "surface_ref",
        "surface_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "automation_state",
        "proof_packet",
        "backport_eligibility",
        "evidence_expiry_records",
        "owner_signoff",
        "published_label",
        "rationale"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "lane_kind": {
          "type": "string",
          "enum": [
            "notebook",
            "data_rich",
            "ai_adjacent",
            "framework",
            "review",
            "companion",
            "managed_depth"
          ]
        },
        "surface_ref": { "type": "string", "minLength": 1 },
        "surface_summary": { "type": "string", "minLength": 1 },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "type": "string", "minLength": 1 },
        "claim_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "automation_state": {
          "type": "string",
          "enum": [
            "complete",
            "incomplete",
            "stale",
            "on_waiver",
            "blocked",
            "rule_missing"
          ]
        },
        "proof_packet": {
          "$ref": "https://aureline.dev/schemas/governance/boundary_manifest_v1.schema.json#/properties/proof_packet"
        },
        "backport_eligibility": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "eligible",
            "backport_kind",
            "window_closes_at",
            "policy_ref",
            "rationale"
          ],
          "properties": {
            "eligible": { "type": "boolean" },
            "backport_kind": {
              "type": "string",
              "enum": [
                "security_only",
                "critical_fix",
                "feature_backport",
                "policy_exempt"
              ]
            },
            "window_closes_at": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "format": "date" }
              ]
            },
            "policy_ref": { "type": "string" },
            "rationale": { "type": "string", "minLength": 1 }
          }
        },
        "evidence_expiry_records": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_expiry_record" }
        },
        "waiver": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["waiver_ref", "expires_at", "reason"],
              "properties": {
                "waiver_ref": { "type": "string", "minLength": 1 },
                "expires_at": { "type": "string", "format": "date" },
                "reason": { "type": "string", "minLength": 1 }
              }
            }
          ]
        },
        "owner_signoff": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner_ref", "signed_off"],
          "properties": {
            "owner_ref": { "type": "string", "minLength": 1 },
            "signed_off": { "type": "boolean" },
            "signed_at": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "format": "date" }
              ]
            }
          }
        },
        "active_gap_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "proof_packet_missing",
              "proof_packet_stale",
              "evidence_expired",
              "evidence_missing",
              "backport_window_closed",
              "backport_policy_missing",
              "compatibility_report_stale",
              "rollback_path_stale",
              "waiver_expired",
              "owner_signoff_missing"
            ]
          }
        },
        "published_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "upstream_lane_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "downstream_lane_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "publication_destinations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "evidence_expiry_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_kind",
        "evidence_ref",
        "captured_at",
        "expires_at",
        "days_remaining",
        "expired",
        "rationale"
      ],
      "properties": {
        "evidence_kind": {
          "type": "string",
          "enum": [
            "proof_packet",
            "compatibility_report",
            "admin_policy",
            "rollback_path",
            "benchmark_result"
          ]
        },
        "evidence_ref": { "type": "string", "minLength": 1 },
        "captured_at": { "type": "string", "format": "date" },
        "expires_at": { "type": "string", "format": "date" },
        "days_remaining": { "type": "integer" },
        "expired": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "promotion_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_claim_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": { "type": "string", "minLength": 1 },
        "decision": {
          "type": "string",
          "enum": ["proceed", "hold"]
        },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blocking_claim_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "total_claims",
        "entries_holding_stable",
        "entries_narrowed",
        "entries_on_active_waiver",
        "entries_blocked",
        "entries_rule_missing",
        "release_blocking_total",
        "release_blocking_holding",
        "release_blocking_narrowed",
        "notebook_entries",
        "data_rich_entries",
        "ai_adjacent_entries",
        "framework_entries",
        "review_entries",
        "companion_entries",
        "managed_depth_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_gap_reasons",
        "rules_firing",
        "entries_expired_evidence",
        "entries_missing_backport_policy",
        "entries_backport_window_closed"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "entries_holding_stable": { "type": "integer", "minimum": 0 },
        "entries_narrowed": { "type": "integer", "minimum": 0 },
        "entries_on_active_waiver": { "type": "integer", "minimum": 0 },
        "entries_blocked": { "type": "integer", "minimum": 0 },
        "entries_rule_missing": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_holding": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "notebook_entries": { "type": "integer", "minimum": 0 },
        "data_rich_entries": { "type": "integer", "minimum": 0 },
        "ai_adjacent_entries": { "type": "integer", "minimum": 0 },
        "framework_entries": { "type": "integer", "minimum": 0 },
        "review_entries": { "type": "integer", "minimum": 0 },
        "companion_entries": { "type": "integer", "minimum": 0 },
        "managed_depth_entries": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_active_gap_reasons": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 },
        "entries_expired_evidence": { "type": "integer", "minimum": 0 },
        "entries_missing_backport_policy": { "type": "integer", "minimum": 0 },
        "entries_backport_window_closed": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
