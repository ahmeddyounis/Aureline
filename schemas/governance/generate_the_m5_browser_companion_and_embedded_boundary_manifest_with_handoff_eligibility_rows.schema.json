{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "M5BrowserCompanionEmbeddedBoundaryManifest",
  "description": "Schema for the M5 browser, companion, and embedded-boundary manifest with handoff eligibility rows.",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "manifest_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "feature_train_matrix_ref",
    "lifecycle_labels",
    "surface_kinds",
    "handoff_states",
    "gap_reasons",
    "stop_rule_actions",
    "launch_cutline",
    "release_blocking_surface_refs",
    "stop_rules",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "record_kind": {
      "type": "string"
    },
    "manifest_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "overview_page": {
      "type": "string"
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "claim_manifest_ref": {
      "type": "string"
    },
    "feature_train_matrix_ref": {
      "type": "string"
    },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "lts",
          "stable",
          "beta",
          "preview",
          "withdrawn"
        ]
      }
    },
    "surface_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "browser",
          "companion",
          "embedded_boundary"
        ]
      }
    },
    "handoff_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "eligible",
          "eligible_degraded",
          "blocked",
          "pending_evidence",
          "not_applicable"
        ]
      }
    },
    "gap_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "proof_packet_missing",
          "proof_packet_stale",
          "compatibility_report_missing",
          "compatibility_report_stale",
          "desktop_handoff_truth_incomplete",
          "browser_fallback_unavailable",
          "owner_signoff_missing",
          "waiver_expired",
          "source_surface_narrowed",
          "target_surface_narrowed"
        ]
      }
    },
    "stop_rule_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "hold_publication",
          "narrow_label",
          "refresh_proof_packet",
          "refresh_compatibility_report",
          "complete_desktop_handoff_truth",
          "restore_browser_fallback",
          "request_owner_signoff"
        ]
      }
    },
    "launch_cutline": {
      "type": "object",
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": {
          "type": "string",
          "enum": [
            "stable"
          ]
        },
        "above_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        }
      }
    },
    "release_blocking_surface_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stop_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "title",
          "trigger_reason",
          "applies_to_labels",
          "default_action",
          "blocks_publication",
          "rationale"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "trigger_reason": {
            "type": "string"
          },
          "applies_to_labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "default_action": {
            "type": "string"
          },
          "blocks_publication": {
            "type": "boolean"
          },
          "rationale": {
            "type": "string"
          }
        }
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entry_id",
          "title",
          "source_kind",
          "target_kind",
          "surface_ref",
          "surface_summary",
          "release_blocking",
          "claim_ref",
          "claim_label",
          "handoff_state",
          "effective_label",
          "proof_packet",
          "owner_signoff",
          "active_gap_reasons",
          "publication_destinations",
          "rationale"
        ],
        "properties": {
          "entry_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "source_kind": {
            "type": "string",
            "enum": [
              "browser",
              "companion",
              "embedded_boundary"
            ]
          },
          "target_kind": {
            "type": "string",
            "enum": [
              "browser",
              "companion",
              "embedded_boundary"
            ]
          },
          "surface_ref": {
            "type": "string"
          },
          "surface_summary": {
            "type": "string"
          },
          "release_blocking": {
            "type": "boolean"
          },
          "claim_ref": {
            "type": "string"
          },
          "claim_label": {
            "type": "string"
          },
          "handoff_state": {
            "type": "string"
          },
          "effective_label": {
            "type": "string"
          },
          "proof_packet": {
            "type": "object",
            "required": [
              "packet_id",
              "packet_ref",
              "proof_index_ref",
              "freshness_slo",
              "slo_state",
              "evidence_refs"
            ],
            "properties": {
              "packet_id": {
                "type": "string"
              },
              "packet_ref": {
                "type": "string"
              },
              "proof_index_ref": {
                "type": "string"
              },
              "captured_at": {
                "type": ["string", "null"]
              },
              "freshness_slo": {
                "type": "object",
                "required": [
                  "slo_register_ref",
                  "target_max_age_days",
                  "warn_within_days"
                ],
                "properties": {
                  "slo_register_ref": {
                    "type": "string"
                  },
                  "target_max_age_days": {
                    "type": "integer"
                  },
                  "warn_within_days": {
                    "type": "integer"
                  }
                }
              },
              "slo_state": {
                "type": "string",
                "enum": [
                  "current",
                  "due_for_refresh",
                  "breached",
                  "missing"
                ]
              },
              "evidence_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "waiver": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "waiver_ref",
              "expires_at",
              "reason"
            ],
            "properties": {
              "waiver_ref": {
                "type": "string"
              },
              "expires_at": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            }
          },
          "owner_signoff": {
            "type": "object",
            "required": [
              "owner_ref",
              "signed_off",
              "signed_at"
            ],
            "properties": {
              "owner_ref": {
                "type": "string"
              },
              "signed_off": {
                "type": "boolean"
              },
              "signed_at": {
                "type": ["string", "null"]
              }
            }
          },
          "active_gap_reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "publication_destinations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rationale": {
            "type": "string"
          }
        }
      }
    },
    "publication": {
      "type": "object",
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_claim_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": {
          "type": "string"
        },
        "decision": {
          "type": "string",
          "enum": [
            "proceed",
            "hold"
          ]
        },
        "blocking_rule_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking_claim_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rationale": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total_entries",
        "total_claims",
        "entries_holding_stable",
        "entries_narrowed",
        "entries_on_active_waiver",
        "entries_owner_blocked",
        "release_blocking_total",
        "release_blocking_holding",
        "release_blocking_narrowed",
        "browser_entries",
        "companion_entries",
        "embedded_boundary_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_gap_reasons",
        "rules_firing"
      ],
      "properties": {
        "total_entries": {
          "type": "integer"
        },
        "total_claims": {
          "type": "integer"
        },
        "entries_holding_stable": {
          "type": "integer"
        },
        "entries_narrowed": {
          "type": "integer"
        },
        "entries_on_active_waiver": {
          "type": "integer"
        },
        "entries_owner_blocked": {
          "type": "integer"
        },
        "release_blocking_total": {
          "type": "integer"
        },
        "release_blocking_holding": {
          "type": "integer"
        },
        "release_blocking_narrowed": {
          "type": "integer"
        },
        "browser_entries": {
          "type": "integer"
        },
        "companion_entries": {
          "type": "integer"
        },
        "embedded_boundary_entries": {
          "type": "integer"
        },
        "packets_current": {
          "type": "integer"
        },
        "packets_due_for_refresh": {
          "type": "integer"
        },
        "packets_breached": {
          "type": "integer"
        },
        "packets_missing": {
          "type": "integer"
        },
        "total_active_gap_reasons": {
          "type": "integer"
        },
        "rules_firing": {
          "type": "integer"
        }
      }
    }
  }
}