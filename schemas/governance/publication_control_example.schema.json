{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/publication_control_example.schema.json",
  "title": "Aureline repository/publication-control worked example",
  "description": "Boundary schema for worked examples under fixtures/governance/publication_control_examples/. The examples exercise the publication-control portion of the open-vs-paid/anti-lock-in matrix: public source vs public spec, stable-surface schema/docs obligations, sample availability posture, and issue-routing posture. The schema is intentionally narrow and review-focused; it carries bounded text plus file refs, not raw page bodies or confidential URLs.",
  "$ref": "#/$defs/publication_control_example",
  "$defs": {
    "publication_control_example_schema_version": {
      "type": "integer",
      "const": 1
    },
    "example_id": {
      "type": "string",
      "pattern": "^publication_control_example:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "artifact_family_class": {
      "type": "string",
      "enum": [
        "core_desktop_client_platform",
        "sdks_schemas_wit_protocol_samples",
        "documentation_and_migration_guides",
        "brand_and_trademarks",
        "hosted_control_plane_and_managed_services",
        "extensions",
        "policy_bundles",
        "docs_service_health",
        "support_exports",
        "workflow_bundles"
      ]
    },
    "license_lane_class": {
      "type": "string",
      "enum": [
        "mpl_2_0_public_source",
        "apache_2_0_public_source",
        "cc_by_4_0_public_docs",
        "restricted_exception_inventory",
        "service_plane_contract_publication"
      ]
    },
    "code_visibility_requirement": {
      "type": "string",
      "enum": [
        "public_source_required",
        "public_source_required_with_exceptions",
        "public_source_optional",
        "not_applicable"
      ]
    },
    "spec_visibility_requirement": {
      "type": "string",
      "enum": [
        "public_spec_required",
        "public_spec_required_for_stable",
        "public_spec_optional",
        "not_applicable"
      ]
    },
    "stable_surface_schema_docs_requirement": {
      "type": "string",
      "enum": [
        "public_schema_and_docs_required_for_stable",
        "public_schema_required_for_stable",
        "public_docs_required",
        "not_applicable"
      ]
    },
    "sample_availability_requirement": {
      "type": "string",
      "enum": [
        "public_samples_required_for_stable",
        "public_samples_recommended",
        "not_applicable"
      ]
    },
    "issue_routing_requirement": {
      "type": "string",
      "enum": [
        "public_issue_tracker_required",
        "mixed_public_private_allowed_with_matrix",
        "issue_routing_matrix_required",
        "not_applicable"
      ]
    },
    "publication_verdict": {
      "type": "string",
      "enum": [
        "conforming",
        "nonconforming"
      ]
    },
    "controls_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "license_lane_classes",
        "code_visibility_requirement",
        "spec_visibility_requirement",
        "stable_surface_schema_docs_requirement",
        "sample_availability_requirement",
        "issue_routing_requirement"
      ],
      "properties": {
        "license_lane_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/license_lane_class" }
        },
        "code_visibility_requirement": { "$ref": "#/$defs/code_visibility_requirement" },
        "spec_visibility_requirement": { "$ref": "#/$defs/spec_visibility_requirement" },
        "stable_surface_schema_docs_requirement": { "$ref": "#/$defs/stable_surface_schema_docs_requirement" },
        "sample_availability_requirement": { "$ref": "#/$defs/sample_availability_requirement" },
        "issue_routing_requirement": { "$ref": "#/$defs/issue_routing_requirement" }
      }
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario", "contract_sections"],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/non_empty_string" },
        "contract_sections": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        }
      }
    },
    "publication_control_example": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "__fixture__",
        "record_kind",
        "publication_control_example_schema_version",
        "example_id",
        "title",
        "artifact_family_class",
        "controls",
        "evidence_refs",
        "expected_verdict"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "publication_control_example" },
        "publication_control_example_schema_version": { "$ref": "#/$defs/publication_control_example_schema_version" },
        "example_id": { "$ref": "#/$defs/example_id" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "artifact_family_class": { "$ref": "#/$defs/artifact_family_class" },
        "controls": { "$ref": "#/$defs/controls_block" },
        "evidence_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "expected_verdict": { "$ref": "#/$defs/publication_verdict" },
        "notes": { "type": "string" }
      }
    }
  }
}

