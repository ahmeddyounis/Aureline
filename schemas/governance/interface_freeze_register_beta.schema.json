{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/interface_freeze_register_beta.schema.json",
  "title": "Aureline interface-freeze register (Beta)",
  "description": "Boundary schema for artifacts/governance/interface_freeze_register_beta.json. The register makes the Beta interface freeze explicit: every governed schema family carries a freeze state (open / soft_frozen / hard_frozen), the version it was frozen at, the exception classes permitted for it, and any recorded exceptions that authorized a change. Rows whose version_source is governed_schema_registry are cross-checked against schemas/registry/schema_registry.json by the typed consumer and the CI gate; declared rows pin a serialization surface (settings, portable-state, extension manifest) that is not itself a governed-registry family. A hard_frozen row may not move past its frozen_at_version without a recorded exception drawn from its allowed_exception_classes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "register_id",
    "status",
    "overview_page",
    "governed_schema_registry_ref",
    "surface_classes",
    "freeze_state_classes",
    "exception_classes",
    "rows",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "interface_freeze_register"
    },
    "register_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "overview_page": {
      "type": "string",
      "minLength": 1
    },
    "governed_schema_registry_ref": {
      "type": "string",
      "const": "schemas/registry/schema_registry.json"
    },
    "surface_classes": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/surface_class" }
    },
    "freeze_state_classes": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/freeze_state" }
    },
    "exception_classes": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/exception_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/row" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows",
        "open_rows",
        "soft_frozen_rows",
        "hard_frozen_rows",
        "governed_schema_rows",
        "declared_rows",
        "recorded_exception_count"
      ],
      "properties": {
        "total_rows": { "type": "integer", "minimum": 0 },
        "open_rows": { "type": "integer", "minimum": 0 },
        "soft_frozen_rows": { "type": "integer", "minimum": 0 },
        "hard_frozen_rows": { "type": "integer", "minimum": 0 },
        "governed_schema_rows": { "type": "integer", "minimum": 0 },
        "declared_rows": { "type": "integer", "minimum": 0 },
        "recorded_exception_count": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "surface_class": {
      "type": "string",
      "enum": [
        "cli_headless",
        "settings_portable_state",
        "extension_sdk_manifest",
        "governed_export_packet"
      ]
    },
    "freeze_state": {
      "type": "string",
      "enum": ["open", "soft_frozen", "hard_frozen"]
    },
    "exception_class": {
      "type": "string",
      "enum": [
        "additive_backward_compatible",
        "security_fix",
        "defect_correction",
        "coordinated_breaking_change"
      ]
    },
    "version_source": {
      "type": "string",
      "enum": ["governed_schema_registry", "declared"]
    },
    "recorded_exception": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exception_class",
        "from_version",
        "to_version",
        "rationale",
        "authority_ref"
      ],
      "properties": {
        "exception_class": { "$ref": "#/$defs/exception_class" },
        "from_version": { "type": "integer", "minimum": 1 },
        "to_version": { "type": "integer", "minimum": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "authority_ref": { "type": "string", "minLength": 1 }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id",
        "title",
        "surface_class",
        "version_source",
        "schema_ref",
        "freeze_state",
        "frozen_at_version",
        "current_version",
        "allowed_exception_classes",
        "recorded_exceptions",
        "owner_ref",
        "rationale"
      ],
      "properties": {
        "schema_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "version_source": { "$ref": "#/$defs/version_source" },
        "schema_ref": { "type": "string", "minLength": 1 },
        "freeze_state": { "$ref": "#/$defs/freeze_state" },
        "frozen_at_version": { "type": "integer", "minimum": 1 },
        "current_version": { "type": "integer", "minimum": 1 },
        "allowed_exception_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/exception_class" }
        },
        "recorded_exceptions": {
          "type": "array",
          "items": { "$ref": "#/$defs/recorded_exception" }
        },
        "owner_ref": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 }
      }
    }
  }
}
