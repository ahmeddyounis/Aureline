{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/ship_benchmark_corpora_reference_workspace_expansions_and_m5_specific_protected_fitness_dashboards.schema.json",
  "title": "M5 Fitness-Surface Register: Benchmark Corpora, Reference-Workspace Expansions, and Protected Fitness Dashboards",
  "description": "Canonical typed register that freezes one fitness-surface lane per surface kind, each binding the surface to its stable claim, a fitness scorecard of one cell per dimension, the disclosed corpus provenance, an owner-manifest sign-off, and an explicit downgrade/rollback automation record. Downstream docs, Help/About, and support surfaces ingest this directly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "manifest_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "lifecycle_labels",
    "surface_kinds",
    "fitness_dimensions",
    "dimension_grades",
    "surface_states",
    "narrowing_reasons",
    "stop_rule_actions",
    "automation_triggers",
    "automation_states",
    "trust_tiers",
    "launch_cutline",
    "release_blocking_surface_refs",
    "stop_rules",
    "rows",
    "promotion",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version of the register."
    },
    "record_kind": {
      "type": "string",
      "const": "ship_benchmark_corpora_reference_workspace_expansions_and_m5_specific_protected_fitness_dashboards"
    },
    "manifest_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "overview_page": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "type": "string", "minLength": 1 },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
      }
    },
    "surface_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_kind" }
    },
    "fitness_dimensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/fitness_dimension" }
    },
    "dimension_grades": {
      "type": "array",
      "items": { "$ref": "#/$defs/dimension_grade" }
    },
    "surface_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_state" }
    },
    "narrowing_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/narrowing_reason" }
    },
    "stop_rule_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/stop_rule_action" }
    },
    "automation_triggers": {
      "type": "array",
      "items": { "$ref": "#/$defs/automation_trigger" }
    },
    "automation_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/automation_state" }
    },
    "trust_tiers": {
      "type": "array",
      "items": { "$ref": "#/$defs/trust_tier" }
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_surface_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stop_rule" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fitness_surface_lane" }
    },
    "promotion": { "$ref": "#/$defs/promotion_record" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "surface_kind": {
      "type": "string",
      "enum": [
        "benchmark_corpus",
        "reference_workspace",
        "fitness_dashboard",
        "fitness_function"
      ]
    },
    "fitness_dimension": {
      "type": "string",
      "enum": [
        "corpus_lineage",
        "baseline_coverage",
        "threshold_calibration",
        "regression_guard",
        "accessibility_audit",
        "docs_truth"
      ]
    },
    "dimension_grade": {
      "type": "string",
      "enum": ["pass", "partial", "fail", "waived", "missing"]
    },
    "surface_state": {
      "type": "string",
      "enum": [
        "certified",
        "fitness_regressed",
        "stale",
        "on_waiver",
        "automation_undefined",
        "owner_unsigned"
      ]
    },
    "narrowing_reason": {
      "type": "string",
      "enum": [
        "fitness_dimension_failed",
        "fitness_dimension_missing",
        "proof_packet_missing",
        "proof_packet_stale",
        "owner_manifest_unsigned",
        "rollback_plan_unverified",
        "downgrade_automation_undefined",
        "waiver_expired"
      ]
    },
    "stop_rule_action": {
      "type": "string",
      "enum": [
        "hold_promotion",
        "narrow_label",
        "remediate_fitness",
        "refresh_proof_packet",
        "request_owner_signoff",
        "verify_rollback_plan",
        "define_downgrade_automation",
        "renew_waiver"
      ]
    },
    "automation_trigger": {
      "type": "string",
      "enum": ["proof_stale", "fitness_regressed", "owner_revoked", "manual"]
    },
    "automation_state": {
      "type": "string",
      "enum": ["defined", "unverified", "undefined"]
    },
    "trust_tier": {
      "type": "string",
      "enum": ["first_party", "verified_partner", "community", "generated"]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "type": "string", "const": "stable" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "type": "string", "enum": ["lts", "stable"] }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "type": "string", "enum": ["beta", "preview", "withdrawn"] }
        },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "stop_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_promotion",
        "rationale"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "trigger_reason": { "$ref": "#/$defs/narrowing_reason" },
        "applies_to_labels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
          }
        },
        "default_action": { "$ref": "#/$defs/stop_rule_action" },
        "blocks_promotion": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "freshness_slo",
        "slo_state"
      ],
      "properties": {
        "packet_id": { "type": "string", "minLength": 1 },
        "packet_ref": { "type": "string", "minLength": 1 },
        "proof_index_ref": { "type": "string", "minLength": 1 },
        "captured_at": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "format": "date" }
          ]
        },
        "freshness_slo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
          "properties": {
            "target_max_age_days": { "type": "integer", "minimum": 1 },
            "warn_within_days": { "type": "integer", "minimum": 0 },
            "slo_register_ref": { "type": "string", "minLength": 1 }
          }
        },
        "slo_state": {
          "type": "string",
          "enum": ["current", "due_for_refresh", "breached", "missing"]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "fitness_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "grade", "evidence_ref"],
      "properties": {
        "dimension": { "$ref": "#/$defs/fitness_dimension" },
        "grade": { "$ref": "#/$defs/dimension_grade" },
        "evidence_ref": { "type": "string" }
      }
    },
    "corpus_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["corpus_ref", "baseline_ref", "trust_tier", "provenance_disclosed"],
      "properties": {
        "corpus_ref": { "type": "string", "minLength": 1 },
        "baseline_ref": { "type": "string", "minLength": 1 },
        "trust_tier": { "$ref": "#/$defs/trust_tier" },
        "dataset_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "provenance_disclosed": { "type": "boolean" }
      }
    },
    "downgrade_automation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "automation_ref",
        "rollback_plan_ref",
        "trigger",
        "target_floor",
        "state",
        "rollback_verified"
      ],
      "properties": {
        "automation_ref": { "type": "string", "minLength": 1 },
        "rollback_plan_ref": { "type": "string", "minLength": 1 },
        "trigger": { "$ref": "#/$defs/automation_trigger" },
        "target_floor": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "state": { "$ref": "#/$defs/automation_state" },
        "rollback_verified": { "type": "boolean" }
      }
    },
    "fitness_surface_lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "surface_kind",
        "surface_ref",
        "surface_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "surface_state",
        "scorecard",
        "provenance",
        "downgrade_automation",
        "proof_packet",
        "owner_signoff",
        "published_label",
        "rationale"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "surface_ref": { "type": "string", "minLength": 1 },
        "surface_summary": { "type": "string", "minLength": 1 },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "type": "string", "minLength": 1 },
        "claim_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "surface_state": { "$ref": "#/$defs/surface_state" },
        "scorecard": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fitness_cell" }
        },
        "provenance": { "$ref": "#/$defs/corpus_provenance" },
        "downgrade_automation": { "$ref": "#/$defs/downgrade_automation" },
        "proof_packet": { "$ref": "#/$defs/proof_packet" },
        "waiver": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["waiver_ref", "expires_at", "reason"],
              "properties": {
                "waiver_ref": { "type": "string", "minLength": 1 },
                "expires_at": { "type": "string", "format": "date" },
                "reason": { "type": "string", "minLength": 1 }
              }
            }
          ]
        },
        "owner_signoff": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner_ref", "signed_off"],
          "properties": {
            "owner_ref": { "type": "string", "minLength": 1 },
            "signed_off": { "type": "boolean" },
            "signed_at": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "format": "date" }
              ]
            }
          }
        },
        "active_narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        },
        "published_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "publication_destinations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "promotion_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_claim_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blocking_claim_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "total_claims",
        "entries_certified",
        "entries_narrowed",
        "entries_on_active_waiver",
        "entries_with_dimension_gap",
        "entries_with_owner_gap",
        "entries_with_automation_gap",
        "entries_provenance_undisclosed",
        "release_blocking_total",
        "release_blocking_certified",
        "release_blocking_narrowed",
        "benchmark_corpus_entries",
        "reference_workspace_entries",
        "fitness_dashboard_entries",
        "fitness_function_entries",
        "first_party_entries",
        "verified_partner_entries",
        "community_entries",
        "generated_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_narrowing_reasons",
        "total_fitness_cells",
        "cells_pass",
        "cells_partial",
        "cells_fail",
        "cells_waived",
        "cells_missing",
        "rules_firing"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "entries_certified": { "type": "integer", "minimum": 0 },
        "entries_narrowed": { "type": "integer", "minimum": 0 },
        "entries_on_active_waiver": { "type": "integer", "minimum": 0 },
        "entries_with_dimension_gap": { "type": "integer", "minimum": 0 },
        "entries_with_owner_gap": { "type": "integer", "minimum": 0 },
        "entries_with_automation_gap": { "type": "integer", "minimum": 0 },
        "entries_provenance_undisclosed": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_certified": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "benchmark_corpus_entries": { "type": "integer", "minimum": 0 },
        "reference_workspace_entries": { "type": "integer", "minimum": 0 },
        "fitness_dashboard_entries": { "type": "integer", "minimum": 0 },
        "fitness_function_entries": { "type": "integer", "minimum": 0 },
        "first_party_entries": { "type": "integer", "minimum": 0 },
        "verified_partner_entries": { "type": "integer", "minimum": 0 },
        "community_entries": { "type": "integer", "minimum": 0 },
        "generated_entries": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_active_narrowing_reasons": { "type": "integer", "minimum": 0 },
        "total_fitness_cells": { "type": "integer", "minimum": 0 },
        "cells_pass": { "type": "integer", "minimum": 0 },
        "cells_partial": { "type": "integer", "minimum": 0 },
        "cells_fail": { "type": "integer", "minimum": 0 },
        "cells_waived": { "type": "integer", "minimum": 0 },
        "cells_missing": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
