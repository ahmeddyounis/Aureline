{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/dependency_marker.schema.json",
  "title": "Aureline dependency marker record",
  "description": "Boundary schema for dependency markers attached to the external alpha capability-lifecycle registry. A marker names the artifact, hosted integration, policy disable, or claim dependency that narrows a parent capability so stable-facing surfaces cannot inherit non-stable truth silently.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "marker_id",
    "marker_schema_version",
    "marker_kind",
    "parent_row_ref",
    "artifact_classes",
    "dependency_ref",
    "dependency_lifecycle_state",
    "effect_on_parent",
    "reason_code",
    "disclosure_summary",
    "repair_or_review_ref",
    "review_or_expiry_date",
    "export_visibility",
    "source_refs"
  ],
  "properties": {
    "marker_id": {
      "type": "string",
      "pattern": "^dependency_marker:[A-Za-z0-9_.:-]+$"
    },
    "marker_schema_version": {
      "type": "integer",
      "const": 1
    },
    "marker_kind": {
      "type": "string",
      "enum": [
        "NonStableCapabilityDependency",
        "DisabledByPolicyDependency",
        "HostedIntegrationDependency",
        "FreshnessFloorDependency",
        "KillSwitchDependency",
        "ManagedOnlyDependency"
      ]
    },
    "parent_row_ref": {
      "type": "string",
      "pattern": "^capability_lifecycle:[A-Za-z0-9_.:-]+$"
    },
    "artifact_classes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "profile_artifact",
          "workspace_manifest",
          "saved_view",
          "export",
          "migration_packet",
          "bundle_claim",
          "archetype_claim",
          "hosted_integration",
          "helper_internal",
          "policy_disable"
        ]
      }
    },
    "dependency_ref": {
      "type": "string",
      "minLength": 1
    },
    "dependency_lifecycle_state": {
      "type": "string",
      "enum": [
        "Labs",
        "Preview",
        "Beta",
        "Stable",
        "Deprecated",
        "DisabledByPolicy",
        "Retired"
      ]
    },
    "effect_on_parent": {
      "type": "string",
      "enum": [
        "NarrowsLifecycle",
        "NarrowsSupport",
        "NarrowsFreshness",
        "NarrowsClientScope",
        "GatesCapability"
      ]
    },
    "reason_code": {
      "type": "string",
      "enum": [
        "dependency_state_below_parent_declared_state",
        "dependency_disabled_by_policy",
        "dependency_kill_switch_tripped",
        "dependency_deprecated_within_window",
        "dependency_retired",
        "provider_grant_narrowed",
        "provider_connection_unhealthy",
        "client_scope_excludes_surface",
        "freshness_floor_unmet",
        "managed_only_channel_required"
      ]
    },
    "disclosure_summary": {
      "type": "string",
      "minLength": 1
    },
    "repair_or_review_ref": {
      "type": "string",
      "minLength": 1
    },
    "review_or_expiry_date": {
      "type": "string",
      "format": "date"
    },
    "export_visibility": {
      "type": "string",
      "enum": [
        "export_safe_summary",
        "internal_support_restricted",
        "operator_only_restricted"
      ]
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
