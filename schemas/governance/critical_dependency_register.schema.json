{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/critical_dependency_register.schema.json",
  "title": "Aureline critical-dependency / import register seed envelope",
  "description": "Boundary schema for artifacts/governance/critical_dependency_register.yaml. The envelope pins the canonical row vocabulary at critical_dependency_register_entry.schema.json, the reviewer-facing landing page at docs/governance/m1_dependency_and_notice_seed.md, the companion register paths the rows reference, the build-identity record the validation lane embeds, the validation-lane registry ref, the closed template / criticality / publication-target / release-notice-action vocabularies, the required coverage lists, the named-runtime-consumer set the seed asserts is live, and the named failure-drill ids the per-row drills must draw from. Rows conform to the row schema; the envelope cannot relax that contract.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "status",
    "matrix_id",
    "owner_dri",
    "overview_page",
    "row_schema_ref",
    "build_identity_ref",
    "validation_lane_ref",
    "companion_registers",
    "source_register_class_vocabulary",
    "template_class_vocabulary",
    "criticality_class_vocabulary",
    "protected_path_class_vocabulary",
    "license_class_vocabulary",
    "provenance_status_class_vocabulary",
    "admission_state_class_vocabulary",
    "publication_target_class_vocabulary",
    "release_notice_action_class_vocabulary",
    "required_template_class_coverage",
    "required_publication_target_coverage",
    "required_release_notice_action_coverage",
    "failure_drill_id_vocabulary",
    "named_runtime_consumers",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": ["seeded", "stabilising", "stable"]
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "matrix_id": {
      "type": "string",
      "const": "m1_critical_dependency_register_seed"
    },
    "owner_dri": {
      "type": "string",
      "pattern": "^@[a-zA-Z0-9_-]+$"
    },
    "overview_page": {
      "type": "string",
      "const": "docs/governance/m1_dependency_and_notice_seed.md"
    },
    "row_schema_ref": {
      "type": "string",
      "const": "schemas/governance/critical_dependency_register_entry.schema.json"
    },
    "build_identity_ref": {
      "type": "string",
      "minLength": 1
    },
    "validation_lane_ref": {
      "type": "string",
      "minLength": 1
    },
    "companion_registers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dependency_register",
        "third_party_import_register",
        "release_notice_seed"
      ],
      "properties": {
        "dependency_register": {
          "type": "string",
          "const": "artifacts/governance/dependency_register.yaml"
        },
        "third_party_import_register": {
          "type": "string",
          "const": "artifacts/governance/third_party_import_register.yaml"
        },
        "release_notice_seed": {
          "type": "string",
          "const": "artifacts/governance/release_notice_seed.yaml"
        }
      },
      "description": "Stable companion-register paths the M1 seed projects against. The seed never forks these registers; it consumes their stable ids and re-projects them into a release-notice-draft contract."
    },
    "draft_output_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "draft_notice_markdown",
        "draft_notice_json"
      ],
      "properties": {
        "draft_notice_markdown": {
          "type": "string",
          "minLength": 1,
          "description": "Repo-relative path where build_dependency_notice_seed.py writes its markdown draft notice."
        },
        "draft_notice_json": {
          "type": "string",
          "minLength": 1,
          "description": "Repo-relative path where build_dependency_notice_seed.py writes its JSON sidecar for downstream automation."
        }
      },
      "description": "Where the draft notice / report pipeline writes its outputs. The validation lane resolves these paths exist or that the draft tool produced them on a clean run."
    },
    "source_register_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 2,
      "items": {
        "type": "string",
        "enum": ["dependency_register", "third_party_import_register"]
      },
      "description": "Closed source-register vocabulary. MUST agree with the row schema's source_register_class $defs enum."
    },
    "template_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "runtime_dependency",
          "bundled_asset",
          "build_tooling",
          "host_runtime",
          "mirrored_pack"
        ]
      },
      "description": "Closed template vocabulary. MUST agree with the row schema's template_class $defs enum."
    },
    "criticality_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "protected_path_release_critical",
          "release_engineering_critical",
          "benchmark_lab_required",
          "repo_operations_required",
          "docs_public_truth_supporting"
        ]
      },
      "description": "Closed criticality vocabulary mirrored from the companion registers."
    },
    "protected_path_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "protected_path_critical",
          "non_protected_repo_operations",
          "non_protected_docs_pack"
        ]
      }
    },
    "license_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 7,
      "items": {
        "type": "string",
        "enum": [
          "permissive_oss",
          "permissive_oss_expected_pending_admission",
          "redistributable_font_expected_pending_import",
          "permissive_runtime",
          "strong_copyleft_runtime",
          "permissive_toolchain_runtime",
          "upstream_pack_license_to_verify_on_first_mirror"
        ]
      }
    },
    "provenance_status_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "pinned_in_repo_and_observed",
          "selected_by_adr_not_manifested",
          "host_runtime_required_not_pinned",
          "reserved_by_contract_not_imported",
          "imported_with_origin_recorded"
        ]
      }
    },
    "admission_state_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "admitted_repo_tooling",
          "selected_not_admitted",
          "reserved_not_yet_imported",
          "imported_and_tracked"
        ]
      }
    },
    "publication_target_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "third_party_notice",
          "spdx_sbom",
          "cyclonedx_sbom",
          "provenance_statement",
          "docs_pack_manifest"
        ]
      }
    },
    "release_notice_action_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 6,
      "items": {
        "type": "string",
        "enum": [
          "emit_third_party_notice_and_sbom_entries",
          "emit_bundled_asset_notice_when_imported",
          "emit_build_tooling_provenance_record_only",
          "emit_host_runtime_environment_capture_only",
          "emit_docs_pack_manifest_attribution",
          "hold_pending_first_admission"
        ]
      }
    },
    "required_template_class_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "runtime_dependency",
          "bundled_asset",
          "build_tooling",
          "host_runtime",
          "mirrored_pack"
        ]
      },
      "description": "Template classes the seed MUST seed at least once across its entries."
    },
    "required_publication_target_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "third_party_notice",
          "spdx_sbom",
          "provenance_statement",
          "docs_pack_manifest"
        ]
      },
      "description": "Publication targets the seed MUST exercise at least once across its entries."
    },
    "required_release_notice_action_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "emit_third_party_notice_and_sbom_entries",
          "emit_build_tooling_provenance_record_only",
          "emit_host_runtime_environment_capture_only",
          "emit_docs_pack_manifest_attribution",
          "hold_pending_first_admission"
        ]
      },
      "description": "Release-notice actions the seed MUST exercise at least once across its entries. emit_bundled_asset_notice_when_imported is part of the closed action vocabulary but is not required for M1 coverage; no critical bundled asset has been imported and tracked yet, so the seed cannot pretend to exercise that action without a real imported row."
    },
    "failure_drill_id_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "description": "Closed vocabulary of named failure drills the per-row failure_drill blocks must draw from."
    },
    "named_runtime_consumers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "consumer_id",
          "consumer_class",
          "consumer_ref",
          "consumed_fields"
        ],
        "properties": {
          "consumer_id": { "type": "string", "minLength": 1 },
          "consumer_class": {
            "type": "string",
            "enum": [
              "review_docs_landing_page",
              "release_notice_draft_tool",
              "ci_schema_validator",
              "docs_or_help_surface",
              "support_or_release_surface",
              "upstream_governance_register"
            ]
          },
          "consumer_ref": { "type": "string", "minLength": 1 },
          "consumed_fields": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "notes": { "type": "string" }
        }
      },
      "description": "Named live consumers that read the register. The validation lane resolves consumer_ref on disk and asserts consumed_fields is non-empty so a consumer cannot regress to 'mentioned but never read'."
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "critical_dependency_register_entry.schema.json"
      }
    }
  }
}
