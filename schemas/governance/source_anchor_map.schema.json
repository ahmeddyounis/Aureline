{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/source_anchor_map.schema.json",
  "title": "Source-anchor map",
  "description": "Machine-readable map that binds canonical requirement ids, control artifacts, and governance packet families back to the source-document sections that authorize them. Aliases, copied prose, and packet-local labels remain non-authoritative references that must resolve through this map rather than becoming parallel specs. Tooling reads this file; it is authoritative for the linter, and the human-readable companion lives at docs/governance/canonical_reference_rules.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "map_id",
    "title",
    "overview_doc",
    "drift_report_dir",
    "drift_report_template_ref",
    "canonical_source_documents",
    "artifact_classes",
    "severity_classes",
    "ownership",
    "rows"
  ],
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "source_anchor_map_record"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "map_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "overview_doc": {
      "type": "string",
      "minLength": 1
    },
    "drift_report_dir": {
      "type": "string",
      "minLength": 1
    },
    "drift_report_template_ref": {
      "type": "string",
      "minLength": 1
    },
    "canonical_source_documents": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/canonical_source_document" }
    },
    "artifact_classes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/artifact_class" }
    },
    "severity_classes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/severity_class" }
    },
    "ownership": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_owner", "evidence_owner", "owning_lane"],
      "properties": {
        "primary_owner": { "type": "string", "minLength": 1 },
        "evidence_owner": { "type": "string", "minLength": 1 },
        "owning_lane": { "type": "string", "minLength": 1 }
      }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source_anchor_row" }
    }
  },
  "$defs": {
    "canonical_source_document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doc_id", "doc_ref", "purpose"],
      "properties": {
        "doc_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "doc_ref": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifact_class": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class_id", "summary", "authority_posture"],
      "properties": {
        "class_id": { "$ref": "#/$defs/artifact_class_id" },
        "summary": { "type": "string", "minLength": 1 },
        "authority_posture": { "$ref": "#/$defs/authority_posture" }
      }
    },
    "artifact_class_id": {
      "type": "string",
      "enum": [
        "requirement_row",
        "control_artifact",
        "packet_family",
        "shiproom_artifact",
        "evidence_label"
      ]
    },
    "authority_posture": {
      "type": "string",
      "enum": [
        "claims_source_authority",
        "no_source_authority"
      ]
    },
    "severity_class": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity_id", "summary", "blocks"],
      "properties": {
        "severity_id": { "$ref": "#/$defs/severity_id" },
        "summary": { "type": "string", "minLength": 1 },
        "blocks": { "type": "string", "minLength": 1 }
      }
    },
    "severity_id": {
      "type": "string",
      "enum": [
        "missing_canonical_anchor",
        "source_authority_without_anchor",
        "duplicate_alias",
        "alias_without_canonical_target",
        "orphaned_requirement_id",
        "unknown_source_document",
        "missing_source_document_file",
        "class_coverage_gap"
      ]
    },
    "subject_kind": {
      "type": "string",
      "enum": [
        "canonical_requirement_id",
        "control_artifact_index_row",
        "packet_family_name",
        "shiproom_artifact_name",
        "evidence_label_name"
      ]
    },
    "canonical_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doc_id", "anchor", "note"],
      "properties": {
        "doc_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "anchor": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "alias_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alias_id", "alias_kind", "source_ref", "note"],
      "properties": {
        "alias_id": { "type": "string", "minLength": 1 },
        "alias_kind": {
          "type": "string",
          "enum": [
            "spec_local_label",
            "legacy_label",
            "superseded_label",
            "control_artifact_row_id",
            "packet_local_label",
            "scorecard_call",
            "fitness_row"
          ]
        },
        "source_ref": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "source_anchor_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "anchor_id",
        "artifact_class",
        "subject_kind",
        "subject_ref",
        "summary",
        "claims_source_authority",
        "canonical_anchors",
        "primary_owner",
        "owning_lane",
        "last_reviewed",
        "aliases"
      ],
      "properties": {
        "anchor_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*\\.[A-Za-z0-9_\\-]+$"
        },
        "artifact_class": { "$ref": "#/$defs/artifact_class_id" },
        "subject_kind": { "$ref": "#/$defs/subject_kind" },
        "subject_ref": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "claims_source_authority": { "type": "boolean" },
        "canonical_anchors": {
          "type": "array",
          "items": { "$ref": "#/$defs/canonical_anchor" }
        },
        "primary_owner": { "type": "string", "minLength": 1 },
        "owning_lane": { "type": "string", "minLength": 1 },
        "last_reviewed": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "aliases": {
          "type": "array",
          "items": { "$ref": "#/$defs/alias_entry" }
        },
        "notes": { "type": "string" }
      }
    }
  }
}
