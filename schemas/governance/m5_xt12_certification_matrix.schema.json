{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/m5_xt12_certification_matrix.schema.json",
  "title": "M5 Certification Matrix: Switching, Visual-System, Durable-Attention, and Embedded-Boundary Evidence",
  "description": "Canonical typed matrix that closes Milestone 5 by certifying every marketed M5 surface across ten certification dimensions grouped into four axes: switching truth (onboarding/migration, first-useful-work, command discoverability), visual-system parity (component-state, appearance), durable attention (durable-attention routes, notification privacy), and embedded-boundary integrity (embedded boundary, desktop conformance, accessibility/i18n). The marketed-surface list and each surface's claim ceiling and effective label are ingested from the canonical M5 feature-family register, so the matrix can never advertise a surface wider than its canonical packet. Every surface ends qualified, narrowed, or held back; below-cutline surfaces carry the dimension(s) and reason(s) that narrow them. Release center, Help/About, support exports, and docs/public-truth publication ingest this directly instead of cloning status text. The matrix is regenerated by tools/regenerate_xt12_certification_matrix.py and enforced by tools/ci/m5/xt12_certification_check.py. It is metadata-only and carries no credential bodies or raw provider payloads.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "matrix_id",
    "status",
    "overview_page",
    "evidence_index_page",
    "narrowing_report_page",
    "as_of",
    "source_refs",
    "claim_manifest_ref",
    "marketed_surfaces",
    "xt12_dimensions",
    "xt12_axes",
    "xt12_states",
    "dimension_grades",
    "lifecycle_labels",
    "posture_classes",
    "narrowing_reasons",
    "launch_cutline",
    "release_blocking_surface_refs",
    "stop_rules",
    "evidence_catalog",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "record_kind": { "type": "string", "const": "m5_xt12_certification_matrix" },
    "matrix_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "overview_page": { "type": "string", "minLength": 1 },
    "evidence_index_page": { "type": "string", "minLength": 1 },
    "narrowing_report_page": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "format": "date" },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "feature_family_register_ref",
        "cert_train_register_ref",
        "truth_surface_ingestion_ref"
      ],
      "properties": {
        "feature_family_register_ref": { "type": "string", "minLength": 1 },
        "cert_train_register_ref": { "type": "string", "minLength": 1 },
        "truth_surface_ingestion_ref": { "type": "string", "minLength": 1 }
      }
    },
    "claim_manifest_ref": { "type": "string", "minLength": 1 },
    "marketed_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "xt12_dimensions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/dimension_key" }
    },
    "xt12_axes": {
      "type": "array",
      "items": { "$ref": "#/$defs/axis" }
    },
    "xt12_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/xt12_state" }
    },
    "dimension_grades": {
      "type": "array",
      "items": { "$ref": "#/$defs/dimension_grade" }
    },
    "lifecycle_labels": {
      "type": "array",
      "items": { "$ref": "#/$defs/lifecycle_label" }
    },
    "posture_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/posture" }
    },
    "narrowing_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/narrowing_reason" }
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_surface_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stop_rule" }
    },
    "evidence_catalog": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence_catalog_entry" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surface_row" }
    },
    "publication": { "$ref": "#/$defs/publication" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "dimension_key": {
      "type": "string",
      "enum": [
        "onboarding_migration",
        "first_useful_work",
        "command_discoverability",
        "component_state_parity",
        "appearance_conformance",
        "durable_attention",
        "notification_privacy",
        "embedded_boundary",
        "desktop_conformance",
        "accessibility_i18n"
      ]
    },
    "axis": {
      "type": "string",
      "enum": ["switching", "visual_system", "durable_attention", "embedded_boundary"]
    },
    "xt12_state": {
      "type": "string",
      "enum": ["qualified", "narrowed", "held_back"]
    },
    "dimension_grade": {
      "type": "string",
      "enum": ["pass", "partial", "fail", "stale", "missing", "waived"]
    },
    "lifecycle_label": {
      "type": "string",
      "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
    },
    "posture": {
      "type": "string",
      "enum": ["local_only", "mirrored", "managed", "browser_handoff"]
    },
    "narrowing_reason": {
      "type": "string",
      "enum": [
        "onboarding_migration_unqualified",
        "first_useful_work_unqualified",
        "command_discoverability_unqualified",
        "component_state_parity_unqualified",
        "appearance_conformance_unqualified",
        "durable_attention_unqualified",
        "notification_privacy_unqualified",
        "embedded_boundary_unqualified",
        "desktop_conformance_unqualified",
        "accessibility_i18n_unqualified",
        "evidence_stale",
        "evidence_missing",
        "owner_signoff_missing",
        "policy_blocked",
        "source_surface_below_claim",
        "hidden_onboarding_gap",
        "embedded_high_risk_approval",
        "toast_only_long_running_truth",
        "theme_only_state_semantics"
      ]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "type": "string", "const": "stable" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "type": "string", "enum": ["lts", "stable"] }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "type": "string", "enum": ["beta", "preview", "withdrawn"] }
        },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "stop_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_widening",
        "rationale"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "trigger_reason": { "$ref": "#/$defs/narrowing_reason" },
        "applies_to_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" }
        },
        "default_action": {
          "type": "string",
          "enum": ["narrow_label", "hold_back", "hold_publication", "request_owner_signoff"]
        },
        "blocks_widening": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "evidence_catalog_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "axis", "title", "artifact_ref", "doc_ref"],
      "properties": {
        "dimension": { "$ref": "#/$defs/dimension_key" },
        "axis": { "$ref": "#/$defs/axis" },
        "title": { "type": "string", "minLength": 1 },
        "artifact_ref": { "type": "string", "minLength": 1 },
        "doc_ref": { "type": "string", "minLength": 1 },
        "check_ref": { "type": "string", "minLength": 1 }
      }
    },
    "readiness_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "axis", "title", "grade", "evidence_ref", "doc_ref", "note"],
      "properties": {
        "dimension": { "$ref": "#/$defs/dimension_key" },
        "axis": { "$ref": "#/$defs/axis" },
        "title": { "type": "string", "minLength": 1 },
        "grade": { "$ref": "#/$defs/dimension_grade" },
        "evidence_ref": { "type": "string", "minLength": 1 },
        "doc_ref": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 },
        "check_ref": { "type": "string", "minLength": 1 },
        "waiver_ref": { "type": "string" }
      }
    },
    "waiver": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["waiver_ref", "expires_at", "reason"],
          "properties": {
            "waiver_ref": { "type": "string", "minLength": 1 },
            "expires_at": { "type": "string", "format": "date" },
            "reason": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "family_kind",
        "family_ref",
        "surface_summary",
        "canonical_source_ref",
        "release_blocking",
        "posture",
        "claim_label",
        "canonical_published_label",
        "published_label",
        "xt12_state",
        "cells",
        "waiver",
        "active_narrowing_reasons",
        "publication_destinations",
        "rationale"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "family_kind": { "type": "string", "minLength": 1 },
        "family_ref": { "type": "string", "minLength": 1 },
        "surface_summary": { "type": "string" },
        "canonical_source_ref": { "type": "string", "minLength": 1 },
        "release_blocking": { "type": "boolean" },
        "posture": { "$ref": "#/$defs/posture" },
        "claim_label": { "$ref": "#/$defs/lifecycle_label" },
        "canonical_published_label": { "$ref": "#/$defs/lifecycle_label" },
        "published_label": { "$ref": "#/$defs/lifecycle_label" },
        "xt12_state": { "$ref": "#/$defs/xt12_state" },
        "cells": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/readiness_cell" }
        },
        "waiver": { "$ref": "#/$defs/waiver" },
        "active_narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        },
        "publication_destinations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_surface_ids",
        "rationale"
      ],
      "properties": {
        "publication_gate": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blocking_surface_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_surfaces",
        "total_dimensions",
        "total_cells",
        "surfaces_qualified",
        "surfaces_narrowed",
        "surfaces_held_back",
        "surfaces_on_waiver",
        "release_blocking_total",
        "release_blocking_qualified",
        "release_blocking_below_cutline",
        "cells_pass",
        "cells_partial",
        "cells_fail",
        "cells_stale",
        "cells_missing",
        "cells_waived",
        "total_active_narrowing_reasons",
        "rules_firing"
      ],
      "properties": {
        "total_surfaces": { "type": "integer", "minimum": 0 },
        "total_dimensions": { "type": "integer", "minimum": 0 },
        "total_cells": { "type": "integer", "minimum": 0 },
        "surfaces_qualified": { "type": "integer", "minimum": 0 },
        "surfaces_narrowed": { "type": "integer", "minimum": 0 },
        "surfaces_held_back": { "type": "integer", "minimum": 0 },
        "surfaces_on_waiver": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_qualified": { "type": "integer", "minimum": 0 },
        "release_blocking_below_cutline": { "type": "integer", "minimum": 0 },
        "cells_pass": { "type": "integer", "minimum": 0 },
        "cells_partial": { "type": "integer", "minimum": 0 },
        "cells_fail": { "type": "integer", "minimum": 0 },
        "cells_stale": { "type": "integer", "minimum": 0 },
        "cells_missing": { "type": "integer", "minimum": 0 },
        "cells_waived": { "type": "integer", "minimum": 0 },
        "total_active_narrowing_reasons": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
