{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/experiments_labs_governance_beta.schema.json",
  "title": "Beta experiments / flags / Labs governance UI projection",
  "description": "Beta-scope projection of the settings-owned experiments inventory. Each row carries an owner, cohort/ring, expiry or review date, and a kill-switch path summary so the UI, CLI/headless inspection, support-export packets, and reviewer docs all read the same lifecycle, alignment, and stop-path fields. The projection consumes artifacts/governance/experiments_inventory_alpha.yaml; it does not mint a parallel inventory, kill-switch precedence, or lifecycle vocabulary. Adding a new lifecycle_state, host_surface_class, or visible_marker_token is additive-minor and bumps schema_version; repurposing an existing token is breaking and opens a decision row.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "page_label",
    "source_inventory_ref",
    "source_inventory_id",
    "as_of",
    "lifecycle_counts",
    "rows",
    "badges"
  ],
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "settings_experiments_labs_governance_beta_page_record"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": {
      "type": "string",
      "const": "settings:experiments_labs_governance_beta:v1"
    },
    "page_id": { "type": "string", "minLength": 1 },
    "page_label": { "type": "string", "minLength": 1 },
    "source_inventory_ref": { "type": "string", "minLength": 1 },
    "source_inventory_id": { "type": "string", "minLength": 1 },
    "as_of": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "lifecycle_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 },
      "description": "Counts of rows keyed by effective lifecycle state token. The projection MUST cover every lifecycle vocabulary token."
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/row" }
    },
    "badges": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/badge" }
    }
  },
  "$defs": {
    "lifecycle_state_token": {
      "type": "string",
      "enum": [
        "Labs",
        "Preview",
        "Beta",
        "Stable",
        "Deprecated",
        "DisabledByPolicy",
        "Retired"
      ]
    },
    "host_surface_class_token": {
      "type": "string",
      "enum": [
        "settings_root",
        "settings_labs_tab",
        "help_about_panel",
        "diagnostics_panel",
        "support_export_packet",
        "release_center",
        "command_palette"
      ]
    },
    "visible_marker_token": {
      "type": "string",
      "enum": [
        "labs_chip",
        "preview_chip",
        "beta_chip",
        "deprecated_chip",
        "policy_disabled_chip",
        "retired_tombstone"
      ]
    },
    "host_surface_assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host_surface", "renders_row", "disclosure"],
      "properties": {
        "host_surface": { "$ref": "#/$defs/host_surface_class_token" },
        "renders_row": { "type": "boolean" },
        "disclosure": { "type": "string", "minLength": 1 }
      }
    },
    "kill_switch_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disable_path_declared",
        "highest_precedence_source_ref",
        "preserves_user_data",
        "fallback_path",
        "summary"
      ],
      "properties": {
        "disable_path_declared": { "type": "boolean" },
        "active_source_class": {
          "type": "string",
          "minLength": 1,
          "description": "Source class token of the currently winning disable source. Omitted when no disable source is active."
        },
        "highest_precedence_source_ref": { "type": "string" },
        "preserves_user_data": { "type": "boolean" },
        "fallback_path": { "type": "string" },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "capability_id",
        "title",
        "target_workflow",
        "owner",
        "cohort_or_ring",
        "public_label",
        "declared_lifecycle_state",
        "effective_lifecycle_state",
        "review_or_expiry_date",
        "kill_switch_path",
        "host_surfaces",
        "saved_artifact_dependency_present",
        "source_inventory_row_ref"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "settings_experiments_labs_governance_beta_row_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "settings:experiments_labs_governance_beta:v1"
        },
        "capability_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "target_workflow": { "type": "string", "minLength": 1 },
        "owner": {
          "type": "string",
          "minLength": 1,
          "description": "Owner ref. Required: a row without an owner cannot ship under beta."
        },
        "cohort_or_ring": {
          "type": "string",
          "minLength": 1,
          "description": "Cohort or ring label. Required: a row without a cohort cannot ship under beta."
        },
        "public_label": { "type": "string", "minLength": 1 },
        "declared_lifecycle_state": { "$ref": "#/$defs/lifecycle_state_token" },
        "effective_lifecycle_state": { "$ref": "#/$defs/lifecycle_state_token" },
        "review_or_expiry_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Required: a row without an expiry or review date cannot ship under beta."
        },
        "visible_marker_token": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/visible_marker_token" }
          ],
          "description": "Visible marker token rendered next to the row title. MUST be present whenever effective_lifecycle_state is not 'Stable'; MUST be null when 'Stable'."
        },
        "visible_marker_disclosure": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Reviewer-facing copy. MUST be a non-empty string whenever effective_lifecycle_state is not 'Stable'."
        },
        "kill_switch_path": { "$ref": "#/$defs/kill_switch_path" },
        "host_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/host_surface_assignment" }
        },
        "saved_artifact_dependency_present": { "type": "boolean" },
        "source_inventory_row_ref": { "type": "string", "minLength": 1 }
      }
    },
    "badge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "capability_id",
        "effective_lifecycle_state",
        "badge_label",
        "counts_toward_attention_chip"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "settings_experiments_labs_governance_beta_badge_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "settings:experiments_labs_governance_beta:v1"
        },
        "capability_id": { "type": "string", "minLength": 1 },
        "effective_lifecycle_state": { "$ref": "#/$defs/lifecycle_state_token" },
        "visible_marker_token": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/visible_marker_token" }
          ]
        },
        "badge_label": { "type": "string", "minLength": 1 },
        "counts_toward_attention_chip": { "type": "boolean" }
      }
    }
  }
}
