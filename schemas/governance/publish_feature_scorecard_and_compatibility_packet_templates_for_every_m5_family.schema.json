{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/publish_feature_scorecard_and_compatibility_packet_templates_for_every_m5_family.schema.json",
  "title": "M5 Feature Scorecard and Compatibility-Packet Template Register",
  "description": "Canonical typed register that publishes scorecard and compatibility-packet templates for every M5 feature family. Downstream docs, Help/About, and support surfaces ingest this directly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "register_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "feature_train_matrix_ref",
    "lifecycle_labels",
    "family_kinds",
    "scorecard_section_kinds",
    "compatibility_packet_section_kinds",
    "template_section_states",
    "template_states",
    "gap_reasons",
    "stop_rule_actions",
    "launch_cutline",
    "release_blocking_family_refs",
    "stop_rules",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version of the register."
    },
    "record_kind": {
      "type": "string",
      "const": "publish_feature_scorecard_and_compatibility_packet_templates_for_every_m5_family"
    },
    "register_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "overview_page": {
      "type": "string",
      "minLength": 1
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "claim_manifest_ref": {
      "type": "string",
      "minLength": 1
    },
    "feature_train_matrix_ref": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "lts",
          "stable",
          "beta",
          "preview",
          "withdrawn"
        ]
      }
    },
    "family_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "notebook",
          "data_rich",
          "ai_adjacent",
          "framework",
          "review",
          "companion",
          "managed_depth"
        ]
      }
    },
    "scorecard_section_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "proof_packet",
          "compatibility_report",
          "admin_policy",
          "rollback_path",
          "owner_signoff"
        ]
      }
    },
    "compatibility_packet_section_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "schema_surface",
          "api_surface",
          "cli_surface",
          "platform_matrix",
          "downgrade_behavior",
          "mixed_version_posture",
          "deprecation_window"
        ]
      }
    },
    "template_section_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "planned",
          "drafted",
          "reviewed",
          "published",
          "stale",
          "missing"
        ]
      }
    },
    "template_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "complete",
          "incomplete",
          "stale",
          "on_waiver",
          "owner_blocked"
        ]
      }
    },
    "gap_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "scorecard_template_incomplete",
          "scorecard_template_stale",
          "compatibility_packet_template_incomplete",
          "compatibility_packet_template_stale",
          "proof_packet_missing",
          "proof_packet_stale",
          "owner_signoff_missing",
          "waiver_expired"
        ]
      }
    },
    "stop_rule_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "hold_publication",
          "narrow_label",
          "refresh_scorecard_template",
          "refresh_compatibility_packet_template",
          "refresh_proof_packet",
          "request_owner_signoff"
        ]
      }
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": {
          "type": "string",
          "const": "stable"
        },
        "above_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "lts",
              "stable"
            ]
          }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "beta",
              "preview",
              "withdrawn"
            ]
          }
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "release_blocking_family_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "stop_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule_id",
          "title",
          "trigger_reason",
          "applies_to_labels",
          "default_action",
          "blocks_publication",
          "rationale"
        ],
        "properties": {
          "rule_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "trigger_reason": {
            "type": "string"
          },
          "applies_to_labels": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "lts",
                "stable",
                "beta",
                "preview",
                "withdrawn"
              ]
            }
          },
          "default_action": {
            "type": "string"
          },
          "blocks_publication": {
            "type": "boolean"
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entry_id",
          "title",
          "family_kind",
          "surface_ref",
          "surface_summary",
          "release_blocking",
          "claim_ref",
          "claim_label",
          "scorecard_template",
          "compatibility_packet_template",
          "template_state",
          "proof_packet",
          "owner_signoff",
          "active_gap_reasons",
          "published_label",
          "publication_destinations",
          "rationale"
        ],
        "properties": {
          "entry_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "family_kind": {
            "type": "string"
          },
          "surface_ref": {
            "type": "string",
            "minLength": 1
          },
          "surface_summary": {
            "type": "string",
            "minLength": 1
          },
          "release_blocking": {
            "type": "boolean"
          },
          "claim_ref": {
            "type": "string",
            "minLength": 1
          },
          "claim_label": {
            "type": "string"
          },
          "scorecard_template": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "template_id",
              "template_version",
              "sections"
            ],
            "properties": {
              "template_id": {
                "type": "string",
                "minLength": 1
              },
              "template_version": {
                "type": "integer",
                "minimum": 1
              },
              "sections": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "section_id",
                    "title",
                    "section_kind",
                    "required",
                    "item_state",
                    "rationale"
                  ],
                  "properties": {
                    "section_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "title": {
                      "type": "string",
                      "minLength": 1
                    },
                    "section_kind": {
                      "type": "string"
                    },
                    "required": {
                      "type": "boolean"
                    },
                    "item_state": {
                      "type": "string"
                    },
                    "rationale": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          },
          "compatibility_packet_template": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "template_id",
              "template_version",
              "sections"
            ],
            "properties": {
              "template_id": {
                "type": "string",
                "minLength": 1
              },
              "template_version": {
                "type": "integer",
                "minimum": 1
              },
              "sections": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "section_id",
                    "title",
                    "section_kind",
                    "required",
                    "item_state",
                    "rationale"
                  ],
                  "properties": {
                    "section_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "title": {
                      "type": "string",
                      "minLength": 1
                    },
                    "section_kind": {
                      "type": "string"
                    },
                    "required": {
                      "type": "boolean"
                    },
                    "item_state": {
                      "type": "string"
                    },
                    "rationale": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          },
          "template_state": {
            "type": "string"
          },
          "proof_packet": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "packet_id",
              "packet_ref",
              "proof_index_ref",
              "freshness_slo",
              "slo_state",
              "evidence_refs"
            ],
            "properties": {
              "packet_id": {
                "type": "string",
                "minLength": 1
              },
              "packet_ref": {
                "type": "string",
                "minLength": 1
              },
              "proof_index_ref": {
                "type": "string",
                "minLength": 1
              },
              "captured_at": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "freshness_slo": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "target_max_age_days",
                  "warn_within_days",
                  "slo_register_ref"
                ],
                "properties": {
                  "target_max_age_days": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "warn_within_days": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "slo_register_ref": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "slo_state": {
                "type": "string"
              },
              "evidence_refs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "waiver": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": false,
            "required": [
              "waiver_ref",
              "expires_at",
              "reason"
            ],
            "properties": {
              "waiver_ref": {
                "type": "string",
                "minLength": 1
              },
              "expires_at": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "owner_signoff": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "owner_ref",
              "signed_off",
              "signed_at"
            ],
            "properties": {
              "owner_ref": {
                "type": "string",
                "minLength": 1
              },
              "signed_off": {
                "type": "boolean"
              },
              "signed_at": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "active_gap_reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "published_label": {
            "type": "string"
          },
          "publication_destinations": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "blocking_rule_ids",
        "blocking_claim_ids",
        "rationale",
        "promotion_gate"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "proceed",
            "hold"
          ]
        },
        "blocking_rule_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking_claim_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "promotion_gate": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "total_claims",
        "entries_holding_stable",
        "entries_narrowed",
        "entries_on_active_waiver",
        "entries_owner_blocked",
        "release_blocking_total",
        "release_blocking_holding",
        "release_blocking_narrowed",
        "notebook_entries",
        "data_rich_entries",
        "ai_adjacent_entries",
        "framework_entries",
        "review_entries",
        "companion_entries",
        "managed_depth_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "scorecard_sections_published",
        "scorecard_sections_stale",
        "scorecard_sections_missing",
        "compat_sections_published",
        "compat_sections_stale",
        "compat_sections_missing",
        "total_active_gap_reasons",
        "rules_firing"
      ],
      "properties": {
        "total_entries": {
          "type": "integer",
          "minimum": 0
        },
        "total_claims": {
          "type": "integer",
          "minimum": 0
        },
        "entries_holding_stable": {
          "type": "integer",
          "minimum": 0
        },
        "entries_narrowed": {
          "type": "integer",
          "minimum": 0
        },
        "entries_on_active_waiver": {
          "type": "integer",
          "minimum": 0
        },
        "entries_owner_blocked": {
          "type": "integer",
          "minimum": 0
        },
        "release_blocking_total": {
          "type": "integer",
          "minimum": 0
        },
        "release_blocking_holding": {
          "type": "integer",
          "minimum": 0
        },
        "release_blocking_narrowed": {
          "type": "integer",
          "minimum": 0
        },
        "notebook_entries": {
          "type": "integer",
          "minimum": 0
        },
        "data_rich_entries": {
          "type": "integer",
          "minimum": 0
        },
        "ai_adjacent_entries": {
          "type": "integer",
          "minimum": 0
        },
        "framework_entries": {
          "type": "integer",
          "minimum": 0
        },
        "review_entries": {
          "type": "integer",
          "minimum": 0
        },
        "companion_entries": {
          "type": "integer",
          "minimum": 0
        },
        "managed_depth_entries": {
          "type": "integer",
          "minimum": 0
        },
        "packets_current": {
          "type": "integer",
          "minimum": 0
        },
        "packets_due_for_refresh": {
          "type": "integer",
          "minimum": 0
        },
        "packets_breached": {
          "type": "integer",
          "minimum": 0
        },
        "packets_missing": {
          "type": "integer",
          "minimum": 0
        },
        "scorecard_sections_published": {
          "type": "integer",
          "minimum": 0
        },
        "scorecard_sections_stale": {
          "type": "integer",
          "minimum": 0
        },
        "scorecard_sections_missing": {
          "type": "integer",
          "minimum": 0
        },
        "compat_sections_published": {
          "type": "integer",
          "minimum": 0
        },
        "compat_sections_stale": {
          "type": "integer",
          "minimum": 0
        },
        "compat_sections_missing": {
          "type": "integer",
          "minimum": 0
        },
        "total_active_gap_reasons": {
          "type": "integer",
          "minimum": 0
        },
        "rules_firing": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}