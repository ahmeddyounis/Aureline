{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/ship_generated_artifact_lineage_surfaces_for_scaffolded_ai_generated_notebook_derived_and_preview_derived_outputs.schema.json",
  "title": "Generated-Artifact Lineage Surfaces for Scaffolded, AI-Generated, Notebook-Derived, and Preview-Derived Outputs",
  "description": "Canonical typed register that freezes one lineage surface per generated-artifact family, each binding the family to its stable claim, a lineage scorecard of one cell per dimension, the disclosed artifact provenance, an owner-manifest sign-off, and an explicit rollback/downgrade automation record. Downstream docs, Help/About, and support surfaces ingest this directly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "manifest_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "lifecycle_labels",
    "generator_kinds",
    "lineage_dimensions",
    "dimension_grades",
    "lineage_states",
    "narrowing_reasons",
    "stop_rule_actions",
    "downgrade_triggers",
    "automation_states",
    "trust_tiers",
    "launch_cutline",
    "release_blocking_surface_refs",
    "stop_rules",
    "rows",
    "promotion",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version of the register."
    },
    "record_kind": {
      "type": "string",
      "const": "ship_generated_artifact_lineage_surfaces_for_scaffolded_ai_generated_notebook_derived_and_preview_derived_outputs"
    },
    "manifest_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "overview_page": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "type": "string", "minLength": 1 },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
      }
    },
    "generator_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/generator_kind" }
    },
    "lineage_dimensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/lineage_dimension" }
    },
    "dimension_grades": {
      "type": "array",
      "items": { "$ref": "#/$defs/dimension_grade" }
    },
    "lineage_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/lineage_state" }
    },
    "narrowing_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/narrowing_reason" }
    },
    "stop_rule_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/stop_rule_action" }
    },
    "downgrade_triggers": {
      "type": "array",
      "items": { "$ref": "#/$defs/downgrade_trigger" }
    },
    "automation_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/automation_state" }
    },
    "trust_tiers": {
      "type": "array",
      "items": { "$ref": "#/$defs/trust_tier" }
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_surface_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stop_rule" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/lineage_surface" }
    },
    "promotion": { "$ref": "#/$defs/promotion_record" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "generator_kind": {
      "type": "string",
      "enum": [
        "scaffolded",
        "ai_generated",
        "notebook_derived",
        "preview_derived"
      ]
    },
    "lineage_dimension": {
      "type": "string",
      "enum": [
        "provenance",
        "inputs",
        "generator_identity",
        "transform",
        "reproducibility",
        "disclosure"
      ]
    },
    "dimension_grade": {
      "type": "string",
      "enum": ["pass", "partial", "fail", "waived", "missing"]
    },
    "lineage_state": {
      "type": "string",
      "enum": [
        "traced",
        "lineage_regressed",
        "stale",
        "on_waiver",
        "rollback_undefined",
        "owner_unsigned"
      ]
    },
    "narrowing_reason": {
      "type": "string",
      "enum": [
        "lineage_dimension_failed",
        "lineage_dimension_missing",
        "proof_packet_missing",
        "proof_packet_stale",
        "owner_manifest_unsigned",
        "rollback_plan_unverified",
        "downgrade_automation_undefined",
        "waiver_expired"
      ]
    },
    "stop_rule_action": {
      "type": "string",
      "enum": [
        "hold_promotion",
        "narrow_label",
        "remediate_lineage",
        "refresh_proof_packet",
        "request_owner_signoff",
        "verify_rollback_plan",
        "define_downgrade_automation",
        "renew_waiver"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": ["proof_stale", "lineage_regressed", "owner_revoked", "manual"]
    },
    "automation_state": {
      "type": "string",
      "enum": ["defined", "unverified", "undefined"]
    },
    "trust_tier": {
      "type": "string",
      "enum": ["first_party", "verified_third_party", "community", "untrusted"]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "type": "string", "const": "stable" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "type": "string", "enum": ["lts", "stable"] }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "type": "string", "enum": ["beta", "preview", "withdrawn"] }
        },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "stop_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_promotion",
        "rationale"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "trigger_reason": { "$ref": "#/$defs/narrowing_reason" },
        "applies_to_labels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
          }
        },
        "default_action": { "$ref": "#/$defs/stop_rule_action" },
        "blocks_promotion": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "freshness_slo",
        "slo_state"
      ],
      "properties": {
        "packet_id": { "type": "string", "minLength": 1 },
        "packet_ref": { "type": "string", "minLength": 1 },
        "proof_index_ref": { "type": "string", "minLength": 1 },
        "captured_at": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "format": "date" }
          ]
        },
        "freshness_slo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
          "properties": {
            "target_max_age_days": { "type": "integer", "minimum": 1 },
            "warn_within_days": { "type": "integer", "minimum": 0 },
            "slo_register_ref": { "type": "string", "minLength": 1 }
          }
        },
        "slo_state": {
          "type": "string",
          "enum": ["current", "due_for_refresh", "breached", "missing"]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "lineage_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "grade", "evidence_ref"],
      "properties": {
        "dimension": { "$ref": "#/$defs/lineage_dimension" },
        "grade": { "$ref": "#/$defs/dimension_grade" },
        "evidence_ref": { "type": "string" }
      }
    },
    "lineage_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generator_ref", "provider_ref", "trust_tier", "generated_labeled"],
      "properties": {
        "generator_ref": { "type": "string", "minLength": 1 },
        "provider_ref": { "type": "string", "minLength": 1 },
        "trust_tier": { "$ref": "#/$defs/trust_tier" },
        "input_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "generated_labeled": { "type": "boolean" }
      }
    },
    "downgrade_automation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "automation_ref",
        "rollback_plan_ref",
        "trigger",
        "target_floor",
        "state",
        "rollback_verified"
      ],
      "properties": {
        "automation_ref": { "type": "string", "minLength": 1 },
        "rollback_plan_ref": { "type": "string", "minLength": 1 },
        "trigger": { "$ref": "#/$defs/downgrade_trigger" },
        "target_floor": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "state": { "$ref": "#/$defs/automation_state" },
        "rollback_verified": { "type": "boolean" }
      }
    },
    "lineage_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "generator_kind",
        "surface_ref",
        "surface_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "lineage_state",
        "scorecard",
        "lineage",
        "downgrade_automation",
        "proof_packet",
        "owner_signoff",
        "published_label",
        "rationale"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "generator_kind": { "$ref": "#/$defs/generator_kind" },
        "surface_ref": { "type": "string", "minLength": 1 },
        "surface_summary": { "type": "string", "minLength": 1 },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "type": "string", "minLength": 1 },
        "claim_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "lineage_state": { "$ref": "#/$defs/lineage_state" },
        "scorecard": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/lineage_cell" }
        },
        "lineage": { "$ref": "#/$defs/lineage_provenance" },
        "downgrade_automation": { "$ref": "#/$defs/downgrade_automation" },
        "proof_packet": { "$ref": "#/$defs/proof_packet" },
        "waiver": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["waiver_ref", "expires_at", "reason"],
              "properties": {
                "waiver_ref": { "type": "string", "minLength": 1 },
                "expires_at": { "type": "string", "format": "date" },
                "reason": { "type": "string", "minLength": 1 }
              }
            }
          ]
        },
        "owner_signoff": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner_ref", "signed_off"],
          "properties": {
            "owner_ref": { "type": "string", "minLength": 1 },
            "signed_off": { "type": "boolean" },
            "signed_at": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "format": "date" }
              ]
            }
          }
        },
        "active_narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        },
        "published_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "publication_destinations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "promotion_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_claim_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blocking_claim_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "total_claims",
        "entries_traced",
        "entries_narrowed",
        "entries_on_active_waiver",
        "entries_with_dimension_gap",
        "entries_with_owner_gap",
        "entries_with_rollback_gap",
        "entries_unlabeled",
        "release_blocking_total",
        "release_blocking_traced",
        "release_blocking_narrowed",
        "scaffolded_entries",
        "ai_generated_entries",
        "notebook_derived_entries",
        "preview_derived_entries",
        "first_party_entries",
        "verified_third_party_entries",
        "community_entries",
        "untrusted_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_narrowing_reasons",
        "total_lineage_cells",
        "cells_pass",
        "cells_partial",
        "cells_fail",
        "cells_waived",
        "cells_missing",
        "rules_firing"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "entries_traced": { "type": "integer", "minimum": 0 },
        "entries_narrowed": { "type": "integer", "minimum": 0 },
        "entries_on_active_waiver": { "type": "integer", "minimum": 0 },
        "entries_with_dimension_gap": { "type": "integer", "minimum": 0 },
        "entries_with_owner_gap": { "type": "integer", "minimum": 0 },
        "entries_with_rollback_gap": { "type": "integer", "minimum": 0 },
        "entries_unlabeled": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_traced": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "scaffolded_entries": { "type": "integer", "minimum": 0 },
        "ai_generated_entries": { "type": "integer", "minimum": 0 },
        "notebook_derived_entries": { "type": "integer", "minimum": 0 },
        "preview_derived_entries": { "type": "integer", "minimum": 0 },
        "first_party_entries": { "type": "integer", "minimum": 0 },
        "verified_third_party_entries": { "type": "integer", "minimum": 0 },
        "community_entries": { "type": "integer", "minimum": 0 },
        "untrusted_entries": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_active_narrowing_reasons": { "type": "integer", "minimum": 0 },
        "total_lineage_cells": { "type": "integer", "minimum": 0 },
        "cells_pass": { "type": "integer", "minimum": 0 },
        "cells_partial": { "type": "integer", "minimum": 0 },
        "cells_fail": { "type": "integer", "minimum": 0 },
        "cells_waived": { "type": "integer", "minimum": 0 },
        "cells_missing": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
