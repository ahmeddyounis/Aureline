{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/publish_the_m5_storage_retention_export_and_offboarding_matrix_for_new_durable_artifacts.schema.json",
  "title": "M5 Storage, Retention, Export, and Offboarding Matrix for New Durable Artifacts",
  "description": "Canonical typed matrix that publishes M5 durable artifact storage, retention, export, and offboarding posture. Downstream docs, Help/About, and support surfaces ingest this directly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "matrix_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "feature_train_matrix_ref",
    "lifecycle_labels",
    "artifact_kinds",
    "indicator_kinds",
    "indicator_states",
    "row_states",
    "gap_reasons",
    "stop_rule_actions",
    "launch_cutline",
    "release_blocking_artifact_refs",
    "stop_rules",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version of the matrix."
    },
    "record_kind": {
      "type": "string",
      "const": "publish_the_m5_storage_retention_export_and_offboarding_matrix_for_new_durable_artifacts"
    },
    "matrix_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "overview_page": {
      "type": "string",
      "minLength": 1
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "claim_manifest_ref": {
      "type": "string",
      "minLength": 1
    },
    "feature_train_matrix_ref": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
      }
    },
    "artifact_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "user_owned_local",
          "workspace_owned_managed",
          "ai_memory",
          "sync_state",
          "session_export",
          "derived_cache"
        ]
      }
    },
    "indicator_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "storage_defined",
          "retention_defined",
          "export_defined",
          "offboarding_tested"
        ]
      }
    },
    "indicator_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "planned",
          "drafted",
          "reviewed",
          "published",
          "stale",
          "missing"
        ]
      }
    },
    "row_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "complete",
          "incomplete",
          "stale",
          "on_waiver",
          "owner_blocked"
        ]
      }
    },
    "gap_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "retention_posture_incomplete",
          "retention_posture_stale",
          "proof_packet_missing",
          "proof_packet_stale",
          "owner_signoff_missing",
          "waiver_expired"
        ]
      }
    },
    "stop_rule_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "hold_publication",
          "narrow_label",
          "staff_retention_policy",
          "request_owner_signoff"
        ]
      }
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": {
          "type": "string",
          "enum": ["stable"]
        },
        "above_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["lts", "stable"]
          }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["beta", "preview", "withdrawn"]
          }
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "release_blocking_artifact_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "stop_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule_id",
          "title",
          "trigger_reason",
          "applies_to_labels",
          "default_action",
          "blocks_publication",
          "rationale"
        ],
        "properties": {
          "rule_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "trigger_reason": {
            "type": "string",
            "enum": [
              "retention_posture_incomplete",
              "retention_posture_stale",
              "proof_packet_missing",
              "proof_packet_stale",
              "owner_signoff_missing",
              "waiver_expired"
            ]
          },
          "applies_to_labels": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
            }
          },
          "default_action": {
            "type": "string",
            "enum": [
              "hold_publication",
              "narrow_label",
              "staff_retention_policy",
              "request_owner_signoff"
            ]
          },
          "blocks_publication": {
            "type": "boolean"
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entry_id",
          "title",
          "artifact_kind",
          "surface_ref",
          "surface_summary",
          "release_blocking",
          "claim_ref",
          "claim_label",
          "retention_posture",
          "row_state",
          "proof_packet",
          "owner_signoff",
          "active_gap_reasons",
          "published_label",
          "rationale"
        ],
        "properties": {
          "entry_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "artifact_kind": {
            "type": "string",
            "enum": [
              "user_owned_local",
              "workspace_owned_managed",
              "ai_memory",
              "sync_state",
              "session_export",
              "derived_cache"
            ]
          },
          "surface_ref": {
            "type": "string",
            "minLength": 1
          },
          "surface_summary": {
            "type": "string",
            "minLength": 1
          },
          "release_blocking": {
            "type": "boolean"
          },
          "claim_ref": {
            "type": "string",
            "minLength": 1
          },
          "claim_label": {
            "type": "string",
            "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
          },
          "retention_posture": {
            "type": "object",
            "additionalProperties": false,
            "required": ["posture_id", "posture_version", "indicators"],
            "properties": {
              "posture_id": {
                "type": "string",
                "minLength": 1
              },
              "posture_version": {
                "type": "integer",
                "minimum": 1
              },
              "indicators": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "indicator_id",
                    "title",
                    "indicator_kind",
                    "artifact_ref",
                    "indicator_state",
                    "owner_ref",
                    "rationale"
                  ],
                  "properties": {
                    "indicator_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "title": {
                      "type": "string",
                      "minLength": 1
                    },
                    "indicator_kind": {
                      "type": "string",
                      "enum": [
                        "storage_defined",
                        "retention_defined",
                        "export_defined",
                        "offboarding_tested"
                      ]
                    },
                    "artifact_ref": {
                      "type": "string",
                      "minLength": 1
                    },
                    "indicator_state": {
                      "type": "string",
                      "enum": [
                        "planned",
                        "drafted",
                        "reviewed",
                        "published",
                        "stale",
                        "missing"
                      ]
                    },
                    "owner_ref": {
                      "type": "string",
                      "minLength": 1
                    },
                    "rationale": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          },
          "proof_packet": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "packet_id",
              "packet_ref",
              "proof_index_ref",
              "captured_at",
              "freshness_slo",
              "slo_state",
              "evidence_refs"
            ],
            "properties": {
              "packet_id": {
                "type": "string",
                "minLength": 1
              },
              "packet_ref": {
                "type": "string",
                "minLength": 1
              },
              "proof_index_ref": {
                "type": "string",
                "minLength": 1
              },
              "captured_at": {
                "type": ["string", "null"]
              },
              "freshness_slo": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "target_max_age_days",
                  "warn_within_days",
                  "slo_register_ref"
                ],
                "properties": {
                  "target_max_age_days": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "warn_within_days": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "slo_register_ref": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "slo_state": {
                "type": "string",
                "enum": [
                  "current",
                  "due_for_refresh",
                  "breached",
                  "missing"
                ]
              },
              "evidence_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "waiver": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": [
              "waiver_ref",
              "expires_at",
              "reason"
            ],
            "properties": {
              "waiver_ref": {
                "type": "string",
                "minLength": 1
              },
              "expires_at": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "owner_signoff": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "owner_ref",
              "signed_off",
              "signed_at"
            ],
            "properties": {
              "owner_ref": {
                "type": "string",
                "minLength": 1
              },
              "signed_off": {
                "type": "boolean"
              },
              "signed_at": {
                "type": ["string", "null"]
              }
            }
          },
          "active_gap_reasons": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "retention_posture_incomplete",
                "retention_posture_stale",
                "proof_packet_missing",
                "proof_packet_stale",
                "owner_signoff_missing",
                "waiver_expired"
              ]
            }
          },
          "published_label": {
            "type": "string",
            "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
          },
          "publication_destinations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_claim_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": ["proceed", "hold"]
        },
        "blocking_rule_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking_claim_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "total_claims",
        "entries_holding_stable",
        "entries_narrowed",
        "entries_on_active_waiver",
        "entries_owner_blocked",
        "release_blocking_total",
        "release_blocking_holding",
        "release_blocking_narrowed",
        "user_owned_local_entries",
        "workspace_owned_managed_entries",
        "ai_memory_entries",
        "sync_state_entries",
        "session_export_entries",
        "derived_cache_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "indicators_published",
        "indicators_stale",
        "indicators_missing",
        "total_active_gap_reasons",
        "rules_firing"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "entries_holding_stable": { "type": "integer", "minimum": 0 },
        "entries_narrowed": { "type": "integer", "minimum": 0 },
        "entries_on_active_waiver": { "type": "integer", "minimum": 0 },
        "entries_owner_blocked": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_holding": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "user_owned_local_entries": { "type": "integer", "minimum": 0 },
        "workspace_owned_managed_entries": { "type": "integer", "minimum": 0 },
        "ai_memory_entries": { "type": "integer", "minimum": 0 },
        "sync_state_entries": { "type": "integer", "minimum": 0 },
        "session_export_entries": { "type": "integer", "minimum": 0 },
        "derived_cache_entries": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "indicators_published": { "type": "integer", "minimum": 0 },
        "indicators_stale": { "type": "integer", "minimum": 0 },
        "indicators_missing": { "type": "integer", "minimum": 0 },
        "total_active_gap_reasons": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
