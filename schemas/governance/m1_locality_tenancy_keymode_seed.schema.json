{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/m1_locality_tenancy_keymode_seed.schema.json",
  "title": "Aureline locality/tenancy/key-mode seed envelope",
  "description": "Boundary schema for artifacts/governance/locality_examples.yaml. The envelope pins the canonical row vocabulary at locality_tenancy_keymode.schema.json, the reviewer-facing landing page at docs/governance/m1_locality_tenancy_keymode_vocabulary.md, the existing internal boundary manifest as an upstream source, the build-identity record the validation lane embeds, the validation-lane registry ref, the closed locality / tenancy / key-mode / local-safe-fallback / residency-disclosure / truth-badge / diagnostic-surface vocabularies, the required coverage lists, the named-runtime-consumer set the seed asserts is live, and the named failure-drill ids the per-row drills must draw from. Rows conform to the row schema; the envelope cannot relax that contract.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "status",
    "matrix_id",
    "owner_dri",
    "overview_page",
    "upstream_boundary_manifest_ref",
    "row_schema_ref",
    "build_identity_ref",
    "validation_lane_ref",
    "locality_class_vocabulary",
    "tenancy_scope_class_vocabulary",
    "key_storage_mode_class_vocabulary",
    "local_safe_fallback_class_vocabulary",
    "data_residency_disclosure_class_vocabulary",
    "truth_badge_class_vocabulary",
    "diagnostic_surface_class_vocabulary",
    "surface_family_class_vocabulary",
    "failure_drill_id_vocabulary",
    "named_runtime_consumers",
    "required_locality_class_coverage",
    "required_tenancy_scope_class_coverage",
    "required_key_storage_mode_class_coverage",
    "required_diagnostic_surface_class_coverage",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": ["seeded", "stabilising", "stable"]
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "matrix_id": {
      "type": "string",
      "const": "m1_locality_tenancy_keymode_seed"
    },
    "owner_dri": {
      "type": "string",
      "pattern": "^@[a-zA-Z0-9_-]+$"
    },
    "overview_page": {
      "type": "string",
      "const": "docs/governance/m1_locality_tenancy_keymode_vocabulary.md"
    },
    "upstream_boundary_manifest_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Upstream internal boundary manifest matrix the M1 locality/tenancy/key-mode seed projects against. Must resolve on disk."
    },
    "upstream_connected_provider_seed_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Optional reference to the upstream connected-provider/provider-descriptor seed when the row applies to provider-linked or managed surfaces."
    },
    "row_schema_ref": {
      "type": "string",
      "const": "schemas/governance/locality_tenancy_keymode.schema.json"
    },
    "build_identity_ref": {
      "type": "string",
      "minLength": 1
    },
    "validation_lane_ref": {
      "type": "string",
      "minLength": 1
    },
    "locality_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 6,
      "items": {
        "type": "string",
        "enum": [
          "local_only",
          "remote_target",
          "provider_linked",
          "managed_control_plane_bearing",
          "mirrored",
          "unknown_locality"
        ]
      },
      "description": "Closed locality vocabulary. MUST agree with the row schema's locality_class $defs enum."
    },
    "tenancy_scope_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 7,
      "items": {
        "type": "string",
        "enum": [
          "not_applicable_local_only",
          "single_user_local",
          "single_user_managed_tenant",
          "org_tenant",
          "multi_tenant_isolated",
          "multi_tenant_shared",
          "unknown_tenancy"
        ]
      },
      "description": "Closed tenancy-scope vocabulary. MUST agree with the row schema's tenancy_scope_class $defs enum."
    },
    "key_storage_mode_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 7,
      "items": {
        "type": "string",
        "enum": [
          "not_applicable_local_only",
          "local_storage_only",
          "os_keychain_backed",
          "byok_user_managed",
          "provider_managed_key",
          "managed_service_kms",
          "unknown_key_mode"
        ]
      },
      "description": "Closed key/storage-mode vocabulary. MUST agree with the row schema's key_storage_mode_class $defs enum."
    },
    "local_safe_fallback_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "local_safe_fallback_present",
          "local_safe_fallback_narrowed",
          "local_safe_fallback_unavailable"
        ]
      }
    },
    "data_residency_disclosure_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "residency_local_device_only",
          "residency_user_owned_remote_target",
          "residency_provider_default",
          "residency_managed_tenant_documented_region",
          "residency_unknown"
        ]
      }
    },
    "truth_badge_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "client_scope_badge",
          "boundary_class_badge",
          "residual_dependency_posture_badge",
          "freshness_badge",
          "managed_disclosure_badge"
        ]
      }
    },
    "diagnostic_surface_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "help_about_pane",
          "service_health_row",
          "support_export_section",
          "release_evidence_pack",
          "ci_validation"
        ]
      }
    },
    "surface_family_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 6,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Closed surface-family vocabulary. MUST agree with the row schema's surface_family_class $defs enum."
    },
    "failure_drill_id_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "description": "Closed vocabulary of named failure drills the per-row failure_drill blocks must draw from."
    },
    "named_runtime_consumers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "consumer_id",
          "consumer_class",
          "consumer_ref",
          "consumed_fields"
        ],
        "properties": {
          "consumer_id": { "type": "string", "minLength": 1 },
          "consumer_class": {
            "type": "string",
            "enum": [
              "review_docs_landing_page",
              "rust_runtime_validator",
              "ci_schema_validator",
              "support_or_release_surface",
              "docs_or_help_surface",
              "design_packet",
              "upstream_governance_matrix"
            ]
          },
          "consumer_ref": { "type": "string", "minLength": 1 },
          "consumed_fields": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "notes": { "type": "string" }
        }
      },
      "description": "Named live consumers that read the locality/tenancy/key-mode seed. The lane resolves consumer_ref on disk and asserts consumed_fields is non-empty so a consumer cannot regress to mentioned-but-unread."
    },
    "required_locality_class_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "local_only",
          "remote_target",
          "provider_linked",
          "managed_control_plane_bearing",
          "mirrored",
          "unknown_locality"
        ]
      },
      "description": "Locality classes that MUST appear at least once across the entries so the seed names local-only, remote-target, provider-linked, and managed/control-plane-bearing surfaces explicitly."
    },
    "required_tenancy_scope_class_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "not_applicable_local_only",
          "single_user_local",
          "single_user_managed_tenant",
          "org_tenant",
          "multi_tenant_isolated",
          "multi_tenant_shared",
          "unknown_tenancy"
        ]
      }
    },
    "required_key_storage_mode_class_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "not_applicable_local_only",
          "local_storage_only",
          "os_keychain_backed",
          "byok_user_managed",
          "provider_managed_key",
          "managed_service_kms",
          "unknown_key_mode"
        ]
      }
    },
    "required_diagnostic_surface_class_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "help_about_pane",
          "service_health_row",
          "support_export_section",
          "release_evidence_pack",
          "ci_validation"
        ]
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "locality_tenancy_keymode.schema.json"
      }
    }
  }
}
