{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/experiment_registry.schema.json",
  "title": "Aureline experiments / flags / Labs registry seed envelope",
  "description": "Boundary schema for artifacts/governance/experiments_registry.yaml. The envelope pins the canonical row vocabulary at experiment_registry_entry.schema.json, the reviewer-facing landing page at docs/governance/m1_experiments_and_labs_seed.md, the upstream registers the seed projects against (experiments_register.yaml and labs_register.yaml), the build-identity record the validation lane embeds, the validation-lane registry ref, the closed row-kind / audience / lifecycle / cohort / default-posture / public-label / telemetry / graduation-retirement / kill-switch vocabularies, the required coverage lists, the named-runtime-consumer set the seed asserts is live, and the named failure-drill ids the per-row drills must draw from. Rows conform to the row schema; the envelope cannot relax that contract.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "status",
    "as_of",
    "matrix_id",
    "owner_dri",
    "overview_page",
    "row_schema_ref",
    "build_identity_ref",
    "validation_lane_ref",
    "companion_registers",
    "row_kind_class_vocabulary",
    "audience_class_vocabulary",
    "lifecycle_state_class_vocabulary",
    "cohort_class_vocabulary",
    "default_posture_class_vocabulary",
    "public_label_class_vocabulary",
    "telemetry_posture_class_vocabulary",
    "graduation_retirement_path_class_vocabulary",
    "kill_switch_source_class_vocabulary",
    "required_row_kind_class_coverage",
    "required_audience_class_coverage",
    "required_lifecycle_state_class_coverage",
    "failure_drill_id_vocabulary",
    "named_runtime_consumers",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": ["seeded", "stabilising", "stable"]
    },
    "as_of": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO-8601 calendar date the registry snapshot was taken. The validation lane compares each row's review_by / expires_on against as_of so an expired row trips the experiment-registry expiry check."
    },
    "matrix_id": {
      "type": "string",
      "const": "m1_experiments_and_labs_seed"
    },
    "owner_dri": {
      "type": "string",
      "pattern": "^@[a-zA-Z0-9_-]+$"
    },
    "overview_page": {
      "type": "string",
      "const": "docs/governance/m1_experiments_and_labs_seed.md"
    },
    "row_schema_ref": {
      "type": "string",
      "const": "schemas/governance/experiment_registry_entry.schema.json"
    },
    "build_identity_ref": {
      "type": "string",
      "minLength": 1
    },
    "validation_lane_ref": {
      "type": "string",
      "minLength": 1
    },
    "companion_registers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["experiments_register", "labs_register"],
      "properties": {
        "experiments_register": {
          "type": "string",
          "const": "artifacts/governance/experiments_register.yaml"
        },
        "labs_register": {
          "type": "string",
          "const": "artifacts/governance/labs_register.yaml"
        }
      },
      "description": "Stable companion-register paths the M1 seed projects against. The seed never forks these registers; it consumes their stable ids and re-projects them into a closed governance vocabulary."
    },
    "row_kind_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": ["experiment", "feature_flag", "benchmark_mode", "rollout"]
      },
      "description": "Closed row-kind vocabulary. MUST agree with the row schema's row_kind_class $defs enum."
    },
    "audience_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "contributor_visible_labs",
          "hidden_developer_toggle",
          "control_stack_reserved",
          "ci_rollout_only"
        ]
      },
      "description": "Closed audience vocabulary. MUST agree with the row schema's audience_class $defs enum."
    },
    "lifecycle_state_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 7,
      "items": {
        "type": "string",
        "enum": [
          "labs",
          "preview",
          "beta",
          "stable",
          "deprecated",
          "disabled_by_policy",
          "retired"
        ]
      },
      "description": "Closed lifecycle vocabulary. MUST agree with the row schema's lifecycle_state_class $defs enum."
    },
    "cohort_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 7,
      "items": {
        "type": "string",
        "enum": [
          "maintainer_and_contributor_local",
          "developer_local_only",
          "developer_local_and_ci_preview",
          "developer_local_and_ci_seed_guard",
          "ci_nightly_reference_hardware",
          "workflow_dispatch_only",
          "reserved_for_future_settings_rollout"
        ]
      },
      "description": "Closed cohort / ring vocabulary mirrored from the upstream experiments_register.yaml."
    },
    "default_posture_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 7,
      "items": {
        "type": "string",
        "enum": [
          "off_by_default",
          "opt_in_only",
          "enabled_when_named_on_cli",
          "default_for_developer_local",
          "scheduled_ci_only",
          "manual_failure_drill_only",
          "reserved_until_runtime_control_stack_lands"
        ]
      },
      "description": "Closed default-posture vocabulary mirrored from the upstream experiments_register.yaml."
    },
    "public_label_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "public_labs_visible_label",
          "hidden_developer_toggle_label",
          "control_stack_reserved_label",
          "ci_rollout_only_label"
        ]
      },
      "description": "Closed public-label vocabulary. MUST agree with the row schema's public_label_class $defs enum."
    },
    "telemetry_posture_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "counts_only_local",
          "counts_only_local_then_optional_export",
          "no_remote_telemetry",
          "not_applicable_reserved_binding"
        ]
      },
      "description": "Closed telemetry-posture vocabulary."
    },
    "graduation_retirement_path_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 6,
      "items": {
        "type": "string",
        "enum": [
          "graduate_to_stable",
          "graduate_to_beta",
          "retire_to_disabled_by_policy",
          "retire_to_deleted",
          "hold_pending_runtime_control_stack",
          "hold_pending_review_decision"
        ]
      },
      "description": "Closed graduation / retirement vocabulary."
    },
    "kill_switch_source_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "embedded_default_off",
          "local_cli_argument",
          "ci_workflow_input",
          "signed_local_admin_bundle",
          "optional_managed_override"
        ]
      },
      "description": "Closed kill-switch source vocabulary mirrored from the upstream experiments_register.yaml."
    },
    "required_row_kind_class_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": ["experiment", "feature_flag", "benchmark_mode", "rollout"]
      },
      "description": "Row-kind classes the seed MUST seed at least once across its entries."
    },
    "required_audience_class_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "contributor_visible_labs",
          "hidden_developer_toggle",
          "control_stack_reserved",
          "ci_rollout_only"
        ]
      },
      "description": "Audience classes the seed MUST exercise at least once across its entries."
    },
    "required_lifecycle_state_class_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 2,
      "items": {
        "type": "string",
        "enum": [
          "labs",
          "preview",
          "beta",
          "stable",
          "deprecated",
          "disabled_by_policy",
          "retired"
        ]
      },
      "description": "Lifecycle states the seed MUST exercise at least once across its entries. M1 has no graduated rows yet, so beta/stable/deprecated/disabled_by_policy/retired are not required coverage; the seed MUST exercise at least labs and preview so the lifecycle vocabulary is not aspirational."
    },
    "failure_drill_id_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "description": "Closed vocabulary of named failure drills the per-row failure_drill blocks must draw from."
    },
    "named_runtime_consumers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "consumer_id",
          "consumer_class",
          "consumer_ref",
          "consumed_fields"
        ],
        "properties": {
          "consumer_id": { "type": "string", "minLength": 1 },
          "consumer_class": {
            "type": "string",
            "enum": [
              "review_docs_landing_page",
              "ci_schema_validator",
              "docs_or_help_surface",
              "support_or_release_surface",
              "upstream_governance_register"
            ]
          },
          "consumer_ref": { "type": "string", "minLength": 1 },
          "consumed_fields": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "notes": { "type": "string" }
        }
      },
      "description": "Named live consumers that read the registry. The validation lane resolves consumer_ref on disk and asserts consumed_fields is non-empty so a consumer cannot regress to 'mentioned but never read'."
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "experiment_registry_entry.schema.json"
      }
    }
  }
}
