{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/boundary_manifest_v1.schema.json",
  "title": "Aureline alpha boundary manifest",
  "description": "Boundary schema for the alpha capability manifest that joins open local, self-hostable, mirrored, managed, entitlement, quota, usage-export, and offboarding truth. The manifest is the source consumed by docs/help, admin, CLI/headless, support-export, and release-evidence surfaces before they label a capability as local, self-hostable, mirrored, managed, quota-gated, restricted, or offboarded. Local-core capability rows must not require managed identity, live network reachability, quota meters, or usage-export packets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "as_of",
    "owner_dri",
    "schema_ref",
    "source_contract_refs",
    "consumer_bindings",
    "boundary_class_vocabulary",
    "claim_status_vocabulary",
    "identity_boundary_vocabulary",
    "network_boundary_vocabulary",
    "meter_definitions",
    "capability_rows"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "manifest_id": { "type": "string", "pattern": "^boundary_manifest\\.[a-z0-9_]+$" },
    "as_of": { "type": "string", "format": "date" },
    "owner_dri": { "type": "string", "pattern": "^@.+" },
    "schema_ref": {
      "type": "string",
      "const": "schemas/governance/boundary_manifest_v1.schema.json"
    },
    "source_contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alpha_wedge_matrix_ref",
        "schema_registry_ref",
        "record_class_registry_ref",
        "usage_export_posture_matrix_ref",
        "product_boundary_strawman_ref",
        "usage_offboarding_contract_ref"
      ],
      "properties": {
        "alpha_wedge_matrix_ref": { "$ref": "#/$defs/ref" },
        "schema_registry_ref": { "$ref": "#/$defs/ref" },
        "record_class_registry_ref": { "$ref": "#/$defs/ref" },
        "usage_export_posture_matrix_ref": { "$ref": "#/$defs/ref" },
        "product_boundary_strawman_ref": { "$ref": "#/$defs/ref" },
        "usage_offboarding_contract_ref": { "$ref": "#/$defs/ref" }
      }
    },
    "consumer_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first_consumer", "consumer_surfaces"],
      "properties": {
        "first_consumer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["consumer_id", "consumer_kind", "consumer_ref", "render_command"],
          "properties": {
            "consumer_id": { "$ref": "#/$defs/opaque_id" },
            "consumer_kind": {
              "type": "string",
              "enum": ["cli_support_export_projection", "docs_help_projection", "admin_projection", "ci_validator"]
            },
            "consumer_ref": { "$ref": "#/$defs/ref" },
            "render_command": { "type": "string", "minLength": 1 }
          }
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["docs_help", "admin", "support_export", "cli", "release_evidence"]
          }
        }
      }
    },
    "boundary_class_vocabulary": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/boundary_class" }
    },
    "claim_status_vocabulary": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/claim_status" }
    },
    "identity_boundary_vocabulary": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identity_boundary" }
    },
    "network_boundary_vocabulary": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/network_boundary" }
    },
    "meter_definitions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/meter_definition" }
    },
    "capability_rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability_row" }
    }
  },
  "$defs": {
    "ref": { "type": "string", "minLength": 1 },
    "opaque_id": { "type": "string", "minLength": 1 },
    "sentence": { "type": "string", "minLength": 1 },
    "capability_id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "meter_id": { "type": "string", "pattern": "^meter\\.[a-z0-9_.]+$" },
    "boundary_class": {
      "type": "string",
      "enum": [
        "open_local_core",
        "self_hostable_service",
        "mirrored_service",
        "managed_optional",
        "managed_premium",
        "managed_admin_only",
        "explicitly_out_of_scope"
      ]
    },
    "claim_status": {
      "type": "string",
      "enum": ["alpha_core_claim", "alpha_managed_truth_seed", "explicitly_out_of_scope"]
    },
    "identity_boundary": {
      "type": "string",
      "enum": [
        "no_identity_required",
        "optional_account",
        "org_identity_required_for_managed_action",
        "admin_identity_required_for_managed_action"
      ]
    },
    "network_boundary": {
      "type": "string",
      "enum": [
        "none",
        "optional_public_or_mirror",
        "customer_operated_control_plane",
        "vendor_managed_control_plane",
        "mirror_or_file_import",
        "denied_for_alpha"
      ]
    },
    "alternative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "capability_ref", "summary"],
      "properties": {
        "available": { "type": "boolean" },
        "capability_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/capability_id" }
          ]
        },
        "summary": { "$ref": "#/$defs/sentence" }
      }
    },
    "mirrored_alternative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "mirror_class", "summary"],
      "properties": {
        "available": { "type": "boolean" },
        "mirror_class": {
          "type": "string",
          "enum": ["signed_mirror", "file_import", "offline_bundle", "not_applicable"]
        },
        "summary": { "$ref": "#/$defs/sentence" }
      }
    },
    "lifecycle_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["introduced_at", "review_state", "owner_dri", "source_refs"],
      "properties": {
        "introduced_at": { "type": "string", "format": "date" },
        "review_state": { "type": "string", "enum": ["seeded", "accepted", "deferred", "superseded"] },
        "owner_dri": { "type": "string", "pattern": "^@.+" },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/ref" }
        },
        "supersedes_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      }
    },
    "meter_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "meter_id",
        "capability_refs",
        "service_family_class",
        "quota_family_class",
        "quota_unit_class",
        "export_row_contract_ref",
        "meter_summary"
      ],
      "properties": {
        "meter_id": { "$ref": "#/$defs/meter_id" },
        "capability_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/capability_id" }
        },
        "service_family_class": { "$ref": "#/$defs/opaque_id" },
        "quota_family_class": { "$ref": "#/$defs/opaque_id" },
        "quota_unit_class": { "$ref": "#/$defs/opaque_id" },
        "export_row_contract_ref": { "$ref": "#/$defs/ref" },
        "meter_summary": { "$ref": "#/$defs/sentence" }
      }
    },
    "capability_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_id",
        "title",
        "boundary_class",
        "claim_status",
        "open_local_alternative",
        "self_host_alternative",
        "mirrored_or_airgap_alternative",
        "required_identity_boundary",
        "required_network_boundary",
        "entitlement_state_refs",
        "quota_meter_refs",
        "usage_export_baseline_refs",
        "offboarding_baseline_refs",
        "local_core_guardrail",
        "lifecycle_metadata"
      ],
      "properties": {
        "capability_id": { "$ref": "#/$defs/capability_id" },
        "title": { "$ref": "#/$defs/sentence" },
        "boundary_class": { "$ref": "#/$defs/boundary_class" },
        "claim_status": { "$ref": "#/$defs/claim_status" },
        "open_local_alternative": { "$ref": "#/$defs/alternative" },
        "self_host_alternative": { "$ref": "#/$defs/alternative" },
        "mirrored_or_airgap_alternative": { "$ref": "#/$defs/mirrored_alternative" },
        "required_identity_boundary": { "$ref": "#/$defs/identity_boundary" },
        "required_network_boundary": { "$ref": "#/$defs/network_boundary" },
        "entitlement_state_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "quota_meter_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/meter_id" }
        },
        "usage_export_baseline_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "offboarding_baseline_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "local_core_guardrail": { "$ref": "#/$defs/sentence" },
        "lifecycle_metadata": { "$ref": "#/$defs/lifecycle_metadata" }
      }
    }
  }
}
