{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/m5_truth_surface_evidence_ingestion.schema.json",
  "title": "Aureline M5 truth-surface evidence-ingestion register",
  "description": "Boundary schema for the m5_truth_surface_evidence_ingestion register emitted by the aureline-release m5_truth_surface_evidence_ingestion module. For every M5 feature family the register records one ingestion row per user-/operator-facing truth surface (Help/About, service health, release center, support export, public-truth pack) so each surface shows the family's current canonical lifecycle state from the same checked-in inputs instead of cloning stale status text. This is the XT-12 learnability/boundary truth ingestion lane. Each row ingests the canonical claim ceiling and effective label straight from the M5 feature family register, publishes a label that must equal the canonical effective label, exposes whether the lane is stale/narrowed/policy-blocked/preview-only/underqualified, and always discloses local-only/mirrored/managed/browser-handoff posture. Service-health rows additionally carry an operational service-contract state. The schema is metadata-only and carries no credential bodies or raw provider payloads. The artifact is regenerated by tools/regenerate_m5_truth_surface_ingestion.py and cross-checked against its canonical source packet by tools/ci/m5/truth_surface_ingestion_check.py.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "register_id",
    "status",
    "overview_page",
    "as_of",
    "source_refs",
    "claim_manifest_ref",
    "family_kinds",
    "truth_surfaces",
    "ingest_states",
    "posture_classes",
    "service_contract_states",
    "lifecycle_labels",
    "launch_cutline",
    "release_blocking_family_refs",
    "contradiction_rules",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "m5_truth_surface_evidence_ingestion" },
    "register_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "type": "string", "enum": ["published", "draft", "hold"] },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "$ref": "#/$defs/date" },
    "source_refs": { "$ref": "#/$defs/source_refs" },
    "claim_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "family_kinds": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/family_kind" }
    },
    "truth_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/truth_surface" }
    },
    "ingest_states": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ingest_state" }
    },
    "posture_classes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/posture_class" }
    },
    "service_contract_states": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/service_contract_state" }
    },
    "lifecycle_labels": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/lifecycle_label" }
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_family_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "contradiction_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/contradiction_rule" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/row" }
    },
    "publication": { "$ref": "#/$defs/publication" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "lifecycle_label": {
      "type": "string",
      "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
    },
    "family_kind": {
      "type": "string",
      "enum": [
        "notebook",
        "data_rich",
        "ai_adjacent",
        "framework",
        "review",
        "companion",
        "managed_depth"
      ]
    },
    "truth_surface": {
      "type": "string",
      "enum": [
        "help_about",
        "service_health",
        "release_center",
        "support_export",
        "public_truth_pack"
      ]
    },
    "ingest_state": {
      "type": "string",
      "enum": [
        "current",
        "stale",
        "narrowed",
        "policy_blocked",
        "preview_only",
        "underqualified"
      ]
    },
    "posture_class": {
      "type": "string",
      "enum": ["local_only", "mirrored", "managed", "browser_handoff"]
    },
    "service_contract_state": {
      "type": "string",
      "enum": [
        "ready",
        "degraded",
        "local_only",
        "stale",
        "contract_mismatch",
        "policy_blocked",
        "unavailable"
      ]
    },
    "ingest_reason": {
      "type": "string",
      "enum": [
        "source_on_active_waiver",
        "source_proof_packet_stale",
        "source_family_incomplete",
        "source_rollback_path_missing",
        "admin_policy_managed",
        "source_family_narrowed"
      ]
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "feature_family_register_ref",
        "depth_claim_manifest_ref",
        "cross_surface_hardening_ref",
        "certify_train_register_ref",
        "docs_help_about_service_health_truth_ref"
      ],
      "properties": {
        "feature_family_register_ref": { "$ref": "#/$defs/non_empty_string" },
        "depth_claim_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "cross_surface_hardening_ref": { "$ref": "#/$defs/non_empty_string" },
        "certify_train_register_ref": { "$ref": "#/$defs/non_empty_string" },
        "docs_help_about_service_health_truth_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "$ref": "#/$defs/lifecycle_label" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" }
        },
        "description": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "contradiction_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "default_action",
        "blocks_publication",
        "rationale"
      ],
      "properties": {
        "rule_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "trigger_reason": { "$ref": "#/$defs/non_empty_string" },
        "default_action": { "$ref": "#/$defs/non_empty_string" },
        "blocks_publication": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "family_kind",
        "family_ref",
        "truth_surface",
        "surface_ref",
        "surface_summary",
        "release_blocking",
        "canonical_source_ref",
        "canonical_claim_label",
        "canonical_published_label",
        "ingest_state",
        "posture",
        "published_label",
        "active_ingest_reasons",
        "evidence_ref",
        "rationale"
      ],
      "properties": {
        "entry_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "family_kind": { "$ref": "#/$defs/family_kind" },
        "family_ref": { "$ref": "#/$defs/non_empty_string" },
        "truth_surface": { "$ref": "#/$defs/truth_surface" },
        "surface_ref": { "$ref": "#/$defs/non_empty_string" },
        "surface_summary": { "$ref": "#/$defs/non_empty_string" },
        "release_blocking": { "type": "boolean" },
        "canonical_source_ref": { "$ref": "#/$defs/non_empty_string" },
        "canonical_claim_label": { "$ref": "#/$defs/lifecycle_label" },
        "canonical_published_label": { "$ref": "#/$defs/lifecycle_label" },
        "ingest_state": { "$ref": "#/$defs/ingest_state" },
        "posture": { "$ref": "#/$defs/posture_class" },
        "published_label": { "$ref": "#/$defs/lifecycle_label" },
        "active_ingest_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/ingest_reason" }
        },
        "evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "service_contract_state": { "$ref": "#/$defs/service_contract_state" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_entry_ids",
        "rationale"
      ],
      "properties": {
        "publication_gate": { "$ref": "#/$defs/non_empty_string" },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "blocking_entry_ids": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows",
        "total_families",
        "total_surfaces",
        "release_blocking_rows",
        "rows_below_cutline",
        "service_health_rows",
        "contradiction_rules_firing",
        "rows_current",
        "rows_stale",
        "rows_narrowed",
        "rows_policy_blocked",
        "rows_preview_only",
        "rows_underqualified",
        "help_about_rows",
        "release_center_rows",
        "support_export_rows",
        "public_truth_pack_rows"
      ],
      "properties": {
        "total_rows": { "type": "integer", "minimum": 0 },
        "total_families": { "type": "integer", "minimum": 0 },
        "total_surfaces": { "type": "integer", "minimum": 0 },
        "release_blocking_rows": { "type": "integer", "minimum": 0 },
        "rows_below_cutline": { "type": "integer", "minimum": 0 },
        "service_health_rows": { "type": "integer", "minimum": 0 },
        "contradiction_rules_firing": { "type": "integer", "minimum": 0 },
        "rows_current": { "type": "integer", "minimum": 0 },
        "rows_stale": { "type": "integer", "minimum": 0 },
        "rows_narrowed": { "type": "integer", "minimum": 0 },
        "rows_policy_blocked": { "type": "integer", "minimum": 0 },
        "rows_preview_only": { "type": "integer", "minimum": 0 },
        "rows_underqualified": { "type": "integer", "minimum": 0 },
        "help_about_rows": { "type": "integer", "minimum": 0 },
        "release_center_rows": { "type": "integer", "minimum": 0 },
        "support_export_rows": { "type": "integer", "minimum": 0 },
        "public_truth_pack_rows": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
