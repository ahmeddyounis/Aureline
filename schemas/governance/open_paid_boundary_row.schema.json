{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/open_paid_boundary_row.schema.json",
  "title": "Aureline open-vs-paid boundary, anti-lock-in, and publication-control row",
  "description": "Boundary schema for one open_paid_boundary_row seeded in artifacts/governance/open_paid_boundary_rows.yaml and explained in docs/governance/open_paid_boundary_and_antilockin_matrix.md. The row encodes an open/local floor, explicitly allowed optional paid convenience, managed-only control surfaces (kept non-essential), enterprise/self-host posture, explicit prohibited hidden prerequisites, anti-lock-in rules (export/offboarding, mirror/manual import, no vendor-console-only controls, docs truth, license/notice availability, absence fallback), and minimum publication controls (code/spec visibility, sample posture, issue-routing posture, stable-surface schema/docs obligations). Adding a vocabulary value is additive-minor and bumps open_paid_boundary_row_schema_version; repurposing a value is breaking and requires a new decision row.",
  "$ref": "#/$defs/open_paid_boundary_row",
  "$defs": {
    "open_paid_boundary_row_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the open-paid boundary row. Current value is 1. Bumped only on breaking payload changes; additive-optional fields do not bump this version."
    },
    "open_paid_boundary_row_id": {
      "type": "string",
      "pattern": "^open_paid_boundary_row:[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "description": "Stable, machine-readable row id."
    },
    "deployment_profile_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Deployment-profile id (must resolve to artifacts/governance/deployment_profiles.yaml)."
    },
    "boundary_manifest_capability_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Capability id from the boundary-manifest strawman (docs/product/boundary_manifest_strawman.md)."
    },
    "portability_row_ref": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Portability-row id from artifacts/governance/portability_artifact_matrix.yaml."
    },
    "dependency_class": {
      "type": "string",
      "enum": [
        "sign_in",
        "package_registry",
        "remote_mirror",
        "remote_agent",
        "symbol_service",
        "ai_provider",
        "policy_bundle",
        "docs_pack",
        "browser_handoff",
        "companion_notification_channel",
        "hosted_control_plane_reachability"
      ],
      "description": "Residual dependency class. Mirrors artifacts/governance/residual_dependencies.yaml dependency_class_vocabulary."
    },
    "artifact_family_class": {
      "type": "string",
      "enum": [
        "core_desktop_client_platform",
        "sdks_schemas_wit_protocol_samples",
        "documentation_and_migration_guides",
        "brand_and_trademarks",
        "hosted_control_plane_and_managed_services",
        "extensions",
        "policy_bundles",
        "docs_service_health",
        "support_exports",
        "workflow_bundles"
      ],
      "description": "Closed seeded set of asset/capability families the matrix governs. Adding a value is additive-minor and bumps open_paid_boundary_row_schema_version."
    },
    "license_lane_class": {
      "type": "string",
      "enum": [
        "mpl_2_0_public_source",
        "apache_2_0_public_source",
        "cc_by_4_0_public_docs",
        "restricted_exception_inventory",
        "service_plane_contract_publication"
      ],
      "description": "License/publication lane class seeded by the technical architecture appendix (open source lanes, docs lane, restricted exception lane, service-plane contract publication)."
    },
    "code_visibility_requirement": {
      "type": "string",
      "enum": [
        "public_source_required",
        "public_source_required_with_exceptions",
        "public_source_optional",
        "not_applicable"
      ],
      "description": "Minimum code-visibility posture for the family."
    },
    "spec_visibility_requirement": {
      "type": "string",
      "enum": [
        "public_spec_required",
        "public_spec_required_for_stable",
        "public_spec_optional",
        "not_applicable"
      ],
      "description": "Minimum spec visibility posture. public_spec_required_for_stable means stable-labeled surfaces must publish schemas/contracts publicly."
    },
    "stable_surface_schema_docs_requirement": {
      "type": "string",
      "enum": [
        "public_schema_and_docs_required_for_stable",
        "public_schema_required_for_stable",
        "public_docs_required",
        "not_applicable"
      ],
      "description": "Minimum schema/docs publication obligation for stable-labeled surfaces under this family."
    },
    "sample_availability_requirement": {
      "type": "string",
      "enum": [
        "public_samples_required_for_stable",
        "public_samples_recommended",
        "not_applicable"
      ],
      "description": "Minimum sample availability posture for the family."
    },
    "issue_routing_requirement": {
      "type": "string",
      "enum": [
        "public_issue_tracker_required",
        "mixed_public_private_allowed_with_matrix",
        "issue_routing_matrix_required",
        "not_applicable"
      ],
      "description": "Issue-routing posture. mixed_public_private_allowed_with_matrix means public+private routes are allowed, but must resolve through the canonical issue-routing matrix."
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "scope_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deployment_profiles_in_scope",
        "boundary_manifest_capability_ids",
        "portability_row_refs",
        "dependency_classes_in_scope"
      ],
      "properties": {
        "deployment_profiles_in_scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/deployment_profile_id" }
        },
        "boundary_manifest_capability_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/boundary_manifest_capability_id" }
        },
        "portability_row_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/portability_row_ref" }
        },
        "dependency_classes_in_scope": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/dependency_class" }
        }
      }
    },
    "open_vs_paid_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "open_local_core_floor",
        "optional_paid_convenience_additions",
        "managed_only_controls",
        "enterprise_self_host_lane",
        "prohibited_hidden_prerequisites",
        "anti_lock_in_rules"
      ],
      "properties": {
        "open_local_core_floor": {
          "$ref": "#/$defs/non_empty_string",
          "description": "The minimum open/local floor (or continuity floor) that must remain usable when optional services are absent."
        },
        "optional_paid_convenience_additions": {
          "$ref": "#/$defs/non_empty_string_array",
          "description": "Explicitly allowed optional paid convenience additions. These may exist as paid/managed, but must remain optional."
        },
        "managed_only_controls": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "description": "Managed-only controls allowed for this family (must not be required to operate the open/local floor). May be empty."
        },
        "enterprise_self_host_lane": {
          "$ref": "#/$defs/non_empty_string",
          "description": "What is required for enterprise/self-host claims to be truthful for this family."
        },
        "prohibited_hidden_prerequisites": {
          "$ref": "#/$defs/non_empty_string_array",
          "description": "Explicit prohibited hidden prerequisite rules reviewers can enforce mechanically."
        },
        "anti_lock_in_rules": {
          "$ref": "#/$defs/non_empty_string_array",
          "description": "Anti-lock-in rules that apply to this family."
        }
      }
    },
    "publication_controls_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "license_lane_classes",
        "code_visibility_requirement",
        "spec_visibility_requirement",
        "stable_surface_schema_docs_requirement",
        "sample_availability_requirement",
        "issue_routing_requirement",
        "rules"
      ],
      "properties": {
        "license_lane_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/license_lane_class" }
        },
        "code_visibility_requirement": { "$ref": "#/$defs/code_visibility_requirement" },
        "spec_visibility_requirement": { "$ref": "#/$defs/spec_visibility_requirement" },
        "stable_surface_schema_docs_requirement": { "$ref": "#/$defs/stable_surface_schema_docs_requirement" },
        "sample_availability_requirement": { "$ref": "#/$defs/sample_availability_requirement" },
        "issue_routing_requirement": { "$ref": "#/$defs/issue_routing_requirement" },
        "rules": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "open_paid_boundary_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "open_paid_boundary_row_schema_version",
        "open_paid_boundary_row_id",
        "title",
        "artifact_family_class",
        "description",
        "scope",
        "open_vs_paid",
        "publication_controls"
      ],
      "properties": {
        "record_kind": { "const": "open_paid_boundary_row" },
        "open_paid_boundary_row_schema_version": { "$ref": "#/$defs/open_paid_boundary_row_schema_version" },
        "open_paid_boundary_row_id": { "$ref": "#/$defs/open_paid_boundary_row_id" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "artifact_family_class": { "$ref": "#/$defs/artifact_family_class" },
        "description": { "$ref": "#/$defs/non_empty_string" },
        "scope": { "$ref": "#/$defs/scope_block" },
        "open_vs_paid": { "$ref": "#/$defs/open_vs_paid_block" },
        "publication_controls": { "$ref": "#/$defs/publication_controls_block" }
      }
    }
  }
}

