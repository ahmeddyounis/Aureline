{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/add_community_locale_pack_lifecycle_translation_governance_and_parity_audits_for_new_m5_surfaces.schema.json",
  "title": "Community Locale-Pack Lifecycle, Translation Governance, and Parity Audits for New Surfaces",
  "description": "Canonical typed register that freezes one locale-pack lane per pack channel, each binding the pack to its stable claim, a translation-governance scorecard of one cell per dimension, the disclosed translation governance, an owner-manifest sign-off, and an explicit base-locale rollback/downgrade automation record. Downstream docs, Help/About, and support surfaces ingest this directly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "manifest_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "lifecycle_labels",
    "pack_channels",
    "governance_dimensions",
    "dimension_grades",
    "pack_states",
    "narrowing_reasons",
    "stop_rule_actions",
    "downgrade_triggers",
    "automation_states",
    "trust_tiers",
    "launch_cutline",
    "release_blocking_pack_refs",
    "stop_rules",
    "rows",
    "promotion",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version of the register."
    },
    "record_kind": {
      "type": "string",
      "const": "add_community_locale_pack_lifecycle_translation_governance_and_parity_audits_for_new_m5_surfaces"
    },
    "manifest_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "overview_page": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "type": "string", "minLength": 1 },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
      }
    },
    "pack_channels": {
      "type": "array",
      "items": { "$ref": "#/$defs/pack_channel" }
    },
    "governance_dimensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/governance_dimension" }
    },
    "dimension_grades": {
      "type": "array",
      "items": { "$ref": "#/$defs/dimension_grade" }
    },
    "pack_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/pack_state" }
    },
    "narrowing_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/narrowing_reason" }
    },
    "stop_rule_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/stop_rule_action" }
    },
    "downgrade_triggers": {
      "type": "array",
      "items": { "$ref": "#/$defs/downgrade_trigger" }
    },
    "automation_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/automation_state" }
    },
    "trust_tiers": {
      "type": "array",
      "items": { "$ref": "#/$defs/trust_tier" }
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_pack_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stop_rule" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/locale_pack_lane" }
    },
    "promotion": { "$ref": "#/$defs/promotion_record" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "pack_channel": {
      "type": "string",
      "enum": [
        "core_locale",
        "community_pack",
        "partner_pack",
        "machine_assisted"
      ]
    },
    "governance_dimension": {
      "type": "string",
      "enum": [
        "string_coverage",
        "critical_state_coverage",
        "terminology",
        "translation_review",
        "locale_parity",
        "source_sync"
      ]
    },
    "dimension_grade": {
      "type": "string",
      "enum": ["pass", "partial", "fail", "waived", "missing"]
    },
    "pack_state": {
      "type": "string",
      "enum": [
        "certified",
        "parity_drifted",
        "stale",
        "on_waiver",
        "rollback_undefined",
        "owner_unsigned"
      ]
    },
    "narrowing_reason": {
      "type": "string",
      "enum": [
        "governance_dimension_failed",
        "governance_dimension_missing",
        "proof_packet_missing",
        "proof_packet_stale",
        "owner_manifest_unsigned",
        "rollback_plan_unverified",
        "downgrade_automation_undefined",
        "waiver_expired"
      ]
    },
    "stop_rule_action": {
      "type": "string",
      "enum": [
        "hold_promotion",
        "narrow_label",
        "remediate_translation",
        "refresh_proof_packet",
        "request_owner_signoff",
        "verify_rollback_plan",
        "define_downgrade_automation",
        "renew_waiver"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": ["proof_stale", "parity_drifted", "owner_revoked", "manual"]
    },
    "automation_state": {
      "type": "string",
      "enum": ["defined", "unverified", "undefined"]
    },
    "trust_tier": {
      "type": "string",
      "enum": ["first_party", "verified_partner", "community", "untrusted"]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "type": "string", "const": "stable" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "type": "string", "enum": ["lts", "stable"] }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "type": "string", "enum": ["beta", "preview", "withdrawn"] }
        },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "stop_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_promotion",
        "rationale"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "trigger_reason": { "$ref": "#/$defs/narrowing_reason" },
        "applies_to_labels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
          }
        },
        "default_action": { "$ref": "#/$defs/stop_rule_action" },
        "blocks_promotion": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "freshness_slo",
        "slo_state"
      ],
      "properties": {
        "packet_id": { "type": "string", "minLength": 1 },
        "packet_ref": { "type": "string", "minLength": 1 },
        "proof_index_ref": { "type": "string", "minLength": 1 },
        "captured_at": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "format": "date" }
          ]
        },
        "freshness_slo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
          "properties": {
            "target_max_age_days": { "type": "integer", "minimum": 1 },
            "warn_within_days": { "type": "integer", "minimum": 0 },
            "slo_register_ref": { "type": "string", "minLength": 1 }
          }
        },
        "slo_state": {
          "type": "string",
          "enum": ["current", "due_for_refresh", "breached", "missing"]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "governance_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "grade", "evidence_ref"],
      "properties": {
        "dimension": { "$ref": "#/$defs/governance_dimension" },
        "grade": { "$ref": "#/$defs/dimension_grade" },
        "evidence_ref": { "type": "string" }
      }
    },
    "translation_governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maintainer_ref", "source_ref", "trust_tier", "fallback_disclosed"],
      "properties": {
        "maintainer_ref": { "type": "string", "minLength": 1 },
        "source_ref": { "type": "string", "minLength": 1 },
        "trust_tier": { "$ref": "#/$defs/trust_tier" },
        "string_set_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "fallback_disclosed": { "type": "boolean" }
      }
    },
    "downgrade_automation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "automation_ref",
        "rollback_plan_ref",
        "trigger",
        "target_floor",
        "state",
        "rollback_verified"
      ],
      "properties": {
        "automation_ref": { "type": "string", "minLength": 1 },
        "rollback_plan_ref": { "type": "string", "minLength": 1 },
        "trigger": { "$ref": "#/$defs/downgrade_trigger" },
        "target_floor": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "state": { "$ref": "#/$defs/automation_state" },
        "rollback_verified": { "type": "boolean" }
      }
    },
    "locale_pack_lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "pack_channel",
        "pack_ref",
        "pack_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "pack_state",
        "scorecard",
        "governance",
        "downgrade_automation",
        "proof_packet",
        "owner_signoff",
        "published_label",
        "rationale"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "pack_channel": { "$ref": "#/$defs/pack_channel" },
        "pack_ref": { "type": "string", "minLength": 1 },
        "pack_summary": { "type": "string", "minLength": 1 },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "type": "string", "minLength": 1 },
        "claim_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "pack_state": { "$ref": "#/$defs/pack_state" },
        "scorecard": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/governance_cell" }
        },
        "governance": { "$ref": "#/$defs/translation_governance" },
        "downgrade_automation": { "$ref": "#/$defs/downgrade_automation" },
        "proof_packet": { "$ref": "#/$defs/proof_packet" },
        "waiver": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["waiver_ref", "expires_at", "reason"],
              "properties": {
                "waiver_ref": { "type": "string", "minLength": 1 },
                "expires_at": { "type": "string", "format": "date" },
                "reason": { "type": "string", "minLength": 1 }
              }
            }
          ]
        },
        "owner_signoff": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner_ref", "signed_off"],
          "properties": {
            "owner_ref": { "type": "string", "minLength": 1 },
            "signed_off": { "type": "boolean" },
            "signed_at": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "format": "date" }
              ]
            }
          }
        },
        "active_narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        },
        "published_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "publication_destinations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "promotion_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_claim_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blocking_claim_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "total_claims",
        "entries_certified",
        "entries_narrowed",
        "entries_on_active_waiver",
        "entries_with_dimension_gap",
        "entries_with_owner_gap",
        "entries_with_rollback_gap",
        "entries_fallback_undisclosed",
        "release_blocking_total",
        "release_blocking_certified",
        "release_blocking_narrowed",
        "core_locale_entries",
        "community_pack_entries",
        "partner_pack_entries",
        "machine_assisted_entries",
        "first_party_entries",
        "verified_partner_entries",
        "community_entries",
        "untrusted_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_narrowing_reasons",
        "total_governance_cells",
        "cells_pass",
        "cells_partial",
        "cells_fail",
        "cells_waived",
        "cells_missing",
        "rules_firing"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "entries_certified": { "type": "integer", "minimum": 0 },
        "entries_narrowed": { "type": "integer", "minimum": 0 },
        "entries_on_active_waiver": { "type": "integer", "minimum": 0 },
        "entries_with_dimension_gap": { "type": "integer", "minimum": 0 },
        "entries_with_owner_gap": { "type": "integer", "minimum": 0 },
        "entries_with_rollback_gap": { "type": "integer", "minimum": 0 },
        "entries_fallback_undisclosed": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_certified": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "core_locale_entries": { "type": "integer", "minimum": 0 },
        "community_pack_entries": { "type": "integer", "minimum": 0 },
        "partner_pack_entries": { "type": "integer", "minimum": 0 },
        "machine_assisted_entries": { "type": "integer", "minimum": 0 },
        "first_party_entries": { "type": "integer", "minimum": 0 },
        "verified_partner_entries": { "type": "integer", "minimum": 0 },
        "community_entries": { "type": "integer", "minimum": 0 },
        "untrusted_entries": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_active_narrowing_reasons": { "type": "integer", "minimum": 0 },
        "total_governance_cells": { "type": "integer", "minimum": 0 },
        "cells_pass": { "type": "integer", "minimum": 0 },
        "cells_partial": { "type": "integer", "minimum": 0 },
        "cells_fail": { "type": "integer", "minimum": 0 },
        "cells_waived": { "type": "integer", "minimum": 0 },
        "cells_missing": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
