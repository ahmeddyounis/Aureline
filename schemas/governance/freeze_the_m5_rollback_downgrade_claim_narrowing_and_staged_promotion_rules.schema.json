{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/freeze_the_m5_rollback_downgrade_claim_narrowing_and_staged_promotion_rules.schema.json",
  "title": "M5 Rollback, Downgrade, Claim-Narrowing, and Staged-Promotion Rules",
  "description": "Canonical typed register that freezes M5 rollback, downgrade, claim-narrowing, and staged-promotion rules. Downstream docs, Help/About, and support surfaces ingest this directly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "register_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "feature_train_matrix_ref",
    "lifecycle_labels",
    "lane_kinds",
    "rollback_path_states",
    "downgrade_kinds",
    "promotion_stage_kinds",
    "stage_states",
    "gap_reasons",
    "stop_rule_actions",
    "launch_cutline",
    "release_blocking_lane_refs",
    "stop_rules",
    "rows",
    "promotion",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version of the register."
    },
    "record_kind": {
      "type": "string",
      "const": "freeze_the_m5_rollback_downgrade_claim_narrowing_and_staged_promotion_rules"
    },
    "register_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "overview_page": {
      "type": "string",
      "minLength": 1
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "claim_manifest_ref": {
      "type": "string",
      "minLength": 1
    },
    "feature_train_matrix_ref": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
      }
    },
    "lane_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "notebook",
          "data_rich",
          "ai_adjacent",
          "framework",
          "review",
          "companion",
          "managed_depth"
        ]
      }
    },
    "rollback_path_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["defined", "tested", "exercised", "missing"]
      }
    },
    "downgrade_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["automatic_narrowing", "manual_hold", "emergency_rollback", "staged_reversal"]
      }
    },
    "promotion_stage_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["canary", "pilot", "stable"]
      }
    },
    "stage_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["complete", "in_progress", "not_started", "blocked"]
      }
    },
    "gap_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "rollback_path_missing",
          "rollback_path_untested",
          "rollback_path_unexercised",
          "downgrade_rule_missing",
          "claim_narrowing_rule_missing",
          "staged_promotion_rule_missing",
          "promotion_stage_blocked",
          "proof_packet_missing",
          "proof_packet_stale",
          "waiver_expired",
          "owner_signoff_missing"
        ]
      }
    },
    "stop_rule_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "hold_promotion",
          "narrow_label",
          "define_rollback_path",
          "test_rollback_path",
          "exercise_rollback_path",
          "define_downgrade_rule",
          "define_claim_narrowing_rule",
          "define_staged_promotion_rule",
          "advance_promotion_stage",
          "refresh_proof_packet",
          "request_owner_signoff"
        ]
      }
    },
    "launch_cutline": {
      "$ref": "#/$defs/launch_cutline"
    },
    "release_blocking_lane_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stop_rule" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/lane_row" }
    },
    "promotion": {
      "$ref": "#/$defs/promotion_record"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": {
          "type": "string",
          "const": "stable"
        },
        "above_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["lts", "stable"]
          }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["beta", "preview", "withdrawn"]
          }
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stop_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_promotion",
        "rationale"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "trigger_reason": { "type": "string", "minLength": 1 },
        "applies_to_labels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "default_action": { "type": "string", "minLength": 1 },
        "blocks_promotion": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "promotion_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_claim_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blocking_claim_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "freshness_slo",
        "slo_state"
      ],
      "properties": {
        "packet_id": { "type": "string", "minLength": 1 },
        "packet_ref": { "type": "string", "minLength": 1 },
        "proof_index_ref": { "type": "string", "minLength": 1 },
        "captured_at": { "type": ["string", "null"] },
        "freshness_slo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
          "properties": {
            "target_max_age_days": { "type": "integer", "minimum": 1 },
            "warn_within_days": { "type": "integer", "minimum": 0 },
            "slo_register_ref": { "type": "string", "minLength": 1 }
          }
        },
        "slo_state": {
          "type": "string",
          "enum": ["current", "due_for_refresh", "breached", "missing"]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "downgrade_kind",
        "trigger_label",
        "target_label",
        "rule_ref",
        "rationale"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "downgrade_kind": { "type": "string", "minLength": 1 },
        "trigger_label": { "type": "string", "minLength": 1 },
        "target_label": { "type": "string", "minLength": 1 },
        "rule_ref": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "claim_narrowing_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "trigger_reason",
        "target_label",
        "auto_apply",
        "rule_ref",
        "rationale"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "trigger_reason": { "type": "string", "minLength": 1 },
        "target_label": { "type": "string", "minLength": 1 },
        "auto_apply": { "type": "boolean" },
        "rule_ref": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "promotion_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_kind",
        "stage_state",
        "stage_ref",
        "rationale"
      ],
      "properties": {
        "stage_kind": { "type": "string", "minLength": 1 },
        "stage_state": { "type": "string", "minLength": 1 },
        "stage_ref": { "type": "string", "minLength": 1 },
        "completed_at": { "type": ["string", "null"] },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "lane_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "lane_kind",
        "surface_ref",
        "surface_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "rollback_path_state",
        "rollback_path_ref",
        "proof_packet",
        "owner_signoff",
        "published_label",
        "rationale"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "lane_kind": { "type": "string", "minLength": 1 },
        "surface_ref": { "type": "string", "minLength": 1 },
        "surface_summary": { "type": "string", "minLength": 1 },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "type": "string", "minLength": 1 },
        "claim_label": { "type": "string", "minLength": 1 },
        "rollback_path_state": { "type": "string", "minLength": 1 },
        "rollback_path_ref": { "type": "string" },
        "downgrade_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_rule" }
        },
        "claim_narrowing_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim_narrowing_rule" }
        },
        "promotion_stages": {
          "type": "array",
          "items": { "$ref": "#/$defs/promotion_stage" }
        },
        "proof_packet": { "$ref": "#/$defs/proof_packet" },
        "waiver": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["waiver_ref", "expires_at", "reason"],
          "properties": {
            "waiver_ref": { "type": "string", "minLength": 1 },
            "expires_at": { "type": "string", "minLength": 1 },
            "reason": { "type": "string", "minLength": 1 }
          }
        },
        "owner_signoff": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner_ref", "signed_off"],
          "properties": {
            "owner_ref": { "type": "string", "minLength": 1 },
            "signed_off": { "type": "boolean" },
            "signed_at": { "type": ["string", "null"] }
          }
        },
        "active_gap_reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "published_label": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "total_claims",
        "entries_holding_stable",
        "entries_narrowed",
        "entries_on_active_waiver",
        "entries_blocked",
        "entries_rule_missing",
        "release_blocking_total",
        "release_blocking_holding",
        "release_blocking_narrowed",
        "notebook_entries",
        "data_rich_entries",
        "ai_adjacent_entries",
        "framework_entries",
        "review_entries",
        "companion_entries",
        "managed_depth_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_gap_reasons",
        "rules_firing",
        "total_downgrade_rules",
        "total_claim_narrowing_rules",
        "total_promotion_stages",
        "rollback_path_missing",
        "rollback_path_untested",
        "rollback_path_unexercised",
        "stages_blocked"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "entries_holding_stable": { "type": "integer", "minimum": 0 },
        "entries_narrowed": { "type": "integer", "minimum": 0 },
        "entries_on_active_waiver": { "type": "integer", "minimum": 0 },
        "entries_blocked": { "type": "integer", "minimum": 0 },
        "entries_rule_missing": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_holding": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "notebook_entries": { "type": "integer", "minimum": 0 },
        "data_rich_entries": { "type": "integer", "minimum": 0 },
        "ai_adjacent_entries": { "type": "integer", "minimum": 0 },
        "framework_entries": { "type": "integer", "minimum": 0 },
        "review_entries": { "type": "integer", "minimum": 0 },
        "companion_entries": { "type": "integer", "minimum": 0 },
        "managed_depth_entries": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_active_gap_reasons": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 },
        "total_downgrade_rules": { "type": "integer", "minimum": 0 },
        "total_claim_narrowing_rules": { "type": "integer", "minimum": 0 },
        "total_promotion_stages": { "type": "integer", "minimum": 0 },
        "rollback_path_missing": { "type": "integer", "minimum": 0 },
        "rollback_path_untested": { "type": "integer", "minimum": 0 },
        "rollback_path_unexercised": { "type": "integer", "minimum": 0 },
        "stages_blocked": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
