{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/destruction_receipt_alpha.schema.json",
  "title": "Aureline destruction receipt alpha record",
  "description": "Boundary schema for alpha destruction-receipt and non-receipt disclosure records used by admin, support, export, and offboarding surfaces. The record names the requested action, result class, destroyed refs, retained refs, skipped-held refs, outside-scope refs, policy version, verifier refs, execution chronology, mirror or lag note, and the archive/redaction boundary that constrained the result. Raw payload bodies, raw credentials, raw policy bodies, raw prompts, raw URLs, raw tenant names, raw billing identifiers, and raw hold justifications never cross this boundary.",
  "$ref": "#/$defs/destruction_receipt_alpha_record",
  "$defs": {
    "destruction_receipt_alpha_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "destruction_receipt_alpha_record"
    },
    "stable_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$",
      "description": "Opaque stable ref safe for support, admin, export, and logs."
    },
    "lower_snake_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Short reviewable sentence that excludes raw payload bodies and private identifiers."
    },
    "nullable_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/stable_ref" }
      ]
    },
    "nullable_sentence": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/reviewable_sentence" }
      ]
    },
    "chronology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "utc_instant",
        "local_iso_with_offset",
        "timezone_id",
        "offset_at_instant",
        "source_clock_class",
        "ordering_key"
      ],
      "properties": {
        "utc_instant": {
          "type": "string",
          "format": "date-time"
        },
        "local_iso_with_offset": {
          "type": "string",
          "format": "date-time"
        },
        "timezone_id": {
          "type": "string",
          "minLength": 1
        },
        "offset_at_instant": {
          "type": "string",
          "pattern": "^[+-][0-9]{2}:[0-9]{2}$"
        },
        "source_clock_class": {
          "type": "string",
          "enum": [
            "local_wall_clock_synchronized",
            "local_wall_clock_unsynchronized",
            "remote_host_wall_clock",
            "imported_external_wall_clock"
          ]
        },
        "ordering_key": { "$ref": "#/$defs/stable_ref" }
      }
    },
    "result_class": {
      "type": "string",
      "enum": [
        "completed",
        "partial",
        "blocked_by_hold",
        "policy_retained",
        "outside_platform_scope",
        "manual_local_capture_required",
        "omitted_by_redaction",
        "not_found"
      ]
    },
    "receipt_state": {
      "type": "string",
      "enum": [
        "available",
        "pending_after_hold_clear",
        "pending_policy_floor",
        "not_available_outside_scope",
        "manual_local_action_required",
        "omitted_by_redaction"
      ]
    },
    "executed_action_class": {
      "type": "string",
      "enum": [
        "delete",
        "cleanup",
        "offboarding_delete",
        "redaction_delete",
        "archive_compaction",
        "export_delete"
      ]
    },
    "locality_class": {
      "type": "string",
      "enum": [
        "local_only",
        "managed_copy",
        "archived",
        "held",
        "receipt_only",
        "outside_platform_scope",
        "redacted_boundary"
      ]
    },
    "reason_class": {
      "type": "string",
      "enum": [
        "destroyed",
        "skipped_held",
        "policy_retained",
        "outside_platform_scope",
        "manual_local_capture_required",
        "omitted_by_redaction",
        "receipt_only_metadata",
        "not_found"
      ]
    },
    "scope_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref",
        "record_class_id",
        "locality_class",
        "result_class",
        "reason_class",
        "summary"
      ],
      "properties": {
        "ref": { "$ref": "#/$defs/stable_ref" },
        "record_class_id": { "$ref": "#/$defs/lower_snake_id" },
        "locality_class": { "$ref": "#/$defs/locality_class" },
        "result_class": { "$ref": "#/$defs/result_class" },
        "reason_class": { "$ref": "#/$defs/reason_class" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_version",
        "policy_source_ref",
        "retention_owner_ref"
      ],
      "properties": {
        "policy_version": { "$ref": "#/$defs/stable_ref" },
        "policy_source_ref": { "$ref": "#/$defs/stable_ref" },
        "retention_owner_ref": { "$ref": "#/$defs/stable_ref" }
      }
    },
    "artifact_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_ref_count",
        "destroyed_ref_count",
        "retained_ref_count",
        "skipped_held_ref_count",
        "outside_scope_ref_count",
        "manual_local_capture_count",
        "omitted_by_redaction_count"
      ],
      "properties": {
        "requested_ref_count": { "type": "integer", "minimum": 0 },
        "destroyed_ref_count": { "type": "integer", "minimum": 0 },
        "retained_ref_count": { "type": "integer", "minimum": 0 },
        "skipped_held_ref_count": { "type": "integer", "minimum": 0 },
        "outside_scope_ref_count": { "type": "integer", "minimum": 0 },
        "manual_local_capture_count": { "type": "integer", "minimum": 0 },
        "omitted_by_redaction_count": { "type": "integer", "minimum": 0 }
      }
    },
    "hash_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "root_hash",
        "previous_receipt_ref",
        "summary"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["sha256", "not_applicable"]
        },
        "root_hash": {
          "type": "string",
          "minLength": 1
        },
        "previous_receipt_ref": { "$ref": "#/$defs/nullable_ref" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "chain_of_custody": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "custody_event_refs",
        "source_packet_refs",
        "verifier_refs",
        "hash_chain",
        "summary"
      ],
      "properties": {
        "custody_event_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/stable_ref" }
        },
        "source_packet_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/stable_ref" }
        },
        "verifier_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/stable_ref" }
        },
        "hash_chain": { "$ref": "#/$defs/hash_chain" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "mirror_or_lag": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lag_class",
        "mirror_or_lag_note"
      ],
      "properties": {
        "lag_class": {
          "type": "string",
          "enum": [
            "no_mirror_lag",
            "mirror_purge_pending",
            "mirror_observation_lag",
            "self_hosted_mirror_not_observable",
            "not_applicable"
          ]
        },
        "mirror_or_lag_note": { "$ref": "#/$defs/reviewable_sentence" },
        "expected_clearance_ref": { "$ref": "#/$defs/nullable_ref" }
      }
    },
    "receipt_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "covers_full_requested_scope",
        "unavailable_reason",
        "partial_reason_classes"
      ],
      "properties": {
        "covers_full_requested_scope": { "type": "boolean" },
        "unavailable_reason": { "$ref": "#/$defs/nullable_sentence" },
        "partial_reason_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/reason_class" }
        }
      }
    },
    "honesty_assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_full_delete_overclaim",
        "raw_payloads_not_embedded",
        "held_and_retained_refs_listed",
        "locality_disclosed"
      ],
      "properties": {
        "no_full_delete_overclaim": { "type": "boolean", "const": true },
        "raw_payloads_not_embedded": { "type": "boolean", "const": true },
        "held_and_retained_refs_listed": { "type": "boolean", "const": true },
        "locality_disclosed": { "type": "boolean", "const": true }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "governance_contract_ref",
        "archive_boundary_contract_ref",
        "schema_registry_ref",
        "record_class_ref",
        "retention_deletion_contract_ref",
        "record_state_contract_ref"
      ],
      "properties": {
        "governance_contract_ref": {
          "type": "string",
          "const": "docs/governance/archive_search_destruction_alpha.md"
        },
        "archive_boundary_contract_ref": {
          "type": "string",
          "const": "artifacts/governance/archive_redaction_boundary_alpha.yaml"
        },
        "schema_registry_ref": {
          "type": "string",
          "const": "artifacts/governance/schema_registry_alpha.yaml#schema_alpha:receipt.destruction_receipt"
        },
        "record_class_ref": {
          "type": "string",
          "const": "artifacts/governance/record_class_registry.yaml#destruction_receipt_record"
        },
        "retention_deletion_contract_ref": {
          "type": "string",
          "const": "docs/governance/retention_deletion_matrix_contract.md"
        },
        "record_state_contract_ref": {
          "type": "string",
          "const": "docs/governance/record_state_and_policy_simulation_models.md"
        }
      }
    },
    "destruction_receipt_alpha_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "destruction_receipt_alpha_schema_version",
        "record_kind",
        "receipt_record_id",
        "emitted_receipt_ref",
        "receipt_state",
        "result_class",
        "executed_action_class",
        "request_ref",
        "record_class_refs",
        "scope_summary",
        "policy_context",
        "executed_at",
        "destroyed_refs",
        "retained_refs",
        "skipped_held_refs",
        "outside_scope_refs",
        "manual_local_capture_refs",
        "omitted_by_redaction_refs",
        "artifact_counts",
        "receipt_coverage",
        "chain_of_custody",
        "mirror_or_lag",
        "support_export_refs",
        "offboarding_packet_refs",
        "honesty_assertions",
        "links"
      ],
      "properties": {
        "destruction_receipt_alpha_schema_version": { "$ref": "#/$defs/destruction_receipt_alpha_schema_version" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "receipt_record_id": { "$ref": "#/$defs/stable_ref" },
        "emitted_receipt_ref": { "$ref": "#/$defs/nullable_ref" },
        "receipt_state": { "$ref": "#/$defs/receipt_state" },
        "result_class": { "$ref": "#/$defs/result_class" },
        "executed_action_class": { "$ref": "#/$defs/executed_action_class" },
        "request_ref": { "$ref": "#/$defs/stable_ref" },
        "record_class_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/lower_snake_id" }
        },
        "scope_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "executed_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/chronology" }
          ]
        },
        "destroyed_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/scope_ref" }
        },
        "retained_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/scope_ref" }
        },
        "skipped_held_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/scope_ref" }
        },
        "outside_scope_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/scope_ref" }
        },
        "manual_local_capture_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/scope_ref" }
        },
        "omitted_by_redaction_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/scope_ref" }
        },
        "artifact_counts": { "$ref": "#/$defs/artifact_counts" },
        "receipt_coverage": { "$ref": "#/$defs/receipt_coverage" },
        "chain_of_custody": { "$ref": "#/$defs/chain_of_custody" },
        "mirror_or_lag": { "$ref": "#/$defs/mirror_or_lag" },
        "support_export_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/stable_ref" }
        },
        "offboarding_packet_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/stable_ref" }
        },
        "honesty_assertions": { "$ref": "#/$defs/honesty_assertions" },
        "links": { "$ref": "#/$defs/links" },
        "__fixture__": {
          "type": "object",
          "description": "Optional fixture annotation block; never part of the runtime record."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "receipt_state": { "const": "available" } },
            "required": ["receipt_state"]
          },
          "then": {
            "properties": {
              "emitted_receipt_ref": { "$ref": "#/$defs/stable_ref" },
              "executed_at": { "$ref": "#/$defs/chronology" }
            }
          },
          "else": {
            "properties": {
              "emitted_receipt_ref": { "type": "null" },
              "executed_at": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "receipt_coverage": {
                "properties": { "covers_full_requested_scope": { "const": false } },
                "required": ["covers_full_requested_scope"]
              }
            },
            "required": ["receipt_coverage"]
          },
          "then": {
            "properties": {
              "receipt_coverage": {
                "properties": {
                  "unavailable_reason": { "$ref": "#/$defs/reviewable_sentence" },
                  "partial_reason_classes": { "minItems": 1 }
                }
              }
            }
          }
        }
      ]
    }
  }
}
