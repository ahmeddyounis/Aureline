{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/lifecycle_state.schema.json",
  "title": "Aureline protected-object lifecycle statechart and authority vocabulary",
  "description": "Boundary schema for protected-object lifecycle statecharts, state nodes, transition rows, and actor-authority rules frozen in docs/architecture/lifecycle_statecharts.md and artifacts/architecture/statecharts/. The schema gives UI, support exports, automation logs, audit trails, and docs/help one state and recovery vocabulary for workspace sessions, document buffers, command invocations, notifications, task/run attempts, collaboration sessions, migration/import sessions, and repair transactions. Raw object bodies, raw paths, raw URLs, raw terminal output, raw provider payloads, raw credentials, and raw export payloads never cross this boundary; records carry opaque refs, typed state names, typed recovery classes, actor authority, preview/checkpoint posture, and evidence/export/audit refs only. Adding a protected object family, lifecycle state, transition class, recovery transition class, actor class, authority action class, or field binding class is additive-minor and requires a lifecycle_state_schema_version bump; repurposing an existing value is breaking and requires a governance decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/lifecycle_statechart_record" },
    { "$ref": "#/$defs/lifecycle_state_node_record" },
    { "$ref": "#/$defs/lifecycle_transition_record" },
    { "$ref": "#/$defs/lifecycle_actor_authority_rule_record" }
  ],
  "$defs": {
    "lifecycle_state_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the protected-object lifecycle vocabulary."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "lifecycle_statechart_record",
        "lifecycle_state_node_record",
        "lifecycle_transition_record",
        "lifecycle_actor_authority_rule_record"
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe for logs, manifests, audit rows, support bundles, and exports."
    },
    "stable_ref": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._:-][a-z0-9]+)*$",
      "description": "Stable lowercase reference token. It may use '.', ':', '_', or '-' separators."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Short redaction-aware sentence safe for reviewer tables and support previews."
    },
    "protected_object_family": {
      "type": "string",
      "enum": [
        "workspace_session",
        "document_buffer",
        "command_invocation",
        "notification",
        "task_run_attempt",
        "collaboration_session",
        "migration_import_session",
        "repair_transaction"
      ],
      "description": "Protected object families covered by the architecture lifecycle pack."
    },
    "lifecycle_state_class": {
      "type": "string",
      "enum": [
        "unopened",
        "opening",
        "active",
        "degraded",
        "recovering",
        "suspended",
        "closing",
        "closed",
        "clean",
        "dirty",
        "saving",
        "conflict",
        "recovered_snapshot",
        "read_only",
        "stale",
        "created",
        "enablement_checked",
        "previewing",
        "awaiting_approval",
        "executing",
        "scheduled_pending_background",
        "succeeded",
        "succeeded_with_warnings",
        "denied",
        "rolled_back",
        "partially_applied_and_halted",
        "minted",
        "delivered",
        "held_for_suppression",
        "released_from_hold",
        "dedupe_collapsed",
        "grouped_into_digest",
        "acknowledged",
        "dismissed",
        "resolved",
        "dropped_by_policy",
        "expired",
        "queued",
        "preparing",
        "running",
        "waiting_input",
        "partially_complete",
        "passed",
        "cancelled",
        "stale_output",
        "solo",
        "publish_pending",
        "shared_active",
        "participant_degraded",
        "shared_degraded",
        "ended",
        "source_selected",
        "domains_chosen",
        "diff_ready",
        "applying",
        "applied",
        "partially_applied",
        "restored",
        "abandoned",
        "proposed",
        "dry_run_complete_pending_review",
        "dry_run_safe_apply_authorized",
        "dry_run_blocked_by_policy",
        "applied_success_recovered",
        "applied_partial_recovered_with_typed_unknowns",
        "applied_failed_rolled_back",
        "applied_failed_compensated",
        "applied_failed_no_reversal_export_only",
        "escalated_no_apply",
        "refused_pre_apply",
        "audit_only_closed",
        "failed",
        "archived"
      ],
      "description": "Union of canonical state tokens used by the protected family statecharts. Some tokens are re-exported from owning schemas; family records declare which subset applies."
    },
    "state_category_class": {
      "type": "string",
      "enum": [
        "initial",
        "active",
        "blocked",
        "recoverable",
        "retryable",
        "terminal_success",
        "terminal_cancelled",
        "terminal_failed",
        "terminal_archived",
        "terminal_noop"
      ],
      "description": "Reviewer-facing rollup for terminal, recoverable, and retryable posture. The explicit booleans on each node remain authoritative."
    },
    "transition_class": {
      "type": "string",
      "enum": [
        "create",
        "start",
        "admit",
        "preview",
        "approve",
        "reject",
        "execute",
        "complete",
        "failure",
        "timeout",
        "cancel",
        "retry",
        "repair",
        "rollback",
        "downgrade",
        "stale_reconciliation",
        "archive",
        "export"
      ],
      "description": "Closed transition vocabulary. Recovery transitions also populate recovery_transition_class."
    },
    "recovery_transition_class": {
      "type": "string",
      "enum": [
        "failure",
        "timeout",
        "cancel",
        "retry",
        "rollback",
        "downgrade",
        "stale_reconciliation"
      ],
      "description": "Shared recovery-transition vocabulary. Null when the transition is not a recovery transition."
    },
    "actor_class": {
      "type": "string",
      "enum": [
        "interactive_user",
        "workspace_owner",
        "session_owner",
        "participant",
        "command_router",
        "policy_service",
        "supervisor",
        "support_operator",
        "admin",
        "automation_scheduler",
        "ai_assistant",
        "extension_host",
        "remote_agent",
        "provider_service",
        "owning_subsystem",
        "second_party_reviewer",
        "migration_importer",
        "repair_executor"
      ],
      "description": "Actor classes allowed to initiate, approve, reject, retry, repair, archive, or export lifecycle transitions."
    },
    "authority_action_class": {
      "type": "string",
      "enum": [
        "initiate",
        "approve",
        "reject",
        "retry",
        "repair",
        "archive",
        "export"
      ],
      "description": "Authority action controlled by a lifecycle actor-authority rule."
    },
    "field_binding_class": {
      "type": "string",
      "enum": [
        "lifecycle_state_class",
        "prior_state_class",
        "next_state_class",
        "transition_class",
        "recovery_transition_class",
        "actor_ref",
        "authority_ticket_ref",
        "preview_ref",
        "checkpoint_ref",
        "rollback_checkpoint_ref",
        "evidence_refs",
        "export_refs",
        "audit_event_refs",
        "denial_reason_class",
        "failure_reason_class",
        "deadline_ref",
        "cancellation_actor_ref",
        "cancellation_authority_class",
        "idempotency_key_ref",
        "downgrade_reason_class",
        "preserved_state_refs",
        "last_known_good_ref",
        "reconciliation_outcome_class",
        "stale_basis_ref",
        "event_lineage_ref"
      ],
      "description": "Field classes every statechart node or transition may bind to an owning schema field."
    },
    "field_binding_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_binding_class", "field_name", "owner_contract_ref"],
      "properties": {
        "field_binding_class": { "$ref": "#/$defs/field_binding_class" },
        "field_name": { "$ref": "#/$defs/stable_ref" },
        "owner_contract_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Repo-relative schema, doc, artifact, or packet ref that owns the field semantics."
        },
        "required_when_state_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/lifecycle_state_class" }
        },
        "required_when_transition_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/transition_class" }
        }
      }
    },
    "state_node_inline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_class",
        "state_category",
        "is_terminal",
        "is_recoverable",
        "is_retryable",
        "field_bindings"
      ],
      "properties": {
        "state_class": { "$ref": "#/$defs/lifecycle_state_class" },
        "state_category": { "$ref": "#/$defs/state_category_class" },
        "is_terminal": { "type": "boolean" },
        "is_recoverable": { "type": "boolean" },
        "is_retryable": { "type": "boolean" },
        "field_bindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/field_binding_record" }
        },
        "state_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "transition_inline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transition_id",
        "from_state_class",
        "to_state_class",
        "transition_class",
        "initiating_actor_classes",
        "preview_required",
        "checkpoint_required",
        "field_bindings"
      ],
      "properties": {
        "transition_id": { "$ref": "#/$defs/stable_ref" },
        "from_state_class": { "$ref": "#/$defs/lifecycle_state_class" },
        "to_state_class": { "$ref": "#/$defs/lifecycle_state_class" },
        "transition_class": { "$ref": "#/$defs/transition_class" },
        "recovery_transition_class": { "$ref": "#/$defs/recovery_transition_class" },
        "initiating_actor_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/actor_class" }
        },
        "approving_actor_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/actor_class" }
        },
        "rejecting_actor_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/actor_class" }
        },
        "retry_actor_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/actor_class" }
        },
        "repair_actor_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/actor_class" }
        },
        "preview_required": { "type": "boolean" },
        "checkpoint_required": { "type": "boolean" },
        "field_bindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/field_binding_record" }
        },
        "transition_summary": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "description": "Recovery transitions must carry the matching recovery_transition_class.",
          "if": {
            "properties": {
              "transition_class": {
                "enum": [
                  "failure",
                  "timeout",
                  "cancel",
                  "retry",
                  "rollback",
                  "downgrade",
                  "stale_reconciliation"
                ]
              }
            },
            "required": ["transition_class"]
          },
          "then": {
            "required": ["recovery_transition_class"]
          }
        },
        {
          "description": "Transitions requiring preview must bind a preview_ref field.",
          "if": {
            "properties": { "preview_required": { "const": true } },
            "required": ["preview_required"]
          },
          "then": {
            "properties": {
              "field_bindings": {
                "contains": {
                  "type": "object",
                  "properties": {
                    "field_binding_class": { "const": "preview_ref" }
                  },
                  "required": ["field_binding_class"]
                }
              }
            }
          }
        },
        {
          "description": "Transitions requiring checkpointing must bind a checkpoint_ref or rollback_checkpoint_ref field.",
          "if": {
            "properties": { "checkpoint_required": { "const": true } },
            "required": ["checkpoint_required"]
          },
          "then": {
            "properties": {
              "field_bindings": {
                "contains": {
                  "type": "object",
                  "properties": {
                    "field_binding_class": {
                      "enum": ["checkpoint_ref", "rollback_checkpoint_ref"]
                    }
                  },
                  "required": ["field_binding_class"]
                }
              }
            }
          }
        }
      ]
    },
    "actor_authority_rule_inline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_action_class",
        "actor_classes",
        "requires_preview",
        "requires_checkpoint",
        "rule_summary"
      ],
      "properties": {
        "authority_action_class": { "$ref": "#/$defs/authority_action_class" },
        "actor_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/actor_class" }
        },
        "requires_preview": { "type": "boolean" },
        "requires_checkpoint": { "type": "boolean" },
        "rule_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "authority_ticket_required": { "type": "boolean" }
      }
    },
    "lifecycle_statechart_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "lifecycle_state_schema_version",
        "statechart_id",
        "protected_object_family",
        "source_contract_refs",
        "state_nodes",
        "transitions",
        "actor_authority_rules"
      ],
      "properties": {
        "record_kind": { "const": "lifecycle_statechart_record" },
        "lifecycle_state_schema_version": { "$ref": "#/$defs/lifecycle_state_schema_version" },
        "statechart_id": { "$ref": "#/$defs/stable_ref" },
        "protected_object_family": { "$ref": "#/$defs/protected_object_family" },
        "source_contract_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "state_nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/state_node_inline" }
        },
        "transitions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/transition_inline" }
        },
        "actor_authority_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/actor_authority_rule_inline" }
        },
        "audit_stream_ref": { "$ref": "#/$defs/opaque_id" },
        "export_surface_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      }
    },
    "lifecycle_state_node_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "lifecycle_state_schema_version",
        "protected_object_family",
        "state_node"
      ],
      "properties": {
        "record_kind": { "const": "lifecycle_state_node_record" },
        "lifecycle_state_schema_version": { "$ref": "#/$defs/lifecycle_state_schema_version" },
        "protected_object_family": { "$ref": "#/$defs/protected_object_family" },
        "state_node": { "$ref": "#/$defs/state_node_inline" }
      }
    },
    "lifecycle_transition_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "lifecycle_state_schema_version",
        "protected_object_family",
        "transition"
      ],
      "properties": {
        "record_kind": { "const": "lifecycle_transition_record" },
        "lifecycle_state_schema_version": { "$ref": "#/$defs/lifecycle_state_schema_version" },
        "protected_object_family": { "$ref": "#/$defs/protected_object_family" },
        "transition": { "$ref": "#/$defs/transition_inline" }
      }
    },
    "lifecycle_actor_authority_rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "lifecycle_state_schema_version",
        "protected_object_family",
        "authority_rule"
      ],
      "properties": {
        "record_kind": { "const": "lifecycle_actor_authority_rule_record" },
        "lifecycle_state_schema_version": { "$ref": "#/$defs/lifecycle_state_schema_version" },
        "protected_object_family": { "$ref": "#/$defs/protected_object_family" },
        "authority_rule": { "$ref": "#/$defs/actor_authority_rule_inline" }
      }
    }
  }
}
