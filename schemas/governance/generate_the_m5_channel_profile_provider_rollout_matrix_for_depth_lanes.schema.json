{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/governance/generate_the_m5_channel_profile_provider_rollout_matrix_for_depth_lanes.schema.json",
  "title": "M5 Channel/Profile/Provider Rollout Matrix for Depth Lanes",
  "description": "Canonical typed matrix that maps every M5 depth lane to its cleared channel, deployment profile, and provider family. Downstream docs, Help/About, and support surfaces ingest this directly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "matrix_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "feature_train_matrix_ref",
    "lifecycle_labels",
    "channels",
    "profiles",
    "providers",
    "rollout_states",
    "gap_reasons",
    "stop_rule_actions",
    "launch_cutline",
    "release_blocking_lane_refs",
    "stop_rules",
    "rows",
    "rollout",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version of the matrix."
    },
    "record_kind": {
      "type": "string",
      "const": "generate_the_m5_channel_profile_provider_rollout_matrix_for_depth_lanes"
    },
    "matrix_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "overview_page": {
      "type": "string",
      "minLength": 1
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "claim_manifest_ref": {
      "type": "string",
      "minLength": 1
    },
    "feature_train_matrix_ref": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
      }
    },
    "channels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["stable", "beta", "preview", "nightly", "labs"]
      }
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["desktop", "browser", "mobile", "remote", "headless"]
      }
    },
    "providers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["aureline_hosted", "local", "managed_control_plane", "third_party"]
      }
    },
    "rollout_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["eligible", "eligible_degraded", "blocked", "pending_evidence", "not_applicable"]
      }
    },
    "gap_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "proof_packet_missing",
          "proof_packet_stale",
          "compatibility_report_missing",
          "compatibility_report_stale",
          "admin_policy_missing",
          "rollback_path_missing",
          "channel_blocked",
          "profile_unsupported",
          "provider_not_ready",
          "lane_narrowed",
          "waiver_expired"
        ]
      }
    },
    "stop_rule_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "hold_rollout",
          "narrow_label",
          "refresh_proof_packet",
          "refresh_compatibility_report",
          "staff_admin_policy",
          "define_rollback_path",
          "widen_channel",
          "restrict_profile",
          "restrict_provider"
        ]
      }
    },
    "launch_cutline": {
      "$ref": "#/$defs/launch_cutline"
    },
    "release_blocking_lane_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stop_rule" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rollout_row" }
    },
    "rollout": {
      "$ref": "#/$defs/rollout_record"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": {
          "type": "string",
          "const": "stable"
        },
        "above_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["lts", "stable"]
          }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["beta", "preview", "withdrawn"]
          }
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stop_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_rollout",
        "rationale"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "trigger_reason": {
          "type": "string",
          "enum": [
            "proof_packet_missing",
            "proof_packet_stale",
            "compatibility_report_missing",
            "compatibility_report_stale",
            "admin_policy_missing",
            "rollback_path_missing",
            "channel_blocked",
            "profile_unsupported",
            "provider_not_ready",
            "lane_narrowed",
            "waiver_expired"
          ]
        },
        "applies_to_labels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
          }
        },
        "default_action": {
          "type": "string",
          "enum": [
            "hold_rollout",
            "narrow_label",
            "refresh_proof_packet",
            "refresh_compatibility_report",
            "staff_admin_policy",
            "define_rollback_path",
            "widen_channel",
            "restrict_profile",
            "restrict_provider"
          ]
        },
        "blocks_rollout": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "rollout_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "lane_kind",
        "surface_ref",
        "channel",
        "profile",
        "provider",
        "surface_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "rollout_state",
        "effective_label",
        "proof_packet",
        "owner_signoff",
        "rationale"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "lane_kind": {
          "type": "string",
          "enum": [
            "notebook",
            "data_rich",
            "ai_adjacent",
            "framework",
            "review",
            "companion",
            "managed_depth"
          ]
        },
        "surface_ref": { "type": "string", "minLength": 1 },
        "channel": {
          "type": "string",
          "enum": ["stable", "beta", "preview", "nightly", "labs"]
        },
        "profile": {
          "type": "string",
          "enum": ["desktop", "browser", "mobile", "remote", "headless"]
        },
        "provider": {
          "type": "string",
          "enum": ["aureline_hosted", "local", "managed_control_plane", "third_party"]
        },
        "surface_summary": { "type": "string", "minLength": 1 },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "type": "string", "minLength": 1 },
        "claim_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "rollout_state": {
          "type": "string",
          "enum": ["eligible", "eligible_degraded", "blocked", "pending_evidence", "not_applicable"]
        },
        "effective_label": {
          "type": "string",
          "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
        },
        "proof_packet": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "packet_id",
            "packet_ref",
            "proof_index_ref",
            "captured_at",
            "freshness_slo",
            "slo_state",
            "evidence_refs"
          ],
          "properties": {
            "packet_id": { "type": "string", "minLength": 1 },
            "packet_ref": { "type": "string" },
            "proof_index_ref": { "type": "string", "minLength": 1 },
            "captured_at": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "format": "date" }
              ]
            },
            "freshness_slo": {
              "type": "object",
              "additionalProperties": false,
              "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
              "properties": {
                "target_max_age_days": { "type": "integer", "minimum": 1 },
                "warn_within_days": { "type": "integer", "minimum": 0 },
                "slo_register_ref": { "type": "string", "minLength": 1 }
              }
            },
            "slo_state": {
              "type": "string",
              "enum": ["current", "due_for_refresh", "breached", "missing"]
            },
            "evidence_refs": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "waiver": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["waiver_ref", "expires_at", "reason"],
              "properties": {
                "waiver_ref": { "type": "string", "minLength": 1 },
                "expires_at": { "type": "string", "format": "date" },
                "reason": { "type": "string", "minLength": 1 }
              }
            }
          ]
        },
        "owner_signoff": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner_ref", "signed_off"],
          "properties": {
            "owner_ref": { "type": "string", "minLength": 1 },
            "signed_off": { "type": "boolean" },
            "signed_at": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "format": "date" }
              ]
            }
          }
        },
        "active_gap_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "proof_packet_missing",
              "proof_packet_stale",
              "compatibility_report_missing",
              "compatibility_report_stale",
              "admin_policy_missing",
              "rollback_path_missing",
              "channel_blocked",
              "profile_unsupported",
              "provider_not_ready",
              "lane_narrowed",
              "waiver_expired"
            ]
          }
        },
        "publication_destinations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "rollout_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_claim_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": { "type": "string", "minLength": 1 },
        "decision": {
          "type": "string",
          "enum": ["proceed", "hold"]
        },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blocking_claim_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "entries_holding_stable",
        "entries_narrowed",
        "entries_eligible",
        "entries_eligible_degraded",
        "entries_blocked",
        "entries_pending_evidence",
        "entries_not_applicable",
        "entries_on_active_waiver",
        "entries_owner_blocked",
        "release_blocking_total",
        "release_blocking_holding",
        "release_blocking_narrowed",
        "notebook_entries",
        "data_rich_entries",
        "ai_adjacent_entries",
        "framework_entries",
        "review_entries",
        "companion_entries",
        "managed_depth_entries",
        "stable_channel_entries",
        "beta_channel_entries",
        "preview_channel_entries",
        "nightly_channel_entries",
        "labs_channel_entries",
        "desktop_profile_entries",
        "browser_profile_entries",
        "mobile_profile_entries",
        "remote_profile_entries",
        "headless_profile_entries",
        "aureline_hosted_entries",
        "local_entries",
        "managed_control_plane_entries",
        "third_party_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_gap_reasons",
        "rules_firing"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "entries_holding_stable": { "type": "integer", "minimum": 0 },
        "entries_narrowed": { "type": "integer", "minimum": 0 },
        "entries_eligible": { "type": "integer", "minimum": 0 },
        "entries_eligible_degraded": { "type": "integer", "minimum": 0 },
        "entries_blocked": { "type": "integer", "minimum": 0 },
        "entries_pending_evidence": { "type": "integer", "minimum": 0 },
        "entries_not_applicable": { "type": "integer", "minimum": 0 },
        "entries_on_active_waiver": { "type": "integer", "minimum": 0 },
        "entries_owner_blocked": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_holding": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "notebook_entries": { "type": "integer", "minimum": 0 },
        "data_rich_entries": { "type": "integer", "minimum": 0 },
        "ai_adjacent_entries": { "type": "integer", "minimum": 0 },
        "framework_entries": { "type": "integer", "minimum": 0 },
        "review_entries": { "type": "integer", "minimum": 0 },
        "companion_entries": { "type": "integer", "minimum": 0 },
        "managed_depth_entries": { "type": "integer", "minimum": 0 },
        "stable_channel_entries": { "type": "integer", "minimum": 0 },
        "beta_channel_entries": { "type": "integer", "minimum": 0 },
        "preview_channel_entries": { "type": "integer", "minimum": 0 },
        "nightly_channel_entries": { "type": "integer", "minimum": 0 },
        "labs_channel_entries": { "type": "integer", "minimum": 0 },
        "desktop_profile_entries": { "type": "integer", "minimum": 0 },
        "browser_profile_entries": { "type": "integer", "minimum": 0 },
        "mobile_profile_entries": { "type": "integer", "minimum": 0 },
        "remote_profile_entries": { "type": "integer", "minimum": 0 },
        "headless_profile_entries": { "type": "integer", "minimum": 0 },
        "aureline_hosted_entries": { "type": "integer", "minimum": 0 },
        "local_entries": { "type": "integer", "minimum": 0 },
        "managed_control_plane_entries": { "type": "integer", "minimum": 0 },
        "third_party_entries": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_active_gap_reasons": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
