{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/collab/session-envelope.schema.json",
  "title": "Aureline collaboration session envelope qualification",
  "description": "Canonical schema for collaboration session role, invite/admission, observer join, presenter/follow, retention, export/delete, and downgrade envelopes. Any visible session, follow, join, observer, or collaboration-adjacent lane must either carry this truth source or render below the Stable contract. The envelope separates local-only and managed copies, requires explicit workspace identity, inviter or approver, requested role, expiry, client boundary, retention mode, guest scope, export/delete rights, and downgrade behavior before acceptance, and requires visible review events for retention broadening, guest admission, role widening, route widening, or support-evidence enablement.",
  "oneOf": [
    { "$ref": "#/$defs/qualification_packet" },
    { "$ref": "#/$defs/session_envelope_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "string_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "qualification_label": {
      "type": "string",
      "enum": ["stable", "preview", "labs", "withdrawn"]
    },
    "lane_kind": {
      "type": "string",
      "enum": [
        "invitation",
        "lobby_admission",
        "observer_join",
        "presenter_follow",
        "rejoin",
        "session_export_delete"
      ]
    },
    "admission_state": {
      "type": "string",
      "enum": [
        "invited",
        "requested",
        "admitted",
        "observer",
        "declined",
        "expired",
        "revoked",
        "rejoin_required"
      ]
    },
    "session_state": {
      "type": "string",
      "enum": [
        "publish_pending",
        "shared_active",
        "participant_degraded",
        "shared_degraded",
        "ended",
        "archived"
      ]
    },
    "requested_role": {
      "type": "string",
      "enum": [
        "observer",
        "commenter",
        "editor",
        "navigator",
        "driver",
        "presenter",
        "co_presenter",
        "approver",
        "support_agent"
      ]
    },
    "client_boundary": {
      "type": "string",
      "enum": [
        "desktop_native",
        "browser_companion",
        "mobile_companion",
        "managed_admin",
        "external_guest"
      ]
    },
    "retention_mode": {
      "type": "string",
      "enum": [
        "live_only",
        "metadata_audit",
        "replayable_text_comment_timeline",
        "support_or_regulated_evidence"
      ]
    },
    "guest_scope": {
      "type": "string",
      "enum": [
        "org_members_only",
        "named_guest_by_invite",
        "approved_guest_with_ticket",
        "public_read_only_watermarked",
        "guest_forbidden"
      ]
    },
    "export_delete_right": {
      "type": "string",
      "enum": [
        "export_own_contributions",
        "owner_redacted_bundle",
        "admin_audit_export",
        "delete_local_copy",
        "request_managed_deletion",
        "legal_hold_blocks_delete",
        "no_durable_export"
      ]
    },
    "presenter_role": {
      "type": "string",
      "enum": ["not_applicable", "presenter", "co_presenter", "viewer", "moderator"]
    },
    "follow_state": {
      "type": "string",
      "enum": [
        "not_applicable",
        "following_presenter",
        "breakaway",
        "return_available",
        "follow_degraded"
      ]
    },
    "consent_trigger": {
      "type": "string",
      "enum": [
        "none",
        "retention_broadened",
        "guest_admitted",
        "role_widened",
        "route_visibility_widened",
        "support_evidence_enabled"
      ]
    },
    "downgrade_class": {
      "type": "string",
      "enum": [
        "none",
        "relay_degraded",
        "policy_narrowed",
        "client_scope_narrowed",
        "guest_boundary_narrowed",
        "invite_expired",
        "legal_hold_applied"
      ]
    },
    "local_continuity": {
      "type": "string",
      "enum": [
        "not_applicable",
        "preserve_unsent_local_only",
        "preserve_as_review_patch",
        "preserve_local_notes",
        "no_local_mutation"
      ]
    },
    "stable_proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "captured_at",
        "evidence_refs",
        "current"
      ],
      "properties": {
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/string_list" },
        "current": { "type": "boolean" }
      }
    },
    "retained_copy_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_copy_present",
        "local_retention",
        "local_rights",
        "managed_copy_present",
        "managed_retention",
        "managed_rights",
        "legal_hold"
      ],
      "properties": {
        "local_copy_present": { "type": "boolean" },
        "local_retention": { "$ref": "#/$defs/non_empty_string" },
        "local_rights": {
          "type": "array",
          "items": { "$ref": "#/$defs/export_delete_right" },
          "uniqueItems": true
        },
        "managed_copy_present": { "type": "boolean" },
        "managed_retention": { "$ref": "#/$defs/non_empty_string" },
        "managed_rights": {
          "type": "array",
          "items": { "$ref": "#/$defs/export_delete_right" },
          "uniqueItems": true
        },
        "legal_hold": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "local_copy_present": { "const": true } },
            "required": ["local_copy_present"]
          },
          "then": {
            "properties": { "local_rights": { "minItems": 1 } }
          }
        },
        {
          "if": {
            "properties": { "managed_copy_present": { "const": true } },
            "required": ["managed_copy_present"]
          },
          "then": {
            "properties": { "managed_rights": { "minItems": 1 } }
          }
        },
        {
          "if": {
            "properties": { "legal_hold": { "const": true } },
            "required": ["legal_hold"]
          },
          "then": {
            "anyOf": [
              {
                "properties": {
                  "local_rights": { "contains": { "const": "legal_hold_blocks_delete" } }
                }
              },
              {
                "properties": {
                  "managed_rights": { "contains": { "const": "legal_hold_blocks_delete" } }
                }
              }
            ]
          }
        }
      ]
    },
    "session_envelope_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "envelope_id",
        "title",
        "lane_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "workspace_identity",
        "inviter_or_approver",
        "requested_role",
        "expiry",
        "client_boundary",
        "admission_state",
        "session_state",
        "retention_mode",
        "guest_scope",
        "retained_copy_truth",
        "presenter_role",
        "follow_state",
        "consent_trigger",
        "visible_review_event",
        "downgrade_class",
        "downgrade_behavior",
        "local_continuity",
        "participant_actions",
        "projection_destinations",
        "support_export_refs",
        "rationale"
      ],
      "properties": {
        "envelope_id": {
          "type": "string",
          "pattern": "^session_envelope:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
        },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "lane_kind": { "$ref": "#/$defs/lane_kind" },
        "promoted_build_surface": { "type": "boolean" },
        "claim_label": { "$ref": "#/$defs/qualification_label" },
        "displayed_label": { "$ref": "#/$defs/qualification_label" },
        "proof_packet": { "$ref": "#/$defs/stable_proof_packet" },
        "workspace_identity": { "$ref": "#/$defs/non_empty_string" },
        "inviter_or_approver": { "$ref": "#/$defs/non_empty_string" },
        "requested_role": { "$ref": "#/$defs/requested_role" },
        "expiry": { "$ref": "#/$defs/non_empty_string" },
        "client_boundary": { "$ref": "#/$defs/client_boundary" },
        "admission_state": { "$ref": "#/$defs/admission_state" },
        "session_state": { "$ref": "#/$defs/session_state" },
        "retention_mode": { "$ref": "#/$defs/retention_mode" },
        "guest_scope": { "$ref": "#/$defs/guest_scope" },
        "retained_copy_truth": { "$ref": "#/$defs/retained_copy_truth" },
        "presenter_role": { "$ref": "#/$defs/presenter_role" },
        "follow_state": { "$ref": "#/$defs/follow_state" },
        "consent_trigger": { "$ref": "#/$defs/consent_trigger" },
        "visible_review_event": { "type": "boolean" },
        "downgrade_class": { "$ref": "#/$defs/downgrade_class" },
        "downgrade_behavior": { "$ref": "#/$defs/non_empty_string" },
        "local_continuity": { "$ref": "#/$defs/local_continuity" },
        "participant_actions": { "$ref": "#/$defs/string_list" },
        "projection_destinations": { "$ref": "#/$defs/string_list" },
        "support_export_refs": { "$ref": "#/$defs/string_list" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      },
      "allOf": [
        {
          "description": "Stable rows must carry a current proof packet.",
          "if": {
            "properties": { "displayed_label": { "const": "stable" } },
            "required": ["displayed_label"]
          },
          "then": {
            "required": ["proof_packet"],
            "properties": {
              "proof_packet": {
                "properties": { "current": { "const": true } },
                "required": ["current"]
              }
            }
          }
        },
        {
          "description": "Scope-widening consent triggers require a visible review event.",
          "if": {
            "properties": {
              "consent_trigger": {
                "enum": [
                  "retention_broadened",
                  "guest_admitted",
                  "role_widened",
                  "route_visibility_widened",
                  "support_evidence_enabled"
                ]
              }
            },
            "required": ["consent_trigger"]
          },
          "then": {
            "properties": { "visible_review_event": { "const": true } },
            "required": ["visible_review_event"]
          }
        },
        {
          "description": "Browser, mobile, and external guest joins are observer-first unless visibly downgraded below Stable.",
          "if": {
            "properties": {
              "client_boundary": {
                "enum": ["browser_companion", "mobile_companion", "external_guest"]
              },
              "displayed_label": { "const": "stable" }
            },
            "required": ["client_boundary", "displayed_label"]
          },
          "then": {
            "properties": {
              "requested_role": { "enum": ["observer", "commenter"] }
            }
          }
        },
        {
          "description": "Presenter/follow lanes must disclose presenter role and follow state.",
          "if": {
            "properties": { "lane_kind": { "const": "presenter_follow" } },
            "required": ["lane_kind"]
          },
          "then": {
            "properties": {
              "presenter_role": {
                "enum": ["presenter", "co_presenter", "viewer", "moderator"]
              },
              "follow_state": {
                "enum": [
                  "following_presenter",
                  "breakaway",
                  "return_available",
                  "follow_degraded"
                ]
              }
            }
          }
        },
        {
          "description": "Downgraded rows must describe local continuity.",
          "if": {
            "properties": {
              "downgrade_class": {
                "enum": [
                  "relay_degraded",
                  "policy_narrowed",
                  "client_scope_narrowed",
                  "guest_boundary_narrowed",
                  "invite_expired",
                  "legal_hold_applied"
                ]
              }
            },
            "required": ["downgrade_class"]
          },
          "then": {
            "properties": {
              "local_continuity": {
                "enum": [
                  "preserve_unsent_local_only",
                  "preserve_as_review_patch",
                  "preserve_local_notes",
                  "no_local_mutation"
                ]
              }
            }
          }
        }
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exposed_lane_count",
        "stable_lane_count",
        "downgraded_lane_count",
        "green_packet_count",
        "fresh_review_event_count"
      ],
      "properties": {
        "exposed_lane_count": { "type": "integer", "minimum": 0 },
        "stable_lane_count": { "type": "integer", "minimum": 0 },
        "downgraded_lane_count": { "type": "integer", "minimum": 0 },
        "green_packet_count": { "type": "integer", "minimum": 0 },
        "fresh_review_event_count": { "type": "integer", "minimum": 0 }
      }
    },
    "qualification_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "as_of",
        "artifact_ref",
        "docs_ref",
        "schema_ref",
        "fixture_ref",
        "session_envelopes",
        "summary"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "record_kind": {
          "type": "string",
          "const": "session_role_admission_and_retention_qualification"
        },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "as_of": { "$ref": "#/$defs/non_empty_string" },
        "artifact_ref": { "$ref": "#/$defs/non_empty_string" },
        "docs_ref": { "$ref": "#/$defs/non_empty_string" },
        "schema_ref": { "const": "schemas/collab/session-envelope.schema.json" },
        "fixture_ref": { "$ref": "#/$defs/non_empty_string" },
        "session_envelopes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/session_envelope_record" }
        },
        "summary": { "$ref": "#/$defs/summary" }
      }
    }
  }
}
