{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/collab/shared-control-grant.schema.json",
  "title": "Aureline shared terminal/debug control grant qualification",
  "description": "Canonical schema for shared terminal, debugger, presenter handoff, support-follow, and restore/rejoin control-plane qualification. Stable rows must prove transport-separated control, explicit grants, single-driver semantics, visible holder or view-only state, paste/secret and debug guardrails, replay-free join/restore, and support-export lineage.",
  "oneOf": [
    { "$ref": "#/$defs/packet" },
    { "$ref": "#/$defs/control_grant" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "string_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "qualification_label": {
      "type": "string",
      "enum": ["stable", "preview", "labs", "withdrawn"]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "shared_terminal",
        "shared_debugger",
        "presenter_handoff",
        "support_follow",
        "restore_rejoin"
      ]
    },
    "client_boundary": {
      "type": "string",
      "enum": [
        "desktop_native",
        "browser_companion",
        "mobile_companion",
        "support_console",
        "external_guest"
      ]
    },
    "grant_state": {
      "type": "string",
      "enum": [
        "no_grant",
        "requested",
        "offered",
        "accepted",
        "active",
        "revoked",
        "expired",
        "denied",
        "view_only_restore"
      ]
    },
    "grant_scope": {
      "type": "string",
      "enum": [
        "terminal_input",
        "terminal_paste",
        "signal_send",
        "terminal_resize",
        "debug_step_continue",
        "debug_breakpoint_edit",
        "debug_evaluate",
        "debug_attach_live_process",
        "presenter_handoff",
        "follow_moderation"
      ]
    },
    "guardrail": {
      "type": "string",
      "enum": [
        "high_risk_paste_review",
        "secret_detection",
        "clipboard_bridge_policy",
        "signal_send_approval",
        "debug_evaluate_step_up",
        "environment_reveal_redaction",
        "live_process_attach_approval",
        "visible_expiry_and_revoke"
      ]
    },
    "restore_posture": {
      "type": "string",
      "enum": [
        "not_restore",
        "view_only_fresh_grant_required",
        "evidence_only_no_live_control",
        "breakaway_view_only"
      ]
    },
    "retention_profile": {
      "type": "string",
      "enum": [
        "live_only",
        "metadata_audit",
        "redacted_evidence",
        "support_evidence"
      ]
    },
    "follow_state": {
      "type": "string",
      "enum": [
        "not_applicable",
        "following_presenter",
        "breakaway",
        "return_available",
        "follow_degraded"
      ]
    },
    "lineage_event_kind": {
      "type": "string",
      "enum": [
        "grant_issued",
        "grant_accepted",
        "driver_activated",
        "handoff_requested",
        "handoff_accepted",
        "breakaway",
        "view_only_join",
        "grant_revoked",
        "grant_expired",
        "guardrail_denied"
      ]
    },
    "lineage_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_kind",
        "actor_ref",
        "target_context_ref",
        "observed_at"
      ],
      "properties": {
        "event_id": { "$ref": "#/$defs/non_empty_string" },
        "event_kind": { "$ref": "#/$defs/lineage_event_kind" },
        "actor_ref": { "$ref": "#/$defs/non_empty_string" },
        "from_holder_ref": { "$ref": "#/$defs/non_empty_string" },
        "to_holder_ref": { "$ref": "#/$defs/non_empty_string" },
        "target_context_ref": { "$ref": "#/$defs/non_empty_string" },
        "observed_at": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "control_grant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "client_boundary",
        "target_context_ref",
        "view_stream_ref",
        "control_channel_ref",
        "presence_channel_ref",
        "transport_separated",
        "grant_state",
        "grant_scope",
        "grant_expiry",
        "revoke_action",
        "single_active_driver",
        "restore_posture",
        "no_replay_on_join",
        "prior_actions_replayed",
        "guardrails",
        "high_risk_actions_require_step_up",
        "retention_profile",
        "raw_runtime_content_retained",
        "follow_state",
        "lineage",
        "ui_indicators",
        "participant_actions",
        "projection_destinations",
        "support_export_refs",
        "evidence_refs",
        "rationale"
      ],
      "properties": {
        "control_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "promoted_build_surface": { "type": "boolean" },
        "claim_label": { "$ref": "#/$defs/qualification_label" },
        "displayed_label": { "$ref": "#/$defs/qualification_label" },
        "client_boundary": { "$ref": "#/$defs/client_boundary" },
        "target_context_ref": { "$ref": "#/$defs/non_empty_string" },
        "view_stream_ref": { "$ref": "#/$defs/non_empty_string" },
        "control_channel_ref": { "$ref": "#/$defs/non_empty_string" },
        "presence_channel_ref": { "$ref": "#/$defs/non_empty_string" },
        "transport_separated": { "type": "boolean" },
        "grant_state": { "$ref": "#/$defs/grant_state" },
        "grant_scope": {
          "type": "array",
          "items": { "$ref": "#/$defs/grant_scope" },
          "uniqueItems": true
        },
        "grant_issuer_ref": { "$ref": "#/$defs/non_empty_string" },
        "grant_accepter_ref": { "$ref": "#/$defs/non_empty_string" },
        "current_driver_ref": { "$ref": "#/$defs/non_empty_string" },
        "presenter_ref": { "$ref": "#/$defs/non_empty_string" },
        "grant_expiry": { "$ref": "#/$defs/non_empty_string" },
        "revoke_action": { "$ref": "#/$defs/non_empty_string" },
        "single_active_driver": { "type": "boolean" },
        "restore_posture": { "$ref": "#/$defs/restore_posture" },
        "no_replay_on_join": { "type": "boolean" },
        "prior_actions_replayed": { "type": "boolean" },
        "guardrails": {
          "type": "array",
          "items": { "$ref": "#/$defs/guardrail" },
          "uniqueItems": true
        },
        "high_risk_actions_require_step_up": { "type": "boolean" },
        "retention_profile": { "$ref": "#/$defs/retention_profile" },
        "raw_runtime_content_retained": { "type": "boolean" },
        "follow_state": { "$ref": "#/$defs/follow_state" },
        "lineage": {
          "type": "array",
          "items": { "$ref": "#/$defs/lineage_event" },
          "minItems": 1
        },
        "ui_indicators": { "$ref": "#/$defs/string_list" },
        "participant_actions": { "$ref": "#/$defs/string_list" },
        "projection_destinations": { "$ref": "#/$defs/string_list" },
        "support_export_refs": { "$ref": "#/$defs/string_list" },
        "evidence_refs": { "$ref": "#/$defs/string_list" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "grant_state": { "const": "active" } },
            "required": ["grant_state"]
          },
          "then": {
            "required": [
              "grant_issuer_ref",
              "grant_accepter_ref",
              "current_driver_ref"
            ],
            "properties": {
              "grant_scope": { "minItems": 1 },
              "single_active_driver": { "const": true }
            }
          }
        },
        {
          "if": {
            "properties": {
              "client_boundary": {
                "enum": [
                  "browser_companion",
                  "mobile_companion",
                  "support_console",
                  "external_guest"
                ]
              },
              "displayed_label": { "const": "stable" }
            },
            "required": ["client_boundary", "displayed_label"]
          },
          "then": {
            "not": {
              "properties": { "grant_state": { "const": "active" } },
              "required": ["grant_state"]
            }
          }
        }
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exposed_lane_count",
        "stable_lane_count",
        "downgraded_lane_count",
        "active_driver_lane_count",
        "replay_free_restore_lane_count",
        "boundary_view_only_lane_count"
      ],
      "properties": {
        "exposed_lane_count": { "type": "integer", "minimum": 0 },
        "stable_lane_count": { "type": "integer", "minimum": 0 },
        "downgraded_lane_count": { "type": "integer", "minimum": 0 },
        "active_driver_lane_count": { "type": "integer", "minimum": 0 },
        "replay_free_restore_lane_count": { "type": "integer", "minimum": 0 },
        "boundary_view_only_lane_count": { "type": "integer", "minimum": 0 }
      }
    },
    "packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "as_of",
        "artifact_ref",
        "docs_ref",
        "schema_ref",
        "fixture_ref",
        "control_grants",
        "summary"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "record_kind": {
          "type": "string",
          "const": "shared_terminal_debug_control_plane"
        },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "as_of": { "$ref": "#/$defs/non_empty_string" },
        "artifact_ref": { "$ref": "#/$defs/non_empty_string" },
        "docs_ref": { "$ref": "#/$defs/non_empty_string" },
        "schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "fixture_ref": { "$ref": "#/$defs/non_empty_string" },
        "control_grants": {
          "type": "array",
          "items": { "$ref": "#/$defs/control_grant" },
          "minItems": 1
        },
        "summary": { "$ref": "#/$defs/summary" }
      }
    }
  }
}
