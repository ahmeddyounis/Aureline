{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/platform/desktop_entry_event.schema.json",
  "title": "Aureline desktop entry event and native desktop contract packet",
  "description": "Boundary schema for desktop_entry_event_record and native_desktop_contract_packet. The record preserves OS source, origin, requested action class, literal target, canonical target, handler owner, trust/profile context, privacy posture, recovery action, and no-silent-replay posture for system open, file association, protocol callback, auth callback, recent item, jump-list action, OS notification, badge, and reveal-in-shell flows. Raw file bodies, callback bodies, provider payloads, tokens, command lines, secrets, and raw customer-owned identifiers must not cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/desktop_entry_event_record" },
    { "$ref": "#/$defs/native_desktop_contract_packet" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "string_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1
    },
    "source_surface_token": {
      "type": "string",
      "enum": [
        "system_open",
        "file_association",
        "default_browser_callback",
        "protocol_handler",
        "dock_taskbar_recent",
        "dock_taskbar_jump_action",
        "os_notification_click",
        "os_badge_activation",
        "reveal_in_system_shell"
      ]
    },
    "desktop_entry_event_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "event_id",
        "source_surface_token",
        "origin_class_token",
        "requested_action_class_token",
        "route_class_token",
        "literal_target_label",
        "literal_target_ref",
        "resulting_mode_token",
        "canonical_target_ref",
        "target_kind_token",
        "availability_class_token",
        "freshness_class_token",
        "owning_channel_ref",
        "owner_build_ref",
        "handler_ownership_token",
        "trust_profile_context_ref",
        "policy_epoch_ref",
        "recovery_surface_token",
        "recovery_action_tokens",
        "lock_screen_payload_redacted",
        "notification_summary_bounded",
        "badge_or_progress_count_traceable",
        "direct_os_execution_forbidden",
        "placeholder_recovery_required",
        "authority_widening_review_required",
        "no_silent_mutating_replay",
        "raw_private_material_excluded",
        "source_evidence_refs"
      ],
      "properties": {
        "record_kind": { "const": "desktop_entry_event_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "event_id": { "$ref": "#/$defs/non_empty_string" },
        "source_surface_token": { "$ref": "#/$defs/source_surface_token" },
        "origin_class_token": { "$ref": "#/$defs/non_empty_string" },
        "requested_action_class_token": { "$ref": "#/$defs/non_empty_string" },
        "route_class_token": { "$ref": "#/$defs/non_empty_string" },
        "literal_target_label": { "$ref": "#/$defs/non_empty_string" },
        "literal_target_ref": { "$ref": "#/$defs/non_empty_string" },
        "resulting_mode_token": { "$ref": "#/$defs/non_empty_string" },
        "canonical_target_ref": { "$ref": "#/$defs/non_empty_string" },
        "target_kind_token": { "$ref": "#/$defs/non_empty_string" },
        "availability_class_token": { "$ref": "#/$defs/non_empty_string" },
        "freshness_class_token": { "$ref": "#/$defs/non_empty_string" },
        "owning_channel_ref": { "$ref": "#/$defs/non_empty_string" },
        "owner_build_ref": { "$ref": "#/$defs/non_empty_string" },
        "handler_ownership_token": { "$ref": "#/$defs/non_empty_string" },
        "trust_profile_context_ref": { "$ref": "#/$defs/non_empty_string" },
        "policy_epoch_ref": { "$ref": "#/$defs/non_empty_string" },
        "recovery_surface_token": { "$ref": "#/$defs/non_empty_string" },
        "recovery_action_tokens": { "$ref": "#/$defs/string_list" },
        "privacy_payload_class_token": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/non_empty_string" }
          ]
        },
        "lock_screen_payload_redacted": { "type": "boolean" },
        "notification_summary_bounded": { "type": "boolean" },
        "badge_or_progress_count_traceable": { "type": "boolean" },
        "direct_os_execution_forbidden": { "type": "boolean" },
        "placeholder_recovery_required": { "type": "boolean" },
        "authority_widening_review_required": { "type": "boolean" },
        "no_silent_mutating_replay": { "type": "boolean", "const": true },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "source_evidence_refs": { "$ref": "#/$defs/string_list" }
      }
    },
    "desktop_interruption_recovery_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "row_id",
        "interruption_class_token",
        "affected_target_ref",
        "availability_class_token",
        "continuity_state_tokens",
        "resulting_mode_token",
        "recovery_action_tokens",
        "placeholder_required",
        "local_work_preserved",
        "privileged_or_mutating_work_paused",
        "no_silent_replay_or_authority_reuse",
        "source_evidence_refs"
      ],
      "properties": {
        "record_kind": { "const": "desktop_interruption_recovery_row" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "interruption_class_token": { "$ref": "#/$defs/non_empty_string" },
        "affected_target_ref": { "$ref": "#/$defs/non_empty_string" },
        "availability_class_token": { "$ref": "#/$defs/non_empty_string" },
        "continuity_state_tokens": { "$ref": "#/$defs/string_list" },
        "resulting_mode_token": { "$ref": "#/$defs/non_empty_string" },
        "recovery_action_tokens": { "$ref": "#/$defs/string_list" },
        "placeholder_required": { "type": "boolean" },
        "local_work_preserved": { "type": "boolean" },
        "privileged_or_mutating_work_paused": { "type": "boolean" },
        "no_silent_replay_or_authority_reuse": { "type": "boolean", "const": true },
        "source_evidence_refs": { "$ref": "#/$defs/string_list" }
      }
    },
    "platform_desktop_drill_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "row_id",
        "platform_profile_id",
        "drill_class_token",
        "source_evidence_ref",
        "required_disclosure_tokens",
        "channel_precedence_explicit",
        "handler_spoof_resistant",
        "exact_reopen_or_placeholder",
        "lock_screen_redacted",
        "wake_resume_truthful",
        "no_silent_mutating_replay",
        "current_proof"
      ],
      "properties": {
        "record_kind": { "const": "platform_desktop_drill_row" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "platform_profile_id": { "$ref": "#/$defs/non_empty_string" },
        "drill_class_token": { "$ref": "#/$defs/non_empty_string" },
        "source_evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "required_disclosure_tokens": { "$ref": "#/$defs/string_list" },
        "channel_precedence_explicit": { "type": "boolean" },
        "handler_spoof_resistant": { "type": "boolean" },
        "exact_reopen_or_placeholder": { "type": "boolean" },
        "lock_screen_redacted": { "type": "boolean" },
        "wake_resume_truthful": { "type": "boolean" },
        "no_silent_mutating_replay": { "type": "boolean", "const": true },
        "current_proof": { "type": "boolean", "const": true }
      }
    },
    "desktop_support_matrix_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "row_id",
        "surface_token",
        "platform_profile_ids",
        "proof_refs",
        "support_status_token",
        "current_proof",
        "exact_target_or_truthful_placeholder",
        "privacy_safe",
        "no_silent_replay"
      ],
      "properties": {
        "record_kind": { "const": "desktop_support_matrix_row" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "surface_token": { "$ref": "#/$defs/non_empty_string" },
        "platform_profile_ids": { "$ref": "#/$defs/string_list" },
        "proof_refs": { "$ref": "#/$defs/string_list" },
        "support_status_token": { "$ref": "#/$defs/non_empty_string" },
        "current_proof": { "type": "boolean", "const": true },
        "exact_target_or_truthful_placeholder": { "type": "boolean", "const": true },
        "privacy_safe": { "type": "boolean", "const": true },
        "no_silent_replay": { "type": "boolean", "const": true }
      }
    },
    "native_desktop_contract_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "build_identity_ref",
        "generated_at",
        "source_packet_refs",
        "desktop_entry_events",
        "recovery_rows",
        "platform_drills",
        "support_matrix_rows"
      ],
      "properties": {
        "record_kind": { "const": "native_desktop_contract_packet" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "build_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "source_packet_refs": { "$ref": "#/$defs/string_list" },
        "desktop_entry_events": {
          "type": "array",
          "items": { "$ref": "#/$defs/desktop_entry_event_record" },
          "minItems": 1
        },
        "recovery_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/desktop_interruption_recovery_row" },
          "minItems": 1
        },
        "platform_drills": {
          "type": "array",
          "items": { "$ref": "#/$defs/platform_desktop_drill_row" },
          "minItems": 1
        },
        "support_matrix_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/desktop_support_matrix_row" },
          "minItems": 1
        }
      }
    }
  }
}
