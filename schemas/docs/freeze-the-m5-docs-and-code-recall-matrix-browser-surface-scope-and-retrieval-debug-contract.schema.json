{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/freeze-the-m5-docs-and-code-recall-matrix-browser-surface-scope-and-retrieval-debug-contract.schema.json",
  "title": "Aureline M5 docs and code-recall matrix, browser-surface scope, and retrieval-debug contract",
  "description": "Export-safe packet freezing the M5 depth qualification for four docs-and-code-understanding lanes: mirror-aware docs semantic recall, cited codebase explainers, the retrieval-debug inspector, and scoped browser surfaces. The packet binds each lane to its qualification class, evidence requirements, downgrade triggers, rollback posture, source contracts, and consumer-surface parity. Raw document bodies, raw source files, raw query text, raw provider payloads, credentials, and live vendor-doc snapshots never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "matrix_label",
    "lane_rows",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "freeze_m5_docs_and_code_recall_matrix_browser_surface_scope_and_retrieval_debug_contract"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "matrix_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "lane_rows": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/lane_row"
      }
    },
    "trust_review": {
      "$ref": "#/$defs/trust_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "lane": {
      "type": "string",
      "enum": [
        "docs_semantic_recall",
        "codebase_explainer",
        "retrieval_debug",
        "scoped_browser_surface"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "evidence_requirement": {
      "type": "string",
      "enum": [
        "required",
        "recommended",
        "optional",
        "not_applicable"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "mirror_offline",
        "source_version_mismatch",
        "freshness_expired",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed"
      ]
    },
    "rollback_posture": {
      "type": "string",
      "enum": [
        "read_only_no_mutation",
        "return_path_preserved",
        "evidence_preserved_no_revert",
        "not_applicable"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "docs_browser",
        "code_explainer_panel",
        "retrieval_debug_inspector",
        "browser_companion",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "lane_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane",
        "qualification",
        "scope_summary",
        "evidence_requirement",
        "required_evidence_packet_refs",
        "downgrade_triggers",
        "rollback_posture",
        "source_contract_refs",
        "consumer_surfaces"
      ],
      "properties": {
        "lane": {
          "$ref": "#/$defs/lane"
        },
        "qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "scope_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_requirement": {
          "$ref": "#/$defs/evidence_requirement"
        },
        "required_evidence_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "rollback_posture": {
          "$ref": "#/$defs/rollback_posture"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/consumer_surface"
          }
        }
      }
    },
    "trust_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "docs_recall_mirror_aware",
        "explainers_cited_with_source_class",
        "confidence_class_preserved",
        "open_raw_open_source_escape_preserved",
        "ranking_reasons_explicit",
        "retrieval_debug_available",
        "browser_surface_narrow_and_attributable",
        "browser_handoff_return_path_safe",
        "no_source_looks_more_authoritative_than_proven",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "docs_recall_mirror_aware": {
          "type": "boolean",
          "const": true
        },
        "explainers_cited_with_source_class": {
          "type": "boolean",
          "const": true
        },
        "confidence_class_preserved": {
          "type": "boolean",
          "const": true
        },
        "open_raw_open_source_escape_preserved": {
          "type": "boolean",
          "const": true
        },
        "ranking_reasons_explicit": {
          "type": "boolean",
          "const": true
        },
        "retrieval_debug_available": {
          "type": "boolean",
          "const": true
        },
        "browser_surface_narrow_and_attributable": {
          "type": "boolean",
          "const": true
        },
        "browser_handoff_return_path_safe": {
          "type": "boolean",
          "const": true
        },
        "no_source_looks_more_authoritative_than_proven": {
          "type": "boolean",
          "const": true
        },
        "downgrade_narrows_instead_of_hides": {
          "type": "boolean",
          "const": true
        },
        "stale_or_underqualified_blocks_promotion": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "docs_browser_shows_provenance_and_freshness",
        "code_explainer_shows_source_class_and_confidence",
        "retrieval_debug_shows_ranking_reasons",
        "browser_companion_shows_captured_vs_live",
        "cli_headless_shows_qualification",
        "support_export_shows_qualification",
        "diagnostics_shows_qualification",
        "help_about_shows_qualification",
        "preview_labs_label_for_unqualified_lanes"
      ],
      "properties": {
        "docs_browser_shows_provenance_and_freshness": {
          "type": "boolean",
          "const": true
        },
        "code_explainer_shows_source_class_and_confidence": {
          "type": "boolean",
          "const": true
        },
        "retrieval_debug_shows_ranking_reasons": {
          "type": "boolean",
          "const": true
        },
        "browser_companion_shows_captured_vs_live": {
          "type": "boolean",
          "const": true
        },
        "cli_headless_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "support_export_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "diagnostics_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "help_about_shows_qualification": {
          "type": "boolean",
          "const": true
        },
        "preview_labs_label_for_unqualified_lanes": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
