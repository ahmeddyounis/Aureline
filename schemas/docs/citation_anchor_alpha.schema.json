{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/citation_anchor_alpha.schema.json",
  "title": "Citation Anchor Alpha Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "anchor_id",
    "docs_node_ref",
    "source_class",
    "source_pack_ref",
    "source_pack_revision_ref",
    "target_ref",
    "locale",
    "version_match_state",
    "freshness_class",
    "locality_class",
    "citation_availability",
    "inference_marker",
    "confidence_class"
  ],
  "properties": {
    "record_kind": {
      "const": "citation_anchor_alpha_record"
    },
    "schema_version": {
      "const": 1
    },
    "anchor_id": {
      "type": "string",
      "minLength": 1
    },
    "docs_node_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_class": {
      "$ref": "#/$defs/citation_source_class"
    },
    "source_pack_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_pack_revision_ref": {
      "type": "string",
      "minLength": 1
    },
    "target_ref": {
      "type": "string",
      "minLength": 1
    },
    "exact_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "locale": {
      "type": "string",
      "minLength": 2
    },
    "version_match_state": {
      "$ref": "#/$defs/version_match_state"
    },
    "freshness_class": {
      "$ref": "#/$defs/freshness_class"
    },
    "locality_class": {
      "$ref": "#/$defs/locality_class"
    },
    "citation_availability": {
      "$ref": "#/$defs/citation_anchor_availability"
    },
    "inference_marker": {
      "enum": [
        "raw_source",
        "inference",
        "heuristic",
        "generated_summary"
      ]
    },
    "confidence_class": {
      "enum": [
        "evidence_backed",
        "inferred",
        "low_confidence",
        "unknown_unverified"
      ]
    },
    "hidden_or_omitted_note": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "citation_source_class": {
      "enum": [
        "project_docs",
        "generated_reference",
        "mirrored_official_docs",
        "curated_knowledge_pack",
        "vendor_provider_docs",
        "support_runbook",
        "derived_explanation"
      ]
    },
    "version_match_state": {
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ]
    },
    "freshness_class": {
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },
    "locality_class": {
      "enum": [
        "local_project_pack",
        "generated_local",
        "mirrored_offline",
        "cached_local",
        "vendor_live",
        "not_installed",
        "support_pack"
      ]
    },
    "citation_anchor_availability": {
      "enum": [
        "exact_anchor_available",
        "anchor_unavailable_disclosed",
        "hidden_by_policy",
        "omitted_by_policy",
        "not_citation_bearing"
      ]
    }
  }
}
