{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/certify-docs-browser-semantic-recall-and-codebase-understanding-rows-and-narrow-any-underqualified-surface.schema.json",
  "title": "Aureline M5 docs and code-understanding certification packet",
  "description": "Export-safe packet certifying every landed M5 docs, browser, semantic-recall, and codebase-understanding surface against the frozen docs and code-recall matrix. Each surface row binds a shipped surface to the schema and support export it certifies, the qualification class it earned, a certification verdict, evidence packet refs, downgrade triggers, and an explicit not-greener-than-matrix flag. The packet carries a compatibility report against the frozen matrix, a machine-readable downgrade-rule set that release/support tooling auto-enforces, trust-review and consumer-projection invariants, and a proof-freshness block. This packet is canonical for claimed M5 support in this lane: no surface may stay greener than it. Raw document bodies, raw source files, raw query text, raw provider payloads, credentials, and live vendor-doc snapshots never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "certification_label",
    "surface_rows",
    "compatibility_report",
    "downgrade_rules",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "certify_docs_browser_semantic_recall_and_codebase_understanding_rows_and_narrow_any_underqualified_surface"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "certification_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "surface_rows": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "$ref": "#/$defs/surface_row"
      }
    },
    "compatibility_report": {
      "$ref": "#/$defs/compatibility_report"
    },
    "downgrade_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/downgrade_rule"
      }
    },
    "trust_review": {
      "$ref": "#/$defs/trust_review"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "proof_freshness": {
      "$ref": "#/$defs/proof_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "lane": {
      "type": "string",
      "enum": [
        "docs_pack_recall",
        "semantic_recall",
        "codebase_understanding_cards",
        "retrieval_debug",
        "scoped_browser_surface",
        "light_remote_edit",
        "saved_query_privacy",
        "docs_authoring_review",
        "docs_search_link",
        "recall_matrix"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "unavailable",
        "held"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "certified",
        "narrowed_to_qualified",
        "held_pending_evidence",
        "blocked_underqualified"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "proof_stale",
        "policy_blocked",
        "mirror_offline",
        "source_version_mismatch",
        "freshness_expired",
        "trust_narrowing",
        "scope_expansion_unqualified",
        "upstream_dependency_narrowed",
        "greener_than_matrix"
      ]
    },
    "downgrade_action": {
      "type": "string",
      "enum": [
        "narrow_to_beta",
        "narrow_to_preview",
        "hold",
        "block_promotion"
      ]
    },
    "surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane",
        "qualification",
        "verdict",
        "scope_summary",
        "schema_ref",
        "artifact_ref",
        "evidence_packet_refs",
        "downgrade_triggers",
        "not_greener_than_matrix",
        "open_raw_open_source_escape_preserved"
      ],
      "properties": {
        "lane": {
          "$ref": "#/$defs/lane"
        },
        "qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "verdict": {
          "$ref": "#/$defs/verdict"
        },
        "scope_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "schema_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "artifact_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_trigger"
          }
        },
        "not_greener_than_matrix": {
          "type": "boolean",
          "const": true
        },
        "open_raw_open_source_escape_preserved": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "compatibility_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matrix_artifact_ref",
        "matrix_schema_ref",
        "matrix_schema_version",
        "all_surfaces_present",
        "no_surface_greener_than_matrix",
        "every_surface_has_schema_and_artifact",
        "downgrade_rules_auto_enforced"
      ],
      "properties": {
        "matrix_artifact_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "matrix_schema_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "matrix_schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "all_surfaces_present": {
          "type": "boolean",
          "const": true
        },
        "no_surface_greener_than_matrix": {
          "type": "boolean",
          "const": true
        },
        "every_surface_has_schema_and_artifact": {
          "type": "boolean",
          "const": true
        },
        "downgrade_rules_auto_enforced": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "trigger",
        "action",
        "applies_to",
        "auto_enforced",
        "rationale"
      ],
      "properties": {
        "rule_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "action": {
          "$ref": "#/$defs/downgrade_action"
        },
        "applies_to": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/lane"
          }
        },
        "auto_enforced": {
          "type": "boolean",
          "const": true
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "trust_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "docs_recall_mirror_aware",
        "explainers_cited_with_source_class",
        "confidence_class_preserved",
        "open_raw_open_source_escape_preserved",
        "ranking_reasons_explicit",
        "retrieval_debug_available",
        "browser_surfaces_narrow_and_return_path_safe",
        "no_source_looks_more_authoritative_than_proven",
        "no_surface_greener_than_packet",
        "downgrade_narrows_instead_of_hides",
        "stale_or_underqualified_blocks_promotion"
      ],
      "properties": {
        "docs_recall_mirror_aware": {
          "type": "boolean",
          "const": true
        },
        "explainers_cited_with_source_class": {
          "type": "boolean",
          "const": true
        },
        "confidence_class_preserved": {
          "type": "boolean",
          "const": true
        },
        "open_raw_open_source_escape_preserved": {
          "type": "boolean",
          "const": true
        },
        "ranking_reasons_explicit": {
          "type": "boolean",
          "const": true
        },
        "retrieval_debug_available": {
          "type": "boolean",
          "const": true
        },
        "browser_surfaces_narrow_and_return_path_safe": {
          "type": "boolean",
          "const": true
        },
        "no_source_looks_more_authoritative_than_proven": {
          "type": "boolean",
          "const": true
        },
        "no_surface_greener_than_packet": {
          "type": "boolean",
          "const": true
        },
        "downgrade_narrows_instead_of_hides": {
          "type": "boolean",
          "const": true
        },
        "stale_or_underqualified_blocks_promotion": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_gate_consumes_packet",
        "cli_headless_shows_certification",
        "support_export_shows_certification",
        "diagnostics_shows_certification",
        "help_about_shows_certification",
        "evidence_index_references_packet",
        "narrowed_surfaces_labeled_not_hidden"
      ],
      "properties": {
        "release_gate_consumes_packet": {
          "type": "boolean",
          "const": true
        },
        "cli_headless_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "support_export_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "diagnostics_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "help_about_shows_certification": {
          "type": "boolean",
          "const": true
        },
        "evidence_index_references_packet": {
          "type": "boolean",
          "const": true
        },
        "narrowed_surfaces_labeled_not_hidden": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "proof_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_proof_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
