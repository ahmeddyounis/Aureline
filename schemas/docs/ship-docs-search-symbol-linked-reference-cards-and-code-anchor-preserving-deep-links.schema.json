{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/ship-docs-search-symbol-linked-reference-cards-and-code-anchor-preserving-deep-links.schema.json",
  "title": "Aureline docs search, symbol-linked reference cards, and code-anchor-preserving deep links",
  "description": "Export-safe packet binding three docs-search-depth surfaces: ranked docs-search result rows (each with a source/version/freshness chip set, an explicit ranking reason, and open-raw/open-source escapes); symbol-linked reference cards (binding a project subject to citation anchors with a resolution class, fallback chain, and project-vs-vendor truth cue); and code-anchor-preserving deep links (whose file/symbol/line/revision anchor survives export and any browser handoff with a safe return path). Resolution disclosures attach to rows, cards, or deep links by id so nearby-version, package-guide, vendor-override, and unresolved states stay distinct. The promotion state (stable / narrowed_below_stable / blocks_stable) is computed from the validation findings and disclosures. Raw query text, raw document or source bodies, raw provider payloads, raw paths, and credentials never cross this boundary; the packet carries opaque ids and typed vocabulary only. Vocabularies are re-exported from schemas/docs/symbol_linked_reference.schema.json and fixtures/docs/symbol_link_validation_manifest.yaml.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "search_label",
    "query_digest_ref",
    "search_results",
    "symbol_cards",
    "code_anchor_deep_links",
    "resolution_disclosures",
    "consumer_projections",
    "promotion_state",
    "validation_findings",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "docs_search_symbol_linked_reference_cards_and_code_anchor_deep_links"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "search_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "query_digest_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "search_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/result_row"
      }
    },
    "symbol_cards": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/symbol_card"
      }
    },
    "code_anchor_deep_links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/deep_link"
      }
    },
    "resolution_disclosures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/disclosure"
      }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/consumer_projection"
      }
    },
    "promotion_state": {
      "$ref": "#/$defs/promotion_state"
    },
    "validation_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation_finding"
      }
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "result_kind": {
      "type": "string",
      "enum": [
        "docs_page_result",
        "generated_reference_result",
        "symbol_reference_result",
        "runbook_step_result",
        "curated_pack_result",
        "vendor_provider_result",
        "derived_explanation_result"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "project_docs",
        "generated_reference",
        "mirrored_official_docs",
        "curated_knowledge_pack",
        "support_runbook",
        "vendor_provider_docs",
        "extension_docs_pack"
      ]
    },
    "version_match": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },
    "subject_kind": {
      "type": "string",
      "enum": [
        "symbol",
        "file",
        "setting",
        "command",
        "capability_lifecycle",
        "keybinding",
        "runbook_step",
        "glossary_term",
        "onboarding_step"
      ]
    },
    "resolution_class": {
      "type": "string",
      "enum": [
        "exact_symbol_match",
        "nearby_version_fallback",
        "package_level_guide_fallback",
        "project_docs_outranks_vendor_match",
        "vendor_overrides_project_disclosed",
        "unresolved_requires_refresh",
        "no_claim_yet_support_routed"
      ]
    },
    "project_vs_vendor_cue": {
      "type": "string",
      "enum": [
        "project_authoritative_only",
        "project_outranks_vendor_default",
        "vendor_overrides_project_by_policy",
        "vendor_provider_overlay_inspect_only",
        "no_project_claim_vendor_available"
      ]
    },
    "reuse_state": {
      "type": "string",
      "enum": [
        "reusable_with_citation_anchor",
        "refused_uncited",
        "refused_signature_unverified",
        "refused_mirror_continuity_broken",
        "refused_vendor_overlay_requires_higher_trust",
        "refused_external_status_feed"
      ]
    },
    "browser_handoff_reason": {
      "type": "string",
      "enum": [
        "external_docs_or_runbook",
        "provider_consent_flow",
        "license_or_portal_acceptance",
        "admin_only_surface",
        "step_up_required",
        "mutation_not_supported_in_product"
      ]
    },
    "repair_hook_kind": {
      "type": "string",
      "enum": [
        "refresh_freshness",
        "migrate_to_replacement",
        "reconnect_provider",
        "request_admin_policy_change",
        "contact_support"
      ]
    },
    "anchor_kind": {
      "type": "string",
      "enum": [
        "symbol_ref",
        "file_line_range",
        "docs_anchor",
        "setting_id",
        "command_id"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "docs_browser",
        "search_shell",
        "ai_explanation_overlay",
        "retrieval_inspector",
        "glossary_card",
        "onboarding",
        "support_export",
        "help_about"
      ]
    },
    "finding_severity": {
      "type": "string",
      "enum": [
        "blocking",
        "narrowing",
        "advisory"
      ]
    },
    "disclosure_class": {
      "type": "string",
      "enum": [
        "nearby_version_fallback",
        "package_guide_fallback",
        "project_outranks_vendor",
        "vendor_overrides_project",
        "unresolved_requires_refresh",
        "no_claim_support_routed",
        "deep_link_anchor_degraded",
        "superseded_reference"
      ]
    },
    "promotion_state": {
      "type": "string",
      "enum": [
        "stable",
        "narrowed_below_stable",
        "blocks_stable"
      ]
    },
    "validation_finding_kind": {
      "type": "string",
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "result_rows_empty",
        "result_rank_not_monotonic",
        "duplicate_result_id",
        "ranking_reason_missing",
        "open_raw_open_source_escape_missing",
        "symbol_card_orphan",
        "deep_link_ref_orphan",
        "duplicate_symbol_card_id",
        "duplicate_deep_link_id",
        "symbol_card_uncited",
        "resolution_fallback_inconsistent",
        "vendor_overlay_missing_handoff",
        "unresolved_missing_repair_hook",
        "refused_reuse_missing_repair_hook",
        "project_vs_vendor_truth_collapsed",
        "deep_link_anchor_not_preserved",
        "deep_link_return_path_missing",
        "deep_link_code_anchor_incomplete",
        "deep_link_handoff_missing_descriptor",
        "disclosure_incomplete",
        "disclosure_orphan",
        "consumer_projection_drift",
        "consumer_projection_packet_id_mismatch",
        "required_surface_coverage_missing",
        "raw_boundary_material_present"
      ]
    },
    "repair_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hook_kind",
        "hook_id",
        "display_label"
      ],
      "properties": {
        "hook_kind": {
          "$ref": "#/$defs/repair_hook_kind"
        },
        "hook_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "display_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "chip_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "version_match",
        "freshness"
      ],
      "properties": {
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "version_match": {
          "$ref": "#/$defs/version_match"
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        }
      }
    },
    "result_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank",
        "result_id",
        "result_kind",
        "display_title",
        "doc_node_ref",
        "pack_id_ref",
        "pack_revision_ref",
        "chips",
        "ranking_reason",
        "citation_anchor_refs",
        "open_raw_escape_ref",
        "open_source_escape_ref"
      ],
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "result_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "result_kind": {
          "$ref": "#/$defs/result_kind"
        },
        "display_title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "doc_node_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pack_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pack_revision_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "chips": {
          "$ref": "#/$defs/chip_set"
        },
        "ranking_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "citation_anchor_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "symbol_card_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "deep_link_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_raw_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_source_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "symbol_card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id",
        "subject_kind",
        "subject_ref",
        "display_label",
        "source_class",
        "pack_id_ref",
        "pack_revision_ref",
        "resolution_class",
        "resolution_fallback_chain",
        "project_vs_vendor_cue",
        "reuse_state",
        "citation_anchor_refs"
      ],
      "properties": {
        "card_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "subject_kind": {
          "$ref": "#/$defs/subject_kind"
        },
        "subject_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "display_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "pack_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pack_revision_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "resolution_class": {
          "$ref": "#/$defs/resolution_class"
        },
        "resolution_fallback_chain": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resolution_class"
          }
        },
        "project_vs_vendor_cue": {
          "$ref": "#/$defs/project_vs_vendor_cue"
        },
        "reuse_state": {
          "$ref": "#/$defs/reuse_state"
        },
        "citation_anchor_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "browser_handoff_reason": {
          "$ref": "#/$defs/browser_handoff_reason"
        },
        "destination_descriptor_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "repair_hook": {
          "$ref": "#/$defs/repair_hook"
        },
        "superseded_by_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "code_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file_ref",
        "revision_ref"
      ],
      "properties": {
        "file_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "symbol_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "line_anchor_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "revision_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "deep_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deep_link_id",
        "anchor_kind",
        "display_label",
        "target_subject_ref",
        "code_anchor",
        "preserves_anchor_across_export",
        "return_path_ref"
      ],
      "properties": {
        "deep_link_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "anchor_kind": {
          "$ref": "#/$defs/anchor_kind"
        },
        "display_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_subject_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "code_anchor": {
          "$ref": "#/$defs/code_anchor"
        },
        "preserves_anchor_across_export": {
          "type": "boolean"
        },
        "return_path_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "browser_handoff_reason": {
          "$ref": "#/$defs/browser_handoff_reason"
        },
        "destination_descriptor_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disclosure_class",
        "severity",
        "subject_id_ref",
        "summary"
      ],
      "properties": {
        "disclosure_class": {
          "$ref": "#/$defs/disclosure_class"
        },
        "severity": {
          "$ref": "#/$defs/finding_severity"
        },
        "subject_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "repair_hook": {
          "$ref": "#/$defs/repair_hook"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "packet_id_ref",
        "preserves_chips",
        "preserves_symbol_resolution",
        "preserves_citation_anchors",
        "preserves_code_anchor_deep_links",
        "preserves_open_raw_open_source_escape"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/consumer_surface"
        },
        "packet_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preserves_chips": {
          "type": "boolean"
        },
        "preserves_symbol_resolution": {
          "type": "boolean"
        },
        "preserves_citation_anchors": {
          "type": "boolean"
        },
        "preserves_code_anchor_deep_links": {
          "type": "boolean"
        },
        "preserves_open_raw_open_source_escape": {
          "type": "boolean"
        }
      }
    },
    "validation_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_kind",
        "severity",
        "summary"
      ],
      "properties": {
        "finding_kind": {
          "$ref": "#/$defs/validation_finding_kind"
        },
        "severity": {
          "$ref": "#/$defs/finding_severity"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
