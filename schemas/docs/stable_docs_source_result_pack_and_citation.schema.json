{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aureline.dev/docs/stable-docs-source-result-pack-and-citation/v1.json",
  "title": "Stable docs source/result/pack/citation packet",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "sources",
    "results",
    "pack_manifests",
    "pack_detail_sheets",
    "derived_citation_sets",
    "citation_drawers",
    "consumer_projections",
    "promotion_state"
  ],
  "properties": {
    "record_kind": {
      "const": "stable_docs_source_result_pack_citation_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "minItems": 1
    },
    "results": {
      "type": "array",
      "minItems": 1
    },
    "pack_manifests": {
      "type": "array",
      "minItems": 1
    },
    "pack_detail_sheets": {
      "type": "array",
      "minItems": 1
    },
    "derived_citation_sets": {
      "type": "array",
      "minItems": 1
    },
    "citation_drawers": {
      "type": "array",
      "minItems": 1
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 1
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    }
  }
}
