{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/learning_tour_alpha.schema.json",
  "title": "Aureline learning-tour alpha package manifest",
  "description": "Canonical alpha manifest for versioned learning-tour packages, guided exercise rails, package availability, contextual teaching projections, and support/export reconstruction. The manifest is an authoring/runtime bridge: every step uses stable command, docs, file, symbol, graph, or help anchors instead of coordinates; mutation-capable teaching keeps Explain and Do separate and routes through the command registry, preview sheet, approval path, and evidence packet rules; cached, local-only, mirror-only, and not-installed packages degrade with explicit citations and exact reopen refs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "manifest_id",
    "generated_at",
    "contract_refs",
    "runtime_consumer_refs",
    "packages",
    "tours",
    "steps",
    "exercise_rails",
    "contextual_teaching_surfaces",
    "support_export",
    "protected_proofs"
  ],
  "properties": {
    "record_kind": { "const": "learning_tour_alpha_manifest_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "manifest_id": { "$ref": "#/$defs/opaque_id" },
    "generated_at": { "$ref": "#/$defs/timestamp_or_fixture" },
    "contract_refs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/opaque_id" },
      "minProperties": 1
    },
    "runtime_consumer_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/opaque_id" },
      "uniqueItems": true
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/package" }
    },
    "tours": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/tour" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "exercise_rails": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/exercise_rail" }
    },
    "contextual_teaching_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/contextual_teaching_surface" }
    },
    "progress_snapshots": {
      "type": "array",
      "items": { "$ref": "https://aureline.dev/schemas/user/learning_progress_alpha.schema.json" }
    },
    "support_export": { "$ref": "#/$defs/support_export" },
    "protected_proofs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/proof" }
    }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Opaque stable id. Raw URLs, raw absolute paths, raw pack bodies, raw prompts, and secrets are not allowed."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "timestamp_or_fixture": {
      "type": "string",
      "minLength": 1,
      "description": "ISO-8601 UTC timestamp or a deterministic fixture token."
    },
    "command_id": {
      "type": "string",
      "pattern": "^cmd:[a-z0-9_.:]+$"
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_id" },
      "uniqueItems": true
    },
    "non_empty_ref_array": {
      "allOf": [
        { "$ref": "#/$defs/ref_array" },
        { "minItems": 1 }
      ]
    },
    "bcp47_locale": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "source_class": {
      "type": "string",
      "enum": ["project_docs", "curated_knowledge_pack", "mirrored_official_docs", "generated_reference"]
    },
    "package_install_state": {
      "type": "string",
      "enum": ["local_only", "cached_current", "mirror_only", "not_installed"]
    },
    "package_availability_state": {
      "type": "string",
      "enum": ["installed", "cached_available", "mirror_available", "unavailable_not_installed"]
    },
    "package_degradation_class": {
      "type": "string",
      "enum": ["no_degradation", "local_only_disclosed", "cached_disclosed", "mirror_only_disclosed", "not_installed_placeholder"]
    },
    "step_kind": {
      "type": "string",
      "enum": [
        "inline_tip",
        "guided_tour_step",
        "guided_exercise_step",
        "glossary_card",
        "educational_ai_panel",
        "practice_sandbox_indicator"
      ]
    },
    "target_kind": {
      "type": "string",
      "enum": ["command_id", "docs_node", "source_file", "symbol", "graph_node", "help_anchor"]
    },
    "scope_widening_class": {
      "type": "string",
      "enum": ["no_scope_widening", "disclosed_review_scope_widening", "blocked_until_review"]
    },
    "action_safety_class": {
      "type": "string",
      "enum": ["read_only", "preview_before_write", "mutation_requires_approval", "blocked_not_installed"]
    },
    "sandbox_posture": {
      "type": "string",
      "enum": ["read_only_walkthrough", "reversible_workspace_preview", "isolated_sandbox", "blocked_until_trust"]
    },
    "reversibility_posture": {
      "type": "string",
      "enum": ["not_applicable_read_only", "reversible_via_undo_or_reset", "discardable_sandbox", "requires_explicit_restore_review"]
    },
    "mutation_guardrail_class": {
      "type": "string",
      "enum": ["explain_only", "preview_required", "approval_required", "blocked_until_trust"]
    },
    "learning_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_label", "action_safety_class", "separate_from_explanation"],
      "properties": {
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "action_label": { "$ref": "#/$defs/opaque_id" },
        "action_safety_class": { "$ref": "#/$defs/action_safety_class" },
        "command_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/command_id" }
          ]
        },
        "preview_sheet_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "approval_path_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "evidence_packet_rule_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "separate_from_explanation": { "type": "boolean", "const": true }
      },
      "allOf": [
        {
          "if": {
            "properties": { "action_safety_class": { "enum": ["preview_before_write", "mutation_requires_approval"] } },
            "required": ["action_safety_class"]
          },
          "then": {
            "required": ["command_id", "preview_sheet_ref", "evidence_packet_rule_ref"],
            "properties": {
              "command_id": { "$ref": "#/$defs/command_id" },
              "preview_sheet_ref": { "$ref": "#/$defs/opaque_id" },
              "evidence_packet_rule_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        },
        {
          "if": {
            "properties": { "action_safety_class": { "const": "mutation_requires_approval" } },
            "required": ["action_safety_class"]
          },
          "then": {
            "properties": { "approval_path_ref": { "$ref": "#/$defs/opaque_id" } },
            "required": ["approval_path_ref"]
          }
        }
      ]
    },
    "target_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_kind"],
      "properties": {
        "target_kind": { "$ref": "#/$defs/target_kind" },
        "command_id": { "$ref": "#/$defs/command_id" },
        "docs_node_id": { "$ref": "#/$defs/opaque_id" },
        "source_file_ref": { "$ref": "#/$defs/opaque_id" },
        "symbol_ref": { "$ref": "#/$defs/opaque_id" },
        "graph_node_ref": { "$ref": "#/$defs/opaque_id" },
        "help_anchor_id": { "$ref": "#/$defs/opaque_id" }
      },
      "allOf": [
        {
          "if": { "properties": { "target_kind": { "const": "command_id" } }, "required": ["target_kind"] },
          "then": { "required": ["command_id"] }
        },
        {
          "if": { "properties": { "target_kind": { "const": "docs_node" } }, "required": ["target_kind"] },
          "then": { "required": ["docs_node_id"] }
        },
        {
          "if": { "properties": { "target_kind": { "const": "source_file" } }, "required": ["target_kind"] },
          "then": { "required": ["source_file_ref"] }
        },
        {
          "if": { "properties": { "target_kind": { "const": "symbol" } }, "required": ["target_kind"] },
          "then": { "required": ["symbol_ref"] }
        },
        {
          "if": { "properties": { "target_kind": { "const": "graph_node" } }, "required": ["target_kind"] },
          "then": { "required": ["graph_node_ref"] }
        },
        {
          "if": { "properties": { "target_kind": { "const": "help_anchor" } }, "required": ["target_kind"] },
          "then": { "required": ["help_anchor_id"] }
        }
      ]
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_id",
        "package_version",
        "package_revision_ref",
        "source_class",
        "install_state",
        "availability_state",
        "docs_pack_ref",
        "docs_pack_revision_ref",
        "source_locale",
        "available_locales",
        "citation_refs",
        "exact_reopen_ref",
        "degradation_copy_class"
      ],
      "properties": {
        "package_id": { "$ref": "#/$defs/opaque_id" },
        "package_version": { "$ref": "#/$defs/opaque_id" },
        "package_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "install_state": { "$ref": "#/$defs/package_install_state" },
        "availability_state": { "$ref": "#/$defs/package_availability_state" },
        "docs_pack_ref": { "$ref": "#/$defs/opaque_id" },
        "docs_pack_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "source_locale": { "$ref": "#/$defs/bcp47_locale" },
        "available_locales": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bcp47_locale" },
          "uniqueItems": true
        },
        "citation_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "exact_reopen_ref": { "$ref": "#/$defs/opaque_id" },
        "degradation_copy_class": { "$ref": "#/$defs/package_degradation_class" }
      }
    },
    "tour": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tour_id",
        "package_ref",
        "title",
        "audience_class",
        "profile_ref",
        "ordered_step_refs",
        "docs_pack_refs",
        "citation_refs",
        "package_availability_state",
        "exact_resume_ref"
      ],
      "properties": {
        "tour_id": { "$ref": "#/$defs/opaque_id" },
        "package_ref": { "$ref": "#/$defs/opaque_id" },
        "title": { "$ref": "#/$defs/opaque_id" },
        "audience_class": { "$ref": "#/$defs/opaque_id" },
        "profile_ref": { "$ref": "#/$defs/opaque_id" },
        "ordered_step_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "docs_pack_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "citation_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "package_availability_state": { "$ref": "#/$defs/package_availability_state" },
        "exact_resume_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "tour_ref",
        "package_ref",
        "position_index",
        "step_kind",
        "title",
        "target_ref",
        "current_scope_ref",
        "scope_widening_class",
        "citation_refs",
        "success_criteria",
        "hint_ref",
        "reveal_ref",
        "skip_action",
        "reset_action",
        "sandbox_posture",
        "reversibility_posture",
        "explain_before_action",
        "primary_action",
        "degradation_copy_class",
        "exact_reopen_ref",
        "active"
      ],
      "properties": {
        "step_id": { "$ref": "#/$defs/opaque_id" },
        "tour_ref": { "$ref": "#/$defs/opaque_id" },
        "package_ref": { "$ref": "#/$defs/opaque_id" },
        "position_index": { "type": "integer", "minimum": 0 },
        "step_kind": { "$ref": "#/$defs/step_kind" },
        "title": { "$ref": "#/$defs/opaque_id" },
        "target_ref": { "$ref": "#/$defs/target_ref" },
        "current_scope_ref": { "$ref": "#/$defs/opaque_id" },
        "scope_widening_class": { "$ref": "#/$defs/scope_widening_class" },
        "citation_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "success_criteria": { "$ref": "#/$defs/non_empty_ref_array" },
        "hint_ref": { "$ref": "#/$defs/opaque_id" },
        "reveal_ref": { "$ref": "#/$defs/opaque_id" },
        "skip_action": { "$ref": "#/$defs/learning_action" },
        "reset_action": { "$ref": "#/$defs/learning_action" },
        "sandbox_posture": { "$ref": "#/$defs/sandbox_posture" },
        "reversibility_posture": { "$ref": "#/$defs/reversibility_posture" },
        "explain_before_action": { "type": "boolean", "const": true },
        "primary_action": { "$ref": "#/$defs/learning_action" },
        "degradation_copy_class": { "$ref": "#/$defs/package_degradation_class" },
        "exact_reopen_ref": { "$ref": "#/$defs/opaque_id" },
        "active": { "type": "boolean" }
      }
    },
    "exercise_rail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rail_id",
        "tour_ref",
        "current_step_ref",
        "ordered_step_refs",
        "success_criteria_refs",
        "hint_action",
        "reveal_action",
        "skip_action",
        "reset_action",
        "sandbox_posture",
        "reversibility_posture",
        "explanation_before_action_required",
        "mutation_guardrail_class",
        "reversible_or_sandboxed"
      ],
      "properties": {
        "rail_id": { "$ref": "#/$defs/opaque_id" },
        "tour_ref": { "$ref": "#/$defs/opaque_id" },
        "current_step_ref": { "$ref": "#/$defs/opaque_id" },
        "ordered_step_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "success_criteria_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "hint_action": { "$ref": "#/$defs/learning_action" },
        "reveal_action": { "$ref": "#/$defs/learning_action" },
        "skip_action": { "$ref": "#/$defs/learning_action" },
        "reset_action": { "$ref": "#/$defs/learning_action" },
        "sandbox_posture": { "$ref": "#/$defs/sandbox_posture" },
        "reversibility_posture": { "$ref": "#/$defs/reversibility_posture" },
        "explanation_before_action_required": { "type": "boolean", "const": true },
        "mutation_guardrail_class": { "$ref": "#/$defs/mutation_guardrail_class" },
        "reversible_or_sandboxed": { "type": "boolean", "const": true }
      }
    },
    "contextual_teaching_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "step_ref",
        "render_surface_kind",
        "command_id",
        "docs_anchor_ref",
        "citation_refs",
        "current_step_ref",
        "package_install_state",
        "package_degradation_class",
        "exact_reopen_ref",
        "explanation_copy_ref",
        "action_copy_ref",
        "explain_and_do_separate",
        "mutation_uses_command_registry",
        "support_export_row_ref"
      ],
      "properties": {
        "surface_id": { "$ref": "#/$defs/opaque_id" },
        "step_ref": { "$ref": "#/$defs/opaque_id" },
        "render_surface_kind": { "$ref": "#/$defs/step_kind" },
        "command_id": { "$ref": "#/$defs/command_id" },
        "docs_anchor_ref": { "$ref": "#/$defs/opaque_id" },
        "citation_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "current_step_ref": { "$ref": "#/$defs/opaque_id" },
        "package_install_state": { "$ref": "#/$defs/package_install_state" },
        "package_degradation_class": { "$ref": "#/$defs/package_degradation_class" },
        "exact_reopen_ref": { "$ref": "#/$defs/opaque_id" },
        "explanation_copy_ref": { "$ref": "#/$defs/opaque_id" },
        "action_copy_ref": { "$ref": "#/$defs/opaque_id" },
        "explain_and_do_separate": { "type": "boolean", "const": true },
        "mutation_uses_command_registry": { "type": "boolean", "const": true },
        "support_export_row_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": ["export_id", "raw_pack_body_exported", "rows"],
      "properties": {
        "export_id": { "$ref": "#/$defs/opaque_id" },
        "raw_pack_body_exported": { "type": "boolean", "const": false },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/support_export_row" }
        }
      }
    },
    "support_export_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "surface_ref",
        "package_ref",
        "step_ref",
        "package_revision_ref",
        "citation_refs",
        "exact_reopen_ref",
        "progress_snapshot_ref",
        "raw_body_exported"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/opaque_id" },
        "surface_ref": { "$ref": "#/$defs/opaque_id" },
        "package_ref": { "$ref": "#/$defs/opaque_id" },
        "step_ref": { "$ref": "#/$defs/opaque_id" },
        "package_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "citation_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "exact_reopen_ref": { "$ref": "#/$defs/opaque_id" },
        "progress_snapshot_ref": { "$ref": "#/$defs/opaque_id" },
        "raw_body_exported": { "type": "boolean", "const": false }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_id", "fixture_ref", "exercised_package_refs", "exercised_step_refs", "exercised_states"],
      "properties": {
        "proof_id": { "$ref": "#/$defs/opaque_id" },
        "fixture_ref": { "$ref": "#/$defs/opaque_id" },
        "exercised_package_refs": { "$ref": "#/$defs/ref_array" },
        "exercised_step_refs": { "$ref": "#/$defs/ref_array" },
        "exercised_states": { "$ref": "#/$defs/non_empty_ref_array" }
      }
    }
  }
}
