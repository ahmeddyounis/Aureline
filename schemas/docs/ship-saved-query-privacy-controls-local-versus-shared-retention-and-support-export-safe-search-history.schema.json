        "visibility_expansion_detected",
        "privacy_visibility_mismatch",
        "retention_privacy_mismatch",
        "support_export_unsafe",
        "export_row_orphan",
        "export_coverage_missing",
        "export_drops_preservation",
        "export_privacy_class_mismatch",
        "export_retention_mismatch",
        "export_visibility_mismatch",
        "export_trust_class_mismatch",
        "export_source_class_mismatch",
        "export_confidence_mismatch",
        "export_redaction_mismatch",
        "export_export_safe_mismatch",
        "degradation_incomplete",
        "degradation_orphan",
        "consumer_projection_drift",
        "consumer_projection_packet_id_mismatch",
        "required_surface_coverage_missing",
        "raw_boundary_material_present"
      ]
    },
    "chip_set": {
      "type": "object",
