        "synced_private",
        "shared_store",
        "managed_retention"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "redacted_label_only",
        "digest_only",
        "raw_withheld",
        "needs_redaction",
        "not_exportable"
      ]
    },
    "entry_kind": {
      "type": "string",
      "enum": [
