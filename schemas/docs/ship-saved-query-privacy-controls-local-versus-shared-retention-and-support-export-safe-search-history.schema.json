{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/ship-saved-query-privacy-controls-local-versus-shared-retention-and-support-export-safe-search-history.schema.json",
  "title": "Aureline saved-query privacy controls, local-versus-shared retention, and support-export-safe search history",
  "description": "Export-safe packet for the M5 saved-query privacy boundary. The packet carries one or more saved-query / history entries across the qualified private_local / private_synced / shared_team / shared_org privacy classes, each with a five-chip set (source class, version match, freshness, locality, confidence), one trust-class disclosure (first_party_user_saved / signed_shared_library / extension_imported_set / live_synced_suggestion / derived_suggestion_only), a granted-vs-effective visibility pair (no hidden visibility expansion), a retention disclosure (local-versus-shared retention truth), a support-export safety block (export-safe history), a share posture, a live-vs-captured state, citation state, and open-raw/open-source escapes. An entry declaring a privacy class outside the qualified scope, exposing more visibility than was granted or than its privacy class permits, retaining a query in a storage tier that exposes it more widely than its privacy class allows, failing to disclose a synced or shared tier, marking an entry export-safe while its redaction class is not export-safe, presenting an untrusted origin at high confidence, or presenting a policy-blocked share as available blocks the claim. An export preserves privacy class, retention, visibility, trust class, source class, confidence, redaction, export-safe, and escapes per entry. Packet-level degradations narrow or block the claim. The promotion state (stable / narrowed_below_stable / blocks_stable) is computed from validation and degradation findings. Raw query bodies, raw URLs, raw history payloads, raw source files, raw provider payloads, and credentials never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "session_label",
    "session_digest_ref",
    "entries",
    "export",
    "query_degradations",
    "consumer_projections",
    "promotion_state",
    "validation_findings",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "saved_query_privacy_controls"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "session_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "session_digest_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "export": {
      "$ref": "#/$defs/export"
    },
    "query_degradations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/query_degradation"
      }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/consumer_projection"
      }
    },
    "promotion_state": {
      "$ref": "#/$defs/promotion_state"
    },
    "validation_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation_finding"
      }
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
