{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/implement-mirrored-docs-pack-recall-source-or-version-or-freshness-chips-and-stale-example-findings.schema.json",
  "title": "Aureline mirrored docs-pack recall with source/version/freshness chips and stale-example findings",
  "description": "Export-safe packet for a mirror-aware docs-pack recall. Each ranked result row carries a five-chip set (source class, version match, freshness, locality, confidence), an explicit ranking reason, and open-raw/open-source escapes. Stale-example findings attach to rows by result id so nearby-version, stale-example, and quarantined-pack states stay distinct. The promotion state (stable / narrowed_below_stable / blocks_stable) is computed from the validation and stale-example findings. Raw query text, raw document bodies, raw provider payloads, and credentials never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "recall_label",
    "query_digest_ref",
    "mirror_awareness",
    "result_rows",
    "stale_example_findings",
    "consumer_projections",
    "promotion_state",
    "validation_findings",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "mirrored_docs_pack_recall_chips_and_stale_example_findings"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "recall_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "query_digest_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "mirror_awareness": {
      "$ref": "#/$defs/mirror_awareness"
    },
    "result_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/result_row"
      }
    },
    "stale_example_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stale_finding"
      }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/consumer_projection"
      }
    },
    "promotion_state": {
      "$ref": "#/$defs/promotion_state"
    },
    "validation_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation_finding"
      }
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "source_class": {
      "type": "string",
      "enum": [
        "project_docs",
        "generated_reference",
        "mirrored_official_docs",
        "curated_knowledge_pack",
        "support_runbook",
        "extension_docs_pack"
      ]
    },
    "version_match": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified",
        "refresh_pending"
      ]
    },
    "locality": {
      "type": "string",
      "enum": [
        "local",
        "mirrored_pack",
        "remote_helper",
        "managed"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "heuristic"
      ]
    },
    "finding_severity": {
      "type": "string",
      "enum": [
        "blocking",
        "narrowing",
        "advisory"
      ]
    },
    "stale_finding_class": {
      "type": "string",
      "enum": [
        "nearby_version",
        "stale_example",
        "quarantined_pack",
        "broken_link",
        "needs_review",
        "missing_evidence"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "docs_browser",
        "search_shell",
        "ai_context",
        "retrieval_inspector",
        "cli_headless",
        "support_export",
        "help_about"
      ]
    },
    "promotion_state": {
      "type": "string",
      "enum": [
        "stable",
        "narrowed_below_stable",
        "blocks_stable"
      ]
    },
    "validation_finding_kind": {
      "type": "string",
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "result_rows_empty",
        "result_rank_not_monotonic",
        "duplicate_result_id",
        "ranking_reason_missing",
        "open_raw_open_source_escape_missing",
        "mirror_awareness_incomplete",
        "live_mirror_looks_more_authoritative",
        "version_truth_collapsed",
        "mirrored_source_coverage_missing",
        "stale_finding_incomplete",
        "stale_finding_orphan",
        "consumer_projection_drift",
        "consumer_projection_packet_id_mismatch",
        "required_surface_coverage_missing",
        "raw_boundary_material_present"
      ]
    },
    "mirror_awareness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pinned_signed_mirror_outranks_live",
        "live_vendor_docs_demoted_when_unpinned",
        "mirror_signature_verified"
      ],
      "properties": {
        "pinned_signed_mirror_outranks_live": {
          "type": "boolean"
        },
        "live_vendor_docs_demoted_when_unpinned": {
          "type": "boolean"
        },
        "mirror_signature_verified": {
          "type": "boolean"
        }
      }
    },
    "chip_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "version_match",
        "freshness",
        "locality",
        "confidence"
      ],
      "properties": {
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "version_match": {
          "$ref": "#/$defs/version_match"
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        },
        "locality": {
          "$ref": "#/$defs/locality"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "result_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank",
        "result_id",
        "doc_node_ref",
        "pack_id_ref",
        "pack_pinned",
        "pack_signed_and_verified",
        "chips",
        "ranking_reason",
        "open_raw_escape_ref",
        "open_source_escape_ref"
      ],
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "result_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "doc_node_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pack_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pack_pinned": {
          "type": "boolean"
        },
        "pack_signed_and_verified": {
          "type": "boolean"
        },
        "chips": {
          "$ref": "#/$defs/chip_set"
        },
        "ranking_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_raw_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_source_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "stale_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_class",
        "severity",
        "result_id_ref",
        "pack_id_ref",
        "summary"
      ],
      "properties": {
        "finding_class": {
          "$ref": "#/$defs/stale_finding_class"
        },
        "severity": {
          "$ref": "#/$defs/finding_severity"
        },
        "result_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pack_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "nearby_version_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "packet_id_ref",
        "preserves_chips",
        "preserves_stale_findings",
        "preserves_ranking_reason",
        "preserves_open_raw_open_source_escape",
        "preserves_mirror_awareness"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/consumer_surface"
        },
        "packet_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preserves_chips": {
          "type": "boolean"
        },
        "preserves_stale_findings": {
          "type": "boolean"
        },
        "preserves_ranking_reason": {
          "type": "boolean"
        },
        "preserves_open_raw_open_source_escape": {
          "type": "boolean"
        },
        "preserves_mirror_awareness": {
          "type": "boolean"
        }
      }
    },
    "validation_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_kind",
        "severity",
        "summary"
      ],
      "properties": {
        "finding_kind": {
          "$ref": "#/$defs/validation_finding_kind"
        },
        "severity": {
          "$ref": "#/$defs/finding_severity"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
