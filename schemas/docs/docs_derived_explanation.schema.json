{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/docs_derived_explanation.schema.json",
  "title": "Docs Derived Explanation Record",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_kind",
    "schema_version",
    "explanation_id",
    "surface_kind",
    "derived_explanation_kind",
    "summary_label",
    "provenance",
    "upstream_citation_anchor_refs",
    "cited_docs_node_refs",
    "claims",
    "docs_pack_refs"
  ],
  "properties": {
    "record_kind": {
      "const": "docs_derived_explanation_record"
    },
    "schema_version": {
      "const": 1
    },
    "explanation_id": {
      "type": "string",
      "minLength": 1
    },
    "surface_kind": {
      "enum": [
        "docs_browser",
        "glossary_card",
        "architecture_map",
        "topology_explainer",
        "codebase_explainer",
        "quick_help",
        "docs_backed_search",
        "docs_backed_ai",
        "support_export"
      ]
    },
    "derived_explanation_kind": {
      "enum": ["curated", "generated"]
    },
    "summary_label": {
      "type": "string",
      "minLength": 1
    },
    "provenance": {
      "$ref": "docs_node_provenance.schema.json"
    },
    "upstream_citation_anchor_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cited_docs_node_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "claim_id",
          "claim_kind",
          "claim_summary",
          "supporting_citation_anchor_refs",
          "inference_marker",
          "confidence_class"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "claim_kind": {
            "enum": [
              "fact_claim",
              "inference_claim",
              "procedure_or_step",
              "definition_or_glossary",
              "architecture_relation"
            ]
          },
          "claim_summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "supporting_citation_anchor_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "inference_marker": {
            "enum": ["raw_source", "inference", "heuristic", "generated_summary"]
          },
          "confidence_class": {
            "enum": [
              "evidence_backed",
              "inferred",
              "low_confidence",
              "unknown_unverified"
            ]
          }
        },
        "allOf": [
          {
            "description": "Uncited claims must not present as raw evidence-backed source truth.",
            "if": {
              "properties": {
                "supporting_citation_anchor_refs": { "maxItems": 0 }
              },
              "required": ["supporting_citation_anchor_refs"]
            },
            "then": {
              "not": {
                "properties": {
                  "inference_marker": { "const": "raw_source" },
                  "confidence_class": { "const": "evidence_backed" }
                },
                "required": ["inference_marker", "confidence_class"]
              }
            }
          }
        ]
      }
    },
    "derivation_epoch_ref": {
      "type": "string",
      "minLength": 1
    },
    "docs_pack_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
