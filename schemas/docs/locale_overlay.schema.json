{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/locale_overlay.schema.json",
  "title": "Aureline locale-overlay contract",
  "description": "Boundary schema for translated docs, help, glossary, onboarding, guided-tour, and troubleshooting overlays. Locale overlays preserve pack identity, source revision, overlay revision, source-revision basis, coverage state, freshness/skew state, mirror/offline posture, citation anchors, command ids, keyboard paths, scope labels, and a stable source-language action without carrying raw translated or source bodies.",
  "oneOf": [
    { "$ref": "#/$defs/locale_overlay_contract_record" },
    { "$ref": "#/$defs/locale_overlay_surface_projection_record" },
    { "$ref": "#/$defs/locale_overlay_support_export_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "stable_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:._@#/-]*$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "locale": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "non_empty_strings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stable_id" },
      "uniqueItems": true
    },
    "pack_kind": {
      "type": "string",
      "enum": [
        "docs_pack",
        "help_pack",
        "glossary_pack",
        "onboarding_pack",
        "guided_tour_pack",
        "troubleshooting_help_pack"
      ]
    },
    "coverage_state": {
      "type": "string",
      "enum": [
        "source_language_original",
        "translated_complete",
        "translated_partial",
        "translated_stale",
        "source_language_fallback",
        "locale_not_installed"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },
    "skew_state": {
      "type": "string",
      "enum": [
        "no_skew",
        "source_revision_ahead",
        "overlay_revision_ahead",
        "unknown_skew"
      ]
    },
    "mirror_offline_posture": {
      "type": "string",
      "enum": [
        "built_in_local",
        "mirrored",
        "offline_pack",
        "cached",
        "live_online",
        "not_installed"
      ]
    },
    "badge_class": {
      "type": "string",
      "enum": [
        "translated",
        "partial_translation",
        "stale_translation",
        "source_language_fallback"
      ]
    },
    "source_language_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "action_label",
        "command_id",
        "target_ref",
        "source_locale",
        "keyboard_reachable"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/stable_id" },
        "action_label": {
          "type": "string",
          "const": "Open in source language"
        },
        "command_id": {
          "type": "string",
          "pattern": "^cmd:[A-Za-z0-9_.:-]+$"
        },
        "target_ref": { "$ref": "#/$defs/stable_id" },
        "source_locale": { "$ref": "#/$defs/locale" },
        "keyboard_reachable": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "locale_overlay_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "overlay_id",
        "pack_id",
        "pack_kind",
        "pack_owner_ref",
        "source_locale",
        "requested_locale",
        "effective_locale",
        "source_revision_ref",
        "overlay_revision_ref",
        "overlay_source_revision_ref",
        "coverage_state",
        "freshness_class",
        "skew_state",
        "mirror_offline_posture",
        "badge_class",
        "surface_refs",
        "citation_anchor_refs",
        "command_id_refs",
        "keyboard_path_refs",
        "scope_label_refs",
        "source_language_action",
        "exact_reopen_ref",
        "support_row_ref"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "locale_overlay_record"
        },
        "overlay_id": { "$ref": "#/$defs/stable_id" },
        "pack_id": { "$ref": "#/$defs/stable_id" },
        "pack_kind": { "$ref": "#/$defs/pack_kind" },
        "pack_owner_ref": { "$ref": "#/$defs/stable_id" },
        "source_locale": { "$ref": "#/$defs/locale" },
        "requested_locale": { "$ref": "#/$defs/locale" },
        "effective_locale": { "$ref": "#/$defs/locale" },
        "source_revision_ref": { "$ref": "#/$defs/stable_id" },
        "overlay_revision_ref": { "$ref": "#/$defs/stable_id" },
        "overlay_source_revision_ref": { "$ref": "#/$defs/stable_id" },
        "coverage_state": { "$ref": "#/$defs/coverage_state" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "skew_state": { "$ref": "#/$defs/skew_state" },
        "mirror_offline_posture": { "$ref": "#/$defs/mirror_offline_posture" },
        "badge_class": { "$ref": "#/$defs/badge_class" },
        "surface_refs": { "$ref": "#/$defs/non_empty_strings" },
        "citation_anchor_refs": { "$ref": "#/$defs/non_empty_strings" },
        "command_id_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^cmd:[A-Za-z0-9_.:-]+$"
          },
          "uniqueItems": true
        },
        "keyboard_path_refs": { "$ref": "#/$defs/non_empty_strings" },
        "scope_label_refs": { "$ref": "#/$defs/non_empty_strings" },
        "source_language_action": { "$ref": "#/$defs/source_language_action" },
        "exact_reopen_ref": { "$ref": "#/$defs/stable_id" },
        "support_row_ref": { "$ref": "#/$defs/stable_id" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "coverage_state": { "const": "translated_complete" }
            },
            "required": ["coverage_state"]
          },
          "then": {
            "properties": {
              "badge_class": { "const": "translated" },
              "skew_state": { "const": "no_skew" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "coverage_state": { "const": "translated_partial" }
            },
            "required": ["coverage_state"]
          },
          "then": {
            "properties": {
              "badge_class": { "const": "partial_translation" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "coverage_state": { "const": "translated_stale" }
            },
            "required": ["coverage_state"]
          },
          "then": {
            "properties": {
              "badge_class": { "const": "stale_translation" },
              "freshness_class": { "const": "stale" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "coverage_state": {
                "enum": ["source_language_fallback", "locale_not_installed"]
              }
            },
            "required": ["coverage_state"]
          },
          "then": {
            "properties": {
              "badge_class": { "const": "source_language_fallback" }
            }
          }
        }
      ]
    },
    "support_export_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "record_source_and_overlay_revisions",
        "record_integrity_refs",
        "record_source_language_action",
        "raw_translated_bodies_exported",
        "bounded_material_classes",
        "omitted_material_classes"
      ],
      "properties": {
        "policy_id": { "$ref": "#/$defs/stable_id" },
        "record_source_and_overlay_revisions": { "type": "boolean", "const": true },
        "record_integrity_refs": { "type": "boolean", "const": true },
        "record_source_language_action": { "type": "boolean", "const": true },
        "raw_translated_bodies_exported": { "type": "boolean", "const": false },
        "bounded_material_classes": { "$ref": "#/$defs/non_empty_strings" },
        "omitted_material_classes": { "$ref": "#/$defs/non_empty_strings" }
      }
    },
    "locale_overlay_contract_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "contract_id",
        "contract_version_ref",
        "generated_at",
        "source_language_locale",
        "contract_refs",
        "overlays",
        "support_export_policy"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "locale_overlay_contract_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "contract_id": { "$ref": "#/$defs/stable_id" },
        "contract_version_ref": { "$ref": "#/$defs/stable_id" },
        "generated_at": { "$ref": "#/$defs/timestamp" },
        "source_language_locale": { "$ref": "#/$defs/locale" },
        "contract_refs": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/stable_id" }
        },
        "overlays": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/locale_overlay_record" }
        },
        "support_export_policy": { "$ref": "#/$defs/support_export_policy" }
      }
    },
    "locale_overlay_surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "surface_ref",
        "overlay_id",
        "pack_id",
        "pack_kind",
        "requested_locale",
        "effective_locale",
        "source_revision_ref",
        "overlay_revision_ref",
        "overlay_source_revision_ref",
        "coverage_state",
        "freshness_class",
        "skew_state",
        "mirror_offline_posture",
        "badge_class",
        "badge_label",
        "source_language_action_id",
        "source_language_action_label",
        "citation_anchor_refs",
        "command_id_refs",
        "keyboard_path_refs",
        "scope_label_refs",
        "support_row_ref"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/stable_id" },
        "surface_ref": { "$ref": "#/$defs/stable_id" },
        "overlay_id": { "$ref": "#/$defs/stable_id" },
        "pack_id": { "$ref": "#/$defs/stable_id" },
        "pack_kind": { "$ref": "#/$defs/pack_kind" },
        "requested_locale": { "$ref": "#/$defs/locale" },
        "effective_locale": { "$ref": "#/$defs/locale" },
        "source_revision_ref": { "$ref": "#/$defs/stable_id" },
        "overlay_revision_ref": { "$ref": "#/$defs/stable_id" },
        "overlay_source_revision_ref": { "$ref": "#/$defs/stable_id" },
        "coverage_state": { "$ref": "#/$defs/coverage_state" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "skew_state": { "$ref": "#/$defs/skew_state" },
        "mirror_offline_posture": { "$ref": "#/$defs/mirror_offline_posture" },
        "badge_class": { "$ref": "#/$defs/badge_class" },
        "badge_label": {
          "type": "string",
          "enum": [
            "Translated",
            "Partial translation",
            "Stale translation",
            "Source-language fallback"
          ]
        },
        "source_language_action_id": { "$ref": "#/$defs/stable_id" },
        "source_language_action_label": {
          "type": "string",
          "const": "Open in source language"
        },
        "citation_anchor_refs": { "$ref": "#/$defs/non_empty_strings" },
        "command_id_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^cmd:[A-Za-z0-9_.:-]+$"
          },
          "uniqueItems": true
        },
        "keyboard_path_refs": { "$ref": "#/$defs/non_empty_strings" },
        "scope_label_refs": { "$ref": "#/$defs/non_empty_strings" },
        "support_row_ref": { "$ref": "#/$defs/stable_id" }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overlay_count",
        "pack_kind_count",
        "pack_kinds",
        "coverage_counts",
        "badge_counts",
        "source_language_action_count"
      ],
      "properties": {
        "overlay_count": { "type": "integer", "minimum": 1 },
        "pack_kind_count": { "type": "integer", "minimum": 1 },
        "pack_kinds": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/pack_kind" },
          "uniqueItems": true
        },
        "coverage_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "badge_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "source_language_action_count": { "type": "integer", "minimum": 1 }
      }
    },
    "locale_overlay_surface_projection_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "projection_id",
        "generated_at",
        "contract_id",
        "contract_version_ref",
        "rows",
        "coverage"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "locale_overlay_surface_projection_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "projection_id": { "$ref": "#/$defs/stable_id" },
        "generated_at": { "$ref": "#/$defs/timestamp" },
        "contract_id": { "$ref": "#/$defs/stable_id" },
        "contract_version_ref": { "$ref": "#/$defs/stable_id" },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/locale_overlay_surface_row" }
        },
        "coverage": { "$ref": "#/$defs/coverage" }
      }
    },
    "locale_overlay_support_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_row_ref",
        "overlay_id",
        "pack_id",
        "pack_kind",
        "pack_owner_ref",
        "source_locale",
        "requested_locale",
        "effective_locale",
        "source_revision_ref",
        "overlay_revision_ref",
        "overlay_source_revision_ref",
        "coverage_state",
        "freshness_class",
        "skew_state",
        "mirror_offline_posture",
        "badge_class",
        "source_language_action_id",
        "source_language_action_label",
        "citation_anchor_refs",
        "command_id_refs",
        "keyboard_path_refs",
        "scope_label_refs",
        "exact_reopen_ref",
        "raw_translated_body_exported"
      ],
      "properties": {
        "support_row_ref": { "$ref": "#/$defs/stable_id" },
        "overlay_id": { "$ref": "#/$defs/stable_id" },
        "pack_id": { "$ref": "#/$defs/stable_id" },
        "pack_kind": { "$ref": "#/$defs/pack_kind" },
        "pack_owner_ref": { "$ref": "#/$defs/stable_id" },
        "source_locale": { "$ref": "#/$defs/locale" },
        "requested_locale": { "$ref": "#/$defs/locale" },
        "effective_locale": { "$ref": "#/$defs/locale" },
        "source_revision_ref": { "$ref": "#/$defs/stable_id" },
        "overlay_revision_ref": { "$ref": "#/$defs/stable_id" },
        "overlay_source_revision_ref": { "$ref": "#/$defs/stable_id" },
        "coverage_state": { "$ref": "#/$defs/coverage_state" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "skew_state": { "$ref": "#/$defs/skew_state" },
        "mirror_offline_posture": { "$ref": "#/$defs/mirror_offline_posture" },
        "badge_class": { "$ref": "#/$defs/badge_class" },
        "source_language_action_id": { "$ref": "#/$defs/stable_id" },
        "source_language_action_label": {
          "type": "string",
          "const": "Open in source language"
        },
        "citation_anchor_refs": { "$ref": "#/$defs/non_empty_strings" },
        "command_id_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^cmd:[A-Za-z0-9_.:-]+$"
          },
          "uniqueItems": true
        },
        "keyboard_path_refs": { "$ref": "#/$defs/non_empty_strings" },
        "scope_label_refs": { "$ref": "#/$defs/non_empty_strings" },
        "exact_reopen_ref": { "$ref": "#/$defs/stable_id" },
        "raw_translated_body_exported": { "type": "boolean", "const": false }
      }
    },
    "locale_overlay_support_export_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "support_export_id",
        "generated_at",
        "source_contract_id",
        "contract_version_ref",
        "rows",
        "omitted_material_classes",
        "raw_translated_bodies_exported"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "locale_overlay_support_export_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "support_export_id": { "$ref": "#/$defs/stable_id" },
        "generated_at": { "$ref": "#/$defs/timestamp" },
        "source_contract_id": { "$ref": "#/$defs/stable_id" },
        "contract_version_ref": { "$ref": "#/$defs/stable_id" },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/locale_overlay_support_row" }
        },
        "omitted_material_classes": { "$ref": "#/$defs/non_empty_strings" },
        "raw_translated_bodies_exported": { "type": "boolean", "const": false }
      }
    }
  }
}
