{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/docs_suggestion.schema.json",
  "title": "Aureline docs suggestion and validation-budget contract",
  "description": "Boundary schema for docs_suggestion_record, the review-safe object used by docs-maintenance surfaces before proposing README, changelog, help, stale-example, symbol-linked docs, migration-note, support-window, screenshot, or benchmark-copy changes. Suggestions must carry cited source refs, validation-budget state, freshness/version posture, draft-vs-apply posture, and no-marketing-lift gates. Draft generated prose is not authority.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/docs_suggestion_record" }
  ],
  "$defs": {
    "docs_suggestion_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for docs suggestion records. Bumped only for breaking payload changes."
    },
    "record_kind": {
      "type": "string",
      "const": "docs_suggestion_record"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_non_empty_string": {
      "oneOf": [
        { "$ref": "#/$defs/non_empty_string" },
        { "type": "null" }
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "bcp47_locale_tag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Stable opaque reference. Raw URLs and raw document bodies must not appear here."
    },
    "docs_suggestion_id": {
      "type": "string",
      "pattern": "^docs-suggestion:[a-z0-9]+(?:[._:-][a-z0-9]+)*$"
    },
    "validation_budget_ref": {
      "type": "string",
      "pattern": "^validation-budget:[a-z0-9]+(?:[._:-][a-z0-9]+)*$"
    },
    "suggestion_class": {
      "type": "string",
      "enum": [
        "readme_update",
        "changelog_update",
        "help_update",
        "stale_example_finding",
        "symbol_linked_doc_suggestion",
        "migration_note_prompt",
        "support_window_alignment",
        "benchmark_copy_review",
        "screenshot_refresh"
      ]
    },
    "trigger_class": {
      "type": "string",
      "enum": [
        "broken_link",
        "renamed_command",
        "renamed_setting",
        "renamed_symbol",
        "stale_screenshot",
        "missing_migration_note",
        "support_window_mismatch",
        "benchmark_reference_unverifiable",
        "api_contract_changed",
        "command_output_drift",
        "docs_pack_freshness_expired",
        "version_mismatch",
        "claim_row_changed",
        "failing_snippet",
        "stale_example"
      ]
    },
    "finding_class": {
      "type": "string",
      "enum": [
        "broken_link",
        "renamed_command",
        "renamed_setting",
        "renamed_symbol",
        "stale_screenshot",
        "missing_migration_note",
        "support_window_mismatch",
        "api_mismatch",
        "command_output_drift",
        "import_path_drift",
        "version_mismatch",
        "unverifiable_benchmark_copy",
        "unchanged_unverified",
        "none"
      ]
    },
    "artifact_kind": {
      "type": "string",
      "enum": [
        "readme",
        "changelog",
        "help_article",
        "onboarding_note",
        "module_doc",
        "migration_notes",
        "release_notes",
        "docs_pack",
        "support_runbook",
        "benchmark_copy",
        "screenshot",
        "symbol_reference"
      ]
    },
    "audience_scope": {
      "type": "string",
      "enum": [
        "developer",
        "maintainer",
        "end_user",
        "release_manager",
        "support_operator",
        "enterprise_admin",
        "public_reader"
      ]
    },
    "validation_mode": {
      "type": "string",
      "enum": [
        "rendered",
        "syntax_checked",
        "executed_locally",
        "executed_remotely",
        "unsupported_in_environment",
        "not_validated"
      ]
    },
    "freshness_state": {
      "type": "string",
      "enum": [
        "current",
        "within_validation_budget",
        "revalidation_required",
        "stale",
        "unverified",
        "unsupported"
      ]
    },
    "version_match_state": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build",
        "not_applicable"
      ]
    },
    "stale_detection_state": {
      "type": "string",
      "enum": [
        "proven_broken",
        "suspected_stale",
        "unchanged_unverified",
        "not_applicable"
      ],
      "description": "Closed stale-detection posture. proven_broken means a resolver or validator observed a concrete failure; suspected_stale means drift signals exist but failure has not been reproduced; unchanged_unverified means required validation is missing or expired even though content may be unchanged."
    },
    "apply_posture": {
      "type": "string",
      "enum": [
        "draft_only",
        "review_diff_only",
        "apply_after_validation",
        "apply_after_owner_review",
        "publish_handoff_only",
        "blocked_pending_evidence"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "project_docs",
        "generated_reference",
        "mirrored_official_docs",
        "curated_knowledge_pack",
        "derived_explanation",
        "vendor_provider_docs",
        "support_runbook",
        "external_status_feed",
        "claim_manifest",
        "compatibility_row",
        "benchmark_publication_pack",
        "validation_output",
        "destination_descriptor",
        "command_descriptor",
        "settings_registry",
        "migration_packet"
      ]
    },
    "evidence_kind": {
      "type": "string",
      "enum": [
        "citation_anchor_ref",
        "symbol_linked_reference_ref",
        "claim_row_ref",
        "compatibility_row_ref",
        "reviewed_pack_ref",
        "benchmark_publication_pack_ref",
        "validation_output_ref",
        "source_revision_ref",
        "destination_descriptor_ref",
        "command_descriptor_ref",
        "generated_reference_ref",
        "settings_registry_ref",
        "migration_packet_ref",
        "docs_pack_manifest_ref",
        "screenshot_anchor_ref",
        "snippet_validation_ref",
        "toolchain_identity_ref",
        "render_capture_ref",
        "exact_build_identity_ref",
        "diff_ref"
      ]
    },
    "review_role": {
      "type": "string",
      "enum": [
        "docs_public_truth_owner",
        "release_owner",
        "support_owner",
        "security_trust_owner",
        "legal_policy_owner",
        "compatibility_owner",
        "recovery_owner",
        "domain_owner",
        "benchmark_owner"
      ]
    },
    "claim_change_posture": {
      "type": "string",
      "enum": [
        "no_claim_change",
        "claim_narrowing_only",
        "claim_widening_blocked",
        "support_level_change_blocked",
        "benchmark_claim_blocked",
        "known_limit_change_blocked"
      ]
    },
    "generated_text_posture": {
      "type": "string",
      "enum": [
        "no_generated_text",
        "draft_text_with_citations",
        "migration_prompt_only",
        "evidence_summary_only",
        "diff_only"
      ]
    },
    "blocked_reason_class": {
      "type": "string",
      "enum": [
        "none",
        "missing_citation",
        "stale_validation_budget",
        "unsupported_validation_environment",
        "unverified_benchmark_evidence",
        "claim_widening_without_owner_review",
        "support_window_evidence_missing",
        "migration_note_missing_source",
        "symbol_reference_unresolved",
        "screenshot_anchor_unverified"
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_kind",
        "path_or_artifact_ref",
        "section_ref",
        "audience_scope",
        "branch_scope",
        "release_scope",
        "channel_scope",
        "locale"
      ],
      "properties": {
        "artifact_kind": { "$ref": "#/$defs/artifact_kind" },
        "path_or_artifact_ref": { "$ref": "#/$defs/opaque_ref" },
        "section_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
        "audience_scope": { "$ref": "#/$defs/audience_scope" },
        "branch_scope": { "$ref": "#/$defs/nullable_non_empty_string" },
        "release_scope": { "$ref": "#/$defs/nullable_non_empty_string" },
        "channel_scope": { "$ref": "#/$defs/nullable_non_empty_string" },
        "locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "support_window_ref": { "$ref": "#/$defs/nullable_non_empty_string" }
      }
    },
    "cited_source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref",
        "source_class",
        "evidence_kind",
        "freshness_state",
        "version_match_state"
      ],
      "properties": {
        "ref": { "$ref": "#/$defs/opaque_ref" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "evidence_kind": { "$ref": "#/$defs/evidence_kind" },
        "citation_anchor_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
        "symbol_linked_reference_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
        "freshness_state": { "$ref": "#/$defs/freshness_state" },
        "version_match_state": { "$ref": "#/$defs/version_match_state" },
        "captured_at": {
          "oneOf": [
            { "$ref": "#/$defs/timestamp" },
            { "type": "null" }
          ]
        }
      }
    },
    "validation_budget_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budget_row_ref",
        "freshness_state",
        "required_validation_modes",
        "satisfied_validation_modes",
        "last_validated_at",
        "validation_due_at",
        "revalidation_required",
        "revalidation_reason_refs"
      ],
      "properties": {
        "budget_row_ref": { "$ref": "#/$defs/validation_budget_ref" },
        "freshness_state": { "$ref": "#/$defs/freshness_state" },
        "required_validation_modes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/validation_mode" }
        },
        "satisfied_validation_modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/validation_mode" }
        },
        "last_validated_at": {
          "oneOf": [
            { "$ref": "#/$defs/timestamp" },
            { "type": "null" }
          ]
        },
        "validation_due_at": {
          "oneOf": [
            { "$ref": "#/$defs/timestamp" },
            { "type": "null" }
          ]
        },
        "revalidation_required": { "type": "boolean" },
        "revalidation_reason_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "unsupported_reason": { "$ref": "#/$defs/nullable_non_empty_string" }
      }
    },
    "proposed_change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "diff_ref",
        "generated_text_posture",
        "claim_change_posture",
        "blocked_reason_classes"
      ],
      "properties": {
        "summary": { "$ref": "#/$defs/non_empty_string" },
        "diff_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
        "generated_text_posture": { "$ref": "#/$defs/generated_text_posture" },
        "claim_change_posture": { "$ref": "#/$defs/claim_change_posture" },
        "blocked_reason_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/blocked_reason_class" }
        }
      }
    },
    "owner_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "required_review_roles",
        "review_reason_refs"
      ],
      "properties": {
        "required": { "type": "boolean" },
        "required_review_roles": {
          "type": "array",
          "items": { "$ref": "#/$defs/review_role" }
        },
        "review_reason_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        }
      }
    },
    "no_marketing_lift_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "creates_new_product_claim",
        "widens_support_level",
        "adds_or_widens_benchmark_claim",
        "removes_known_limit",
        "owner_review_required_for_claim_change"
      ],
      "properties": {
        "creates_new_product_claim": { "const": false },
        "widens_support_level": { "const": false },
        "adds_or_widens_benchmark_claim": { "const": false },
        "removes_known_limit": { "const": false },
        "owner_review_required_for_claim_change": { "type": "boolean" }
      },
      "description": "All claim-widening booleans are const false because a docs suggestion may not itself create new product, support, or benchmark authority. Blocked review records express attempted widening through proposed_change.claim_change_posture."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Fixture-only metadata. Publishers strip this field before emitting production records."
    },
    "docs_suggestion_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "docs_suggestion_schema_version",
        "suggestion_id",
        "suggestion_class",
        "trigger_class",
        "finding_class",
        "target",
        "cited_source_refs",
        "validation_budget_state",
        "freshness_state",
        "version_match_state",
        "stale_detection_state",
        "apply_posture",
        "proposed_change",
        "owner_review",
        "no_marketing_lift_gate",
        "created_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "docs_suggestion_schema_version": {
          "$ref": "#/$defs/docs_suggestion_schema_version"
        },
        "suggestion_id": { "$ref": "#/$defs/docs_suggestion_id" },
        "suggestion_class": { "$ref": "#/$defs/suggestion_class" },
        "trigger_class": { "$ref": "#/$defs/trigger_class" },
        "finding_class": { "$ref": "#/$defs/finding_class" },
        "target": { "$ref": "#/$defs/target" },
        "cited_source_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/cited_source_ref" }
        },
        "validation_budget_state": { "$ref": "#/$defs/validation_budget_state" },
        "freshness_state": { "$ref": "#/$defs/freshness_state" },
        "version_match_state": { "$ref": "#/$defs/version_match_state" },
        "stale_detection_state": { "$ref": "#/$defs/stale_detection_state" },
        "apply_posture": { "$ref": "#/$defs/apply_posture" },
        "proposed_change": { "$ref": "#/$defs/proposed_change" },
        "owner_review": { "$ref": "#/$defs/owner_review" },
        "no_marketing_lift_gate": { "$ref": "#/$defs/no_marketing_lift_gate" },
        "suppression_or_deferral_ref": { "$ref": "#/$defs/nullable_non_empty_string" },
        "created_at": { "$ref": "#/$defs/timestamp" }
      },
      "allOf": [
        {
          "description": "Benchmark-copy review suggestions cannot be apply-ready without owner review.",
          "if": {
            "properties": {
              "suggestion_class": { "const": "benchmark_copy_review" }
            },
            "required": ["suggestion_class"]
          },
          "then": {
            "properties": {
              "apply_posture": {
                "enum": [
                  "draft_only",
                  "review_diff_only",
                  "apply_after_owner_review",
                  "blocked_pending_evidence"
                ]
              },
              "owner_review": {
                "type": "object",
                "properties": {
                  "required": { "const": true }
                },
                "required": ["required"]
              }
            }
          }
        },
        {
          "description": "Unchanged-but-unverified findings cannot be presented as apply-ready.",
          "if": {
            "properties": {
              "stale_detection_state": { "const": "unchanged_unverified" }
            },
            "required": ["stale_detection_state"]
          },
          "then": {
            "properties": {
              "apply_posture": {
                "enum": [
                  "draft_only",
                  "review_diff_only",
                  "publish_handoff_only",
                  "blocked_pending_evidence"
                ]
              }
            }
          }
        },
        {
          "description": "Proven broken findings must not cite not_validated as their only satisfied mode.",
          "if": {
            "properties": {
              "stale_detection_state": { "const": "proven_broken" }
            },
            "required": ["stale_detection_state"]
          },
          "then": {
            "properties": {
              "validation_budget_state": {
                "type": "object",
                "properties": {
                  "satisfied_validation_modes": {
                    "not": {
                      "type": "array",
                      "maxItems": 1,
                      "items": { "const": "not_validated" }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
