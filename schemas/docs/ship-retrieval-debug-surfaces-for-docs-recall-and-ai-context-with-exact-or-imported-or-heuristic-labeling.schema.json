{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/ship-retrieval-debug-surfaces-for-docs-recall-and-ai-context-with-exact-or-imported-or-heuristic-labeling.schema.json",
  "title": "Aureline retrieval-debug surfaces for docs, recall, and AI context with exact / imported / heuristic labeling",
  "description": "Export-safe packet for the M5 retrieval-debug inspector. The packet carries one or more entries across three retrieval lanes (docs search, semantic recall, AI context), each with a five-chip set (source class, version match, freshness, locality, confidence), one exact/imported/heuristic derivation label, an explicit derivation reason, a non-empty list of ranking-signal reasons, citation state, and open-raw/open-source escapes. An export preserves lane, derivation label, source class, confidence, ranking reasons, and escapes per entry. Packet-level degradations narrow or block the claim. The promotion state (stable / narrowed_below_stable / blocks_stable) is computed from validation and degradation findings. Raw query text, raw document bodies, raw source files, raw provider payloads, and credentials never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "query_label",
    "query_digest_ref",
    "entries",
    "export",
    "retrieval_degradations",
    "consumer_projections",
    "promotion_state",
    "validation_findings",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "retrieval_debug_surfaces_for_docs_recall_and_ai_context"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "query_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "query_digest_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "export": {
      "$ref": "#/$defs/export"
    },
    "retrieval_degradations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/retrieval_degradation"
      }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/consumer_projection"
      }
    },
    "promotion_state": {
      "$ref": "#/$defs/promotion_state"
    },
    "validation_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation_finding"
      }
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "lane": {
      "type": "string",
      "enum": [
        "docs_search",
        "semantic_recall",
        "ai_context"
      ]
    },
    "derivation_label": {
      "type": "string",
      "enum": [
        "exact",
        "imported",
        "heuristic"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "workspace_code",
        "dependency_source",
        "graph_index",
        "project_docs",
        "generated_reference",
        "mirrored_official_docs",
        "imported_pack",
        "ai_assembled_context"
      ]
    },
    "version_match": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified",
        "refresh_pending"
      ]
    },
    "locality": {
      "type": "string",
      "enum": [
        "local",
        "mirrored_pack",
        "remote_helper",
        "managed"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "heuristic"
      ]
    },
    "subject_kind": {
      "type": "string",
      "enum": [
        "docs_node",
        "code_symbol",
        "code_file",
        "code_module",
        "pack_node",
        "context_fragment"
      ]
    },
    "ranking_signal_kind": {
      "type": "string",
      "enum": [
        "lexical_match",
        "semantic_similarity",
        "symbol_exact_match",
        "path_proximity",
        "recency_boost",
        "pinned_source_boost",
        "freshness_penalty",
        "imported_source_penalty",
        "heuristic_penalty"
      ]
    },
    "signal_contribution": {
      "type": "string",
      "enum": [
        "boost",
        "penalty",
        "neutral"
      ]
    },
    "infrastructure_truth_layer": {
      "type": "string",
      "enum": [
        "authored_desired",
        "rendered_expanded",
        "planned_validated",
        "observed_live",
        "provider_overlay"
      ]
    },
    "finding_severity": {
      "type": "string",
      "enum": [
        "blocking",
        "narrowing",
        "advisory"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "retrieval_debug_inspector",
        "docs_browser",
        "semantic_recall_panel",
        "ai_context_panel",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "retrieval_degradation_class": {
      "type": "string",
      "enum": [
        "embedder_unavailable_lexical_fallback",
        "mirror_offline_snapshot",
        "index_stale",
        "imported_pack_unverified",
        "partial_index",
        "quarantined_pack",
        "broken_anchor"
      ]
    },
    "export_scope": {
      "type": "string",
      "enum": [
        "all_entries",
        "docs_search_only",
        "semantic_recall_only",
        "ai_context_only"
      ]
    },
    "promotion_state": {
      "type": "string",
      "enum": [
        "stable",
        "narrowed_below_stable",
        "blocks_stable"
      ]
    },
    "validation_finding_kind": {
      "type": "string",
      "enum": [
        "missing_identity",
        "entries_empty",
        "duplicate_entry_id",
        "required_lane_missing",
        "entry_title_or_headline_missing",
        "derivation_reason_missing",
        "ranking_signals_missing",
        "ranking_signal_note_missing",
        "entry_not_cited",
        "open_raw_open_source_escape_missing",
        "heuristic_label_looks_authoritative",
        "version_truth_collapsed",
        "infrastructure_lineage_invalid",
        "export_row_orphan",
        "export_coverage_missing",
        "export_drops_preservation",
        "export_lane_mismatch",
        "export_derivation_label_mismatch",
        "export_source_class_mismatch",
        "export_confidence_mismatch",
        "export_infrastructure_lineage_mismatch",
        "degradation_incomplete",
        "degradation_orphan",
        "consumer_projection_drift",
        "consumer_projection_packet_id_mismatch",
        "required_surface_coverage_missing",
        "raw_boundary_material_present"
      ]
    },
    "chip_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "version_match",
        "freshness",
        "locality",
        "confidence"
      ],
      "properties": {
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "version_match": {
          "$ref": "#/$defs/version_match"
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        },
        "locality": {
          "$ref": "#/$defs/locality"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "ranking_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_kind",
        "contribution",
        "weight_label",
        "note"
      ],
      "properties": {
        "signal_kind": {
          "$ref": "#/$defs/ranking_signal_kind"
        },
        "contribution": {
          "$ref": "#/$defs/signal_contribution"
        },
        "weight_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "note": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "infrastructure_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lineage_ref",
        "subject_ref",
        "truth_layers_used",
        "relationship_refs",
        "support_summary"
      ],
      "properties": {
        "lineage_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "subject_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "context_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "truth_layers_used": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/infrastructure_truth_layer"
          }
        },
        "unavailable_truth_layers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/infrastructure_truth_layer"
          }
        },
        "relationship_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "visible_limit_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "support_summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "lane",
        "subject_kind",
        "subject_ref",
        "title",
        "headline",
        "chips",
        "derivation_label",
        "derivation_reason",
        "ranking_signals",
        "cited",
        "open_raw_escape_ref",
        "open_source_escape_ref"
      ],
      "properties": {
        "entry_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "lane": {
          "$ref": "#/$defs/lane"
        },
        "subject_kind": {
          "$ref": "#/$defs/subject_kind"
        },
        "subject_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "headline": {
          "$ref": "#/$defs/non_empty_string"
        },
        "chips": {
          "$ref": "#/$defs/chip_set"
        },
        "derivation_label": {
          "$ref": "#/$defs/derivation_label"
        },
        "derivation_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "ranking_signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ranking_signal"
          }
        },
        "cited": {
          "type": "boolean"
        },
        "citation_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_raw_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_source_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "infrastructure_lineage": {
          "$ref": "#/$defs/infrastructure_lineage"
        }
      }
    },
    "export_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id_ref",
        "lane",
        "derivation_label",
        "source_class",
        "confidence",
        "cited",
        "ranking_signal_count",
        "open_raw_escape_ref",
        "open_source_escape_ref"
      ],
      "properties": {
        "entry_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "lane": {
          "$ref": "#/$defs/lane"
        },
        "derivation_label": {
          "$ref": "#/$defs/derivation_label"
        },
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "cited": {
          "type": "boolean"
        },
        "ranking_signal_count": {
          "type": "integer",
          "minimum": 0
        },
        "open_raw_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_source_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "infrastructure_lineage_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "infrastructure_truth_layers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/infrastructure_truth_layer"
          }
        },
        "infrastructure_unavailable_truth_layers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/infrastructure_truth_layer"
          }
        },
        "infrastructure_limit_summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "preserves_lane",
        "preserves_derivation_label",
        "preserves_source_class",
        "preserves_confidence",
        "preserves_ranking_reasons",
        "preserves_open_raw_open_source_escape",
        "preserves_infrastructure_lineage",
        "rows"
      ],
      "properties": {
        "scope": {
          "$ref": "#/$defs/export_scope"
        },
        "preserves_lane": {
          "type": "boolean"
        },
        "preserves_derivation_label": {
          "type": "boolean"
        },
        "preserves_source_class": {
          "type": "boolean"
        },
        "preserves_confidence": {
          "type": "boolean"
        },
        "preserves_ranking_reasons": {
          "type": "boolean"
        },
        "preserves_open_raw_open_source_escape": {
          "type": "boolean"
        },
        "preserves_infrastructure_lineage": {
          "type": "boolean"
        },
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/export_row"
          }
        }
      }
    },
    "retrieval_degradation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "degradation_class",
        "severity",
        "summary"
      ],
      "properties": {
        "degradation_class": {
          "$ref": "#/$defs/retrieval_degradation_class"
        },
        "severity": {
          "$ref": "#/$defs/finding_severity"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "entry_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "packet_id_ref",
        "preserves_chips",
        "preserves_lanes",
        "preserves_derivation_labels",
        "preserves_ranking_reasons",
        "preserves_open_raw_open_source_escape",
        "preserves_infrastructure_lineage"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/consumer_surface"
        },
        "packet_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preserves_chips": {
          "type": "boolean"
        },
        "preserves_lanes": {
          "type": "boolean"
        },
        "preserves_derivation_labels": {
          "type": "boolean"
        },
        "preserves_ranking_reasons": {
          "type": "boolean"
        },
        "preserves_open_raw_open_source_escape": {
          "type": "boolean"
        },
        "preserves_infrastructure_lineage": {
          "type": "boolean"
        }
      }
    },
    "validation_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_kind",
        "severity",
        "summary"
      ],
      "properties": {
        "finding_kind": {
          "$ref": "#/$defs/validation_finding_kind"
        },
        "severity": {
          "$ref": "#/$defs/finding_severity"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
