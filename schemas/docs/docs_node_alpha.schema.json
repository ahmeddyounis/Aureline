{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/docs_node_alpha.schema.json",
  "title": "Docs Node Alpha Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "docs_node_id",
    "doc_kind",
    "source_class",
    "scope_class",
    "source_pack_ref",
    "source_pack_revision_ref",
    "version_or_revision_ref",
    "version_match_state",
    "freshness_class",
    "locality_class",
    "source_locale",
    "requested_locale",
    "effective_locale",
    "locale_overlay_state",
    "citation_availability",
    "citation_anchor_refs",
    "exact_reopen_ref"
  ],
  "properties": {
    "record_kind": {
      "const": "docs_node_alpha_record"
    },
    "schema_version": {
      "const": 1
    },
    "docs_node_id": {
      "type": "string",
      "minLength": 1
    },
    "doc_kind": {
      "$ref": "#/$defs/docs_node_kind"
    },
    "source_class": {
      "$ref": "#/$defs/citation_source_class"
    },
    "scope_class": {
      "$ref": "#/$defs/docs_scope_class"
    },
    "source_pack_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_pack_revision_ref": {
      "type": "string",
      "minLength": 1
    },
    "version_or_revision_ref": {
      "type": "string",
      "minLength": 1
    },
    "version_match_state": {
      "$ref": "#/$defs/version_match_state"
    },
    "freshness_class": {
      "$ref": "#/$defs/freshness_class"
    },
    "locality_class": {
      "$ref": "#/$defs/locality_class"
    },
    "source_locale": {
      "type": "string",
      "minLength": 2
    },
    "requested_locale": {
      "type": "string",
      "minLength": 2
    },
    "effective_locale": {
      "type": "string",
      "minLength": 2
    },
    "locale_overlay_state": {
      "$ref": "#/$defs/locale_overlay_state"
    },
    "source_language_fallback_ref": {
      "type": "string",
      "minLength": 1
    },
    "citation_availability": {
      "$ref": "#/$defs/citation_anchor_availability"
    },
    "citation_anchor_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "exact_reopen_ref": {
      "type": "string",
      "minLength": 1
    },
    "hidden_or_omitted_note": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "docs_node_kind": {
      "enum": [
        "product_help",
        "reference_page",
        "glossary_item",
        "onboarding_card",
        "guided_tour_step",
        "derived_explainer",
        "ai_evidence_source",
        "support_runbook"
      ]
    },
    "citation_source_class": {
      "enum": [
        "project_docs",
        "generated_reference",
        "mirrored_official_docs",
        "curated_knowledge_pack",
        "vendor_provider_docs",
        "support_runbook",
        "derived_explanation"
      ]
    },
    "docs_scope_class": {
      "enum": [
        "workspace",
        "docs_help",
        "onboarding",
        "help_pack",
        "explainer",
        "ai_evidence",
        "support_export"
      ]
    },
    "version_match_state": {
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ]
    },
    "freshness_class": {
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },
    "locality_class": {
      "enum": [
        "local_project_pack",
        "generated_local",
        "mirrored_offline",
        "cached_local",
        "vendor_live",
        "not_installed",
        "support_pack"
      ]
    },
    "locale_overlay_state": {
      "enum": [
        "source_language_original",
        "requested_locale_available",
        "locale_overlay_partial",
        "locale_overlay_stale",
        "locale_missing_fallback_to_source_language",
        "locale_missing_not_installed",
        "untranslated_source_language_only"
      ]
    },
    "citation_anchor_availability": {
      "enum": [
        "exact_anchor_available",
        "anchor_unavailable_disclosed",
        "hidden_by_policy",
        "omitted_by_policy",
        "not_citation_bearing"
      ]
    }
  }
}
