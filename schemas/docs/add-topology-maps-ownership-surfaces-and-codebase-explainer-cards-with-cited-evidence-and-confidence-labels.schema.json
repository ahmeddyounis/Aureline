{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/add-topology-maps-ownership-surfaces-and-codebase-explainer-cards-with-cited-evidence-and-confidence-labels.schema.json",
  "title": "Aureline topology, ownership, and codebase-explainer cards with cited evidence and confidence labels",
  "description": "Export-safe packet for codebase-understanding cards. The packet carries one or more cards of three kinds (topology map, ownership surface, codebase explainer), each with a five-chip set (source class, version match, freshness, locality, confidence), an explicit confidence reason, a non-empty list of cited evidence items, inline provenance, and open-raw/open-source escapes. Topology cards carry topology edges; ownership cards carry attributed owners with a basis. An evidence export preserves card kind, source class, confidence, derivation, citation state, and escapes per card. Packet-level degradations narrow or block the claim. The promotion state (stable / narrowed_below_stable / blocks_stable) is computed from validation and degradation findings. Raw source files, raw document bodies, raw provider payloads, and credentials never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "region_label",
    "region_digest_ref",
    "cards",
    "evidence_export",
    "understanding_degradations",
    "consumer_projections",
    "promotion_state",
    "validation_findings",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "topology_ownership_and_codebase_explainer_cards"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "region_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "region_digest_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/card"
      }
    },
    "evidence_export": {
      "$ref": "#/$defs/evidence_export"
    },
    "understanding_degradations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/understanding_degradation"
      }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/consumer_projection"
      }
    },
    "promotion_state": {
      "$ref": "#/$defs/promotion_state"
    },
    "validation_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation_finding"
      }
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "card_kind": {
      "type": "string",
      "enum": [
        "topology_map",
        "ownership_surface",
        "codebase_explainer"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "workspace_code",
        "dependency_source",
        "graph_index",
        "codeowners_file",
        "ownership_registry",
        "project_docs",
        "generated_reference",
        "mirrored_official_docs"
      ]
    },
    "version_match": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified",
        "refresh_pending"
      ]
    },
    "locality": {
      "type": "string",
      "enum": [
        "local",
        "mirrored_pack",
        "remote_helper",
        "managed"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "heuristic"
      ]
    },
    "derivation_class": {
      "type": "string",
      "enum": [
        "verbatim_node",
        "extracted_snippet",
        "derived_summary",
        "inferred_explanation"
      ]
    },
    "evidence_subject_kind": {
      "type": "string",
      "enum": [
        "code_symbol",
        "code_file",
        "code_module",
        "crate_node",
        "dependency_edge",
        "owner_entry",
        "docs_node"
      ]
    },
    "topology_edge_kind": {
      "type": "string",
      "enum": [
        "depends_on",
        "contains",
        "implements",
        "calls",
        "references"
      ]
    },
    "ownership_basis": {
      "type": "string",
      "enum": [
        "codeowners_entry",
        "declared_registry",
        "directory_convention",
        "git_history_heuristic",
        "unassigned"
      ]
    },
    "finding_severity": {
      "type": "string",
      "enum": [
        "blocking",
        "narrowing",
        "advisory"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "codebase_explorer",
        "docs_browser",
        "graph_panel",
        "ai_context",
        "retrieval_inspector",
        "cli_headless",
        "support_export",
        "help_about"
      ]
    },
    "understanding_degradation_class": {
      "type": "string",
      "enum": [
        "graph_index_stale",
        "ownership_unresolved",
        "mirror_offline_snapshot",
        "partial_topology",
        "embedder_unavailable_lexical_fallback",
        "quarantined_pack",
        "broken_anchor"
      ]
    },
    "evidence_export_scope": {
      "type": "string",
      "enum": [
        "all_cards",
        "topology_only",
        "ownership_only",
        "explainer_only"
      ]
    },
    "promotion_state": {
      "type": "string",
      "enum": [
        "stable",
        "narrowed_below_stable",
        "blocks_stable"
      ]
    },
    "validation_finding_kind": {
      "type": "string",
      "enum": [
        "missing_identity",
        "cards_empty",
        "duplicate_card_id",
        "required_card_kind_missing",
        "card_title_or_headline_missing",
        "confidence_reason_missing",
        "card_evidence_missing",
        "duplicate_evidence_id",
        "card_not_cited",
        "evidence_not_cited",
        "open_raw_open_source_escape_missing",
        "evidence_escape_missing",
        "inferred_card_looks_authoritative",
        "version_truth_collapsed",
        "topology_card_missing_edges",
        "topology_edge_endpoint_missing",
        "ownership_card_missing_owner",
        "ownership_basis_unattributed",
        "evidence_export_row_orphan",
        "evidence_export_coverage_missing",
        "evidence_export_drops_preservation",
        "evidence_export_card_kind_mismatch",
        "evidence_export_source_class_mismatch",
        "evidence_export_confidence_mismatch",
        "degradation_incomplete",
        "degradation_orphan",
        "consumer_projection_drift",
        "consumer_projection_packet_id_mismatch",
        "required_surface_coverage_missing",
        "raw_boundary_material_present"
      ]
    },
    "chip_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "version_match",
        "freshness",
        "locality",
        "confidence"
      ],
      "properties": {
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "version_match": {
          "$ref": "#/$defs/version_match"
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        },
        "locality": {
          "$ref": "#/$defs/locality"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "card_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "subject_kind",
        "subject_ref",
        "derivation",
        "cited",
        "open_raw_escape_ref",
        "open_source_escape_ref",
        "note"
      ],
      "properties": {
        "evidence_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "subject_kind": {
          "$ref": "#/$defs/evidence_subject_kind"
        },
        "subject_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "derivation": {
          "$ref": "#/$defs/derivation_class"
        },
        "cited": {
          "type": "boolean"
        },
        "citation_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_raw_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_source_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "note": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "topology_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_ref",
        "to_ref",
        "edge_kind",
        "note"
      ],
      "properties": {
        "from_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "to_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "edge_kind": {
          "$ref": "#/$defs/topology_edge_kind"
        },
        "note": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "owner_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_ref",
        "ownership_basis",
        "coverage_note"
      ],
      "properties": {
        "owner_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "ownership_basis": {
          "$ref": "#/$defs/ownership_basis"
        },
        "coverage_note": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "card_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pack_id_ref",
        "pack_pinned",
        "pack_signed_and_verified",
        "derivation",
        "cited"
      ],
      "properties": {
        "pack_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pack_pinned": {
          "type": "boolean"
        },
        "pack_signed_and_verified": {
          "type": "boolean"
        },
        "derivation": {
          "$ref": "#/$defs/derivation_class"
        },
        "cited": {
          "type": "boolean"
        },
        "citation_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id",
        "card_kind",
        "subject_ref",
        "title",
        "headline",
        "chips",
        "confidence_reason",
        "evidence",
        "provenance",
        "open_raw_escape_ref",
        "open_source_escape_ref"
      ],
      "properties": {
        "card_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "card_kind": {
          "$ref": "#/$defs/card_kind"
        },
        "subject_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "headline": {
          "$ref": "#/$defs/non_empty_string"
        },
        "chips": {
          "$ref": "#/$defs/chip_set"
        },
        "confidence_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/card_evidence"
          }
        },
        "topology_edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/topology_edge"
          }
        },
        "owners": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/owner_ref"
          }
        },
        "provenance": {
          "$ref": "#/$defs/card_provenance"
        },
        "open_raw_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_source_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "evidence_export_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id_ref",
        "card_kind",
        "source_class",
        "confidence",
        "derivation",
        "cited",
        "evidence_count",
        "open_raw_escape_ref",
        "open_source_escape_ref"
      ],
      "properties": {
        "card_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "card_kind": {
          "$ref": "#/$defs/card_kind"
        },
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "derivation": {
          "$ref": "#/$defs/derivation_class"
        },
        "cited": {
          "type": "boolean"
        },
        "evidence_count": {
          "type": "integer",
          "minimum": 0
        },
        "open_raw_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_source_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "evidence_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "preserves_card_kind",
        "preserves_source_class",
        "preserves_confidence",
        "preserves_open_raw_open_source_escape",
        "preserves_inference_labels",
        "rows"
      ],
      "properties": {
        "scope": {
          "$ref": "#/$defs/evidence_export_scope"
        },
        "preserves_card_kind": {
          "type": "boolean"
        },
        "preserves_source_class": {
          "type": "boolean"
        },
        "preserves_confidence": {
          "type": "boolean"
        },
        "preserves_open_raw_open_source_escape": {
          "type": "boolean"
        },
        "preserves_inference_labels": {
          "type": "boolean"
        },
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_export_row"
          }
        }
      }
    },
    "understanding_degradation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "degradation_class",
        "severity",
        "summary"
      ],
      "properties": {
        "degradation_class": {
          "$ref": "#/$defs/understanding_degradation_class"
        },
        "severity": {
          "$ref": "#/$defs/finding_severity"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "card_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "packet_id_ref",
        "preserves_chips",
        "preserves_cards",
        "preserves_confidence_labels",
        "preserves_evidence_export",
        "preserves_open_raw_open_source_escape"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/consumer_surface"
        },
        "packet_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preserves_chips": {
          "type": "boolean"
        },
        "preserves_cards": {
          "type": "boolean"
        },
        "preserves_confidence_labels": {
          "type": "boolean"
        },
        "preserves_evidence_export": {
          "type": "boolean"
        },
        "preserves_open_raw_open_source_escape": {
          "type": "boolean"
        }
      }
    },
    "validation_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_kind",
        "severity",
        "summary"
      ],
      "properties": {
        "finding_kind": {
          "$ref": "#/$defs/validation_finding_kind"
        },
        "severity": {
          "$ref": "#/$defs/finding_severity"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
