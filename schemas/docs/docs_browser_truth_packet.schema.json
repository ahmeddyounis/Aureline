{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/docs_browser_truth_packet.schema.json",
  "title": "DocsBrowserTruthPacket",
  "description": "Stable docs-browser truth packet certifying docs-source descriptors, docs-result objects, machine-readable source-class / version-match / freshness enums, and symbol-linked docs flows.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "captured_vs_live",
    "sources",
    "results",
    "promotion_state"
  ],
  "additionalProperties": false,
  "properties": {
    "record_kind": { "const": "docs_browser_truth_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "workflow_or_surface_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "captured_vs_live": {
      "type": "string",
      "enum": ["live", "captured_snapshot", "narrowed_scope_rerun"]
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_descriptor" }
    },
    "results": {
      "type": "array",
      "items": { "$ref": "#/$defs/result_object" }
    },
    "symbol_flows": {
      "type": "array",
      "items": { "$ref": "#/$defs/symbol_flow" }
    },
    "consumer_projections": {
      "type": "array",
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "promotion_state": {
      "type": "string",
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "$defs": {
    "source_class": {
      "type": "string",
      "enum": [
        "project_docs",
        "mirrored_official_docs",
        "extension_docs_pack",
        "live_external_docs",
        "curated_knowledge_pack",
        "generated_reference",
        "derived_explanation"
      ]
    },
    "trust_class": {
      "type": "string",
      "enum": [
        "first_party_authoritative",
        "signed_mirror_verified",
        "extension_pack_signed",
        "live_provider_handoff",
        "derived_inference_only"
      ]
    },
    "browser_handoff_capability": {
      "type": "string",
      "enum": [
        "not_required_local",
        "available_explicit",
        "blocked_by_policy",
        "unavailable_disclosed"
      ]
    },
    "version_match_state": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ]
    },
    "freshness_state": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },
    "symbol_link_class": {
      "type": "string",
      "enum": [
        "symbol_anchor_available",
        "symbol_anchor_partial",
        "symbol_anchor_missing_disclosed",
        "not_symbol_linked"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "docs_browser_shell",
        "peek_overlay",
        "split_pane",
        "browser_handoff_packet",
        "ai_context_inspector",
        "extension_api",
        "onboarding_tour",
        "support_export",
        "release_proof_index"
      ]
    },
    "symbol_flow_step": {
      "type": "string",
      "enum": [
        "open_in_browser",
        "peek",
        "split",
        "browser_handoff",
        "support_export",
        "ai_handoff"
      ]
    },
    "source_descriptor": {
      "type": "object",
      "required": [
        "source_id",
        "source_class",
        "provider_or_pack_id",
        "provider_or_pack_revision_ref",
        "locale",
        "trust_class",
        "browser_handoff",
        "raw_boundary_material_excluded"
      ],
      "additionalProperties": false,
      "properties": {
        "source_id": { "type": "string", "minLength": 1 },
        "source_class": { "$ref": "#/$defs/source_class" },
        "provider_or_pack_id": { "type": "string", "minLength": 1 },
        "provider_or_pack_revision_ref": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "minLength": 1 },
        "trust_class": { "$ref": "#/$defs/trust_class" },
        "browser_handoff": { "$ref": "#/$defs/browser_handoff_capability" },
        "browser_handoff_packet_ref": { "type": "string", "minLength": 1 },
        "policy_disclosure_note": { "type": "string", "minLength": 1 },
        "raw_boundary_material_excluded": { "type": "boolean" }
      }
    },
    "symbol_ref": {
      "type": "object",
      "required": ["symbol_id", "display_label", "source_ref", "symbol_kind_token"],
      "additionalProperties": false,
      "properties": {
        "symbol_id": { "type": "string", "minLength": 1 },
        "display_label": { "type": "string", "minLength": 1 },
        "source_ref": { "type": "string", "minLength": 1 },
        "symbol_kind_token": { "type": "string", "minLength": 1 }
      }
    },
    "citation_anchor": {
      "type": "object",
      "required": ["anchor_id", "target_ref", "anchor_class_token"],
      "additionalProperties": false,
      "properties": {
        "anchor_id": { "type": "string", "minLength": 1 },
        "target_ref": { "type": "string", "minLength": 1 },
        "anchor_class_token": { "type": "string", "minLength": 1 }
      }
    },
    "result_object": {
      "type": "object",
      "required": [
        "result_id",
        "title",
        "docs_source_ref",
        "version_match_state",
        "freshness_state",
        "symbol_link_class",
        "raw_boundary_material_excluded"
      ],
      "additionalProperties": false,
      "properties": {
        "result_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "docs_source_ref": { "type": "string", "minLength": 1 },
        "version_match_state": { "$ref": "#/$defs/version_match_state" },
        "freshness_state": { "$ref": "#/$defs/freshness_state" },
        "symbol_link_class": { "$ref": "#/$defs/symbol_link_class" },
        "symbol_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/symbol_ref" }
        },
        "citation_anchors": {
          "type": "array",
          "items": { "$ref": "#/$defs/citation_anchor" }
        },
        "snippet_anchor_ref": { "type": "string", "minLength": 1 },
        "downgrade_note": { "type": "string", "minLength": 1 },
        "raw_boundary_material_excluded": { "type": "boolean" }
      }
    },
    "symbol_flow": {
      "type": "object",
      "required": [
        "flow_id",
        "origin_symbol_id",
        "linked_result_id",
        "steps_preserving_identity",
        "preserves_docs_source_ref",
        "preserves_symbol_refs",
        "preserves_citation_anchors",
        "captured_at"
      ],
      "additionalProperties": false,
      "properties": {
        "flow_id": { "type": "string", "minLength": 1 },
        "origin_symbol_id": { "type": "string", "minLength": 1 },
        "linked_result_id": { "type": "string", "minLength": 1 },
        "steps_preserving_identity": {
          "type": "array",
          "items": { "$ref": "#/$defs/symbol_flow_step" }
        },
        "preserves_docs_source_ref": { "type": "boolean" },
        "preserves_symbol_refs": { "type": "boolean" },
        "preserves_citation_anchors": { "type": "boolean" },
        "captured_at": { "type": "string", "minLength": 1 }
      }
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "packet_id_ref",
        "rendered_at",
        "preserves_source_class",
        "preserves_version_match",
        "preserves_freshness",
        "preserves_trust_class",
        "preserves_browser_handoff",
        "preserves_result_object_identity",
        "preserves_symbol_flow_identity",
        "preserves_same_packet",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "additionalProperties": false,
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "projection_ref": { "type": "string", "minLength": 1 },
        "packet_id_ref": { "type": "string", "minLength": 1 },
        "rendered_at": { "type": "string", "minLength": 1 },
        "preserves_source_class": { "type": "boolean" },
        "preserves_version_match": { "type": "boolean" },
        "preserves_freshness": { "type": "boolean" },
        "preserves_trust_class": { "type": "boolean" },
        "preserves_browser_handoff": { "type": "boolean" },
        "preserves_result_object_identity": { "type": "boolean" },
        "preserves_symbol_flow_identity": { "type": "boolean" },
        "preserves_same_packet": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      }
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "additionalProperties": false,
      "properties": {
        "finding_kind": {
          "type": "string",
          "enum": [
            "wrong_record_kind",
            "wrong_schema_version",
            "missing_packet_identity",
            "missing_source_descriptors",
            "missing_result_objects",
            "source_descriptor_incomplete",
            "result_source_ref_unpinned",
            "result_identity_incomplete",
            "result_disclosure_missing",
            "symbol_refs_missing",
            "symbol_flow_identity_lost",
            "symbol_flow_result_ref_unpinned",
            "browser_handoff_packet_missing",
            "missing_consumer_projection",
            "consumer_projection_drift",
            "source_class_taxonomy_dropped",
            "version_match_vocabulary_dropped",
            "freshness_vocabulary_dropped",
            "symbol_flow_identity_dropped",
            "raw_boundary_material_present",
            "required_source_class_coverage_missing",
            "derived_explanation_not_downgraded",
            "promotion_state_mismatch"
          ]
        },
        "severity": { "type": "string", "enum": ["info", "warning", "blocker"] },
        "summary": { "type": "string", "minLength": 1 }
      }
    }
  }
}
