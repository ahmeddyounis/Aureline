{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/semantic_recall_boundary_truth.schema.json",
  "title": "Aureline docs/code semantic-recall boundary truth packet",
  "description": "Boundary schema for the stable docs/code semantic-recall boundary truth packet shared by the M4 stable lane and the v1.x preview lane. Every row binds a recall-lane class, surface track, locality class, retrieval epoch state, optional embedder identity, optional pack signature, lane participation, chunk-or-anchor provenance, downgrade state, confidence class, and disclosure ref. Mirrored/managed locality requires a verified pack signature. Non-lexical lanes require an embedder identity. Mismatched epochs require a recorded downgrade. v1.x preview rows must carry a recorded downgrade so they cannot inherit adjacent green/stable rows.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "covered_lane_classes",
    "covered_surface_tracks",
    "rows",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "semantic_recall_boundary_truth_stable_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "workflow_or_surface_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "covered_lane_classes": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/recall_lane_class" }
    },
    "covered_surface_tracks": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/surface_track" }
    },
    "rows": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/boundary_row" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": { "$ref": "#/$defs/ref_array" },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "recall_lane_class": {
      "enum": [
        "docs_semantic_recall",
        "code_semantic_recall",
        "hybrid_fused_recall",
        "lexical_only_fallback"
      ]
    },
    "surface_track": {
      "enum": ["m4_stable", "v1x_preview"]
    },
    "locality_class": {
      "enum": ["local", "remote_helper", "mirrored_pack", "managed"]
    },
    "retrieval_epoch_state": {
      "enum": [
        "current_epoch_aligned",
        "epoch_mismatch_invalidated",
        "mixed_generation_blocked",
        "epoch_not_applicable"
      ]
    },
    "pack_signature_state": {
      "enum": [
        "signed_and_verified",
        "signature_mismatch_blocked",
        "not_applicable_local"
      ]
    },
    "downgrade_state": {
      "enum": [
        "none",
        "locality_downgraded_to_local",
        "embedder_unavailable_fallback_lexical",
        "epoch_drift_invalidated",
        "pack_signature_failed",
        "policy_omitted_candidates",
        "mixed_generation_blocked",
        "compatibility_drift_disclosed"
      ]
    },
    "confidence_class": {
      "enum": ["high", "medium", "low", "heuristic"]
    },
    "consumer_surface": {
      "enum": [
        "search_shell",
        "docs_help",
        "ai_context",
        "review_workspace",
        "cli_headless",
        "retrieval_inspector",
        "support_export",
        "release_proof_index"
      ]
    },
    "promotion_state": {
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "finding_severity": { "enum": ["info", "warning", "blocker"] },
    "finding_kind": {
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "missing_lane_coverage",
        "missing_surface_track_coverage",
        "missing_embedder_identity",
        "missing_chunk_or_anchor_provenance",
        "missing_ranking_reason",
        "missing_disclosure_ref",
        "missing_evidence_refs",
        "missing_pack_signature",
        "pack_signature_not_verified",
        "epoch_mismatch_presented_as_current",
        "raw_query_text_present",
        "raw_source_bodies_present",
        "secrets_present",
        "ambient_authority_present",
        "policy_omissions_undisclosed",
        "preview_row_claims_m4_stable_certainty",
        "unlabeled_managed_or_vector_match",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "lane_vocabulary_collapsed",
        "surface_track_vocabulary_collapsed",
        "locality_vocabulary_collapsed",
        "epoch_state_vocabulary_collapsed",
        "pack_signature_vocabulary_collapsed",
        "downgrade_vocabulary_collapsed",
        "embedder_identity_dropped",
        "lane_participation_dropped",
        "promotion_state_mismatch"
      ]
    },
    "embedder_identity": {
      "type": "object",
      "required": [
        "embedder_model_id",
        "embedder_model_version",
        "tokenizer_id",
        "chunking_strategy_id",
        "retention_policy_id",
        "retrieval_epoch_label"
      ],
      "properties": {
        "embedder_model_id": { "$ref": "#/$defs/non_empty_string" },
        "embedder_model_version": { "$ref": "#/$defs/non_empty_string" },
        "tokenizer_id": { "$ref": "#/$defs/non_empty_string" },
        "chunking_strategy_id": { "$ref": "#/$defs/non_empty_string" },
        "retention_policy_id": { "$ref": "#/$defs/non_empty_string" },
        "retrieval_epoch_label": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "pack_signature": {
      "type": "object",
      "required": [
        "signature_state",
        "pack_id_ref",
        "pack_version",
        "signer_id_ref",
        "verified_at"
      ],
      "properties": {
        "signature_state": { "$ref": "#/$defs/pack_signature_state" },
        "pack_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "pack_version": { "$ref": "#/$defs/non_empty_string" },
        "signer_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "verified_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "lane_participation": {
      "type": "object",
      "required": [
        "participating_lane_refs",
        "policy_hidden_omissions_disclosed"
      ],
      "properties": {
        "participating_lane_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/recall_lane_class" }
        },
        "omitted_lane_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/recall_lane_class" }
        },
        "policy_hidden_omissions_disclosed": { "type": "boolean" },
        "policy_hidden_omissions_disclosure_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "boundary_row": {
      "type": "object",
      "required": [
        "row_id",
        "recall_lane_class",
        "surface_track",
        "locality_class",
        "retrieval_epoch_state",
        "lane_participation",
        "chunk_or_anchor_provenance_ref",
        "workspace_id",
        "downgrade_state",
        "confidence_class",
        "disclosure_ref",
        "evidence_refs",
        "raw_query_text_excluded",
        "secrets_excluded",
        "ambient_authority_excluded",
        "raw_source_bodies_excluded",
        "captured_at"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "recall_lane_class": { "$ref": "#/$defs/recall_lane_class" },
        "surface_track": { "$ref": "#/$defs/surface_track" },
        "locality_class": { "$ref": "#/$defs/locality_class" },
        "retrieval_epoch_state": { "$ref": "#/$defs/retrieval_epoch_state" },
        "embedder_identity": { "$ref": "#/$defs/embedder_identity" },
        "pack_signature": { "$ref": "#/$defs/pack_signature" },
        "lane_participation": { "$ref": "#/$defs/lane_participation" },
        "chunk_or_anchor_provenance_ref": { "$ref": "#/$defs/non_empty_string" },
        "ranking_reason_ref": { "$ref": "#/$defs/non_empty_string" },
        "workspace_id": { "$ref": "#/$defs/non_empty_string" },
        "downgrade_state": { "$ref": "#/$defs/downgrade_state" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "disclosure_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "raw_query_text_excluded": { "type": "boolean" },
        "secrets_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "raw_source_bodies_excluded": { "type": "boolean" },
        "captured_at": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "consumer_projection": {
      "type": "object",
      "required": [
        "consumer_surface",
        "projection_ref",
        "semantic_recall_boundary_packet_id_ref",
        "rendered_at",
        "preserves_same_packet",
        "preserves_lane_vocabulary",
        "preserves_surface_track_vocabulary",
        "preserves_locality_vocabulary",
        "preserves_epoch_state_vocabulary",
        "preserves_pack_signature_vocabulary",
        "preserves_downgrade_vocabulary",
        "exposes_embedder_identity",
        "exposes_participating_and_omitted_lanes",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "projection_ref": { "$ref": "#/$defs/non_empty_string" },
        "semantic_recall_boundary_packet_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rendered_at": { "$ref": "#/$defs/non_empty_string" },
        "preserves_same_packet": { "type": "boolean" },
        "preserves_lane_vocabulary": { "type": "boolean" },
        "preserves_surface_track_vocabulary": { "type": "boolean" },
        "preserves_locality_vocabulary": { "type": "boolean" },
        "preserves_epoch_state_vocabulary": { "type": "boolean" },
        "preserves_pack_signature_vocabulary": { "type": "boolean" },
        "preserves_downgrade_vocabulary": { "type": "boolean" },
        "exposes_embedder_identity": { "type": "boolean" },
        "exposes_participating_and_omitted_lanes": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_finding": {
      "type": "object",
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  }
}
