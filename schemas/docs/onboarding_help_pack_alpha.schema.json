{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/onboarding_help_pack_alpha.schema.json",
  "title": "Aureline onboarding/help-pack alpha manifest",
  "description": "Versioned alpha contract for onboarding, help, glossary, migration, and future guided-learning pack items. The manifest preserves stable pack and item IDs, source/version/freshness, locale and source-language fallback, offline posture, citation refs, exact reopen refs, command/help anchors, and user-owned progress state without carrying raw article bodies or raw URLs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "manifest_id",
    "generated_at",
    "source_contract_refs",
    "runtime_consumer_refs",
    "packs",
    "items",
    "progress_states",
    "protected_proofs"
  ],
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "onboarding_help_pack_alpha_record"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "manifest_id": {
      "$ref": "#/$defs/stable_id"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_contract_refs": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "runtime_consumer_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stable_id"
      },
      "uniqueItems": true
    },
    "packs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/pack"
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/item"
      }
    },
    "progress_states": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/progress_state"
      }
    },
    "protected_proofs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/proof"
      }
    }
  },
  "$defs": {
    "stable_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:._@#/-]*$"
    },
    "locale": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "pack_role": {
      "type": "string",
      "enum": [
        "first_run_starter_pack",
        "migration_welcome_pack",
        "glossary_bundle",
        "guided_content_pack",
        "in_product_help_overlay_pack"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "project_docs",
        "generated_reference",
        "mirrored_official_docs",
        "curated_knowledge_pack",
        "support_runbook"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },
    "version_match_state": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ]
    },
    "install_state": {
      "type": "string",
      "enum": [
        "local_only_starter",
        "cached_snapshot_current",
        "cached_snapshot_stale",
        "mirror_only_verified",
        "not_installed"
      ]
    },
    "offline_posture": {
      "type": "string",
      "enum": [
        "fully_available_offline_local_build",
        "cached_snapshot_offline",
        "mirror_verified_offline",
        "not_available_offline"
      ]
    },
    "citation_availability": {
      "type": "string",
      "enum": [
        "available",
        "required_missing",
        "not_required"
      ]
    },
    "locale_availability": {
      "type": "string",
      "enum": [
        "locale_available_reviewed",
        "locale_available_stale_copy",
        "locale_missing_fallback_to_primary",
        "locale_missing_not_installed"
      ]
    },
    "fallback_class": {
      "type": "string",
      "enum": [
        "no_fallback_primary_locale_only",
        "fallback_to_source_language_disclosed",
        "fallback_blocked_pack_missing"
      ]
    },
    "item_kind": {
      "type": "string",
      "enum": [
        "start_center_card",
        "contextual_hint",
        "keymap_bridge",
        "migration_guidance",
        "glossary_pack_item",
        "future_guided_learning_ref"
      ]
    },
    "render_state": {
      "type": "string",
      "enum": [
        "renderable",
        "placeholder_only",
        "blocked_not_installed"
      ]
    },
    "command_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "help_anchor_id",
        "keyboard_route",
        "route_kind",
        "metadata_source"
      ],
      "properties": {
        "command_id": {
          "type": "string",
          "pattern": "^cmd:[A-Za-z0-9_.:-]+$"
        },
        "command_revision_ref": {
          "type": ["string", "null"]
        },
        "help_anchor_id": {
          "$ref": "#/$defs/stable_id"
        },
        "keyboard_route": {
          "type": "string",
          "minLength": 1
        },
        "route_kind": {
          "type": "string",
          "enum": [
            "command",
            "help_search",
            "browser_handoff",
            "evidence_card"
          ]
        },
        "metadata_source": {
          "type": "string",
          "enum": [
            "command_registry",
            "alpha_owned_descriptor"
          ]
        }
      }
    },
    "locale_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_locale",
        "requested_locale",
        "effective_locale",
        "locale_availability",
        "stale_translation_marker"
      ],
      "properties": {
        "source_locale": {
          "$ref": "#/$defs/locale"
        },
        "requested_locale": {
          "$ref": "#/$defs/locale"
        },
        "effective_locale": {
          "$ref": "#/$defs/locale"
        },
        "locale_availability": {
          "$ref": "#/$defs/locale_availability"
        },
        "stale_translation_marker": {
          "type": "boolean"
        }
      }
    },
    "source_language_fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fallback_class",
        "source_language_item_ref",
        "escape_hatch_command_id"
      ],
      "properties": {
        "fallback_class": {
          "$ref": "#/$defs/fallback_class"
        },
        "source_language_item_ref": {
          "type": ["string", "null"]
        },
        "escape_hatch_command_id": {
          "type": ["string", "null"],
          "pattern": "^cmd:[A-Za-z0-9_.:-]+$"
        }
      }
    },
    "citation_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "availability",
        "citation_refs",
        "source_strip_ref",
        "citation_drawer_ref"
      ],
      "properties": {
        "availability": {
          "$ref": "#/$defs/citation_availability"
        },
        "citation_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stable_id"
          },
          "uniqueItems": true
        },
        "source_strip_ref": {
          "type": ["string", "null"]
        },
        "citation_drawer_ref": {
          "type": ["string", "null"]
        }
      }
    },
    "support_export_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_pack_item_id",
        "redaction_class",
        "raw_body_exported",
        "exact_reopen_ref"
      ],
      "properties": {
        "support_pack_item_id": {
          "$ref": "#/$defs/stable_id"
        },
        "redaction_class": {
          "type": "string",
          "enum": [
            "metadata_safe_default",
            "operator_only_restricted"
          ]
        },
        "raw_body_exported": {
          "type": "boolean",
          "const": false
        },
        "exact_reopen_ref": {
          "$ref": "#/$defs/stable_id"
        }
      }
    },
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pack_id",
        "pack_revision_ref",
        "pack_role",
        "source_class",
        "source_ref",
        "source_version_ref",
        "freshness_class",
        "version_match_state",
        "install_state",
        "offline_posture",
        "source_locale",
        "available_locales",
        "citation_availability"
      ],
      "properties": {
        "pack_id": {
          "$ref": "#/$defs/stable_id"
        },
        "pack_revision_ref": {
          "$ref": "#/$defs/stable_id"
        },
        "pack_role": {
          "$ref": "#/$defs/pack_role"
        },
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "source_ref": {
          "$ref": "#/$defs/stable_id"
        },
        "source_version_ref": {
          "$ref": "#/$defs/stable_id"
        },
        "freshness_class": {
          "$ref": "#/$defs/freshness_class"
        },
        "version_match_state": {
          "$ref": "#/$defs/version_match_state"
        },
        "install_state": {
          "$ref": "#/$defs/install_state"
        },
        "offline_posture": {
          "$ref": "#/$defs/offline_posture"
        },
        "source_locale": {
          "$ref": "#/$defs/locale"
        },
        "available_locales": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/locale"
          },
          "uniqueItems": true
        },
        "citation_availability": {
          "$ref": "#/$defs/citation_availability"
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "item_kind",
        "title",
        "pack_id",
        "pack_revision_ref",
        "docs_node_id",
        "command_hint",
        "locale",
        "source_language_fallback",
        "citation",
        "content_render_state",
        "exact_reopen_ref",
        "support_export_identity",
        "progress_state_ref"
      ],
      "properties": {
        "item_id": {
          "$ref": "#/$defs/stable_id"
        },
        "item_kind": {
          "$ref": "#/$defs/item_kind"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "pack_id": {
          "$ref": "#/$defs/stable_id"
        },
        "pack_revision_ref": {
          "$ref": "#/$defs/stable_id"
        },
        "docs_node_id": {
          "$ref": "#/$defs/stable_id"
        },
        "glossary_item_id": {
          "type": ["string", "null"]
        },
        "command_hint": {
          "$ref": "#/$defs/command_hint"
        },
        "locale": {
          "$ref": "#/$defs/locale_state"
        },
        "source_language_fallback": {
          "$ref": "#/$defs/source_language_fallback"
        },
        "citation": {
          "$ref": "#/$defs/citation_state"
        },
        "content_render_state": {
          "$ref": "#/$defs/render_state"
        },
        "exact_reopen_ref": {
          "$ref": "#/$defs/stable_id"
        },
        "support_export_identity": {
          "$ref": "#/$defs/support_export_identity"
        },
        "progress_state_ref": {
          "$ref": "#/$defs/stable_id"
        },
        "future_surface_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stable_id"
          },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "progress_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_item_id",
        "item_ref",
        "state_kind",
        "storage_lane",
        "reset_class",
        "export_class",
        "repo_mutation_allowed",
        "repo_read_access_default",
        "telemetry_read_default"
      ],
      "properties": {
        "state_item_id": {
          "$ref": "#/$defs/stable_id"
        },
        "item_ref": {
          "$ref": "#/$defs/stable_id"
        },
        "state_kind": {
          "type": "string",
          "enum": [
            "dismissed_hint",
            "completed_item",
            "resume_point",
            "bookmarked_glossary_item",
            "deferred_pack_install"
          ]
        },
        "storage_lane": {
          "type": "string",
          "const": "portable_user_profile_state"
        },
        "reset_class": {
          "type": "string",
          "enum": [
            "resettable_per_profile",
            "resettable_with_pack_refresh",
            "resettable_with_reinstall_or_import"
          ]
        },
        "export_class": {
          "type": "string",
          "enum": [
            "in_portable_profile_package",
            "in_support_bundle_redacted"
          ]
        },
        "repo_mutation_allowed": {
          "type": "boolean",
          "const": false
        },
        "repo_read_access_default": {
          "type": "boolean",
          "const": false
        },
        "telemetry_read_default": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_id",
        "fixture_ref",
        "exercised_item_refs",
        "exercised_states"
      ],
      "properties": {
        "proof_id": {
          "$ref": "#/$defs/stable_id"
        },
        "fixture_ref": {
          "type": "string",
          "minLength": 1
        },
        "exercised_item_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/stable_id"
          }
        },
        "exercised_states": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
