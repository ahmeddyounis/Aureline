{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/implement-docs-and-code-semantic-recall-with-query-session-ledger-ranking-reasons-and-provenance-export.schema.json",
  "title": "Aureline docs and code semantic recall with query-session ledger, ranking reasons, and provenance export",
  "description": "Export-safe packet for a unified docs-and-code semantic recall. A query-session ledger records the ordered queries of one session, each with an opaque query digest, a refinement relation, a subject scope, and the result ids it surfaced. Each ranked result row carries a five-chip set (source class, version match, freshness, locality, confidence), an explicit ranking reason with a ranking-signal breakdown, inline provenance, and open-raw/open-source escapes. A provenance export preserves source class, confidence, derivation, citation state, and escapes per result. Session-level degradations narrow or block the claim. The promotion state (stable / narrowed_below_stable / blocks_stable) is computed from validation and degradation findings. Raw query text, raw document bodies, raw source files, raw provider payloads, and credentials never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "session_label",
    "session_digest_ref",
    "query_session_ledger",
    "result_rows",
    "provenance_export",
    "recall_degradations",
    "consumer_projections",
    "promotion_state",
    "validation_findings",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "docs_and_code_semantic_recall_query_session_ledger"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "session_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "session_digest_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "query_session_ledger": {
      "$ref": "#/$defs/query_session_ledger"
    },
    "result_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/result_row"
      }
    },
    "provenance_export": {
      "$ref": "#/$defs/provenance_export"
    },
    "recall_degradations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recall_degradation"
      }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/consumer_projection"
      }
    },
    "promotion_state": {
      "$ref": "#/$defs/promotion_state"
    },
    "validation_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation_finding"
      }
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "source_class": {
      "type": "string",
      "enum": [
        "project_docs",
        "generated_reference",
        "mirrored_official_docs",
        "curated_knowledge_pack",
        "support_runbook",
        "extension_docs_pack",
        "workspace_code",
        "dependency_source"
      ]
    },
    "version_match": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified",
        "refresh_pending"
      ]
    },
    "locality": {
      "type": "string",
      "enum": [
        "local",
        "mirrored_pack",
        "remote_helper",
        "managed"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "heuristic"
      ]
    },
    "subject_kind": {
      "type": "string",
      "enum": [
        "docs_node",
        "code_symbol",
        "code_file",
        "code_snippet"
      ]
    },
    "derivation_class": {
      "type": "string",
      "enum": [
        "verbatim_node",
        "extracted_snippet",
        "derived_summary",
        "inferred_explanation"
      ]
    },
    "query_refinement_relation": {
      "type": "string",
      "enum": [
        "initial",
        "narrowed",
        "broadened",
        "reformulated",
        "pivoted_subject"
      ]
    },
    "subject_scope": {
      "type": "string",
      "enum": [
        "docs_only",
        "code_only",
        "docs_and_code"
      ]
    },
    "ranking_signal_kind": {
      "type": "string",
      "enum": [
        "lexical_overlap",
        "semantic_similarity",
        "symbol_exact_match",
        "graph_proximity",
        "recency",
        "pin_boost",
        "authority_boost",
        "path_affinity"
      ]
    },
    "signal_contribution_class": {
      "type": "string",
      "enum": [
        "primary",
        "supporting",
        "minor",
        "penalty"
      ]
    },
    "recall_degradation_class": {
      "type": "string",
      "enum": [
        "embedder_unavailable_lexical_fallback",
        "code_graph_stale",
        "mirror_offline_snapshot",
        "partial_index",
        "session_truncated",
        "quarantined_pack",
        "broken_anchor"
      ]
    },
    "finding_severity": {
      "type": "string",
      "enum": [
        "blocking",
        "narrowing",
        "advisory"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "docs_browser",
        "search_shell",
        "code_explainer",
        "ai_context",
        "retrieval_inspector",
        "cli_headless",
        "support_export",
        "help_about"
      ]
    },
    "provenance_export_scope": {
      "type": "string",
      "enum": [
        "full_session",
        "active_query_only",
        "docs_only",
        "code_only"
      ]
    },
    "promotion_state": {
      "type": "string",
      "enum": [
        "stable",
        "narrowed_below_stable",
        "blocks_stable"
      ]
    },
    "validation_finding_kind": {
      "type": "string",
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_identity",
        "ledger_empty",
        "ledger_sequence_not_monotonic",
        "ledger_entry_query_digest_missing",
        "ledger_refinement_inconsistent",
        "ledger_surfaced_result_orphan",
        "result_rows_empty",
        "result_rank_not_monotonic",
        "duplicate_result_id",
        "result_origin_query_orphan",
        "ranking_reason_missing",
        "ranking_signals_missing",
        "open_raw_open_source_escape_missing",
        "code_result_not_cited",
        "inferred_result_looks_authoritative",
        "version_truth_collapsed",
        "provenance_export_row_orphan",
        "provenance_export_coverage_missing",
        "provenance_export_drops_preservation",
        "provenance_source_class_mismatch",
        "provenance_confidence_mismatch",
        "degradation_incomplete",
        "degradation_orphan",
        "consumer_projection_drift",
        "consumer_projection_packet_id_mismatch",
        "required_surface_coverage_missing",
        "raw_boundary_material_present"
      ]
    },
    "ranking_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal",
        "contribution",
        "note"
      ],
      "properties": {
        "signal": {
          "$ref": "#/$defs/ranking_signal_kind"
        },
        "contribution": {
          "$ref": "#/$defs/signal_contribution_class"
        },
        "note": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "chip_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "version_match",
        "freshness",
        "locality",
        "confidence"
      ],
      "properties": {
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "version_match": {
          "$ref": "#/$defs/version_match"
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        },
        "locality": {
          "$ref": "#/$defs/locality"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "result_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pack_id_ref",
        "pack_pinned",
        "pack_signed_and_verified",
        "derivation",
        "cited"
      ],
      "properties": {
        "pack_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pack_pinned": {
          "type": "boolean"
        },
        "pack_signed_and_verified": {
          "type": "boolean"
        },
        "derivation": {
          "$ref": "#/$defs/derivation_class"
        },
        "cited": {
          "type": "boolean"
        },
        "citation_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "ledger_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "query_digest_ref",
        "query_label",
        "refinement",
        "subject_scope",
        "surfaced_result_ids"
      ],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "query_digest_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "query_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "refinement": {
          "$ref": "#/$defs/query_refinement_relation"
        },
        "subject_scope": {
          "$ref": "#/$defs/subject_scope"
        },
        "surfaced_result_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "query_session_ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "entries"
      ],
      "properties": {
        "session_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ledger_entry"
          }
        }
      }
    },
    "result_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank",
        "result_id",
        "subject_kind",
        "subject_ref",
        "origin_query_sequence",
        "chips",
        "ranking_reason",
        "ranking_signals",
        "provenance",
        "open_raw_escape_ref",
        "open_source_escape_ref"
      ],
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "result_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "subject_kind": {
          "$ref": "#/$defs/subject_kind"
        },
        "subject_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "origin_query_sequence": {
          "type": "integer",
          "minimum": 1
        },
        "chips": {
          "$ref": "#/$defs/chip_set"
        },
        "ranking_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "ranking_signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ranking_signal"
          }
        },
        "provenance": {
          "$ref": "#/$defs/result_provenance"
        },
        "open_raw_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_source_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "provenance_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_id_ref",
        "subject_kind",
        "source_class",
        "confidence",
        "derivation",
        "cited",
        "open_raw_escape_ref",
        "open_source_escape_ref"
      ],
      "properties": {
        "result_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "subject_kind": {
          "$ref": "#/$defs/subject_kind"
        },
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "derivation": {
          "$ref": "#/$defs/derivation_class"
        },
        "cited": {
          "type": "boolean"
        },
        "open_raw_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_source_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "provenance_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "preserves_source_class",
        "preserves_confidence",
        "preserves_open_raw_open_source_escape",
        "preserves_inference_labels",
        "rows"
      ],
      "properties": {
        "scope": {
          "$ref": "#/$defs/provenance_export_scope"
        },
        "preserves_source_class": {
          "type": "boolean"
        },
        "preserves_confidence": {
          "type": "boolean"
        },
        "preserves_open_raw_open_source_escape": {
          "type": "boolean"
        },
        "preserves_inference_labels": {
          "type": "boolean"
        },
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/provenance_row"
          }
        }
      }
    },
    "recall_degradation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "degradation_class",
        "severity",
        "summary"
      ],
      "properties": {
        "degradation_class": {
          "$ref": "#/$defs/recall_degradation_class"
        },
        "severity": {
          "$ref": "#/$defs/finding_severity"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "result_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "packet_id_ref",
        "preserves_chips",
        "preserves_query_session_ledger",
        "preserves_ranking_reasons",
        "preserves_provenance_export",
        "preserves_open_raw_open_source_escape"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/consumer_surface"
        },
        "packet_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preserves_chips": {
          "type": "boolean"
        },
        "preserves_query_session_ledger": {
          "type": "boolean"
        },
        "preserves_ranking_reasons": {
          "type": "boolean"
        },
        "preserves_provenance_export": {
          "type": "boolean"
        },
        "preserves_open_raw_open_source_escape": {
          "type": "boolean"
        }
      }
    },
    "validation_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_kind",
        "severity",
        "summary"
      ],
      "properties": {
        "finding_kind": {
          "$ref": "#/$defs/validation_finding_kind"
        },
        "severity": {
          "$ref": "#/$defs/finding_severity"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
