{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/docs_pack_truth_packet.schema.json",
  "title": "Aureline docs-pack truth packet",
  "description": "Boundary schema for the stable docs-pack truth packet that hardens docs-pack manifests, mirror/offline truth, stale-example detection, and citation-set export across help surfaces. The Rust types in crates/aureline-docs/src/docs_pack_truth_packet/mod.rs are the schema of record; this file is the cross-tool boundary every non-owning surface reads. Raw document bodies, raw URLs, secrets, and provider payloads never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workflow_or_surface_id",
    "generated_at",
    "manifests",
    "stale_example_findings",
    "citation_sets",
    "consumer_projections",
    "promotion_state"
  ],
  "properties": {
    "record_kind": { "const": "docs_pack_truth_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "workflow_or_surface_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "manifests": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/pack_manifest" }
    },
    "stale_example_findings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stale_example_finding" }
    },
    "citation_sets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/citation_set_export" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "source_contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "promotion_state": { "$ref": "#/$defs/promotion_state" },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "$defs": {
    "promotion_state": {
      "type": "string",
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "project_docs",
        "generated_reference",
        "mirrored_official_docs",
        "curated_knowledge_pack",
        "support_runbook",
        "extension_docs_pack"
      ]
    },
    "signer_class": {
      "type": "string",
      "enum": [
        "first_party_project",
        "permitted_publisher",
        "official_upstream_mirror",
        "operator_curated",
        "support_pipeline"
      ]
    },
    "signature_status": {
      "type": "string",
      "enum": [
        "signed_and_verified",
        "signed_but_unverified",
        "signature_missing",
        "signature_revoked"
      ]
    },
    "source_channel": {
      "type": "string",
      "enum": ["stable", "beta", "nightly", "enterprise"]
    },
    "refresh_state": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified",
        "refresh_pending"
      ]
    },
    "mirror_state": {
      "type": "string",
      "enum": [
        "not_applicable",
        "continuous",
        "predecessor_missing",
        "signing_chain_broken"
      ]
    },
    "pin_state": {
      "type": "string",
      "enum": ["pinned", "unpinned", "pinned_offline", "pinned_compat_window"]
    },
    "local_availability": {
      "type": "string",
      "enum": [
        "available_local",
        "mirror_offline_pinned",
        "not_installed",
        "unavailable_disclosed",
        "quarantined"
      ]
    },
    "publishable_state": {
      "type": "string",
      "enum": [
        "publishable",
        "draft",
        "blocked",
        "withdrawn",
        "quarantined"
      ]
    },
    "render_mode": {
      "type": "string",
      "enum": [
        "rendered",
        "syntax_checked",
        "executed_locally",
        "executed_remotely",
        "mirrored_only",
        "browser_handoff_only",
        "not_rendered"
      ]
    },
    "validation_result_class": {
      "type": "string",
      "enum": [
        "validated_clean",
        "validated_with_warnings",
        "validated_failed",
        "not_validated",
        "validation_unsupported"
      ]
    },
    "stale_finding_class": {
      "type": "string",
      "enum": [
        "nearby_version",
        "stale_example",
        "quarantined_pack",
        "broken_link",
        "needs_review",
        "missing_evidence"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "docs_browser_shell",
        "help_pane",
        "onboarding_tour",
        "ai_context_inspector",
        "cli_headless",
        "support_export",
        "release_proof_index",
        "mirror_offline_console",
        "citation_drawer",
        "stale_example_review"
      ]
    },
    "finding_kind": {
      "type": "string",
      "enum": [
        "wrong_record_kind",
        "wrong_schema_version",
        "missing_packet_identity",
        "missing_pack_manifests",
        "missing_citation_sets",
        "missing_stale_example_findings",
        "pack_manifest_incomplete",
        "pack_identity_lost_when_offline",
        "mirror_state_inconsistent",
        "publishable_state_inconsistent",
        "refresh_disclosure_missing",
        "stale_state_collapsed",
        "stale_finding_pack_ref_unpinned",
        "suppression_attribution_lost",
        "suppression_lost_source_version",
        "citation_set_bundles_raw_pack",
        "citation_set_identity_incomplete",
        "citation_set_pack_ref_unpinned",
        "required_source_class_coverage_missing",
        "required_render_mode_coverage_missing",
        "required_local_availability_coverage_missing",
        "missing_consumer_projection",
        "consumer_projection_drift",
        "render_mode_vocabulary_dropped",
        "validation_result_class_dropped",
        "stale_finding_class_dropped",
        "citation_set_identity_dropped",
        "raw_boundary_material_present",
        "promotion_state_mismatch"
      ]
    },
    "finding_severity": {
      "type": "string",
      "enum": ["info", "warning", "blocker"]
    },
    "validation_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_kind", "severity", "summary"],
      "properties": {
        "finding_kind": { "$ref": "#/$defs/finding_kind" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "version_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_inclusive_ref", "max_inclusive_ref"],
      "properties": {
        "min_inclusive_ref": { "type": "string", "minLength": 1 },
        "max_inclusive_ref": { "type": "string", "minLength": 1 }
      }
    },
    "signing_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signature_status",
        "signer_class",
        "signing_authority_ref"
      ],
      "properties": {
        "signature_status": { "$ref": "#/$defs/signature_status" },
        "signer_class": { "$ref": "#/$defs/signer_class" },
        "signing_authority_ref": { "type": "string", "minLength": 1 },
        "signing_chain_digest": { "type": "string", "minLength": 1 }
      }
    },
    "mirror_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mirror_state"],
      "properties": {
        "mirror_state": { "$ref": "#/$defs/mirror_state" },
        "mirror_of_pack_id": { "type": "string", "minLength": 1 },
        "upstream_revision_ref": { "type": "string", "minLength": 1 },
        "predecessor_revision_ref": { "type": "string", "minLength": 1 },
        "air_gapped_origin_label": { "type": "string", "minLength": 1 },
        "offline_expiration_at": { "type": "string", "format": "date-time" }
      }
    },
    "pack_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pack_id",
        "pack_revision_ref",
        "display_label",
        "source_class",
        "source_channel",
        "signing",
        "version_range",
        "refresh_state",
        "mirror_lineage",
        "pin_state",
        "local_availability",
        "publishable_state",
        "publishable_blocking_reasons",
        "manifest_schema_version",
        "raw_boundary_material_excluded"
      ],
      "properties": {
        "pack_id": { "type": "string", "minLength": 1 },
        "pack_revision_ref": { "type": "string", "minLength": 1 },
        "display_label": { "type": "string", "minLength": 1 },
        "source_class": { "$ref": "#/$defs/source_class" },
        "source_channel": { "$ref": "#/$defs/source_channel" },
        "signing": { "$ref": "#/$defs/signing_block" },
        "version_range": { "$ref": "#/$defs/version_range" },
        "refresh_state": { "$ref": "#/$defs/refresh_state" },
        "last_refresh_at": { "type": "string", "format": "date-time" },
        "mirror_lineage": { "$ref": "#/$defs/mirror_lineage" },
        "pin_state": { "$ref": "#/$defs/pin_state" },
        "local_availability": { "$ref": "#/$defs/local_availability" },
        "publishable_state": { "$ref": "#/$defs/publishable_state" },
        "publishable_blocking_reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "manifest_schema_version": { "type": "integer", "minimum": 1 },
        "disclosure_note": { "type": "string", "minLength": 1 },
        "raw_boundary_material_excluded": { "type": "boolean" }
      }
    },
    "stale_example_suppression": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suppression_id",
        "actor_ref",
        "reason",
        "expiry_at",
        "evidence_refs",
        "source_pack_id_ref",
        "source_pack_revision_ref"
      ],
      "properties": {
        "suppression_id": { "type": "string", "minLength": 1 },
        "actor_ref": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "expiry_at": { "type": "string", "format": "date-time" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "source_pack_id_ref": { "type": "string", "minLength": 1 },
        "source_pack_revision_ref": { "type": "string", "minLength": 1 }
      }
    },
    "stale_example_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "pack_id_ref",
        "pack_revision_ref",
        "finding_class",
        "render_mode",
        "validation_result_class",
        "evidence_refs"
      ],
      "properties": {
        "finding_id": { "type": "string", "minLength": 1 },
        "pack_id_ref": { "type": "string", "minLength": 1 },
        "pack_revision_ref": { "type": "string", "minLength": 1 },
        "finding_class": { "$ref": "#/$defs/stale_finding_class" },
        "render_mode": { "$ref": "#/$defs/render_mode" },
        "validation_result_class": { "$ref": "#/$defs/validation_result_class" },
        "nearby_version_ref": { "type": "string", "minLength": 1 },
        "superseding_example_id": { "type": "string", "minLength": 1 },
        "suppression": { "$ref": "#/$defs/stale_example_suppression" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "citation_set_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "citation_set_id",
        "derived_explanation_ref",
        "source_pack_id_refs",
        "cited_file_refs",
        "cited_symbol_refs",
        "cited_docs_refs",
        "graph_epoch_ref",
        "locale",
        "derivation_tool_ref",
        "derivation_tool_version",
        "raw_pack_bodies_excluded",
        "raw_urls_excluded"
      ],
      "properties": {
        "citation_set_id": { "type": "string", "minLength": 1 },
        "derived_explanation_ref": { "type": "string", "minLength": 1 },
        "source_pack_id_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "cited_file_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "cited_symbol_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "cited_docs_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "graph_epoch_ref": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "minLength": 1 },
        "derivation_tool_ref": { "type": "string", "minLength": 1 },
        "derivation_tool_version": { "type": "string", "minLength": 1 },
        "raw_pack_bodies_excluded": { "type": "boolean" },
        "raw_urls_excluded": { "type": "boolean" }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer_surface",
        "projection_ref",
        "packet_id_ref",
        "rendered_at",
        "preserves_pack_manifest",
        "preserves_mirror_offline",
        "preserves_pin_availability",
        "preserves_render_mode",
        "preserves_validation_result_class",
        "preserves_stale_finding_class",
        "preserves_suppression_attribution",
        "preserves_citation_set_identity",
        "preserves_same_packet",
        "supports_json_export",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "projection_ref": { "type": "string", "minLength": 1 },
        "packet_id_ref": { "type": "string", "minLength": 1 },
        "rendered_at": { "type": "string", "format": "date-time" },
        "preserves_pack_manifest": { "type": "boolean" },
        "preserves_mirror_offline": { "type": "boolean" },
        "preserves_pin_availability": { "type": "boolean" },
        "preserves_render_mode": { "type": "boolean" },
        "preserves_validation_result_class": { "type": "boolean" },
        "preserves_stale_finding_class": { "type": "boolean" },
        "preserves_suppression_attribution": { "type": "boolean" },
        "preserves_citation_set_identity": { "type": "boolean" },
        "preserves_same_packet": { "type": "boolean" },
        "supports_json_export": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" }
      }
    }
  }
}
