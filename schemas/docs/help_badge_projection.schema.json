{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/help_badge_projection.schema.json",
  "title": "Aureline docs/help/About/service-health badge parity projection contract",
  "description": "Boundary schema for the help_badge_projection_record and the docs_help_about_service_health_parity_case_record frozen in docs/docs/docs_help_about_service_health_parity.md. The projection record is the minimal, cross-surface badge/disclosure packet that embedded docs panes, Help/About, service-health, migration/help pivots, release center artifact rows, and support-bundle exports must agree on so truth cannot fork into surface-local wording islands. The record intentionally re-exports existing vocabularies (ADR-0013 badge fields, destination-descriptor fields, About/community handoff route fields, and release-center parity refs) instead of re-minting them. Raw URLs, raw hostnames, raw tenant identifiers, raw issue-template bodies, raw docs bytes, raw release artifact bodies, and raw credentials never cross this boundary; the record carries opaque refs and typed vocabulary only. The eventual docs-help-service-health crate's Rust types are the schema of record; this file is the cross-tool boundary every non-owning surface can consume without translation tables.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/help_badge_projection_record" },
    { "$ref": "#/$defs/docs_help_about_service_health_parity_case_record" }
  ],
  "$defs": {
    "help_badge_projection_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this projection export. Current value is 1. Bumped only on breaking payload changes; additive-optional fields do not bump this version."
    },

    "record_kind": {
      "type": "string",
      "enum": [
        "help_badge_projection_record",
        "docs_help_about_service_health_parity_case_record"
      ],
      "description": "Discriminator for the concrete payload shape. Every record carries exactly one kind."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests and support bundles."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },

    "surface_class": {
      "type": "string",
      "enum": [
        "docs_pane",
        "docs_browser",
        "help_about",
        "service_health",
        "migration_center",
        "release_center",
        "release_notice",
        "support_summary",
        "support_export",
        "support_bundle_summary",
        "onboarding",
        "ai_explanation_overlay",
        "provenance_inspector",
        "community_handoff"
      ],
      "description": "Cross-surface consumer vocabulary for this projection record. It intentionally composes the surface classes frozen by ADR-0013, the destination-descriptor surface families, and the export display-layer classes used by support bundles."
    },

    "source_class": {
      "type": "string",
      "enum": [
        "project_docs",
        "generated_reference",
        "mirrored_official_docs",
        "curated_knowledge_pack",
        "derived_explanation",
        "vendor_provider_docs",
        "support_runbook",
        "external_status_feed"
      ],
      "description": "Re-exported from schemas/docs/help_status_badge.schema.json without modification (ADR-0013)."
    },

    "exact_build_applicability": {
      "type": "string",
      "enum": [
        "same_build_only",
        "compatible_minor_window",
        "release_channel_window",
        "not_build_bound"
      ],
      "description": "Re-exported from schemas/docs/destination_descriptor.schema.json without modification."
    },

    "version_match_state": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ],
      "description": "Re-exported from schemas/docs/help_status_badge.schema.json without modification (ADR-0013)."
    },

    "support_class": {
      "type": "string",
      "enum": [
        "best_effort",
        "community_supported",
        "standard_support",
        "extended_support",
        "operator_only_support",
        "no_support"
      ],
      "description": "Re-exported from schemas/docs/destination_descriptor.schema.json and schemas/governance/capability_lifecycle.schema.json without modification."
    },

    "client_scope": {
      "type": "string",
      "enum": [
        "desktop_product",
        "cli",
        "companion_surface",
        "remote_agent",
        "sdk_or_api",
        "managed_admin_surface"
      ],
      "description": "Re-exported from schemas/docs/help_status_badge.schema.json without modification (ADR-0013)."
    },

    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ],
      "description": "Re-exported from schemas/docs/help_status_badge.schema.json without modification (ADR-0013)."
    },

    "availability_state": {
      "type": "string",
      "enum": [
        "available",
        "cached_snapshot",
        "mirror_only",
        "local_only_continuation",
        "not_installed",
        "version_mismatched",
        "unreachable",
        "policy_blocked"
      ],
      "description": "Re-exported from schemas/docs/destination_descriptor.schema.json without modification."
    },

    "service_contract_state": {
      "type": "string",
      "enum": [
        "ready",
        "degraded",
        "local_only",
        "stale",
        "contract_mismatch",
        "policy_blocked",
        "unavailable"
      ],
      "description": "Re-exported from schemas/docs/help_status_badge.schema.json without modification (ADR-0013). Null when the projection is not service-backed."
    },

    "degraded_state_cause": {
      "type": "string",
      "enum": [
        "pack_unreachable",
        "version_mismatch",
        "signature_unverified",
        "mirror_continuity_broken",
        "pack_quarantined",
        "local_only_fallback",
        "policy_blocked",
        "freshness_floor_unmet",
        "client_scope_excludes_surface",
        "derived_explanation_uncited",
        "vendor_docs_overrides_project",
        "external_status_feed_unreachable",
        "unresolved_axis"
      ],
      "description": "Re-exported from schemas/docs/help_status_badge.schema.json without modification (ADR-0013). Null only when the projection is fully green on freshness/version/service/scope."
    },

    "browser_handoff_reason_subset": {
      "type": "string",
      "enum": [
        "external_docs_or_runbook",
        "provider_consent_flow",
        "provider_admin_delegation",
        "license_or_portal_acceptance",
        "admin_only_surface",
        "step_up_required",
        "mutation_not_supported_in_product"
      ],
      "description": "Re-exported from schemas/docs/help_status_badge.schema.json without modification (ADR-0013)."
    },

    "external_open_policy": {
      "type": "string",
      "enum": [
        "not_permitted",
        "optional_same_object",
        "required_primary_route",
        "required_fallback_when_in_product_unavailable"
      ],
      "description": "Re-exported from schemas/docs/destination_descriptor.schema.json without modification."
    },

    "disclosure_safety_class": {
      "type": "string",
      "enum": [
        "screenshot_safe_export_safe",
        "local_only_diagnostic_only"
      ],
      "description": "Re-exported from schemas/docs/destination_descriptor.schema.json without modification."
    },

    "community_handoff_route_class": {
      "type": "string",
      "enum": [
        "public_issue_tracker",
        "public_rfc_forum",
        "private_security_channel",
        "private_partner_channel",
        "private_support_channel",
        "benchmark_council_queue",
        "governance_packet_queue"
      ],
      "description": "Re-exported from schemas/about/about_card.schema.json without modification."
    },

    "community_handoff_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_class",
        "destination_descriptor_ref"
      ],
      "properties": {
        "route_class": { "$ref": "#/$defs/community_handoff_route_class" },
        "destination_descriptor_ref": { "$ref": "#/$defs/opaque_id" }
      },
      "description": "Community/support routing disclosure. Surfaces that offer a community handoff MUST surface the same route_class and the same destination_descriptor_ref as About."
    },

    "help_badge_projection_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "help_badge_projection_schema_version",
        "projection_id",
        "surface_class",
        "source_class",
        "exact_build_applicability",
        "running_build_identity_ref",
        "version_match_state",
        "support_class",
        "client_scopes",
        "freshness_class",
        "availability_state",
        "service_contract_state",
        "degraded_state_cause",
        "external_open_policy",
        "browser_handoff_reason",
        "disclosure_safety_class",
        "community_handoff_route",
        "release_center_event_ref",
        "release_center_exact_build_identity_ref",
        "minted_at"
      ],
      "properties": {
        "__fixture__": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional worked-fixture prelude. Runtime producers omit this field."
        },
        "record_kind": { "const": "help_badge_projection_record" },
        "help_badge_projection_schema_version": {
          "$ref": "#/$defs/help_badge_projection_schema_version"
        },
        "projection_id": { "$ref": "#/$defs/opaque_id" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "exact_build_applicability": { "$ref": "#/$defs/exact_build_applicability" },
        "running_build_identity_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Opaque ref to the running build's exact-build identity. Null only when exact_build_applicability = not_build_bound."
        },
        "version_match_state": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/version_match_state" }
          ],
          "description": "Null only when exact_build_applicability = not_build_bound."
        },
        "support_class": { "$ref": "#/$defs/support_class" },
        "client_scopes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/client_scope" }
        },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "availability_state": { "$ref": "#/$defs/availability_state" },
        "service_contract_state": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/service_contract_state" }
          ]
        },
        "degraded_state_cause": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/degraded_state_cause" }
          ]
        },
        "external_open_policy": { "$ref": "#/$defs/external_open_policy" },
        "browser_handoff_reason": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/browser_handoff_reason_subset" }
          ]
        },
        "disclosure_safety_class": { "$ref": "#/$defs/disclosure_safety_class" },
        "community_handoff_route": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/community_handoff_route" }
          ]
        },
        "release_center_event_ref": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Opaque release-center event ref when this projection is release-bearing or references release-center history. Null when not applicable."
        },
        "release_center_exact_build_identity_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Exact-build identity ref quoted from a release-center backreference when present. When present, it MUST match running_build_identity_ref for build-bound projections."
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    },

    "axis_name": {
      "type": "string",
      "enum": [
        "source_class",
        "exact_build_applicability",
        "running_build_identity_ref",
        "version_match_state",
        "support_class",
        "client_scopes",
        "freshness_class",
        "availability_state",
        "service_contract_state",
        "degraded_state_cause",
        "external_open_policy",
        "browser_handoff_reason",
        "disclosure_safety_class",
        "community_handoff_route",
        "release_center_event_ref",
        "release_center_exact_build_identity_ref"
      ],
      "description": "Closed axis-name set used by parity cases to declare what must match."
    },

    "allowed_axis_disagreement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axis", "rationale"],
      "properties": {
        "axis": { "$ref": "#/$defs/axis_name" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },

    "docs_help_about_service_health_parity_case_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "help_badge_projection_schema_version",
        "case_id",
        "parity_packet_ref",
        "parity_matrix_ref",
        "projections",
        "parity_axes_must_match",
        "allowed_axis_disagreements",
        "minted_at"
      ],
      "properties": {
        "__fixture__": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional worked-fixture prelude. Runtime producers omit this field."
        },
        "record_kind": { "const": "docs_help_about_service_health_parity_case_record" },
        "help_badge_projection_schema_version": {
          "$ref": "#/$defs/help_badge_projection_schema_version"
        },
        "case_id": { "type": "string", "minLength": 1 },
        "parity_packet_ref": { "type": "string", "minLength": 1 },
        "parity_matrix_ref": { "type": "string", "minLength": 1 },
        "projections": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/help_badge_projection_record" }
        },
        "parity_axes_must_match": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/axis_name" }
        },
        "allowed_axis_disagreements": {
          "type": "array",
          "items": { "$ref": "#/$defs/allowed_axis_disagreement" }
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    }
  }
}

