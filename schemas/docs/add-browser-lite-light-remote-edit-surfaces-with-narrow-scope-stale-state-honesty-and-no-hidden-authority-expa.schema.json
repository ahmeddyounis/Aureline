{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/add-browser-lite-light-remote-edit-surfaces-with-narrow-scope-stale-state-honesty-and-no-hidden-authority-expa.schema.json",
  "title": "Aureline browser-lite light remote edit surfaces with narrow scope, stale-state honesty, and no hidden authority expansion",
  "description": "Export-safe packet for the M5 light-remote-edit boundary. The packet carries one or more surfaces across the qualified doc_comment_edit / single_file_text_edit / config_value_edit / review_reply scopes, each with a five-chip set (source class, version match, freshness, locality, confidence), one trust-class disclosure (first_party_workspace / signed_mirror_backed_suggestion / extension_pack_suggestion / live_provider_edit_surface / derived_suggestion_only), an explicit edit intent, a non-empty return path (return-path safety), a granted-vs-effective authority pair (no hidden authority expansion), a base-state disclosure (stale-state honesty), an apply posture, a live-vs-captured state, citation state, and open-raw/open-source escapes. A surface declaring a scope outside the qualified edit scopes, dropping its return path, presenting an untrusted destination at high confidence, presenting an apply blocked by policy as available, failing to disclose a stale or unknown base, presenting a stale base at high confidence, or exercising more authority than was granted or than its scope permits blocks the claim. An export preserves scope, edit intent, return path, trust class, source class, confidence, authority, stale state, and escapes per surface. Packet-level degradations narrow or block the claim. The promotion state (stable / narrowed_below_stable / blocks_stable) is computed from validation and degradation findings. Raw page bodies, raw URLs, raw edit diffs, raw source files, raw provider payloads, and credentials never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "session_label",
    "session_digest_ref",
    "surfaces",
    "export",
    "edit_degradations",
    "consumer_projections",
    "promotion_state",
    "validation_findings",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
