      "const": "light_remote_edit_surfaces"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "session_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "session_digest_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/surface"
      }
    },
    "export": {
      "$ref": "#/$defs/export"
    },
    "edit_degradations": {
