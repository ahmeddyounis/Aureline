{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/docs-maintenance-and-stale-example-governance.schema.json",
  "title": "Aureline docs maintenance and stale-example governance packet",
  "description": "Stable metadata-only packet for docs render configs, suggestions, validation results, stale-example findings, governed suppressions, maintenance packets, and consumer projections. Raw document bodies, rendered HTML, raw URLs, provider payloads, and ambient credentials must be omitted.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "source_branch_ref",
    "release_ref",
    "channel_ref",
    "render_configs",
    "suggestions",
    "validation_results",
    "stale_example_findings",
    "maintenance_packets",
    "consumer_projections",
    "omitted_material_classes",
    "raw_boundary_material_exported",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "docs_maintenance_and_stale_example_governance_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/ref" },
    "generated_at": { "$ref": "#/$defs/ref" },
    "source_branch_ref": { "$ref": "#/$defs/ref" },
    "release_ref": { "$ref": "#/$defs/ref" },
    "channel_ref": { "$ref": "#/$defs/ref" },
    "render_configs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/render_config" } },
    "suggestions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/suggestion" } },
    "validation_results": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/validation_result" } },
    "stale_example_findings": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/stale_finding" } },
    "maintenance_packets": { "type": "array", "minItems": 5, "items": { "$ref": "#/$defs/maintenance_packet" } },
    "consumer_projections": { "type": "array", "minItems": 8, "items": { "$ref": "#/$defs/projection" } },
    "omitted_material_classes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } },
    "raw_boundary_material_exported": { "const": false },
    "promotion_state": { "enum": ["stable", "needs_review", "blocks_stable"] },
    "validation_findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } }
  },
  "$defs": {
    "ref": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/ref" } },
    "preview_mode": { "enum": ["source", "split", "rendered"] },
    "freshness": { "enum": ["authoritative_live", "warm_cached", "degraded_cached", "stale", "unverified"] },
    "version_match": { "enum": ["exact_build_match", "compatible_minor_drift", "incompatible_drift_detected", "pre_release_unverified", "unknown_target_build"] },
    "publish_boundary": { "enum": ["local_only", "review_handoff_scoped", "publish_handoff_scoped", "blocked_unscoped"] },
    "audience": { "enum": ["developer", "maintainer", "end_user", "release_manager", "support_operator", "enterprise_admin", "public_reader"] },
    "validation_mode": { "enum": ["rendered", "syntax_checked", "executed_locally", "executed_remotely", "unsupported", "skipped", "stale", "not_validated"] },
    "render_config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["render_config_id", "mode", "commonmark_baseline_ref", "extension_baseline", "active_content_state", "docs_source_ref", "docs_version_ref", "security_profile", "mirror_browser_handoff_posture", "rendered_preview_not_canonical", "evidence_refs"],
      "properties": {
        "render_config_id": { "$ref": "#/$defs/ref" },
        "mode": { "$ref": "#/$defs/preview_mode" },
        "commonmark_baseline_ref": { "$ref": "#/$defs/ref" },
        "extension_baseline": { "$ref": "#/$defs/string_array" },
        "active_content_state": { "enum": ["blocked", "sanitized_inert_only", "not_applicable"] },
        "docs_source_ref": { "$ref": "#/$defs/ref" },
        "docs_version_ref": { "$ref": "#/$defs/ref" },
        "security_profile": { "enum": ["source_first_safe_markdown", "mirror_offline_safe", "browser_handoff_required"] },
        "mirror_browser_handoff_posture": { "enum": ["local_only", "mirrored_offline", "browser_handoff_available", "browser_handoff_blocked"] },
        "browser_handoff_packet_ref": { "$ref": "#/$defs/ref" },
        "rendered_preview_not_canonical": { "type": "boolean" },
        "evidence_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } }
      }
    },
    "suggestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suggestion_id", "target_artifact_ref", "trigger", "evidence_refs", "diff_ref", "confidence_class", "freshness_class", "audience_scope", "share_export_posture", "publish_boundary_state", "publish_boundary_note"],
      "properties": {
        "suggestion_id": { "$ref": "#/$defs/ref" },
        "target_artifact_ref": { "$ref": "#/$defs/ref" },
        "target_section_ref": { "$ref": "#/$defs/ref" },
        "trigger": { "enum": ["code_diff", "stale_example", "release_note_drift", "failing_snippet", "contract_change", "human_note"] },
        "evidence_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } },
        "diff_ref": { "$ref": "#/$defs/ref" },
        "confidence_class": { "enum": ["evidence_backed", "inferred", "low_confidence", "unknown_unverified"] },
        "freshness_class": { "$ref": "#/$defs/freshness" },
        "audience_scope": { "$ref": "#/$defs/audience" },
        "share_export_posture": { "enum": ["reference_only_exportable", "review_packet_exportable", "public_publish_blocked"] },
        "publish_boundary_state": { "$ref": "#/$defs/publish_boundary" },
        "publish_boundary_note": { "$ref": "#/$defs/ref" }
      }
    },
    "validation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation_result_id", "artifact_or_snippet_ref", "validation_mode", "outcome", "toolchain_context_ref", "output_snapshot_ref", "diagnostics_refs", "freshness_class", "last_checked_at", "evidence_refs"],
      "properties": {
        "validation_result_id": { "$ref": "#/$defs/ref" },
        "artifact_or_snippet_ref": { "$ref": "#/$defs/ref" },
        "validation_mode": { "$ref": "#/$defs/validation_mode" },
        "outcome": { "enum": ["passed", "failed", "stale", "unsupported", "blocked"] },
        "toolchain_context_ref": { "$ref": "#/$defs/ref" },
        "output_snapshot_ref": { "$ref": "#/$defs/ref" },
        "diagnostics_refs": { "$ref": "#/$defs/string_array" },
        "freshness_class": { "$ref": "#/$defs/freshness" },
        "last_checked_at": { "$ref": "#/$defs/ref" },
        "evidence_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } }
      }
    },
    "stale_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_id", "finding_class", "detection_state", "validation_mode", "environment_scope_ref", "version_scope_ref", "last_checked_at", "freshness_class", "suppression_state", "evidence_refs", "publish_boundary_notes"],
      "properties": {
        "finding_id": { "$ref": "#/$defs/ref" },
        "finding_class": { "enum": ["broken_link", "stale_example", "renamed_command", "renamed_setting", "renamed_symbol", "stale_screenshot", "api_mismatch", "command_output_drift", "import_path_drift", "version_mismatch", "unverifiable_benchmark_copy", "missing_migration_note"] },
        "detection_state": { "enum": ["proven_broken", "suspected_stale", "unchanged_unverified"] },
        "validation_mode": { "$ref": "#/$defs/validation_mode" },
        "environment_scope_ref": { "$ref": "#/$defs/ref" },
        "version_scope_ref": { "$ref": "#/$defs/ref" },
        "last_checked_at": { "$ref": "#/$defs/ref" },
        "freshness_class": { "$ref": "#/$defs/freshness" },
        "suppression_state": { "enum": ["active", "suppressed_until_reviewed", "acknowledged", "resolved"] },
        "suppression": { "$ref": "#/$defs/suppression" },
        "evidence_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } },
        "publish_boundary_notes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } }
      }
    },
    "suppression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_ref", "reason", "expiry_at", "evidence_refs"],
      "properties": {
        "actor_ref": { "$ref": "#/$defs/ref" },
        "reason": { "$ref": "#/$defs/ref" },
        "expiry_at": { "$ref": "#/$defs/ref" },
        "evidence_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } }
      }
    },
    "publish_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "branch_scope": { "$ref": "#/$defs/ref" },
        "release_scope": { "$ref": "#/$defs/ref" },
        "channel_scope": { "$ref": "#/$defs/ref" }
      }
    },
    "maintenance_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maintenance_packet_id", "artifact_class", "artifact_ref", "docs_source_ref", "docs_version_ref", "audience_scope", "publish_scope", "validation_result_refs", "pending_suggestion_refs", "stale_finding_refs", "validation_freshness", "version_match_state", "publish_boundary_state", "publish_boundary_notes", "share_export_posture", "surface_refs"],
      "properties": {
        "maintenance_packet_id": { "$ref": "#/$defs/ref" },
        "artifact_class": { "enum": ["readme", "changelog", "onboarding", "module_docs", "support_article"] },
        "artifact_ref": { "$ref": "#/$defs/ref" },
        "docs_source_ref": { "$ref": "#/$defs/ref" },
        "docs_version_ref": { "$ref": "#/$defs/ref" },
        "audience_scope": { "$ref": "#/$defs/audience" },
        "publish_scope": { "$ref": "#/$defs/publish_scope" },
        "validation_result_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } },
        "pending_suggestion_refs": { "$ref": "#/$defs/string_array" },
        "stale_finding_refs": { "$ref": "#/$defs/string_array" },
        "validation_freshness": { "$ref": "#/$defs/freshness" },
        "version_match_state": { "$ref": "#/$defs/version_match" },
        "publish_boundary_state": { "$ref": "#/$defs/publish_boundary" },
        "publish_boundary_notes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } },
        "share_export_posture": { "enum": ["reference_only_exportable", "review_packet_exportable", "public_publish_blocked"] },
        "surface_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } }
      }
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "packet_id_ref", "maintenance_packet_refs", "preserves_source_version_refs", "preserves_validation_freshness", "preserves_stale_findings_and_suppressions", "preserves_publish_boundary_and_handoff", "preserves_destination_vocabulary"],
      "properties": {
        "surface": { "enum": ["help_about", "onboarding_cards", "migration_guidance", "release_notes", "docs_feedback_export", "support_community_handoff", "docs_pack", "cli_headless"] },
        "packet_id_ref": { "$ref": "#/$defs/ref" },
        "maintenance_packet_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } },
        "preserves_source_version_refs": { "type": "boolean" },
        "preserves_validation_freshness": { "type": "boolean" },
        "preserves_stale_findings_and_suppressions": { "type": "boolean" },
        "preserves_publish_boundary_and_handoff": { "type": "boolean" },
        "preserves_destination_vocabulary": { "type": "boolean" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_kind", "object_ref", "summary"],
      "properties": {
        "finding_kind": { "type": "string" },
        "object_ref": { "$ref": "#/$defs/ref" },
        "summary": { "$ref": "#/$defs/ref" }
      }
    }
  }
}
