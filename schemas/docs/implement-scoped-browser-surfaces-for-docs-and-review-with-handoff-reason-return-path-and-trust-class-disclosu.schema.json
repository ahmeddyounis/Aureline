{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/docs/implement-scoped-browser-surfaces-for-docs-and-review-with-handoff-reason-return-path-and-trust-class-disclosu.schema.json",
  "title": "Aureline scoped browser surfaces for docs and review with handoff reason, return path, and trust-class disclosure",
  "description": "Export-safe packet for the M5 scoped-browser-surface boundary. The packet carries one or more surfaces across the qualified docs_reading / review / light_edit scopes, each with a five-chip set (source class, version match, freshness, locality, confidence), one trust-class disclosure (first_party_authoritative / signed_mirror_verified / extension_pack_signed / live_provider_handoff / derived_inference_only), an explicit handoff reason, a non-empty return path (return-path safety), a handoff-capability posture, a live-vs-captured state, citation state, and open-raw/open-source escapes. A surface declaring a scope outside docs/review/light-edit, dropping its return path, presenting an untrusted destination at high confidence, or presenting a policy-blocked handoff as available blocks the claim. An export preserves scope, handoff reason, return path, trust class, source class, confidence, and escapes per surface. Packet-level degradations narrow or block the claim. The promotion state (stable / narrowed_below_stable / blocks_stable) is computed from validation and degradation findings. Raw page bodies, raw URLs, raw review payloads, raw source files, raw provider payloads, and credentials never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "session_label",
    "session_digest_ref",
    "surfaces",
    "export",
    "browser_degradations",
    "consumer_projections",
    "promotion_state",
    "validation_findings",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "scoped_browser_surfaces_for_docs_and_review"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "session_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "session_digest_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/surface"
      }
    },
    "export": {
      "$ref": "#/$defs/export"
    },
    "browser_degradations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/browser_degradation"
      }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/consumer_projection"
      }
    },
    "promotion_state": {
      "$ref": "#/$defs/promotion_state"
    },
    "validation_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation_finding"
      }
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "enum": [
        "docs_reading",
        "review",
        "light_edit",
        "general_web",
        "full_browser_runtime"
      ]
    },
    "handoff_reason_kind": {
      "type": "string",
      "enum": [
        "exact_anchor_unavailable_locally",
        "live_version_newer_than_mirror",
        "source_not_mirrored",
        "review_thread_requires_hosted_view",
        "light_edit_requires_scoped_editor",
        "user_requested_open_in_browser"
      ]
    },
    "return_path_kind": {
      "type": "string",
      "enum": [
        "back_to_inline_peek",
        "back_to_docs_browser",
        "back_to_review_panel",
        "back_to_workspace"
      ]
    },
    "trust_class": {
      "type": "string",
      "enum": [
        "first_party_authoritative",
        "signed_mirror_verified",
        "extension_pack_signed",
        "live_provider_handoff",
        "derived_inference_only"
      ]
    },
    "handoff_capability": {
      "type": "string",
      "enum": [
        "not_required_local",
        "available_explicit",
        "blocked_by_policy",
        "unavailable_disclosed"
      ]
    },
    "captured_vs_live": {
      "type": "string",
      "enum": [
        "live",
        "captured_snapshot",
        "narrowed_scope_rerun"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "project_docs",
        "mirrored_official_docs",
        "extension_docs_pack",
        "live_external_docs",
        "review_host",
        "generated_reference",
        "derived_explanation"
      ]
    },
    "version_match": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified",
        "refresh_pending"
      ]
    },
    "locality": {
      "type": "string",
      "enum": [
        "local",
        "mirrored_pack",
        "remote_helper",
        "managed"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "heuristic"
      ]
    },
    "finding_severity": {
      "type": "string",
      "enum": [
        "blocking",
        "narrowing",
        "advisory"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "docs_browser_shell",
        "review_surface",
        "browser_handoff_packet",
        "peek_overlay",
        "ai_context_inspector",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about"
      ]
    },
    "browser_degradation_class": {
      "type": "string",
      "enum": [
        "mirror_offline_snapshot",
        "live_provider_unreachable_captured_snapshot",
        "handoff_blocked_by_policy",
        "return_path_degraded",
        "scope_narrowed_rerun",
        "broken_anchor",
        "quarantined_source"
      ]
    },
    "export_scope": {
      "type": "string",
      "enum": [
        "all_surfaces",
        "docs_reading_only",
        "review_only",
        "light_edit_only"
      ]
    },
    "promotion_state": {
      "type": "string",
      "enum": [
        "stable",
        "narrowed_below_stable",
        "blocks_stable"
      ]
    },
    "validation_finding_kind": {
      "type": "string",
      "enum": [
        "missing_identity",
        "surfaces_empty",
        "duplicate_surface_id",
        "required_scope_missing",
        "surface_scope_out_of_bounds",
        "surface_title_or_headline_missing",
        "handoff_reason_missing",
        "return_path_missing",
        "trust_class_disclosure_missing",
        "trust_class_disclosure_collapsed",
        "blocked_handoff_presented_available",
        "open_raw_open_source_escape_missing",
        "surface_not_cited",
        "version_truth_collapsed",
        "export_row_orphan",
        "export_coverage_missing",
        "export_drops_preservation",
        "export_scope_mismatch",
        "export_trust_class_mismatch",
        "export_source_class_mismatch",
        "export_confidence_mismatch",
        "export_return_path_mismatch",
        "degradation_incomplete",
        "degradation_orphan",
        "consumer_projection_drift",
        "consumer_projection_packet_id_mismatch",
        "required_surface_coverage_missing",
        "raw_boundary_material_present"
      ]
    },
    "chip_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "version_match",
        "freshness",
        "locality",
        "confidence"
      ],
      "properties": {
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "version_match": {
          "$ref": "#/$defs/version_match"
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        },
        "locality": {
          "$ref": "#/$defs/locality"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "handoff_reason": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason_kind",
        "note"
      ],
      "properties": {
        "reason_kind": {
          "$ref": "#/$defs/handoff_reason_kind"
        },
        "note": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "return_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "return_kind",
        "return_ref",
        "label"
      ],
      "properties": {
        "return_kind": {
          "$ref": "#/$defs/return_path_kind"
        },
        "return_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "scope",
        "subject_ref",
        "title",
        "headline",
        "chips",
        "trust_class",
        "trust_disclosure_note",
        "handoff_reason",
        "return_path",
        "handoff_capability",
        "captured_vs_live",
        "cited",
        "open_raw_escape_ref",
        "open_source_escape_ref"
      ],
      "properties": {
        "surface_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "subject_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "headline": {
          "$ref": "#/$defs/non_empty_string"
        },
        "chips": {
          "$ref": "#/$defs/chip_set"
        },
        "trust_class": {
          "$ref": "#/$defs/trust_class"
        },
        "trust_disclosure_note": {
          "$ref": "#/$defs/non_empty_string"
        },
        "handoff_reason": {
          "$ref": "#/$defs/handoff_reason"
        },
        "return_path": {
          "$ref": "#/$defs/return_path"
        },
        "handoff_capability": {
          "$ref": "#/$defs/handoff_capability"
        },
        "captured_vs_live": {
          "$ref": "#/$defs/captured_vs_live"
        },
        "cited": {
          "type": "boolean"
        },
        "citation_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_raw_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_source_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "export_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id_ref",
        "scope",
        "trust_class",
        "source_class",
        "confidence",
        "handoff_capability",
        "has_return_path",
        "cited",
        "open_raw_escape_ref",
        "open_source_escape_ref"
      ],
      "properties": {
        "surface_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "trust_class": {
          "$ref": "#/$defs/trust_class"
        },
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "handoff_capability": {
          "$ref": "#/$defs/handoff_capability"
        },
        "has_return_path": {
          "type": "boolean"
        },
        "cited": {
          "type": "boolean"
        },
        "open_raw_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_source_escape_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "preserves_scope",
        "preserves_handoff_reason",
        "preserves_return_path",
        "preserves_trust_class",
        "preserves_source_class",
        "preserves_confidence",
        "preserves_open_raw_open_source_escape",
        "rows"
      ],
      "properties": {
        "scope": {
          "$ref": "#/$defs/export_scope"
        },
        "preserves_scope": {
          "type": "boolean"
        },
        "preserves_handoff_reason": {
          "type": "boolean"
        },
        "preserves_return_path": {
          "type": "boolean"
        },
        "preserves_trust_class": {
          "type": "boolean"
        },
        "preserves_source_class": {
          "type": "boolean"
        },
        "preserves_confidence": {
          "type": "boolean"
        },
        "preserves_open_raw_open_source_escape": {
          "type": "boolean"
        },
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/export_row"
          }
        }
      }
    },
    "browser_degradation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "degradation_class",
        "severity",
        "summary"
      ],
      "properties": {
        "degradation_class": {
          "$ref": "#/$defs/browser_degradation_class"
        },
        "severity": {
          "$ref": "#/$defs/finding_severity"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "packet_id_ref",
        "preserves_chips",
        "preserves_scopes",
        "preserves_trust_classes",
        "preserves_handoff_reasons",
        "preserves_return_paths",
        "preserves_open_raw_open_source_escape"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/consumer_surface"
        },
        "packet_id_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preserves_chips": {
          "type": "boolean"
        },
        "preserves_scopes": {
          "type": "boolean"
        },
        "preserves_trust_classes": {
          "type": "boolean"
        },
        "preserves_handoff_reasons": {
          "type": "boolean"
        },
        "preserves_return_paths": {
          "type": "boolean"
        },
        "preserves_open_raw_open_source_escape": {
          "type": "boolean"
        }
      }
    },
    "validation_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_kind",
        "severity",
        "summary"
      ],
      "properties": {
        "finding_kind": {
          "$ref": "#/$defs/validation_finding_kind"
        },
        "severity": {
          "$ref": "#/$defs/finding_severity"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
