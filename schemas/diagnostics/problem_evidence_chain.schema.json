        },
        "target_context": { "$ref": "#/$defs/target_context" },
        "freshness": { "$ref": "#/$defs/freshness_state" },
        "remap_state": { "$ref": "#/$defs/remap_state" },
        "confidence": { "$ref": "#/$defs/confidence_projection" },
        "correlation_basis": { "$ref": "#/$defs/correlation_basis" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_ref" }
        },
        "collapse_projection": { "$ref": "#/$defs/collapse_projection" },
        "export_projection": { "$ref": "#/$defs/export_projection" },
        "chronology": { "$ref": "#/$defs/chronology" },
        "aggregate_counts": { "$ref": "#/$defs/aggregate_counts" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    }
  }
}
