{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/diagnostics/diagnostic_anchor_remap.schema.json",
  "title": "Aureline diagnostic anchor remap record",
  "description": "Boundary schema for append-only anchor-remap evidence used by the unified diagnostic plane. The record names the old and current anchor refs, remap state, evidence basis, revision pair, actor/tool, and export-safe summary without carrying raw source text, raw paths, raw scanner payloads, raw command lines, URLs, logs, or secret material.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "diagnostic_anchor_remap_schema_version",
    "remap_id",
    "anchor_family_id",
    "original_anchor_ref",
    "current_anchor_ref",
    "remap_state_class",
    "evidence_basis_ref",
    "source_revision_ref",
    "current_revision_ref",
    "actor_tool_ref",
    "produced_at",
    "export_safe_summary"
  ],
  "properties": {
    "record_kind": { "const": "diagnostic_anchor_remap" },
    "diagnostic_anchor_remap_schema_version": { "type": "integer", "const": 1 },
    "remap_id": { "$ref": "#/$defs/opaque_id" },
    "anchor_family_id": { "$ref": "#/$defs/opaque_id" },
    "original_anchor_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
    "current_anchor_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
    "remap_state_class": { "$ref": "#/$defs/remap_state_class" },
    "evidence_basis_ref": { "$ref": "#/$defs/opaque_ref" },
    "source_revision_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
    "current_revision_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
    "actor_tool_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
    "produced_at": { "$ref": "#/$defs/timestamp" },
    "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
  },
  "$defs": {
    "opaque_id": { "type": "string", "minLength": 1 },
    "opaque_ref": { "type": "string", "minLength": 1 },
    "opaque_ref_nullable": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 720
    },
    "remap_state_class": {
      "type": "string",
      "enum": [
        "exact",
        "contextual",
        "stale",
        "unmapped",
        "imported_static"
      ]
    }
  }
}
