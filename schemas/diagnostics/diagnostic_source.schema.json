{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/diagnostics/diagnostic_source.schema.json",
  "title": "Aureline diagnostic source descriptor",
  "description": "Boundary schema for the diagnostic_source record used by the unified diagnostic plane. It preserves source kind, evidence plane, live/imported origin, tool and adapter version metadata, target or environment fingerprint, originating session or import refs, confidence, support class, and raw-payload backlink refs without carrying raw source text, raw logs, raw command lines, raw paths, raw URLs, provider payload bodies, or secret material.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "diagnostic_source_schema_version",
    "source_id",
    "source_kind",
    "evidence_plane_class",
    "origin_class",
    "confidence_class",
    "support_class",
    "producer_ref",
    "tool_ref",
    "tool_version_ref",
    "adapter_ref",
    "adapter_version_ref",
    "target_or_environment_ref",
    "originating_session_ref",
    "import_ref",
    "run_ref",
    "task_ref",
    "raw_payload_ref",
    "export_safe_summary"
  ],
  "properties": {
    "record_kind": { "const": "diagnostic_source" },
    "diagnostic_source_schema_version": { "type": "integer", "const": 1 },
    "source_id": { "$ref": "#/$defs/opaque_id" },
    "source_kind": { "$ref": "#/$defs/source_kind" },
    "evidence_plane_class": { "$ref": "#/$defs/evidence_plane_class" },
    "origin_class": { "$ref": "#/$defs/origin_class" },
    "confidence_class": { "$ref": "#/$defs/confidence_class" },
    "support_class": { "$ref": "#/$defs/support_class" },
    "producer_ref": { "$ref": "#/$defs/opaque_ref" },
    "tool_ref": { "$ref": "#/$defs/opaque_ref" },
    "tool_version_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
    "adapter_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
    "adapter_version_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
    "target_or_environment_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
    "originating_session_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
    "import_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
    "run_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
    "task_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
    "raw_payload_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
    "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
  },
  "$defs": {
    "opaque_id": { "type": "string", "minLength": 1 },
    "opaque_ref": { "type": "string", "minLength": 1 },
    "opaque_ref_nullable": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 720,
      "description": "Export-safe summary. Raw source, raw output, raw logs, raw paths, raw URLs, command lines, provider payload bodies, and secret material are forbidden."
    },
    "source_kind": {
      "type": "string",
      "enum": [
        "editor_structural",
        "language_service",
        "build_or_task",
        "runtime_or_test",
        "scanner_import",
        "policy",
        "heuristic"
      ]
    },
    "evidence_plane_class": {
      "type": "string",
      "enum": [
        "static_analysis",
        "build_time_execution",
        "runtime_or_test_execution",
        "policy_or_trust_evaluation",
        "imported_snapshot_evidence",
        "heuristic_fallback"
      ]
    },
    "origin_class": {
      "type": "string",
      "enum": [
        "live_local_session",
        "live_remote_session",
        "managed_provider_live",
        "imported_snapshot",
        "replayed_support_bundle",
        "local_cache"
      ]
    },
    "confidence_class": {
      "type": "string",
      "enum": [
        "authoritative",
        "derived_structured",
        "imported_authoritative",
        "heuristic_parsed",
        "correlated_suggestive",
        "unknown_requires_review"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "authoritative",
        "advisory",
        "fallback_only",
        "inspect_only",
        "unsupported"
      ]
    }
  }
}
