{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/diagnostics/heuristic_confidence.schema.json",
  "title": "Aureline heuristic-confidence taxonomy and projection contract",
  "description": "Boundary schema for the shared heuristic-confidence vocabulary used by problem/output/evidence chains, diagnostics views, support bundles, review packets, release packets, CLI JSON, and AI context packets. The taxonomy prevents heuristic parses, imported snapshots, derived projections, and correlated multi-signal incidents from masquerading as exact source truth. Raw output bodies, raw logs, raw source text, raw paths, raw URLs, command lines, environment bodies, and secret material never cross this boundary; records carry stable refs, class labels, required disclosure copy, downgrade triggers, and export-safe summaries only.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/heuristic_confidence_taxonomy_record" },
    { "$ref": "#/$defs/heuristic_confidence_projection_record" }
  ],
  "$defs": {
    "heuristic_confidence_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this confidence taxonomy. Adding an optional field or enum value is additive-minor and bumps this const; repurposing a value is breaking and requires a new decision row."
    },
    "taxonomy_record_kind": {
      "type": "string",
      "const": "heuristic_confidence_taxonomy_record"
    },
    "projection_record_kind": {
      "type": "string",
      "const": "heuristic_confidence_projection_record"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe to log and export. Raw paths, raw URLs, raw output, and secret material never appear here."
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480,
      "description": "Export-safe human-readable sentence. It must not contain raw output bodies, raw source text, raw paths, raw URLs, command lines, environment bodies, or secret material."
    },
    "confidence_class": {
      "type": "string",
      "enum": [
        "exact",
        "imported_authoritative",
        "derived_structured",
        "heuristic_parsed",
        "correlated_suggestive",
        "unknown"
      ],
      "description": "Closed confidence vocabulary shared by problem evidence chains and all export surfaces."
    },
    "confidence_label": {
      "type": "string",
      "enum": [
        "Exact",
        "Imported authoritative",
        "Derived structured",
        "Heuristic parsed",
        "Correlated suggestive",
        "Unknown"
      ]
    },
    "source_truth_ceiling_class": {
      "type": "string",
      "enum": [
        "source_truth_preserved",
        "source_truth_imported_read_only",
        "source_truth_derived_from_structured",
        "source_truth_inferred_from_output",
        "source_truth_correlated_not_proven",
        "source_truth_unknown"
      ]
    },
    "downgrade_trigger_class": {
      "type": "string",
      "enum": [
        "source_record_missing",
        "raw_or_sanitized_backlink_missing",
        "raw_payload_redacted_beyond_review",
        "source_imported_not_local",
        "source_stale_or_superseded",
        "anchor_remapped_or_unmapped",
        "target_context_missing",
        "structured_field_loss",
        "truncated_or_sampled_output",
        "heuristic_parser_used",
        "correlation_without_causality",
        "contradictory_evidence_present",
        "local_rerun_conflict",
        "mapping_quality_below_floor",
        "confidence_unknown_requires_review"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "local_diagnosis_view",
        "problems_row",
        "output_viewer",
        "support_bundle",
        "review_packet",
        "release_packet",
        "cli_json",
        "ai_context_packet"
      ]
    },
    "taxonomy_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confidence_class",
        "label",
        "source_truth_ceiling_class",
        "may_claim",
        "required_copy",
        "downgrade_behavior",
        "export_copy_requirement",
        "forbidden_claims"
      ],
      "properties": {
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "label": { "$ref": "#/$defs/confidence_label" },
        "source_truth_ceiling_class": { "$ref": "#/$defs/source_truth_ceiling_class" },
        "may_claim": { "$ref": "#/$defs/short_sentence" },
        "required_copy": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/short_sentence" }
        },
        "downgrade_behavior": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgrade_trigger_class" },
          "uniqueItems": true
        },
        "export_copy_requirement": { "$ref": "#/$defs/short_sentence" },
        "forbidden_claims": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/short_sentence" }
        }
      }
    },
    "surface_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "must_cite_confidence_class",
        "must_cite_required_copy",
        "may_replace_label_with_local_adjective",
        "summary"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "must_cite_confidence_class": { "type": "boolean", "const": true },
        "must_cite_required_copy": { "type": "boolean", "const": true },
        "may_replace_label_with_local_adjective": { "type": "boolean", "const": false },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "heuristic_confidence_taxonomy_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "heuristic_confidence_schema_version",
        "taxonomy_id",
        "issued_at",
        "entries",
        "surface_rules",
        "summary"
      ],
      "properties": {
        "record_kind": { "$ref": "#/$defs/taxonomy_record_kind" },
        "heuristic_confidence_schema_version": {
          "$ref": "#/$defs/heuristic_confidence_schema_version"
        },
        "taxonomy_id": { "$ref": "#/$defs/opaque_id" },
        "issued_at": { "$ref": "#/$defs/timestamp" },
        "entries": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": { "$ref": "#/$defs/taxonomy_entry" },
          "allOf": [
            {
              "contains": {
                "type": "object",
                "required": ["confidence_class"],
                "properties": { "confidence_class": { "const": "exact" } }
              },
              "minContains": 1
            },
            {
              "contains": {
                "type": "object",
                "required": ["confidence_class"],
                "properties": { "confidence_class": { "const": "imported_authoritative" } }
              },
              "minContains": 1
            },
            {
              "contains": {
                "type": "object",
                "required": ["confidence_class"],
                "properties": { "confidence_class": { "const": "derived_structured" } }
              },
              "minContains": 1
            },
            {
              "contains": {
                "type": "object",
                "required": ["confidence_class"],
                "properties": { "confidence_class": { "const": "heuristic_parsed" } }
              },
              "minContains": 1
            },
            {
              "contains": {
                "type": "object",
                "required": ["confidence_class"],
                "properties": { "confidence_class": { "const": "correlated_suggestive" } }
              },
              "minContains": 1
            },
            {
              "contains": {
                "type": "object",
                "required": ["confidence_class"],
                "properties": { "confidence_class": { "const": "unknown" } }
              },
              "minContains": 1
            }
          ]
        },
        "surface_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_rule" }
        },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "heuristic_confidence_projection_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "heuristic_confidence_schema_version",
        "projection_id",
        "subject_ref",
        "confidence_class",
        "label",
        "source_truth_ceiling_class",
        "required_disclosure",
        "downgrade_applied",
        "downgrade_triggers",
        "source_record_refs",
        "summary"
      ],
      "properties": {
        "record_kind": { "$ref": "#/$defs/projection_record_kind" },
        "heuristic_confidence_schema_version": {
          "$ref": "#/$defs/heuristic_confidence_schema_version"
        },
        "projection_id": { "$ref": "#/$defs/opaque_id" },
        "subject_ref": { "$ref": "#/$defs/opaque_ref" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "label": { "$ref": "#/$defs/confidence_label" },
        "source_truth_ceiling_class": { "$ref": "#/$defs/source_truth_ceiling_class" },
        "required_disclosure": { "$ref": "#/$defs/short_sentence" },
        "downgrade_applied": { "type": "boolean" },
        "downgrade_triggers": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_trigger_class" },
          "uniqueItems": true
        },
        "source_record_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    }
  }
}
