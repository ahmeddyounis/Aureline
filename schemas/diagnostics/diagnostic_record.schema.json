{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/diagnostics/diagnostic_record.schema.json",
  "title": "Aureline unified diagnostic record plane",
  "description": "Boundary schema for canonical diagnostic records, surface projections, clusters, support-export references, AI-evidence references, and plane snapshots. Editor squiggles, Problems rows, output/timeline entries, review packets, CLI explain output, AI evidence, and support exports cite the same diagnostic_id and preserve source kind, freshness, remap state, causal lineage, tool/version metadata, support class, suppression refs, and baseline refs. Raw source text, raw output bodies, raw logs, raw paths, raw URLs, command lines, provider payload bodies, and secret material never cross this boundary by default.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/diagnostic_record" },
    { "$ref": "#/$defs/diagnostic_surface_projection" },
    { "$ref": "#/$defs/unified_diagnostic_cluster" },
    { "$ref": "#/$defs/diagnostic_support_export" },
    { "$ref": "#/$defs/diagnostic_ai_evidence_reference_packet" },
    { "$ref": "#/$defs/unified_diagnostic_plane_snapshot" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "opaque_id": { "type": "string", "minLength": 1 },
    "opaque_ref": { "type": "string", "minLength": 1 },
    "opaque_ref_nullable": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 840,
      "description": "Export-safe summary. Raw source, output, logs, paths, URLs, command lines, provider payload bodies, and secret material are forbidden."
    },
    "source_kind": {
      "type": "string",
      "enum": [
        "editor_structural",
        "language_service",
        "build_or_task",
        "runtime_or_test",
        "scanner_import",
        "policy",
        "heuristic"
      ]
    },
    "evidence_plane_class": {
      "type": "string",
      "enum": [
        "static_analysis",
        "build_time_execution",
        "runtime_or_test_execution",
        "policy_or_trust_evaluation",
        "imported_snapshot_evidence",
        "heuristic_fallback"
      ]
    },
    "origin_class": {
      "type": "string",
      "enum": [
        "live_local_session",
        "live_remote_session",
        "managed_provider_live",
        "imported_snapshot",
        "replayed_support_bundle",
        "local_cache"
      ]
    },
    "source_confidence_class": {
      "type": "string",
      "enum": [
        "authoritative",
        "derived_structured",
        "imported_authoritative",
        "heuristic_parsed",
        "correlated_suggestive",
        "unknown_requires_review"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "authoritative",
        "advisory",
        "fallback_only",
        "inspect_only",
        "unsupported"
      ]
    },
    "severity_class": {
      "type": "string",
      "enum": ["error", "warning", "notice", "hint"]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "recent",
        "warm_cached",
        "degraded_cached",
        "stale",
        "superseded",
        "imported_snapshot",
        "unverified"
      ]
    },
    "remap_state_class": {
      "type": "string",
      "enum": [
        "exact",
        "contextual",
        "stale",
        "unmapped",
        "imported_static"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "editor",
        "problems",
        "output",
        "review",
        "cli_explain",
        "ai_evidence",
        "support_export"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "causal_link_kind": {
      "type": "string",
      "enum": [
        "task",
        "run",
        "adapter_session",
        "import_session",
        "policy_decision",
        "output_entry",
        "timeline_entry",
        "rerun_action",
        "review_packet",
        "support_replay"
      ]
    },
    "diagnostic_causal_link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["link_kind", "causal_ref", "summary"],
      "properties": {
        "link_kind": { "$ref": "#/$defs/causal_link_kind" },
        "causal_ref": { "$ref": "#/$defs/opaque_ref" },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "diagnostic_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "diagnostic_source_schema_version",
        "source_id",
        "source_kind",
        "evidence_plane_class",
        "origin_class",
        "confidence_class",
        "support_class",
        "producer_ref",
        "tool_ref",
        "tool_version_ref",
        "adapter_ref",
        "adapter_version_ref",
        "target_or_environment_ref",
        "originating_session_ref",
        "import_ref",
        "run_ref",
        "task_ref",
        "raw_payload_ref",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": { "const": "diagnostic_source" },
        "diagnostic_source_schema_version": { "$ref": "#/$defs/schema_version" },
        "source_id": { "$ref": "#/$defs/opaque_id" },
        "source_kind": { "$ref": "#/$defs/source_kind" },
        "evidence_plane_class": { "$ref": "#/$defs/evidence_plane_class" },
        "origin_class": { "$ref": "#/$defs/origin_class" },
        "confidence_class": { "$ref": "#/$defs/source_confidence_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "producer_ref": { "$ref": "#/$defs/opaque_ref" },
        "tool_ref": { "$ref": "#/$defs/opaque_ref" },
        "tool_version_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "adapter_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "adapter_version_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "target_or_environment_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "originating_session_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "import_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "run_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "task_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "raw_payload_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "diagnostic_anchor_remap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "diagnostic_anchor_remap_schema_version",
        "remap_id",
        "anchor_family_id",
        "original_anchor_ref",
        "current_anchor_ref",
        "remap_state_class",
        "evidence_basis_ref",
        "source_revision_ref",
        "current_revision_ref",
        "actor_tool_ref",
        "produced_at",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": { "const": "diagnostic_anchor_remap" },
        "diagnostic_anchor_remap_schema_version": { "$ref": "#/$defs/schema_version" },
        "remap_id": { "$ref": "#/$defs/opaque_id" },
        "anchor_family_id": { "$ref": "#/$defs/opaque_id" },
        "original_anchor_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "current_anchor_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "remap_state_class": { "$ref": "#/$defs/remap_state_class" },
        "evidence_basis_ref": { "$ref": "#/$defs/opaque_ref" },
        "source_revision_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "current_revision_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "actor_tool_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "produced_at": { "$ref": "#/$defs/timestamp" },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "surface_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "editor_decoration_ref",
        "problems_row_ref",
        "output_entry_ref",
        "timeline_entry_ref",
        "rerun_action_ref",
        "review_packet_ref",
        "cli_explain_ref",
        "ai_evidence_ref",
        "support_export_ref"
      ],
      "properties": {
        "editor_decoration_ref": { "$ref": "#/$defs/opaque_ref" },
        "problems_row_ref": { "$ref": "#/$defs/opaque_ref" },
        "output_entry_ref": { "$ref": "#/$defs/opaque_ref" },
        "timeline_entry_ref": { "$ref": "#/$defs/opaque_ref" },
        "rerun_action_ref": { "$ref": "#/$defs/opaque_ref" },
        "review_packet_ref": { "$ref": "#/$defs/opaque_ref" },
        "cli_explain_ref": { "$ref": "#/$defs/opaque_ref" },
        "ai_evidence_ref": { "$ref": "#/$defs/opaque_ref" },
        "support_export_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "diagnostic_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "diagnostic_record_schema_version",
        "diagnostic_id",
        "rule_id_ref",
        "category_ref",
        "severity_class",
        "source",
        "freshness_class",
        "anchor_remap",
        "support_class",
        "message_ref",
        "detail_ref",
        "suppression_refs",
        "baseline_refs",
        "causal_links",
        "surface_refs",
        "redaction_class",
        "captured_at",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": { "const": "diagnostic_record" },
        "diagnostic_record_schema_version": { "$ref": "#/$defs/schema_version" },
        "diagnostic_id": { "$ref": "#/$defs/opaque_id" },
        "rule_id_ref": { "$ref": "#/$defs/opaque_ref" },
        "category_ref": { "$ref": "#/$defs/opaque_ref" },
        "severity_class": { "$ref": "#/$defs/severity_class" },
        "source": { "$ref": "#/$defs/diagnostic_source" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "anchor_remap": { "$ref": "#/$defs/diagnostic_anchor_remap" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "message_ref": { "$ref": "#/$defs/opaque_ref" },
        "detail_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "suppression_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "baseline_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "causal_links": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/diagnostic_causal_link" }
        },
        "surface_refs": { "$ref": "#/$defs/surface_refs" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "captured_at": { "$ref": "#/$defs/timestamp" },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "diagnostic_surface_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "diagnostic_record_schema_version",
        "projection_id",
        "diagnostic_id",
        "stable_surface_ref",
        "surface_class",
        "source_kind",
        "freshness_class",
        "remap_state_class",
        "source_id",
        "origin_ref",
        "open_origin_ref",
        "output_entry_ref",
        "timeline_entry_ref",
        "rerun_action_ref",
        "review_packet_ref",
        "cli_explain_ref",
        "support_export_ref",
        "ai_evidence_ref",
        "disclosure_labels",
        "raw_source_content_included",
        "raw_payload_included",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": { "const": "diagnostic_surface_projection" },
        "diagnostic_record_schema_version": { "$ref": "#/$defs/schema_version" },
        "projection_id": { "$ref": "#/$defs/opaque_id" },
        "diagnostic_id": { "$ref": "#/$defs/opaque_id" },
        "stable_surface_ref": { "$ref": "#/$defs/opaque_ref" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "source_kind": { "$ref": "#/$defs/source_kind" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "remap_state_class": { "$ref": "#/$defs/remap_state_class" },
        "source_id": { "$ref": "#/$defs/opaque_ref" },
        "origin_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "open_origin_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "output_entry_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "timeline_entry_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "rerun_action_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "review_packet_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "cli_explain_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "support_export_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "ai_evidence_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "disclosure_labels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "raw_source_content_included": { "type": "boolean", "const": false },
        "raw_payload_included": { "type": "boolean", "const": false },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "unified_diagnostic_cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "diagnostic_record_schema_version",
        "cluster_id",
        "primary_diagnostic_id",
        "contributing_diagnostic_ids",
        "dedupe_reason_ref",
        "preserved_source_kinds",
        "preserved_freshness_classes",
        "preserved_remap_states",
        "disclosure_required",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": { "const": "unified_diagnostic_cluster" },
        "diagnostic_record_schema_version": { "$ref": "#/$defs/schema_version" },
        "cluster_id": { "$ref": "#/$defs/opaque_id" },
        "primary_diagnostic_id": { "$ref": "#/$defs/opaque_id" },
        "contributing_diagnostic_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "dedupe_reason_ref": { "$ref": "#/$defs/opaque_ref" },
        "preserved_source_kinds": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_kind" },
          "uniqueItems": true
        },
        "preserved_freshness_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/freshness_class" },
          "uniqueItems": true
        },
        "preserved_remap_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/remap_state_class" },
          "uniqueItems": true
        },
        "disclosure_required": { "type": "boolean" },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "diagnostic_support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "diagnostic_record_schema_version",
        "export_id",
        "workspace_id",
        "diagnostic_record_refs",
        "source_refs",
        "remap_refs",
        "redaction_class",
        "raw_source_content_included",
        "raw_payload_included",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": { "const": "diagnostic_support_export" },
        "diagnostic_record_schema_version": { "$ref": "#/$defs/schema_version" },
        "export_id": { "$ref": "#/$defs/opaque_id" },
        "workspace_id": { "$ref": "#/$defs/opaque_id" },
        "diagnostic_record_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "remap_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "raw_source_content_included": { "type": "boolean", "const": false },
        "raw_payload_included": { "type": "boolean", "const": false },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "diagnostic_ai_evidence_reference_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "diagnostic_record_schema_version",
        "evidence_packet_id",
        "diagnostic_record_refs",
        "redaction_class",
        "raw_source_content_included",
        "raw_payload_included",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": { "const": "diagnostic_ai_evidence_reference_packet" },
        "diagnostic_record_schema_version": { "$ref": "#/$defs/schema_version" },
        "evidence_packet_id": { "$ref": "#/$defs/opaque_id" },
        "diagnostic_record_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "raw_source_content_included": { "type": "boolean", "const": false },
        "raw_payload_included": { "type": "boolean", "const": false },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "unified_diagnostic_plane_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "diagnostic_record_schema_version",
        "snapshot_id",
        "workspace_id",
        "captured_at",
        "diagnostics",
        "surface_projections",
        "clusters",
        "support_export",
        "ai_evidence",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": { "const": "unified_diagnostic_plane_snapshot" },
        "diagnostic_record_schema_version": { "$ref": "#/$defs/schema_version" },
        "snapshot_id": { "$ref": "#/$defs/opaque_id" },
        "workspace_id": { "$ref": "#/$defs/opaque_id" },
        "captured_at": { "$ref": "#/$defs/timestamp" },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic_record" }
        },
        "surface_projections": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic_surface_projection" }
        },
        "clusters": {
          "type": "array",
          "items": { "$ref": "#/$defs/unified_diagnostic_cluster" }
        },
        "support_export": { "$ref": "#/$defs/diagnostic_support_export" },
        "ai_evidence": { "$ref": "#/$defs/diagnostic_ai_evidence_reference_packet" },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    }
  }
}
