{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/state/filesystem_truth_review.schema.json",
  "title": "Filesystem truth review packet",
  "description": "Boundary schema for the packet that freezes watch-fidelity strips, ignore-resolution drawers, compare-first external-change reviews, and cross-root move reviews for M5 file-bearing surfaces. Raw file bodies, raw credentials, raw provider payloads, and raw absolute paths outside the review surface do not cross this boundary; records carry closed vocabularies, bounded summaries, and opaque logical or canonical refs only.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/packet" },
    { "$ref": "#/$defs/fixture" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "packet_record_kind": {
      "type": "string",
      "const": "filesystem_truth_review_packet_record"
    },
    "fixture_record_kind": {
      "type": "string",
      "const": "filesystem_truth_review_fixture_record"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "root_class": {
      "type": "string",
      "enum": [
        "local_filesystem",
        "remote_agent",
        "container_mount",
        "generated_managed",
        "archive_packaged",
        "virtual_provider_backed",
        "managed_offline_bundle"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "notebook_document",
        "notebook_output_artifact",
        "request_workspace_document",
        "request_response_snapshot",
        "database_export_artifact",
        "profiler_trace_artifact",
        "preview_output_artifact",
        "sync_packet_artifact",
        "provider_local_draft",
        "infrastructure_overlay_document",
        "imported_archive_capture"
      ]
    },
    "watch_mode": {
      "type": "string",
      "enum": [
        "live_watch",
        "reduced_fidelity_watch",
        "polling_fallback",
        "manual_refresh_only",
        "provider_refresh_only"
      ]
    },
    "watch_reason": {
      "type": "string",
      "enum": [
        "rename_pairing_missing",
        "remote_agent_partial_event_stream",
        "container_mount_bridge_drops_metadata",
        "generated_refresh_depends_on_source",
        "provider_change_feed_throttled"
      ]
    },
    "watch_impact": {
      "type": "string",
      "enum": [
        "external_change_detection",
        "conflict_timing",
        "generated_refresh",
        "search_freshness",
        "metadata_attribute_freshness",
        "provider_revision_freshness"
      ]
    },
    "ignore_source_class": {
      "type": "string",
      "enum": [
        "hidden_file",
        "tool_ignore",
        "workspace_exclude",
        "generated_overlay",
        "policy_hidden",
        "workset_boundary",
        "scope_limit"
      ]
    },
    "ignore_visibility_class": {
      "type": "string",
      "enum": [
        "ignore_hidden",
        "generated_overlay_hidden",
        "policy_hidden",
        "scope_limited_results"
      ]
    },
    "compare_outcome": {
      "type": "string",
      "enum": [
        "unchanged",
        "external_change_detected",
        "save_conflict",
        "wrong_target_prevented",
        "current_bytes_unavailable"
      ]
    },
    "diff_availability": {
      "type": "string",
      "enum": [
        "not_needed",
        "available",
        "binary_only",
        "current_bytes_unavailable"
      ]
    },
    "content_kind": {
      "type": "string",
      "enum": [
        "text",
        "binary",
        "unknown"
      ]
    },
    "metadata_delta_kind": {
      "type": "string",
      "enum": [
        "newline_mode_changed",
        "encoding_changed",
        "execute_bit_changed",
        "permission_mode_changed",
        "provider_revision_changed",
        "generator_revision_changed",
        "ownership_changed"
      ]
    },
    "boundary_crossing": {
      "type": "string",
      "enum": [
        "remote_authority_change",
        "container_mount_crossing",
        "symlink_or_mount_crossing",
        "generated_lineage_detach"
      ]
    },
    "metadata_consequence": {
      "type": "string",
      "enum": [
        "execute_bit_may_drop",
        "ownership_may_change",
        "permission_model_changes",
        "save_becomes_copy_then_review",
        "provider_precondition_required",
        "generated_lineage_detached"
      ]
    },
    "action_offer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "label", "enabled", "outcome_summary"],
      "properties": {
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "enabled": { "type": "boolean" },
        "outcome_summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_family", "redaction_policy", "parity_signature"],
      "properties": {
        "packet_family": { "$ref": "#/$defs/non_empty_string" },
        "redaction_policy": { "$ref": "#/$defs/non_empty_string" },
        "parity_signature": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "watch_strip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strip_id",
        "root_class",
        "surface_class",
        "root_label",
        "watch_mode",
        "reason",
        "affected_guarantees",
        "summary",
        "detail_lines",
        "actions",
        "support_export"
      ],
      "properties": {
        "strip_id": { "$ref": "#/$defs/non_empty_string" },
        "root_class": { "$ref": "#/$defs/root_class" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "root_label": { "$ref": "#/$defs/non_empty_string" },
        "watch_mode": { "$ref": "#/$defs/watch_mode" },
        "reason": {
          "oneOf": [
            { "$ref": "#/$defs/watch_reason" },
            { "type": "null" }
          ]
        },
        "affected_guarantees": {
          "type": "array",
          "items": { "$ref": "#/$defs/watch_impact" },
          "uniqueItems": true
        },
        "summary": { "$ref": "#/$defs/non_empty_string" },
        "detail_lines": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/action_offer" }
        },
        "support_export": { "$ref": "#/$defs/support_export" }
      }
    },
    "ignore_source_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_class", "source_label", "summary"],
      "properties": {
        "source_class": { "$ref": "#/$defs/ignore_source_class" },
        "source_label": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "ignore_drawer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drawer_id",
        "root_class",
        "surface_class",
        "item_label",
        "visibility_class",
        "contributing_sources",
        "scope_impact",
        "override_allowed",
        "summary",
        "detail_lines",
        "actions",
        "support_export"
      ],
      "properties": {
        "drawer_id": { "$ref": "#/$defs/non_empty_string" },
        "root_class": { "$ref": "#/$defs/root_class" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "item_label": { "$ref": "#/$defs/non_empty_string" },
        "visibility_class": { "$ref": "#/$defs/ignore_visibility_class" },
        "contributing_sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ignore_source_entry" }
        },
        "scope_impact": { "$ref": "#/$defs/non_empty_string" },
        "override_allowed": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/non_empty_string" },
        "detail_lines": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/action_offer" }
        },
        "support_export": { "$ref": "#/$defs/support_export" }
      }
    },
    "metadata_delta_note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "summary"],
      "properties": {
        "kind": { "$ref": "#/$defs/metadata_delta_kind" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "external_change_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_id",
        "root_class",
        "surface_class",
        "presentation_path",
        "logical_identity_ref",
        "pinned_canonical_target",
        "observed_canonical_target",
        "identity_note",
        "change_source",
        "compare_outcome",
        "diff_availability",
        "content_kind",
        "diff_summary",
        "diff_preview_lines",
        "metadata_delta_notes",
        "silent_overwrite_forbidden",
        "actions",
        "detail_lines",
        "support_export"
      ],
      "properties": {
        "review_id": { "$ref": "#/$defs/non_empty_string" },
        "root_class": { "$ref": "#/$defs/root_class" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "presentation_path": { "$ref": "#/$defs/non_empty_string" },
        "logical_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "pinned_canonical_target": { "$ref": "#/$defs/non_empty_string" },
        "observed_canonical_target": {
          "oneOf": [
            { "$ref": "#/$defs/non_empty_string" },
            { "type": "null" }
          ]
        },
        "identity_note": { "$ref": "#/$defs/non_empty_string" },
        "change_source": { "$ref": "#/$defs/non_empty_string" },
        "compare_outcome": { "$ref": "#/$defs/compare_outcome" },
        "diff_availability": { "$ref": "#/$defs/diff_availability" },
        "content_kind": { "$ref": "#/$defs/content_kind" },
        "diff_summary": { "$ref": "#/$defs/non_empty_string" },
        "diff_preview_lines": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "metadata_delta_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/metadata_delta_note" }
        },
        "silent_overwrite_forbidden": { "type": "boolean", "const": true },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/action_offer" }
        },
        "detail_lines": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "support_export": { "$ref": "#/$defs/support_export" }
      }
    },
    "cross_root_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_id",
        "surface_class",
        "source_root_class",
        "target_root_class",
        "operation_label",
        "source_path",
        "target_path",
        "case_sensitivity_note",
        "normalization_note",
        "boundary_crossing",
        "metadata_consequences",
        "summary",
        "detail_lines",
        "actions",
        "support_export"
      ],
      "properties": {
        "review_id": { "$ref": "#/$defs/non_empty_string" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "source_root_class": { "$ref": "#/$defs/root_class" },
        "target_root_class": { "$ref": "#/$defs/root_class" },
        "operation_label": { "$ref": "#/$defs/non_empty_string" },
        "source_path": { "$ref": "#/$defs/non_empty_string" },
        "target_path": { "$ref": "#/$defs/non_empty_string" },
        "case_sensitivity_note": { "$ref": "#/$defs/non_empty_string" },
        "normalization_note": {
          "oneOf": [
            { "$ref": "#/$defs/non_empty_string" },
            { "type": "null" }
          ]
        },
        "boundary_crossing": { "$ref": "#/$defs/boundary_crossing" },
        "metadata_consequences": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/metadata_consequence" },
          "uniqueItems": true
        },
        "summary": { "$ref": "#/$defs/non_empty_string" },
        "detail_lines": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/action_offer" }
        },
        "support_export": { "$ref": "#/$defs/support_export" }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "consumer_ref",
        "scenario",
        "root_class",
        "surface_class",
        "watch_strip_id",
        "ignore_drawer_id",
        "external_change_review_id",
        "cross_root_move_review_id"
      ],
      "properties": {
        "scenario_id": { "$ref": "#/$defs/non_empty_string" },
        "consumer_ref": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/non_empty_string" },
        "root_class": { "$ref": "#/$defs/root_class" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "watch_strip_id": { "$ref": "#/$defs/non_empty_string" },
        "ignore_drawer_id": { "$ref": "#/$defs/non_empty_string" },
        "external_change_review_id": { "$ref": "#/$defs/non_empty_string" },
        "cross_root_move_review_id": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "generated_at",
        "title",
        "summary",
        "watch_fidelity_strips",
        "ignore_resolution_drawers",
        "external_change_reviews",
        "cross_root_move_reviews",
        "scenarios"
      ],
      "properties": {
        "record_kind": { "$ref": "#/$defs/packet_record_kind" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "$ref": "#/$defs/timestamp" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/non_empty_string" },
        "watch_fidelity_strips": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/watch_strip" }
        },
        "ignore_resolution_drawers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ignore_drawer" }
        },
        "external_change_reviews": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/external_change_review" }
        },
        "cross_root_move_reviews": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/cross_root_review" }
        },
        "scenarios": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/scenario" }
        }
      }
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "fixture_id",
        "expected_scenario_id",
        "root_class",
        "surface_class",
        "consumer_ref",
        "scenario",
        "expected_watch_mode",
        "expected_ignore_visibility",
        "expected_compare_outcome",
        "expected_boundary_crossing",
        "required_action_ids"
      ],
      "properties": {
        "record_kind": { "$ref": "#/$defs/fixture_record_kind" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "fixture_id": { "$ref": "#/$defs/non_empty_string" },
        "expected_scenario_id": { "$ref": "#/$defs/non_empty_string" },
        "root_class": { "$ref": "#/$defs/root_class" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "consumer_ref": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/non_empty_string" },
        "expected_watch_mode": { "$ref": "#/$defs/watch_mode" },
        "expected_ignore_visibility": { "$ref": "#/$defs/ignore_visibility_class" },
        "expected_compare_outcome": { "$ref": "#/$defs/compare_outcome" },
        "expected_boundary_crossing": { "$ref": "#/$defs/boundary_crossing" },
        "required_action_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        }
      }
    }
  }
}
