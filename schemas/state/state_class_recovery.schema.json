{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/state/state_class_recovery.schema.json",
  "title": "Aureline state-class recovery routing and placeholder continuity packet",
  "description": "Boundary schema for the checked-in state-class recovery packet and its scenario fixtures. The packet freezes the class-level recovery route, placeholder continuity posture, preserved context, blocked capabilities, and support-safe recovery rationale for durable user state, workspace state, derived caches, generated artifacts, recovery journals, and trust or security state. Raw state payloads, credentials, raw provider responses, raw paths, raw commands, raw traces, and raw source bodies never cross this boundary.",
  "oneOf": [
    { "$ref": "#/$defs/packet" },
    { "$ref": "#/$defs/fixture" }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "state_class": {
      "type": "string",
      "enum": [
        "durable_user_state",
        "workspace_state",
        "derived_cache_state",
        "generated_artifact_state",
        "recovery_journal_state",
        "security_trust_state"
      ]
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "notebook_workspace",
        "request_workspace",
        "provider_draft",
        "preview_cache",
        "generated_artifacts",
        "sync_journal",
        "trust_policy"
      ]
    },
    "authority_class": {
      "type": "string",
      "enum": [
        "user_authored_durable_truth",
        "user_owned_recovery_state",
        "admin_or_control_artifact",
        "disposable_derived_cache"
      ]
    },
    "recovery_route": {
      "type": "string",
      "enum": [
        "rebuild_automatically",
        "guided_repair",
        "rollback_to_preserved_artifact",
        "fail_closed_privileged_operations"
      ]
    },
    "failure_mode": {
      "type": "string",
      "enum": [
        "partial_corruption",
        "missing_dependency",
        "stale_derived_overlay",
        "broken_cache_shard",
        "journal_preserved_unsaved_work",
        "quarantined_trust_state"
      ]
    },
    "placeholder_kind": {
      "type": "string",
      "enum": [
        "context_only",
        "stale_derived_artifact",
        "recovered_draft",
        "rollback_ready",
        "privileged_blocked"
      ]
    },
    "preserved_context": {
      "type": "string",
      "enum": [
        "layout_slot",
        "logical_identity",
        "workspace_chrome",
        "mutation_lineage",
        "draft_edits",
        "last_known_metadata",
        "retained_evidence"
      ]
    },
    "blocked_capability": {
      "type": "string",
      "enum": [
        "live_execution",
        "direct_write",
        "managed_publish",
        "regeneration_claims",
        "background_refresh",
        "privileged_apply"
      ]
    },
    "placeholder_action": {
      "type": "string",
      "enum": [
        "start_repair_flow",
        "compare_preserved_artifact",
        "restore_from_rollback",
        "retry_rebuild",
        "reauthenticate_managed_surface",
        "open_without_artifact",
        "export_support_packet",
        "remove_placeholder"
      ]
    },
    "source_contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "doc_ref",
        "schema_ref",
        "packet_ref",
        "report_ref",
        "fixture_manifest_ref"
      ],
      "properties": {
        "doc_ref": {
          "type": "string",
          "const": "docs/state/state_class_recovery.md"
        },
        "schema_ref": {
          "type": "string",
          "const": "schemas/state/state_class_recovery.schema.json"
        },
        "packet_ref": {
          "type": "string",
          "const": "artifacts/state/state_class_recovery.json"
        },
        "report_ref": {
          "type": "string",
          "const": "artifacts/state/state_class_recovery.md"
        },
        "fixture_manifest_ref": {
          "type": "string",
          "const": "fixtures/state/state_class_recovery/manifest.yaml"
        }
      }
    },
    "placeholder_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "placeholder_kind",
        "preserves_layout_slot",
        "preserves_logical_identity",
        "preserved_context",
        "blocked_capabilities",
        "actions",
        "summary"
      ],
      "properties": {
        "placeholder_kind": { "$ref": "#/$defs/placeholder_kind" },
        "preserves_layout_slot": { "type": "boolean", "const": true },
        "preserves_logical_identity": { "type": "boolean", "const": true },
        "preserved_context": {
          "type": "array",
          "items": { "$ref": "#/$defs/preserved_context" },
          "minItems": 1,
          "uniqueItems": true
        },
        "blocked_capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/blocked_capability" },
          "minItems": 1,
          "uniqueItems": true
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/placeholder_action" },
          "minItems": 1,
          "uniqueItems": true
        },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "family_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_id",
        "surface_family",
        "state_class",
        "authority_class",
        "primary_recovery_route",
        "fallback_recovery_routes",
        "supported_failure_modes",
        "placeholder_plan",
        "intact_state_summary",
        "safest_route_rationale",
        "source_contract_refs",
        "consumer_refs",
        "notes"
      ],
      "properties": {
        "family_id": { "$ref": "#/$defs/non_empty_string" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "state_class": { "$ref": "#/$defs/state_class" },
        "authority_class": { "$ref": "#/$defs/authority_class" },
        "primary_recovery_route": { "$ref": "#/$defs/recovery_route" },
        "fallback_recovery_routes": {
          "type": "array",
          "items": { "$ref": "#/$defs/recovery_route" },
          "minItems": 1,
          "uniqueItems": true
        },
        "supported_failure_modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/failure_mode" },
          "minItems": 1,
          "uniqueItems": true
        },
        "placeholder_plan": { "$ref": "#/$defs/placeholder_plan" },
        "intact_state_summary": { "$ref": "#/$defs/non_empty_string" },
        "safest_route_rationale": { "$ref": "#/$defs/non_empty_string" },
        "source_contract_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "minItems": 1
        },
        "consumer_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "minItems": 1
        },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "title",
        "source_contract_refs",
        "families",
        "invariants"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "state_class_recovery_packet_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "source_contract_refs": { "$ref": "#/$defs/source_contract_refs" },
        "families": {
          "type": "array",
          "items": { "$ref": "#/$defs/family_row" },
          "minItems": 1
        },
        "invariants": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "minItems": 1
        }
      }
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "fixture_id",
        "expected_family_id",
        "failure_mode",
        "expected_primary_recovery_route",
        "expected_placeholder_kind",
        "expected_actions",
        "expected_preserved_context",
        "consumer_ref",
        "notes"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "state_class_recovery_fixture_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "fixture_id": { "$ref": "#/$defs/non_empty_string" },
        "expected_family_id": { "$ref": "#/$defs/non_empty_string" },
        "failure_mode": { "$ref": "#/$defs/failure_mode" },
        "expected_primary_recovery_route": { "$ref": "#/$defs/recovery_route" },
        "expected_placeholder_kind": { "$ref": "#/$defs/placeholder_kind" },
        "expected_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/placeholder_action" },
          "minItems": 1,
          "uniqueItems": true
        },
        "expected_preserved_context": {
          "type": "array",
          "items": { "$ref": "#/$defs/preserved_context" },
          "minItems": 1,
          "uniqueItems": true
        },
        "consumer_ref": { "$ref": "#/$defs/non_empty_string" },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  }
}
