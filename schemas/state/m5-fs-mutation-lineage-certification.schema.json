{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/state/m5-fs-mutation-lineage-certification.schema.json",
  "title": "M5 filesystem and mutation-lineage certification",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "schema_ref",
    "doc_ref",
    "artifact_ref",
    "summary_ref",
    "source_spec_refs",
    "supporting_contract_refs",
    "root_classes",
    "connectivity_states",
    "lineage_root_ids",
    "recovery_family_ids",
    "certification_rows",
    "downgrade_rules",
    "surface_bindings",
    "export_safe_summary"
  ],
  "properties": {
    "record_kind": {
      "const": "m5_fs_mutation_lineage_certification_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "schema_ref": {
      "const": "schemas/state/m5-fs-mutation-lineage-certification.schema.json"
    },
    "doc_ref": {
      "const": "docs/state/m5-fs-mutation-lineage-certification.md"
    },
    "artifact_ref": {
      "const": "artifacts/state/m5-fs-mutation-lineage-certification.json"
    },
    "summary_ref": {
      "const": "artifacts/state/m5-fs-mutation-lineage-certification.md"
    },
    "source_spec_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "supporting_contract_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "root_classes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/root_class"
      },
      "minItems": 1
    },
    "connectivity_states": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/connectivity_state"
      },
      "minItems": 1
    },
    "lineage_root_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "recovery_family_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "certification_rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/certification_row"
      },
      "minItems": 1
    },
    "downgrade_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/downgrade_rule"
      },
      "minItems": 1
    },
    "surface_bindings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/surface_binding"
      },
      "minItems": 1
    },
    "export_safe_summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "root_class": {
      "type": "string",
      "enum": [
        "local_filesystem",
        "remote_agent",
        "container_mount",
        "archive_packaged",
        "generated_managed",
        "virtual_provider_backed",
        "managed_offline_bundle"
      ]
    },
    "connectivity_state": {
      "type": "string",
      "enum": [
        "connected",
        "constrained",
        "offline_local_safe",
        "reauth_required",
        "reconciliation_pending",
        "service_unavailable"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "notebook_document",
        "notebook_output_artifact",
        "request_workspace_document",
        "request_response_snapshot",
        "database_export_artifact",
        "profiler_trace_artifact",
        "preview_output_artifact",
        "sync_packet_artifact",
        "provider_local_draft",
        "infrastructure_overlay_document",
        "imported_archive_capture"
      ]
    },
    "published_state": {
      "type": "string",
      "enum": [
        "qualified",
        "limited",
        "stale",
        "reconcile_required"
      ]
    },
    "surface_binding_class": {
      "type": "string",
      "enum": [
        "help_surface",
        "diagnostics_export",
        "support_bundle",
        "release_center"
      ]
    },
    "downgrade_trigger_class": {
      "type": "string",
      "enum": [
        "canonical_identity_unavailable",
        "canonical_save_target_unavailable",
        "watch_truth_degraded",
        "mutation_lineage_scoped",
        "recovery_path_scoped",
        "deferred_intent_needs_review",
        "consumer_binding_missing"
      ]
    },
    "certification_row": {
      "type": "object",
      "required": [
        "certification_row_id",
        "surface_row_id",
        "surface_class",
        "published_state",
        "primary_root_class",
        "supported_root_classes",
        "path_identity_class",
        "watch_state",
        "save_fallback",
        "undo_class",
        "corruption_state",
        "connectivity_state",
        "reconciliation_posture",
        "review_scenario_ids",
        "lineage_root_ids",
        "recovery_family_ids",
        "source_packet_refs",
        "stale_or_narrow_tokens",
        "downgrade_rule_ids",
        "summary"
      ],
      "properties": {
        "certification_row_id": { "type": "string", "minLength": 1 },
        "surface_row_id": { "type": "string", "minLength": 1 },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "published_state": { "$ref": "#/$defs/published_state" },
        "primary_root_class": { "$ref": "#/$defs/root_class" },
        "supported_root_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/root_class" },
          "minItems": 1
        },
        "path_identity_class": { "type": "string", "minLength": 1 },
        "watch_state": { "type": "string", "minLength": 1 },
        "save_fallback": { "type": "string", "minLength": 1 },
        "undo_class": { "type": "string", "minLength": 1 },
        "corruption_state": { "type": "string", "minLength": 1 },
        "connectivity_state": { "$ref": "#/$defs/connectivity_state" },
        "reconciliation_posture": { "type": "string", "minLength": 1 },
        "review_scenario_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "lineage_root_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "recovery_family_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source_packet_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "stale_or_narrow_tokens": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "downgrade_rule_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "required": [
        "rule_id",
        "trigger_class",
        "source_state",
        "downgraded_state",
        "required_effect",
        "rationale",
        "evidence_refs"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "trigger_class": { "$ref": "#/$defs/downgrade_trigger_class" },
        "source_state": { "$ref": "#/$defs/published_state" },
        "downgraded_state": { "$ref": "#/$defs/published_state" },
        "required_effect": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      }
    },
    "surface_binding": {
      "type": "object",
      "required": [
        "surface",
        "consumer_ref",
        "ingested_packet_id",
        "certification_row_count",
        "required_verbatim_fields",
        "narrow_on_narrowed_rows",
        "explicit_state_labels_required",
        "summary"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/surface_binding_class" },
        "consumer_ref": { "type": "string", "minLength": 1 },
        "ingested_packet_id": { "type": "string", "minLength": 1 },
        "certification_row_count": { "type": "integer", "minimum": 0 },
        "required_verbatim_fields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "narrow_on_narrowed_rows": { "type": "boolean" },
        "explicit_state_labels_required": { "type": "boolean" },
        "summary": { "type": "string", "minLength": 1 }
      }
    }
  },
  "additionalProperties": false
}
