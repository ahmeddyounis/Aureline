{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/state/compatibility_window_row.schema.json",
  "title": "Aureline durable-state compatibility-window row",
  "description": "Boundary schema for one compatibility-window row in the durable-state compatibility contract frozen in docs/state/durable_state_compatibility_contract.md. The row freezes — for one artifact family — the backward-readable window, the forward-read expectations, the backup-before-migrate rule, the rollback or downgrade behavior, the corruption or repair path, the migration-policy owner, and the help/support/migration-center/shiproom surfaces the row feeds. Raw paths, raw URLs, raw secrets, raw command lines, raw logs, and raw source content do not cross this boundary; only opaque refs and class-level vocabularies appear. The closed vocabularies re-export upstream contracts (state-object inventory, migration-and-restore playbook, portable-state package, profile-and-state map) verbatim so the matrix can feed downstream surfaces without restating policy manually.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/compatibility_window_row_record" },
    { "$ref": "#/$defs/compatibility_window_matrix_record" }
  ],
  "$defs": {
    "compatibility_window_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this compatibility-window vocabulary. Bumped only on breaking payload changes."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe for manifests, logs, support exports, and compare handles. Raw paths, raw URLs, credentials, source content, command lines, and live authority handles never appear here."
    },
    "nullable_opaque_id": {
      "anyOf": [
        { "$ref": "#/$defs/opaque_id" },
        { "type": "null" }
      ]
    },
    "redaction_aware_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "description": "Reviewable prose or label after the active redaction policy has already been applied."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "doc_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "compatibility_window_row_record",
        "compatibility_window_matrix_record"
      ]
    },
    "artifact_family_class": {
      "type": "string",
      "enum": [
        "user_authored_durable_state",
        "workspace_authored_durable_state",
        "cache_or_index_state",
        "public_schemas_or_interfaces",
        "portable_state_packages",
        "generated_or_structured_artifacts"
      ],
      "description": "Closed set of compatibility-window artifact families. Maps onto and re-exports the state-object inventory's object_category vocabulary plus the public-schema and portable-state package families that ride above the per-object rows."
    },
    "schema_evolution_posture": {
      "type": "string",
      "enum": [
        "frozen_no_evolution",
        "additive_minor_only",
        "migrating_with_equivalence_map",
        "replay_only_no_schema",
        "signed_epoch_replacement",
        "content_addressed_immutable"
      ],
      "description": "Re-export of the state-object inventory's schema-evolution-posture vocabulary."
    },
    "backward_readable_window_class": {
      "type": "string",
      "enum": [
        "stable_indefinite",
        "stable_within_major_version",
        "stable_within_signed_epoch_window",
        "additive_minor_only_back_to_first_release",
        "translation_required_through_equivalence_map",
        "replay_only_no_backward_window",
        "no_backward_window_content_addressed",
        "no_backward_window_admin_refused"
      ],
      "description": "Closed window class describing how far back an older target reads a newer producer's body. The backward direction is always 'older target reads body produced by a newer producer'."
    },
    "forward_read_expectations_class": {
      "type": "string",
      "enum": [
        "exact_forward_read",
        "compatible_forward_read_with_translation",
        "forward_read_with_documented_fallback",
        "forward_read_export_only",
        "forward_read_refused_by_authority",
        "forward_read_replay_into_new_buffer",
        "forward_read_content_addressed_supersede",
        "forward_read_inspect_only_off_producing_machine"
      ],
      "description": "Closed expectation class describing what a forward (newer target reading older body) target promises before any apply runs."
    },
    "backup_before_migrate_rule_class": {
      "type": "string",
      "enum": [
        "backup_required_before_destructive_migration",
        "backup_optional_user_offered",
        "backup_not_applicable_content_addressed",
        "backup_not_applicable_disposable",
        "backup_handled_by_authority"
      ],
      "description": "Re-export of the state-object inventory's backup-before-migrate rule vocabulary."
    },
    "rollback_or_downgrade_behavior_class": {
      "type": "string",
      "enum": [
        "rollback_to_preserved_prior_artifact",
        "downgrade_reads_with_documented_fallback",
        "downgrade_export_only_through_translator",
        "downgrade_refused_by_authority_signed_epoch",
        "downgrade_inspect_only_off_producing_machine",
        "downgrade_rebuild_from_authoritative_truth",
        "downgrade_compare_only_no_apply",
        "downgrade_read_only_mode"
      ],
      "description": "Closed behavior class describing what the surface does when a target older than the producer attempts to read or apply the body."
    },
    "corruption_or_repair_path_class": {
      "type": "string",
      "enum": [
        "block_feature_only",
        "rebuild_automatically",
        "open_with_warning",
        "repair_flow",
        "backup_rollback",
        "fail_closed_for_privileged_operations",
        "compare_only_no_apply",
        "read_only_mode",
        "no_repair_path_disposable_only"
      ],
      "description": "Closed corruption-or-repair path class. Re-exports the state-object inventory's six corruption-posture classes and adds compare_only_no_apply, read_only_mode, and no_repair_path_disposable_only to cover generated-structure fallback rows."
    },
    "migration_policy_owner_class": {
      "type": "string",
      "enum": [
        "user_authored_durable_truth",
        "workspace_authored_durable_truth",
        "user_owned_recovery_state",
        "disposable_derived_cache",
        "admin_or_control_authority",
        "public_interface_authority",
        "portable_state_package_authority",
        "generated_structure_producer"
      ],
      "description": "Closed owner class. Re-exports the profile-and-state map authority owners and adds the public-interface, portable-state package, and generated-structure producer owners that ride above the per-object inventory rows."
    },
    "downgrade_readability_class": {
      "type": "string",
      "enum": [
        "downgrade_reads_fully",
        "downgrade_reads_with_fallback",
        "downgrade_requires_export_only",
        "downgrade_refused"
      ],
      "description": "Re-export of the state-object inventory's backward / downgrade-readability vocabulary."
    },
    "consumer_surface_class": {
      "type": "string",
      "enum": [
        "help_center",
        "support_center",
        "migration_center",
        "shiproom_dashboard",
        "project_doctor",
        "portable_state_export_sheet",
        "release_notes",
        "admin_console",
        "public_changelog"
      ],
      "description": "Closed downstream surface class the row feeds. The compatibility matrix is the single source of truth for these surfaces; they MUST NOT mint a parallel policy vocabulary."
    },
    "policy_summary_text_keys": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "backward_readable_window",
        "forward_read_expectations",
        "backup_before_migrate",
        "rollback_or_downgrade",
        "corruption_or_repair",
        "migration_policy_owner"
      ],
      "properties": {
        "title": { "$ref": "#/$defs/redaction_aware_text" },
        "backward_readable_window": { "$ref": "#/$defs/redaction_aware_text" },
        "forward_read_expectations": { "$ref": "#/$defs/redaction_aware_text" },
        "backup_before_migrate": { "$ref": "#/$defs/redaction_aware_text" },
        "rollback_or_downgrade": { "$ref": "#/$defs/redaction_aware_text" },
        "corruption_or_repair": { "$ref": "#/$defs/redaction_aware_text" },
        "migration_policy_owner": { "$ref": "#/$defs/redaction_aware_text" },
        "stable_label_implication": { "$ref": "#/$defs/redaction_aware_text" }
      },
      "description": "Reviewable prose snippets the matrix feeds into help / support / migration-center / shiproom surfaces verbatim. Surfaces resolve copy keys against this block; they MUST NOT re-author policy text."
    },
    "stable_label_implication_class": {
      "type": "string",
      "enum": [
        "stable_label_implies_no_format_change",
        "stable_label_implies_compatible_translation_with_backup",
        "stable_label_implies_signed_epoch_replacement",
        "stable_label_implies_content_addressed_supersede",
        "stable_label_implies_replay_into_new_buffer",
        "stable_label_implies_compare_or_read_only_fallback",
        "stable_label_implies_admin_owned_distribution"
      ],
      "description": "Closed class describing what a stable-channel label promises for this artifact family. A surface that claims a stable label without quoting one of these implications is non-conforming."
    },
    "compatibility_window_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "compatibility_window_schema_version",
        "row_id",
        "artifact_family_class",
        "row_label",
        "schema_evolution_posture",
        "backward_readable_window",
        "forward_read_expectations",
        "backup_before_migrate_rule",
        "rollback_or_downgrade_behavior",
        "corruption_or_repair_path",
        "migration_policy_owner",
        "downgrade_readability",
        "stable_label_implication",
        "applicable_state_object_refs",
        "consumer_surfaces",
        "policy_summary_text_keys"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "compatibility_window_row_record" },
        "compatibility_window_schema_version": { "$ref": "#/$defs/compatibility_window_schema_version" },
        "row_id": { "$ref": "#/$defs/opaque_id" },
        "artifact_family_class": { "$ref": "#/$defs/artifact_family_class" },
        "row_label": { "$ref": "#/$defs/redaction_aware_text" },
        "schema_evolution_posture": { "$ref": "#/$defs/schema_evolution_posture" },
        "backward_readable_window": { "$ref": "#/$defs/backward_readable_window_class" },
        "forward_read_expectations": { "$ref": "#/$defs/forward_read_expectations_class" },
        "backup_before_migrate_rule": { "$ref": "#/$defs/backup_before_migrate_rule_class" },
        "rollback_or_downgrade_behavior": { "$ref": "#/$defs/rollback_or_downgrade_behavior_class" },
        "corruption_or_repair_path": { "$ref": "#/$defs/corruption_or_repair_path_class" },
        "migration_policy_owner": { "$ref": "#/$defs/migration_policy_owner_class" },
        "downgrade_readability": { "$ref": "#/$defs/downgrade_readability_class" },
        "stable_label_implication": { "$ref": "#/$defs/stable_label_implication_class" },
        "applicable_state_object_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Opaque refs into state-object inventory rows (or, for non-inventory families, into the per-family contract anchors). Empty for families that have no per-object inventory row."
        },
        "consumer_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/consumer_surface_class" },
          "uniqueItems": true,
          "minItems": 1
        },
        "policy_summary_text_keys": { "$ref": "#/$defs/policy_summary_text_keys" },
        "restore_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Optional opaque refs to restore_after_downgrade_packet_record bodies that worked through this row."
        },
        "notes": { "$ref": "#/$defs/redaction_aware_text" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "schema_evolution_posture": { "const": "migrating_with_equivalence_map" }
            }
          },
          "then": {
            "properties": {
              "backup_before_migrate_rule": { "const": "backup_required_before_destructive_migration" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "corruption_or_repair_path": { "const": "backup_rollback" }
            }
          },
          "then": {
            "properties": {
              "backup_before_migrate_rule": { "const": "backup_required_before_destructive_migration" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "schema_evolution_posture": { "const": "signed_epoch_replacement" }
            }
          },
          "then": {
            "properties": {
              "rollback_or_downgrade_behavior": { "const": "downgrade_refused_by_authority_signed_epoch" },
              "downgrade_readability": { "const": "downgrade_refused" },
              "migration_policy_owner": { "const": "admin_or_control_authority" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "artifact_family_class": { "const": "cache_or_index_state" }
            }
          },
          "then": {
            "properties": {
              "migration_policy_owner": { "const": "disposable_derived_cache" },
              "corruption_or_repair_path": {
                "enum": ["rebuild_automatically", "no_repair_path_disposable_only"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "artifact_family_class": { "const": "user_authored_durable_state" }
            }
          },
          "then": {
            "properties": {
              "backup_before_migrate_rule": { "const": "backup_required_before_destructive_migration" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "artifact_family_class": { "const": "workspace_authored_durable_state" }
            }
          },
          "then": {
            "properties": {
              "backup_before_migrate_rule": {
                "enum": [
                  "backup_required_before_destructive_migration",
                  "backup_optional_user_offered"
                ]
              }
            }
          }
        }
      ],
      "description": "One compatibility-window row binding artifact family to backward window, forward expectations, backup rule, rollback / downgrade behavior, corruption or repair path, migration-policy owner, and the closed downstream surfaces the row feeds."
    },
    "compatibility_window_matrix_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "compatibility_window_schema_version",
        "matrix_id",
        "matrix_label",
        "rows"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "compatibility_window_matrix_record" },
        "compatibility_window_schema_version": { "$ref": "#/$defs/compatibility_window_schema_version" },
        "matrix_id": { "$ref": "#/$defs/opaque_id" },
        "matrix_label": { "$ref": "#/$defs/redaction_aware_text" },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/compatibility_window_row_record" },
          "minItems": 6,
          "description": "The matrix MUST carry at least one row per artifact_family_class so no stable-bearing family is missing from the cross-surface lookup."
        },
        "notes": { "$ref": "#/$defs/redaction_aware_text" }
      },
      "description": "Aggregate matrix carrying every compatibility-window row. Help, Support Center, Migration Center, and shiproom surfaces resolve their per-family answers against this matrix verbatim."
    }
  }
}
