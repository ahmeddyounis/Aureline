{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/state/filesystem_mutation_lineage_matrix.schema.json",
  "title": "Filesystem identity, watch fidelity, mutation lineage, and deferred-intent matrix",
  "description": "Boundary schema for the filesystem_mutation_lineage_matrix_packet_record and filesystem_mutation_lineage_matrix_fixture_record emitted by aureline-vfs. The packet freezes the cross-surface vocabulary for root class, path identity, watch state, save fallback, undo class, corruption state, connectivity state, and reconciliation posture across notebook documents, generated notebook outputs, request workspaces, request snapshots, database exports, profiler traces, preview outputs, sync packets, provider drafts, infrastructure overlays, and imported archive captures.",
  "oneOf": [
    {
      "$ref": "#/$defs/packet"
    },
    {
      "$ref": "#/$defs/fixture"
    }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "root_class": {
      "type": "string",
      "enum": [
        "local_filesystem",
        "remote_agent",
        "container_mount",
        "archive_packaged",
        "generated_managed",
        "virtual_provider_backed",
        "managed_offline_bundle"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "notebook_document",
        "notebook_output_artifact",
        "request_workspace_document",
        "request_response_snapshot",
        "database_export_artifact",
        "profiler_trace_artifact",
        "preview_output_artifact",
        "sync_packet_artifact",
        "provider_local_draft",
        "infrastructure_overlay_document",
        "imported_archive_capture"
      ]
    },
    "path_identity_class": {
      "type": "string",
      "enum": [
        "canonical_filesystem_object",
        "generated_source_identity",
        "provider_object_identity",
        "imported_snapshot_identity",
        "local_draft_identity",
        "offline_bundle_identity"
      ]
    },
    "watch_state": {
      "type": "string",
      "enum": [
        "live_watch",
        "reduced_fidelity_watch",
        "polling_fallback",
        "manual_refresh_only",
        "provider_refresh_only",
        "no_external_watch"
      ]
    },
    "save_fallback": {
      "type": "string",
      "enum": [
        "atomic_replace",
        "conditional_remote_write",
        "in_place_write",
        "save_as_copy",
        "regenerate_from_source",
        "stage_local_draft",
        "compare_only_blocked"
      ]
    },
    "undo_class": {
      "type": "string",
      "enum": [
        "exact_undo",
        "compensating_undo",
        "regenerate_recompute",
        "restore_from_checkpoint",
        "audit_only_non_undoable"
      ]
    },
    "corruption_state": {
      "type": "string",
      "enum": [
        "block_feature_only",
        "rebuild_automatically",
        "open_with_warning",
        "repair_flow",
        "backup_rollback",
        "fail_closed_for_privileged_operations"
      ]
    },
    "connectivity_state": {
      "type": "string",
      "enum": [
        "connected",
        "constrained",
        "offline_local_safe",
        "reauth_required",
        "reconciliation_pending",
        "service_unavailable"
      ]
    },
    "reconciliation_posture": {
      "type": "string",
      "enum": [
        "not_applicable",
        "no_invisible_replay",
        "revalidate_before_replay",
        "manual_review_required",
        "expire_without_replay"
      ]
    },
    "repo_ref": {
      "type": "string",
      "pattern": "^(artifacts|crates|docs|fixtures|schemas)/.+"
    },
    "coverage_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_filesystem_identity",
        "watch_guarantee",
        "writable_save_target",
        "mutation_journal_coverage",
        "deferred_intent_or_reconcile_exposure"
      ],
      "properties": {
        "canonical_filesystem_identity": {
          "type": "boolean"
        },
        "watch_guarantee": {
          "type": "boolean"
        },
        "writable_save_target": {
          "type": "boolean"
        },
        "mutation_journal_coverage": {
          "type": "boolean"
        },
        "deferred_intent_or_reconcile_exposure": {
          "type": "boolean"
        }
      }
    },
    "source_contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "doc_ref",
        "schema_ref",
        "packet_ref",
        "report_ref",
        "fixture_manifest_ref"
      ],
      "properties": {
        "doc_ref": {
          "type": "string",
          "const": "docs/state/filesystem_mutation_lineage_matrix.md"
        },
        "schema_ref": {
          "type": "string",
          "const": "schemas/state/filesystem_mutation_lineage_matrix.schema.json"
        },
        "packet_ref": {
          "type": "string",
          "const": "artifacts/state/filesystem_mutation_lineage_matrix.json"
        },
        "report_ref": {
          "type": "string",
          "const": "artifacts/state/filesystem_mutation_lineage_matrix.md"
        },
        "fixture_manifest_ref": {
          "type": "string",
          "const": "fixtures/state/filesystem_mutation_lineage_matrix/manifest.yaml"
        }
      }
    },
    "matrix_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "surface_class",
        "title",
        "primary_root_class",
        "supported_root_classes",
        "path_identity_class",
        "watch_state",
        "save_fallback",
        "undo_class",
        "corruption_state",
        "connectivity_state",
        "reconciliation_posture",
        "coverage",
        "consumer_refs",
        "fixture_refs",
        "notes"
      ],
      "properties": {
        "row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_class": {
          "$ref": "#/$defs/surface_class"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "primary_root_class": {
          "$ref": "#/$defs/root_class"
        },
        "supported_root_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/root_class"
          }
        },
        "path_identity_class": {
          "$ref": "#/$defs/path_identity_class"
        },
        "watch_state": {
          "$ref": "#/$defs/watch_state"
        },
        "save_fallback": {
          "$ref": "#/$defs/save_fallback"
        },
        "undo_class": {
          "$ref": "#/$defs/undo_class"
        },
        "corruption_state": {
          "$ref": "#/$defs/corruption_state"
        },
        "connectivity_state": {
          "$ref": "#/$defs/connectivity_state"
        },
        "reconciliation_posture": {
          "$ref": "#/$defs/reconciliation_posture"
        },
        "coverage": {
          "$ref": "#/$defs/coverage_flags"
        },
        "consumer_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/repo_ref"
          }
        },
        "fixture_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/repo_ref"
          }
        },
        "notes": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "title",
        "source_contract_refs",
        "rows",
        "invariants"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "filesystem_mutation_lineage_matrix_packet_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "packet_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/source_contract_refs"
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/matrix_row"
          }
        },
        "invariants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "fixture_id",
        "expected_row_id",
        "scenario",
        "root_class",
        "path_identity_class",
        "watch_state",
        "save_fallback",
        "undo_class",
        "corruption_state",
        "connectivity_state",
        "reconciliation_posture",
        "coverage",
        "consumer_ref",
        "notes"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "filesystem_mutation_lineage_matrix_fixture_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "fixture_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "expected_row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "scenario": {
          "$ref": "#/$defs/non_empty_string"
        },
        "root_class": {
          "$ref": "#/$defs/root_class"
        },
        "path_identity_class": {
          "$ref": "#/$defs/path_identity_class"
        },
        "watch_state": {
          "$ref": "#/$defs/watch_state"
        },
        "save_fallback": {
          "$ref": "#/$defs/save_fallback"
        },
        "undo_class": {
          "$ref": "#/$defs/undo_class"
        },
        "corruption_state": {
          "$ref": "#/$defs/corruption_state"
        },
        "connectivity_state": {
          "$ref": "#/$defs/connectivity_state"
        },
        "reconciliation_posture": {
          "$ref": "#/$defs/reconciliation_posture"
        },
        "coverage": {
          "$ref": "#/$defs/coverage_flags"
        },
        "consumer_ref": {
          "$ref": "#/$defs/repo_ref"
        },
        "notes": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
