{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/state/generated_artifact.schema.json",
  "title": "Aureline generated-artifact lineage and drift-state record",
  "description": "Boundary schema for the generated_artifact_lineage_record and generated_artifact_lineage_report_record consumed by aureline-reactive-state's generated_lineage module. A lineage record binds one consumer surface (search, review, ai_context, support_export) to one artifact under a closed artifact-family vocabulary (build_output, lockfile, preview_render, notebook_output, run_result_artifact), captures generator identity, canonical source refs, lineage class, drift state, and default edit posture in one metadata-safe object, and pins a closed downgrade_label so a failing row downgrades without inventing new vocabulary. The default_edit_posture is re-derived from lineage_class and the downgrade_label is re-derived from drift_state so prose cannot lie about generator identity. The report record folds every packet into per-surface, per-family, and per-lineage summaries so search, review, AI, and support pipelines can audit generated-artifact truth without re-running generators and without forcing raw payload capture.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/generated_artifact_lineage_record" },
    { "$ref": "#/$defs/generated_artifact_lineage_report_record" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "non_empty_string": { "type": "string", "minLength": 1 },
    "reviewable_sentence": { "type": "string", "minLength": 1 },
    "monotonic_timestamp": { "type": "string", "minLength": 1 },
    "consumer_surface": {
      "type": "string",
      "enum": ["search", "review", "ai_context", "support_export"]
    },
    "artifact_family": {
      "type": "string",
      "enum": [
        "build_output",
        "lockfile",
        "preview_render",
        "notebook_output",
        "run_result_artifact"
      ]
    },
    "lineage_class": {
      "type": "string",
      "enum": [
        "canonical_source",
        "generated_from_local_source",
        "regenerable_lockfile_artifact",
        "mirrored_from_local_source",
        "imported_external_artifact",
        "derived_from_run_artifact",
        "previewed_from_local_source",
        "unknown_lineage"
      ]
    },
    "drift_state": {
      "type": "string",
      "enum": [
        "aligned",
        "source_drifted",
        "regen_pending",
        "stale_generated",
        "generator_missing",
        "imported_no_local_source",
        "out_of_scope"
      ]
    },
    "default_edit_posture": {
      "type": "string",
      "enum": [
        "editable_canonical",
        "read_only_generated",
        "regenerate_only",
        "review_required_before_edit",
        "imported_read_only",
        "transient_run_artifact"
      ]
    },
    "downgrade_label": {
      "type": "string",
      "enum": [
        "none",
        "red_blocks_beta_row",
        "yellow_drift_pending",
        "yellow_generator_unknown",
        "yellow_partial_coverage",
        "degraded_to_metadata_only",
        "stale_corpus_blocks_release_candidate"
      ]
    },
    "open_gap_class": {
      "type": "string",
      "enum": [
        "none",
        "regen_pending",
        "generator_identity_pending",
        "source_ref_pending",
        "surface_coverage_pending",
        "lineage_pending",
        "evidence_export_pending"
      ]
    },
    "open_gap_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gap_class", "summary"],
      "properties": {
        "gap_class": { "$ref": "#/$defs/open_gap_class" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "generator_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generator_kind", "generator_ref"],
      "properties": {
        "generator_kind": {
          "type": "string",
          "enum": [
            "build_system",
            "package_manager",
            "preview_renderer",
            "notebook_kernel",
            "task_runner",
            "external_import",
            "unknown_generator"
          ]
        },
        "generator_ref": { "$ref": "#/$defs/non_empty_string" },
        "generator_version_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_kind", "source_path"],
      "properties": {
        "source_kind": {
          "type": "string",
          "enum": [
            "local_source_file",
            "local_source_manifest",
            "local_notebook_cell",
            "external_import_descriptor",
            "run_invocation_descriptor",
            "no_local_source"
          ]
        },
        "source_path": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "evidence_export_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preserves_artifact_family_label",
        "preserves_lineage_label",
        "preserves_drift_state_label",
        "preserves_edit_posture_label",
        "preserves_consumer_surface_label",
        "preserves_generator_identity",
        "preserves_source_refs",
        "raw_payload_excluded",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "preserves_user_authored_files"
      ],
      "properties": {
        "preserves_artifact_family_label": { "type": "boolean", "const": true },
        "preserves_lineage_label": { "type": "boolean", "const": true },
        "preserves_drift_state_label": { "type": "boolean", "const": true },
        "preserves_edit_posture_label": { "type": "boolean", "const": true },
        "preserves_consumer_surface_label": { "type": "boolean", "const": true },
        "preserves_generator_identity": { "type": "boolean", "const": true },
        "preserves_source_refs": { "type": "boolean", "const": true },
        "raw_payload_excluded": { "type": "boolean", "const": true },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "ambient_authority_excluded": { "type": "boolean", "const": true },
        "preserves_user_authored_files": { "type": "boolean", "const": true }
      }
    },
    "packet_safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_payload_excluded",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "destructive_resets_present",
        "preserves_user_authored_files"
      ],
      "properties": {
        "raw_payload_excluded": { "type": "boolean", "const": true },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "ambient_authority_excluded": { "type": "boolean", "const": true },
        "destructive_resets_present": { "type": "boolean", "const": false },
        "preserves_user_authored_files": { "type": "boolean", "const": true }
      }
    },
    "packet_references": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doc_ref", "schema_ref", "report_ref"],
      "properties": {
        "doc_ref": {
          "type": "string",
          "const": "docs/state/m3/generated_artifact_lineage_beta.md"
        },
        "schema_ref": {
          "type": "string",
          "const": "schemas/state/generated_artifact.schema.json"
        },
        "report_ref": {
          "type": "string",
          "const": "artifacts/support/m3/generated_artifact_lineage_report.md"
        }
      }
    },
    "generated_artifact_lineage_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "title",
        "consumer_surface",
        "artifact_family",
        "artifact_ref",
        "workspace_id",
        "lineage_class",
        "drift_state",
        "default_edit_posture",
        "downgrade_label",
        "generator_identity",
        "source_refs",
        "evidence_export",
        "safety",
        "references",
        "captured_at"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "record_kind": {
          "type": "string",
          "const": "generated_artifact_lineage_record"
        },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "artifact_family": { "$ref": "#/$defs/artifact_family" },
        "artifact_ref": { "$ref": "#/$defs/non_empty_string" },
        "workspace_id": { "$ref": "#/$defs/non_empty_string" },
        "lineage_class": { "$ref": "#/$defs/lineage_class" },
        "drift_state": { "$ref": "#/$defs/drift_state" },
        "default_edit_posture": { "$ref": "#/$defs/default_edit_posture" },
        "downgrade_label": { "$ref": "#/$defs/downgrade_label" },
        "generator_identity": { "$ref": "#/$defs/generator_identity" },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source_ref" }
        },
        "evidence_export": { "$ref": "#/$defs/evidence_export_projection" },
        "open_gaps": {
          "type": "array",
          "items": { "$ref": "#/$defs/open_gap_entry" }
        },
        "safety": { "$ref": "#/$defs/packet_safety" },
        "references": { "$ref": "#/$defs/packet_references" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "reviewer_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "report_matrix_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "consumer_surface",
        "artifact_family",
        "artifact_ref",
        "lineage_class",
        "drift_state",
        "default_edit_posture",
        "downgrade_label",
        "open_gap_classes"
      ],
      "properties": {
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "artifact_family": { "$ref": "#/$defs/artifact_family" },
        "artifact_ref": { "$ref": "#/$defs/non_empty_string" },
        "lineage_class": { "$ref": "#/$defs/lineage_class" },
        "drift_state": { "$ref": "#/$defs/drift_state" },
        "default_edit_posture": { "$ref": "#/$defs/default_edit_posture" },
        "downgrade_label": { "$ref": "#/$defs/downgrade_label" },
        "open_gap_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/open_gap_class" }
        }
      }
    },
    "consumer_surface_summary_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer_surface",
        "packet_count",
        "aligned_count",
        "drift_count",
        "imported_count",
        "downgrade_required_count"
      ],
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "packet_count": { "type": "integer", "minimum": 0 },
        "aligned_count": { "type": "integer", "minimum": 0 },
        "drift_count": { "type": "integer", "minimum": 0 },
        "imported_count": { "type": "integer", "minimum": 0 },
        "downgrade_required_count": { "type": "integer", "minimum": 0 }
      }
    },
    "artifact_family_summary_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_family",
        "packet_count",
        "aligned_count",
        "drift_count",
        "downgrade_required_count"
      ],
      "properties": {
        "artifact_family": { "$ref": "#/$defs/artifact_family" },
        "packet_count": { "type": "integer", "minimum": 0 },
        "aligned_count": { "type": "integer", "minimum": 0 },
        "drift_count": { "type": "integer", "minimum": 0 },
        "downgrade_required_count": { "type": "integer", "minimum": 0 }
      }
    },
    "lineage_summary_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lineage_class",
        "packet_count",
        "aligned_count",
        "drift_count",
        "downgrade_required_count"
      ],
      "properties": {
        "lineage_class": { "$ref": "#/$defs/lineage_class" },
        "packet_count": { "type": "integer", "minimum": 0 },
        "aligned_count": { "type": "integer", "minimum": 0 },
        "drift_count": { "type": "integer", "minimum": 0 },
        "downgrade_required_count": { "type": "integer", "minimum": 0 }
      }
    },
    "generated_artifact_lineage_report_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "report_id",
        "captured_at",
        "doc_ref",
        "schema_ref",
        "corpus_manifest_ref",
        "raw_payload_excluded",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "required_consumer_surfaces",
        "required_artifact_families",
        "required_lineages",
        "matrix_rows",
        "consumer_surface_summaries",
        "artifact_family_summaries",
        "lineage_summaries"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "record_kind": {
          "type": "string",
          "const": "generated_artifact_lineage_report_record"
        },
        "report_id": { "$ref": "#/$defs/non_empty_string" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "doc_ref": {
          "type": "string",
          "const": "docs/state/m3/generated_artifact_lineage_beta.md"
        },
        "schema_ref": {
          "type": "string",
          "const": "schemas/state/generated_artifact.schema.json"
        },
        "corpus_manifest_ref": {
          "type": "string",
          "const": "fixtures/state/generated_artifacts_beta/manifest.yaml"
        },
        "raw_payload_excluded": { "type": "boolean", "const": true },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "ambient_authority_excluded": { "type": "boolean", "const": true },
        "required_consumer_surfaces": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/consumer_surface" }
        },
        "required_artifact_families": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/artifact_family" }
        },
        "required_lineages": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/lineage_class" }
        },
        "matrix_rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/report_matrix_row" }
        },
        "consumer_surface_summaries": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/consumer_surface_summary_row" }
        },
        "artifact_family_summaries": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/artifact_family_summary_row" }
        },
        "lineage_summaries": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/lineage_summary_row" }
        }
      }
    }
  }
}
