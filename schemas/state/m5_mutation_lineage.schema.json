{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/state/m5_mutation_lineage.schema.json",
  "title": "Unified M5 mutation-lineage packet",
  "description": "Boundary schema for the canonical M5 mutation-lineage packet and fixture rows emitted by aureline-reactive-state. The packet freezes the cross-surface journal vocabulary for notebook, request, data, preview, sync, repair, provider, workflow, profiler, AI-evidence, and incident mutations. It preserves mutation ids, group ids, lineage-root ids, actor and source classes, affected scope, checkpoint lineage, explicit reversal class, file counts, artifact classes, and automation or policy influence. The packet also carries thread-level history-inspector rows and support-export manifest rows so shell, support, and incident consumers read one lineage truth instead of reconstructing it from logs.",
  "oneOf": [
    { "$ref": "#/$defs/packet" },
    { "$ref": "#/$defs/fixture" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "repo_ref": {
      "type": "string",
      "pattern": "^(artifacts|crates|docs|fixtures|schemas)/.+"
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "notebook_document",
        "notebook_output",
        "request_workspace",
        "data_export_artifact",
        "preview_output",
        "sync_packet",
        "repair_transaction",
        "provider_draft",
        "workflow_bundle",
        "profiler_trace",
        "ai_evidence_packet",
        "incident_action"
      ]
    },
    "artifact_class": {
      "type": "string",
      "enum": [
        "notebook_file",
        "notebook_output_bundle",
        "request_document",
        "query_export",
        "preview_snapshot",
        "sync_manifest",
        "repair_receipt",
        "provider_draft",
        "workflow_bundle",
        "trace_capture",
        "ai_evidence_packet",
        "incident_packet"
      ]
    },
    "reversal_class": {
      "type": "string",
      "enum": [
        "exact",
        "grouped_exact",
        "compensate",
        "regenerate",
        "manual",
        "audit_only"
      ]
    },
    "actor_class": {
      "type": "string",
      "enum": [
        "interactive_user",
        "notebook_runtime",
        "query_runner",
        "preview_publisher",
        "sync_engine",
        "repair_executor",
        "provider_publisher",
        "workflow_bundle_runner",
        "profiler_capture_service",
        "ai_assistant",
        "incident_responder"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "human_local",
        "machine_local",
        "machine_remote_agent",
        "ai_hosted_provider",
        "policy_driven",
        "imported_evidence"
      ]
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "workspace",
        "notebook",
        "request_workspace",
        "data_workspace",
        "preview_route",
        "sync_lane",
        "repair_scope",
        "provider_draft",
        "workflow_bundle",
        "performance_session",
        "incident_workspace"
      ]
    },
    "checkpoint_class": {
      "type": "string",
      "enum": [
        "pre_mutation",
        "execution_bundle",
        "export_snapshot",
        "reconciliation_checkpoint",
        "repair_checkpoint",
        "incident_capture"
      ]
    },
    "checkpoint_role": {
      "type": "string",
      "enum": [
        "created_before_mutation",
        "produced_by_mutation",
        "required_for_manual_recovery"
      ]
    },
    "automation_influence": {
      "type": "string",
      "enum": [
        "none",
        "notebook_runtime",
        "query_plan_automation",
        "preview_publish_automation",
        "sync_reconciliation",
        "workflow_bundle",
        "repair_transaction",
        "incident_capture",
        "ai_evidence_capture"
      ]
    },
    "policy_influence": {
      "type": "string",
      "enum": [
        "none",
        "policy_checked",
        "approval_bound",
        "reauth_gate",
        "incident_retention",
        "provider_publish_rules"
      ]
    },
    "group_phase_class": {
      "type": "string",
      "enum": [
        "primary_mutation",
        "derived_artifact_follow_on",
        "audit_capture",
        "repair_follow_on",
        "incident_follow_on"
      ]
    },
    "checkpoint_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkpoint_id", "checkpoint_class", "checkpoint_role"],
      "properties": {
        "checkpoint_id": { "$ref": "#/$defs/non_empty_string" },
        "checkpoint_class": { "$ref": "#/$defs/checkpoint_class" },
        "checkpoint_role": { "$ref": "#/$defs/checkpoint_role" }
      }
    },
    "source_contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doc_ref", "schema_ref", "packet_ref", "report_ref", "fixture_manifest_ref"],
      "properties": {
        "doc_ref": { "type": "string", "const": "docs/state/m5_mutation_lineage.md" },
        "schema_ref": { "type": "string", "const": "schemas/state/m5_mutation_lineage.schema.json" },
        "packet_ref": { "type": "string", "const": "artifacts/state/m5_mutation_lineage.json" },
        "report_ref": { "type": "string", "const": "artifacts/state/m5_mutation_lineage.md" },
        "fixture_manifest_ref": { "type": "string", "const": "fixtures/state/m5_mutation_lineage/manifest.yaml" }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mutation_id",
        "group_id",
        "lineage_root_id",
        "surface_class",
        "artifact_class",
        "actor_class",
        "source_class",
        "scope_class",
        "scope_id",
        "checkpoint_refs",
        "reversal_class",
        "affected_file_count",
        "automation_influence",
        "policy_influence",
        "consumer_refs",
        "notes"
      ],
      "properties": {
        "mutation_id": { "$ref": "#/$defs/non_empty_string" },
        "group_id": { "$ref": "#/$defs/non_empty_string" },
        "lineage_root_id": { "$ref": "#/$defs/non_empty_string" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "artifact_class": { "$ref": "#/$defs/artifact_class" },
        "actor_class": { "$ref": "#/$defs/actor_class" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "scope_class": { "$ref": "#/$defs/scope_class" },
        "scope_id": { "$ref": "#/$defs/non_empty_string" },
        "checkpoint_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/checkpoint_ref" }
        },
        "reversal_class": { "$ref": "#/$defs/reversal_class" },
        "affected_file_count": { "type": "integer", "minimum": 1 },
        "automation_influence": { "$ref": "#/$defs/automation_influence" },
        "policy_influence": { "$ref": "#/$defs/policy_influence" },
        "consumer_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/repo_ref" }
        },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_id",
        "lineage_root_id",
        "phase_class",
        "title",
        "primary_surface_class",
        "member_mutation_ids",
        "reversal_class",
        "total_file_count",
        "artifact_classes",
        "automation_influences",
        "policy_influences",
        "checkpoint_refs",
        "consumer_refs",
        "notes"
      ],
      "properties": {
        "group_id": { "$ref": "#/$defs/non_empty_string" },
        "lineage_root_id": { "$ref": "#/$defs/non_empty_string" },
        "phase_class": { "$ref": "#/$defs/group_phase_class" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "primary_surface_class": { "$ref": "#/$defs/surface_class" },
        "member_mutation_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "reversal_class": { "$ref": "#/$defs/reversal_class" },
        "total_file_count": { "type": "integer", "minimum": 1 },
        "artifact_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/artifact_class" }
        },
        "automation_influences": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/automation_influence" }
        },
        "policy_influences": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/policy_influence" }
        },
        "checkpoint_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/checkpoint_ref" }
        },
        "consumer_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/repo_ref" }
        },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "history_inspector_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "lineage_root_id",
        "title",
        "primary_surface_class",
        "group_ids",
        "mutation_ids",
        "highest_risk_reversal_class",
        "reversal_classes",
        "total_file_count",
        "artifact_classes",
        "automation_influences",
        "policy_influences",
        "checkpoint_ids",
        "reopen_action_label",
        "notes"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lineage_root_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "primary_surface_class": { "$ref": "#/$defs/surface_class" },
        "group_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "mutation_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "highest_risk_reversal_class": { "$ref": "#/$defs/reversal_class" },
        "reversal_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reversal_class" }
        },
        "total_file_count": { "type": "integer", "minimum": 1 },
        "artifact_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/artifact_class" }
        },
        "automation_influences": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/automation_influence" }
        },
        "policy_influences": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/policy_influence" }
        },
        "checkpoint_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "reopen_action_label": { "$ref": "#/$defs/non_empty_string" },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "support_export_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "lineage_root_id",
        "group_ids",
        "mutation_ids",
        "highest_risk_reversal_class",
        "reversal_classes",
        "total_file_count",
        "artifact_classes",
        "automation_influences",
        "policy_influences",
        "raw_payload_excluded",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "single_lineage_thread_preserved",
        "notes"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lineage_root_id": { "$ref": "#/$defs/non_empty_string" },
        "group_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "mutation_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "highest_risk_reversal_class": { "$ref": "#/$defs/reversal_class" },
        "reversal_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reversal_class" }
        },
        "total_file_count": { "type": "integer", "minimum": 1 },
        "artifact_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/artifact_class" }
        },
        "automation_influences": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/automation_influence" }
        },
        "policy_influences": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/policy_influence" }
        },
        "raw_payload_excluded": { "type": "boolean", "const": true },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "ambient_authority_excluded": { "type": "boolean", "const": true },
        "single_lineage_thread_preserved": { "type": "boolean", "const": true },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "title",
        "source_contract_refs",
        "entries",
        "groups",
        "history_inspector_rows",
        "support_export_rows",
        "invariants"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "m5_mutation_lineage_packet_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "source_contract_refs": { "$ref": "#/$defs/source_contract_refs" },
        "entries": {
          "type": "array",
          "minItems": 12,
          "items": { "$ref": "#/$defs/entry" }
        },
        "groups": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/group" }
        },
        "history_inspector_rows": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/history_inspector_row" }
        },
        "support_export_rows": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/support_export_row" }
        },
        "invariants": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "fixture_id",
        "expected_lineage_root_id",
        "primary_surface_class",
        "highest_risk_reversal_class",
        "total_file_count",
        "artifact_classes",
        "automation_influences",
        "policy_influences",
        "history_inspector_row_id",
        "support_export_row_id",
        "consumer_ref",
        "notes"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "m5_mutation_lineage_fixture_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "fixture_id": { "$ref": "#/$defs/non_empty_string" },
        "expected_lineage_root_id": { "$ref": "#/$defs/non_empty_string" },
        "primary_surface_class": { "$ref": "#/$defs/surface_class" },
        "highest_risk_reversal_class": { "$ref": "#/$defs/reversal_class" },
        "total_file_count": { "type": "integer", "minimum": 1 },
        "artifact_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/artifact_class" }
        },
        "automation_influences": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/automation_influence" }
        },
        "policy_influences": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/policy_influence" }
        },
        "history_inspector_row_id": { "$ref": "#/$defs/non_empty_string" },
        "support_export_row_id": { "$ref": "#/$defs/non_empty_string" },
        "consumer_ref": { "$ref": "#/$defs/repo_ref" },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  }
}
