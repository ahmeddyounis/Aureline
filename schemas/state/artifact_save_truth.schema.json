{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/state/artifact_save_truth.schema.json",
  "title": "Artifact save truth",
  "description": "Boundary schema for the artifact_save_truth_packet_record and artifact_save_truth_fixture_record emitted by aureline-shell. The packet freezes metadata-sensitive save cues, fallback disclosure actions, and no-silent-stomp mutator guards across notebook, request, export, preview, sync, draft, overlay, and archive-backed artifact families.",
  "oneOf": [
    {
      "$ref": "#/$defs/packet"
    },
    {
      "$ref": "#/$defs/fixture"
    }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "repo_ref": {
      "type": "string",
      "pattern": "^(artifacts|crates|docs|fixtures|schemas)/.+"
    },
    "root_class": {
      "type": "string",
      "enum": [
        "local_filesystem",
        "remote_agent",
        "container_mount",
        "archive_packaged",
        "generated_managed",
        "virtual_provider_backed",
        "managed_offline_bundle"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "notebook_document",
        "notebook_output_artifact",
        "request_workspace_document",
        "request_response_snapshot",
        "database_export_artifact",
        "profiler_trace_artifact",
        "preview_output_artifact",
        "sync_packet_artifact",
        "provider_local_draft",
        "infrastructure_overlay_document",
        "imported_archive_capture"
      ]
    },
    "path_identity_class": {
      "type": "string",
      "enum": [
        "canonical_filesystem_object",
        "generated_source_identity",
        "provider_object_identity",
        "imported_snapshot_identity",
        "local_draft_identity",
        "offline_bundle_identity"
      ]
    },
    "save_fallback": {
      "type": "string",
      "enum": [
        "atomic_replace",
        "conditional_remote_write",
        "in_place_write",
        "save_as_copy",
        "regenerate_from_source",
        "stage_local_draft",
        "compare_only_blocked"
      ]
    },
    "metadata_indicator": {
      "type": "string",
      "enum": [
        "encoding",
        "newline_mode",
        "bom_or_final_newline",
        "execute_bit_or_permissions",
        "generated_state_boundary",
        "logical_target_ambiguity"
      ]
    },
    "disclosure_class": {
      "type": "string",
      "enum": [
        "atomic_with_disclosed_fallback",
        "regenerate_or_export_disclosed",
        "draft_stage_disclosed",
        "compare_only_blocked"
      ]
    },
    "fallback_action_class": {
      "type": "string",
      "enum": [
        "continue",
        "inspect_safety_note",
        "alternate_target",
        "compare_before_save"
      ]
    },
    "mutator_class": {
      "type": "string",
      "enum": [
        "format_on_save",
        "organize_imports",
        "refactor_apply",
        "ai_apply",
        "generated_output_write"
      ]
    },
    "drift_policy": {
      "type": "string",
      "enum": [
        "rebase_or_abort",
        "compare_then_manual_recovery",
        "not_applicable"
      ]
    },
    "evidence_class": {
      "type": "string",
      "enum": [
        "lossy_decode_risk",
        "metadata_preservation_disclosure",
        "execute_bit_retention",
        "export_or_regenerate_not_exact_save",
        "logical_target_ambiguity_disclosure",
        "mid_flight_drift_rebase_required"
      ]
    },
    "fallback_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_class",
        "visible_label",
        "enabled",
        "summary"
      ],
      "properties": {
        "action_class": {
          "$ref": "#/$defs/fallback_action_class"
        },
        "visible_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "enabled": {
          "type": "boolean"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "disabled_reason": {
          "type": "string"
        }
      }
    },
    "mutator_guard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mutator_class",
        "available",
        "drift_policy_class",
        "summary"
      ],
      "properties": {
        "mutator_class": {
          "$ref": "#/$defs/mutator_class"
        },
        "available": {
          "type": "boolean"
        },
        "drift_policy_class": {
          "$ref": "#/$defs/drift_policy"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "source_contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "doc_ref",
        "schema_ref",
        "packet_ref",
        "report_ref",
        "fixture_dir_ref",
        "fixture_readme_ref"
      ],
      "properties": {
        "doc_ref": {
          "const": "docs/state/artifact_save_truth.md"
        },
        "schema_ref": {
          "const": "schemas/state/artifact_save_truth.schema.json"
        },
        "packet_ref": {
          "const": "artifacts/state/artifact_save_truth.json"
        },
        "report_ref": {
          "const": "artifacts/state/artifact_save_truth.md"
        },
        "fixture_dir_ref": {
          "const": "fixtures/state/artifact_save_truth"
        },
        "fixture_readme_ref": {
          "const": "fixtures/state/artifact_save_truth/README.md"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_count",
        "fixture_count",
        "preferred_atomic_row_count",
        "regenerate_or_export_row_count",
        "draft_stage_row_count",
        "compare_only_blocked_row_count",
        "logical_target_indicator_row_count",
        "rebase_or_abort_mutator_count"
      ],
      "properties": {
        "row_count": {
          "type": "integer",
          "minimum": 0
        },
        "fixture_count": {
          "type": "integer",
          "minimum": 0
        },
        "preferred_atomic_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "regenerate_or_export_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "draft_stage_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "compare_only_blocked_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "logical_target_indicator_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "rebase_or_abort_mutator_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "surface_class",
        "title",
        "supported_root_classes",
        "path_identity_class",
        "preferred_save_path",
        "disclosed_alternate_paths",
        "metadata_sensitivity_indicators",
        "save_fallback_disclosure_class",
        "fallback_actions",
        "mutator_guards",
        "consumer_refs",
        "fixture_refs",
        "summary"
      ],
      "properties": {
        "row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_class": {
          "$ref": "#/$defs/surface_class"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "supported_root_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/root_class"
          }
        },
        "path_identity_class": {
          "$ref": "#/$defs/path_identity_class"
        },
        "preferred_save_path": {
          "$ref": "#/$defs/save_fallback"
        },
        "disclosed_alternate_paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/save_fallback"
          }
        },
        "metadata_sensitivity_indicators": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/metadata_indicator"
          }
        },
        "save_fallback_disclosure_class": {
          "$ref": "#/$defs/disclosure_class"
        },
        "fallback_actions": {
          "type": "array",
          "minItems": 4,
          "items": {
            "$ref": "#/$defs/fallback_action"
          }
        },
        "mutator_guards": {
          "type": "array",
          "minItems": 5,
          "items": {
            "$ref": "#/$defs/mutator_guard"
          }
        },
        "consumer_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/repo_ref"
          }
        },
        "fixture_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/repo_ref"
          }
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "title",
        "source_contract_refs",
        "rows",
        "summary",
        "invariants"
      ],
      "properties": {
        "record_kind": {
          "const": "artifact_save_truth_packet_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "packet_id": {
          "const": "state.artifact_save_truth.v1"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/source_contract_refs"
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/row"
          }
        },
        "summary": {
          "$ref": "#/$defs/summary"
        },
        "invariants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "fixture_id",
        "expected_row_id",
        "scenario",
        "root_class",
        "observed_save_path",
        "metadata_sensitivity_indicators",
        "save_fallback_disclosure_class",
        "fallback_actions",
        "drift_policy_class",
        "evidence_classes",
        "notes"
      ],
      "properties": {
        "record_kind": {
          "const": "artifact_save_truth_fixture_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "fixture_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "expected_row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "scenario": {
          "$ref": "#/$defs/non_empty_string"
        },
        "root_class": {
          "$ref": "#/$defs/root_class"
        },
        "observed_save_path": {
          "$ref": "#/$defs/save_fallback"
        },
        "metadata_sensitivity_indicators": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/metadata_indicator"
          }
        },
        "save_fallback_disclosure_class": {
          "$ref": "#/$defs/disclosure_class"
        },
        "fallback_actions": {
          "type": "array",
          "minItems": 4,
          "items": {
            "$ref": "#/$defs/fallback_action"
          }
        },
        "active_mutator": {
          "$ref": "#/$defs/mutator_class"
        },
        "drift_policy_class": {
          "$ref": "#/$defs/drift_policy"
        },
        "evidence_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_class"
          }
        },
        "notes": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
