{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/m5-fault-crash-certification.schema.json",
  "title": "Aureline M5 fault/crash certification packet",
  "description": "Boundary schema for the m5_fault_crash_certification_packet emitted by aureline-support. The packet certifies each claimed M5 host family on each claimed M5 profile by binding one shared row to restart, crash-artifact, symbolication, diagnostics-schema, and field-readiness proof, then exposing the same certification index to Help/About, service-health, support-export, and release-manifest consumers. The packet is metadata-safe and never embeds raw dumps, raw logs, raw source content, or live credentials.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "doc_ref",
    "schema_ref",
    "artifact_ref",
    "source_spec_refs",
    "supporting_contract_refs",
    "claimed_profiles",
    "certification_rows",
    "downgrade_rules",
    "surface_bindings",
    "export_safe_summary"
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "claimed_profile": {
      "type": "string",
      "enum": [
        "desktop_local_first",
        "hybrid_remote_attach",
        "managed_cloud",
        "self_hosted_sovereign",
        "air_gapped_mirror_only"
      ]
    },
    "certification_state": {
      "type": "string",
      "enum": [
        "qualified",
        "limited_profile_scoped",
        "experimental_local_only",
        "not_marketed",
        "blocked_unverified"
      ]
    },
    "fault_domain_class": {
      "type": "string",
      "enum": [
        "shell_interaction_core",
        "workspace_knowledge_group",
        "session_execution_host",
        "extension_or_external_tool_host",
        "ai_tool_broker",
        "remote_connector",
        "policy_verifier_helper"
      ]
    },
    "restart_class": {
      "type": "string",
      "enum": [
        "stateless_helper",
        "workspace_knowledge",
        "session_scoped",
        "privileged_externally_mutating",
        "authority_verifier"
      ]
    },
    "symbolication_posture": {
      "type": "string",
      "enum": [
        "exact_build_local_first",
        "exact_build_mirror_allowed",
        "imported_or_approximate_labeled",
        "shared_claim_blocked"
      ]
    },
    "diagnostics_governance_posture": {
      "type": "string",
      "enum": [
        "local_first_schema_governed",
        "managed_export_schema_governed",
        "manual_export_only",
        "claim_blocked_pending_schema_refresh"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "help_about",
        "service_health",
        "support_export",
        "release_manifest"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "restart_evidence_stale",
        "crash_artifact_proof_stale",
        "symbolication_not_exact_build",
        "diagnostic_schema_stale",
        "field_readiness_drill_stale",
        "profile_capability_absent",
        "consumer_binding_missing"
      ]
    },
    "certification_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "certification_row_id",
        "host_family_id",
        "host_family_label",
        "profile",
        "published_state",
        "fault_domain_class",
        "restart_class",
        "restart_posture_packet_ref",
        "crash_artifact_packet_ref",
        "symbolication_packet_ref",
        "diagnostic_schema_packet_ref",
        "field_readiness_packet_ref",
        "symbolication_posture",
        "diagnostics_governance_posture",
        "stale_proof_tokens",
        "downgrade_rule_ids",
        "summary"
      ],
      "properties": {
        "certification_row_id": { "$ref": "#/$defs/non_empty_string" },
        "host_family_id": { "$ref": "#/$defs/non_empty_string" },
        "host_family_label": { "$ref": "#/$defs/non_empty_string" },
        "profile": { "$ref": "#/$defs/claimed_profile" },
        "published_state": { "$ref": "#/$defs/certification_state" },
        "fault_domain_class": { "$ref": "#/$defs/fault_domain_class" },
        "restart_class": { "$ref": "#/$defs/restart_class" },
        "restart_posture_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "crash_artifact_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "symbolication_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "diagnostic_schema_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "field_readiness_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "symbolication_posture": { "$ref": "#/$defs/symbolication_posture" },
        "diagnostics_governance_posture": {
          "$ref": "#/$defs/diagnostics_governance_posture"
        },
        "stale_proof_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "downgrade_rule_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "trigger_class",
        "source_state",
        "downgraded_state",
        "required_effect",
        "rationale",
        "evidence_refs"
      ],
      "properties": {
        "rule_id": { "$ref": "#/$defs/non_empty_string" },
        "trigger_class": { "$ref": "#/$defs/downgrade_trigger" },
        "source_state": { "$ref": "#/$defs/certification_state" },
        "downgraded_state": { "$ref": "#/$defs/certification_state" },
        "required_effect": { "$ref": "#/$defs/non_empty_string" },
        "rationale": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "minItems": 1
        }
      }
    },
    "surface_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "consumer_ref",
        "ingested_packet_id",
        "certification_row_count",
        "required_verbatim_fields",
        "narrow_on_stale_proof",
        "explicit_limited_state_labels_required",
        "summary"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/surface_class" },
        "consumer_ref": { "$ref": "#/$defs/non_empty_string" },
        "ingested_packet_id": { "$ref": "#/$defs/non_empty_string" },
        "certification_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "required_verbatim_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "minItems": 1
        },
        "narrow_on_stale_proof": { "type": "boolean" },
        "explicit_limited_state_labels_required": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  },
  "properties": {
    "record_kind": {
      "const": "m5_fault_crash_certification_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "generated_at": {
      "$ref": "#/$defs/timestamp"
    },
    "doc_ref": {
      "const": "docs/help/support/m5-fault-crash-certification.md"
    },
    "schema_ref": {
      "const": "schemas/support/m5-fault-crash-certification.schema.json"
    },
    "artifact_ref": {
      "const": "artifacts/support/m5/fault-crash-certification.md"
    },
    "source_spec_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1
    },
    "supporting_contract_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1
    },
    "claimed_profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/claimed_profile" },
      "minItems": 1
    },
    "certification_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/certification_row" },
      "minItems": 1
    },
    "downgrade_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/downgrade_rule" },
      "minItems": 1
    },
    "surface_bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_binding" },
      "minItems": 1
    },
    "export_safe_summary": {
      "$ref": "#/$defs/non_empty_string"
    }
  }
}
