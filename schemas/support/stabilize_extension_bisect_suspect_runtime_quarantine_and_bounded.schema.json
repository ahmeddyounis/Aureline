{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/stabilize_extension_bisect_suspect_runtime_quarantine_and_bounded.schema.json",
  "title": "Aureline stabilized extension-bisect, suspect-runtime quarantine, and bounded repair orchestration",
  "description": "Boundary schema for the stabilized_orchestration_profile_record and stabilized_orchestration_support_packet_record consumed by aureline-support's stabilized orchestration module. A stabilized orchestration profile binds extension bisect, suspect-runtime quarantine, and bounded repair into one typed, truthful, and narrow recovery contract. Both shapes use closed vocabularies so the chrome, headless export, and reviewer surfaces share one truth.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/stabilized_orchestration_profile_record"
    },
    {
      "$ref": "#/$defs/stabilized_orchestration_support_packet_record"
    }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "profile_class": {
      "type": "string",
      "enum": [
        "post_crash_loop_orchestration",
        "user_invoked_orchestration",
        "policy_forced_orchestration",
        "diagnostics_orchestration"
      ]
    },
    "extension_bisect_status_class": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "escalated_to_quarantine",
        "restored_prior_state"
      ]
    },
    "quarantine_reason_class": {
      "type": "string",
      "enum": [
        "crash_loop_suspected",
        "extension_regression_suspected",
        "runtime_fault_domain_suspected",
        "policy_forced"
      ]
    },
    "bounded_repair_blast_radius_class": {
      "type": "string",
      "enum": [
        "cache_index_only",
        "extension_quarantine_only",
        "toolchain_reresolve_only",
        "remote_agent_rollback_only",
        "policy_refresh_only",
        "escalation_only"
      ]
    },
    "bounded_repair_compensation_class": {
      "type": "string",
      "enum": [
        "rollbackable",
        "reversible",
        "escalation_only"
      ]
    },
    "bounded_repair_status_class": {
      "type": "string",
      "enum": [
        "previewed",
        "applied",
        "reversed",
        "escalated"
      ]
    },
    "preserved_state_class": {
      "type": "string",
      "enum": [
        "user_authored_files",
        "open_buffer_selection",
        "workspace_trust_store",
        "credential_store",
        "session_restore_store",
        "support_export_store",
        "extension_state_store",
        "runtime_quarantine_store"
      ]
    },
    "retained_capability_class": {
      "type": "string",
      "enum": [
        "local_editing",
        "basic_navigation",
        "local_search",
        "local_git_operations",
        "local_diagnostics_export",
        "support_bundle_preview",
        "project_doctor_surfaces",
        "safe_mode_exit_action"
      ]
    },
    "accessibility_dimension_class": {
      "type": "string",
      "enum": [
        "keyboard",
        "screen_reader",
        "ime_grapheme_bidi",
        "zoom",
        "high_contrast",
        "reduced_motion"
      ]
    },
    "accessibility_posture_class": {
      "type": "string",
      "enum": [
        "fully_supported",
        "degraded_but_functional",
        "not_applicable",
        "blocked_in_safe_mode"
      ]
    },
    "recovery_ladder_rung_class": {
      "type": "string",
      "enum": [
        "safe_mode",
        "open_without_restore",
        "disable_recent_extension",
        "disable_recent_layout",
        "open_logs",
        "export_crash_manifest",
        "report_issue",
        "extension_bisect",
        "bounded_repair"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported"
      ]
    },
    "extension_bisect_binding": {
      "type": "object",
      "required": [
        "session_ref",
        "step_refs",
        "finding_ref",
        "restore_ref",
        "support_packet_ref",
        "status_class"
      ],
      "properties": {
        "session_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "step_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "finding_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "restore_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "support_packet_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "status_class": {
          "$ref": "#/$defs/extension_bisect_status_class"
        }
      },
      "additionalProperties": false
    },
    "suspect_runtime_quarantine_binding": {
      "type": "object",
      "required": [
        "quarantine_ref",
        "lane_ref",
        "owner_ref",
        "reason_class",
        "expires_at",
        "clear_action_ref",
        "reenable_action_ref",
        "evidence_refs"
      ],
      "properties": {
        "quarantine_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "lane_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "owner_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reason_class": {
          "$ref": "#/$defs/quarantine_reason_class"
        },
        "expires_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        },
        "clear_action_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reenable_action_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      },
      "additionalProperties": false
    },
    "bounded_repair_binding": {
      "type": "object",
      "required": [
        "transaction_ref",
        "preview_ref",
        "outcome_ref",
        "blast_radius_class",
        "compensation_class",
        "status_class"
      ],
      "properties": {
        "transaction_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preview_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "outcome_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "blast_radius_class": {
          "$ref": "#/$defs/bounded_repair_blast_radius_class"
        },
        "compensation_class": {
          "$ref": "#/$defs/bounded_repair_compensation_class"
        },
        "status_class": {
          "$ref": "#/$defs/bounded_repair_status_class"
        }
      },
      "additionalProperties": false
    },
    "retained_capability_record": {
      "type": "object",
      "required": [
        "capability_class",
        "rationale",
        "support_guidance",
        "explicitly_tested"
      ],
      "properties": {
        "capability_class": {
          "$ref": "#/$defs/retained_capability_class"
        },
        "rationale": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "support_guidance": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "explicitly_tested": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "accessibility_posture_row": {
      "type": "object",
      "required": [
        "target_id",
        "target_kind",
        "dimension",
        "posture",
        "explanation"
      ],
      "properties": {
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_kind": {
          "type": "string",
          "enum": [
            "capability",
            "surface"
          ]
        },
        "dimension": {
          "$ref": "#/$defs/accessibility_dimension_class"
        },
        "posture": {
          "$ref": "#/$defs/accessibility_posture_class"
        },
        "explanation": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      },
      "additionalProperties": false
    },
    "recovery_ladder_binding_row": {
      "type": "object",
      "required": [
        "rung_class",
        "support_class",
        "requires_review",
        "rung_summary",
        "evidence_refs"
      ],
      "properties": {
        "rung_class": {
          "$ref": "#/$defs/recovery_ladder_rung_class"
        },
        "support_class": {
          "$ref": "#/$defs/support_class"
        },
        "requires_review": {
          "type": "boolean"
        },
        "rung_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      },
      "additionalProperties": false
    },
    "stabilized_orchestration_profile_record": {
      "type": "object",
      "required": [
        "schema_version",
        "record_kind",
        "profile_id",
        "profile_class",
        "captured_at",
        "doctor_finding_ref",
        "support_packet_ref",
        "extension_bisect_binding",
        "suspect_runtime_quarantine_binding",
        "bounded_repair_binding",
        "retained_capabilities",
        "preserved_state_classes",
        "accessibility_postures",
        "recovery_ladder_bindings",
        "destructive_resets_present"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "record_kind": {
          "const": "stabilized_orchestration_profile_record"
        },
        "profile_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "profile_class": {
          "$ref": "#/$defs/profile_class"
        },
        "captured_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        },
        "doctor_finding_ref": {
          "type": "string",
          "pattern": "^doctor\\.finding\\..+$"
        },
        "support_packet_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "extension_bisect_binding": {
          "$ref": "#/$defs/extension_bisect_binding"
        },
        "suspect_runtime_quarantine_binding": {
          "$ref": "#/$defs/suspect_runtime_quarantine_binding"
        },
        "bounded_repair_binding": {
          "$ref": "#/$defs/bounded_repair_binding"
        },
        "retained_capabilities": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/retained_capability_record"
          }
        },
        "preserved_state_classes": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/preserved_state_class"
          }
        },
        "accessibility_postures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/accessibility_posture_row"
          }
        },
        "recovery_ladder_bindings": {
          "type": "array",
          "minItems": 9,
          "maxItems": 9,
          "items": {
            "$ref": "#/$defs/recovery_ladder_binding_row"
          }
        },
        "destructive_resets_present": {
          "type": "boolean",
          "const": false
        }
      },
      "additionalProperties": false
    },
    "stabilized_orchestration_support_packet_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "captured_at",
        "doc_ref",
        "schema_ref",
        "profile_id",
        "profile_class",
        "doctor_finding_ref",
        "extension_bisect_binding",
        "suspect_runtime_quarantine_binding",
        "bounded_repair_binding",
        "retained_capability_rows",
        "preserved_state_classes",
        "accessibility_posture_rows",
        "recovery_ladder_binding_rows",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "destructive_resets_present"
      ],
      "properties": {
        "record_kind": {
          "const": "stabilized_orchestration_support_packet_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "packet_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "captured_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        },
        "doc_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "schema_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "profile_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "profile_class": {
          "$ref": "#/$defs/profile_class"
        },
        "doctor_finding_ref": {
          "type": "string",
          "pattern": "^doctor\\.finding\\..+$"
        },
        "extension_bisect_binding": {
          "$ref": "#/$defs/extension_bisect_binding"
        },
        "suspect_runtime_quarantine_binding": {
          "$ref": "#/$defs/suspect_runtime_quarantine_binding"
        },
        "bounded_repair_binding": {
          "$ref": "#/$defs/bounded_repair_binding"
        },
        "retained_capability_rows": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/retained_capability_record"
          }
        },
        "preserved_state_classes": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/preserved_state_class"
          }
        },
        "accessibility_posture_rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/accessibility_posture_row"
          }
        },
        "recovery_ladder_binding_rows": {
          "type": "array",
          "minItems": 9,
          "maxItems": 9,
          "items": {
            "$ref": "#/$defs/recovery_ladder_binding_row"
          }
        },
        "raw_private_material_excluded": {
          "type": "boolean",
          "const": true
        },
        "ambient_authority_excluded": {
          "type": "boolean",
          "const": true
        },
        "destructive_resets_present": {
          "type": "boolean",
          "const": false
        }
      },
      "additionalProperties": false
    }
  }
}
