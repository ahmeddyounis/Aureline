{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/depth-surface-schema-registry.schema.json",
  "title": "Depth-surface schema registry packet",
  "description": "Boundary schema for the support-side packet that freezes M5 depth-surface telemetry, diagnostics, consent-ledger inheritance, endpoint truth, retention posture, and redaction-default packet classes. The packet covers notebook, provider, profiler, pipeline, preview, and data surfaces and keeps support export separate from ambient telemetry even when the same registry vocabulary is reused.",
  "$ref": "#/$defs/packet",
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "depth_surface": {
      "type": "string",
      "enum": [
        "notebook_kernel",
        "provider_run_session",
        "profiler_replay_session",
        "pipeline_viewer",
        "preview_dev_server",
        "data_api_connector"
      ]
    },
    "signal_class": {
      "type": "string",
      "enum": [
        "crash_diagnostic",
        "performance_diagnostic",
        "feature_usage_telemetry",
        "support_export"
      ]
    },
    "consent_state": {
      "type": "string",
      "enum": [
        "local_capture_pending_submission",
        "disabled_pending_opt_in",
        "explicit_user_request_required",
        "admin_locked_disabled"
      ]
    },
    "endpoint_state": {
      "type": "string",
      "enum": [
        "local_only_until_explicit_submission",
        "optional_upload_after_opt_in",
        "manual_export_only",
        "disabled_by_policy"
      ]
    },
    "diagnostic_data_class": {
      "type": "string",
      "enum": [
        "metadata_only",
        "environment_adjacent",
        "code_adjacent",
        "high_risk"
      ]
    },
    "diagnostic_opt_in_scope": {
      "type": "string",
      "enum": [
        "explicit_submission_or_policy",
        "opt_in_only",
        "user_initiated_export_only",
        "admin_policy_gated"
      ]
    },
    "retention_class": {
      "type": "string",
      "enum": [
        "local_user_owned_until_delete_or_attach",
        "local_sampling_window",
        "managed_contract_window",
        "local_manifest_until_sent"
      ]
    },
    "redaction_profile": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "environment_summary_only",
        "operator_only_restricted",
        "local_only_review_required"
      ]
    },
    "schema_declaration_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id",
        "schema_version",
        "schema_ref",
        "surface",
        "signal_class",
        "purpose",
        "data_class",
        "opt_in_scope",
        "active_consent_state",
        "active_endpoint_state",
        "allowed_fields",
        "prohibited_content_classes",
        "retention_class",
        "redaction_profile",
        "owner_ref",
        "reviewer_refs",
        "evidence_refs"
      ],
      "properties": {
        "schema_id": { "$ref": "#/$defs/non_empty_string" },
        "schema_version": { "type": "integer", "minimum": 1 },
        "schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "surface": { "$ref": "#/$defs/depth_surface" },
        "signal_class": { "$ref": "#/$defs/signal_class" },
        "purpose": { "$ref": "#/$defs/non_empty_string" },
        "data_class": { "$ref": "#/$defs/diagnostic_data_class" },
        "opt_in_scope": { "$ref": "#/$defs/diagnostic_opt_in_scope" },
        "active_consent_state": { "$ref": "#/$defs/consent_state" },
        "active_endpoint_state": { "$ref": "#/$defs/endpoint_state" },
        "allowed_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "prohibited_content_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "retention_class": { "$ref": "#/$defs/retention_class" },
        "redaction_profile": { "$ref": "#/$defs/redaction_profile" },
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "reviewer_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "consent_ledger_binding_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_class",
        "consent_ledger_entry_ref",
        "stable_registry_entry_ref",
        "endpoint_policy_ref",
        "inheritance_note",
        "open_source_local_default",
        "managed_builds_may_narrow_but_not_broaden",
        "explicit_export_not_ambient_telemetry"
      ],
      "properties": {
        "signal_class": { "$ref": "#/$defs/signal_class" },
        "consent_ledger_entry_ref": { "$ref": "#/$defs/non_empty_string" },
        "stable_registry_entry_ref": { "$ref": "#/$defs/non_empty_string" },
        "endpoint_policy_ref": { "$ref": "#/$defs/non_empty_string" },
        "inheritance_note": { "$ref": "#/$defs/non_empty_string" },
        "open_source_local_default": { "type": "boolean" },
        "managed_builds_may_narrow_but_not_broaden": { "type": "boolean" },
        "explicit_export_not_ambient_telemetry": { "type": "boolean" }
      }
    },
    "surface_inspection_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "declared_signal_classes",
        "disabled_by_default_signal_classes",
        "export_only_signal_classes",
        "redaction_default_packet_class_refs",
        "retention_classes",
        "inspection_note"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/depth_surface" },
        "declared_signal_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/signal_class" }
        },
        "disabled_by_default_signal_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/signal_class" }
        },
        "export_only_signal_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/signal_class" }
        },
        "redaction_default_packet_class_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "retention_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/retention_class" }
        },
        "inspection_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "packet_class_manifest_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_class_id",
        "packet_class_label",
        "surfaces",
        "signal_classes",
        "default_redaction_profile",
        "local_only_by_default",
        "explicit_review_required_before_share",
        "raw_source_code_forbidden",
        "filenames_and_paths_forbidden",
        "prompt_bodies_forbidden",
        "terminal_contents_forbidden",
        "secrets_forbidden",
        "clipboard_contents_forbidden",
        "evidence_refs"
      ],
      "properties": {
        "packet_class_id": { "$ref": "#/$defs/non_empty_string" },
        "packet_class_label": { "$ref": "#/$defs/non_empty_string" },
        "surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/depth_surface" }
        },
        "signal_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/signal_class" }
        },
        "default_redaction_profile": { "$ref": "#/$defs/redaction_profile" },
        "local_only_by_default": { "type": "boolean" },
        "explicit_review_required_before_share": { "type": "boolean" },
        "raw_source_code_forbidden": { "type": "boolean" },
        "filenames_and_paths_forbidden": { "type": "boolean" },
        "prompt_bodies_forbidden": { "type": "boolean" },
        "terminal_contents_forbidden": { "type": "boolean" },
        "secrets_forbidden": { "type": "boolean" },
        "clipboard_contents_forbidden": { "type": "boolean" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "generated_at",
        "doc_ref",
        "schema_ref",
        "source_spec_refs",
        "supporting_contract_refs",
        "normative_rules",
        "schema_declarations",
        "consent_ledger_bindings",
        "surface_inspections",
        "packet_class_manifest",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "depth_surface_schema_registry_packet"
        },
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "$ref": "#/$defs/non_empty_string" },
        "doc_ref": { "$ref": "#/$defs/non_empty_string" },
        "schema_ref": {
          "type": "string",
          "const": "schemas/support/depth-surface-schema-registry.schema.json"
        },
        "source_spec_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "supporting_contract_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "normative_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "schema_declarations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/schema_declaration_row" }
        },
        "consent_ledger_bindings": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/consent_ledger_binding_row" }
        },
        "surface_inspections": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_inspection_row" }
        },
        "packet_class_manifest": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/packet_class_manifest_row" }
        },
        "export_safe_summary": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  }
}
