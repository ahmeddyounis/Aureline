{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/stabilize_the_seeded_support_scenario_corpus_across_launch_archetypes_and_enterprise_network_rows.schema.json",
  "title": "Aureline stabilized seeded support-scenario corpus across launch archetypes and enterprise-network rows",
  "description": "Boundary schema for the stabilized_support_scenario_record, stabilized_scenario_report_record, stabilized_scenario_report_row_record, and stabilized_scenario_support_packet_record consumed by aureline-support's stabilized scenario corpus module. The corpus covers blocked-user recovery, support-export verification, diagnosis routing, and repair-preview validation across the full matrix of launch archetypes and enterprise-network postures. All shapes use closed vocabularies so the chrome, headless export, and reviewer surfaces share one truth.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/stabilized_support_scenario_record"
    },
    {
      "$ref": "#/$defs/stabilized_scenario_report_record"
    },
    {
      "$ref": "#/$defs/stabilized_scenario_report_row_record"
    },
    {
      "$ref": "#/$defs/stabilized_scenario_support_packet_record"
    }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "launch_archetype_class": {
      "type": "string",
      "enum": [
        "first_run",
        "update_restart",
        "crash_recovery",
        "enterprise_managed",
        "extension_install",
        "workspace_open"
      ]
    },
    "enterprise_network_row_class": {
      "type": "string",
      "enum": [
        "standard_internet",
        "air_gapped",
        "proxied",
        "offline_first",
        "restricted_enterprise"
      ]
    },
    "stabilized_scenario_class": {
      "type": "string",
      "enum": [
        "blocked_user_recovery",
        "support_export_verification",
        "diagnosis_routing",
        "repair_preview_validation",
        "safe_mode_transition",
        "crash_loop_center_evidence"
      ]
    },
    "scenario_claim_state_class": {
      "type": "string",
      "enum": [
        "green",
        "yellow_aging",
        "red_blocked",
        "stale_corpus"
      ]
    },
    "scenario_downgrade_trigger_class": {
      "type": "string",
      "enum": [
        "fixture_missing",
        "doc_missing",
        "schema_missing",
        "crate_consumer_missing",
        "integration_test_missing",
        "drill_step_unproven",
        "drill_proves_regression",
        "recovery_action_unsafe",
        "raw_private_material_present",
        "archetype_mismatch",
        "network_posture_mismatch"
      ]
    },
    "stabilized_support_scenario_record": {
      "type": "object",
      "required": [
        "schema_version",
        "record_kind",
        "scenario_id",
        "title",
        "launch_archetype_class",
        "enterprise_network_row_class",
        "stabilized_scenario_class",
        "doctor_finding_ref",
        "consumer_refs",
        "starting_condition",
        "validation_steps",
        "expected_first_actionable_artifact",
        "primary_fixture_refs",
        "scorecard_contribution",
        "claim_downgrade_rules",
        "safety",
        "references",
        "emitted_at"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "record_kind": {
          "type": "string",
          "const": "stabilized_support_scenario_record"
        },
        "scenario_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "launch_archetype_class": {
          "$ref": "#/$defs/launch_archetype_class"
        },
        "enterprise_network_row_class": {
          "$ref": "#/$defs/enterprise_network_row_class"
        },
        "stabilized_scenario_class": {
          "$ref": "#/$defs/stabilized_scenario_class"
        },
        "doctor_finding_ref": {
          "type": "string",
          "pattern": "^doctor\\.finding\\."
        },
        "consumer_refs": {
          "type": "object",
          "required": ["doc_ref", "schema_ref", "crate_consumer", "integration_test"],
          "properties": {
            "doc_ref": { "$ref": "#/$defs/non_empty_string" },
            "schema_ref": { "$ref": "#/$defs/non_empty_string" },
            "crate_consumer": { "$ref": "#/$defs/non_empty_string" },
            "integration_test": { "$ref": "#/$defs/non_empty_string" }
          }
        },
        "starting_condition": {
          "type": "object",
          "required": ["state_ref", "summary"],
          "properties": {
            "state_ref": { "$ref": "#/$defs/non_empty_string" },
            "summary": { "$ref": "#/$defs/reviewable_sentence" }
          }
        },
        "validation_steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["step_id", "step_class", "summary", "expected_artifact_kind", "expected_artifact_ref"],
            "properties": {
              "step_id": { "$ref": "#/$defs/non_empty_string" },
              "step_class": { "$ref": "#/$defs/non_empty_string" },
              "summary": { "$ref": "#/$defs/reviewable_sentence" },
              "expected_artifact_kind": { "$ref": "#/$defs/non_empty_string" },
              "expected_artifact_ref": { "$ref": "#/$defs/non_empty_string" }
            }
          }
        },
        "expected_first_actionable_artifact": {
          "type": "object",
          "required": ["artifact_kind", "artifact_ref", "recovery_action_class", "reviewer_summary"],
          "properties": {
            "artifact_kind": { "$ref": "#/$defs/non_empty_string" },
            "artifact_ref": { "$ref": "#/$defs/non_empty_string" },
            "recovery_action_class": { "$ref": "#/$defs/non_empty_string" },
            "reviewer_summary": { "$ref": "#/$defs/reviewable_sentence" }
          }
        },
        "primary_fixture_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "scorecard_contribution": {
          "type": "object",
          "required": ["scorecard_target", "coverage_class", "expected_state", "contributes_to_release_gate"],
          "properties": {
            "scorecard_target": { "$ref": "#/$defs/non_empty_string" },
            "coverage_class": { "$ref": "#/$defs/non_empty_string" },
            "expected_state": { "$ref": "#/$defs/non_empty_string" },
            "contributes_to_release_gate": { "type": "boolean" }
          }
        },
        "claim_downgrade_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["trigger_class", "claim_state_class", "reviewer_note"],
            "properties": {
              "trigger_class": { "$ref": "#/$defs/scenario_downgrade_trigger_class" },
              "claim_state_class": { "$ref": "#/$defs/scenario_claim_state_class" },
              "reviewer_note": { "$ref": "#/$defs/reviewable_sentence" }
            }
          }
        },
        "safety": {
          "type": "object",
          "required": ["read_only_diagnosis", "raw_private_material_excluded", "destructive_resets_present", "preserves_user_authored_files", "forbidden_fix_classes", "no_touch_boundary_set"],
          "properties": {
            "read_only_diagnosis": { "type": "boolean" },
            "raw_private_material_excluded": { "type": "boolean" },
            "destructive_resets_present": { "type": "boolean", "const": false },
            "preserves_user_authored_files": { "type": "boolean", "const": true },
            "forbidden_fix_classes": {
              "type": "array",
              "items": { "$ref": "#/$defs/non_empty_string" }
            },
            "no_touch_boundary_set": {
              "type": "array",
              "items": { "$ref": "#/$defs/non_empty_string" }
            }
          }
        },
        "references": {
          "type": "object",
          "required": ["lane_doc_ref", "recovery_ladder_ref", "diagnosis_latency_scorecard_ref"],
          "properties": {
            "lane_doc_ref": { "$ref": "#/$defs/non_empty_string" },
            "recovery_ladder_ref": { "$ref": "#/$defs/non_empty_string" },
            "diagnosis_latency_scorecard_ref": { "$ref": "#/$defs/non_empty_string" }
          }
        },
        "emitted_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        }
      }
    },
    "stabilized_scenario_report_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "report_id",
        "generated_at",
        "corpus_doc_ref",
        "corpus_schema_ref",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "required_launch_archetype_classes",
        "required_enterprise_network_row_classes",
        "rows"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "stabilized_scenario_report_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "report_id": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "corpus_doc_ref": { "$ref": "#/$defs/non_empty_string" },
        "corpus_schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "ambient_authority_excluded": { "type": "boolean", "const": true },
        "required_launch_archetype_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/launch_archetype_class" }
        },
        "required_enterprise_network_row_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/enterprise_network_row_class" }
        },
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stabilized_scenario_report_row_record"
          }
        }
      }
    },
    "stabilized_scenario_report_row_record": {
      "type": "object",
      "required": [
        "record_kind",
        "launch_archetype_class",
        "enterprise_network_row_class",
        "stabilized_scenario_class",
        "scenario_id",
        "title",
        "fixture_ref",
        "validation_step_classes",
        "expected_artifact_kinds",
        "recovery_action_class",
        "scorecard_target",
        "coverage_class",
        "expected_state",
        "contributes_to_release_gate",
        "downgrade_trigger_classes",
        "claim_state_classes",
        "doc_ref",
        "schema_ref",
        "crate_consumer_ref",
        "integration_test_ref",
        "metadata_safe_baseline_met"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "stabilized_scenario_report_row_record"
        },
        "launch_archetype_class": { "$ref": "#/$defs/launch_archetype_class" },
        "enterprise_network_row_class": { "$ref": "#/$defs/enterprise_network_row_class" },
        "stabilized_scenario_class": { "$ref": "#/$defs/stabilized_scenario_class" },
        "scenario_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/reviewable_sentence" },
        "fixture_ref": { "$ref": "#/$defs/non_empty_string" },
        "validation_step_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "expected_artifact_kinds": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "recovery_action_class": { "$ref": "#/$defs/non_empty_string" },
        "scorecard_target": { "$ref": "#/$defs/non_empty_string" },
        "coverage_class": { "$ref": "#/$defs/non_empty_string" },
        "expected_state": { "$ref": "#/$defs/non_empty_string" },
        "contributes_to_release_gate": { "type": "boolean" },
        "downgrade_trigger_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/scenario_downgrade_trigger_class" }
        },
        "claim_state_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/scenario_claim_state_class" }
        },
        "doc_ref": { "$ref": "#/$defs/non_empty_string" },
        "schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "crate_consumer_ref": { "$ref": "#/$defs/non_empty_string" },
        "integration_test_ref": { "$ref": "#/$defs/non_empty_string" },
        "metadata_safe_baseline_met": { "type": "boolean" }
      }
    },
    "stabilized_scenario_support_packet_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "captured_at",
        "doc_ref",
        "schema_ref",
        "scenario_id",
        "launch_archetype_class",
        "enterprise_network_row_class",
        "stabilized_scenario_class",
        "doctor_finding_ref",
        "validation_step_classes",
        "expected_artifact_kinds",
        "recovery_action_class",
        "scorecard_target",
        "coverage_class",
        "expected_state",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "destructive_resets_present"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "stabilized_scenario_support_packet_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "doc_ref": { "$ref": "#/$defs/non_empty_string" },
        "schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "scenario_id": { "$ref": "#/$defs/non_empty_string" },
        "launch_archetype_class": { "$ref": "#/$defs/launch_archetype_class" },
        "enterprise_network_row_class": { "$ref": "#/$defs/enterprise_network_row_class" },
        "stabilized_scenario_class": { "$ref": "#/$defs/stabilized_scenario_class" },
        "doctor_finding_ref": { "type": "string", "pattern": "^doctor\\.finding\\." },
        "validation_step_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "expected_artifact_kinds": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "recovery_action_class": { "$ref": "#/$defs/non_empty_string" },
        "scorecard_target": { "$ref": "#/$defs/non_empty_string" },
        "coverage_class": { "$ref": "#/$defs/non_empty_string" },
        "expected_state": { "$ref": "#/$defs/non_empty_string" },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "ambient_authority_excluded": { "type": "boolean", "const": true },
        "destructive_resets_present": { "type": "boolean", "const": false }
      }
    }
  }
}
