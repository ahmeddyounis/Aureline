{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/m5-fault-crash-governance.schema.json",
  "title": "Aureline M5 fault/crash governance packet",
  "description": "Boundary schema for the m5_fault_crash_governance_packet emitted by aureline-support's m5_fault_crash_governance module. The packet freezes the canonical M5 fault-domain classes, restart classes, checkpoint sources, crash-artifact vocabulary, diagnostics-schema governance rows, and downgrade rules that notebook, data/API, preview, provider, profiler/replay, pipeline, docs/browser, and infrastructure helper hosts reuse. The packet is metadata-safe and never embeds raw dumps, raw logs, raw source bodies, or live authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "doc_ref",
    "schema_ref",
    "source_spec_refs",
    "supporting_contract_refs",
    "normative_rules",
    "fault_domains",
    "restart_classes",
    "crash_artifacts",
    "diagnostic_schemas",
    "host_families",
    "downgrade_rules",
    "export_safe_summary"
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "fault_domain_class": {
      "type": "string",
      "enum": [
        "shell_interaction_core",
        "workspace_knowledge_group",
        "session_execution_host",
        "extension_or_external_tool_host",
        "ai_tool_broker",
        "remote_connector",
        "policy_verifier_helper"
      ]
    },
    "restart_class": {
      "type": "string",
      "enum": [
        "stateless_helper",
        "workspace_knowledge",
        "session_scoped",
        "privileged_externally_mutating",
        "authority_verifier"
      ]
    },
    "checkpoint_source_class": {
      "type": "string",
      "enum": [
        "session_restore_checkpoint",
        "vfs_truth_and_disposable_caches",
        "explicit_rerun_or_metadata_restore",
        "manifest_restart_clean_state",
        "provider_registry_and_allowed_local_cache",
        "reconnect_token_and_target_metadata",
        "signed_bundle_cache_snapshot"
      ]
    },
    "crash_artifact_class": {
      "type": "string",
      "enum": [
        "crash_envelope",
        "minidump_or_core_artifact",
        "symbol_or_source_map_manifest",
        "local_symbolication_report",
        "mirrored_symbol_service"
      ]
    },
    "diagnostic_signal_class": {
      "type": "string",
      "enum": [
        "crash",
        "performance",
        "usage",
        "support"
      ]
    },
    "diagnostic_data_class": {
      "type": "string",
      "enum": [
        "metadata_only",
        "environment_adjacent",
        "code_adjacent",
        "high_risk"
      ]
    },
    "diagnostic_opt_in_scope": {
      "type": "string",
      "enum": [
        "explicit_submission_or_policy",
        "opt_in_only",
        "user_initiated_export_only",
        "admin_policy_gated"
      ]
    },
    "retention_class": {
      "type": "string",
      "enum": [
        "local_user_owned_until_delete_or_attach",
        "local_sampling_window",
        "managed_contract_window",
        "local_manifest_until_sent"
      ]
    },
    "redaction_profile_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "environment_summary_only",
        "operator_only_restricted",
        "local_only_review_required"
      ]
    },
    "claim_state_class": {
      "type": "string",
      "enum": [
        "qualified",
        "narrowed_preview",
        "narrowed_local_only",
        "blocked_unverified"
      ]
    },
    "downgrade_trigger_class": {
      "type": "string",
      "enum": [
        "restart_evidence_stale",
        "quarantine_proof_missing",
        "crash_artifact_proof_stale",
        "symbolication_not_exact_build",
        "diagnostic_schema_stale",
        "consent_or_redaction_review_stale"
      ]
    },
    "fault_domain_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fault_domain_class",
        "isolation_unit",
        "restart_class",
        "checkpoint_source",
        "quarantine_or_hard_stop_triggers",
        "minimum_diagnostic_exports",
        "supporting_contract_refs"
      ],
      "properties": {
        "fault_domain_class": {
          "$ref": "#/$defs/fault_domain_class"
        },
        "isolation_unit": {
          "$ref": "#/$defs/non_empty_string"
        },
        "restart_class": {
          "$ref": "#/$defs/restart_class"
        },
        "checkpoint_source": {
          "$ref": "#/$defs/checkpoint_source_class"
        },
        "quarantine_or_hard_stop_triggers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "minItems": 1
        },
        "minimum_diagnostic_exports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "minItems": 1
        },
        "supporting_contract_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "minItems": 1
        }
      }
    },
    "restart_class_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "restart_class",
        "typical_fault_domains",
        "default_strike_window_minutes",
        "default_automatic_restarts",
        "escalation_posture",
        "hidden_authority_widening_forbidden"
      ],
      "properties": {
        "restart_class": {
          "$ref": "#/$defs/restart_class"
        },
        "typical_fault_domains": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fault_domain_class"
          },
          "minItems": 1
        },
        "default_strike_window_minutes": {
          "type": "integer",
          "minimum": 0
        },
        "default_automatic_restarts": {
          "type": "integer",
          "minimum": 0
        },
        "escalation_posture": {
          "$ref": "#/$defs/non_empty_string"
        },
        "hidden_authority_widening_forbidden": {
          "type": "boolean"
        }
      }
    },
    "crash_artifact_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_class",
        "default_location",
        "high_risk_content_class",
        "required_companion_metadata",
        "local_first_by_default",
        "exact_build_only",
        "auto_upload_forbidden",
        "mirrorable_when_claimed",
        "supporting_contract_refs"
      ],
      "properties": {
        "artifact_class": {
          "$ref": "#/$defs/crash_artifact_class"
        },
        "default_location": {
          "$ref": "#/$defs/non_empty_string"
        },
        "high_risk_content_class": {
          "$ref": "#/$defs/diagnostic_data_class"
        },
        "required_companion_metadata": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "minItems": 1
        },
        "local_first_by_default": {
          "type": "boolean"
        },
        "exact_build_only": {
          "type": "boolean"
        },
        "auto_upload_forbidden": {
          "type": "boolean"
        },
        "mirrorable_when_claimed": {
          "type": "boolean"
        },
        "supporting_contract_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "minItems": 1
        }
      }
    },
    "diagnostic_schema_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_class",
        "schema_id",
        "schema_ref",
        "purpose",
        "data_class",
        "opt_in_scope",
        "prohibited_content_classes",
        "retention_class",
        "redaction_profile",
        "evidence_source_refs"
      ],
      "properties": {
        "signal_class": {
          "$ref": "#/$defs/diagnostic_signal_class"
        },
        "schema_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "schema_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "purpose": {
          "$ref": "#/$defs/non_empty_string"
        },
        "data_class": {
          "$ref": "#/$defs/diagnostic_data_class"
        },
        "opt_in_scope": {
          "$ref": "#/$defs/diagnostic_opt_in_scope"
        },
        "prohibited_content_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "minItems": 1
        },
        "retention_class": {
          "$ref": "#/$defs/retention_class"
        },
        "redaction_profile": {
          "$ref": "#/$defs/redaction_profile_class"
        },
        "evidence_source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "minItems": 1
        }
      }
    },
    "host_family_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "host_family_id",
        "host_family_label",
        "fault_domain_class",
        "restart_class",
        "default_strike_window_minutes",
        "default_automatic_restarts",
        "checkpoint_source",
        "quarantine_trigger_classes",
        "minimum_diagnostic_exports",
        "required_crash_artifacts",
        "required_diagnostic_signal_classes",
        "canonical_support_packet_refs",
        "claim_state",
        "stale_proof_tokens",
        "downgrade_rule_ids"
      ],
      "properties": {
        "host_family_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "host_family_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "fault_domain_class": {
          "$ref": "#/$defs/fault_domain_class"
        },
        "restart_class": {
          "$ref": "#/$defs/restart_class"
        },
        "default_strike_window_minutes": {
          "type": "integer",
          "minimum": 0
        },
        "default_automatic_restarts": {
          "type": "integer",
          "minimum": 0
        },
        "checkpoint_source": {
          "$ref": "#/$defs/checkpoint_source_class"
        },
        "quarantine_trigger_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "minItems": 1
        },
        "minimum_diagnostic_exports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "minItems": 1
        },
        "required_crash_artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/crash_artifact_class"
          },
          "minItems": 1
        },
        "required_diagnostic_signal_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/diagnostic_signal_class"
          },
          "minItems": 1
        },
        "canonical_support_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "minItems": 1
        },
        "claim_state": {
          "$ref": "#/$defs/claim_state_class"
        },
        "stale_proof_tokens": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "downgrade_rule_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "downgrade_rule_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "applies_to",
        "trigger_class",
        "source_claim_state",
        "downgraded_claim_state",
        "required_effect",
        "rationale",
        "evidence_refs"
      ],
      "properties": {
        "rule_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "applies_to": {
          "$ref": "#/$defs/non_empty_string"
        },
        "trigger_class": {
          "$ref": "#/$defs/downgrade_trigger_class"
        },
        "source_claim_state": {
          "$ref": "#/$defs/claim_state_class"
        },
        "downgraded_claim_state": {
          "$ref": "#/$defs/claim_state_class"
        },
        "required_effect": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "minItems": 1
        }
      }
    }
  },
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "m5_fault_crash_governance_packet"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "generated_at": {
      "$ref": "#/$defs/timestamp"
    },
    "doc_ref": {
      "type": "string",
      "const": "docs/help/support/m5-fault-crash-governance.md"
    },
    "schema_ref": {
      "type": "string",
      "const": "schemas/support/m5-fault-crash-governance.schema.json"
    },
    "source_spec_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "minItems": 1
    },
    "supporting_contract_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "minItems": 1
    },
    "normative_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "minItems": 1
    },
    "fault_domains": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fault_domain_row"
      },
      "minItems": 7
    },
    "restart_classes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/restart_class_row"
      },
      "minItems": 5
    },
    "crash_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/crash_artifact_row"
      },
      "minItems": 5
    },
    "diagnostic_schemas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic_schema_row"
      },
      "minItems": 4
    },
    "host_families": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/host_family_row"
      },
      "minItems": 6
    },
    "downgrade_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/downgrade_rule_row"
      },
      "minItems": 4
    },
    "export_safe_summary": {
      "$ref": "#/$defs/non_empty_string"
    }
  }
}
