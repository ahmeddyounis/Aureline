{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/finalize_typed_repair_transaction_preview_checkpoint_rollback_and.schema.json",
  "title": "Aureline finalized typed repair-transaction preview, checkpoint, rollback, and compensation flow contract",
  "description": "Boundary schema for the finalized_repair_transaction_preview_checkpoint_rollback_and_flow_record and finalized_repair_transaction_preview_checkpoint_rollback_and_support_packet_record. Promotes the alpha repair-transaction compiler, beta preview-skeleton evaluator, and recovery-ladder alpha decision path into a single stable M4 contract. Guarantees typed, truthful, narrow, versioned, and export-safe blocked-user recovery.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/finalized_repair_transaction_flow_record"
    },
    {
      "$ref": "#/$defs/finalized_repair_flow_support_packet_record"
    }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Frozen schema version for finalized repair-flow records."
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Short human-readable sentence intended for support previews, Doctor surfaces, or reviewer tables."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "doctor_finding_ref": {
      "type": "string",
      "pattern": "^doctor\\.finding\\."
    },
    "finalized_checkpoint_class": {
      "type": "string",
      "enum": [
        "durable_pre_apply",
        "ephemeral_pre_apply",
        "no_checkpoint_needed",
        "checkpoint_refused",
        "no_checkpoint_escalation_only"
      ],
      "description": "Closed finalized checkpoint class. durable_pre_apply and ephemeral_pre_apply require a non-null checkpoint_ref. checkpoint_refused and no_checkpoint_escalation_only block apply."
    },
    "finalized_rollback_class": {
      "type": "string",
      "enum": [
        "exact_restore_from_checkpoint",
        "compensating_restore",
        "regenerate_from_authoritative_source",
        "manual_recovery_path",
        "no_rollback_not_applicable",
        "rollback_failed_export_only"
      ],
      "description": "Closed finalized rollback class. exact_restore_from_checkpoint requires a checkpoint ref. no_rollback_not_applicable is used for audit-only or refused flows. rollback_failed_export_only means apply failed and evidence was exported instead of restoring."
    },
    "finalized_compensation_class": {
      "type": "string",
      "enum": [
        "no_compensation_needed",
        "regenerate_from_authoritative_source",
        "semantic_inverse_compensation",
        "manual_followup_required",
        "audit_only_no_state_change",
        "compensation_failed_escalation"
      ],
      "description": "Closed finalized compensation class. semantic_inverse_compensation and manual_followup_required require strong acknowledgement."
    },
    "finalized_preview_disposition_class": {
      "type": "string",
      "enum": [
        "pending_review",
        "compared_with_baseline",
        "authorized_for_apply",
        "cancelled_before_apply",
        "blocked_pending_evidence",
        "refused_escalation_only"
      ],
      "description": "Closed finalized preview disposition. authorized_for_apply is the only class that authorizes downstream apply. cancelled_before_apply and refused_escalation_only forbid apply."
    },
    "finalized_repair_flow_class": {
      "type": "string",
      "enum": [
        "preview_checkpoint_apply_with_rollback",
        "preview_checkpoint_apply_with_compensation",
        "preview_observe_only_audit",
        "preview_refused_escalation",
        "comparison_then_authorize"
      ],
      "description": "Closed finalized repair-flow class. Each variant implies default checkpoint and rollback classes."
    },
    "blast_radius_class": {
      "type": "string",
      "enum": [
        "single_object_class",
        "multi_object_class_same_family",
        "multi_object_class_cross_family",
        "no_local_blast_escalation_only"
      ],
      "description": "Re-exported from schemas/support/repair_transaction_preview_skeleton.schema.json."
    },
    "confirmation_class": {
      "type": "string",
      "enum": [
        "standard_review",
        "strong_confirmation_required",
        "no_apply_escalation_only"
      ],
      "description": "Re-exported from schemas/support/repair_preview.schema.json."
    },
    "impacted_state_class": {
      "type": "string",
      "enum": [
        "disposable_derived_cache",
        "watcher_backlog_state",
        "docs_pack_mirror_snapshot",
        "execution_context_handle",
        "language_server_session_handle",
        "extension_quarantine_state",
        "extension_install_set",
        "remote_helper_session_handle",
        "remote_agent_runtime_handle",
        "policy_entitlement_handle",
        "trust_approval_ticket",
        "support_export_store_export",
        "doctor_audit_log_entry"
      ],
      "description": "Re-exported from schemas/support/repair_transaction.schema.json."
    },
    "preserved_state_class": {
      "type": "string",
      "enum": [
        "user_authored_files",
        "open_buffer_selection",
        "durable_workspace_indexes",
        "workspace_trust_store",
        "credential_store",
        "remote_helper_authorization",
        "managed_policy_overrides",
        "session_restore_store",
        "support_export_store",
        "docs_pack_authoring",
        "installed_extension_marketplace_state",
        "managed_workspace_control_plane"
      ],
      "description": "Re-exported from schemas/support/repair_transaction.schema.json."
    },
    "recovery_rung_class": {
      "type": "string",
      "enum": [
        "safe_mode",
        "runtime_extension_quarantine",
        "open_without_restore",
        "cache_index_repair"
      ],
      "description": "Re-exported from schemas/support/recovery_ladder_packet.schema.json."
    },
    "seeded_scenario_class": {
      "type": "string",
      "enum": [
        "cache_index_repair",
        "extension_quarantine_bisect",
        "toolchain_reresolve",
        "remote_agent_rollback",
        "policy_entitlement_refresh",
        "trust_reacquire",
        "watcher_restart_reseed",
        "docs_mirror_refresh",
        "escalation_only_no_local_repair",
        "observe_only_no_repair"
      ],
      "description": "Closed seeded-scenario vocabulary. Every finalized flow must cover all ten scenarios."
    },
    "finalized_repair_preview_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "preview_id",
        "repair_transaction_ref",
        "preview_disposition_class",
        "blast_radius_class",
        "confirmation_class",
        "strong_confirmation_required",
        "doctor_finding_ref",
        "impacted_state_classes",
        "preserved_state_classes",
        "preview_summary",
        "captured_at"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "record_kind": {
          "type": "string",
          "const": "finalized_repair_preview_record"
        },
        "preview_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "repair_transaction_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preview_disposition_class": {
          "$ref": "#/$defs/finalized_preview_disposition_class"
        },
        "blast_radius_class": {
          "$ref": "#/$defs/blast_radius_class"
        },
        "confirmation_class": {
          "$ref": "#/$defs/confirmation_class"
        },
        "strong_confirmation_required": {
          "type": "boolean"
        },
        "doctor_finding_ref": {
          "$ref": "#/$defs/doctor_finding_ref"
        },
        "impacted_state_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/impacted_state_class"
          }
        },
        "preserved_state_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/preserved_state_class"
          }
        },
        "preview_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "captured_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        }
      }
    },
    "finalized_repair_checkpoint_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "checkpoint_id",
        "repair_transaction_ref",
        "checkpoint_class",
        "scoped_state_classes",
        "capture_summary",
        "export_safe",
        "captured_at"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "record_kind": {
          "type": "string",
          "const": "finalized_repair_checkpoint_record"
        },
        "checkpoint_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "repair_transaction_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "checkpoint_class": {
          "$ref": "#/$defs/finalized_checkpoint_class"
        },
        "checkpoint_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/non_empty_string"
            }
          ]
        },
        "scoped_state_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/impacted_state_class"
          }
        },
        "capture_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "export_safe": {
          "type": "boolean"
        },
        "captured_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        }
      }
    },
    "finalized_repair_rollback_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "rollback_id",
        "repair_transaction_ref",
        "rollback_class",
        "rollback_succeeded",
        "rollback_summary",
        "captured_at"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "record_kind": {
          "type": "string",
          "const": "finalized_repair_rollback_record"
        },
        "rollback_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "repair_transaction_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rollback_class": {
          "$ref": "#/$defs/finalized_rollback_class"
        },
        "checkpoint_ref_consumed": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/non_empty_string"
            }
          ]
        },
        "rollback_succeeded": {
          "type": "boolean"
        },
        "rollback_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "captured_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        }
      }
    },
    "finalized_repair_compensation_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "compensation_id",
        "repair_transaction_ref",
        "compensation_class",
        "strong_acknowledgement_required",
        "compensation_summary",
        "follow_up_action_summary",
        "captured_at"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "record_kind": {
          "type": "string",
          "const": "finalized_repair_compensation_record"
        },
        "compensation_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "repair_transaction_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "compensation_class": {
          "$ref": "#/$defs/finalized_compensation_class"
        },
        "strong_acknowledgement_required": {
          "type": "boolean"
        },
        "compensation_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "follow_up_action_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "captured_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        }
      }
    },
    "recovery_ladder_proof_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rung_class",
        "decision_id",
        "ladder_approved",
        "ladder_summary"
      ],
      "properties": {
        "rung_class": {
          "$ref": "#/$defs/recovery_rung_class"
        },
        "decision_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "ladder_approved": {
          "type": "boolean"
        },
        "ladder_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "seeded_support_scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_class",
        "covered",
        "coverage_note"
      ],
      "properties": {
        "scenario_class": {
          "$ref": "#/$defs/seeded_scenario_class"
        },
        "covered": {
          "type": "boolean"
        },
        "coverage_note": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "finalized_repair_transaction_flow_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "flow_id",
        "repair_transaction_ref",
        "flow_class",
        "preview",
        "checkpoint",
        "rollback",
        "compensation",
        "ladder_bindings",
        "seeded_scenarios",
        "destructive_reset_present",
        "exact_build_identity_ref",
        "captured_at"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "record_kind": {
          "type": "string",
          "const": "finalized_repair_transaction_preview_checkpoint_rollback_and_flow_record"
        },
        "flow_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "repair_transaction_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "flow_class": {
          "$ref": "#/$defs/finalized_repair_flow_class"
        },
        "preview": {
          "$ref": "#/$defs/finalized_repair_preview_record"
        },
        "checkpoint": {
          "$ref": "#/$defs/finalized_repair_checkpoint_record"
        },
        "rollback": {
          "$ref": "#/$defs/finalized_repair_rollback_record"
        },
        "compensation": {
          "$ref": "#/$defs/finalized_repair_compensation_record"
        },
        "ladder_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/recovery_ladder_proof_binding"
          }
        },
        "seeded_scenarios": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/seeded_support_scenario"
          }
        },
        "destructive_reset_present": {
          "type": "boolean"
        },
        "exact_build_identity_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "captured_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        }
      }
    },
    "finalized_repair_flow_support_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "flow_id",
        "repair_transaction_ref",
        "flow_class",
        "preview_disposition_class",
        "checkpoint_class",
        "rollback_class",
        "compensation_class",
        "doctor_finding_ref",
        "blast_radius_class",
        "strong_confirmation_required",
        "ladder_rung_refs",
        "seeded_scenarios_covered",
        "destructive_reset_present"
      ],
      "properties": {
        "flow_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "repair_transaction_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "flow_class": {
          "$ref": "#/$defs/finalized_repair_flow_class"
        },
        "preview_disposition_class": {
          "$ref": "#/$defs/finalized_preview_disposition_class"
        },
        "checkpoint_class": {
          "$ref": "#/$defs/finalized_checkpoint_class"
        },
        "rollback_class": {
          "$ref": "#/$defs/finalized_rollback_class"
        },
        "compensation_class": {
          "$ref": "#/$defs/finalized_compensation_class"
        },
        "doctor_finding_ref": {
          "$ref": "#/$defs/doctor_finding_ref"
        },
        "blast_radius_class": {
          "$ref": "#/$defs/blast_radius_class"
        },
        "strong_confirmation_required": {
          "type": "boolean"
        },
        "ladder_rung_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "seeded_scenarios_covered": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "destructive_reset_present": {
          "type": "boolean"
        }
      }
    },
    "finalized_repair_flow_support_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "captured_at",
        "doc_ref",
        "schema_ref",
        "rows",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "all_rows_export_safe"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "finalized_repair_transaction_preview_checkpoint_rollback_and_support_packet_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "packet_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "captured_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        },
        "doc_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "schema_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finalized_repair_flow_support_row"
          }
        },
        "raw_private_material_excluded": {
          "type": "boolean"
        },
        "ambient_authority_excluded": {
          "type": "boolean"
        },
        "all_rows_export_safe": {
          "type": "boolean"
        }
      }
    }
  }
}
