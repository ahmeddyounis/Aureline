{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/storage_cleanup_receipt.schema.json",
  "title": "Aureline storage cleanup receipt",
  "description": "Boundary schema for the typed receipt minted after any class-selective cleanup runs. Pairs with a confirmed clear_data_review_record and records actor, timestamp, classes affected, bytes reclaimed, blocked pins, skipped protected classes, resulting stale/rebuild state, and reopen-inspector routing. The receipt is metadata-only so support exports can quote it verbatim without leaking raw payloads, raw paths, or raw credential bodies.",
  "$ref": "#/$defs/storage_cleanup_receipt_record",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "storage_cleanup_receipt_record"
    },
    "stable_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "storage_class_id": {
      "type": "string",
      "enum": [
        "interactive_hot_cache",
        "knowledge_cache",
        "artifact_cache",
        "prebuild_environment_cache",
        "evidence_support_cache",
        "user_owned_recovery_state"
      ]
    },
    "actor_lineage_class": {
      "type": "string",
      "enum": [
        "user_invoked_in_shell",
        "admin_invoked_in_console",
        "automation_invoked",
        "low_disk_eviction_prompt"
      ]
    },
    "trigger_class": {
      "type": "string",
      "enum": [
        "user_requested_cleanup",
        "low_disk_pressure",
        "quota_pressure",
        "corruption_repair_request"
      ]
    },
    "result_class": {
      "type": "string",
      "enum": [
        "completed",
        "partial",
        "blocked_by_pin",
        "blocked_by_protected_class",
        "cancelled",
        "no_op_nothing_to_reclaim"
      ]
    },
    "rebuild_state_class": {
      "type": "string",
      "enum": [
        "fresh_no_rebuild_needed",
        "rebuild_on_demand_cheaply",
        "rebuild_on_demand_expensive",
        "rebuild_requires_network",
        "stale_until_rebuilt",
        "irrecoverable_without_external_source"
      ]
    },
    "low_disk_state_class": {
      "type": "string",
      "enum": [
        "not_triggered",
        "warning",
        "critical",
        "quota_pressure"
      ]
    },
    "pin_source_class": {
      "type": "string",
      "enum": [
        "user_pin",
        "workspace_pin",
        "policy_pin",
        "evidence_hold",
        "rollback_checkpoint_pin",
        "last_known_good_policy_pin",
        "offline_entitlement_pin"
      ]
    },
    "protected_reason_class": {
      "type": "string",
      "enum": [
        "user_owned_recovery_state",
        "evidence_class",
        "policy_pin",
        "active_hold",
        "rollback_checkpoint",
        "dirty_buffer_journal",
        "offline_entitlement_bundle",
        "last_known_good_policy_bundle"
      ]
    },
    "class_outcome_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class_id",
        "bytes_reclaimed",
        "rebuild_state_class",
        "rebuild_summary"
      ],
      "properties": {
        "class_id": { "$ref": "#/$defs/storage_class_id" },
        "bytes_reclaimed": { "type": "integer", "minimum": 0 },
        "rebuild_state_class": { "$ref": "#/$defs/rebuild_state_class" },
        "rebuild_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "blocked_pin_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pin_ref",
        "class_id",
        "pin_source_class",
        "pin_summary"
      ],
      "properties": {
        "pin_ref": { "$ref": "#/$defs/stable_ref" },
        "class_id": { "$ref": "#/$defs/storage_class_id" },
        "pin_source_class": { "$ref": "#/$defs/pin_source_class" },
        "pin_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "skipped_protected_class_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class_id",
        "protected_reason_class",
        "reason_summary"
      ],
      "properties": {
        "class_id": { "$ref": "#/$defs/storage_class_id" },
        "protected_reason_class": { "$ref": "#/$defs/protected_reason_class" },
        "reason_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "low_disk_eviction_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "order",
        "class_id",
        "bytes_evicted",
        "summary"
      ],
      "properties": {
        "order": { "type": "integer", "minimum": 1 },
        "class_id": { "$ref": "#/$defs/storage_class_id" },
        "bytes_evicted": { "type": "integer", "minimum": 0 },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "paused_work_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["work_ref", "summary"],
      "properties": {
        "work_ref": { "$ref": "#/$defs/stable_ref" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "low_disk_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_class",
        "ordered_eviction_steps",
        "paused_work_rows",
        "reviewer_summary"
      ],
      "properties": {
        "state_class": { "$ref": "#/$defs/low_disk_state_class" },
        "ordered_eviction_steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/low_disk_eviction_step" }
        },
        "paused_work_rows": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/paused_work_row" }
        },
        "reviewer_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "storage_cleanup_receipt_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "receipt_id",
        "review_ref",
        "executed_at",
        "actor_lineage_class",
        "trigger_class",
        "result_class",
        "class_outcomes",
        "blocked_pin_rows",
        "skipped_protected_class_rows",
        "reopen_inspector_action_ref",
        "raw_content_exported",
        "redaction_class",
        "schema_ref",
        "doc_ref",
        "registry_ref",
        "review_schema_ref",
        "reviewer_summary"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "receipt_id": { "$ref": "#/$defs/stable_ref" },
        "review_ref": { "$ref": "#/$defs/stable_ref" },
        "executed_at": {
          "type": "string",
          "format": "date-time"
        },
        "actor_lineage_class": { "$ref": "#/$defs/actor_lineage_class" },
        "trigger_class": { "$ref": "#/$defs/trigger_class" },
        "result_class": { "$ref": "#/$defs/result_class" },
        "class_outcomes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/class_outcome_row" }
        },
        "blocked_pin_rows": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/blocked_pin_row" }
        },
        "skipped_protected_class_rows": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/skipped_protected_class_row" }
        },
        "low_disk_context": { "$ref": "#/$defs/low_disk_context" },
        "reopen_inspector_action_ref": { "$ref": "#/$defs/stable_ref" },
        "raw_content_exported": {
          "type": "boolean",
          "const": false
        },
        "redaction_class": {
          "type": "string",
          "const": "metadata_safe_default"
        },
        "schema_ref": {
          "type": "string",
          "const": "schemas/support/storage_cleanup_receipt.schema.json"
        },
        "doc_ref": {
          "type": "string",
          "const": "docs/support/m3/storage_cleanup_beta.md"
        },
        "registry_ref": {
          "type": "string",
          "const": "schemas/support/storage_class.schema.json"
        },
        "review_schema_ref": {
          "type": "string",
          "const": "schemas/support/clear_data_review.schema.json"
        },
        "reviewer_summary": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "trigger_class": { "const": "low_disk_pressure" }
            },
            "required": ["trigger_class"]
          },
          "then": {
            "required": ["low_disk_context"]
          }
        }
      ]
    }
  }
}
