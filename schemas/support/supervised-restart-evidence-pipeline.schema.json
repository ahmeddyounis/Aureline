{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/supervised-restart-evidence-pipeline.schema.json",
  "title": "Aureline supervised-restart evidence pipeline packet contract",
  "description": "Boundary schema for the supervised_restart_evidence_packet and its constituent rows consumed by aureline-support's supervised_restart_evidence_pipeline module. The packet captures restart lineage, fault-domain identity, host-lane identity, strike budget, quarantine state, and reattach / no-rerun policy across local, remote, extension, debug, and notebook fault domains. All shapes use closed vocabularies so Support Center, Diagnostics Center, shiproom proof, support bundles, and known-limits publication share one truth. The packet is metadata-only and never embeds raw secret-bearing material.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/supervised_restart_evidence_packet"
    },
    {
      "$ref": "#/$defs/restart_lineage_entry_record"
    },
    {
      "$ref": "#/$defs/host_lane_identity_record"
    },
    {
      "$ref": "#/$defs/supervised_restart_review_decision_record"
    },
    {
      "$ref": "#/$defs/no_rerun_policy_record"
    },
    {
      "$ref": "#/$defs/fault_domain_restart_summary_record"
    }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "restart_domain_class": {
      "type": "string",
      "enum": [
        "local",
        "remote",
        "extension",
        "debug",
        "notebook"
      ]
    },
    "restart_trigger_class": {
      "type": "string",
      "enum": [
        "host_crash",
        "user_initiated_restart",
        "supervisor_restart",
        "reattach_attempt",
        "quarantine_entered",
        "policy_disable"
      ]
    },
    "restart_budget_token": {
      "type": "string",
      "enum": [
        "within_budget",
        "budget_warning",
        "budget_exhausted",
        "quarantined",
        "no_automatic_restart",
        "reattach_review_required",
        "disabled"
      ]
    },
    "supervised_restart_decision_class": {
      "type": "string",
      "enum": [
        "current",
        "auto_reattached_stale_refresh",
        "review_required",
        "reapproval_required",
        "rerun_required",
        "blocked_manual_repair"
      ]
    },
    "no_rerun_policy_class": {
      "type": "string",
      "enum": [
        "safe_rehydrate",
        "explicit_rerun_required",
        "reapproval_required",
        "blocked_until_repair"
      ]
    },
    "restart_lineage_entry_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "entry_id",
        "domain",
        "domain_token",
        "host_lane_ref",
        "host_family_label",
        "timestamp",
        "trigger",
        "trigger_token",
        "strike_count",
        "restart_budget_in_window",
        "budget_state",
        "budget_state_token",
        "quarantined",
        "build_id",
        "summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "restart_lineage_entry_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "entry_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "domain": {
          "$ref": "#/$defs/restart_domain_class"
        },
        "domain_token": {
          "$ref": "#/$defs/restart_domain_class"
        },
        "host_lane_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "host_family_label": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "timestamp": {
          "$ref": "#/$defs/monotonic_timestamp"
        },
        "trigger": {
          "$ref": "#/$defs/restart_trigger_class"
        },
        "trigger_token": {
          "$ref": "#/$defs/restart_trigger_class"
        },
        "strike_count": {
          "type": "integer",
          "minimum": 0
        },
        "restart_budget_in_window": {
          "type": "integer",
          "minimum": 0
        },
        "budget_state": {
          "$ref": "#/$defs/restart_budget_token"
        },
        "budget_state_token": {
          "$ref": "#/$defs/restart_budget_token"
        },
        "quarantined": {
          "type": "boolean"
        },
        "quarantine_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "build_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "host_lane_identity_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "host_lane_ref",
        "host_family_label",
        "fault_domain_id",
        "fault_domain_token",
        "boundary_badge_tokens",
        "can_mutate",
        "externally_routed",
        "health_token",
        "restart_budget_ref",
        "affected_capability_tokens",
        "preserved_checkpoint_refs",
        "partial_truth_result_refs"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "host_lane_identity_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "host_lane_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "host_family_label": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "fault_domain_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "fault_domain_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "boundary_badge_tokens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "can_mutate": {
          "type": "boolean"
        },
        "externally_routed": {
          "type": "boolean"
        },
        "health_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "restart_budget_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "affected_capability_tokens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preserved_checkpoint_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "partial_truth_result_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "supervised_restart_review_decision_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "decision_id",
        "host_lane_ref",
        "decision",
        "decision_token",
        "current_lane_accepted",
        "explicit_review_required",
        "preserved_state_refs",
        "lost_state_refs",
        "summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "supervised_restart_review_decision_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "decision_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "host_lane_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "decision": {
          "$ref": "#/$defs/supervised_restart_decision_class"
        },
        "decision_token": {
          "$ref": "#/$defs/supervised_restart_decision_class"
        },
        "current_lane_accepted": {
          "type": "boolean"
        },
        "explicit_review_required": {
          "type": "boolean"
        },
        "preserved_state_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lost_state_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "no_rerun_policy_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "policy_id",
        "host_lane_ref",
        "policy",
        "policy_token",
        "forbids_silent_rerun",
        "reason"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "no_rerun_policy_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "policy_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "host_lane_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "policy": {
          "$ref": "#/$defs/no_rerun_policy_class"
        },
        "policy_token": {
          "$ref": "#/$defs/no_rerun_policy_class"
        },
        "forbids_silent_rerun": {
          "type": "boolean"
        },
        "reason": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "fault_domain_restart_summary_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "summary_id",
        "domain",
        "domain_token",
        "restart_entry_count",
        "lane_count",
        "quarantined_lane_count",
        "review_required_lane_count",
        "mutating_lane_count",
        "externally_routed_lane_count",
        "blocks_healthy_claim"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "fault_domain_restart_summary_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "summary_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "domain": {
          "$ref": "#/$defs/restart_domain_class"
        },
        "domain_token": {
          "$ref": "#/$defs/restart_domain_class"
        },
        "restart_entry_count": {
          "type": "integer",
          "minimum": 0
        },
        "lane_count": {
          "type": "integer",
          "minimum": 0
        },
        "quarantined_lane_count": {
          "type": "integer",
          "minimum": 0
        },
        "review_required_lane_count": {
          "type": "integer",
          "minimum": 0
        },
        "mutating_lane_count": {
          "type": "integer",
          "minimum": 0
        },
        "externally_routed_lane_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocks_healthy_claim": {
          "type": "boolean"
        }
      }
    },
    "supervised_restart_evidence_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "workspace_id",
        "generated_at",
        "build_id",
        "doc_ref",
        "schema_ref",
        "lineage_entries",
        "host_lane_identities",
        "review_decisions",
        "no_rerun_policies",
        "domain_summaries",
        "lineage_entry_count",
        "host_lane_count",
        "review_required_lane_count",
        "mutating_lane_count",
        "externally_routed_lane_count",
        "quarantined_lane_count",
        "export_safe",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "supervised_restart_evidence_packet"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "packet_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "workspace_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "generated_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        },
        "build_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "doc_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "schema_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "lineage_entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/restart_lineage_entry_record"
          }
        },
        "host_lane_identities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/host_lane_identity_record"
          }
        },
        "review_decisions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/supervised_restart_review_decision_record"
          }
        },
        "no_rerun_policies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/no_rerun_policy_record"
          }
        },
        "domain_summaries": {
          "type": "array",
          "minItems": 5,
          "items": {
            "$ref": "#/$defs/fault_domain_restart_summary_record"
          }
        },
        "lineage_entry_count": {
          "type": "integer",
          "minimum": 0
        },
        "host_lane_count": {
          "type": "integer",
          "minimum": 0
        },
        "review_required_lane_count": {
          "type": "integer",
          "minimum": 0
        },
        "mutating_lane_count": {
          "type": "integer",
          "minimum": 0
        },
        "externally_routed_lane_count": {
          "type": "integer",
          "minimum": 0
        },
        "quarantined_lane_count": {
          "type": "integer",
          "minimum": 0
        },
        "export_safe": {
          "type": "boolean",
          "const": true
        },
        "export_safe_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    }
  }
}
