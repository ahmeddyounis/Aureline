{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/topology_inspector.schema.json",
  "title": "Aureline support topology inspector packet",
  "description": "Boundary schema for the metadata-only support/export packet that projects runtime topology inspector results, fault-domain rows, restart-budget cards, reattach reviews, crash-loop banners, and lane-filtered event provenance for M5 runtime-heavy hosts.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "doc_ref",
    "schema_ref",
    "workspace_id",
    "generated_at",
    "topology_inspector_ref",
    "topology_results",
    "rows",
    "restart_cards",
    "reattach_reviews",
    "crash_banners",
    "event_viewer",
    "partial_truth_row_count",
    "blocked_healthy_claim_count",
    "export_safe_summary"
  ],
  "properties": {
    "record_kind": { "const": "fault_domain_view_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "doc_ref": { "const": "docs/support/topology_inspector.md" },
    "schema_ref": { "const": "schemas/support/topology_inspector.schema.json" },
    "workspace_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "topology_inspector_ref": { "type": "string", "minLength": 1 },
    "topology_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_kind",
          "schema_version",
          "result_ref",
          "surface_token",
          "result_summary",
          "visible_truth_label_token",
          "visible_truth_label_label",
          "current_host_confirmed",
          "requires_reattach_review",
          "host_summaries"
        ],
        "properties": {
          "record_kind": { "const": "fault_domain_topology_result_row" },
          "schema_version": { "type": "integer", "const": 1 },
          "result_ref": { "type": "string", "minLength": 1 },
          "surface_token": { "type": "string", "minLength": 1 },
          "result_summary": { "type": "string", "minLength": 1 },
          "visible_truth_label_token": {
            "type": "string",
            "enum": [
              "current",
              "stale",
              "rebuilding",
              "provider_unavailable",
              "reconnecting",
              "local_fallback",
              "captured_snapshot"
            ]
          },
          "visible_truth_label_label": { "type": "string", "minLength": 1 },
          "current_host_confirmed": { "type": "boolean" },
          "requires_reattach_review": { "type": "boolean" },
          "host_summaries": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "host_lane_ref",
                "host_family_label",
                "role_label",
                "locality_label",
                "boundary_badge_labels",
                "health_token",
                "fault_domain_id",
                "detail_action_ref"
              ],
              "properties": {
                "host_lane_ref": { "type": "string", "minLength": 1 },
                "host_family_label": { "type": "string", "minLength": 1 },
                "role_label": { "type": "string", "minLength": 1 },
                "locality_label": { "type": "string", "minLength": 1 },
                "boundary_badge_labels": { "type": "array", "items": { "type": "string" } },
                "health_token": { "type": "string", "minLength": 1 },
                "fault_domain_id": { "type": "string", "minLength": 1 },
                "detail_action_ref": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_kind",
          "schema_version",
          "row_id",
          "host_lane_ref",
          "host_family_label",
          "role_label",
          "host_label",
          "locality_label",
          "boundary_badge_labels",
          "health_token",
          "health_label",
          "fault_domain_id",
          "fault_domain_token",
          "restart_budget_ref",
          "restart_budget_state_token",
          "restart_budget_state_label",
          "restart_strike_count",
          "restart_budget_in_window",
          "restart_window_minutes",
          "restart_window_label",
          "quarantine_trigger_summary",
          "partial_truth_result_refs",
          "partial_truth_results",
          "surface_tokens",
          "lane_event_ids",
          "export_safe"
        ],
        "properties": {
          "record_kind": { "const": "fault_domain_view_row" },
          "schema_version": { "type": "integer", "const": 1 },
          "row_id": { "type": "string", "minLength": 1 },
          "host_lane_ref": { "type": "string", "minLength": 1 },
          "host_family_label": { "type": "string", "minLength": 1 },
          "role_label": { "type": "string", "minLength": 1 },
          "host_label": { "type": "string", "minLength": 1 },
          "locality_label": { "type": "string", "minLength": 1 },
          "boundary_badge_labels": { "type": "array", "items": { "type": "string" } },
          "health_token": { "type": "string", "minLength": 1 },
          "health_label": { "type": "string", "minLength": 1 },
          "fault_domain_id": { "type": "string", "minLength": 1 },
          "fault_domain_token": { "type": "string", "minLength": 1 },
          "restart_budget_ref": { "type": "string", "minLength": 1 },
          "restart_budget_state_token": { "type": "string", "minLength": 1 },
          "restart_budget_state_label": { "type": "string", "minLength": 1 },
          "restart_strike_count": { "type": "integer", "minimum": 0 },
          "restart_budget_in_window": { "type": "integer", "minimum": 0 },
          "restart_window_minutes": { "type": "integer", "minimum": 0 },
          "restart_window_label": { "type": "string", "minLength": 1 },
          "affected_capability_tokens": { "type": "array", "items": { "type": "string" } },
          "preserved_checkpoint_refs": { "type": "array", "items": { "type": "string" } },
          "quarantine_trigger_summary": { "type": "string", "minLength": 1 },
          "partial_truth_result_refs": { "type": "array", "items": { "type": "string" } },
          "partial_truth_results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "result_ref",
                "surface_token",
                "result_summary",
                "visible_truth_label_token",
                "visible_truth_label_label"
              ],
              "properties": {
                "result_ref": { "type": "string", "minLength": 1 },
                "surface_token": { "type": "string", "minLength": 1 },
                "result_summary": { "type": "string", "minLength": 1 },
                "visible_truth_label_token": { "type": "string", "minLength": 1 },
                "visible_truth_label_label": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "surface_tokens": { "type": "array", "items": { "type": "string" } },
          "lane_event_ids": { "type": "array", "items": { "type": "string" } },
          "reattach_decision_token": { "type": "string" },
          "crash_banner_ref": { "type": "string" },
          "export_safe": { "type": "boolean", "const": true }
        },
        "additionalProperties": false
      }
    },
    "restart_cards": { "type": "array" },
    "reattach_reviews": { "type": "array" },
    "crash_banners": { "type": "array" },
    "event_viewer": { "type": "object" },
    "partial_truth_row_count": { "type": "integer", "minimum": 0 },
    "blocked_healthy_claim_count": { "type": "integer", "minimum": 0 },
    "export_safe_summary": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
