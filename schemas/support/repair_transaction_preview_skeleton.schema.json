{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/repair_transaction_preview_skeleton.schema.json",
  "title": "Aureline repair-transaction preview-skeleton, comparison, and support-packet contract",
  "description": "Boundary schema for the repair_preview_skeleton_record and repair_preview_comparison_record consumed by aureline-support's repair_transactions module. The skeleton declares blast-radius class, compensation class, affected object classes, checkpoint disposition, and a cancellable preview disposition bound to an existing alpha repair_transaction_record and its transaction_reversal_class. Comparisons let a reviewer compare a candidate skeleton against a prior baseline before any apply path runs. Support packets preserve the same transaction id and reversal class verbatim.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/repair_preview_skeleton_record"
    },
    {
      "$ref": "#/$defs/repair_preview_comparison_record"
    }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "doctor_finding_ref": {
      "type": "string",
      "pattern": "^doctor\\.finding\\."
    },
    "transaction_reversal_class": {
      "type": "string",
      "enum": [
        "exact",
        "compensating",
        "regenerate",
        "manual",
        "audit_only"
      ],
      "description": "Reversal class re-exported verbatim from schemas/support/repair_transaction.schema.json."
    },
    "blast_radius_class": {
      "type": "string",
      "enum": [
        "single_object_class",
        "multi_object_class_same_family",
        "multi_object_class_cross_family",
        "no_local_blast_escalation_only"
      ]
    },
    "compensation_class": {
      "type": "string",
      "enum": [
        "no_compensation_needed",
        "regenerate_from_authoritative_source",
        "semantic_inverse_compensation",
        "manual_followup_required",
        "audit_only_no_state_change"
      ],
      "description": "Compensation class distinct from transaction_reversal_class: states what compensating work reviewers must accept before apply runs at all."
    },
    "affected_object_class": {
      "type": "string",
      "enum": [
        "derived_cache_object",
        "watcher_backlog_object",
        "docs_pack_mirror_object",
        "execution_context_object",
        "language_server_session_object",
        "extension_quarantine_object",
        "extension_install_set_object",
        "remote_helper_session_object",
        "remote_agent_runtime_object",
        "policy_entitlement_object",
        "trust_approval_object",
        "support_export_object",
        "doctor_audit_log_object"
      ]
    },
    "checkpoint_disposition_class": {
      "type": "string",
      "enum": [
        "durable_pre_apply_checkpoint",
        "ephemeral_pre_apply_checkpoint",
        "no_checkpoint_observe_only",
        "no_checkpoint_escalation_only"
      ]
    },
    "preview_disposition_class": {
      "type": "string",
      "enum": [
        "cancellable_pending_review",
        "comparison_with_prior_baseline",
        "authorized_for_apply",
        "cancelled_before_apply",
        "blocked_pending_evidence",
        "refused_no_local_repair"
      ]
    },
    "comparison_axis_class": {
      "type": "string",
      "enum": [
        "blast_radius_diff",
        "compensation_diff",
        "affected_object_diff",
        "preserved_state_diff",
        "checkpoint_diff",
        "reversal_class_diff"
      ]
    },
    "cancellation_class": {
      "type": "string",
      "enum": [
        "continue_comparison",
        "cancel_before_apply",
        "ready_for_apply_review"
      ]
    },
    "preserved_state_class": {
      "type": "string",
      "enum": [
        "user_authored_files",
        "open_buffer_selection",
        "durable_workspace_indexes",
        "workspace_trust_store",
        "credential_store",
        "remote_helper_authorization",
        "managed_policy_overrides",
        "session_restore_store",
        "support_export_store",
        "docs_pack_authoring",
        "installed_extension_marketplace_state",
        "managed_workspace_control_plane"
      ],
      "description": "Re-exported verbatim from schemas/support/repair_transaction.schema.json$.defs.preserved_state_class."
    },
    "affected_object_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "affected_object_class",
        "change_summary"
      ],
      "properties": {
        "affected_object_class": {
          "$ref": "#/$defs/affected_object_class"
        },
        "change_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "explanation_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "change_summary",
        "preserved_summary",
        "compensation_summary",
        "checkpoint_summary",
        "user_facing_next_step"
      ],
      "properties": {
        "change_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "preserved_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "compensation_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "checkpoint_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "user_facing_next_step": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "repair_preview_skeleton_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "skeleton_id",
        "repair_transaction_ref",
        "reversal_class",
        "blast_radius_class",
        "compensation_class",
        "checkpoint_disposition_class",
        "preview_disposition_class",
        "affected_object_rows",
        "preserved_state_classes",
        "doctor_finding_ref",
        "support_packet_ref",
        "destructive_resets_present",
        "explanation",
        "captured_at"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "record_kind": {
          "type": "string",
          "const": "repair_preview_skeleton_record"
        },
        "skeleton_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "repair_transaction_ref": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Stable id of the alpha repair_transaction_record this skeleton previews. Preserved verbatim across support and audit packets."
        },
        "reversal_class": {
          "$ref": "#/$defs/transaction_reversal_class"
        },
        "blast_radius_class": {
          "$ref": "#/$defs/blast_radius_class"
        },
        "compensation_class": {
          "$ref": "#/$defs/compensation_class"
        },
        "checkpoint_disposition_class": {
          "$ref": "#/$defs/checkpoint_disposition_class"
        },
        "preview_disposition_class": {
          "$ref": "#/$defs/preview_disposition_class"
        },
        "affected_object_rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/affected_object_row"
          }
        },
        "preserved_state_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/preserved_state_class"
          },
          "contains": {
            "const": "user_authored_files"
          }
        },
        "doctor_finding_ref": {
          "$ref": "#/$defs/doctor_finding_ref"
        },
        "checkpoint_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/non_empty_string"
            }
          ]
        },
        "support_packet_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "destructive_resets_present": {
          "type": "boolean",
          "const": false
        },
        "explanation": {
          "$ref": "#/$defs/explanation_block"
        },
        "captured_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "checkpoint_disposition_class": {
                "enum": [
                  "durable_pre_apply_checkpoint",
                  "ephemeral_pre_apply_checkpoint"
                ]
              }
            },
            "required": [
              "checkpoint_disposition_class"
            ]
          },
          "then": {
            "required": [
              "checkpoint_ref"
            ],
            "properties": {
              "checkpoint_ref": {
                "$ref": "#/$defs/non_empty_string"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "checkpoint_disposition_class": {
                "enum": [
                  "no_checkpoint_observe_only",
                  "no_checkpoint_escalation_only"
                ]
              }
            },
            "required": [
              "checkpoint_disposition_class"
            ]
          },
          "then": {
            "properties": {
              "checkpoint_ref": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "blast_radius_class": {
                "const": "no_local_blast_escalation_only"
              }
            },
            "required": [
              "blast_radius_class"
            ]
          },
          "then": {
            "properties": {
              "affected_object_rows": {
                "type": "array",
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "blast_radius_class": {
                "const": "single_object_class"
              }
            },
            "required": [
              "blast_radius_class"
            ]
          },
          "then": {
            "properties": {
              "affected_object_rows": {
                "type": "array",
                "minItems": 1,
                "maxItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "compensation_class": {
                "const": "audit_only_no_state_change"
              }
            },
            "required": [
              "compensation_class"
            ]
          },
          "then": {
            "properties": {
              "affected_object_rows": {
                "type": "array",
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "preview_disposition_class": {
                "const": "refused_no_local_repair"
              }
            },
            "required": [
              "preview_disposition_class"
            ]
          },
          "then": {
            "properties": {
              "checkpoint_disposition_class": {
                "const": "no_checkpoint_escalation_only"
              }
            }
          }
        }
      ]
    },
    "repair_preview_comparison_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "comparison_id",
        "bound_skeleton_ref",
        "baseline_skeleton_ref",
        "candidate_skeleton_ref",
        "differing_axes",
        "cancellation_class",
        "reviewer_summary",
        "captured_at"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "record_kind": {
          "type": "string",
          "const": "repair_preview_comparison_record"
        },
        "comparison_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "bound_skeleton_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "baseline_skeleton_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "candidate_skeleton_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "differing_axes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/comparison_axis_class"
          }
        },
        "cancellation_class": {
          "$ref": "#/$defs/cancellation_class"
        },
        "reviewer_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "captured_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        }
      }
    }
  }
}
