{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/publish_supportability_runbooks_field_playbooks_and_incident_advisory.schema.json",
  "title": "Aureline published supportability runbooks, field playbooks, and incident/advisory packet integration for the stable line",
  "description": "Boundary schema for the M4 stable-line supportability runbook catalog. The schema covers runbook source classes with explicit authoritative posture, executable step envelopes with stable IDs and handoff metadata, durable deviation notes, field-playbook packets, and incident/advisory integration packets. Raw command lines, raw provider URLs, raw console sessions, raw approval bodies, raw private content, and secrets never cross this boundary.",
  "type": "object",
  "$ref": "#/$defs/supportability_runbook_catalog_record",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the published supportability vocabulary."
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "description": "Short redaction-aware sentence safe for review, support export, and postmortem surfaces."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_timestamp": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/timestamp" }
      ]
    },
    "nullable_string": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/non_empty_string" }
      ]
    },
    "runbook_source_class": {
      "type": "string",
      "enum": [
        "repo_local",
        "reviewed_docs_pack",
        "managed_catalog",
        "browser_only_vendor_docs"
      ],
      "description": "Runbook source class with explicit authoritative posture."
    },
    "authoritative_posture": {
      "type": "string",
      "enum": [
        "authoritative",
        "reference_only",
        "managed_admin",
        "unverifiable"
      ]
    },
    "step_class": {
      "type": "string",
      "enum": [
        "observe",
        "verify",
        "mitigate",
        "rollback",
        "communicate"
      ]
    },
    "target_selector_scope": {
      "type": "string",
      "enum": [
        "local_workspace",
        "runtime_target",
        "environment_scope",
        "service_resource",
        "browser_console_external",
        "unresolved_requires_review"
      ]
    },
    "approval_requirement_class": {
      "type": "string",
      "enum": [
        "no_approval_required",
        "runtime_approval_ticket",
        "two_person_approval",
        "policy_grant",
        "break_glass",
        "approval_forbidden"
      ]
    },
    "evidence_output_class": {
      "type": "string",
      "enum": [
        "command_result_packet_ref",
        "runbook_step_result_ref",
        "incident_timeline_entry_ref",
        "support_bundle_item_ref",
        "support_packet_index_ref",
        "approval_ticket_ref",
        "rollback_handle_ref",
        "provider_callback_ref",
        "action_ledger_entry_ref",
        "deviation_note_ref"
      ]
    },
    "handoff_kind": {
      "type": "string",
      "enum": [
        "browser_docs",
        "vendor_console",
        "provider_approval",
        "external_control_plane"
      ]
    },
    "handoff_reason_class": {
      "type": "string",
      "enum": [
        "browser_only_vendor_docs",
        "provider_console_only",
        "in_product_action_unsupported",
        "policy_requires_external_approval",
        "target_unverifiable"
      ]
    },
    "docs_freshness_state": {
      "type": "string",
      "enum": [
        "exact_current",
        "warm_within_grace",
        "stale_requires_review",
        "superseded_requires_upgrade",
        "missing_requires_block",
        "browser_only_reference"
      ]
    },
    "export_right_class": {
      "type": "string",
      "enum": [
        "metadata_safe_export",
        "redacted_export",
        "reference_only",
        "export_forbidden"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only",
        "private_triage_only"
      ]
    },
    "owner_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_ref", "escalation_owner_ref", "review_cadence"],
      "properties": {
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "escalation_owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "backup_owner_ref": { "$ref": "#/$defs/nullable_string" },
        "review_cadence": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "source_document_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "source_revision",
        "source_class",
        "authoritative_posture",
        "docs_freshness_state",
        "signer_or_source_ref",
        "approver_policy_summary",
        "export_right"
      ],
      "properties": {
        "source_ref": { "$ref": "#/$defs/non_empty_string" },
        "source_revision": { "$ref": "#/$defs/non_empty_string" },
        "source_class": { "$ref": "#/$defs/runbook_source_class" },
        "authoritative_posture": { "$ref": "#/$defs/authoritative_posture" },
        "docs_freshness_state": { "$ref": "#/$defs/docs_freshness_state" },
        "signer_or_source_ref": { "$ref": "#/$defs/non_empty_string" },
        "approver_policy_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "export_right": { "$ref": "#/$defs/export_right_class" }
      }
    },
    "compatibility_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version_floor_ref",
        "version_ceiling_ref",
        "valid_from",
        "valid_until",
        "expiry_behavior"
      ],
      "properties": {
        "version_floor_ref": { "$ref": "#/$defs/non_empty_string" },
        "version_ceiling_ref": { "$ref": "#/$defs/non_empty_string" },
        "valid_from": { "$ref": "#/$defs/timestamp" },
        "valid_until": { "$ref": "#/$defs/nullable_timestamp" },
        "expiry_behavior": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "expected_evidence_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_output_id",
        "evidence_class",
        "required_for_completion",
        "redaction_state"
      ],
      "properties": {
        "evidence_output_id": { "$ref": "#/$defs/non_empty_string" },
        "evidence_class": { "$ref": "#/$defs/evidence_output_class" },
        "required_for_completion": { "type": "boolean" },
        "redaction_state": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "handoff_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff_id",
        "handoff_kind",
        "target_console_uri_class",
        "target_context_ref",
        "reason_class",
        "in_product_mutation_supported",
        "external_control_plane_authoritative"
      ],
      "properties": {
        "handoff_id": { "$ref": "#/$defs/non_empty_string" },
        "handoff_kind": { "$ref": "#/$defs/handoff_kind" },
        "target_console_uri_class": { "$ref": "#/$defs/non_empty_string" },
        "target_context_ref": { "$ref": "#/$defs/non_empty_string" },
        "reason_class": { "$ref": "#/$defs/handoff_reason_class" },
        "in_product_mutation_supported": { "type": "boolean" },
        "external_control_plane_authoritative": { "type": "boolean" },
        "return_anchor_ref": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "runbook_step_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "ordinal",
        "step_class",
        "title",
        "intent_summary",
        "target_selector_scope",
        "approval_requirement",
        "expected_evidence_outputs",
        "deviation_note_required"
      ],
      "properties": {
        "step_id": { "$ref": "#/$defs/non_empty_string" },
        "ordinal": { "type": "integer", "minimum": 0 },
        "step_class": { "$ref": "#/$defs/step_class" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "intent_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "target_selector_scope": { "$ref": "#/$defs/target_selector_scope" },
        "target_identity_ref": { "$ref": "#/$defs/nullable_string" },
        "approval_requirement": { "$ref": "#/$defs/approval_requirement_class" },
        "approval_ticket_ref": { "$ref": "#/$defs/nullable_string" },
        "expected_evidence_outputs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/expected_evidence_output" }
        },
        "handoff_metadata": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/handoff_metadata" }
          ]
        },
        "deviation_note_required": { "type": "boolean" },
        "rollback_step_ref": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "deviation_note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "deviation_note_id",
        "actor_ref",
        "reason_class",
        "summary",
        "evidence_refs",
        "departed_step_id",
        "runbook_packet_id",
        "created_at"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "runbook_deviation_note_record"
        },
        "deviation_note_id": { "$ref": "#/$defs/non_empty_string" },
        "actor_ref": { "$ref": "#/$defs/non_empty_string" },
        "reason_class": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "departed_step_id": { "$ref": "#/$defs/non_empty_string" },
        "runbook_packet_id": { "$ref": "#/$defs/non_empty_string" },
        "created_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "field_playbook_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "runbook_id",
        "packet_version",
        "title",
        "summary",
        "owner",
        "source_document",
        "compatibility_window",
        "supported_target_scopes",
        "steps",
        "redaction_class",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "authored_at",
        "last_reviewed_at"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "field_playbook_packet_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "runbook_id": { "$ref": "#/$defs/non_empty_string" },
        "packet_version": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "owner": { "$ref": "#/$defs/owner_block" },
        "source_document": { "$ref": "#/$defs/source_document_block" },
        "compatibility_window": { "$ref": "#/$defs/compatibility_window" },
        "supported_target_scopes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/target_selector_scope" }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/runbook_step_envelope" }
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "authored_at": { "$ref": "#/$defs/timestamp" },
        "last_reviewed_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "incident_advisory_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "incident_id",
        "title",
        "summary",
        "owner",
        "source_document",
        "compatibility_window",
        "field_playbook_ref",
        "action_ledger_entry_refs",
        "deviation_notes",
        "console_handoff_refs",
        "redaction_class",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "emitted_at"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "incident_advisory_packet_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "incident_id": { "$ref": "#/$defs/non_empty_string" },
        "advisory_id": { "$ref": "#/$defs/nullable_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "owner": { "$ref": "#/$defs/owner_block" },
        "source_document": { "$ref": "#/$defs/source_document_block" },
        "compatibility_window": { "$ref": "#/$defs/compatibility_window" },
        "field_playbook_ref": { "$ref": "#/$defs/non_empty_string" },
        "action_ledger_entry_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "deviation_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/deviation_note" }
        },
        "console_handoff_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "emitted_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "catalog_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "entry_id",
        "source_class",
        "playbook_packet",
        "fixture_ref"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "supportability_runbook_catalog_entry_record"
        },
        "entry_id": { "$ref": "#/$defs/non_empty_string" },
        "source_class": { "$ref": "#/$defs/runbook_source_class" },
        "playbook_packet": { "$ref": "#/$defs/field_playbook_packet" },
        "incident_advisory_packet": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/incident_advisory_packet" }
          ]
        },
        "fixture_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "supportability_runbook_catalog_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "catalog_id",
        "generated_at",
        "schema_ref",
        "doc_ref",
        "artifact_ref",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "entries"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "supportability_runbook_catalog_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "catalog_id": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "$ref": "#/$defs/timestamp" },
        "schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "doc_ref": { "$ref": "#/$defs/non_empty_string" },
        "artifact_ref": { "$ref": "#/$defs/non_empty_string" },
        "raw_private_material_excluded": { "type": "boolean" },
        "ambient_authority_excluded": { "type": "boolean" },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/catalog_entry" }
        }
      }
    }
  }
}
