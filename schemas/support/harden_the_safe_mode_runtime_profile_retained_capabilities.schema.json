{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/harden_the_safe_mode_runtime_profile_retained_capabilities.schema.json",
  "title": "Aureline hardened safe-mode runtime profile, retained capabilities, and support guidance",
  "description": "Boundary schema for the hardened_safe_mode_runtime_profile_retained_capabilities_record and hardened_safe_mode_runtime_profile_retained_capabilities_stable_packet consumed by aureline-support's hardened safe_mode module. A hardened profile declares exactly which hosts, services, and surfaces are disabled or narrowed and why; it adds retained capability records with support guidance, accessibility posture rows for every touched surface and capability, and recovery-ladder binding rows so the recovery surface knows which actions are available. Both shapes use closed vocabularies so the chrome, headless export, and reviewer surfaces share one truth.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/hardened_safe_mode_profile_record"
    },
    {
      "$ref": "#/$defs/hardened_safe_mode_support_packet_record"
    }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "profile_class": {
      "type": "string",
      "enum": [
        "post_crash_loop_profile",
        "user_invoked_profile",
        "policy_forced_profile",
        "diagnostics_profile"
      ]
    },
    "host_class": {
      "type": "string",
      "enum": [
        "extension_host",
        "language_runtime_host",
        "ai_runtime_host",
        "remote_helper_host",
        "background_indexer_host",
        "docs_pack_fetcher_host"
      ]
    },
    "service_class": {
      "type": "string",
      "enum": [
        "telemetry_upload",
        "background_rebuild",
        "docs_pack_live_fetch",
        "ai_inference_request",
        "extension_marketplace_sync",
        "session_restore_auto_replay",
        "remote_auto_reattach",
        "managed_policy_sync_push",
        "extension_auto_activation"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "extension_marketplace_panel",
        "ai_assistant_panel",
        "remote_collaboration_panel",
        "live_share_surface",
        "auto_update_panel",
        "managed_admin_panel"
      ]
    },
    "disposition_class": {
      "type": "string",
      "enum": [
        "disabled",
        "narrowed_to_read_only",
        "narrowed_to_local_only",
        "narrowed_to_reviewer_view"
      ]
    },
    "reason_class": {
      "type": "string",
      "enum": [
        "startup_crash_loop_detected",
        "restart_budget_exceeded",
        "compatibility_regression_suspected",
        "unsafe_replay_detected",
        "policy_forced_safe_mode",
        "diagnostics_mode_requested",
        "user_opt_in_request"
      ]
    },
    "retained_capability_class": {
      "type": "string",
      "enum": [
        "local_editing",
        "basic_navigation",
        "local_search",
        "local_git_operations",
        "local_diagnostics_export",
        "support_bundle_preview",
        "project_doctor_surfaces",
        "safe_mode_exit_action"
      ]
    },
    "accessibility_dimension_class": {
      "type": "string",
      "enum": [
        "keyboard",
        "screen_reader",
        "ime_grapheme_bidi",
        "zoom",
        "high_contrast",
        "reduced_motion"
      ]
    },
    "accessibility_posture_class": {
      "type": "string",
      "enum": [
        "fully_supported",
        "degraded_but_functional",
        "not_applicable",
        "blocked_in_safe_mode"
      ]
    },
    "recovery_ladder_rung_class": {
      "type": "string",
      "enum": [
        "safe_mode",
        "open_without_restore",
        "disable_recent_extension",
        "disable_recent_layout",
        "open_logs",
        "export_crash_manifest",
        "report_issue"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "launch_stable",
        "launch_stable_below",
        "beta_grade_only",
        "preview_only",
        "unsupported"
      ]
    },
    "preserved_state_class": {
      "type": "string",
      "enum": [
        "user_authored_files",
        "open_buffer_selection",
        "durable_workspace_indexes",
        "workspace_trust_store",
        "credential_store",
        "session_restore_store",
        "support_export_store"
      ]
    },
    "fuller_mode_class": {
      "type": "string",
      "enum": [
        "full_mode",
        "restore_enabled_entry",
        "lane_readmitted"
      ]
    },
    "hardened_safe_mode_profile_record": {
      "type": "object",
      "required": [
        "schema_version",
        "record_kind",
        "profile_id",
        "profile_class",
        "captured_at",
        "doctor_finding_ref",
        "support_packet_ref",
        "declared_hosts",
        "declared_services",
        "declared_surfaces",
        "retained_capabilities",
        "preserved_state_classes",
        "accessibility_postures",
        "recovery_ladder_bindings",
        "destructive_resets_present",
        "return_path",
        "evidence"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "record_kind": {
          "const": "hardened_safe_mode_runtime_profile_retained_capabilities_record"
        },
        "profile_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "profile_class": {
          "$ref": "#/$defs/profile_class"
        },
        "captured_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        },
        "doctor_finding_ref": {
          "type": "string",
          "pattern": "^doctor\\.finding\\..+$"
        },
        "support_packet_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "declared_hosts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/narrowed_host"
          }
        },
        "declared_services": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/narrowed_service"
          }
        },
        "declared_surfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/narrowed_surface"
          }
        },
        "retained_capabilities": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/retained_capability_record"
          }
        },
        "preserved_state_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/preserved_state_class"
          }
        },
        "accessibility_postures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/accessibility_posture_row"
          }
        },
        "recovery_ladder_bindings": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": {
            "$ref": "#/$defs/recovery_ladder_binding_row"
          }
        },
        "destructive_resets_present": {
          "type": "boolean",
          "const": false
        },
        "return_path": {
          "$ref": "#/$defs/return_path"
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        }
      },
      "additionalProperties": false
    },
    "hardened_safe_mode_support_packet_record": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "captured_at",
        "doc_ref",
        "schema_ref",
        "profile_id",
        "profile_class",
        "doctor_finding_ref",
        "host_rows",
        "service_rows",
        "surface_rows",
        "retained_capability_rows",
        "preserved_state_classes",
        "accessibility_posture_rows",
        "recovery_ladder_binding_rows",
        "return_path",
        "evidence_refs",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "destructive_resets_present"
      ],
      "properties": {
        "record_kind": {
          "const": "hardened_safe_mode_runtime_profile_retained_capabilities_stable_packet"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "packet_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "captured_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        },
        "doc_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "schema_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "profile_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "profile_class": {
          "$ref": "#/$defs/profile_class"
        },
        "doctor_finding_ref": {
          "type": "string",
          "pattern": "^doctor\\.finding\\..+$"
        },
        "host_rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/support_host_row"
          }
        },
        "service_rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/support_service_row"
          }
        },
        "surface_rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/support_surface_row"
          }
        },
        "retained_capability_rows": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/support_retained_capability_row"
          }
        },
        "preserved_state_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/preserved_state_class"
          }
        },
        "accessibility_posture_rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/accessibility_posture_row"
          }
        },
        "recovery_ladder_binding_rows": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": {
            "$ref": "#/$defs/recovery_ladder_binding_row"
          }
        },
        "return_path": {
          "$ref": "#/$defs/return_path"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "raw_private_material_excluded": {
          "type": "boolean",
          "const": true
        },
        "ambient_authority_excluded": {
          "type": "boolean",
          "const": true
        },
        "destructive_resets_present": {
          "type": "boolean",
          "const": false
        }
      },
      "additionalProperties": false
    },
    "narrowed_host": {
      "type": "object",
      "required": [
        "host_id",
        "host_class",
        "disposition_class",
        "reason_class",
        "narrowing_summary"
      ],
      "properties": {
        "host_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "host_class": {
          "$ref": "#/$defs/host_class"
        },
        "disposition_class": {
          "$ref": "#/$defs/disposition_class"
        },
        "reason_class": {
          "$ref": "#/$defs/reason_class"
        },
        "narrowing_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      },
      "additionalProperties": false
    },
    "narrowed_service": {
      "type": "object",
      "required": [
        "service_id",
        "service_class",
        "disposition_class",
        "reason_class",
        "narrowing_summary"
      ],
      "properties": {
        "service_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "service_class": {
          "$ref": "#/$defs/service_class"
        },
        "disposition_class": {
          "$ref": "#/$defs/disposition_class"
        },
        "reason_class": {
          "$ref": "#/$defs/reason_class"
        },
        "narrowing_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      },
      "additionalProperties": false
    },
    "narrowed_surface": {
      "type": "object",
      "required": [
        "surface_id",
        "surface_class",
        "disposition_class",
        "reason_class",
        "narrowing_summary"
      ],
      "properties": {
        "surface_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_class": {
          "$ref": "#/$defs/surface_class"
        },
        "disposition_class": {
          "$ref": "#/$defs/disposition_class"
        },
        "reason_class": {
          "$ref": "#/$defs/reason_class"
        },
        "narrowing_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      },
      "additionalProperties": false
    },
    "retained_capability_record": {
      "type": "object",
      "required": [
        "capability_class",
        "rationale",
        "support_guidance",
        "explicitly_tested"
      ],
      "properties": {
        "capability_class": {
          "$ref": "#/$defs/retained_capability_class"
        },
        "rationale": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "support_guidance": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "explicitly_tested": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "accessibility_posture_row": {
      "type": "object",
      "required": [
        "target_id",
        "target_kind",
        "dimension",
        "posture",
        "explanation"
      ],
      "properties": {
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_kind": {
          "type": "string",
          "enum": [
            "surface",
            "capability"
          ]
        },
        "dimension": {
          "$ref": "#/$defs/accessibility_dimension_class"
        },
        "posture": {
          "$ref": "#/$defs/accessibility_posture_class"
        },
        "explanation": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      },
      "additionalProperties": false
    },
    "recovery_ladder_binding_row": {
      "type": "object",
      "required": [
        "rung_class",
        "support_class",
        "requires_review",
        "rung_summary",
        "evidence_refs"
      ],
      "properties": {
        "rung_class": {
          "$ref": "#/$defs/recovery_ladder_rung_class"
        },
        "support_class": {
          "$ref": "#/$defs/support_class"
        },
        "requires_review": {
          "type": "boolean"
        },
        "rung_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      },
      "additionalProperties": false
    },
    "return_path": {
      "type": "object",
      "required": [
        "fuller_mode_class",
        "return_action",
        "restore_conditions"
      ],
      "properties": {
        "fuller_mode_class": {
          "$ref": "#/$defs/fuller_mode_class"
        },
        "return_action": {
          "$ref": "#/$defs/return_action"
        },
        "restore_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/reviewable_sentence"
          }
        }
      },
      "additionalProperties": false
    },
    "return_action": {
      "type": "object",
      "required": [
        "action_id",
        "requires_review",
        "summary"
      ],
      "properties": {
        "action_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "requires_review": {
          "type": "boolean"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      },
      "additionalProperties": false
    },
    "evidence_ref": {
      "type": "object",
      "required": [
        "evidence_ref",
        "evidence_kind",
        "summary"
      ],
      "properties": {
        "evidence_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      },
      "additionalProperties": false
    },
    "support_host_row": {
      "type": "object",
      "required": [
        "host_id",
        "host_class",
        "disposition_class",
        "reason_class",
        "narrowing_summary"
      ],
      "properties": {
        "host_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "host_class": {
          "$ref": "#/$defs/host_class"
        },
        "disposition_class": {
          "$ref": "#/$defs/disposition_class"
        },
        "reason_class": {
          "$ref": "#/$defs/reason_class"
        },
        "narrowing_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      },
      "additionalProperties": false
    },
    "support_service_row": {
      "type": "object",
      "required": [
        "service_id",
        "service_class",
        "disposition_class",
        "reason_class",
        "narrowing_summary"
      ],
      "properties": {
        "service_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "service_class": {
          "$ref": "#/$defs/service_class"
        },
        "disposition_class": {
          "$ref": "#/$defs/disposition_class"
        },
        "reason_class": {
          "$ref": "#/$defs/reason_class"
        },
        "narrowing_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      },
      "additionalProperties": false
    },
    "support_surface_row": {
      "type": "object",
      "required": [
        "surface_id",
        "surface_class",
        "disposition_class",
        "reason_class",
        "narrowing_summary"
      ],
      "properties": {
        "surface_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_class": {
          "$ref": "#/$defs/surface_class"
        },
        "disposition_class": {
          "$ref": "#/$defs/disposition_class"
        },
        "reason_class": {
          "$ref": "#/$defs/reason_class"
        },
        "narrowing_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      },
      "additionalProperties": false
    },
    "support_retained_capability_row": {
      "type": "object",
      "required": [
        "capability_class",
        "rationale",
        "support_guidance",
        "explicitly_tested"
      ],
      "properties": {
        "capability_class": {
          "$ref": "#/$defs/retained_capability_class"
        },
        "rationale": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "support_guidance": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "explicitly_tested": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}
