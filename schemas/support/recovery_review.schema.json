{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/recovery_review.schema.json",
  "title": "Aureline recovery review packet",
  "description": "Boundary schema for the metadata-only recovery_review_packet consumed by aureline-support. The packet joins crash-loop review, scoped reset or reattach review, quarantine or rollback review, and bounded continuity rows so support, docs, and shell recovery surfaces reuse one fault-domain vocabulary across notebook kernels, adapters, preview servers, provider-run sessions, connectors, and other M5 hosts.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "doc_ref",
    "schema_ref",
    "artifact_ref",
    "topology_packet_ref",
    "crash_store_packet_ref",
    "protected_fault_domain_tokens",
    "continuity_rows",
    "crash_loop_reviews",
    "scoped_reset_reviews",
    "quarantine_reviews",
    "export_safe_summary"
  ],
  "properties": {
    "record_kind": { "const": "recovery_review_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "doc_ref": { "const": "docs/support/recovery-review.md" },
    "schema_ref": { "const": "schemas/support/recovery_review.schema.json" },
    "artifact_ref": { "const": "artifacts/support/m5/recovery-review.md" },
    "topology_packet_ref": { "type": "string", "minLength": 1 },
    "crash_store_packet_ref": { "type": "string", "minLength": 1 },
    "protected_fault_domain_tokens": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "continuity_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "record_kind",
          "schema_version",
          "row_id",
          "host_lane_ref",
          "host_family_label",
          "fault_domain_id",
          "affected_surface_tokens",
          "unaffected_surface_tokens",
          "preserved_checkpoint_refs",
          "preserved_result_refs",
          "next_safe_action_tokens",
          "continuity_summary"
        ],
        "properties": {
          "record_kind": { "const": "recovery_continuity_row" },
          "schema_version": { "type": "integer", "const": 1 },
          "row_id": { "type": "string", "minLength": 1 },
          "host_lane_ref": { "type": "string", "minLength": 1 },
          "host_family_label": { "type": "string", "minLength": 1 },
          "fault_domain_id": { "type": "string", "minLength": 1 },
          "affected_surface_tokens": { "type": "array", "items": { "type": "string" } },
          "unaffected_surface_tokens": { "type": "array", "items": { "type": "string" } },
          "preserved_checkpoint_refs": { "type": "array", "items": { "type": "string" } },
          "preserved_result_refs": { "type": "array", "items": { "type": "string" } },
          "next_safe_action_tokens": { "type": "array", "items": { "type": "string" } },
          "continuity_summary": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "crash_loop_reviews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "record_kind",
          "schema_version",
          "review_id",
          "center_ref",
          "host_lane_ref",
          "host_family_label",
          "fault_domain_id",
          "fault_domain_token",
          "failing_surface_tokens",
          "exact_build_identity_ref",
          "build_id",
          "crash_id",
          "session_ref",
          "last_reopen_mode_token",
          "preserved_checkpoint_refs",
          "evidence_refs",
          "safe_mode_command_id",
          "open_without_restore_command_id",
          "disable_recent_change_command_ids",
          "disable_recent_change_refs",
          "open_logs_command_id",
          "export_command_id",
          "no_hidden_rerun"
        ],
        "properties": {
          "record_kind": { "const": "crash_loop_review_row" },
          "schema_version": { "type": "integer", "const": 1 },
          "review_id": { "type": "string", "minLength": 1 },
          "center_ref": { "type": "string", "minLength": 1 },
          "host_lane_ref": { "type": "string", "minLength": 1 },
          "host_family_label": { "type": "string", "minLength": 1 },
          "fault_domain_id": { "type": "string", "minLength": 1 },
          "fault_domain_token": { "type": "string", "minLength": 1 },
          "failing_surface_tokens": { "type": "array", "items": { "type": "string" } },
          "exact_build_identity_ref": { "type": "string", "minLength": 1 },
          "build_id": { "type": "string", "minLength": 1 },
          "crash_id": { "type": "string", "minLength": 1 },
          "session_ref": { "type": "string", "minLength": 1 },
          "last_reopen_mode_token": { "type": "string", "minLength": 1 },
          "preserved_checkpoint_refs": { "type": "array", "items": { "type": "string" } },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "safe_mode_command_id": { "type": "string", "minLength": 1 },
          "open_without_restore_command_id": { "type": "string", "minLength": 1 },
          "disable_recent_change_command_ids": { "type": "array", "items": { "type": "string" } },
          "disable_recent_change_refs": { "type": "array", "items": { "type": "string" } },
          "open_logs_command_id": { "type": "string", "minLength": 1 },
          "export_command_id": { "type": "string", "minLength": 1 },
          "no_hidden_rerun": { "type": "boolean", "const": true }
        },
        "additionalProperties": false
      }
    },
    "scoped_reset_reviews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "record_kind",
          "schema_version",
          "review_id",
          "previous_host_lane_ref",
          "current_host_lane_ref",
          "previous_host_family_label",
          "current_host_family_label",
          "previous_host_fingerprint_token",
          "current_host_fingerprint_token",
          "session_ref",
          "surrounding_surface_tokens",
          "preserved_checkpoint_refs",
          "preserved_state_refs",
          "lost_state_refs",
          "replay_risk_token",
          "rerun_requirement_token",
          "decision_token",
          "approval_or_policy_drift_present",
          "auth_drift_present",
          "scoped_reset_action_tokens",
          "no_hidden_rerun"
        ],
        "properties": {
          "record_kind": { "const": "scoped_reset_review_row" },
          "schema_version": { "type": "integer", "const": 1 },
          "review_id": { "type": "string", "minLength": 1 },
          "previous_host_lane_ref": { "type": "string", "minLength": 1 },
          "current_host_lane_ref": { "type": "string", "minLength": 1 },
          "previous_host_family_label": { "type": "string", "minLength": 1 },
          "current_host_family_label": { "type": "string", "minLength": 1 },
          "previous_host_fingerprint_token": { "type": "string", "minLength": 1 },
          "current_host_fingerprint_token": { "type": "string", "minLength": 1 },
          "session_ref": { "type": "string", "minLength": 1 },
          "surrounding_surface_tokens": { "type": "array", "items": { "type": "string" } },
          "preserved_checkpoint_refs": { "type": "array", "items": { "type": "string" } },
          "preserved_state_refs": { "type": "array", "items": { "type": "string" } },
          "lost_state_refs": { "type": "array", "items": { "type": "string" } },
          "replay_risk_token": { "type": "string", "minLength": 1 },
          "rerun_requirement_token": { "type": "string", "minLength": 1 },
          "decision_token": { "type": "string", "minLength": 1 },
          "approval_or_policy_drift_present": { "type": "boolean" },
          "auth_drift_present": { "type": "boolean" },
          "scoped_reset_action_tokens": { "type": "array", "items": { "type": "string" } },
          "no_hidden_rerun": { "type": "boolean", "const": true }
        },
        "additionalProperties": false
      }
    },
    "quarantine_reviews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "record_kind",
          "schema_version",
          "review_id",
          "host_lane_ref",
          "host_family_label",
          "fault_domain_id",
          "current_state_token",
          "trigger_summary",
          "scope_summary",
          "evidence_refs",
          "recovery_action_tokens",
          "rollback_candidate_ref",
          "support_export_ref",
          "candidate_action_label",
          "risk_note",
          "confirm_action_ref",
          "preserved_checkpoint_refs",
          "surrounding_surface_tokens"
        ],
        "properties": {
          "record_kind": { "const": "quarantine_review_row" },
          "schema_version": { "type": "integer", "const": 1 },
          "review_id": { "type": "string", "minLength": 1 },
          "host_lane_ref": { "type": "string", "minLength": 1 },
          "host_family_label": { "type": "string", "minLength": 1 },
          "fault_domain_id": { "type": "string", "minLength": 1 },
          "current_state_token": { "type": "string", "minLength": 1 },
          "trigger_summary": { "type": "string", "minLength": 1 },
          "scope_summary": { "type": "string", "minLength": 1 },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "recovery_action_tokens": { "type": "array", "items": { "type": "string" } },
          "rollback_candidate_ref": { "type": "string", "minLength": 1 },
          "support_export_ref": { "type": "string", "minLength": 1 },
          "candidate_action_label": { "type": "string", "minLength": 1 },
          "risk_note": { "type": "string", "minLength": 1 },
          "confirm_action_ref": { "type": "string", "minLength": 1 },
          "preserved_checkpoint_refs": { "type": "array", "items": { "type": "string" } },
          "surrounding_surface_tokens": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "export_safe_summary": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
