{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/m5-host-failure-drills.schema.json",
  "title": "Aureline M5 host-failure drill packet",
  "description": "Boundary schema for the M5 host-failure drill packet emitted by aureline-support's m5_host_failure_drills module. The packet freezes the seeded host-failure corpus, proves restart-budget enforcement and scoped failure across claimed M5 host families, and binds each drill to an export-safe forensic packet and explicit no-silent-upload assertions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "doc_ref",
    "schema_ref",
    "artifact_ref",
    "source_spec_refs",
    "supporting_contract_refs",
    "forensic_packet",
    "drills",
    "export_safe_summary"
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "scenario_class": {
      "type": "string",
      "enum": [
        "notebook_kernel_crash_stall",
        "provider_run_failure",
        "preview_server_restart",
        "remote_connector_drift",
        "ai_broker_circuit_breaker",
        "query_runtime_crash",
        "pipeline_viewer_fault",
        "connector_host_mismatch",
        "docs_browser_bridge_route_drift",
        "profiler_replay_imported_gap",
        "infra_helper_signature_failure"
      ]
    },
    "drill_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "scenario_class",
        "host_family_id",
        "host_family_label",
        "restart_budget_ref",
        "restart_budget_enforced",
        "scoped_failure_only",
        "checkpoint_preserved",
        "no_hidden_rerun",
        "visible_fail_closed_state",
        "forensic_packet_ref",
        "support_packet_refs",
        "upload_guard_assertions",
        "evidence_fixture_ref",
        "summary"
      ],
      "properties": {
        "scenario_id": { "$ref": "#/$defs/non_empty_string" },
        "scenario_class": { "$ref": "#/$defs/scenario_class" },
        "host_family_id": { "$ref": "#/$defs/non_empty_string" },
        "host_family_label": { "$ref": "#/$defs/non_empty_string" },
        "restart_budget_ref": { "$ref": "#/$defs/non_empty_string" },
        "restart_budget_enforced": { "type": "boolean" },
        "scoped_failure_only": { "type": "boolean" },
        "checkpoint_preserved": { "type": "boolean" },
        "no_hidden_rerun": { "type": "boolean" },
        "visible_fail_closed_state": { "type": "boolean" },
        "forensic_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "minItems": 1
        },
        "upload_guard_assertions": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "minItems": 1
        },
        "evidence_fixture_ref": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  },
  "properties": {
    "record_kind": { "type": "string", "const": "m5_host_failure_drill_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/timestamp" },
    "doc_ref": { "$ref": "#/$defs/non_empty_string" },
    "schema_ref": {
      "type": "string",
      "const": "schemas/support/m5-host-failure-drills.schema.json"
    },
    "artifact_ref": { "$ref": "#/$defs/non_empty_string" },
    "source_spec_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1
    },
    "supporting_contract_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1
    },
    "forensic_packet": { "$ref": "m5-forensic-packet.schema.json" },
    "drills": {
      "type": "array",
      "items": { "$ref": "#/$defs/drill_row" },
      "minItems": 1
    },
    "export_safe_summary": { "$ref": "#/$defs/non_empty_string" }
  }
}
