{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/harden_crash_capture_exact_build_symbolication_crash_loop.schema.json",
  "title": "Aureline hardened crash capture, exact-build symbolication, crash-loop detection, and evidence preview/export",
  "description": "Boundary schema for the hardened crash-capture M4 stable lane. A crash_loop_signal_record is emitted when incident trails breach restart budgets. A crash_evidence_preview_record shows what an export would contain before it happens. A crash_evidence_export_packet_record is the metadata-safe export projection that excludes raw dumps, raw stack bodies, and secret-bearing material by default.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/crash_loop_signal_record"
    },
    {
      "$ref": "#/$defs/crash_evidence_preview_record"
    },
    {
      "$ref": "#/$defs/crash_evidence_export_packet_record"
    }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "crash_loop_detection_state": {
      "type": "string",
      "enum": [
        "no_loop",
        "emerging",
        "confirmed",
        "escalating"
      ]
    },
    "crash_loop_scenario_class": {
      "type": "string",
      "enum": [
        "startup_restart_budget_exceeded",
        "reopen_restart_budget_exceeded",
        "runtime_host_restart_budget_exceeded",
        "extension_host_restart_budget_exceeded",
        "restore_replay_failed_repeatedly"
      ]
    },
    "recovery_ladder_hook_class": {
      "type": "string",
      "enum": [
        "safe_mode_minimal_profile",
        "open_without_restore",
        "export_evidence",
        "retry_fault_domain",
        "disable_recent_extension",
        "reset_ephemeral_cache"
      ]
    },
    "export_redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "local_only"
      ]
    },
    "evidence_inclusion_state": {
      "type": "string",
      "enum": [
        "embedded_metadata",
        "by_reference",
        "omitted"
      ]
    },
    "recovery_ladder_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hook_class",
        "hook_ref",
        "label",
        "enabled",
        "blast_radius",
        "preserves_user_state",
        "notes"
      ],
      "properties": {
        "hook_class": {
          "$ref": "#/$defs/recovery_ladder_hook_class"
        },
        "hook_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "enabled": {
          "type": "boolean"
        },
        "blast_radius": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preserves_user_state": {
          "type": "boolean"
        },
        "notes": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "evidence_preview_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_kind",
        "item_ref",
        "inclusion_state",
        "redaction_class",
        "summary"
      ],
      "properties": {
        "item_kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "item_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "inclusion_state": {
          "$ref": "#/$defs/evidence_inclusion_state"
        },
        "redaction_class": {
          "$ref": "#/$defs/export_redaction_class"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "evidence_export_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_kind",
        "item_ref",
        "inclusion_state",
        "redaction_class",
        "summary"
      ],
      "properties": {
        "item_kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "item_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "inclusion_state": {
          "$ref": "#/$defs/evidence_inclusion_state"
        },
        "redaction_class": {
          "$ref": "#/$defs/export_redaction_class"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "chain_of_custody_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "actor",
        "action",
        "timestamp",
        "note"
      ],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "actor": {
          "$ref": "#/$defs/non_empty_string"
        },
        "action": {
          "$ref": "#/$defs/non_empty_string"
        },
        "timestamp": {
          "$ref": "#/$defs/monotonic_timestamp"
        },
        "note": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "crash_loop_signal_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "signal_id",
        "generated_at",
        "detection_state",
        "strike_count",
        "strike_budget",
        "recovery_attempt_count",
        "primary_exact_build_identity_ref",
        "fault_domain_id",
        "all_symbolication_exact",
        "any_build_mismatch_observed",
        "scenario_class",
        "available_hooks",
        "doc_ref",
        "schema_ref",
        "notes"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "record_kind": {
          "type": "string",
          "const": "crash_loop_signal_record"
        },
        "signal_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "generated_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        },
        "detection_state": {
          "$ref": "#/$defs/crash_loop_detection_state"
        },
        "strike_count": {
          "type": "integer",
          "minimum": 1
        },
        "strike_budget": {
          "type": "integer",
          "minimum": 1
        },
        "recovery_attempt_count": {
          "type": "integer",
          "minimum": 0
        },
        "primary_exact_build_identity_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "fault_domain_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "all_symbolication_exact": {
          "type": "boolean"
        },
        "any_build_mismatch_observed": {
          "type": "boolean"
        },
        "scenario_class": {
          "$ref": "#/$defs/crash_loop_scenario_class"
        },
        "available_hooks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/recovery_ladder_hook"
          }
        },
        "doc_ref": {
          "type": "string",
          "const": "docs/support/m4/harden_crash_capture_exact_build_symbolication_crash_loop.md"
        },
        "schema_ref": {
          "type": "string",
          "const": "schemas/support/harden_crash_capture_exact_build_symbolication_crash_loop.schema.json"
        },
        "notes": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "crash_evidence_preview_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "preview_id",
        "generated_at",
        "incident_trail_ref",
        "primary_exact_build_identity_ref",
        "symbolication_state",
        "included_items",
        "omitted_items",
        "redaction_class",
        "raw_dump_exported",
        "doc_ref",
        "schema_ref",
        "notes"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "record_kind": {
          "type": "string",
          "const": "crash_evidence_preview_record"
        },
        "preview_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "generated_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        },
        "incident_trail_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "crash_loop_signal_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/non_empty_string"
            }
          ]
        },
        "primary_exact_build_identity_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "symbolication_state": {
          "$ref": "#/$defs/non_empty_string"
        },
        "included_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_preview_item"
          }
        },
        "omitted_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_preview_item"
          }
        },
        "redaction_class": {
          "$ref": "#/$defs/export_redaction_class"
        },
        "raw_dump_exported": {
          "type": "boolean",
          "const": false
        },
        "doc_ref": {
          "type": "string",
          "const": "docs/support/m4/harden_crash_capture_exact_build_symbolication_crash_loop.md"
        },
        "schema_ref": {
          "type": "string",
          "const": "schemas/support/harden_crash_capture_exact_build_symbolication_crash_loop.schema.json"
        },
        "notes": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "crash_evidence_export_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "generated_at",
        "incident_trail_ref",
        "primary_exact_build_identity_ref",
        "symbolication_state",
        "export_items",
        "chain_of_custody",
        "redaction_class",
        "raw_dump_exported",
        "raw_private_material_excluded",
        "ambient_authority_excluded",
        "doc_ref",
        "schema_ref",
        "notes"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "record_kind": {
          "type": "string",
          "const": "crash_evidence_export_packet_record"
        },
        "packet_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "generated_at": {
          "$ref": "#/$defs/monotonic_timestamp"
        },
        "incident_trail_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "crash_loop_signal_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/non_empty_string"
            }
          ]
        },
        "primary_exact_build_identity_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "symbolication_state": {
          "$ref": "#/$defs/non_empty_string"
        },
        "export_items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_export_item"
          }
        },
        "chain_of_custody": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/chain_of_custody_entry"
          }
        },
        "repair_transaction_id": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/non_empty_string"
            }
          ]
        },
        "redaction_class": {
          "$ref": "#/$defs/export_redaction_class"
        },
        "raw_dump_exported": {
          "type": "boolean",
          "const": false
        },
        "raw_private_material_excluded": {
          "type": "boolean",
          "const": true
        },
        "ambient_authority_excluded": {
          "type": "boolean",
          "const": true
        },
        "doc_ref": {
          "type": "string",
          "const": "docs/support/m4/harden_crash_capture_exact_build_symbolication_crash_loop.md"
        },
        "schema_ref": {
          "type": "string",
          "const": "schemas/support/harden_crash_capture_exact_build_symbolication_crash_loop.schema.json"
        },
        "notes": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    }
  }
}
