{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/crash_store_viewer.schema.json",
  "title": "Aureline local crash-store viewer packet",
  "description": "Boundary schema for the metadata-safe local crash-store viewer packet emitted by aureline-support. The packet binds crash-envelope refs, dump/core metadata, exact-build identity, preservation class, redaction posture, and user-visible local preview/export/upload actions for M5 host families. Raw dump bytes remain local unless a reviewed opt-in action is chosen.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "doc_ref",
    "schema_ref",
    "artifact_ref",
    "source_spec_refs",
    "supporting_contract_refs",
    "rows",
    "export_safe_summary"
  ],
  "properties": {
    "record_kind": {
      "const": "crash_store_viewer_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "doc_ref": {
      "const": "docs/support/m5/crash_store.md"
    },
    "schema_ref": {
      "const": "schemas/support/crash_store_viewer.schema.json"
    },
    "artifact_ref": {
      "const": "artifacts/support/m5/crash-store.md"
    },
    "source_spec_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supporting_contract_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/crash_store_viewer_row"
      }
    },
    "export_safe_summary": {
      "type": "string"
    }
  },
  "$defs": {
    "symbolication_state": {
      "type": "string",
      "enum": [
        "exact",
        "partial",
        "missing",
        "build_mismatch"
      ]
    },
    "preservation_class": {
      "type": "string",
      "enum": [
        "envelope_and_dump_retained_local",
        "envelope_and_symbolication_retained_dump_opt_in_only",
        "envelope_only_dump_expired_metadata_preserved"
      ]
    },
    "redaction_posture": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "local_only_review_required"
      ]
    },
    "action_class": {
      "type": "string",
      "enum": [
        "inspect_metadata_local",
        "inspect_dump_metadata_local",
        "preview_support_export_local",
        "export_metadata_bundle",
        "attach_raw_dump_opt_in",
        "upload_reviewed_packet",
        "open_restart_lineage"
      ]
    },
    "crash_store_action_row": {
      "type": "object",
      "required": [
        "action_class",
        "label",
        "enabled",
        "requires_local_review",
        "raw_dump_opt_in_required",
        "network_egress",
        "notes"
      ],
      "properties": {
        "action_class": {
          "$ref": "#/$defs/action_class"
        },
        "label": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "requires_local_review": {
          "type": "boolean"
        },
        "raw_dump_opt_in_required": {
          "type": "boolean"
        },
        "network_egress": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "crash_store_viewer_row": {
      "type": "object",
      "required": [
        "record_kind",
        "crash_store_entry_id",
        "crash_id",
        "host_family_id",
        "host_family_label",
        "session_type_id",
        "fault_domain_id",
        "crash_envelope_ref",
        "crash_dump_ref",
        "restart_lineage_ref",
        "primary_exact_build_identity_ref",
        "build_id",
        "release_channel_class",
        "trace_ids",
        "extension_or_host_set_hash",
        "policy_fingerprint",
        "sandbox_profile",
        "crash_window_started_at",
        "crash_window_ended_at",
        "architecture",
        "signal_or_exception_class",
        "dump_format_class",
        "dump_format_identity",
        "module_ids",
        "module_build_ids",
        "symbolication_state",
        "preservation_class",
        "redaction_posture",
        "support_export_review_ref",
        "local_first_by_default",
        "raw_dump_exported",
        "available_actions",
        "notes"
      ],
      "properties": {
        "record_kind": {
          "const": "crash_store_viewer_row"
        },
        "crash_store_entry_id": {
          "type": "string"
        },
        "crash_id": {
          "type": "string"
        },
        "host_family_id": {
          "type": "string"
        },
        "host_family_label": {
          "type": "string"
        },
        "session_type_id": {
          "type": "string"
        },
        "fault_domain_id": {
          "type": "string"
        },
        "crash_envelope_ref": {
          "type": "string"
        },
        "crash_dump_ref": {
          "type": "string"
        },
        "symbolication_report_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "support_bundle_manifest_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "support_preview_snapshot_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "restart_lineage_ref": {
          "type": "string"
        },
        "primary_exact_build_identity_ref": {
          "type": "string"
        },
        "build_id": {
          "type": "string"
        },
        "release_channel_class": {
          "type": "string"
        },
        "trace_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extension_or_host_set_hash": {
          "type": "string"
        },
        "policy_fingerprint": {
          "type": "string"
        },
        "sandbox_profile": {
          "type": "string"
        },
        "crash_window_started_at": {
          "type": "string"
        },
        "crash_window_ended_at": {
          "type": "string"
        },
        "architecture": {
          "type": "string"
        },
        "signal_or_exception_class": {
          "type": "string"
        },
        "dump_format_class": {
          "type": "string"
        },
        "dump_format_identity": {
          "type": "string"
        },
        "module_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "module_build_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "symbolication_state": {
          "$ref": "#/$defs/symbolication_state"
        },
        "preservation_class": {
          "$ref": "#/$defs/preservation_class"
        },
        "redaction_posture": {
          "$ref": "#/$defs/redaction_posture"
        },
        "support_export_review_ref": {
          "type": "string"
        },
        "upload_target_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "local_first_by_default": {
          "type": "boolean"
        },
        "raw_dump_exported": {
          "type": "boolean"
        },
        "available_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/crash_store_action_row"
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
