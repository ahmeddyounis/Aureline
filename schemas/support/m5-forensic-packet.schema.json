{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/support/m5-forensic-packet.schema.json",
  "title": "Aureline M5 support-side forensic packet",
  "description": "Boundary schema for the support-side M5 forensic packet emitted by aureline-support's m5_forensic_packet module. The packet projects runtime forensic evidence, crash-store posture, and reviewed share actions into one export-safe object that distinguishes local-only, imported, mirrored, and uploaded artifact states without silently widening retention or egress scope.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "doc_ref",
    "schema_ref",
    "artifact_ref",
    "source_spec_refs",
    "supporting_contract_refs",
    "rows",
    "export_safe_summary"
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "fault_domain_class": {
      "type": "string",
      "enum": [
        "shell_interaction_core",
        "workspace_knowledge_group",
        "session_execution_host",
        "extension_or_external_tool_host",
        "ai_tool_broker",
        "remote_connector",
        "policy_verifier_helper"
      ]
    },
    "redaction_profile_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "environment_summary_only",
        "operator_only_restricted",
        "local_only_review_required"
      ]
    },
    "retention_class": {
      "type": "string",
      "enum": [
        "local_user_owned_until_delete_or_attach",
        "local_sampling_window",
        "managed_contract_window",
        "local_manifest_until_sent"
      ]
    },
    "trigger_class": {
      "type": "string",
      "enum": [
        "crash",
        "stall_detected",
        "restart_budget_exhausted",
        "connector_drift",
        "circuit_breaker_open",
        "host_mismatch",
        "recovery_transition"
      ]
    },
    "artifact_class": {
      "type": "string",
      "enum": [
        "runtime_forensic_packet",
        "crash_envelope",
        "dump_manifest",
        "symbol_manifest",
        "symbolication_report",
        "support_bundle_manifest",
        "upload_receipt"
      ]
    },
    "artifact_state_class": {
      "type": "string",
      "enum": ["local_only", "imported", "mirrored", "uploaded"]
    },
    "share_destination_class": {
      "type": "string",
      "enum": [
        "local_preview",
        "local_export",
        "mirror_copy",
        "managed_upload",
        "imported_handoff"
      ]
    },
    "artifact_state_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_class",
        "artifact_ref",
        "state_class",
        "retention_class",
        "redaction_profile",
        "explicit_user_or_policy_action_required",
        "scope_widening_without_review_forbidden",
        "summary"
      ],
      "properties": {
        "artifact_class": { "$ref": "#/$defs/artifact_class" },
        "artifact_ref": { "$ref": "#/$defs/non_empty_string" },
        "state_class": { "$ref": "#/$defs/artifact_state_class" },
        "retention_class": { "$ref": "#/$defs/retention_class" },
        "redaction_profile": { "$ref": "#/$defs/redaction_profile_class" },
        "explicit_user_or_policy_action_required": { "type": "boolean" },
        "scope_widening_without_review_forbidden": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "share_action_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "label",
        "destination_class",
        "network_egress",
        "explicit_user_or_policy_action_required",
        "enabled",
        "retention_or_scope_change_requires_review",
        "note"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "destination_class": { "$ref": "#/$defs/share_destination_class" },
        "network_egress": { "type": "boolean" },
        "explicit_user_or_policy_action_required": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "retention_or_scope_change_requires_review": { "type": "boolean" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "forensic_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "forensic_packet_id",
        "scenario_id",
        "host_family_id",
        "host_family_label",
        "fault_domain_class",
        "trigger_class",
        "runtime_forensic_packet_ref",
        "exact_build_identity_ref",
        "restart_lineage_ref",
        "checkpoint_ref",
        "redaction_profile",
        "retention_class",
        "artifact_states",
        "share_actions",
        "no_silent_upload_guards",
        "export_safe_summary"
      ],
      "properties": {
        "forensic_packet_id": { "$ref": "#/$defs/non_empty_string" },
        "scenario_id": { "$ref": "#/$defs/non_empty_string" },
        "host_family_id": { "$ref": "#/$defs/non_empty_string" },
        "host_family_label": { "$ref": "#/$defs/non_empty_string" },
        "fault_domain_class": { "$ref": "#/$defs/fault_domain_class" },
        "trigger_class": { "$ref": "#/$defs/trigger_class" },
        "runtime_forensic_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "exact_build_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "restart_lineage_ref": { "$ref": "#/$defs/non_empty_string" },
        "checkpoint_ref": { "$ref": "#/$defs/non_empty_string" },
        "redaction_profile": { "$ref": "#/$defs/redaction_profile_class" },
        "retention_class": { "$ref": "#/$defs/retention_class" },
        "artifact_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact_state_row" },
          "minItems": 1
        },
        "share_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/share_action_row" },
          "minItems": 1
        },
        "no_silent_upload_guards": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "minItems": 1
        },
        "export_safe_summary": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  },
  "properties": {
    "record_kind": { "type": "string", "const": "m5_forensic_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/timestamp" },
    "doc_ref": { "$ref": "#/$defs/non_empty_string" },
    "schema_ref": { "type": "string", "const": "schemas/support/m5-forensic-packet.schema.json" },
    "artifact_ref": { "$ref": "#/$defs/non_empty_string" },
    "source_spec_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1
    },
    "supporting_contract_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/forensic_row" },
      "minItems": 1
    },
    "export_safe_summary": { "$ref": "#/$defs/non_empty_string" }
  }
}
