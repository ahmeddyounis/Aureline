        },
        "decision_note": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "embedding_state": {
                "enum": [
                  "embedded",
                  "redacted"
                ]
              }
            },
            "required": [
              "embedding_state"
            ]
          },
          "then": {
            "properties": {
              "materialization": {
                "properties": {
                  "embedded_member_ref": {
                    "$ref": "#/$defs/opaque_id"
                  }
                },
                "required": [
                  "embedded_member_ref"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "embedding_state": {
                "const": "omitted"
              }
            },
            "required": [
              "embedding_state"
            ]
          },
          "then": {
            "properties": {
              "materialization": {
                "properties": {
                  "omission_reason_class": {
                    "$ref": "#/$defs/omission_reason_class"
                  }
                },
                "required": [
                  "omission_reason_class"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "storage_mode": {
                "const": "local_only_copy_retained"
              }
            },
            "required": [
              "storage_mode"
            ]
          },
          "then": {
            "properties": {
              "materialization": {
                "properties": {
                  "local_retention_ref": {
                    "$ref": "#/$defs/opaque_id"
                  }
                },
                "required": [
                  "local_retention_ref"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "storage_mode": {
                "const": "managed_reference_only"
              }
            },
            "required": [
              "storage_mode"
            ]
          },
          "then": {
            "properties": {
              "materialization": {
                "properties": {
                  "managed_reference_ref": {
                    "$ref": "#/$defs/opaque_id"
                  }
                },
                "required": [
                  "managed_reference_ref"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "storage_mode": {
                "const": "optional_upload_candidate"
              }
            },
            "required": [
              "storage_mode"
            ]
          },
          "then": {
            "properties": {
              "materialization": {
                "properties": {
                  "optional_upload_ref": {
                    "$ref": "#/$defs/opaque_id"
                  }
                },
                "required": [
                  "optional_upload_ref"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "embedding_state": {
                "const": "by_reference"
              }
            },
            "required": [
              "embedding_state"
            ]
          },
          "then": {
            "properties": {
              "materialization": {
                "anyOf": [
                  {
                    "properties": {
                      "managed_reference_ref": {
                        "$ref": "#/$defs/opaque_id"
                      }
                    },
                    "required": [
                      "managed_reference_ref"
                    ]
                  },
                  {
                    "properties": {
                      "local_retention_ref": {
                        "$ref": "#/$defs/opaque_id"
                      }
                    },
                    "required": [
                      "local_retention_ref"
                    ]
                  },
                  {
                    "properties": {
                      "optional_upload_ref": {
                        "$ref": "#/$defs/opaque_id"
                      }
                    },
                    "required": [
                      "optional_upload_ref"
                    ]
                  },
                  {
                    "properties": {
                      "source_manifest_ref": {
                        "$ref": "#/$defs/non_empty_string"
                      }
                    },
                    "required": [
                      "source_manifest_ref"
                    ]
                  }
                ]
              }
            }
          }
        }
      ],
      "description": "One artifact row inside the support-bundle manifest. Every row carries section, data class, redaction class, storage mode, embedding state, and explicit materialization refs so future support tooling does not flatten everything into one generic attachments list."
    },
