{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/research/dataset_summary.schema.json",
  "title": "Aureline dataset summary record",
  "description": "Boundary schema for one governed dataset summary. The record describes source class, snapshot, slice sizes, refresh date, exclusions, sensitivity, redaction, license posture, and comparability notes without embedding raw rows, raw files, raw source names, raw queries, raw paths, raw URLs, private participant identifiers, or credential material.",
  "$ref": "#/$defs/dataset_summary_record",
  "$defs": {
    "dataset_summary_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "dataset_summary_record"
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable ref safe for manifests, support bundles, release evidence, and public-proof packets. No raw URLs, raw file paths outside the repo, raw dataset labels, raw queries, raw rows, raw participant identifiers, credentials, or private source names appear here."
    },
    "nullable_opaque_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_ref" }
      ]
    },
    "safe_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "local_date": {
      "type": "string",
      "format": "date"
    },
    "source_class": {
      "type": "string",
      "enum": [
        "protected_benchmark_corpus",
        "reference_workspace",
        "database_query",
        "warehouse_snapshot",
        "local_file",
        "remote_object_store",
        "notebook_output",
        "design_partner_input",
        "customer_derived_redacted",
        "public_open_dataset",
        "synthetic_generated",
        "captured_sample",
        "imported_report",
        "manual_attachment"
      ]
    },
    "location_class": {
      "type": "string",
      "enum": [
        "repo_fixture",
        "local_workspace",
        "managed_region",
        "customer_restricted_store",
        "partner_restricted_store",
        "public_internet_mirror",
        "artifact_store_ref_only",
        "unknown"
      ]
    },
    "provenance_class": {
      "type": "string",
      "enum": [
        "first_party_authored",
        "first_party_collected",
        "design_partner_supplied",
        "customer_supplied_redacted",
        "public_third_party",
        "synthetic_generated",
        "imported_unverified",
        "manual_attachment"
      ]
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "full_dataset",
        "stratified_sample",
        "random_sample",
        "deterministic_sample",
        "benchmark_fixture_subset",
        "redacted_subset",
        "aggregated_summary",
        "synthetic_slice",
        "unknown"
      ]
    },
    "size_class": {
      "type": "string",
      "enum": [
        "empty",
        "tiny",
        "small",
        "medium",
        "large",
        "oversize",
        "unknown"
      ]
    },
    "truncation_state": {
      "type": "string",
      "enum": [
        "none",
        "sampled",
        "truncated",
        "aggregated",
        "redacted",
        "unknown"
      ]
    },
    "sensitivity_class": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "customer_derived",
        "production_like",
        "secrets_possible",
        "regulated",
        "unknown"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "none_required",
        "metadata_only",
        "redacted_identifiers",
        "aggregated_only",
        "synthetic_replacement",
        "restricted_raw_local_only",
        "blocked_sensitive"
      ]
    },
    "export_posture": {
      "type": "string",
      "enum": [
        "metadata_only",
        "summary_only",
        "redacted_examples_allowed",
        "local_only_raw",
        "approval_required_for_raw",
        "blocked"
      ]
    },
    "license_class": {
      "type": "string",
      "enum": [
        "first_party",
        "permissive_open_source",
        "proprietary_internal",
        "partner_restricted",
        "customer_restricted",
        "public_domain",
        "generated_synthetic",
        "unknown_pending_review",
        "not_redistributable"
      ]
    },
    "license_review_state": {
      "type": "string",
      "enum": [
        "approved",
        "approved_with_restrictions",
        "pending_review",
        "blocked",
        "not_required"
      ]
    },
    "allowed_use_class": {
      "type": "string",
      "enum": [
        "ci_and_release_evidence",
        "internal_research_only",
        "public_proof_metadata_only",
        "public_fixture_allowed",
        "design_research_only",
        "support_only",
        "not_admitted"
      ]
    },
    "redistribution_posture": {
      "type": "string",
      "enum": [
        "redistributable",
        "metadata_only",
        "derived_metrics_only",
        "internal_only",
        "not_redistributable"
      ]
    },
    "refresh_cadence": {
      "type": "string",
      "enum": [
        "per_run",
        "daily",
        "weekly",
        "per_release",
        "per_milestone",
        "manual_refresh",
        "static_snapshot",
        "unknown"
      ]
    },
    "freshness_state": {
      "type": "string",
      "enum": [
        "current",
        "warm_cached",
        "stale",
        "expired",
        "unknown"
      ]
    },
    "exclusion_class": {
      "type": "string",
      "enum": [
        "privacy",
        "license",
        "retention",
        "quality_filter",
        "outlier_policy",
        "unsupported_format",
        "unavailable_source",
        "scope_not_claimed",
        "other"
      ]
    },
    "comparability_axis": {
      "type": "string",
      "enum": [
        "data_snapshot",
        "partition",
        "sampling",
        "redaction",
        "schema",
        "label_policy",
        "source_license",
        "source_location",
        "retention",
        "transformation",
        "known_bias",
        "corpus_manifest_revision"
      ]
    },
    "comparability_effect": {
      "type": "string",
      "enum": [
        "no_effect",
        "advisory",
        "blocks_comparison",
        "resets_baseline",
        "unknown"
      ]
    },
    "link_kind": {
      "type": "string",
      "enum": [
        "benchmark_corpus_manifest",
        "benchmark_run_result",
        "benchmark_publication_pack",
        "public_proof_packet",
        "ai_evidence_packet",
        "ai_graduation_packet",
        "design_study_packet",
        "claim_manifest_row",
        "known_limit_note",
        "record_class_row",
        "retention_policy",
        "redaction_report",
        "approval_ticket"
      ]
    },
    "source_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "source_ref",
        "source_snapshot_ref",
        "location_class",
        "provenance_class",
        "source_steward_ref"
      ],
      "properties": {
        "source_class": { "$ref": "#/$defs/source_class" },
        "source_ref": { "$ref": "#/$defs/opaque_ref" },
        "source_snapshot_ref": { "$ref": "#/$defs/opaque_ref" },
        "location_class": { "$ref": "#/$defs/location_class" },
        "provenance_class": { "$ref": "#/$defs/provenance_class" },
        "source_steward_ref": { "$ref": "#/$defs/opaque_ref" },
        "query_or_schema_summary_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "version_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_label",
        "snapshot_ref",
        "schema_ref",
        "transform_ref",
        "refresh_date"
      ],
      "properties": {
        "snapshot_label": { "$ref": "#/$defs/safe_label" },
        "snapshot_ref": { "$ref": "#/$defs/opaque_ref" },
        "schema_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "transform_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "refresh_date": { "$ref": "#/$defs/local_date" }
      }
    },
    "slice_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_class",
        "row_count_estimate",
        "file_count_estimate",
        "byte_size_class",
        "partition_refs",
        "sampling_method_ref",
        "truncation_state",
        "slice_size_notes"
      ],
      "properties": {
        "scope_class": { "$ref": "#/$defs/scope_class" },
        "row_count_estimate": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 0 }
          ]
        },
        "file_count_estimate": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 0 }
          ]
        },
        "byte_size_class": { "$ref": "#/$defs/size_class" },
        "partition_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "sampling_method_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "truncation_state": { "$ref": "#/$defs/truncation_state" },
        "slice_size_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_sentence" }
        }
      }
    },
    "sensitivity_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sensitivity_class",
        "redaction_class",
        "retention_class_ref",
        "export_posture",
        "redaction_report_ref"
      ],
      "properties": {
        "sensitivity_class": { "$ref": "#/$defs/sensitivity_class" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "retention_class_ref": { "$ref": "#/$defs/opaque_ref" },
        "export_posture": { "$ref": "#/$defs/export_posture" },
        "redaction_report_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "license_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "license_class",
        "license_review_state",
        "license_review_ref",
        "allowed_use_class",
        "redistribution_posture"
      ],
      "properties": {
        "license_class": { "$ref": "#/$defs/license_class" },
        "license_review_state": { "$ref": "#/$defs/license_review_state" },
        "license_review_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "allowed_use_class": { "$ref": "#/$defs/allowed_use_class" },
        "redistribution_posture": { "$ref": "#/$defs/redistribution_posture" }
      }
    },
    "refresh_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "refresh_cadence",
        "freshness_state",
        "last_refreshed_on",
        "next_review_due_on"
      ],
      "properties": {
        "refresh_cadence": { "$ref": "#/$defs/refresh_cadence" },
        "freshness_state": { "$ref": "#/$defs/freshness_state" },
        "last_refreshed_on": { "$ref": "#/$defs/local_date" },
        "next_review_due_on": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/local_date" }
          ]
        }
      }
    },
    "exclusion_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exclusion_class",
        "exclusion_ref",
        "summary"
      ],
      "properties": {
        "exclusion_class": { "$ref": "#/$defs/exclusion_class" },
        "exclusion_ref": { "$ref": "#/$defs/opaque_ref" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "comparability_note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "axis",
        "effect",
        "note_ref",
        "summary"
      ],
      "properties": {
        "axis": { "$ref": "#/$defs/comparability_axis" },
        "effect": { "$ref": "#/$defs/comparability_effect" },
        "note_ref": { "$ref": "#/$defs/opaque_ref" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "linkage_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "link_kind",
        "link_ref"
      ],
      "properties": {
        "link_kind": { "$ref": "#/$defs/link_kind" },
        "link_ref": { "$ref": "#/$defs/opaque_ref" },
        "required_for_publication": { "type": "boolean" }
      }
    },
    "dataset_summary_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_summary_schema_version",
        "record_kind",
        "dataset_summary_id",
        "dataset_label",
        "summary_title",
        "source_profile",
        "version_snapshot",
        "slice_profile",
        "sensitivity_profile",
        "license_posture",
        "refresh_policy",
        "exclusions",
        "comparability_notes",
        "linkage",
        "created_at"
      ],
      "properties": {
        "dataset_summary_schema_version": { "$ref": "#/$defs/dataset_summary_schema_version" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "dataset_summary_id": { "$ref": "#/$defs/opaque_ref" },
        "dataset_label": { "$ref": "#/$defs/safe_label" },
        "summary_title": { "$ref": "#/$defs/safe_label" },
        "source_profile": { "$ref": "#/$defs/source_profile" },
        "version_snapshot": { "$ref": "#/$defs/version_snapshot" },
        "slice_profile": { "$ref": "#/$defs/slice_profile" },
        "sensitivity_profile": { "$ref": "#/$defs/sensitivity_profile" },
        "license_posture": { "$ref": "#/$defs/license_posture" },
        "refresh_policy": { "$ref": "#/$defs/refresh_policy" },
        "exclusions": {
          "type": "array",
          "items": { "$ref": "#/$defs/exclusion_entry" }
        },
        "comparability_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/comparability_note" }
        },
        "linkage": {
          "type": "array",
          "items": { "$ref": "#/$defs/linkage_entry" }
        },
        "notes_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "created_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "expires_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/monotonic_timestamp" }
          ]
        }
      }
    }
  }
}
