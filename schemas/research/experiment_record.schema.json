{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/research/experiment_record.schema.json",
  "title": "Aureline experiment provenance record",
  "description": "Boundary schema for one governed experiment record. The record binds benchmark, design-study, AI-evaluation, notebook, performance, and public-proof evidence to hypothesis, owner, source refs, corpus or dataset refs, hardware/profile, environment fingerprint, build refs, parameter set, seed, approval refs, waiver refs, outcome, reproducibility label, publication posture, and downstream governance links. Raw notebooks, raw prompts, raw datasets, raw screenshots, raw logs, raw repository paths, raw URLs, private participant identifiers, and credential material never cross this boundary.",
  "$ref": "#/$defs/experiment_record",
  "$defs": {
    "experiment_record_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for experiment provenance records. Additive optional fields do not bump this value; breaking payload changes do."
    },
    "record_kind": {
      "type": "string",
      "const": "experiment_record"
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable ref safe for manifests, support bundles, release evidence, and public-proof packets. No raw URLs, raw file paths outside the repo, raw dataset labels, raw prompts, raw logs, raw screenshots, credentials, or private identifiers appear here."
    },
    "nullable_opaque_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_ref" }
      ]
    },
    "safe_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "description": "Short metadata-safe label. It may be shown in review, support, or publication surfaces and must not contain private source names, raw paths, raw URLs, raw prompts, or raw data values."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "local_date": {
      "type": "string",
      "format": "date"
    },
    "experiment_family": {
      "type": "string",
      "enum": [
        "benchmark_run",
        "performance_experiment",
        "ai_evaluation",
        "red_team_evaluation",
        "design_research",
        "usability_study",
        "data_science_experiment",
        "migration_or_compatibility_study",
        "supportability_drill",
        "release_publication_rehearsal"
      ]
    },
    "execution_origin_class": {
      "type": "string",
      "enum": [
        "local_workspace",
        "managed_workspace",
        "ci_runner",
        "benchmark_lab",
        "design_study_lab",
        "imported_record",
        "manual_attachment",
        "partner_environment"
      ]
    },
    "outcome_class": {
      "type": "string",
      "enum": [
        "success",
        "partial_success",
        "failed",
        "inconclusive",
        "superseded",
        "quarantined"
      ]
    },
    "reproducibility_label": {
      "type": "string",
      "enum": [
        "reproducible",
        "likely_reproducible",
        "needs_rerun",
        "context_incomplete",
        "not_reproducible",
        "lineage_missing"
      ]
    },
    "publication_posture": {
      "type": "string",
      "enum": [
        "internal_only",
        "summary_first",
        "metadata_only_public",
        "public_proof_candidate",
        "publishable_public_proof",
        "quarantined_not_comparable",
        "withdrawn"
      ],
      "description": "Publication posture for this experiment. publishable_public_proof requires a downstream public-proof packet or benchmark-publication pack link."
    },
    "source_ref_kind": {
      "type": "string",
      "enum": [
        "benchmark_harness",
        "notebook",
        "script",
        "task_run",
        "test_run",
        "ai_eval_harness",
        "red_team_harness",
        "design_study_packet",
        "usability_session_packet",
        "public_proof_packet",
        "imported_report",
        "manual_attachment"
      ]
    },
    "data_role": {
      "type": "string",
      "enum": [
        "primary_measurement_data",
        "baseline_measurement_data",
        "candidate_measurement_data",
        "validation_data",
        "red_team_corpus",
        "design_research_input",
        "supportability_scenario",
        "publication_fixture",
        "context_only"
      ]
    },
    "host_hardware_class": {
      "type": "string",
      "enum": [
        "host_independent",
        "reference_desktop",
        "reference_laptop",
        "ci_runner",
        "managed_workspace_profile",
        "remote_target_profile",
        "partner_environment_profile",
        "self_capture_unverified",
        "unknown"
      ]
    },
    "build_mode_class": {
      "type": "string",
      "enum": [
        "debug",
        "release",
        "instrumented",
        "profiled",
        "benchmark",
        "preview",
        "stable",
        "unknown"
      ]
    },
    "governance_link_kind": {
      "type": "string",
      "enum": [
        "benchmark_run_result",
        "benchmark_publication_pack",
        "benchmark_corpus_manifest",
        "public_proof_packet",
        "ai_evidence_packet",
        "ai_graduation_packet",
        "design_study_packet",
        "usability_study_packet",
        "claim_manifest_row",
        "governance_packet",
        "approval_ticket",
        "waiver",
        "known_limit_note",
        "record_class_row",
        "support_export_packet",
        "result_comparison_record",
        "dataset_summary_record"
      ]
    },
    "owner_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_owner_ref",
        "evidence_owner_ref",
        "review_forum_ref"
      ],
      "properties": {
        "primary_owner_ref": { "$ref": "#/$defs/opaque_ref" },
        "evidence_owner_ref": { "$ref": "#/$defs/opaque_ref" },
        "review_forum_ref": { "$ref": "#/$defs/opaque_ref" },
        "backup_owner_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref_kind",
        "source_ref",
        "source_revision_ref",
        "source_summary"
      ],
      "properties": {
        "source_ref_kind": { "$ref": "#/$defs/source_ref_kind" },
        "source_ref": { "$ref": "#/$defs/opaque_ref" },
        "source_revision_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "source_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "dataset_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_summary_ref",
        "role",
        "slice_ref"
      ],
      "properties": {
        "dataset_summary_ref": { "$ref": "#/$defs/opaque_ref" },
        "role": { "$ref": "#/$defs/data_role" },
        "slice_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "required_for_reproduction": { "type": "boolean", "default": true }
      }
    },
    "corpus_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "corpus_ref",
        "corpus_manifest_ref",
        "corpus_manifest_revision",
        "role"
      ],
      "properties": {
        "corpus_ref": { "$ref": "#/$defs/opaque_ref" },
        "corpus_manifest_ref": { "$ref": "#/$defs/opaque_ref" },
        "corpus_manifest_revision": { "type": "integer", "minimum": 1 },
        "role": { "$ref": "#/$defs/data_role" }
      }
    },
    "data_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_refs",
        "corpus_refs",
        "data_scope_summary"
      ],
      "properties": {
        "dataset_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/dataset_binding" }
        },
        "corpus_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/corpus_binding" }
        },
        "data_scope_summary": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "anyOf": [
        { "required": ["dataset_refs"], "properties": { "dataset_refs": { "minItems": 1 } } },
        { "required": ["corpus_refs"], "properties": { "corpus_refs": { "minItems": 1 } } }
      ]
    },
    "hardware_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hardware_profile_ref",
        "hardware_class",
        "hardware_definition_ref",
        "power_posture_ref",
        "thermal_posture_ref"
      ],
      "properties": {
        "hardware_profile_ref": { "$ref": "#/$defs/opaque_ref" },
        "hardware_class": { "$ref": "#/$defs/host_hardware_class" },
        "hardware_definition_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "power_posture_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "thermal_posture_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "display_class_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "hardware_notes_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "environment_fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment_fingerprint_id",
        "execution_origin_class",
        "execution_context_ref",
        "runtime_ref",
        "toolchain_ref",
        "environment_digest_ref"
      ],
      "properties": {
        "environment_fingerprint_id": { "$ref": "#/$defs/opaque_ref" },
        "execution_origin_class": { "$ref": "#/$defs/execution_origin_class" },
        "execution_context_ref": { "$ref": "#/$defs/opaque_ref" },
        "runtime_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "toolchain_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "environment_digest_ref": { "$ref": "#/$defs/opaque_ref" },
        "container_or_remote_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "locale_or_region_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "build_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exact_build_identity_ref",
        "source_revision_ref",
        "build_mode"
      ],
      "properties": {
        "exact_build_identity_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "source_revision_ref": { "$ref": "#/$defs/opaque_ref" },
        "build_mode": { "$ref": "#/$defs/build_mode_class" },
        "build_artifact_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "benchmark_run_result_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "public_proof_packet_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "parameter_override": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameter_name",
        "value_class",
        "value_ref"
      ],
      "properties": {
        "parameter_name": { "$ref": "#/$defs/safe_label" },
        "value_class": {
          "type": "string",
          "enum": [
            "default",
            "numeric_bucket",
            "boolean",
            "enum_token",
            "digest_ref",
            "redacted_value",
            "not_applicable"
          ]
        },
        "value_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "presentation_label": { "$ref": "#/$defs/safe_label" }
      }
    },
    "seed_value": {
      "oneOf": [
        { "type": "null" },
        { "type": "integer", "minimum": 0 },
        { "$ref": "#/$defs/opaque_ref" }
      ],
      "description": "Deterministic seed when applicable. Null is explicit and means this experiment is intentionally unseeded or the family has no seed."
    },
    "parameter_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameter_set_id",
        "parameter_set_digest_ref",
        "seed",
        "parameter_overrides"
      ],
      "properties": {
        "parameter_set_id": { "$ref": "#/$defs/opaque_ref" },
        "parameter_set_digest_ref": { "$ref": "#/$defs/opaque_ref" },
        "seed": { "$ref": "#/$defs/seed_value" },
        "randomization_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "parameter_overrides": {
          "type": "array",
          "items": { "$ref": "#/$defs/parameter_override" }
        }
      }
    },
    "review_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_refs",
        "waiver_refs",
        "privacy_review_ref",
        "license_review_ref"
      ],
      "properties": {
        "approval_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "waiver_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "privacy_review_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "license_review_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "retention_review_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome_class",
        "result_summary_ref",
        "measured_at"
      ],
      "properties": {
        "outcome_class": { "$ref": "#/$defs/outcome_class" },
        "result_summary_ref": { "$ref": "#/$defs/opaque_ref" },
        "failure_or_quarantine_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "measured_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    },
    "governance_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "link_kind",
        "link_ref",
        "required_for_publication"
      ],
      "properties": {
        "link_kind": { "$ref": "#/$defs/governance_link_kind" },
        "link_ref": { "$ref": "#/$defs/opaque_ref" },
        "required_for_publication": { "type": "boolean" },
        "link_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "experiment_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "experiment_record_schema_version",
        "record_kind",
        "experiment_id",
        "title",
        "experiment_family",
        "hypothesis",
        "owner",
        "source_refs",
        "data_bindings",
        "hardware_profile",
        "environment_fingerprint",
        "build_refs",
        "parameter_set",
        "review_refs",
        "outcome",
        "reproducibility_label",
        "publication_posture",
        "governance_links",
        "created_at"
      ],
      "properties": {
        "experiment_record_schema_version": { "$ref": "#/$defs/experiment_record_schema_version" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "experiment_id": { "$ref": "#/$defs/opaque_ref" },
        "title": { "$ref": "#/$defs/safe_label" },
        "experiment_family": { "$ref": "#/$defs/experiment_family" },
        "hypothesis": { "$ref": "#/$defs/reviewable_sentence" },
        "owner": { "$ref": "#/$defs/owner_block" },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source_ref" }
        },
        "data_bindings": { "$ref": "#/$defs/data_bindings" },
        "hardware_profile": { "$ref": "#/$defs/hardware_profile" },
        "environment_fingerprint": { "$ref": "#/$defs/environment_fingerprint" },
        "build_refs": { "$ref": "#/$defs/build_refs" },
        "parameter_set": { "$ref": "#/$defs/parameter_set" },
        "review_refs": { "$ref": "#/$defs/review_refs" },
        "outcome": { "$ref": "#/$defs/outcome" },
        "reproducibility_label": { "$ref": "#/$defs/reproducibility_label" },
        "publication_posture": { "$ref": "#/$defs/publication_posture" },
        "governance_links": {
          "type": "array",
          "items": { "$ref": "#/$defs/governance_link" }
        },
        "notes_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "created_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "expires_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/monotonic_timestamp" }
          ]
        }
      },
      "allOf": [
        {
          "description": "Claim-bearing public-proof experiments cite a public-proof packet or benchmark-publication pack.",
          "if": {
            "properties": {
              "publication_posture": { "const": "publishable_public_proof" }
            },
            "required": ["publication_posture"]
          },
          "then": {
            "properties": {
              "governance_links": {
                "contains": {
                  "type": "object",
                  "properties": {
                    "link_kind": {
                      "enum": [
                        "public_proof_packet",
                        "benchmark_publication_pack"
                      ]
                    }
                  },
                  "required": ["link_kind"]
                }
              }
            }
          }
        }
      ]
    }
  }
}
