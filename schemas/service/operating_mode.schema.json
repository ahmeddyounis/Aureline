{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/service/operating_mode.schema.json",
  "title": "Aureline operating-mode card",
  "description": "Boundary schema for operating_mode_card_record, the user- and admin-visible card frozen in docs/service/operating_mode_and_capacity_contract.md. The card pins one operating_mode_class (local_only, shared_community_cloud, enterprise_saas, self_hosted, sovereign), the locality posture re-exported from docs/deployment/locality_and_continuity_seed.md, the per-service-family capacity row list (sync, registry or mirror metadata, collaboration relay, remote workspace control plane, AI gateway, telemetry or support ingest), an optional quota or throttle banner, an optional tenant or key detail summary, the service-continuity note, the retained-local-safe and blocked-managed-only capability lists, and the display-copy invariants that forbid whole-product-failure language. Capacity or key-state failures fail closed only for the managed action family that cannot be bounded safely. Raw URLs, raw hostnames, raw tenant names, raw account ids, raw key bytes, raw cloud-region identifiers, raw billing values, and raw secret material never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "card_id",
    "operating_mode_class",
    "title",
    "summary",
    "issued_at",
    "locality_posture",
    "service_family_capacity",
    "service_continuity_note",
    "freshness_posture",
    "display_copy",
    "narrative_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for this card record. Additive-minor changes bump this integer."
    },
    "record_kind": {
      "type": "string",
      "const": "operating_mode_card_record"
    },
    "card_id": {
      "$ref": "#/$defs/stable_token"
    },
    "operating_mode_class": {
      "$ref": "#/$defs/operating_mode_class"
    },
    "title": {
      "$ref": "#/$defs/reviewable_sentence"
    },
    "summary": {
      "$ref": "#/$defs/reviewable_sentence"
    },
    "issued_at": {
      "$ref": "#/$defs/utc_date_time",
      "description": "When the card was issued, RFC 3339 UTC."
    },
    "locality_posture": {
      "$ref": "#/$defs/locality_posture"
    },
    "service_family_capacity": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "description": "Capacity rows for the service families in scope for the card. Each family appears at most once; families that have no managed form in the active operating mode resolve through quota_owner = not_applicable rather than being omitted when the mode admits the family.",
      "items": {
        "$ref": "#/$defs/service_family_capacity_row"
      }
    },
    "quota_throttle_banner": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/quota_throttle_banner" }
      ],
      "description": "Optional banner. Required (non-null) when at least one service_family_capacity row resolves to at_warning_threshold, at_throttle_threshold, or quota_exhausted."
    },
    "tenant_key_detail_summary": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/tenant_key_detail_summary" }
      ],
      "description": "Short summary the card surfaces when a region_key_state_record is paired with the card. Full region or key truth lives on the paired region_key_state_record; this block is a convenience surface."
    },
    "service_continuity_note": {
      "$ref": "#/$defs/service_continuity_note"
    },
    "freshness_posture": {
      "$ref": "#/$defs/freshness_posture"
    },
    "display_copy": {
      "$ref": "#/$defs/display_copy"
    },
    "linked_region_key_state_refs": {
      "type": "array",
      "uniqueItems": true,
      "description": "Opaque refs to region_key_state_record entries paired with this card.",
      "items": {
        "$ref": "#/$defs/stable_token"
      }
    },
    "linked_continuity_packet_refs": {
      "type": "array",
      "uniqueItems": true,
      "description": "Opaque refs to local_core_continuity_packet_record entries the card surfaces against.",
      "items": {
        "$ref": "#/$defs/stable_token"
      }
    },
    "linked_slo_row_refs": {
      "type": "array",
      "uniqueItems": true,
      "description": "Repo-relative refs to artifacts/service/slo_rows.yaml rows the card resolves against.",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "narrative_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "description": "Repo-relative pointers into companion narrative contracts.",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "notes": {
      "$ref": "#/$defs/reviewable_sentence"
    },
    "__fixture__": {
      "type": "object",
      "description": "Optional fixture annotation block. Never part of the runtime record."
    }
  },
  "allOf": [
    {
      "description": "local_only mode pins on-device-only locality and forbids managed quota owners on every capacity row.",
      "if": {
        "properties": {
          "operating_mode_class": { "const": "local_only" }
        },
        "required": ["operating_mode_class"]
      },
      "then": {
        "properties": {
          "locality_posture": {
            "properties": {
              "processing_location": { "const": "on_device_only" },
              "storage_location": { "const": "device_local_disk" },
              "tenant_org_scope": { "const": "single_user_local" },
              "key_mode": { "const": "os_store" }
            },
            "required": ["processing_location", "storage_location", "tenant_org_scope", "key_mode"]
          },
          "service_family_capacity": {
            "items": {
              "properties": {
                "quota_owner": {
                  "enum": ["account_free_local", "byok_customer_operated", "not_applicable"]
                }
              }
            }
          }
        }
      }
    },
    {
      "description": "Managed and enterprise modes MUST carry an actionable region_scope and key_mode; not_applicable values are forbidden.",
      "if": {
        "properties": {
          "operating_mode_class": {
            "enum": ["shared_community_cloud", "enterprise_saas"]
          }
        },
        "required": ["operating_mode_class"]
      },
      "then": {
        "properties": {
          "locality_posture": {
            "properties": {
              "region_scope": { "not": { "const": "not_applicable" } },
              "key_mode": { "not": { "const": "not_applicable" } },
              "tenant_org_scope": { "not": { "const": "not_applicable" } }
            },
            "required": ["region_scope", "key_mode", "tenant_org_scope"]
          }
        }
      }
    },
    {
      "description": "self_hosted mode pins customer-operated processing and storage and forbids vendor-managed key mode.",
      "if": {
        "properties": {
          "operating_mode_class": { "const": "self_hosted" }
        },
        "required": ["operating_mode_class"]
      },
      "then": {
        "properties": {
          "locality_posture": {
            "properties": {
              "processing_location": { "const": "customer_control_plane" },
              "storage_location": { "const": "customer_control_plane_storage" },
              "tenant_org_scope": { "const": "customer_tenant" },
              "region_scope": { "const": "customer_region_pinned" },
              "key_mode": { "const": "customer_managed" }
            },
            "required": ["processing_location", "storage_location", "tenant_org_scope", "region_scope", "key_mode"]
          },
          "service_family_capacity": {
            "items": {
              "properties": {
                "quota_owner": {
                  "enum": ["self_hosted_customer_operated", "byok_customer_operated", "not_applicable"]
                }
              }
            }
          }
        }
      }
    },
    {
      "description": "sovereign mode pins customer-operated tenant, customer-region, and offline-trust-root or customer-managed keys.",
      "if": {
        "properties": {
          "operating_mode_class": { "const": "sovereign" }
        },
        "required": ["operating_mode_class"]
      },
      "then": {
        "properties": {
          "locality_posture": {
            "properties": {
              "processing_location": {
                "enum": ["customer_control_plane", "on_device_only"]
              },
              "storage_location": {
                "enum": ["customer_control_plane_storage", "mirror_or_offline_bundle"]
              },
              "tenant_org_scope": { "const": "customer_tenant" },
              "region_scope": { "const": "customer_region_pinned" },
              "key_mode": {
                "enum": ["offline_trust_root", "customer_managed"]
              }
            },
            "required": ["processing_location", "storage_location", "tenant_org_scope", "region_scope", "key_mode"]
          },
          "service_family_capacity": {
            "items": {
              "properties": {
                "quota_owner": {
                  "enum": ["sovereign_customer_operated", "byok_customer_operated", "not_applicable"]
                }
              }
            }
          }
        }
      }
    },
    {
      "description": "When any capacity row resolves to at_warning_threshold, at_throttle_threshold, or quota_exhausted the quota_throttle_banner MUST be present (non-null).",
      "if": {
        "properties": {
          "service_family_capacity": {
            "type": "array",
            "contains": {
              "properties": {
                "capacity_state": {
                  "enum": ["at_warning_threshold", "at_throttle_threshold", "quota_exhausted"]
                }
              },
              "required": ["capacity_state"]
            }
          }
        },
        "required": ["service_family_capacity"]
      },
      "then": {
        "properties": {
          "quota_throttle_banner": {
            "type": "object"
          }
        },
        "required": ["quota_throttle_banner"]
      }
    }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Short product-term sentence safe for product copy, support export, admin export, and release evidence. Raw URLs, raw hostnames, raw tenant names, raw account ids, raw key bytes, raw cloud-region identifiers, raw billing values, and raw secret material MUST NOT appear."
    },
    "reviewable_sentence_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/reviewable_sentence" }
    },
    "non_empty_reviewable_sentence_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/reviewable_sentence" }
    },
    "stable_token": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "description": "Snake_case stable token. Does not contain milestone slugs, raw user names, raw emails, or raw ticket numbers."
    },
    "utc_date_time": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 UTC timestamp."
    },
    "nullable_utc_date_time": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/utc_date_time" }
      ]
    },
    "operating_mode_class": {
      "type": "string",
      "enum": [
        "local_only",
        "shared_community_cloud",
        "enterprise_saas",
        "self_hosted",
        "sovereign"
      ],
      "description": "Closed operating-mode vocabulary. The mode pins what processing location, storage location, tenant scope, region scope, retention class, and key mode the user sees."
    },
    "processing_location_class": {
      "type": "string",
      "enum": [
        "on_device_only",
        "on_device_plus_remote_workspace",
        "customer_control_plane",
        "vendor_control_plane",
        "customer_or_vendor_control_plane",
        "not_applicable"
      ],
      "description": "Re-export of the locality seed's processing-location vocabulary."
    },
    "storage_location_class": {
      "type": "string",
      "enum": [
        "device_local_disk",
        "device_local_plus_workspace_repo",
        "customer_control_plane_storage",
        "vendor_control_plane_storage",
        "mirror_or_offline_bundle",
        "none",
        "not_applicable"
      ],
      "description": "Re-export of the locality seed's storage-location vocabulary."
    },
    "tenant_org_scope_class": {
      "type": "string",
      "enum": [
        "single_user_local",
        "customer_tenant",
        "shared_multi_tenant",
        "tenant_boundary_recheck_required",
        "not_applicable"
      ],
      "description": "Re-export of the locality seed's tenant-or-org scope vocabulary."
    },
    "region_scope_class": {
      "type": "string",
      "enum": [
        "customer_region_pinned",
        "remote_target_region",
        "boundary_recheck_required",
        "not_applicable"
      ],
      "description": "Re-export of the locality seed's region-scope vocabulary."
    },
    "retention_class": {
      "type": "string",
      "enum": [
        "no_retention_beyond_local_disk",
        "workspace_repo_retained",
        "customer_retention_window",
        "vendor_retention_window_with_customer_policy",
        "vendor_retention_window_default",
        "retention_not_applicable"
      ],
      "description": "Re-export of the locality seed's retention-class vocabulary."
    },
    "key_mode_class": {
      "type": "string",
      "enum": [
        "os_store",
        "vendor_managed",
        "customer_managed",
        "offline_trust_root",
        "not_applicable"
      ],
      "description": "Re-export of the locality seed's key-mode vocabulary."
    },
    "locality_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "processing_location",
        "storage_location",
        "tenant_org_scope",
        "region_scope",
        "retention_class",
        "key_mode"
      ],
      "properties": {
        "processing_location": { "$ref": "#/$defs/processing_location_class" },
        "storage_location": { "$ref": "#/$defs/storage_location_class" },
        "tenant_org_scope": { "$ref": "#/$defs/tenant_org_scope_class" },
        "region_scope": { "$ref": "#/$defs/region_scope_class" },
        "retention_class": { "$ref": "#/$defs/retention_class" },
        "key_mode": { "$ref": "#/$defs/key_mode_class" }
      }
    },
    "service_family_class": {
      "type": "string",
      "enum": [
        "sync_family",
        "registry_or_mirror_metadata_family",
        "collaboration_relay_family",
        "remote_workspace_control_plane_family",
        "ai_gateway_family",
        "telemetry_or_support_ingest_family"
      ],
      "description": "Closed service-family vocabulary. Each family aggregates one or more service ids from artifacts/service/slo_rows.yaml#service_id_vocabulary."
    },
    "service_id_class": {
      "type": "string",
      "enum": [
        "managed_settings_sync",
        "managed_marketplace",
        "managed_ai_broker",
        "managed_relay",
        "managed_auth_identity",
        "managed_policy_distribution",
        "managed_docs_pack",
        "managed_catalog",
        "managed_telemetry_sink",
        "managed_collaboration_review",
        "managed_support_export",
        "managed_entitlement_usage",
        "managed_offboarding_export"
      ],
      "description": "Re-export of the SLO row service-id vocabulary."
    },
    "capacity_state_class": {
      "type": "string",
      "enum": [
        "healthy",
        "at_warning_threshold",
        "at_throttle_threshold",
        "quota_exhausted",
        "region_mismatch_blocked",
        "tenant_isolation_blocked",
        "key_state_blocked",
        "boundary_recheck_required",
        "unknown_pending_recheck"
      ],
      "description": "Closed capacity-state vocabulary. healthy means the family is within budget and the linked SLO row is healthy or degraded_slow. quota_exhausted, region_mismatch_blocked, tenant_isolation_blocked, and key_state_blocked are non-default-quiet states that MUST pin a fail posture consistent with the affected action families' API-surface fallback posture."
    },
    "quota_owner_class": {
      "type": "string",
      "enum": [
        "account_free_local",
        "community_cloud_shared_pool",
        "enterprise_tenant",
        "self_hosted_customer_operated",
        "sovereign_customer_operated",
        "byok_customer_operated",
        "not_applicable"
      ],
      "description": "Closed quota-owner vocabulary. Names who owns the quota the family is measured against."
    },
    "fail_posture_class": {
      "type": "string",
      "enum": [
        "fail_closed_managed_only",
        "fail_open_local_safe",
        "fail_open_local_safe_with_label",
        "boundary_recheck_required",
        "not_applicable"
      ],
      "description": "Closed fail-posture vocabulary. Capacity or key-state failures fail closed only for the managed action that cannot be bounded safely; rows fail open only where the API-surface fallback posture admits local-safe operation."
    },
    "affected_action_family_class": {
      "type": "string",
      "enum": [
        "sync_action_family",
        "marketplace_publish_action_family",
        "marketplace_install_action_family",
        "collaboration_publish_action_family",
        "remote_attach_action_family",
        "remote_execute_action_family",
        "ai_inference_action_family",
        "ai_evidence_retention_action_family",
        "telemetry_export_action_family",
        "support_export_action_family",
        "offboarding_export_action_family",
        "policy_distribution_action_family",
        "identity_refresh_action_family"
      ],
      "description": "Closed affected-action-family vocabulary shared by the capacity row, the quota throttle banner, and the region or key state record."
    },
    "degradation_mode_class": {
      "type": "string",
      "enum": [
        "healthy",
        "degraded_slow",
        "degraded_stale_cache",
        "unavailable_retry_later",
        "unavailable_quota_exhausted",
        "unavailable_entitlement_expired",
        "unavailable_policy_blocked",
        "mirror_only",
        "boundary_recheck_required"
      ],
      "description": "Re-export of the SLO row degradation-mode vocabulary."
    },
    "service_family_capacity_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service_family_class",
        "linked_service_ids",
        "capacity_state",
        "quota_owner",
        "affected_action_families",
        "fail_posture"
      ],
      "properties": {
        "service_family_class": { "$ref": "#/$defs/service_family_class" },
        "linked_service_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/service_id_class" },
          "description": "Service ids this family resolves through. Every id MUST appear on a row in artifacts/service/slo_rows.yaml."
        },
        "capacity_state": { "$ref": "#/$defs/capacity_state_class" },
        "quota_owner": { "$ref": "#/$defs/quota_owner_class" },
        "measurement_time": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/utc_date_time" }
          ],
          "description": "When the capacity state was last measured. May be null only when capacity_state is unknown_pending_recheck or boundary_recheck_required."
        },
        "measurement_window_summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ],
          "description": "Short reviewable sentence naming the metering window without leaking raw billing values."
        },
        "affected_action_families": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/affected_action_family_class" },
          "description": "Action families that pause when this row is non-healthy. Empty list is valid only when capacity_state is healthy."
        },
        "fail_posture": { "$ref": "#/$defs/fail_posture_class" },
        "degradation_mode": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/degradation_mode_class" }
          ],
          "description": "SLO row degradation-mode value. Required (non-null) when capacity_state is non-healthy and the family has a managed form."
        },
        "recovery_cue": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ],
          "description": "Short product-term sentence naming the next user-visible step. Required (non-null) on every non-healthy row."
        },
        "linked_api_surface_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/non_empty_string" },
          "description": "Repo-relative refs to api_surface_rows.yaml rows the family resolves through."
        },
        "notes": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      },
      "allOf": [
        {
          "description": "Non-healthy rows MUST list at least one affected action family and a non-null recovery cue.",
          "if": {
            "properties": {
              "capacity_state": {
                "not": { "const": "healthy" }
              }
            },
            "required": ["capacity_state"]
          },
          "then": {
            "properties": {
              "affected_action_families": { "minItems": 1 },
              "recovery_cue": { "$ref": "#/$defs/reviewable_sentence" }
            },
            "required": ["recovery_cue"]
          }
        },
        {
          "description": "Quota-exhausted rows MUST fail closed for the managed action family.",
          "if": {
            "properties": {
              "capacity_state": { "const": "quota_exhausted" }
            },
            "required": ["capacity_state"]
          },
          "then": {
            "properties": {
              "fail_posture": {
                "enum": ["fail_closed_managed_only", "fail_open_local_safe", "fail_open_local_safe_with_label"]
              }
            }
          }
        },
        {
          "description": "Region or tenant blocked rows MUST route through the boundary recheck or fail-closed posture.",
          "if": {
            "properties": {
              "capacity_state": {
                "enum": ["region_mismatch_blocked", "tenant_isolation_blocked"]
              }
            },
            "required": ["capacity_state"]
          },
          "then": {
            "properties": {
              "fail_posture": {
                "enum": ["fail_closed_managed_only", "boundary_recheck_required"]
              }
            }
          }
        },
        {
          "description": "Boundary-recheck rows MUST set fail posture to boundary_recheck_required.",
          "if": {
            "properties": {
              "capacity_state": { "const": "boundary_recheck_required" }
            },
            "required": ["capacity_state"]
          },
          "then": {
            "properties": {
              "fail_posture": { "const": "boundary_recheck_required" }
            }
          }
        },
        {
          "description": "Unknown rows pause replay and forbid silent fail-open.",
          "if": {
            "properties": {
              "capacity_state": { "const": "unknown_pending_recheck" }
            },
            "required": ["capacity_state"]
          },
          "then": {
            "properties": {
              "fail_posture": {
                "enum": ["fail_closed_managed_only", "boundary_recheck_required"]
              }
            }
          }
        }
      ]
    },
    "quota_throttle_banner_state_class": {
      "type": "string",
      "enum": [
        "at_warning_threshold",
        "at_throttle_threshold",
        "quota_exhausted",
        "boundary_recheck_required",
        "unknown_pending_recheck"
      ]
    },
    "quota_throttle_banner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "banner_state",
        "quota_owner",
        "measurement_window_summary",
        "affected_action_families",
        "fail_posture",
        "recovery_cue"
      ],
      "properties": {
        "banner_state": { "$ref": "#/$defs/quota_throttle_banner_state_class" },
        "quota_owner": { "$ref": "#/$defs/quota_owner_class" },
        "measurement_time": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/utc_date_time" }
          ]
        },
        "measurement_window_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "affected_action_families": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/affected_action_family_class" }
        },
        "fail_posture": { "$ref": "#/$defs/fail_posture_class" },
        "recovery_cue": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "description": "Quota-exhausted banners MUST NOT use the not_applicable quota owner.",
          "if": {
            "properties": {
              "banner_state": { "const": "quota_exhausted" }
            },
            "required": ["banner_state"]
          },
          "then": {
            "properties": {
              "quota_owner": {
                "not": { "const": "not_applicable" }
              }
            }
          }
        }
      ]
    },
    "tenant_key_detail_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_summary",
        "key_state_summary"
      ],
      "properties": {
        "tenant_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "key_state_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "tenant_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ]
        },
        "key_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ]
        },
        "linked_region_key_state_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ]
        }
      }
    },
    "local_core_status_class": {
      "type": "string",
      "enum": [
        "local_core_unaffected",
        "meaningful_safe_subset_available",
        "local_only_available",
        "no_safe_local_subset",
        "unknown_requires_review"
      ]
    },
    "service_continuity_note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_core_status_class",
        "retained_local_safe_capabilities",
        "blocked_managed_only_capabilities"
      ],
      "properties": {
        "local_core_status_class": { "$ref": "#/$defs/local_core_status_class" },
        "retained_local_safe_capabilities": { "$ref": "#/$defs/non_empty_reviewable_sentence_array" },
        "blocked_managed_only_capabilities": { "$ref": "#/$defs/reviewable_sentence_array" },
        "linked_continuity_packet_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ]
        },
        "note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "fresh",
        "bounded_stale",
        "unbounded_stale"
      ]
    },
    "freshness_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["staleness_class"],
      "properties": {
        "staleness_class": { "$ref": "#/$defs/freshness_class" },
        "freshness_floor_summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        },
        "staleness_rationale": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        },
        "last_authoritative_fetch_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/utc_date_time" }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "staleness_class": { "const": "bounded_stale" }
            },
            "required": ["staleness_class"]
          },
          "then": {
            "properties": {
              "freshness_floor_summary": { "$ref": "#/$defs/reviewable_sentence" }
            },
            "required": ["freshness_floor_summary"]
          }
        },
        {
          "if": {
            "properties": {
              "staleness_class": { "const": "unbounded_stale" }
            },
            "required": ["staleness_class"]
          },
          "then": {
            "properties": {
              "staleness_rationale": { "$ref": "#/$defs/reviewable_sentence" }
            },
            "required": ["staleness_rationale"]
          }
        }
      ]
    },
    "display_copy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "whole_product_failure_implied",
        "generic_unavailable_copy_used",
        "silent_fail_open_under_unknown_state",
        "quota_owner_omitted"
      ],
      "properties": {
        "whole_product_failure_implied": { "type": "boolean", "const": false },
        "generic_unavailable_copy_used": { "type": "boolean", "const": false },
        "silent_fail_open_under_unknown_state": { "type": "boolean", "const": false },
        "quota_owner_omitted": { "type": "boolean", "const": false },
        "stale_label": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ],
          "description": "Stale label rendered when freshness_posture.staleness_class is non-fresh."
        }
      }
    }
  }
}
