{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/service/region_key_state.schema.json",
  "title": "Aureline region or residency strip and tenant or key detail card",
  "description": "Boundary schema for region_key_state_record, the user- and admin-visible record frozen in docs/service/operating_mode_and_capacity_contract.md. The record carries the region or residency strip, the tenant or key detail card, the closed key_state_class vocabulary, the boundary_recheck_required flag, and the affected action family list bounded by the new state. Managed and enterprise modes MUST pin a non-not_applicable region scope, tenant scope, and key mode. A key_state_class other than bound_and_current or not_applicable MUST list at least one affected action family and MUST list only the minimum set of action families that cannot be bounded safely under the new key state. Raw cloud-region identifiers, raw tenant names, raw key bytes, raw certificate bodies, raw secret material, and raw URLs never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "record_id",
    "operating_mode_class",
    "title",
    "summary",
    "issued_at",
    "region_residency_strip",
    "tenant_detail",
    "key_state",
    "boundary_recheck_required",
    "display_copy",
    "narrative_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for this record. Additive-minor changes bump this integer."
    },
    "record_kind": {
      "type": "string",
      "const": "region_key_state_record"
    },
    "record_id": {
      "$ref": "#/$defs/stable_token"
    },
    "operating_mode_class": {
      "$ref": "#/$defs/operating_mode_class",
      "description": "Operating mode the strip and detail card are bound to. MUST agree with the operating_mode_class on the paired operating_mode_card_record."
    },
    "title": {
      "$ref": "#/$defs/reviewable_sentence"
    },
    "summary": {
      "$ref": "#/$defs/reviewable_sentence"
    },
    "issued_at": {
      "$ref": "#/$defs/utc_date_time"
    },
    "region_residency_strip": {
      "$ref": "#/$defs/region_residency_strip"
    },
    "tenant_detail": {
      "$ref": "#/$defs/tenant_detail"
    },
    "key_state": {
      "$ref": "#/$defs/key_state"
    },
    "boundary_recheck_required": {
      "type": "boolean",
      "description": "True whenever region_scope is boundary_recheck_required, residency_scope_class is boundary_recheck_required, tenant_org_scope is tenant_boundary_recheck_required, or key_state_class is one of *_recheck_required / customer_managed_unreachable. Surfaces MUST NOT resume managed routes while this is true."
    },
    "linked_recheck_refs": {
      "type": "array",
      "uniqueItems": true,
      "description": "Opaque refs to recheck packets, route reviews, boundary manifests, or migration events governing the recheck.",
      "items": { "$ref": "#/$defs/stable_token" }
    },
    "linked_operating_mode_card_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/stable_token" }
      ],
      "description": "Opaque ref to the paired operating_mode_card_record."
    },
    "linked_continuity_packet_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/stable_token" }
    },
    "display_copy": {
      "$ref": "#/$defs/display_copy"
    },
    "narrative_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "notes": {
      "$ref": "#/$defs/reviewable_sentence"
    },
    "__fixture__": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "description": "Managed and enterprise modes MUST carry an actionable region, tenant, and key posture; not_applicable values are forbidden.",
      "if": {
        "properties": {
          "operating_mode_class": {
            "enum": ["shared_community_cloud", "enterprise_saas"]
          }
        },
        "required": ["operating_mode_class"]
      },
      "then": {
        "properties": {
          "region_residency_strip": {
            "properties": {
              "region_scope": { "not": { "const": "not_applicable" } }
            }
          },
          "tenant_detail": {
            "properties": {
              "tenant_org_scope": { "not": { "const": "not_applicable" } }
            }
          },
          "key_state": {
            "properties": {
              "key_mode": { "not": { "const": "not_applicable" } }
            }
          }
        }
      }
    },
    {
      "description": "self_hosted mode pins customer-region, customer-tenant, and customer-managed keys.",
      "if": {
        "properties": {
          "operating_mode_class": { "const": "self_hosted" }
        },
        "required": ["operating_mode_class"]
      },
      "then": {
        "properties": {
          "region_residency_strip": {
            "properties": {
              "region_scope": { "const": "customer_region_pinned" }
            }
          },
          "tenant_detail": {
            "properties": {
              "tenant_org_scope": { "const": "customer_tenant" }
            }
          },
          "key_state": {
            "properties": {
              "key_mode": { "const": "customer_managed" }
            }
          }
        }
      }
    },
    {
      "description": "sovereign mode pins customer-region, customer-tenant, and offline-trust-root or customer-managed keys.",
      "if": {
        "properties": {
          "operating_mode_class": { "const": "sovereign" }
        },
        "required": ["operating_mode_class"]
      },
      "then": {
        "properties": {
          "region_residency_strip": {
            "properties": {
              "region_scope": { "const": "customer_region_pinned" }
            }
          },
          "tenant_detail": {
            "properties": {
              "tenant_org_scope": { "const": "customer_tenant" }
            }
          },
          "key_state": {
            "properties": {
              "key_mode": {
                "enum": ["offline_trust_root", "customer_managed"]
              }
            }
          }
        }
      }
    },
    {
      "description": "Boundary-recheck-required region, residency, tenant, or key state MUST set boundary_recheck_required to true and list at least one linked recheck ref.",
      "if": {
        "anyOf": [
          {
            "properties": {
              "region_residency_strip": {
                "properties": {
                  "region_scope": { "const": "boundary_recheck_required" }
                },
                "required": ["region_scope"]
              }
            },
            "required": ["region_residency_strip"]
          },
          {
            "properties": {
              "region_residency_strip": {
                "properties": {
                  "residency_scope_class": { "const": "boundary_recheck_required" }
                },
                "required": ["residency_scope_class"]
              }
            },
            "required": ["region_residency_strip"]
          },
          {
            "properties": {
              "tenant_detail": {
                "properties": {
                  "tenant_org_scope": { "const": "tenant_boundary_recheck_required" }
                },
                "required": ["tenant_org_scope"]
              }
            },
            "required": ["tenant_detail"]
          },
          {
            "properties": {
              "key_state": {
                "properties": {
                  "key_state_class": {
                    "enum": [
                      "rotation_completed_recheck_required",
                      "revoked_recheck_required",
                      "mismatch_recheck_required",
                      "customer_managed_unreachable"
                    ]
                  }
                },
                "required": ["key_state_class"]
              }
            },
            "required": ["key_state"]
          }
        ]
      },
      "then": {
        "properties": {
          "boundary_recheck_required": { "const": true },
          "linked_recheck_refs": { "minItems": 1 }
        },
        "required": ["linked_recheck_refs"]
      }
    },
    {
      "description": "A key_state_class other than bound_and_current or not_applicable MUST list at least one affected action family.",
      "if": {
        "properties": {
          "key_state": {
            "properties": {
              "key_state_class": {
                "not": {
                  "enum": ["bound_and_current", "not_applicable"]
                }
              }
            },
            "required": ["key_state_class"]
          }
        },
        "required": ["key_state"]
      },
      "then": {
        "properties": {
          "key_state": {
            "properties": {
              "affected_action_families": { "minItems": 1 }
            },
            "required": ["affected_action_families"]
          }
        }
      }
    }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Short product-term sentence safe for product copy, support export, admin export, and release evidence. Raw URLs, raw hostnames, raw tenant names, raw account ids, raw key bytes, raw certificate bodies, raw cloud-region identifiers, and raw secret material MUST NOT appear."
    },
    "stable_token": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "utc_date_time": {
      "type": "string",
      "format": "date-time"
    },
    "operating_mode_class": {
      "type": "string",
      "enum": [
        "local_only",
        "shared_community_cloud",
        "enterprise_saas",
        "self_hosted",
        "sovereign"
      ]
    },
    "tenant_org_scope_class": {
      "type": "string",
      "enum": [
        "single_user_local",
        "customer_tenant",
        "shared_multi_tenant",
        "tenant_boundary_recheck_required",
        "not_applicable"
      ]
    },
    "region_scope_class": {
      "type": "string",
      "enum": [
        "customer_region_pinned",
        "remote_target_region",
        "boundary_recheck_required",
        "not_applicable"
      ]
    },
    "residency_scope_class": {
      "type": "string",
      "enum": [
        "customer_region_pinned",
        "regulated_jurisdiction",
        "cross_region_audited_egress",
        "boundary_recheck_required",
        "not_applicable"
      ],
      "description": "Closed residency-scope vocabulary. regulated_jurisdiction names a sovereign or regulated boundary; cross_region_audited_egress names a posture where egress crosses regions under an audited route."
    },
    "key_mode_class": {
      "type": "string",
      "enum": [
        "os_store",
        "vendor_managed",
        "customer_managed",
        "offline_trust_root",
        "not_applicable"
      ]
    },
    "key_state_class": {
      "type": "string",
      "enum": [
        "bound_and_current",
        "bound_pending_rotation",
        "rotation_in_progress",
        "rotation_completed_recheck_required",
        "revoked_recheck_required",
        "mismatch_recheck_required",
        "customer_managed_unreachable",
        "not_applicable"
      ],
      "description": "Closed key-state vocabulary. bound_and_current is the default-quiet state; every other value MUST list the minimum set of action families bounded by the new state."
    },
    "affected_action_family_class": {
      "type": "string",
      "enum": [
        "sync_action_family",
        "marketplace_publish_action_family",
        "marketplace_install_action_family",
        "collaboration_publish_action_family",
        "remote_attach_action_family",
        "remote_execute_action_family",
        "ai_inference_action_family",
        "ai_evidence_retention_action_family",
        "telemetry_export_action_family",
        "support_export_action_family",
        "offboarding_export_action_family",
        "policy_distribution_action_family",
        "identity_refresh_action_family"
      ]
    },
    "fail_posture_class": {
      "type": "string",
      "enum": [
        "fail_closed_managed_only",
        "fail_open_local_safe",
        "fail_open_local_safe_with_label",
        "boundary_recheck_required",
        "not_applicable"
      ]
    },
    "region_residency_strip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "region_scope",
        "residency_scope_class",
        "residency_summary"
      ],
      "properties": {
        "region_scope": { "$ref": "#/$defs/region_scope_class" },
        "region_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ],
          "description": "Opaque region ref. Raw cloud-region identifiers MUST NOT appear."
        },
        "residency_scope_class": { "$ref": "#/$defs/residency_scope_class" },
        "residency_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "tenant_detail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_org_scope",
        "tenant_summary"
      ],
      "properties": {
        "tenant_org_scope": { "$ref": "#/$defs/tenant_org_scope_class" },
        "tenant_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ],
          "description": "Opaque tenant ref. Raw tenant names MUST NOT appear."
        },
        "tenant_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "key_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key_mode",
        "key_state_class",
        "key_state_summary"
      ],
      "properties": {
        "key_mode": { "$ref": "#/$defs/key_mode_class" },
        "key_state_class": { "$ref": "#/$defs/key_state_class" },
        "key_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ],
          "description": "Opaque key ref. Raw key bytes, raw fingerprints, and raw certificate bodies MUST NOT appear; opaque fingerprints in the locality continuity packet's opaque_fingerprint form are acceptable."
        },
        "key_state_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "rotation_planned_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/utc_date_time" }
          ]
        },
        "rotation_completed_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/utc_date_time" }
          ]
        },
        "affected_action_families": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/affected_action_family_class" },
          "description": "Minimum set of action families bounded by the new key state. Empty list is valid only when key_state_class is bound_and_current or not_applicable."
        },
        "fail_posture": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/fail_posture_class" }
          ],
          "description": "Fail posture for the affected action families. Required (non-null) when key_state_class is not bound_and_current or not_applicable."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "key_state_class": {
                "not": {
                  "enum": ["bound_and_current", "not_applicable"]
                }
              }
            },
            "required": ["key_state_class"]
          },
          "then": {
            "properties": {
              "fail_posture": { "$ref": "#/$defs/fail_posture_class" }
            },
            "required": ["fail_posture"]
          }
        },
        {
          "description": "revoked_recheck_required, mismatch_recheck_required, and customer_managed_unreachable MUST fail closed or pause for boundary recheck.",
          "if": {
            "properties": {
              "key_state_class": {
                "enum": [
                  "revoked_recheck_required",
                  "mismatch_recheck_required",
                  "customer_managed_unreachable"
                ]
              }
            },
            "required": ["key_state_class"]
          },
          "then": {
            "properties": {
              "fail_posture": {
                "enum": ["fail_closed_managed_only", "boundary_recheck_required"]
              }
            }
          }
        }
      ]
    },
    "display_copy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "whole_product_failure_implied",
        "all_managed_blocked_overclaimed",
        "silent_fail_open_under_unknown_state"
      ],
      "properties": {
        "whole_product_failure_implied": {
          "type": "boolean",
          "const": false
        },
        "all_managed_blocked_overclaimed": {
          "type": "boolean",
          "const": false,
          "description": "False when the record lists only the minimum action families bounded by the new state. Reviewers MUST reject records that list every action family without a per-family rationale."
        },
        "silent_fail_open_under_unknown_state": {
          "type": "boolean",
          "const": false
        },
        "stale_label": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      }
    }
  }
}
