{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/service/meter_row.schema.json",
  "title": "Aureline commercial-control-plane meter row",
  "description": "Boundary schema for meter_row_record, the family-level service-economics row frozen in docs/service/metering_and_chargeback_contract.md. The row pins one meter_family_class (profile_or_settings_sync_meter_family, collaboration_relay_meter_family, remote_workspace_control_plane_meter_family, ai_gateway_meter_family, registry_or_mirror_meter_family, support_ingest_meter_family), the linked service family class re-exported from docs/service/operating_mode_and_capacity_contract.md, the closed meter unit and aggregation window vocabularies re-exported from docs/managed/metering_and_usage_export_contract.md, the owner scope, the closed measurement authority and meter freshness classes, the closed quota_owner_class, the entitlement summary, the usage and forecast view (with forecast confidence class), the chargeback scope switcher (which never collapses personal, workspace, and org scopes into one total), an optional grace-period or offboarding card, the export-parity posture, the fail posture, the closed prompt-ordering rules that preserve export, support, delete, and local-continuation prompts ahead of upgrade or billing pressure prompts, and the display-copy invariants. Capacity or meter-state failures fail closed only for the managed action family that cannot be bounded safely. Raw URLs, raw hostnames, raw tenant names, raw account ids, raw billing account ids, raw invoice numbers, raw price-list values, raw key bytes, raw cloud-region identifiers, and raw secret material never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "meter_row_id",
    "operating_mode_class",
    "meter_family_class",
    "linked_service_family_class",
    "linked_service_ids",
    "meter_unit_class",
    "aggregation_window_class",
    "owner_scope",
    "title",
    "summary",
    "issued_at",
    "as_of_time",
    "measurement_authority_class",
    "meter_freshness_class",
    "quota_owner_class",
    "entitlement_summary",
    "usage_and_forecast",
    "chargeback_scope_switcher",
    "export_parity",
    "fail_posture",
    "prompt_ordering",
    "local_continuation",
    "freshness_posture",
    "display_copy",
    "narrative_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for this row record. Additive-minor changes bump this integer."
    },
    "record_kind": {
      "type": "string",
      "const": "meter_row_record"
    },
    "meter_row_id": {
      "$ref": "#/$defs/stable_token"
    },
    "operating_mode_class": {
      "$ref": "#/$defs/operating_mode_class"
    },
    "meter_family_class": {
      "$ref": "#/$defs/meter_family_class"
    },
    "linked_service_family_class": {
      "$ref": "#/$defs/service_family_class"
    },
    "linked_service_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/service_id_class" },
      "description": "Service ids the meter row resolves through. Every id MUST appear on a row in artifacts/service/slo_rows.yaml."
    },
    "meter_unit_class": {
      "$ref": "#/$defs/meter_unit_class"
    },
    "aggregation_window_class": {
      "$ref": "#/$defs/aggregation_window_class"
    },
    "owner_scope": {
      "$ref": "#/$defs/owner_scope_block"
    },
    "title": {
      "$ref": "#/$defs/reviewable_sentence"
    },
    "summary": {
      "$ref": "#/$defs/reviewable_sentence"
    },
    "issued_at": {
      "$ref": "#/$defs/utc_date_time",
      "description": "When the meter row was issued, RFC 3339 UTC."
    },
    "as_of_time": {
      "$ref": "#/$defs/utc_date_time",
      "description": "When the row's usage, forecast, entitlement, and chargeback view were measured. RFC 3339 UTC."
    },
    "measurement_authority_class": {
      "$ref": "#/$defs/measurement_authority_class"
    },
    "meter_freshness_class": {
      "$ref": "#/$defs/meter_freshness_class"
    },
    "quota_owner_class": {
      "$ref": "#/$defs/quota_owner_class"
    },
    "linked_quota_state_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/stable_token" },
      "description": "Opaque refs to per-quota explainability objects (quota_state_record) frozen in schemas/managed/quota_state.schema.json."
    },
    "linked_usage_export_row_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/stable_token" },
      "description": "Opaque refs to bounded export rows (usage_export_row_record) frozen in schemas/managed/usage_export_row.schema.json."
    },
    "entitlement_summary": {
      "$ref": "#/$defs/entitlement_summary_block"
    },
    "usage_and_forecast": {
      "$ref": "#/$defs/usage_and_forecast_block"
    },
    "chargeback_scope_switcher": {
      "$ref": "#/$defs/chargeback_scope_switcher_block"
    },
    "grace_or_offboarding_card": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/grace_or_offboarding_card_block" }
      ],
      "description": "Optional card. Required (non-null) when entitlement_summary.entitlement_state_class is entitlement_in_grace, entitlement_expired, or entitlement_suspended_admin, or when offboarding_phase_class is non-not_offboarding."
    },
    "export_parity": {
      "$ref": "#/$defs/export_parity_block"
    },
    "fail_posture": {
      "$ref": "#/$defs/fail_posture_class"
    },
    "prompt_ordering": {
      "$ref": "#/$defs/prompt_ordering_block"
    },
    "local_continuation": {
      "$ref": "#/$defs/non_empty_reviewable_sentence_array",
      "description": "Short reviewable sentences naming what continues to work without the managed meter. Mirrors operating_mode_card_record.service_continuity_note.retained_local_safe_capabilities."
    },
    "blocked_managed_only_actions": {
      "$ref": "#/$defs/reviewable_sentence_array",
      "description": "Short reviewable sentences naming the managed-only paths paused by the active meter posture."
    },
    "freshness_posture": {
      "$ref": "#/$defs/freshness_posture"
    },
    "display_copy": {
      "$ref": "#/$defs/display_copy"
    },
    "linked_operating_mode_card_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/stable_token" },
      "description": "Opaque refs to operating_mode_card_record entries the row composes against."
    },
    "linked_region_key_state_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/stable_token" }
    },
    "linked_slo_row_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "description": "Repo-relative refs to artifacts/service/slo_rows.yaml rows the row resolves against."
    },
    "linked_api_surface_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "description": "Repo-relative refs to artifacts/service/api_surface_rows.yaml rows the row's fail posture is admissible against."
    },
    "narrative_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "notes": {
      "$ref": "#/$defs/reviewable_sentence"
    },
    "__fixture__": {
      "type": "object",
      "description": "Optional fixture annotation block. Never part of the runtime record."
    }
  },
  "allOf": [
    {
      "description": "local_only mode forbids managed quota owners on every meter row.",
      "if": {
        "properties": {
          "operating_mode_class": { "const": "local_only" }
        },
        "required": ["operating_mode_class"]
      },
      "then": {
        "properties": {
          "quota_owner_class": {
            "enum": ["account_free_local", "byok_customer_operated", "not_applicable"]
          }
        }
      }
    },
    {
      "description": "self_hosted mode forbids vendor-operated quota owners on every meter row.",
      "if": {
        "properties": {
          "operating_mode_class": { "const": "self_hosted" }
        },
        "required": ["operating_mode_class"]
      },
      "then": {
        "properties": {
          "quota_owner_class": {
            "enum": ["self_hosted_customer_operated", "byok_customer_operated", "not_applicable"]
          }
        }
      }
    },
    {
      "description": "sovereign mode forbids vendor-operated quota owners on every meter row.",
      "if": {
        "properties": {
          "operating_mode_class": { "const": "sovereign" }
        },
        "required": ["operating_mode_class"]
      },
      "then": {
        "properties": {
          "quota_owner_class": {
            "enum": ["sovereign_customer_operated", "byok_customer_operated", "not_applicable"]
          }
        }
      }
    },
    {
      "description": "Authoritative meter freshness MUST come with authoritative measurement authority and the fresh meter freshness class.",
      "if": {
        "properties": {
          "measurement_authority_class": { "const": "authoritative" }
        },
        "required": ["measurement_authority_class"]
      },
      "then": {
        "properties": {
          "meter_freshness_class": { "const": "fresh" }
        }
      }
    },
    {
      "description": "Cached measurement authority MUST come with one of the cached meter freshness classes.",
      "if": {
        "properties": {
          "measurement_authority_class": { "const": "cached" }
        },
        "required": ["measurement_authority_class"]
      },
      "then": {
        "properties": {
          "meter_freshness_class": {
            "enum": ["cached_within_freshness_floor", "cached_beyond_freshness_floor"]
          }
        }
      }
    },
    {
      "description": "Estimated authority MUST come with estimate_pending_reconciliation freshness.",
      "if": {
        "properties": {
          "measurement_authority_class": { "const": "estimated" }
        },
        "required": ["measurement_authority_class"]
      },
      "then": {
        "properties": {
          "meter_freshness_class": { "const": "estimate_pending_reconciliation" }
        }
      }
    },
    {
      "description": "Unavailable authority MUST come with unavailable_meter freshness.",
      "if": {
        "properties": {
          "measurement_authority_class": { "const": "unavailable" }
        },
        "required": ["measurement_authority_class"]
      },
      "then": {
        "properties": {
          "meter_freshness_class": { "const": "unavailable_meter" }
        }
      }
    },
    {
      "description": "Policy-suppressed authority MUST come with policy_suppressed_meter freshness.",
      "if": {
        "properties": {
          "measurement_authority_class": { "const": "policy_suppressed" }
        },
        "required": ["measurement_authority_class"]
      },
      "then": {
        "properties": {
          "meter_freshness_class": { "const": "policy_suppressed_meter" }
        }
      }
    },
    {
      "description": "A non-active entitlement state MUST present the grace-or-offboarding card.",
      "if": {
        "properties": {
          "entitlement_summary": {
            "properties": {
              "entitlement_state_class": {
                "enum": [
                  "entitlement_in_grace",
                  "entitlement_expired",
                  "entitlement_suspended_admin"
                ]
              }
            },
            "required": ["entitlement_state_class"]
          }
        },
        "required": ["entitlement_summary"]
      },
      "then": {
        "properties": {
          "grace_or_offboarding_card": {
            "type": "object"
          }
        },
        "required": ["grace_or_offboarding_card"]
      }
    },
    {
      "description": "Expired or suspended entitlement MUST fail closed for the managed action.",
      "if": {
        "properties": {
          "entitlement_summary": {
            "properties": {
              "entitlement_state_class": {
                "enum": ["entitlement_expired", "entitlement_suspended_admin"]
              }
            },
            "required": ["entitlement_state_class"]
          }
        },
        "required": ["entitlement_summary"]
      },
      "then": {
        "properties": {
          "fail_posture": {
            "enum": ["fail_closed_managed_only", "boundary_recheck_required"]
          }
        }
      }
    },
    {
      "description": "Forecast values MUST NOT render under unauthoritative confidence.",
      "if": {
        "properties": {
          "usage_and_forecast": {
            "properties": {
              "forecast": {
                "properties": {
                  "forecast_confidence_class": {
                    "enum": [
                      "forecast_unavailable",
                      "forecast_policy_suppressed",
                      "forecast_not_applicable"
                    ]
                  }
                },
                "required": ["forecast_confidence_class"]
              }
            },
            "required": ["forecast"]
          }
        },
        "required": ["usage_and_forecast"]
      },
      "then": {
        "properties": {
          "usage_and_forecast": {
            "properties": {
              "forecast": {
                "properties": {
                  "forecast_value": { "type": "null" }
                }
              }
            }
          }
        }
      }
    },
    {
      "description": "Offboarding phases that retain access MUST surface the offboarding-packet export prompt.",
      "if": {
        "properties": {
          "grace_or_offboarding_card": {
            "type": "object",
            "properties": {
              "offboarding_phase_class": {
                "enum": [
                  "grace_window",
                  "access_end_window",
                  "post_access_export_window"
                ]
              }
            },
            "required": ["offboarding_phase_class"]
          }
        },
        "required": ["grace_or_offboarding_card"]
      },
      "then": {
        "properties": {
          "prompt_ordering": {
            "properties": {
              "ordered_prompts": {
                "type": "array",
                "contains": {
                  "properties": {
                    "prompt_class": { "const": "export_offboarding_packet" }
                  },
                  "required": ["prompt_class"]
                }
              }
            },
            "required": ["ordered_prompts"]
          }
        }
      }
    },
    {
      "description": "Unavailable, cached_beyond_freshness_floor, and policy_suppressed meters require a non-empty recovery cue on the entitlement summary.",
      "if": {
        "properties": {
          "meter_freshness_class": {
            "enum": [
              "cached_beyond_freshness_floor",
              "unavailable_meter",
              "policy_suppressed_meter"
            ]
          }
        },
        "required": ["meter_freshness_class"]
      },
      "then": {
        "properties": {
          "entitlement_summary": {
            "properties": {
              "recovery_cue": {
                "$ref": "#/$defs/reviewable_sentence"
              }
            },
            "required": ["recovery_cue"]
          }
        }
      }
    }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Short product-term sentence safe for product copy, support export, admin export, and release evidence. Raw URLs, raw hostnames, raw tenant names, raw account ids, raw billing account ids, raw invoice numbers, raw price-list values, raw key bytes, raw cloud-region identifiers, and raw secret material MUST NOT appear."
    },
    "reviewable_sentence_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/reviewable_sentence" }
    },
    "non_empty_reviewable_sentence_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/reviewable_sentence" }
    },
    "stable_token": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "description": "Snake_case stable token. Does not contain milestone slugs, raw user names, raw emails, or raw ticket numbers."
    },
    "utc_date_time": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 UTC timestamp."
    },
    "nullable_utc_date_time": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/utc_date_time" }
      ]
    },
    "operating_mode_class": {
      "type": "string",
      "enum": [
        "local_only",
        "shared_community_cloud",
        "enterprise_saas",
        "self_hosted",
        "sovereign"
      ],
      "description": "Re-export of docs/service/operating_mode_and_capacity_contract.md operating-mode vocabulary."
    },
    "service_family_class": {
      "type": "string",
      "enum": [
        "sync_family",
        "registry_or_mirror_metadata_family",
        "collaboration_relay_family",
        "remote_workspace_control_plane_family",
        "ai_gateway_family",
        "telemetry_or_support_ingest_family"
      ],
      "description": "Re-export of docs/service/operating_mode_and_capacity_contract.md service-family vocabulary."
    },
    "service_id_class": {
      "type": "string",
      "enum": [
        "managed_settings_sync",
        "managed_marketplace",
        "managed_ai_broker",
        "managed_relay",
        "managed_auth_identity",
        "managed_policy_distribution",
        "managed_docs_pack",
        "managed_catalog",
        "managed_telemetry_sink",
        "managed_collaboration_review",
        "managed_support_export",
        "managed_entitlement_usage",
        "managed_offboarding_export"
      ],
      "description": "Re-export of artifacts/service/slo_rows.yaml#service_id_vocabulary."
    },
    "meter_family_class": {
      "type": "string",
      "enum": [
        "profile_or_settings_sync_meter_family",
        "collaboration_relay_meter_family",
        "remote_workspace_control_plane_meter_family",
        "ai_gateway_meter_family",
        "registry_or_mirror_meter_family",
        "support_ingest_meter_family"
      ],
      "description": "Closed meter-family vocabulary. A meter row carries exactly one family; multiple rows may resolve through the same service-family class when unit, window, owner scope, or export parity differ."
    },
    "meter_unit_class": {
      "type": "string",
      "enum": [
        "tokens",
        "tool_invocations",
        "validation_run_count",
        "workspace_hours",
        "bytes_stored",
        "bytes_transferred",
        "participant_minutes",
        "download_count",
        "support_bundle_count",
        "orchestration_ops",
        "spend_units",
        "request_count"
      ],
      "description": "Re-export of schemas/managed/quota_state.schema.json#quota_unit_class."
    },
    "aggregation_window_class": {
      "type": "string",
      "enum": [
        "calendar_month_utc",
        "rolling_24h",
        "rolling_7d",
        "rolling_30d",
        "contract_term",
        "manual_admin_reset",
        "no_reset_window",
        "unknown_unavailable",
        "policy_suppressed"
      ],
      "description": "Re-export of schemas/managed/quota_state.schema.json#reset_window_class."
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "tenant",
        "organization",
        "user",
        "workspace",
        "repository",
        "feature",
        "provider",
        "model",
        "action",
        "support_case",
        "offboarding_packet"
      ],
      "description": "Re-export of schemas/managed/quota_state.schema.json#scope_class."
    },
    "owner_scope_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_class", "scope_ref"],
      "properties": {
        "scope_class": { "$ref": "#/$defs/scope_class" },
        "scope_ref": { "$ref": "#/$defs/stable_token" },
        "parent_scope_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/stable_token" }
        },
        "scope_label": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "measurement_authority_class": {
      "type": "string",
      "enum": [
        "authoritative",
        "cached",
        "estimated",
        "unavailable",
        "policy_suppressed"
      ],
      "description": "Re-export of schemas/managed/quota_state.schema.json#authority_class."
    },
    "meter_freshness_class": {
      "type": "string",
      "enum": [
        "fresh",
        "cached_within_freshness_floor",
        "cached_beyond_freshness_floor",
        "estimate_pending_reconciliation",
        "unavailable_meter",
        "policy_suppressed_meter"
      ],
      "description": "Closed meter-freshness vocabulary. Maps to schemas/managed/quota_state.schema.json#stale_label_class with no_stale_label collapsed to fresh."
    },
    "quota_owner_class": {
      "type": "string",
      "enum": [
        "account_free_local",
        "community_cloud_shared_pool",
        "enterprise_tenant",
        "self_hosted_customer_operated",
        "sovereign_customer_operated",
        "byok_customer_operated",
        "not_applicable"
      ],
      "description": "Re-export of docs/service/operating_mode_and_capacity_contract.md quota-owner vocabulary."
    },
    "fail_posture_class": {
      "type": "string",
      "enum": [
        "fail_closed_managed_only",
        "fail_open_local_safe",
        "fail_open_local_safe_with_label",
        "boundary_recheck_required",
        "not_applicable"
      ],
      "description": "Re-export of docs/service/operating_mode_and_capacity_contract.md fail-posture vocabulary."
    },
    "affected_action_family_class": {
      "type": "string",
      "enum": [
        "sync_action_family",
        "marketplace_publish_action_family",
        "marketplace_install_action_family",
        "collaboration_publish_action_family",
        "remote_attach_action_family",
        "remote_execute_action_family",
        "ai_inference_action_family",
        "ai_evidence_retention_action_family",
        "telemetry_export_action_family",
        "support_export_action_family",
        "offboarding_export_action_family",
        "policy_distribution_action_family",
        "identity_refresh_action_family"
      ],
      "description": "Re-export of docs/service/operating_mode_and_capacity_contract.md affected-action-family vocabulary."
    },
    "spend_attribution_dimension_class": {
      "type": "string",
      "enum": [
        "tenant",
        "organization",
        "user",
        "workspace",
        "repository",
        "feature",
        "provider",
        "model",
        "action",
        "execution_locus",
        "region",
        "quota_family",
        "managed_service",
        "source_class"
      ],
      "description": "Re-export of schemas/managed/quota_state.schema.json#spend_attribution_dimension_class."
    },
    "precision_class": {
      "type": "string",
      "enum": [
        "exact",
        "rounded",
        "bucketed",
        "estimated",
        "redacted_policy",
        "unavailable",
        "not_applicable"
      ],
      "description": "Re-export of schemas/managed/quota_state.schema.json#precision_class."
    },
    "entitlement_state_class": {
      "type": "string",
      "enum": [
        "entitlement_active",
        "entitlement_in_grace",
        "entitlement_expired",
        "entitlement_suspended_admin",
        "entitlement_pending_recheck",
        "entitlement_not_applicable"
      ],
      "description": "Closed entitlement-state vocabulary. Surfaces a non-active state through the grace-or-offboarding card."
    },
    "entitlement_summary_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entitlement_state_class",
        "summary"
      ],
      "properties": {
        "entitlement_state_class": { "$ref": "#/$defs/entitlement_state_class" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "linked_managed_session_state_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ]
        },
        "linked_quota_state_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/stable_token" }
        },
        "entitlement_grace_until_at": {
          "$ref": "#/$defs/nullable_utc_date_time"
        },
        "policy_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ],
          "description": "Required (non-null) when entitlement_state_class is entitlement_suspended_admin or entitlement_pending_recheck."
        },
        "recovery_cue": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ],
          "description": "Short product-term sentence naming the next user-visible step. Required (non-null) when meter_freshness_class is non-fresh or entitlement_state_class is non-active."
        }
      }
    },
    "forecast_confidence_class": {
      "type": "string",
      "enum": [
        "forecast_authoritative",
        "forecast_best_effort_local",
        "forecast_unavailable",
        "forecast_policy_suppressed",
        "forecast_not_applicable"
      ],
      "description": "Closed forecast-confidence vocabulary. A numeric forecast_value MAY only render under forecast_authoritative or forecast_best_effort_local."
    },
    "forecast_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forecast_confidence_class"],
      "properties": {
        "forecast_confidence_class": { "$ref": "#/$defs/forecast_confidence_class" },
        "forecast_value": {
          "type": ["number", "null"],
          "description": "Optional numeric projection. MUST be null when forecast_confidence_class is forecast_unavailable, forecast_policy_suppressed, or forecast_not_applicable."
        },
        "forecast_horizon_summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        },
        "forecast_caveats": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/reviewable_sentence" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "forecast_confidence_class": {
                "enum": [
                  "forecast_unavailable",
                  "forecast_policy_suppressed",
                  "forecast_not_applicable"
                ]
              }
            },
            "required": ["forecast_confidence_class"]
          },
          "then": {
            "properties": {
              "forecast_value": { "type": "null" }
            }
          }
        }
      ]
    },
    "usage_and_forecast_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "usage_value",
        "usage_unit_class",
        "aggregation_window_class",
        "as_of_time",
        "precision_class",
        "forecast"
      ],
      "properties": {
        "usage_value": {
          "type": ["number", "null"]
        },
        "usage_limit_value": {
          "type": ["number", "null"]
        },
        "usage_remaining_value": {
          "type": ["number", "null"]
        },
        "usage_unit_class": { "$ref": "#/$defs/meter_unit_class" },
        "aggregation_window_class": { "$ref": "#/$defs/aggregation_window_class" },
        "current_window_start_at": { "$ref": "#/$defs/nullable_utc_date_time" },
        "current_window_end_at": { "$ref": "#/$defs/nullable_utc_date_time" },
        "next_reset_at": { "$ref": "#/$defs/nullable_utc_date_time" },
        "as_of_time": { "$ref": "#/$defs/utc_date_time" },
        "precision_class": { "$ref": "#/$defs/precision_class" },
        "forecast": { "$ref": "#/$defs/forecast_block" },
        "usage_summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      }
    },
    "chargeback_scope_class": {
      "type": "string",
      "enum": [
        "personal_scope",
        "workspace_scope",
        "organization_scope",
        "tenant_scope",
        "byok_external_scope",
        "mixed_requires_split",
        "not_applicable"
      ],
      "description": "Closed chargeback-scope vocabulary. Personal, workspace, and organization scopes do not collapse into one total."
    },
    "chargeback_scope_offer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chargeback_scope_class",
        "scope_ref",
        "offer_summary"
      ],
      "properties": {
        "chargeback_scope_class": { "$ref": "#/$defs/chargeback_scope_class" },
        "scope_ref": { "$ref": "#/$defs/stable_token" },
        "offer_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "linked_quota_state_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ]
        }
      }
    },
    "chargeback_scope_switcher_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_scope",
        "offered_scopes",
        "spend_attribution_dimensions"
      ],
      "properties": {
        "current_scope": { "$ref": "#/$defs/chargeback_scope_class" },
        "offered_scopes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/chargeback_scope_offer" }
        },
        "spend_attribution_dimensions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/spend_attribution_dimension_class" }
        },
        "split_recovery_cue": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ],
          "description": "Required (non-null) when current_scope is mixed_requires_split. Names how the user obtains the per-scope split."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "current_scope": { "const": "mixed_requires_split" }
            },
            "required": ["current_scope"]
          },
          "then": {
            "properties": {
              "split_recovery_cue": { "$ref": "#/$defs/reviewable_sentence" }
            },
            "required": ["split_recovery_cue"]
          }
        }
      ]
    },
    "offboarding_phase_class": {
      "type": "string",
      "enum": [
        "not_offboarding",
        "notice_period",
        "grace_window",
        "access_end_window",
        "post_access_export_window",
        "offboarding_complete"
      ],
      "description": "Closed offboarding-phase vocabulary."
    },
    "grace_or_offboarding_card_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "offboarding_phase_class",
        "summary",
        "retained_action_summary",
        "paused_action_summary"
      ],
      "properties": {
        "offboarding_phase_class": { "$ref": "#/$defs/offboarding_phase_class" },
        "phase_until_at": { "$ref": "#/$defs/nullable_utc_date_time" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "retained_action_summary": { "$ref": "#/$defs/non_empty_reviewable_sentence_array" },
        "paused_action_summary": { "$ref": "#/$defs/reviewable_sentence_array" },
        "affected_action_families": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/affected_action_family_class" }
        },
        "linked_offboarding_export_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ]
        },
        "linked_deletion_job_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ]
        }
      }
    },
    "export_parity_class": {
      "type": "string",
      "enum": [
        "parity_with_csv_and_json",
        "parity_with_json_only",
        "parity_with_csv_only",
        "manifest_only_no_row_export",
        "no_export_documented_local_only",
        "parity_pending_recheck",
        "parity_policy_suppressed"
      ],
      "description": "Closed export-parity vocabulary. Names the row's promise about the bounded export of the displayed usage summary."
    },
    "export_parity_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_parity_class",
        "summary"
      ],
      "properties": {
        "export_parity_class": { "$ref": "#/$defs/export_parity_class" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "csv_manifest_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ],
          "description": "Required (non-null) when export_parity_class is parity_with_csv_and_json or parity_with_csv_only."
        },
        "json_manifest_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ],
          "description": "Required (non-null) when export_parity_class is parity_with_csv_and_json or parity_with_json_only."
        },
        "policy_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ],
          "description": "Required (non-null) when export_parity_class is parity_policy_suppressed."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "export_parity_class": { "const": "parity_with_csv_and_json" }
            },
            "required": ["export_parity_class"]
          },
          "then": {
            "required": ["csv_manifest_ref", "json_manifest_ref"],
            "properties": {
              "csv_manifest_ref": { "$ref": "#/$defs/stable_token" },
              "json_manifest_ref": { "$ref": "#/$defs/stable_token" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "export_parity_class": { "const": "parity_with_csv_only" }
            },
            "required": ["export_parity_class"]
          },
          "then": {
            "required": ["csv_manifest_ref"],
            "properties": {
              "csv_manifest_ref": { "$ref": "#/$defs/stable_token" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "export_parity_class": { "const": "parity_with_json_only" }
            },
            "required": ["export_parity_class"]
          },
          "then": {
            "required": ["json_manifest_ref"],
            "properties": {
              "json_manifest_ref": { "$ref": "#/$defs/stable_token" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "export_parity_class": { "const": "parity_policy_suppressed" }
            },
            "required": ["export_parity_class"]
          },
          "then": {
            "required": ["policy_ref"],
            "properties": {
              "policy_ref": { "$ref": "#/$defs/stable_token" }
            }
          }
        }
      ]
    },
    "commercial_prompt_class": {
      "type": "string",
      "enum": [
        "continue_local_work",
        "export_usage_summary",
        "export_support_bundle",
        "export_offboarding_packet",
        "delete_data",
        "manage_entitlement",
        "request_admin_review",
        "increase_budget",
        "upgrade_plan",
        "add_payment_method"
      ],
      "description": "Closed commercial-prompt vocabulary, ordered by user-preserving priority. Items 1-5 (continue_local_work, export_usage_summary, export_support_bundle, export_offboarding_packet, delete_data) MUST precede items 8-10 (increase_budget, upgrade_plan, add_payment_method) when both apply."
    },
    "prompt_priority_index": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "1-based ordinal matching the contract's prompt-ordering rule. The schema enforces no_billing_prompt_before_user_preserving_prompt via display_copy invariants."
    },
    "prompt_ordering_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_class",
        "priority_index",
        "label"
      ],
      "properties": {
        "prompt_class": { "$ref": "#/$defs/commercial_prompt_class" },
        "priority_index": { "$ref": "#/$defs/prompt_priority_index" },
        "label": { "$ref": "#/$defs/reviewable_sentence" },
        "destination_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stable_token" }
          ]
        }
      }
    },
    "prompt_ordering_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordered_prompts",
        "preserves_user_options_first"
      ],
      "properties": {
        "ordered_prompts": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/prompt_ordering_entry" },
          "description": "Prompts the surface MAY render. The relative order of items MUST honour the priority_index ordering, and items 1-5 MUST precede items 8-10 when both are present."
        },
        "preserves_user_options_first": {
          "type": "boolean",
          "const": true,
          "description": "Reviewer-affirmed invariant that the prompt list does not lead with billing pressure when an export, support, delete, or local-continuation prompt also applies."
        },
        "rationale": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      }
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "fresh",
        "bounded_stale",
        "unbounded_stale"
      ]
    },
    "freshness_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["staleness_class"],
      "properties": {
        "staleness_class": { "$ref": "#/$defs/freshness_class" },
        "freshness_floor_summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        },
        "staleness_rationale": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        },
        "last_authoritative_fetch_at": { "$ref": "#/$defs/nullable_utc_date_time" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "staleness_class": { "const": "bounded_stale" }
            },
            "required": ["staleness_class"]
          },
          "then": {
            "required": ["freshness_floor_summary"],
            "properties": {
              "freshness_floor_summary": { "$ref": "#/$defs/reviewable_sentence" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "staleness_class": { "const": "unbounded_stale" }
            },
            "required": ["staleness_class"]
          },
          "then": {
            "required": ["staleness_rationale"],
            "properties": {
              "staleness_rationale": { "$ref": "#/$defs/reviewable_sentence" }
            }
          }
        }
      ]
    },
    "display_copy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "whole_product_failure_implied",
        "as_of_time_omitted",
        "measurement_unit_omitted",
        "owner_scope_omitted",
        "personal_workspace_org_collapsed",
        "forecast_under_unauthoritative_state",
        "upgrade_prompted_before_export_or_support",
        "local_continuation_path_obscured",
        "local_core_blocking"
      ],
      "properties": {
        "whole_product_failure_implied": { "type": "boolean", "const": false },
        "as_of_time_omitted": { "type": "boolean", "const": false },
        "measurement_unit_omitted": { "type": "boolean", "const": false },
        "owner_scope_omitted": { "type": "boolean", "const": false },
        "personal_workspace_org_collapsed": { "type": "boolean", "const": false },
        "forecast_under_unauthoritative_state": { "type": "boolean", "const": false },
        "upgrade_prompted_before_export_or_support": { "type": "boolean", "const": false },
        "local_continuation_path_obscured": { "type": "boolean", "const": false },
        "local_core_blocking": { "type": "boolean", "const": false },
        "stale_label": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ],
          "description": "Stale label rendered when meter_freshness_class is non-fresh."
        }
      }
    }
  }
}
