{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/migration/compatibility_scorecard.schema.json",
  "title": "Aureline imported-extension and workflow compatibility scorecard contract",
  "description": "Boundary schema for imported-extension, imported-workflow, and workflow-bundle compatibility scorecards. The scorecard row freezes source ecosystem identity, source object identity, target archetype or workflow refs, native path, compatibility-bridge path, blocked state, caveat, owner allocation, docs/help linkage, evidence freshness, and public-claim downgrade semantics so migration center, docs, claim manifests, compatibility reports, support exports, and workflow-bundle handoff surfaces quote one current record instead of contradictory prose. Raw source profile bodies, raw extension storage, raw absolute paths, raw marketplace payloads, raw credentials, and raw workspace contents never cross this boundary; rows carry opaque refs, controlled status labels, redaction-aware summaries, and evidence refs only.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/compatibility_scorecard_row_record" },
    { "$ref": "#/$defs/compatibility_scorecard_packet_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the compatibility scorecard contract."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe to log, persist, cite, and export."
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "redaction_aware_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200,
      "description": "Short redaction-aware summary or caveat. Exporters apply active redaction policy before crossing support, docs, or telemetry boundaries."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "duration": {
      "type": "string",
      "pattern": "^P(?:\\d+D|T\\d+H|\\d+M|\\d+Y)$",
      "description": "ISO-8601 duration subset used for freshness windows, for example P30D."
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_id" },
      "uniqueItems": true
    },
    "non_empty_ref_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/opaque_id" },
      "uniqueItems": true
    },
    "scorecard_row_id": {
      "type": "string",
      "pattern": "^migration_scorecard:[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "description": "Stable row id for one imported extension, imported workflow, or workflow-bundle compatibility decision."
    },
    "scorecard_packet_id": {
      "type": "string",
      "pattern": "^migration_scorecard_packet:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "row_subject_class": {
      "type": "string",
      "enum": [
        "imported_extension",
        "imported_workflow",
        "workflow_bundle"
      ]
    },
    "source_ecosystem_id": {
      "type": "string",
      "enum": [
        "vs_code_code_oss",
        "jetbrains_family",
        "vim_neovim",
        "emacs",
        "sublime_textmate",
        "native_aureline",
        "mixed_imported_sources",
        "generic_import"
      ],
      "description": "Source ecosystem vocabulary aligned with artifacts/migration/source_ecosystem_rows.yaml plus native and mixed-source handoff rows."
    },
    "source_object_class": {
      "type": "string",
      "enum": [
        "extension",
        "plugin",
        "plugin_runtime",
        "workflow",
        "workflow_bundle",
        "run_debug_config",
        "keymap_or_profile",
        "theme_or_asset",
        "syntax_bundle",
        "source_feature"
      ]
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "archetype",
        "workflow",
        "workflow_bundle",
        "native_extension",
        "native_command",
        "native_docs_path",
        "compatibility_bridge",
        "none"
      ]
    },
    "scorecard_status": {
      "type": "string",
      "enum": [
        "supported",
        "partial",
        "community_path",
        "blocked",
        "deprecated",
        "replaced"
      ],
      "description": "Closed scorecard status vocabulary. Surfaces may narrow this value for presentation, but may not invent best-effort synonyms."
    },
    "public_claim_posture": {
      "type": "string",
      "enum": [
        "claim_bearing",
        "limited",
        "community_only",
        "blocked",
        "deprecated",
        "replacement_grade",
        "not_claimed"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "required_evidence_missing",
        "required_evidence_stale",
        "required_evidence_narrower_than_claim",
        "docs_help_link_missing",
        "caveat_uncovered",
        "compatibility_row_degraded",
        "claim_manifest_projection_changed",
        "source_ecosystem_row_missing",
        "workflow_bundle_revision_changed",
        "bridge_profile_changed",
        "native_path_changed",
        "permission_or_policy_blocked",
        "deprecated_source_path",
        "replacement_available",
        "none"
      ]
    },
    "evidence_state": {
      "type": "string",
      "enum": [
        "current",
        "seed_only",
        "warm_cached",
        "stale",
        "missing",
        "retest_pending",
        "not_applicable"
      ]
    },
    "path_state": {
      "type": "string",
      "enum": [
        "available",
        "partial",
        "community",
        "blocked",
        "not_available",
        "not_applicable",
        "replaced"
      ]
    },
    "blocked_state_class": {
      "type": "string",
      "enum": [
        "not_blocked",
        "manual_review_required",
        "unsupported_runtime",
        "unsupported_webview_or_ui_surface",
        "permission_or_policy_block",
        "missing_native_path",
        "missing_bridge_path",
        "stale_or_missing_evidence",
        "deprecated_source_path",
        "replaced_by_native_alternative"
      ]
    },
    "refresh_trigger": {
      "type": "string",
      "enum": [
        "source_extension_version_changed",
        "source_profile_fixture_changed",
        "workflow_bundle_revision_changed",
        "native_package_or_command_changed",
        "bridge_profile_changed",
        "permission_or_policy_vocab_changed",
        "compatibility_report_changed",
        "claim_manifest_projection_changed",
        "docs_help_link_changed",
        "evidence_window_expired",
        "known_limit_or_caveat_changed"
      ]
    },
    "source_object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_object_ref",
        "source_label",
        "source_object_class"
      ],
      "properties": {
        "source_object_ref": { "$ref": "#/$defs/opaque_id" },
        "source_label": { "$ref": "#/$defs/redaction_aware_text" },
        "source_object_class": { "$ref": "#/$defs/source_object_class" },
        "source_version": { "$ref": "#/$defs/non_empty_string" },
        "source_profile_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_kind",
        "target_refs",
        "target_summary"
      ],
      "properties": {
        "target_kind": { "$ref": "#/$defs/target_kind" },
        "target_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "target_archetype_refs": { "$ref": "#/$defs/ref_array" },
        "target_workflow_refs": { "$ref": "#/$defs/ref_array" },
        "target_bundle_refs": { "$ref": "#/$defs/ref_array" },
        "target_summary": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "path_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_state",
        "evidence_state",
        "refs",
        "summary"
      ],
      "properties": {
        "path_state": { "$ref": "#/$defs/path_state" },
        "evidence_state": { "$ref": "#/$defs/evidence_state" },
        "refs": { "$ref": "#/$defs/ref_array" },
        "summary": { "$ref": "#/$defs/redaction_aware_text" },
        "owner": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "blocked_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blocked_state_class",
        "blocked_from_apply",
        "reason_refs",
        "summary"
      ],
      "properties": {
        "blocked_state_class": { "$ref": "#/$defs/blocked_state_class" },
        "blocked_from_apply": { "type": "boolean" },
        "reason_refs": { "$ref": "#/$defs/ref_array" },
        "summary": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "status_semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "declared_status",
        "effective_status",
        "public_claim_posture",
        "downgrade_triggers",
        "scoring_summary"
      ],
      "properties": {
        "declared_status": { "$ref": "#/$defs/scorecard_status" },
        "effective_status": { "$ref": "#/$defs/scorecard_status" },
        "public_claim_posture": { "$ref": "#/$defs/public_claim_posture" },
        "downgrade_triggers": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_trigger" },
          "uniqueItems": true
        },
        "scoring_summary": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "owner_allocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_owner",
        "evidence_owner",
        "publication_owner",
        "support_owner"
      ],
      "properties": {
        "row_owner": { "$ref": "#/$defs/non_empty_string" },
        "evidence_owner": { "$ref": "#/$defs/non_empty_string" },
        "publication_owner": { "$ref": "#/$defs/non_empty_string" },
        "support_owner": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "publication_links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "docs_help_refs",
        "compatibility_row_refs",
        "claim_manifest_refs",
        "migration_report_refs",
        "support_export_refs",
        "issue_template_refs"
      ],
      "properties": {
        "docs_help_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "compatibility_row_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "claim_manifest_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "migration_report_refs": { "$ref": "#/$defs/ref_array" },
        "support_export_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "issue_template_refs": { "$ref": "#/$defs/ref_array" },
        "release_report_refs": { "$ref": "#/$defs/ref_array" },
        "workflow_bundle_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captured_at",
        "stale_after",
        "freshness_state",
        "next_refresh_due",
        "refresh_triggers",
        "source_revision"
      ],
      "properties": {
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "stale_after": { "$ref": "#/$defs/duration" },
        "freshness_state": { "$ref": "#/$defs/evidence_state" },
        "next_refresh_due": {
          "type": "string",
          "format": "date"
        },
        "refresh_triggers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/refresh_trigger" },
          "uniqueItems": true
        },
        "source_revision": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "summary",
        "required_action",
        "refs"
      ],
      "properties": {
        "rule_id": { "$ref": "#/$defs/opaque_id" },
        "summary": { "$ref": "#/$defs/redaction_aware_text" },
        "required_action": { "$ref": "#/$defs/redaction_aware_text" },
        "refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "compatibility_scorecard_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "scorecard_id",
        "row_subject_class",
        "source_ecosystem_id",
        "source_object",
        "target",
        "native_path",
        "compatibility_bridge_path",
        "blocked_state",
        "status_semantics",
        "caveat",
        "owner_allocation",
        "publication_links",
        "evidence_refs",
        "freshness"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "record_kind": {
          "type": "string",
          "const": "compatibility_scorecard_row_record"
        },
        "scorecard_id": { "$ref": "#/$defs/scorecard_row_id" },
        "row_subject_class": { "$ref": "#/$defs/row_subject_class" },
        "source_ecosystem_id": { "$ref": "#/$defs/source_ecosystem_id" },
        "source_object": { "$ref": "#/$defs/source_object" },
        "target": { "$ref": "#/$defs/target" },
        "native_path": { "$ref": "#/$defs/path_record" },
        "compatibility_bridge_path": { "$ref": "#/$defs/path_record" },
        "blocked_state": { "$ref": "#/$defs/blocked_state" },
        "status_semantics": { "$ref": "#/$defs/status_semantics" },
        "caveat": { "$ref": "#/$defs/redaction_aware_text" },
        "owner_allocation": { "$ref": "#/$defs/owner_allocation" },
        "publication_links": { "$ref": "#/$defs/publication_links" },
        "evidence_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "freshness": { "$ref": "#/$defs/freshness" }
      }
    },
    "compatibility_scorecard_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "scorecard_packet_id",
        "title",
        "generated_at",
        "contract_ref",
        "schema_ref",
        "source_catalog_refs",
        "publication_rules",
        "scoring_semantics",
        "refresh_rules",
        "rows"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "record_kind": {
          "type": "string",
          "const": "compatibility_scorecard_packet_record"
        },
        "scorecard_packet_id": { "$ref": "#/$defs/scorecard_packet_id" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "contract_ref": { "$ref": "#/$defs/opaque_id" },
        "schema_ref": { "$ref": "#/$defs/opaque_id" },
        "source_catalog_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "publication_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/rule_record" }
        },
        "scoring_semantics": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/rule_record" }
        },
        "refresh_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/rule_record" }
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/compatibility_scorecard_row_record" }
        }
      }
    }
  }
}
