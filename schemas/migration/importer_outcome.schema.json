{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/migration/importer_outcome.schema.json",
  "title": "Aureline importer-outcome row and packet contracts",
  "description": "Boundary schema for durable migration-center importer outcome records. Freezes one importer_outcome_row_record and one importer_outcome_packet_record so grouped importer outcomes, compatibility linkage, parity-score refs, equivalence-map refs, post-import validation refs, bridge requirements, recommended bundle handoff, and machine-readable report/export refs remain stable across migration center, docs, support, and issue-template projections. See docs/migration/migration_center_object_model.md.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/importer_outcome_row_record" },
    { "$ref": "#/$defs/importer_outcome_packet_record" }
  ],
  "$defs": {
    "importer_outcome_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the migration importer-outcome model. Bumped only on breaking payload changes."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe for logs, exports, and support handoff."
    },

    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },

    "monotonic_timestamp": {
      "type": "string",
      "minLength": 1,
      "description": "Producer-local timestamp. Opaque at this boundary."
    },

    "redaction_aware_text": {
      "type": "string",
      "maxLength": 1024,
      "description": "Redaction-aware free text (<= 1024 graphemes). Exporters apply the active redaction policy before crossing this boundary."
    },

    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    },

    "compatibility_row_ref": {
      "type": "string",
      "pattern": "^compat_row:[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "description": "Stable compatibility-row id from schemas/release/compatibility_row.schema.json."
    },

    "compatibility_row_ref_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/compatibility_row_ref" }
    },

    "migration_domain": {
      "type": "string",
      "enum": [
        "settings",
        "shortcuts",
        "themes_and_visuals",
        "snippets_and_templates",
        "tasks_and_run_configs",
        "launch_debug",
        "extensions_and_providers",
        "workspace_metadata",
        "profiles_and_layout",
        "docs_and_tours",
        "bridge_metadata",
        "other"
      ],
      "description": "Closed migration-domain set used by grouped importer outcomes."
    },

    "interop_result_state": {
      "type": "string",
      "enum": [
        "imported",
        "mapped",
        "skipped",
        "manual_review",
        "bridge_required",
        "unsupported"
      ],
      "description": "Controlled importer outcome vocabulary reused by migration center, docs, and bridge-truth surfaces."
    },

    "outcome_reason_class": {
      "type": "string",
      "enum": [
        "exact_equivalent_available",
        "semantic_equivalent_available",
        "capability_mapping_available",
        "user_declined_import",
        "policy_excludes_import",
        "existing_state_retained",
        "conflict_requires_review",
        "bridge_needed_for_parity",
        "target_feature_not_supported",
        "source_artifact_unreadable",
        "source_version_not_qualified",
        "insufficient_evidence"
      ],
      "description": "Typed reason why the row landed in its outcome state."
    },

    "confidence_class": {
      "type": "string",
      "enum": ["high", "medium", "low", "insufficient_evidence"],
      "description": "How confident Aureline is in the mapping or diagnosis attached to the row."
    },

    "mapping_basis": {
      "type": "string",
      "enum": [
        "exact_identity",
        "semantic_equivalent",
        "capability_based",
        "bridge_adapter",
        "name_heuristic",
        "user_override",
        "not_applicable"
      ],
      "description": "How the importer derived the target-side mapping or follow-up recommendation."
    },

    "bridge_surface_class": {
      "type": "string",
      "enum": [
        "extension_compat_layer",
        "keymap_bridge",
        "theme_token_bridge",
        "task_launch_translator",
        "provider_connector",
        "other"
      ],
      "description": "Which bridge family the row depends on when native parity is not available."
    },

    "bridge_installation_posture": {
      "type": "string",
      "enum": [
        "already_present",
        "required_before_use",
        "recommended",
        "policy_blocked",
        "unavailable"
      ],
      "description": "Whether the required bridge is already present, still needed, blocked, or unavailable."
    },

    "bridge_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bridge_ref", "bridge_surface_class", "installation_posture"],
      "properties": {
        "bridge_ref": { "$ref": "#/$defs/non_empty_string" },
        "bridge_surface_class": { "$ref": "#/$defs/bridge_surface_class" },
        "installation_posture": { "$ref": "#/$defs/bridge_installation_posture" },
        "compatibility_row_refs": { "$ref": "#/$defs/compatibility_row_ref_array" },
        "docs_help_refs": { "$ref": "#/$defs/ref_array" },
        "note": { "$ref": "#/$defs/redaction_aware_text" }
      },
      "description": "Bridge requirement details for rows that cannot claim native parity."
    },

    "parity_score_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "score", "confidence_class"],
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "keymap",
            "theme_and_visuals",
            "settings",
            "tasks_and_run_configs",
            "launch_debug",
            "extensions_and_providers",
            "snippets_and_templates",
            "other"
          ]
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "evidence_ref": { "$ref": "#/$defs/opaque_id" }
      },
      "description": "One category-specific parity score row. Aggregate-only scores that hide weak categories are non-conforming. For the export-safe label + known-gap linkage contract, see schemas/migration/parity_scorecard.schema.json."
    },

    "equivalence_map_row_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "target_id", "mapping_basis"],
      "properties": {
        "source_id": { "$ref": "#/$defs/opaque_id" },
        "target_id": { "$ref": "#/$defs/opaque_id" },
        "mapping_basis": { "$ref": "#/$defs/mapping_basis" },
        "caveat": { "$ref": "#/$defs/redaction_aware_text" }
      },
      "description": "One equivalence-map row reference. name_heuristic is allowed only when no stronger basis exists and the row is reviewable. For the full equivalence-map row contract (including equivalence_outcome and shim requirements), see schemas/migration/equivalence_map_row.schema.json."
    },

    "post_import_validation_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_class", "outcome_class"],
      "properties": {
        "validator_class": {
          "type": "string",
          "enum": [
            "keybinding_conflict",
            "missing_extension_suggestion",
            "launch_config_sanity",
            "cli_headless_smoke",
            "workflow_smoke",
            "settings_schema_migration",
            "bundle_readiness"
          ]
        },
        "outcome_class": {
          "type": "string",
          "enum": [
            "passed",
            "passed_with_warnings",
            "failed_recoverable",
            "failed_blocking",
            "skipped_not_applicable"
          ]
        },
        "validator_run_ref": { "$ref": "#/$defs/opaque_id" }
      },
      "description": "One post-import validation outcome ref."
    },

    "outcome_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "imported",
        "mapped",
        "skipped",
        "manual_review",
        "bridge_required",
        "unsupported",
        "total_rows"
      ],
      "properties": {
        "imported": { "type": "integer", "minimum": 0 },
        "mapped": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "manual_review": { "type": "integer", "minimum": 0 },
        "bridge_required": { "type": "integer", "minimum": 0 },
        "unsupported": { "type": "integer", "minimum": 0 },
        "total_rows": { "type": "integer", "minimum": 0 }
      },
      "description": "Explicit grouped counts for the six controlled outcome states. bridge_required and unsupported remain present even when their count is zero."
    },

    "importer_outcome_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "importer_outcome_schema_version",
        "row_id",
        "migration_session_ref",
        "domain",
        "source_object_ref",
        "outcome_state",
        "reason_class",
        "confidence_class",
        "docs_help_refs"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "importer_outcome_row_record"
        },
        "importer_outcome_schema_version": {
          "$ref": "#/$defs/importer_outcome_schema_version"
        },
        "row_id": { "$ref": "#/$defs/opaque_id" },
        "migration_session_ref": { "$ref": "#/$defs/opaque_id" },
        "domain": { "$ref": "#/$defs/migration_domain" },
        "source_object_ref": { "$ref": "#/$defs/opaque_id" },
        "target_object_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Resolved target object or recommended destination object, when one exists."
        },
        "presentation_label": { "$ref": "#/$defs/redaction_aware_text" },
        "outcome_state": { "$ref": "#/$defs/interop_result_state" },
        "reason_class": { "$ref": "#/$defs/outcome_reason_class" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "mapping_basis": { "$ref": "#/$defs/mapping_basis" },
        "reason_detail": {
          "$ref": "#/$defs/redaction_aware_text",
          "description": "Optional note describing why the row landed in this outcome state."
        },
        "bridge_requirement": {
          "$ref": "#/$defs/bridge_requirement",
          "description": "Required when outcome_state = bridge_required."
        },
        "docs_help_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "outcome_state": {
                "enum": ["imported", "mapped"]
              }
            },
            "required": ["outcome_state"]
          },
          "then": {
            "required": ["target_object_ref", "mapping_basis"]
          }
        },
        {
          "if": {
            "properties": {
              "outcome_state": { "const": "bridge_required" }
            },
            "required": ["outcome_state"]
          },
          "then": {
            "required": ["bridge_requirement"]
          }
        }
      ],
      "description": "One durable importer outcome row. The row remains stable in preview, post-import review, docs, issue-template export, and support handoff."
    },

    "importer_outcome_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "importer_outcome_schema_version",
        "outcome_packet_id",
        "migration_session_ref",
        "rows",
        "outcome_summary",
        "post_import_validation_refs",
        "migration_report_ref",
        "emitted_at"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "importer_outcome_packet_record"
        },
        "importer_outcome_schema_version": {
          "$ref": "#/$defs/importer_outcome_schema_version"
        },
        "outcome_packet_id": { "$ref": "#/$defs/opaque_id" },
        "migration_session_ref": { "$ref": "#/$defs/opaque_id" },
        "entry_restore_result_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Optional ref to the companion migration_result_record from the entry/restore object model."
        },
        "compatibility_report_ref": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Machine-readable ref to the compatibility report or report fragment this packet quotes."
        },
        "compatibility_row_refs": { "$ref": "#/$defs/compatibility_row_ref_array" },
        "shortcut_digest_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Optional ref to the dedicated migration_shortcut_digest_record."
        },
        "restore_record_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Optional ref to the migration_restore_record backing rollback/restore affordances."
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/importer_outcome_row_record" }
        },
        "outcome_summary": { "$ref": "#/$defs/outcome_summary" },
        "parity_score_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/parity_score_ref" },
          "description": "Reserved slot for category-specific parity scores."
        },
        "equivalence_map_row_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/equivalence_map_row_ref" },
          "description": "Reserved slot for shared equivalence-map rows quoted by the packet."
        },
        "post_import_validation_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/post_import_validation_ref" },
          "description": "Post-import validation outcome refs. Required on outcome packets; validators that do not apply MUST still appear with outcome_class = skipped_not_applicable so post-import validation is explicit rather than omitted."
        },
        "recommended_bundle_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Reserved workflow-bundle handoff ref."
        },
        "migration_report_ref": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Machine-readable migration-report ref shared by docs, support, and issue-template projections."
        },
        "issue_template_refs": {
          "$ref": "#/$defs/ref_array",
          "description": "Issue-template refs used when this packet becomes an escalation or follow-up issue."
        },
        "export_refs": {
          "$ref": "#/$defs/ref_array",
          "description": "Stable export refs carrying this packet into support, docs, or offline review packets."
        },
        "support_packet_refs": {
          "$ref": "#/$defs/ref_array",
          "description": "Support packet ids or packet paths that preserve this packet."
        },
        "docs_help_refs": {
          "$ref": "#/$defs/ref_array",
          "description": "Docs/help refs attached to packet-level compatibility or follow-up guidance."
        },
        "emitted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "rows": {
                "contains": {
                  "type": "object",
                  "properties": {
                    "outcome_state": {
                      "enum": ["bridge_required", "unsupported"]
                    }
                  },
                  "required": ["outcome_state"]
                }
              }
            },
            "required": ["rows"]
          },
          "then": {
            "required": ["export_refs", "support_packet_refs"]
          }
        }
      ],
      "description": "Grouped importer outcome packet read by migration center, post-import review, docs projections, support handoff, and machine-readable exports."
    }
  },
  "examples": [
    {
      "record_kind": "importer_outcome_row_record",
      "importer_outcome_schema_version": 1,
      "row_id": "importer-outcome-row:vs-code-eslint-0001",
