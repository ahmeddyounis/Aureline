{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://aureline.dev/schemas/perf/add-memory-analysis-views-snapshot-pairs-retained-or-allocation-diffs-and-leak-hint-confidence.schema.json",
    "title": "Memory-Analysis Views, Snapshot Pairs, Retained or Allocation Diffs, and Leak-Hint Confidence",
    "description": "Schema for the M5 memory-analysis qualification packet that governs memory-analysis views, snapshot pairs, retained diffs, allocation diffs, and leak-hint confidence rows.",
    "type": "object",
    "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "as_of",
        "release_doc_ref",
        "help_doc_ref",
        "schema_ref",
        "surfaces",
        "views",
        "snapshot_pairs",
        "retained_diffs",
        "allocation_diffs",
        "leak_hints",
        "summary"
    ],
    "properties": {
        "schema_version": {
            "type": "integer",
            "minimum": 1,
            "description": "Schema version for this packet family."
        },
        "record_kind": {
            "type": "string",
            "const": "add_memory_analysis_views_snapshot_pairs_retained_or_allocation_diffs_and_leak_hint_confidence",
            "description": "Stable record-kind tag."
        },
        "packet_id": {
            "type": "string",
            "description": "Stable packet identifier."
        },
        "as_of": {
            "type": "string",
            "format": "date",
            "description": "Date the packet was captured."
        },
        "release_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the release reviewer document."
        },
        "help_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the help projection."
        },
        "schema_ref": {
            "type": "string",
            "description": "Repo-relative path to this schema."
        },
        "surfaces": {
            "type": "array",
            "items": { "$ref": "#/definitions/MemoryAnalysisSurfaceQualificationRow" }
        },
        "views": {
            "type": "array",
            "items": { "$ref": "#/definitions/MemoryAnalysisViewRow" }
        },
        "snapshot_pairs": {
            "type": "array",
            "items": { "$ref": "#/definitions/SnapshotPairRow" }
        },
        "retained_diffs": {
            "type": "array",
            "items": { "$ref": "#/definitions/RetainedDiffRow" }
        },
        "allocation_diffs": {
            "type": "array",
            "items": { "$ref": "#/definitions/AllocationDiffRow" }
        },
        "leak_hints": {
            "type": "array",
            "items": { "$ref": "#/definitions/LeakHintRow" }
        },
        "summary": {
            "$ref": "#/definitions/MemoryAnalysisQualificationSummary"
        }
    },
    "definitions": {
        "MemoryAnalysisQualificationLabel": {
            "type": "string",
            "enum": ["stable", "preview", "labs", "inspect_only", "import_only"],
            "description": "Qualification label for a memory-analysis surface."
        },
        "MemoryAnalysisSurfaceKind": {
            "type": "string",
            "enum": [
                "retained_size_view",
                "allocation_count_view",
                "class_histogram_view",
                "instance_list_view",
                "dominator_tree_view",
                "diff_view",
                "leak_hint_view",
                "snapshot_pair_browser",
                "export_review",
                "support_export"
            ],
            "description": "Kind of memory-analysis surface."
        },
        "MemoryAnalysisViewKind": {
            "type": "string",
            "enum": [
                "retained_size_view",
                "allocation_count_view",
                "class_histogram_view",
                "instance_list_view",
                "dominator_tree_view",
                "diff_view",
                "leak_hint_view"
            ],
            "description": "Kind of memory-analysis view."
        },
        "SnapshotKind": {
            "type": "string",
            "enum": ["heap_dump", "allocation_trace", "live_object_set"],
            "description": "Kind of snapshot captured for memory analysis."
        },
        "ComparisonBasis": {
            "type": "string",
            "enum": ["retained_diff", "allocation_diff", "shallow_diff", "object_count_diff"],
            "description": "Basis on which two snapshots are compared."
        },
        "LeakHintConfidence": {
            "type": "string",
            "enum": ["high", "medium", "low", "uncertain"],
            "description": "Confidence level for a leak hint."
        },
        "MemoryMappingQualityLabel": {
            "type": "string",
            "enum": ["exact", "approximate", "partial", "unavailable", "stale", "mismatched"],
            "description": "Mapping quality for symbol-to-type or snapshot resolution."
        },
        "MemoryAnalysisViewRow": {
            "type": "object",
            "required": ["view_id", "title", "view_kind", "mapping_quality", "shows_mapping_quality", "shows_degraded_label"],
            "properties": {
                "view_id": { "type": "string" },
                "title": { "type": "string" },
                "view_kind": { "$ref": "#/definitions/MemoryAnalysisViewKind" },
                "snapshot_pair_ref": { "type": "string" },
                "mapping_quality": { "$ref": "#/definitions/MemoryMappingQualityLabel" },
                "shows_mapping_quality": { "type": "boolean" },
                "shows_degraded_label": { "type": "boolean" }
            }
        },
        "SnapshotPairRow": {
            "type": "object",
            "required": ["pair_id", "title", "baseline_snapshot_ref", "comparison_snapshot_ref", "snapshot_kind", "comparison_basis", "mapping_quality", "shows_comparison_basis", "shows_degraded_label"],
            "properties": {
                "pair_id": { "type": "string" },
                "title": { "type": "string" },
                "baseline_snapshot_ref": { "type": "string" },
                "comparison_snapshot_ref": { "type": "string" },
                "snapshot_kind": { "$ref": "#/definitions/SnapshotKind" },
                "comparison_basis": { "$ref": "#/definitions/ComparisonBasis" },
                "mapping_quality": { "$ref": "#/definitions/MemoryMappingQualityLabel" },
                "shows_comparison_basis": { "type": "boolean" },
                "shows_degraded_label": { "type": "boolean" }
            }
        },
        "RetainedDiffRow": {
            "type": "object",
            "required": ["diff_id", "title", "pair_ref", "type_path_or_class", "baseline_retained_bytes", "comparison_retained_bytes", "delta_bytes", "delta_percent", "mapping_quality", "shows_mapping_quality"],
            "properties": {
                "diff_id": { "type": "string" },
                "title": { "type": "string" },
                "pair_ref": { "type": "string" },
                "type_path_or_class": { "type": "string" },
                "baseline_retained_bytes": { "type": "integer", "minimum": 0 },
                "comparison_retained_bytes": { "type": "integer", "minimum": 0 },
                "delta_bytes": { "type": "integer" },
                "delta_percent": { "type": "number" },
                "mapping_quality": { "$ref": "#/definitions/MemoryMappingQualityLabel" },
                "shows_mapping_quality": { "type": "boolean" }
            }
        },
        "AllocationDiffRow": {
            "type": "object",
            "required": ["diff_id", "title", "pair_ref", "type_path_or_class", "baseline_alloc_count", "comparison_alloc_count", "baseline_alloc_bytes", "comparison_alloc_bytes", "delta_count", "delta_bytes", "mapping_quality", "shows_mapping_quality"],
            "properties": {
                "diff_id": { "type": "string" },
                "title": { "type": "string" },
                "pair_ref": { "type": "string" },
                "type_path_or_class": { "type": "string" },
                "baseline_alloc_count": { "type": "integer", "minimum": 0 },
                "comparison_alloc_count": { "type": "integer", "minimum": 0 },
                "baseline_alloc_bytes": { "type": "integer", "minimum": 0 },
                "comparison_alloc_bytes": { "type": "integer", "minimum": 0 },
                "delta_count": { "type": "integer" },
                "delta_bytes": { "type": "integer" },
                "mapping_quality": { "$ref": "#/definitions/MemoryMappingQualityLabel" },
                "shows_mapping_quality": { "type": "boolean" }
            }
        },
        "LeakHintRow": {
            "type": "object",
            "required": ["hint_id", "title", "pair_ref", "type_path_or_class", "confidence", "retained_bytes", "instance_count", "leak_rationale", "shows_confidence", "mapping_quality"],
            "properties": {
                "hint_id": { "type": "string" },
                "title": { "type": "string" },
                "pair_ref": { "type": "string" },
                "type_path_or_class": { "type": "string" },
                "confidence": { "$ref": "#/definitions/LeakHintConfidence" },
                "retained_bytes": { "type": "integer", "minimum": 0 },
                "instance_count": { "type": "integer", "minimum": 0 },
                "leak_rationale": { "type": "string" },
                "shows_confidence": { "type": "boolean" },
                "mapping_quality": { "$ref": "#/definitions/MemoryMappingQualityLabel" }
            }
        },
        "MemoryAnalysisQualificationProof": {
            "type": "object",
            "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at"],
            "properties": {
                "packet_id": { "type": "string" },
                "packet_ref": { "type": "string" },
                "proof_index_ref": { "type": "string" },
                "captured_at": { "type": "string" },
                "evidence_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        },
        "MemoryAnalysisQualificationSummary": {
            "type": "object",
            "required": ["view_count", "snapshot_pair_count", "retained_diff_count", "allocation_diff_count", "leak_hint_count", "stable_count", "below_stable_count", "all_below_stable_have_disclosure"],
            "properties": {
                "view_count": { "type": "integer", "minimum": 0 },
                "snapshot_pair_count": { "type": "integer", "minimum": 0 },
                "retained_diff_count": { "type": "integer", "minimum": 0 },
                "allocation_diff_count": { "type": "integer", "minimum": 0 },
                "leak_hint_count": { "type": "integer", "minimum": 0 },
                "stable_count": { "type": "integer", "minimum": 0 },
                "below_stable_count": { "type": "integer", "minimum": 0 },
                "all_below_stable_have_disclosure": { "type": "boolean" }
            }
        },
        "MemoryAnalysisSurfaceGuardSet": {
            "type": "object",
            "required": ["views_visible", "snapshot_pairs_visible", "retained_diffs_visible", "allocation_diffs_visible", "leak_hints_visible", "mapping_quality_visible", "export_posture_visible", "degraded_state_label_visible"],
            "properties": {
                "views_visible": { "type": "boolean" },
                "snapshot_pairs_visible": { "type": "boolean" },
                "retained_diffs_visible": { "type": "boolean" },
                "allocation_diffs_visible": { "type": "boolean" },
                "leak_hints_visible": { "type": "boolean" },
                "mapping_quality_visible": { "type": "boolean" },
                "export_posture_visible": { "type": "boolean" },
                "degraded_state_label_visible": { "type": "boolean" }
            }
        },
        "MemoryAnalysisSurfaceQualificationRow": {
            "type": "object",
            "required": ["surface_id", "title", "surface_kind", "promoted_build_surface", "claim_label", "displayed_label", "qualification_packet", "guards", "downgrade_if_missing", "rationale"],
            "properties": {
                "surface_id": { "type": "string" },
                "title": { "type": "string" },
                "surface_kind": { "$ref": "#/definitions/MemoryAnalysisSurfaceKind" },
                "promoted_build_surface": { "type": "boolean" },
                "claim_label": { "$ref": "#/definitions/MemoryAnalysisQualificationLabel" },
                "displayed_label": { "type": "string" },
                "qualification_packet": { "$ref": "#/definitions/MemoryAnalysisQualificationProof" },
                "guards": { "$ref": "#/definitions/MemoryAnalysisSurfaceGuardSet" },
                "downgrade_if_missing": { "type": "boolean" },
                "rationale": { "type": "string" }
            }
        }
    }
}
