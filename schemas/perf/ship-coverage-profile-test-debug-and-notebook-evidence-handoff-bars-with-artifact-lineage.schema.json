{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://aureline.dev/schemas/perf/ship-coverage-profile-test-debug-and-notebook-evidence-handoff-bars-with-artifact-lineage.schema.json",
    "title": "Coverage, Profile, Test, Debug, and Notebook Evidence Handoff Bars with Artifact Lineage",
    "description": "Schema for the M5 evidence-handoff qualification packet that governs handoff bar rows, artifact lineage rows, capture source rows, and save/share scope rows.",
    "type": "object",
    "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "as_of",
        "release_doc_ref",
        "help_doc_ref",
        "schema_ref",
        "surfaces",
        "handoff_bars",
        "artifact_lineages",
        "capture_sources",
        "save_share_scopes",
        "summary"
    ],
    "properties": {
        "schema_version": {
            "type": "integer",
            "minimum": 1,
            "description": "Schema version for this packet family."
        },
        "record_kind": {
            "type": "string",
            "const": "ship_coverage_profile_test_debug_and_notebook_evidence_handoff_bars_with_artifact_lineage",
            "description": "Stable record-kind tag."
        },
        "packet_id": {
            "type": "string",
            "description": "Stable packet identifier."
        },
        "as_of": {
            "type": "string",
            "format": "date",
            "description": "Date the packet was captured."
        },
        "release_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the release reviewer document."
        },
        "help_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the help projection."
        },
        "schema_ref": {
            "type": "string",
            "description": "Repo-relative path to this schema."
        },
        "surfaces": {
            "type": "array",
            "items": { "$ref": "#/definitions/EvidenceHandoffSurfaceQualificationRow" }
        },
        "handoff_bars": {
            "type": "array",
            "items": { "$ref": "#/definitions/EvidenceHandoffBarRow" }
        },
        "artifact_lineages": {
            "type": "array",
            "items": { "$ref": "#/definitions/ArtifactLineageRow" }
        },
        "capture_sources": {
            "type": "array",
            "items": { "$ref": "#/definitions/CaptureSourceRow" }
        },
        "save_share_scopes": {
            "type": "array",
            "items": { "$ref": "#/definitions/SaveShareScopeRow" }
        },
        "summary": {
            "$ref": "#/definitions/EvidenceHandoffQualificationSummary"
        }
    },
    "definitions": {
        "EvidenceHandoffQualificationLabel": {
            "type": "string",
            "enum": [
                "stable",
                "preview",
                "labs",
                "inspect_only",
                "import_only"
            ]
        },
        "EvidenceHandoffSurfaceKind": {
            "type": "string",
            "enum": [
                "coverage_handoff_bar",
                "profile_handoff_bar",
                "test_handoff_bar",
                "debug_handoff_bar",
                "notebook_handoff_bar",
                "export_review",
                "support_export"
            ]
        },
        "CaptureSourceClass": {
            "type": "string",
            "enum": [
                "local_live",
                "remote_live",
                "imported",
                "cached",
                "provider_supplied",
                "ci_provided",
                "synthetic",
                "sampled",
                "instrumented",
                "estimated",
                "partial"
            ]
        },
        "LineageState": {
            "type": "string",
            "enum": [
                "exact_match",
                "probable_mismatch",
                "source_only",
                "artifact_only",
                "restricted_by_policy",
                "unavailable"
            ]
        },
        "EvidenceKind": {
            "type": "string",
            "enum": [
                "coverage",
                "profile",
                "trace",
                "memory_snapshot",
                "test_result",
                "debug_session",
                "notebook_output",
                "replay_timeline"
            ]
        },
        "SaveShareScopeKind": {
            "type": "string",
            "enum": [
                "local_only",
                "exportable",
                "shareable",
                "uploadable",
                "attach_to_incident"
            ]
        },
        "BaselineFreshness": {
            "type": "string",
            "enum": [
                "current",
                "stale",
                "expired",
                "missing",
                "imported",
                "unverified"
            ]
        },
        "EvidenceHandoffQualificationProof": {
            "type": "object",
            "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at"],
            "properties": {
                "packet_id": { "type": "string" },
                "packet_ref": { "type": "string" },
                "proof_index_ref": { "type": "string" },
                "captured_at": { "type": "string", "format": "date" },
                "evidence_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        },
        "EvidenceHandoffSurfaceGuardSet": {
            "type": "object",
            "required": [
                "origin_visible",
                "build_id_visible",
                "commit_visible",
                "capture_source_visible",
                "save_share_scope_visible",
                "lineage_state_visible",
                "lineage_detail_visible",
                "degraded_state_label_visible"
            ],
            "properties": {
                "origin_visible": { "type": "boolean" },
                "build_id_visible": { "type": "boolean" },
                "commit_visible": { "type": "boolean" },
                "capture_source_visible": { "type": "boolean" },
                "save_share_scope_visible": { "type": "boolean" },
                "lineage_state_visible": { "type": "boolean" },
                "lineage_detail_visible": { "type": "boolean" },
                "degraded_state_label_visible": { "type": "boolean" }
            }
        },
        "EvidenceHandoffSurfaceQualificationRow": {
            "type": "object",
            "required": [
                "surface_id",
                "title",
                "surface_kind",
                "promoted_build_surface",
                "claim_label",
                "displayed_label",
                "qualification_packet",
                "guards",
                "downgrade_if_missing",
                "rationale"
            ],
            "properties": {
                "surface_id": { "type": "string" },
                "title": { "type": "string" },
                "surface_kind": { "$ref": "#/definitions/EvidenceHandoffSurfaceKind" },
                "promoted_build_surface": { "type": "boolean" },
                "claim_label": { "$ref": "#/definitions/EvidenceHandoffQualificationLabel" },
                "displayed_label": { "type": "string" },
                "qualification_packet": { "$ref": "#/definitions/EvidenceHandoffQualificationProof" },
                "guards": { "$ref": "#/definitions/EvidenceHandoffSurfaceGuardSet" },
                "downgrade_if_missing": { "type": "boolean" },
                "rationale": { "type": "string" }
            }
        },
        "EvidenceHandoffBarRow": {
            "type": "object",
            "required": [
                "handoff_bar_id",
                "title",
                "surface_kind",
                "originating_run_ref",
                "artifact_build_id",
                "commit_or_revision",
                "capture_source_ref",
                "save_share_scope_ref",
                "lineage_ref",
                "lineage_state",
                "promoted_build_surface",
                "shows_origin",
                "shows_build_id",
                "shows_commit",
                "shows_capture_source",
                "shows_save_share_scope",
                "shows_lineage_state",
                "shows_lineage_detail"
            ],
            "properties": {
                "handoff_bar_id": { "type": "string" },
                "title": { "type": "string" },
                "surface_kind": { "$ref": "#/definitions/EvidenceHandoffSurfaceKind" },
                "originating_run_ref": { "type": "string" },
                "artifact_build_id": { "type": "string" },
                "commit_or_revision": { "type": "string" },
                "capture_source_ref": { "type": "string" },
                "save_share_scope_ref": { "type": "string" },
                "lineage_ref": { "type": "string" },
                "lineage_state": { "$ref": "#/definitions/LineageState" },
                "promoted_build_surface": { "type": "boolean" },
                "shows_origin": { "type": "boolean" },
                "shows_build_id": { "type": "boolean" },
                "shows_commit": { "type": "boolean" },
                "shows_capture_source": { "type": "boolean" },
                "shows_save_share_scope": { "type": "boolean" },
                "shows_lineage_state": { "type": "boolean" },
                "shows_lineage_detail": { "type": "boolean" }
            }
        },
        "ArtifactLineageRow": {
            "type": "object",
            "required": [
                "lineage_id",
                "title",
                "evidence_kind",
                "source_run_ref",
                "build_identity_ref",
                "environment_fingerprint_ref",
                "capture_mode_ref",
                "mapping_quality_ref",
                "freshness",
                "promoted_build_surface",
                "shows_build_identity",
                "shows_environment_fingerprint",
                "shows_capture_mode",
                "shows_mapping_quality",
                "shows_freshness"
            ],
            "properties": {
                "lineage_id": { "type": "string" },
                "title": { "type": "string" },
                "evidence_kind": { "$ref": "#/definitions/EvidenceKind" },
                "source_run_ref": { "type": "string" },
                "build_identity_ref": { "type": "string" },
                "environment_fingerprint_ref": { "type": "string" },
                "capture_mode_ref": { "type": "string" },
                "mapping_quality_ref": { "type": "string" },
                "freshness": { "$ref": "#/definitions/BaselineFreshness" },
                "provenance_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "promoted_build_surface": { "type": "boolean" },
                "shows_build_identity": { "type": "boolean" },
                "shows_environment_fingerprint": { "type": "boolean" },
                "shows_capture_mode": { "type": "boolean" },
                "shows_mapping_quality": { "type": "boolean" },
                "shows_freshness": { "type": "boolean" }
            }
        },
        "CaptureSourceRow": {
            "type": "object",
            "required": [
                "source_id",
                "title",
                "source_class",
                "target_identity",
                "trust_label",
                "data_class_label",
                "promoted_build_surface"
            ],
            "properties": {
                "source_id": { "type": "string" },
                "title": { "type": "string" },
                "source_class": { "$ref": "#/definitions/CaptureSourceClass" },
                "target_identity": { "type": "string" },
                "trust_label": { "type": "string" },
                "data_class_label": { "type": "string" },
                "promoted_build_surface": { "type": "boolean" }
            }
        },
        "SaveShareScopeRow": {
            "type": "object",
            "required": [
                "scope_id",
                "title",
                "scope_kind",
                "shows_redaction_mode",
                "shows_destination_class",
                "promoted_build_surface"
            ],
            "properties": {
                "scope_id": { "type": "string" },
                "title": { "type": "string" },
                "scope_kind": { "$ref": "#/definitions/SaveShareScopeKind" },
                "shows_redaction_mode": { "type": "boolean" },
                "shows_destination_class": { "type": "boolean" },
                "promoted_build_surface": { "type": "boolean" }
            }
        },
        "EvidenceHandoffQualificationSummary": {
            "type": "object",
            "required": [
                "handoff_bar_count",
                "artifact_lineage_count",
                "capture_source_count",
                "save_share_scope_count",
                "stable_count",
                "below_stable_count",
                "all_below_stable_have_disclosure",
                "usable_lineage_count",
                "honest_scope_count"
            ],
            "properties": {
                "handoff_bar_count": { "type": "integer", "minimum": 0 },
                "artifact_lineage_count": { "type": "integer", "minimum": 0 },
                "capture_source_count": { "type": "integer", "minimum": 0 },
                "save_share_scope_count": { "type": "integer", "minimum": 0 },
                "stable_count": { "type": "integer", "minimum": 0 },
                "below_stable_count": { "type": "integer", "minimum": 0 },
                "all_below_stable_have_disclosure": { "type": "boolean" },
                "usable_lineage_count": { "type": "integer", "minimum": 0 },
                "honest_scope_count": { "type": "integer", "minimum": 0 }
            }
        }
    }
}
