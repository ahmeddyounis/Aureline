{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://aureline.dev/schemas/perf/implement-the-first-justified-replay-backend-with-recording-mode-banner-expiry-and-cost-posture.schema.json",
    "title": "Justified Replay Backend with Recording-Mode Banner, Expiry, and Cost Posture",
    "description": "Schema for the M5 replay qualification packet that governs recording-mode banner rows, replay expiry rows, and replay cost-posture rows.",
    "type": "object",
    "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "as_of",
        "release_doc_ref",
        "help_doc_ref",
        "schema_ref",
        "surfaces",
        "recording_mode_banners",
        "replay_expiries",
        "replay_cost_postures",
        "summary"
    ],
    "properties": {
        "schema_version": {
            "type": "integer",
            "minimum": 1,
            "description": "Schema version for this packet family."
        },
        "record_kind": {
            "type": "string",
            "const": "implement_the_first_justified_replay_backend_with_recording_mode_banner_expiry_and_cost_posture",
            "description": "Stable record-kind tag."
        },
        "packet_id": {
            "type": "string",
            "description": "Stable packet identifier."
        },
        "as_of": {
            "type": "string",
            "format": "date",
            "description": "Date the packet was captured."
        },
        "release_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the release reviewer document."
        },
        "help_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the help projection."
        },
        "schema_ref": {
            "type": "string",
            "description": "Repo-relative path to this schema."
        },
        "surfaces": {
            "type": "array",
            "items": { "$ref": "#/definitions/ReplaySurfaceQualificationRow" }
        },
        "recording_mode_banners": {
            "type": "array",
            "items": { "$ref": "#/definitions/RecordingModeBannerRow" }
        },
        "replay_expiries": {
            "type": "array",
            "items": { "$ref": "#/definitions/ReplayExpiryRow" }
        },
        "replay_cost_postures": {
            "type": "array",
            "items": { "$ref": "#/definitions/ReplayCostPostureRow" }
        },
        "summary": {
            "$ref": "#/definitions/ReplayQualificationSummary"
        }
    },
    "definitions": {
        "ReplayQualificationLabel": {
            "type": "string",
            "enum": [
                "stable",
                "preview",
                "labs",
                "inspect_only",
                "import_only"
            ]
        },
        "ReplaySurfaceKind": {
            "type": "string",
            "enum": [
                "recording_mode_banner",
                "replay_expiry_inspector",
                "cost_posture_inspector",
                "replay_backend",
                "export_review",
                "support_export"
            ]
        },
        "RecordingModeState": {
            "type": "string",
            "enum": [
                "recording",
                "not_recording",
                "recorded",
                "expired",
                "unsupported",
                "policy_blocked"
            ]
        },
        "ExpiryStatus": {
            "type": "string",
            "enum": [
                "current",
                "stale",
                "expired",
                "missing",
                "pinned",
                "policy_blocked"
            ]
        },
        "CostPostureClass": {
            "type": "string",
            "enum": [
                "low",
                "moderate",
                "high",
                "extreme",
                "unknown"
            ]
        },
        "ReplayQualificationProof": {
            "type": "object",
            "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at"],
            "properties": {
                "packet_id": { "type": "string" },
                "packet_ref": { "type": "string" },
                "proof_index_ref": { "type": "string" },
                "captured_at": { "type": "string", "format": "date" },
                "evidence_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        },
        "ReplaySurfaceGuardSet": {
            "type": "object",
            "required": [
                "recording_mode_banner_visible",
                "replay_expiry_visible",
                "cost_posture_visible",
                "allowed_verbs_visible",
                "degraded_state_label_visible",
                "export_posture_visible",
                "retention_policy_visible",
                "cost_warning_visible"
            ],
            "properties": {
                "recording_mode_banner_visible": { "type": "boolean" },
                "replay_expiry_visible": { "type": "boolean" },
                "cost_posture_visible": { "type": "boolean" },
                "allowed_verbs_visible": { "type": "boolean" },
                "degraded_state_label_visible": { "type": "boolean" },
                "export_posture_visible": { "type": "boolean" },
                "retention_policy_visible": { "type": "boolean" },
                "cost_warning_visible": { "type": "boolean" }
            }
        },
        "ReplaySurfaceQualificationRow": {
            "type": "object",
            "required": [
                "surface_id",
                "title",
                "surface_kind",
                "promoted_build_surface",
                "claim_label",
                "displayed_label",
                "qualification_packet",
                "guards",
                "downgrade_if_missing",
                "rationale"
            ],
            "properties": {
                "surface_id": { "type": "string" },
                "title": { "type": "string" },
                "surface_kind": { "$ref": "#/definitions/ReplaySurfaceKind" },
                "promoted_build_surface": { "type": "boolean" },
                "claim_label": { "$ref": "#/definitions/ReplayQualificationLabel" },
                "displayed_label": { "type": "string" },
                "qualification_packet": { "$ref": "#/definitions/ReplayQualificationProof" },
                "guards": { "$ref": "#/definitions/ReplaySurfaceGuardSet" },
                "downgrade_if_missing": { "type": "boolean" },
                "rationale": { "type": "string" }
            }
        },
        "RecordingModeBannerRow": {
            "type": "object",
            "required": [
                "banner_id",
                "title",
                "recording_mode_state",
                "backend_ref",
                "chronology_support",
                "reverse_step_available",
                "promoted_build_surface",
                "shows_recording_mode_state",
                "shows_degraded_label",
                "shows_allowed_verbs"
            ],
            "properties": {
                "banner_id": { "type": "string" },
                "title": { "type": "string" },
                "recording_mode_state": { "$ref": "#/definitions/RecordingModeState" },
                "backend_ref": { "type": "string" },
                "allowed_verbs": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "chronology_support": { "type": "string" },
                "reverse_step_available": { "type": "boolean" },
                "reverse_step_unavailable_reason": { "type": ["string", "null"] },
                "promoted_build_surface": { "type": "boolean" },
                "shows_recording_mode_state": { "type": "boolean" },
                "shows_degraded_label": { "type": "boolean" },
                "shows_allowed_verbs": { "type": "boolean" }
            }
        },
        "ReplayExpiryRow": {
            "type": "object",
            "required": [
                "expiry_id",
                "title",
                "retention_class",
                "expiry_status",
                "policy_posture",
                "promoted_build_surface",
                "shows_retention_class",
                "shows_expiry_status",
                "warns_on_degraded_state"
            ],
            "properties": {
                "expiry_id": { "type": "string" },
                "title": { "type": "string" },
                "retention_class": { "type": "string" },
                "expires_at": { "type": ["string", "null"] },
                "expiry_status": { "$ref": "#/definitions/ExpiryStatus" },
                "policy_posture": { "type": "string" },
                "promoted_build_surface": { "type": "boolean" },
                "shows_retention_class": { "type": "boolean" },
                "shows_expiry_status": { "type": "boolean" },
                "warns_on_degraded_state": { "type": "boolean" }
            }
        },
        "ReplayCostPostureRow": {
            "type": "object",
            "required": [
                "cost_id",
                "title",
                "cost_posture_class",
                "overhead_class",
                "storage_band",
                "promoted_build_surface",
                "shows_cost_posture_class",
                "shows_overhead_warning",
                "shows_storage_cost_note",
                "blocks_auto_record_when_extreme"
            ],
            "properties": {
                "cost_id": { "type": "string" },
                "title": { "type": "string" },
                "cost_posture_class": { "$ref": "#/definitions/CostPostureClass" },
                "overhead_class": { "type": "string" },
                "storage_band": { "type": "string" },
                "promoted_build_surface": { "type": "boolean" },
                "shows_cost_posture_class": { "type": "boolean" },
                "shows_overhead_warning": { "type": "boolean" },
                "shows_storage_cost_note": { "type": "boolean" },
                "blocks_auto_record_when_extreme": { "type": "boolean" }
            }
        },
        "ReplayQualificationSummary": {
            "type": "object",
            "required": [
                "recording_mode_banner_count",
                "replay_expiry_count",
                "replay_cost_posture_count",
                "stable_count",
                "below_stable_count",
                "all_below_stable_have_disclosure",
                "banner_showing_degraded_count",
                "expiry_warning_count",
                "cost_warning_count"
            ],
            "properties": {
                "recording_mode_banner_count": { "type": "integer", "minimum": 0 },
                "replay_expiry_count": { "type": "integer", "minimum": 0 },
                "replay_cost_posture_count": { "type": "integer", "minimum": 0 },
                "stable_count": { "type": "integer", "minimum": 0 },
                "below_stable_count": { "type": "integer", "minimum": 0 },
                "all_below_stable_have_disclosure": { "type": "boolean" },
                "banner_showing_degraded_count": { "type": "integer", "minimum": 0 },
                "expiry_warning_count": { "type": "integer", "minimum": 0 },
                "cost_warning_count": { "type": "integer", "minimum": 0 }
            }
        }
    }
}
