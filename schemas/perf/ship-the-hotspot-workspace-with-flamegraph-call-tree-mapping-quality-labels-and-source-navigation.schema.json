{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://aureline.dev/schemas/perf/ship-the-hotspot-workspace-with-flamegraph-call-tree-mapping-quality-labels-and-source-navigation.schema.json",
    "title": "Ship the Hotspot Workspace with Flamegraph, Call Tree, Mapping-Quality Labels, and Source Navigation",
    "description": "Schema for the M5 hotspot-workspace qualification packet that governs flamegraph rows, call-tree rows, session strips, mapping-quality badges, and source-navigation rows.",
    "type": "object",
    "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "as_of",
        "release_doc_ref",
        "help_doc_ref",
        "schema_ref",
        "surfaces",
        "flamegraph_rows",
        "call_tree_rows",
        "session_strips",
        "mapping_quality_badges",
        "source_navigations",
        "summary"
    ],
    "properties": {
        "schema_version": {
            "type": "integer",
            "minimum": 1,
            "description": "Schema version for this packet family."
        },
        "record_kind": {
            "type": "string",
            "const": "ship_the_hotspot_workspace_with_flamegraph_call_tree_mapping_quality_labels_and_source_navigation",
            "description": "Stable record-kind tag."
        },
        "packet_id": {
            "type": "string",
            "description": "Stable packet identifier."
        },
        "as_of": {
            "type": "string",
            "format": "date",
            "description": "Date the packet was captured."
        },
        "release_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the release reviewer document."
        },
        "help_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the help projection."
        },
        "schema_ref": {
            "type": "string",
            "description": "Repo-relative path to this schema."
        },
        "surfaces": {
            "type": "array",
            "items": { "$ref": "#/definitions/HotspotWorkspaceSurfaceQualificationRow" }
        },
        "flamegraph_rows": {
            "type": "array",
            "items": { "$ref": "#/definitions/FlamegraphRow" }
        },
        "call_tree_rows": {
            "type": "array",
            "items": { "$ref": "#/definitions/CallTreeRow" }
        },
        "session_strips": {
            "type": "array",
            "items": { "$ref": "#/definitions/SessionStripRow" }
        },
        "mapping_quality_badges": {
            "type": "array",
            "items": { "$ref": "#/definitions/MappingQualityBadgeRow" }
        },
        "source_navigations": {
            "type": "array",
            "items": { "$ref": "#/definitions/SourceNavigationRow" }
        },
        "summary": {
            "$ref": "#/definitions/HotspotWorkspaceQualificationSummary"
        }
    },
    "definitions": {
        "HotspotWorkspaceQualificationLabel": {
            "type": "string",
            "enum": [
                "stable",
                "preview",
                "labs",
                "inspect_only",
                "import_only"
            ]
        },
        "HotspotWorkspaceSurfaceKind": {
            "type": "string",
            "enum": [
                "flamegraph_view",
                "call_tree_view",
                "session_strip",
                "mapping_quality_badge",
                "source_navigation",
                "export_review",
                "support_export"
            ]
        },
        "MappingQualityLabel": {
            "type": "string",
            "enum": [
                "exact",
                "approximate",
                "partial",
                "unavailable",
                "stale",
                "mismatched"
            ]
        },
        "ProfilePosture": {
            "type": "string",
            "enum": [
                "live_capture",
                "imported_artifact",
                "cached_local_evidence",
                "stale_prior_result"
            ]
        },
        "SourceNavigationAction": {
            "type": "string",
            "enum": [
                "open_source",
                "open_caller",
                "open_callee",
                "open_raw"
            ]
        },
        "HotspotWorkspaceQualificationProof": {
            "type": "object",
            "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at"],
            "properties": {
                "packet_id": { "type": "string" },
                "packet_ref": { "type": "string" },
                "proof_index_ref": { "type": "string" },
                "captured_at": { "type": "string", "format": "date" },
                "evidence_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        },
        "HotspotWorkspaceSurfaceGuardSet": {
            "type": "object",
            "required": [
                "session_strip_visible",
                "mapping_quality_visible",
                "source_navigation_visible",
                "flamegraph_visible",
                "call_tree_visible",
                "thread_filter_visible",
                "export_posture_visible",
                "degraded_state_label_visible"
            ],
            "properties": {
                "session_strip_visible": { "type": "boolean" },
                "mapping_quality_visible": { "type": "boolean" },
                "source_navigation_visible": { "type": "boolean" },
                "flamegraph_visible": { "type": "boolean" },
                "call_tree_visible": { "type": "boolean" },
                "thread_filter_visible": { "type": "boolean" },
                "export_posture_visible": { "type": "boolean" },
                "degraded_state_label_visible": { "type": "boolean" }
            }
        },
        "HotspotWorkspaceSurfaceQualificationRow": {
            "type": "object",
            "required": [
                "surface_id",
                "title",
                "surface_kind",
                "promoted_build_surface",
                "claim_label",
                "displayed_label",
                "qualification_packet",
                "guards",
                "downgrade_if_missing",
                "rationale"
            ],
            "properties": {
                "surface_id": { "type": "string" },
                "title": { "type": "string" },
                "surface_kind": { "$ref": "#/definitions/HotspotWorkspaceSurfaceKind" },
                "promoted_build_surface": { "type": "boolean" },
                "claim_label": { "$ref": "#/definitions/HotspotWorkspaceQualificationLabel" },
                "displayed_label": { "type": "string" },
                "qualification_packet": { "$ref": "#/definitions/HotspotWorkspaceQualificationProof" },
                "guards": { "$ref": "#/definitions/HotspotWorkspaceSurfaceGuardSet" },
                "downgrade_if_missing": { "type": "boolean" },
                "rationale": { "type": "string" }
            }
        },
        "FlamegraphRow": {
            "type": "object",
            "required": [
                "frame_id",
                "title",
                "self_samples",
                "inclusive_samples",
                "depth",
                "thread_id",
                "mapping_quality",
                "has_source_navigation",
                "shows_mapping_quality"
            ],
            "properties": {
                "frame_id": { "type": "string" },
                "title": { "type": "string" },
                "self_samples": { "type": "integer", "minimum": 0 },
                "inclusive_samples": { "type": "integer", "minimum": 0 },
                "depth": { "type": "integer", "minimum": 0 },
                "thread_id": { "type": "string" },
                "mapping_quality": { "$ref": "#/definitions/MappingQualityLabel" },
                "source_ref": { "type": ["string", "null"] },
                "module_ref": { "type": ["string", "null"] },
                "has_source_navigation": { "type": "boolean" },
                "shows_mapping_quality": { "type": "boolean" }
            }
        },
        "CallTreeRow": {
            "type": "object",
            "required": [
                "frame_id",
                "function_name",
                "self_metric",
                "inclusive_metric",
                "file_module_service",
                "thread_id",
                "mapping_quality",
                "shows_symbolization_state",
                "has_caller_callee_navigation"
            ],
            "properties": {
                "frame_id": { "type": "string" },
                "function_name": { "type": "string" },
                "self_metric": { "type": "integer", "minimum": 0 },
                "inclusive_metric": { "type": "integer", "minimum": 0 },
                "file_module_service": { "type": "string" },
                "thread_id": { "type": "string" },
                "mapping_quality": { "$ref": "#/definitions/MappingQualityLabel" },
                "source_ref": { "type": ["string", "null"] },
                "caller_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "callee_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "shows_symbolization_state": { "type": "boolean" },
                "has_caller_callee_navigation": { "type": "boolean" }
            }
        },
        "SessionStripRow": {
            "type": "object",
            "required": [
                "strip_id",
                "workload_identity",
                "build_runtime_identity",
                "capture_mode",
                "mapping_quality_state",
                "capture_time",
                "duration_ms",
                "profile_posture",
                "shows_compare_export",
                "shows_degraded_label"
            ],
            "properties": {
                "strip_id": { "type": "string" },
                "workload_identity": { "type": "string" },
                "build_runtime_identity": { "type": "string" },
                "capture_mode": { "type": "string" },
                "mapping_quality_state": { "$ref": "#/definitions/MappingQualityLabel" },
                "capture_time": { "type": "string" },
                "duration_ms": { "type": "integer", "minimum": 0 },
                "profile_posture": { "$ref": "#/definitions/ProfilePosture" },
                "shows_compare_export": { "type": "boolean" },
                "shows_degraded_label": { "type": "boolean" }
            }
        },
        "MappingQualityBadgeRow": {
            "type": "object",
            "required": [
                "badge_id",
                "context_id",
                "mapping_quality",
                "shows_mapping_quality"
            ],
            "properties": {
                "badge_id": { "type": "string" },
                "context_id": { "type": "string" },
                "mapping_quality": { "$ref": "#/definitions/MappingQualityLabel" },
                "unresolved_frame_count": { "type": ["integer", "null"], "minimum": 0 },
                "imported_symbol_note": { "type": ["string", "null"] },
                "shows_mapping_quality": { "type": "boolean" }
            }
        },
        "SourceNavigationRow": {
            "type": "object",
            "required": [
                "navigation_id",
                "frame_id",
                "default_action",
                "mapping_quality",
                "shows_mapping_quality_before_jump"
            ],
            "properties": {
                "navigation_id": { "type": "string" },
                "frame_id": { "type": "string" },
                "available_actions": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/SourceNavigationAction" }
                },
                "default_action": { "$ref": "#/definitions/SourceNavigationAction" },
                "source_ref": { "type": ["string", "null"] },
                "line_number": { "type": ["integer", "null"], "minimum": 1 },
                "mapping_quality": { "$ref": "#/definitions/MappingQualityLabel" },
                "shows_mapping_quality_before_jump": { "type": "boolean" }
            }
        },
        "HotspotWorkspaceQualificationSummary": {
            "type": "object",
            "required": [
                "flamegraph_row_count",
                "call_tree_row_count",
                "session_strip_count",
                "mapping_quality_badge_count",
                "source_navigation_count",
                "stable_count",
                "below_stable_count",
                "all_below_stable_have_disclosure"
            ],
            "properties": {
                "flamegraph_row_count": { "type": "integer", "minimum": 0 },
                "call_tree_row_count": { "type": "integer", "minimum": 0 },
                "session_strip_count": { "type": "integer", "minimum": 0 },
                "mapping_quality_badge_count": { "type": "integer", "minimum": 0 },
                "source_navigation_count": { "type": "integer", "minimum": 0 },
                "stable_count": { "type": "integer", "minimum": 0 },
                "below_stable_count": { "type": "integer", "minimum": 0 },
                "all_below_stable_have_disclosure": { "type": "boolean" }
            }
        }
    }
}
