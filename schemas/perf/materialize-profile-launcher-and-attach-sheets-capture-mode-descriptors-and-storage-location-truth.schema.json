{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://aureline.dev/schemas/perf/materialize-profile-launcher-and-attach-sheets-capture-mode-descriptors-and-storage-location-truth.schema.json",
    "title": "Profile Launcher and Attach Sheets, Capture-Mode Descriptors, and Storage-Location Truth",
    "description": "Schema for the M5 profile-launcher qualification packet that governs profile launchers, attach sheets, capture-mode descriptors, and storage-location truth rows.",
    "type": "object",
    "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "as_of",
        "release_doc_ref",
        "help_doc_ref",
        "schema_ref",
        "surfaces",
        "launchers",
        "attach_sheets",
        "capture_modes",
        "storage_locations",
        "summary"
    ],
    "properties": {
        "schema_version": {
            "type": "integer",
            "minimum": 1,
            "description": "Schema version for this packet family."
        },
        "record_kind": {
            "type": "string",
            "const": "materialize_profile_launcher_and_attach_sheets_capture_mode_descriptors_and_storage_location_truth",
            "description": "Stable record-kind tag."
        },
        "packet_id": {
            "type": "string",
            "description": "Stable packet identifier."
        },
        "as_of": {
            "type": "string",
            "format": "date",
            "description": "Date the packet was captured."
        },
        "release_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the release reviewer document."
        },
        "help_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the help projection."
        },
        "schema_ref": {
            "type": "string",
            "description": "Repo-relative path to this schema."
        },
        "surfaces": {
            "type": "array",
            "items": { "$ref": "#/definitions/ProfileLauncherSurfaceQualificationRow" }
        },
        "launchers": {
            "type": "array",
            "items": { "$ref": "#/definitions/ProfileLauncherRow" }
        },
        "attach_sheets": {
            "type": "array",
            "items": { "$ref": "#/definitions/AttachSheetRow" }
        },
        "capture_modes": {
            "type": "array",
            "items": { "$ref": "#/definitions/CaptureModeDescriptorRow" }
        },
        "storage_locations": {
            "type": "array",
            "items": { "$ref": "#/definitions/StorageLocationTruthRow" }
        },
        "summary": {
            "$ref": "#/definitions/ProfileLauncherQualificationSummary"
        }
    },
    "definitions": {
        "ProfileLauncherQualificationLabel": {
            "type": "string",
            "enum": [
                "stable",
                "preview",
                "labs",
                "inspect_only",
                "import_only"
            ]
        },
        "ProfileLauncherSurfaceKind": {
            "type": "string",
            "enum": [
                "profile_launcher",
                "attach_sheet",
                "capture_mode_inspector",
                "storage_location_browser",
                "export_review",
                "support_export"
            ]
        },
        "ProfileLaunchMode": {
            "type": "string",
            "enum": [
                "launch",
                "attach",
                "import",
                "cached"
            ]
        },
        "AttachSheetKind": {
            "type": "string",
            "enum": [
                "process_picker",
                "pid_entry",
                "remote_attach",
                "notebook_kernel_attach",
                "browser_runtime_attach",
                "file_system_import",
                "support_bundle_import"
            ]
        },
        "CaptureModeClass": {
            "type": "string",
            "enum": [
                "time_sampling",
                "event_sampling",
                "instrumentation",
                "hybrid",
                "allocation_sampling",
                "render_timeline",
                "trace_span_collection",
                "replay_recording"
            ]
        },
        "StorageLocationClass": {
            "type": "string",
            "enum": [
                "local_temp",
                "local_cache",
                "workspace_relative",
                "remote_store",
                "support_bundle",
                "imported",
                "archived",
                "policy_blocked"
            ]
        },
        "StorageLocationTruthLabel": {
            "type": "string",
            "enum": [
                "current",
                "stale",
                "expired",
                "missing",
                "imported",
                "policy_blocked",
                "unverified"
            ]
        },
        "ProfileLauncherQualificationProof": {
            "type": "object",
            "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at"],
            "properties": {
                "packet_id": { "type": "string" },
                "packet_ref": { "type": "string" },
                "proof_index_ref": { "type": "string" },
                "captured_at": { "type": "string", "format": "date" },
                "evidence_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        },
        "ProfileLauncherSurfaceGuardSet": {
            "type": "object",
            "required": [
                "launch_mode_visible",
                "target_identity_visible",
                "capture_mode_visible",
                "storage_location_visible",
                "build_runtime_visible",
                "degraded_state_label_visible",
                "export_posture_visible",
                "retention_policy_visible"
            ],
            "properties": {
                "launch_mode_visible": { "type": "boolean" },
                "target_identity_visible": { "type": "boolean" },
                "capture_mode_visible": { "type": "boolean" },
                "storage_location_visible": { "type": "boolean" },
                "build_runtime_visible": { "type": "boolean" },
                "degraded_state_label_visible": { "type": "boolean" },
                "export_posture_visible": { "type": "boolean" },
                "retention_policy_visible": { "type": "boolean" }
            }
        },
        "ProfileLauncherSurfaceQualificationRow": {
            "type": "object",
            "required": [
                "surface_id",
                "title",
                "surface_kind",
                "promoted_build_surface",
                "claim_label",
                "displayed_label",
                "qualification_packet",
                "guards",
                "downgrade_if_missing",
                "rationale"
            ],
            "properties": {
                "surface_id": { "type": "string" },
                "title": { "type": "string" },
                "surface_kind": { "$ref": "#/definitions/ProfileLauncherSurfaceKind" },
                "promoted_build_surface": { "type": "boolean" },
                "claim_label": { "$ref": "#/definitions/ProfileLauncherQualificationLabel" },
                "displayed_label": { "type": "string" },
                "qualification_packet": { "$ref": "#/definitions/ProfileLauncherQualificationProof" },
                "guards": { "$ref": "#/definitions/ProfileLauncherSurfaceGuardSet" },
                "downgrade_if_missing": { "type": "boolean" },
                "rationale": { "type": "string" }
            }
        },
        "ProfileLauncherRow": {
            "type": "object",
            "required": [
                "launcher_id",
                "title",
                "launch_mode",
                "target_ref",
                "target_kind",
                "exact_build_identity_ref",
                "execution_context_id",
                "capture_mode_ref",
                "storage_location_ref",
                "promoted_build_surface"
            ],
            "properties": {
                "launcher_id": { "type": "string" },
                "title": { "type": "string" },
                "launch_mode": { "$ref": "#/definitions/ProfileLaunchMode" },
                "target_ref": { "type": "string" },
                "target_kind": { "type": "string" },
                "exact_build_identity_ref": { "type": "string" },
                "execution_context_id": { "type": "string" },
                "capture_mode_ref": { "type": "string" },
                "storage_location_ref": { "type": "string" },
                "promoted_build_surface": { "type": "boolean" }
            }
        },
        "AttachSheetRow": {
            "type": "object",
            "required": [
                "sheet_id",
                "title",
                "sheet_kind",
                "target_process_ref",
                "target_process_kind",
                "capture_mode_ref",
                "storage_location_ref",
                "promoted_build_surface",
                "shows_degraded_label"
            ],
            "properties": {
                "sheet_id": { "type": "string" },
                "title": { "type": "string" },
                "sheet_kind": { "$ref": "#/definitions/AttachSheetKind" },
                "target_process_ref": { "type": "string" },
                "target_process_kind": { "type": "string" },
                "exact_build_identity_ref": { "type": ["string", "null"] },
                "execution_context_id": { "type": ["string", "null"] },
                "capture_mode_ref": { "type": "string" },
                "storage_location_ref": { "type": "string" },
                "promoted_build_surface": { "type": "boolean" },
                "shows_degraded_label": { "type": "boolean" }
            }
        },
        "CaptureModeDescriptorRow": {
            "type": "object",
            "required": [
                "descriptor_id",
                "title",
                "capture_mode_class",
                "overhead_class",
                "mapping_quality",
                "selectable",
                "shows_overhead_warning",
                "shows_unavailable_reason"
            ],
            "properties": {
                "descriptor_id": { "type": "string" },
                "title": { "type": "string" },
                "capture_mode_class": { "$ref": "#/definitions/CaptureModeClass" },
                "sampling_interval_us": { "type": ["integer", "null"] },
                "event_counter": { "type": ["string", "null"] },
                "overhead_class": { "type": "string" },
                "mapping_quality": { "type": "string" },
                "selectable": { "type": "boolean" },
                "shows_overhead_warning": { "type": "boolean" },
                "shows_unavailable_reason": { "type": "boolean" }
            }
        },
        "StorageLocationTruthRow": {
            "type": "object",
            "required": [
                "location_id",
                "title",
                "location_class",
                "path_or_uri_ref",
                "retention_class",
                "freshness",
                "policy_posture",
                "shows_location_class",
                "shows_retention_policy",
                "warns_on_degraded_state"
            ],
            "properties": {
                "location_id": { "type": "string" },
                "title": { "type": "string" },
                "location_class": { "$ref": "#/definitions/StorageLocationClass" },
                "path_or_uri_ref": { "type": "string" },
                "retention_class": { "type": "string" },
                "freshness": { "$ref": "#/definitions/StorageLocationTruthLabel" },
                "provenance_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "policy_posture": { "type": "string" },
                "shows_location_class": { "type": "boolean" },
                "shows_retention_policy": { "type": "boolean" },
                "warns_on_degraded_state": { "type": "boolean" }
            }
        },
        "ProfileLauncherQualificationSummary": {
            "type": "object",
            "required": [
                "launcher_count",
                "attach_sheet_count",
                "capture_mode_count",
                "storage_location_count",
                "stable_count",
                "below_stable_count",
                "all_below_stable_have_disclosure"
            ],
            "properties": {
                "launcher_count": { "type": "integer", "minimum": 0 },
                "attach_sheet_count": { "type": "integer", "minimum": 0 },
                "capture_mode_count": { "type": "integer", "minimum": 0 },
                "storage_location_count": { "type": "integer", "minimum": 0 },
                "stable_count": { "type": "integer", "minimum": 0 },
                "below_stable_count": { "type": "integer", "minimum": 0 },
                "all_below_stable_have_disclosure": { "type": "boolean" }
            }
        }
    }
}
