{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://aureline.dev/schemas/perf/integrate-profile-and-trace-artifacts-into-incident-workspaces-ai-explanations-and-support-bundles.schema.json",
    "title": "Integrate Profile and Trace Artifacts into Incident Workspaces, AI Explanations, and Support Bundles",
    "description": "Schema for the M5 integration qualification packet that governs incident workspace attachments, AI explanations, and support bundle inclusions for profile and trace artifacts.",
    "type": "object",
    "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "as_of",
        "release_doc_ref",
        "help_doc_ref",
        "schema_ref",
        "surfaces",
        "incident_workspace_attachments",
        "ai_explanations",
        "support_bundle_inclusions",
        "summary"
    ],
    "properties": {
        "schema_version": {
            "type": "integer",
            "minimum": 1,
            "description": "Schema version for this packet family."
        },
        "record_kind": {
            "type": "string",
            "const": "integrate_profile_and_trace_artifacts_into_incident_workspaces_ai_explanations_and_support_bundles",
            "description": "Stable record-kind tag."
        },
        "packet_id": {
            "type": "string",
            "description": "Stable packet identifier."
        },
        "as_of": {
            "type": "string",
            "format": "date",
            "description": "Date the packet was captured."
        },
        "release_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the release reviewer document."
        },
        "help_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the help projection."
        },
        "schema_ref": {
            "type": "string",
            "description": "Repo-relative path to this schema."
        },
        "surfaces": {
            "type": "array",
            "items": { "$ref": "#/definitions/IntegrateProfileTraceSurfaceQualificationRow" }
        },
        "incident_workspace_attachments": {
            "type": "array",
            "items": { "$ref": "#/definitions/IncidentWorkspaceAttachmentRow" }
        },
        "ai_explanations": {
            "type": "array",
            "items": { "$ref": "#/definitions/AiExplanationRow" }
        },
        "support_bundle_inclusions": {
            "type": "array",
            "items": { "$ref": "#/definitions/SupportBundleInclusionRow" }
        },
        "summary": {
            "$ref": "#/definitions/IntegrateProfileTraceQualificationSummary"
        }
    },
    "definitions": {
        "IntegrateProfileTraceQualificationLabel": {
            "type": "string",
            "enum": [
                "stable",
                "preview",
                "labs",
                "inspect_only",
                "import_only"
            ]
        },
        "IntegrateProfileTraceSurfaceKind": {
            "type": "string",
            "enum": [
                "incident_workspace_attachment",
                "ai_explanation",
                "support_bundle_inclusion",
                "export_review",
                "cross_reference_integrity"
            ]
        },
        "ArtifactAttachmentKind": {
            "type": "string",
            "enum": [
                "profile",
                "trace",
                "replay_timeline",
                "memory_snapshot",
                "coverage",
                "test_result",
                "debug_session",
                "notebook_output"
            ]
        },
        "AiExplanationKind": {
            "type": "string",
            "enum": [
                "summary",
                "hotspot_explanation",
                "regression_explanation",
                "trace_narrative",
                "comparison_narrative",
                "anomaly_explanation"
            ]
        },
        "SupportBundleInclusionKind": {
            "type": "string",
            "enum": [
                "full_artifact",
                "metadata_only",
                "redacted_summary",
                "reference_only"
            ]
        },
        "ExplanationConfidence": {
            "type": "string",
            "enum": [
                "high",
                "medium",
                "low",
                "uncertain"
            ]
        },
        "BaselineFreshness": {
            "type": "string",
            "enum": [
                "current",
                "stale",
                "expired",
                "missing",
                "imported",
                "unverified"
            ]
        },
        "IntegrateProfileTraceQualificationProof": {
            "type": "object",
            "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at"],
            "properties": {
                "packet_id": { "type": "string" },
                "packet_ref": { "type": "string" },
                "proof_index_ref": { "type": "string" },
                "captured_at": { "type": "string", "format": "date" },
                "evidence_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        },
        "IntegrateProfileTraceSurfaceGuardSet": {
            "type": "object",
            "required": [
                "artifact_origin_visible",
                "build_identity_visible",
                "mapping_quality_visible",
                "comparison_basis_visible",
                "export_posture_visible",
                "incident_workspace_link_visible",
                "ai_explanation_visible",
                "support_bundle_link_visible",
                "degraded_state_label_visible"
            ],
            "properties": {
                "artifact_origin_visible": { "type": "boolean" },
                "build_identity_visible": { "type": "boolean" },
                "mapping_quality_visible": { "type": "boolean" },
                "comparison_basis_visible": { "type": "boolean" },
                "export_posture_visible": { "type": "boolean" },
                "incident_workspace_link_visible": { "type": "boolean" },
                "ai_explanation_visible": { "type": "boolean" },
                "support_bundle_link_visible": { "type": "boolean" },
                "degraded_state_label_visible": { "type": "boolean" }
            }
        },
        "IntegrateProfileTraceSurfaceQualificationRow": {
            "type": "object",
            "required": [
                "surface_id",
                "title",
                "surface_kind",
                "promoted_build_surface",
                "claim_label",
                "displayed_label",
                "qualification_packet",
                "guards",
                "downgrade_if_missing",
                "rationale"
            ],
            "properties": {
                "surface_id": { "type": "string" },
                "title": { "type": "string" },
                "surface_kind": { "$ref": "#/definitions/IntegrateProfileTraceSurfaceKind" },
                "promoted_build_surface": { "type": "boolean" },
                "claim_label": { "$ref": "#/definitions/IntegrateProfileTraceQualificationLabel" },
                "displayed_label": { "type": "string" },
                "qualification_packet": { "$ref": "#/definitions/IntegrateProfileTraceQualificationProof" },
                "guards": { "$ref": "#/definitions/IntegrateProfileTraceSurfaceGuardSet" },
                "downgrade_if_missing": { "type": "boolean" },
                "rationale": { "type": "string" }
            }
        },
        "IncidentWorkspaceAttachmentRow": {
            "type": "object",
            "required": [
                "attachment_id",
                "title",
                "artifact_kind",
                "incident_workspace_ref",
                "artifact_ref",
                "lineage_ref",
                "build_identity_ref",
                "environment_fingerprint_ref",
                "capture_mode_ref",
                "mapping_quality_ref",
                "freshness",
                "promoted_build_surface",
                "shows_artifact_origin",
                "shows_build_identity",
                "shows_environment_fingerprint",
                "shows_capture_mode",
                "shows_mapping_quality",
                "shows_freshness",
                "shows_incident_workspace_link"
            ],
            "properties": {
                "attachment_id": { "type": "string" },
                "title": { "type": "string" },
                "artifact_kind": { "$ref": "#/definitions/ArtifactAttachmentKind" },
                "incident_workspace_ref": { "type": "string" },
                "artifact_ref": { "type": "string" },
                "lineage_ref": { "type": "string" },
                "build_identity_ref": { "type": "string" },
                "environment_fingerprint_ref": { "type": "string" },
                "capture_mode_ref": { "type": "string" },
                "mapping_quality_ref": { "type": "string" },
                "freshness": { "$ref": "#/definitions/BaselineFreshness" },
                "promoted_build_surface": { "type": "boolean" },
                "shows_artifact_origin": { "type": "boolean" },
                "shows_build_identity": { "type": "boolean" },
                "shows_environment_fingerprint": { "type": "boolean" },
                "shows_capture_mode": { "type": "boolean" },
                "shows_mapping_quality": { "type": "boolean" },
                "shows_freshness": { "type": "boolean" },
                "shows_incident_workspace_link": { "type": "boolean" }
            }
        },
        "AiExplanationRow": {
            "type": "object",
            "required": [
                "explanation_id",
                "title",
                "explanation_kind",
                "artifact_ref",
                "lineage_ref",
                "confidence",
                "build_identity_ref",
                "environment_fingerprint_ref",
                "capture_mode_ref",
                "mapping_quality_ref",
                "comparison_basis_ref",
                "promoted_build_surface",
                "shows_confidence",
                "shows_artifact_origin",
                "shows_build_identity",
                "shows_environment_fingerprint",
                "shows_capture_mode",
                "shows_mapping_quality",
                "shows_comparison_basis"
            ],
            "properties": {
                "explanation_id": { "type": "string" },
                "title": { "type": "string" },
                "explanation_kind": { "$ref": "#/definitions/AiExplanationKind" },
                "artifact_ref": { "type": "string" },
                "lineage_ref": { "type": "string" },
                "confidence": { "$ref": "#/definitions/ExplanationConfidence" },
                "build_identity_ref": { "type": "string" },
                "environment_fingerprint_ref": { "type": "string" },
                "capture_mode_ref": { "type": "string" },
                "mapping_quality_ref": { "type": "string" },
                "comparison_basis_ref": { "type": "string" },
                "promoted_build_surface": { "type": "boolean" },
                "shows_confidence": { "type": "boolean" },
                "shows_artifact_origin": { "type": "boolean" },
                "shows_build_identity": { "type": "boolean" },
                "shows_environment_fingerprint": { "type": "boolean" },
                "shows_capture_mode": { "type": "boolean" },
                "shows_mapping_quality": { "type": "boolean" },
                "shows_comparison_basis": { "type": "boolean" }
            }
        },
        "SupportBundleInclusionRow": {
            "type": "object",
            "required": [
                "inclusion_id",
                "title",
                "inclusion_kind",
                "artifact_ref",
                "lineage_ref",
                "bundle_ref",
                "build_identity_ref",
                "environment_fingerprint_ref",
                "capture_mode_ref",
                "mapping_quality_ref",
                "redaction_profile_ref",
                "export_posture_ref",
                "promoted_build_surface",
                "shows_inclusion_kind",
                "shows_artifact_origin",
                "shows_build_identity",
                "shows_environment_fingerprint",
                "shows_capture_mode",
                "shows_mapping_quality",
                "shows_redaction_profile",
                "shows_export_posture"
            ],
            "properties": {
                "inclusion_id": { "type": "string" },
                "title": { "type": "string" },
                "inclusion_kind": { "$ref": "#/definitions/SupportBundleInclusionKind" },
                "artifact_ref": { "type": "string" },
                "lineage_ref": { "type": "string" },
                "bundle_ref": { "type": "string" },
                "build_identity_ref": { "type": "string" },
                "environment_fingerprint_ref": { "type": "string" },
                "capture_mode_ref": { "type": "string" },
                "mapping_quality_ref": { "type": "string" },
                "redaction_profile_ref": { "type": "string" },
                "export_posture_ref": { "type": "string" },
                "promoted_build_surface": { "type": "boolean" },
                "shows_inclusion_kind": { "type": "boolean" },
                "shows_artifact_origin": { "type": "boolean" },
                "shows_build_identity": { "type": "boolean" },
                "shows_environment_fingerprint": { "type": "boolean" },
                "shows_capture_mode": { "type": "boolean" },
                "shows_mapping_quality": { "type": "boolean" },
                "shows_redaction_profile": { "type": "boolean" },
                "shows_export_posture": { "type": "boolean" }
            }
        },
        "IntegrateProfileTraceQualificationSummary": {
            "type": "object",
            "required": [
                "incident_workspace_attachment_count",
                "ai_explanation_count",
                "support_bundle_inclusion_count",
                "stable_count",
                "below_stable_count",
                "all_below_stable_have_disclosure",
                "usable_attachment_count",
                "honest_explanation_count",
                "honest_inclusion_count"
            ],
            "properties": {
                "incident_workspace_attachment_count": { "type": "integer", "minimum": 0 },
                "ai_explanation_count": { "type": "integer", "minimum": 0 },
                "support_bundle_inclusion_count": { "type": "integer", "minimum": 0 },
                "stable_count": { "type": "integer", "minimum": 0 },
                "below_stable_count": { "type": "integer", "minimum": 0 },
                "all_below_stable_have_disclosure": { "type": "boolean" },
                "usable_attachment_count": { "type": "integer", "minimum": 0 },
                "honest_explanation_count": { "type": "integer", "minimum": 0 },
                "honest_inclusion_count": { "type": "integer", "minimum": 0 }
            }
        }
    }
}
