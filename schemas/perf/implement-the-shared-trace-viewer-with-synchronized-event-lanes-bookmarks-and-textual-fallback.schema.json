{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://aureline.dev/schemas/perf/implement-the-shared-trace-viewer-with-synchronized-event-lanes-bookmarks-and-textual-fallback.schema.json",
    "title": "Shared Trace Viewer with Synchronized Event Lanes, Bookmarks, and Textual Fallback",
    "description": "Schema for the M5 trace-viewer qualification packet that governs event-lane rows, bookmark rows, textual-fallback rows, and surface guard sets.",
    "type": "object",
    "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "as_of",
        "release_doc_ref",
        "help_doc_ref",
        "schema_ref",
        "surfaces",
        "event_lanes",
        "bookmarks",
        "textual_fallbacks",
        "summary"
    ],
    "properties": {
        "schema_version": {
            "type": "integer",
            "minimum": 1,
            "description": "Schema version for this packet family."
        },
        "record_kind": {
            "type": "string",
            "const": "implement_the_shared_trace_viewer_with_synchronized_event_lanes_bookmarks_and_textual_fallback",
            "description": "Stable record-kind tag."
        },
        "packet_id": {
            "type": "string",
            "description": "Stable packet identifier."
        },
        "as_of": {
            "type": "string",
            "format": "date",
            "description": "Date the packet was captured."
        },
        "release_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the release reviewer document."
        },
        "help_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the help projection."
        },
        "schema_ref": {
            "type": "string",
            "description": "Repo-relative path to this schema."
        },
        "surfaces": {
            "type": "array",
            "items": { "$ref": "#/definitions/TraceViewerSurfaceQualificationRow" }
        },
        "event_lanes": {
            "type": "array",
            "items": { "$ref": "#/definitions/EventLaneRow" }
        },
        "bookmarks": {
            "type": "array",
            "items": { "$ref": "#/definitions/BookmarkRow" }
        },
        "textual_fallbacks": {
            "type": "array",
            "items": { "$ref": "#/definitions/TextualFallbackRow" }
        },
        "summary": {
            "$ref": "#/definitions/TraceViewerQualificationSummary"
        }
    },
    "definitions": {
        "TraceViewerQualificationLabel": {
            "type": "string",
            "enum": [
                "stable",
                "preview",
                "labs",
                "inspect_only",
                "import_only"
            ]
        },
        "TraceViewerSurfaceKind": {
            "type": "string",
            "enum": [
                "event_lane_view",
                "bookmark_panel",
                "textual_fallback_view",
                "trace_comparison",
                "export_review",
                "support_export"
            ]
        },
        "EventLaneKind": {
            "type": "string",
            "enum": [
                "thread_lane",
                "stream_lane",
                "category_lane",
                "merged_lane"
            ]
        },
        "TraceMappingQualityLabel": {
            "type": "string",
            "enum": [
                "exact",
                "approximate",
                "partial",
                "unavailable",
                "stale",
                "mismatched"
            ]
        },
        "TextualFallbackContentKind": {
            "type": "string",
            "enum": [
                "structured_events",
                "raw_spans",
                "annotated_log",
                "comparison_diff"
            ]
        },
        "TraceViewerQualificationProof": {
            "type": "object",
            "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at"],
            "properties": {
                "packet_id": { "type": "string" },
                "packet_ref": { "type": "string" },
                "proof_index_ref": { "type": "string" },
                "captured_at": { "type": "string", "format": "date" },
                "evidence_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        },
        "TraceViewerSurfaceGuardSet": {
            "type": "object",
            "required": [
                "event_lanes_visible",
                "bookmarks_visible",
                "textual_fallback_visible",
                "synchronization_visible",
                "mapping_quality_visible",
                "export_posture_visible",
                "degraded_state_label_visible"
            ],
            "properties": {
                "event_lanes_visible": { "type": "boolean" },
                "bookmarks_visible": { "type": "boolean" },
                "textual_fallback_visible": { "type": "boolean" },
                "synchronization_visible": { "type": "boolean" },
                "mapping_quality_visible": { "type": "boolean" },
                "export_posture_visible": { "type": "boolean" },
                "degraded_state_label_visible": { "type": "boolean" }
            }
        },
        "TraceViewerSurfaceQualificationRow": {
            "type": "object",
            "required": [
                "surface_id",
                "title",
                "surface_kind",
                "promoted_build_surface",
                "claim_label",
                "displayed_label",
                "qualification_packet",
                "guards",
                "downgrade_if_missing",
                "rationale"
            ],
            "properties": {
                "surface_id": { "type": "string" },
                "title": { "type": "string" },
                "surface_kind": { "$ref": "#/definitions/TraceViewerSurfaceKind" },
                "promoted_build_surface": { "type": "boolean" },
                "claim_label": { "$ref": "#/definitions/TraceViewerQualificationLabel" },
                "displayed_label": { "type": "string" },
                "qualification_packet": { "$ref": "#/definitions/TraceViewerQualificationProof" },
                "guards": { "$ref": "#/definitions/TraceViewerSurfaceGuardSet" },
                "downgrade_if_missing": { "type": "boolean" },
                "rationale": { "type": "string" }
            }
        },
        "EventLaneRow": {
            "type": "object",
            "required": [
                "lane_id",
                "title",
                "lane_kind",
                "thread_or_stream_ref",
                "event_count",
                "start_ns",
                "end_ns",
                "mapping_quality",
                "shows_mapping_quality",
                "shows_degraded_label"
            ],
            "properties": {
                "lane_id": { "type": "string" },
                "title": { "type": "string" },
                "lane_kind": { "$ref": "#/definitions/EventLaneKind" },
                "thread_or_stream_ref": { "type": "string" },
                "event_count": { "type": "integer", "minimum": 0 },
                "start_ns": { "type": "integer", "minimum": 0 },
                "end_ns": { "type": "integer", "minimum": 0 },
                "synchronized_with": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "mapping_quality": { "$ref": "#/definitions/TraceMappingQualityLabel" },
                "shows_mapping_quality": { "type": "boolean" },
                "shows_degraded_label": { "type": "boolean" }
            }
        },
        "BookmarkRow": {
            "type": "object",
            "required": [
                "bookmark_id",
                "title",
                "timestamp_ns",
                "lane_ref",
                "category",
                "created_by",
                "shows_provenance"
            ],
            "properties": {
                "bookmark_id": { "type": "string" },
                "title": { "type": "string" },
                "timestamp_ns": { "type": "integer", "minimum": 0 },
                "lane_ref": { "type": "string" },
                "category": { "type": "string" },
                "note": { "type": ["string", "null"] },
                "created_by": { "type": "string" },
                "shows_provenance": { "type": "boolean" }
            }
        },
        "TextualFallbackRow": {
            "type": "object",
            "required": [
                "fallback_id",
                "title",
                "content_kind",
                "mapping_quality",
                "shows_mapping_quality"
            ],
            "properties": {
                "fallback_id": { "type": "string" },
                "title": { "type": "string" },
                "content_kind": { "$ref": "#/definitions/TextualFallbackContentKind" },
                "raw_lines": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "source_event_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "mapping_quality": { "$ref": "#/definitions/TraceMappingQualityLabel" },
                "shows_mapping_quality": { "type": "boolean" }
            }
        },
        "TraceViewerQualificationSummary": {
            "type": "object",
            "required": [
                "event_lane_count",
                "bookmark_count",
                "textual_fallback_count",
                "stable_count",
                "below_stable_count",
                "all_below_stable_have_disclosure"
            ],
            "properties": {
                "event_lane_count": { "type": "integer", "minimum": 0 },
                "bookmark_count": { "type": "integer", "minimum": 0 },
                "textual_fallback_count": { "type": "integer", "minimum": 0 },
                "stable_count": { "type": "integer", "minimum": 0 },
                "below_stable_count": { "type": "integer", "minimum": 0 },
                "all_below_stable_have_disclosure": { "type": "boolean" }
            }
        }
    }
}
