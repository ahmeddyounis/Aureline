{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://aureline.dev/schemas/perf/build-the-regression-baseline-store-baseline-selection-ux-and-comparable-environment-guards.schema.json",
    "title": "Regression Baseline Store, Baseline Selection UX, and Comparable-Environment Guards",
    "description": "Schema for the M5 regression-baseline qualification packet that governs baseline-store rows, baseline-selection UX rows, comparable-environment guard rows, and environment-fingerprint rows.",
    "type": "object",
    "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "as_of",
        "release_doc_ref",
        "help_doc_ref",
        "schema_ref",
        "surfaces",
        "baseline_stores",
        "baseline_selection_uxs",
        "comparable_environment_guards",
        "environment_fingerprints",
        "summary"
    ],
    "properties": {
        "schema_version": {
            "type": "integer",
            "minimum": 1,
            "description": "Schema version for this packet family."
        },
        "record_kind": {
            "type": "string",
            "const": "build_the_regression_baseline_store_baseline_selection_ux_and_comparable_environment_guards",
            "description": "Stable record-kind tag."
        },
        "packet_id": {
            "type": "string",
            "description": "Stable packet identifier."
        },
        "as_of": {
            "type": "string",
            "format": "date",
            "description": "Date the packet was captured."
        },
        "release_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the release reviewer document."
        },
        "help_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the help projection."
        },
        "schema_ref": {
            "type": "string",
            "description": "Repo-relative path to this schema."
        },
        "surfaces": {
            "type": "array",
            "items": { "$ref": "#/definitions/RegressionBaselineSurfaceQualificationRow" }
        },
        "baseline_stores": {
            "type": "array",
            "items": { "$ref": "#/definitions/BaselineStoreRow" }
        },
        "baseline_selection_uxs": {
            "type": "array",
            "items": { "$ref": "#/definitions/BaselineSelectionUxRow" }
        },
        "comparable_environment_guards": {
            "type": "array",
            "items": { "$ref": "#/definitions/ComparableEnvironmentGuardRow" }
        },
        "environment_fingerprints": {
            "type": "array",
            "items": { "$ref": "#/definitions/EnvironmentFingerprintRow" }
        },
        "summary": {
            "$ref": "#/definitions/RegressionBaselineQualificationSummary"
        }
    },
    "definitions": {
        "RegressionBaselineQualificationLabel": {
            "type": "string",
            "enum": [
                "stable",
                "preview",
                "labs",
                "inspect_only",
                "import_only"
            ]
        },
        "RegressionBaselineSurfaceKind": {
            "type": "string",
            "enum": [
                "baseline_store",
                "baseline_selection_ux",
                "comparison_report",
                "environment_guard_inspector",
                "export_review",
                "support_export"
            ]
        },
        "BaselineFreshness": {
            "type": "string",
            "enum": [
                "current",
                "stale",
                "expired",
                "missing",
                "imported",
                "unverified"
            ]
        },
        "BaselineSelectionKind": {
            "type": "string",
            "enum": [
                "picker",
                "list",
                "recent",
                "pinned"
            ]
        },
        "EnvironmentMatchState": {
            "type": "string",
            "enum": [
                "comparable",
                "partial",
                "mismatch",
                "unknown",
                "stale"
            ]
        },
        "RegressionBaselineQualificationProof": {
            "type": "object",
            "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at"],
            "properties": {
                "packet_id": { "type": "string" },
                "packet_ref": { "type": "string" },
                "proof_index_ref": { "type": "string" },
                "captured_at": { "type": "string", "format": "date" },
                "evidence_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        },
        "RegressionBaselineSurfaceGuardSet": {
            "type": "object",
            "required": [
                "baseline_identity_visible",
                "build_identity_visible",
                "environment_fingerprint_visible",
                "capture_mode_visible",
                "storage_location_visible",
                "freshness_state_visible",
                "comparison_basis_visible",
                "environment_match_visible",
                "mismatch_warning_visible",
                "guard_criteria_visible",
                "degraded_state_label_visible"
            ],
            "properties": {
                "baseline_identity_visible": { "type": "boolean" },
                "build_identity_visible": { "type": "boolean" },
                "environment_fingerprint_visible": { "type": "boolean" },
                "capture_mode_visible": { "type": "boolean" },
                "storage_location_visible": { "type": "boolean" },
                "freshness_state_visible": { "type": "boolean" },
                "comparison_basis_visible": { "type": "boolean" },
                "environment_match_visible": { "type": "boolean" },
                "mismatch_warning_visible": { "type": "boolean" },
                "guard_criteria_visible": { "type": "boolean" },
                "degraded_state_label_visible": { "type": "boolean" }
            }
        },
        "RegressionBaselineSurfaceQualificationRow": {
            "type": "object",
            "required": [
                "surface_id",
                "title",
                "surface_kind",
                "promoted_build_surface",
                "claim_label",
                "displayed_label",
                "qualification_packet",
                "guards",
                "downgrade_if_missing",
                "rationale"
            ],
            "properties": {
                "surface_id": { "type": "string" },
                "title": { "type": "string" },
                "surface_kind": { "$ref": "#/definitions/RegressionBaselineSurfaceKind" },
                "promoted_build_surface": { "type": "boolean" },
                "claim_label": { "$ref": "#/definitions/RegressionBaselineQualificationLabel" },
                "displayed_label": { "type": "string" },
                "qualification_packet": { "$ref": "#/definitions/RegressionBaselineQualificationProof" },
                "guards": { "$ref": "#/definitions/RegressionBaselineSurfaceGuardSet" },
                "downgrade_if_missing": { "type": "boolean" },
                "rationale": { "type": "string" }
            }
        },
        "BaselineStoreRow": {
            "type": "object",
            "required": [
                "baseline_id",
                "title",
                "exact_build_identity_ref",
                "environment_fingerprint_ref",
                "capture_mode_ref",
                "storage_location_ref",
                "freshness",
                "promoted_build_surface",
                "shows_freshness_state",
                "shows_build_identity"
            ],
            "properties": {
                "baseline_id": { "type": "string" },
                "title": { "type": "string" },
                "exact_build_identity_ref": { "type": "string" },
                "environment_fingerprint_ref": { "type": "string" },
                "capture_mode_ref": { "type": "string" },
                "storage_location_ref": { "type": "string" },
                "freshness": { "$ref": "#/definitions/BaselineFreshness" },
                "provenance_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "promoted_build_surface": { "type": "boolean" },
                "shows_freshness_state": { "type": "boolean" },
                "shows_build_identity": { "type": "boolean" }
            }
        },
        "BaselineSelectionUxRow": {
            "type": "object",
            "required": [
                "selection_id",
                "title",
                "selection_kind",
                "comparison_basis_label",
                "baseline_ref",
                "current_environment_fingerprint_ref",
                "environment_match_state",
                "shows_mismatch_warning",
                "shows_stale_warning",
                "promoted_build_surface"
            ],
            "properties": {
                "selection_id": { "type": "string" },
                "title": { "type": "string" },
                "selection_kind": { "$ref": "#/definitions/BaselineSelectionKind" },
                "comparison_basis_label": { "type": "string" },
                "baseline_ref": { "type": "string" },
                "current_environment_fingerprint_ref": { "type": "string" },
                "environment_match_state": { "$ref": "#/definitions/EnvironmentMatchState" },
                "shows_mismatch_warning": { "type": "boolean" },
                "shows_stale_warning": { "type": "boolean" },
                "promoted_build_surface": { "type": "boolean" }
            }
        },
        "ComparableEnvironmentGuardRow": {
            "type": "object",
            "required": [
                "guard_id",
                "title",
                "exact_build_identity_required",
                "architecture_required",
                "os_version_required",
                "runtime_version_required",
                "capture_mode_compatible_required",
                "mapping_quality_compatible_required",
                "freshness_policy",
                "enforced_in_build",
                "shows_criteria_breakdown",
                "narrows_claim_on_mismatch"
            ],
            "properties": {
                "guard_id": { "type": "string" },
                "title": { "type": "string" },
                "exact_build_identity_required": { "type": "boolean" },
                "architecture_required": { "type": "boolean" },
                "os_version_required": { "type": "boolean" },
                "runtime_version_required": { "type": "boolean" },
                "capture_mode_compatible_required": { "type": "boolean" },
                "mapping_quality_compatible_required": { "type": "boolean" },
                "freshness_policy": { "type": "string" },
                "enforced_in_build": { "type": "boolean" },
                "shows_criteria_breakdown": { "type": "boolean" },
                "narrows_claim_on_mismatch": { "type": "boolean" }
            }
        },
        "EnvironmentFingerprintRow": {
            "type": "object",
            "required": [
                "fingerprint_id",
                "title",
                "architecture",
                "os_version",
                "runtime_version",
                "build_identity_ref"
            ],
            "properties": {
                "fingerprint_id": { "type": "string" },
                "title": { "type": "string" },
                "architecture": { "type": "string" },
                "os_version": { "type": "string" },
                "runtime_version": { "type": "string" },
                "build_identity_ref": { "type": "string" },
                "extra_traits": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        },
        "RegressionBaselineQualificationSummary": {
            "type": "object",
            "required": [
                "baseline_store_count",
                "baseline_selection_ux_count",
                "comparable_environment_guard_count",
                "environment_fingerprint_count",
                "stable_count",
                "below_stable_count",
                "all_below_stable_have_disclosure",
                "usable_baseline_count",
                "narrowing_guard_count"
            ],
            "properties": {
                "baseline_store_count": { "type": "integer", "minimum": 0 },
                "baseline_selection_ux_count": { "type": "integer", "minimum": 0 },
                "comparable_environment_guard_count": { "type": "integer", "minimum": 0 },
                "environment_fingerprint_count": { "type": "integer", "minimum": 0 },
                "stable_count": { "type": "integer", "minimum": 0 },
                "below_stable_count": { "type": "integer", "minimum": 0 },
                "all_below_stable_have_disclosure": { "type": "boolean" },
                "usable_baseline_count": { "type": "integer", "minimum": 0 },
                "narrowing_guard_count": { "type": "integer", "minimum": 0 }
            }
        }
    }
}
