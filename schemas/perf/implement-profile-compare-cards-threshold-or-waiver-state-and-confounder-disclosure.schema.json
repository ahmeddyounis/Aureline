{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://aureline.dev/schemas/perf/implement-profile-compare-cards-threshold-or-waiver-state-and-confounder-disclosure.schema.json",
    "title": "Profile-Compare Cards, Threshold or Waiver State, and Confounder Disclosure",
    "description": "Schema for the M5 profile-compare qualification packet that governs profile-compare card rows, threshold-state rows, waiver-state rows, and confounder-disclosure rows.",
    "type": "object",
    "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "as_of",
        "release_doc_ref",
        "help_doc_ref",
        "schema_ref",
        "surfaces",
        "compare_cards",
        "threshold_states",
        "waiver_states",
        "confounder_disclosures",
        "summary"
    ],
    "properties": {
        "schema_version": {
            "type": "integer",
            "minimum": 1,
            "description": "Schema version for this packet family."
        },
        "record_kind": {
            "type": "string",
            "const": "implement_profile_compare_cards_threshold_or_waiver_state_and_confounder_disclosure",
            "description": "Stable record-kind tag."
        },
        "packet_id": {
            "type": "string",
            "description": "Stable packet identifier."
        },
        "as_of": {
            "type": "string",
            "format": "date",
            "description": "Date the packet was captured."
        },
        "release_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the release reviewer document."
        },
        "help_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the help projection."
        },
        "schema_ref": {
            "type": "string",
            "description": "Repo-relative path to this schema."
        },
        "surfaces": {
            "type": "array",
            "items": { "$ref": "#/definitions/ProfileCompareSurfaceQualificationRow" }
        },
        "compare_cards": {
            "type": "array",
            "items": { "$ref": "#/definitions/ProfileCompareCardRow" }
        },
        "threshold_states": {
            "type": "array",
            "items": { "$ref": "#/definitions/ThresholdStateRow" }
        },
        "waiver_states": {
            "type": "array",
            "items": { "$ref": "#/definitions/WaiverStateRow" }
        },
        "confounder_disclosures": {
            "type": "array",
            "items": { "$ref": "#/definitions/ConfounderDisclosureRow" }
        },
        "summary": {
            "$ref": "#/definitions/ProfileCompareQualificationSummary"
        }
    },
    "definitions": {
        "ProfileCompareQualificationLabel": {
            "type": "string",
            "enum": [
                "stable",
                "preview",
                "labs",
                "inspect_only",
                "import_only"
            ]
        },
        "ProfileCompareSurfaceKind": {
            "type": "string",
            "enum": [
                "profile_compare_card",
                "threshold_inspector",
                "waiver_badge",
                "confounder_disclosure_panel",
                "export_review",
                "support_export"
            ]
        },
        "ThresholdState": {
            "type": "string",
            "enum": [
                "within",
                "warning",
                "breach",
                "waived",
                "provisional"
            ]
        },
        "WaiverStatus": {
            "type": "string",
            "enum": [
                "active",
                "expired",
                "pending",
                "retired"
            ]
        },
        "ConfounderSeverity": {
            "type": "string",
            "enum": [
                "critical",
                "major",
                "minor",
                "info"
            ]
        },
        "ConfounderKind": {
            "type": "string",
            "enum": [
                "build_mismatch",
                "environment_drift",
                "capture_mode_diff",
                "mapping_quality_degraded",
                "sample_size_insufficient",
                "thermal_throttle",
                "clock_skew",
                "other"
            ]
        },
        "ComparisonKind": {
            "type": "string",
            "enum": [
                "side_by_side",
                "delta",
                "trend",
                "baseline_vs_current"
            ]
        },
        "ProfileCompareQualificationProof": {
            "type": "object",
            "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at"],
            "properties": {
                "packet_id": { "type": "string" },
                "packet_ref": { "type": "string" },
                "proof_index_ref": { "type": "string" },
                "captured_at": { "type": "string", "format": "date" },
                "evidence_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        },
        "ProfileCompareSurfaceGuardSet": {
            "type": "object",
            "required": [
                "compare_card_visible",
                "threshold_inspector_visible",
                "waiver_badge_visible",
                "confounder_disclosure_visible",
                "capture_identity_visible",
                "comparison_basis_visible",
                "threshold_bar_visible",
                "waiver_expiry_visible",
                "degraded_state_label_visible",
                "mapping_quality_visible"
            ],
            "properties": {
                "compare_card_visible": { "type": "boolean" },
                "threshold_inspector_visible": { "type": "boolean" },
                "waiver_badge_visible": { "type": "boolean" },
                "confounder_disclosure_visible": { "type": "boolean" },
                "capture_identity_visible": { "type": "boolean" },
                "comparison_basis_visible": { "type": "boolean" },
                "threshold_bar_visible": { "type": "boolean" },
                "waiver_expiry_visible": { "type": "boolean" },
                "degraded_state_label_visible": { "type": "boolean" },
                "mapping_quality_visible": { "type": "boolean" }
            }
        },
        "ProfileCompareSurfaceQualificationRow": {
            "type": "object",
            "required": [
                "surface_id",
                "title",
                "surface_kind",
                "promoted_build_surface",
                "claim_label",
                "displayed_label",
                "qualification_packet",
                "guards",
                "downgrade_if_missing",
                "rationale"
            ],
            "properties": {
                "surface_id": { "type": "string" },
                "title": { "type": "string" },
                "surface_kind": { "$ref": "#/definitions/ProfileCompareSurfaceKind" },
                "promoted_build_surface": { "type": "boolean" },
                "claim_label": { "$ref": "#/definitions/ProfileCompareQualificationLabel" },
                "displayed_label": { "type": "string" },
                "qualification_packet": { "$ref": "#/definitions/ProfileCompareQualificationProof" },
                "guards": { "$ref": "#/definitions/ProfileCompareSurfaceGuardSet" },
                "downgrade_if_missing": { "type": "boolean" },
                "rationale": { "type": "string" }
            }
        },
        "ProfileCompareCardRow": {
            "type": "object",
            "required": [
                "card_id",
                "title",
                "left_capture_ref",
                "right_capture_ref",
                "comparison_kind",
                "threshold_state_ref",
                "shows_confounders",
                "promoted_build_surface"
            ],
            "properties": {
                "card_id": { "type": "string" },
                "title": { "type": "string" },
                "left_capture_ref": { "type": "string" },
                "right_capture_ref": { "type": "string" },
                "comparison_kind": { "$ref": "#/definitions/ComparisonKind" },
                "threshold_state_ref": { "type": "string" },
                "confounder_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "shows_confounders": { "type": "boolean" },
                "promoted_build_surface": { "type": "boolean" }
            }
        },
        "ThresholdStateRow": {
            "type": "object",
            "required": [
                "threshold_id",
                "title",
                "metric_family",
                "threshold_value_pct",
                "current_value_pct",
                "threshold_state",
                "shows_threshold_bar",
                "promoted_build_surface"
            ],
            "properties": {
                "threshold_id": { "type": "string" },
                "title": { "type": "string" },
                "metric_family": { "type": "string" },
                "threshold_value_pct": { "type": "integer" },
                "current_value_pct": { "type": "integer" },
                "threshold_state": { "$ref": "#/definitions/ThresholdState" },
                "shows_threshold_bar": { "type": "boolean" },
                "promoted_build_surface": { "type": "boolean" }
            }
        },
        "WaiverStateRow": {
            "type": "object",
            "required": [
                "waiver_id",
                "title",
                "threshold_ref",
                "waiver_status",
                "waiver_cause",
                "expiry_proximity",
                "shows_expiry",
                "promoted_build_surface"
            ],
            "properties": {
                "waiver_id": { "type": "string" },
                "title": { "type": "string" },
                "threshold_ref": { "type": "string" },
                "waiver_status": { "$ref": "#/definitions/WaiverStatus" },
                "waiver_cause": { "type": "string" },
                "expiry_proximity": { "type": "string" },
                "shows_expiry": { "type": "boolean" },
                "promoted_build_surface": { "type": "boolean" }
            }
        },
        "ConfounderDisclosureRow": {
            "type": "object",
            "required": [
                "disclosure_id",
                "title",
                "confounder_kind",
                "severity",
                "is_blocking",
                "disclosure_text",
                "mitigation_hint",
                "promoted_build_surface"
            ],
            "properties": {
                "disclosure_id": { "type": "string" },
                "title": { "type": "string" },
                "confounder_kind": { "$ref": "#/definitions/ConfounderKind" },
                "severity": { "$ref": "#/definitions/ConfounderSeverity" },
                "is_blocking": { "type": "boolean" },
                "disclosure_text": { "type": "string" },
                "mitigation_hint": { "type": "string" },
                "promoted_build_surface": { "type": "boolean" }
            }
        },
        "ProfileCompareQualificationSummary": {
            "type": "object",
            "required": [
                "profile_compare_card_count",
                "threshold_state_count",
                "waiver_state_count",
                "confounder_disclosure_count",
                "stable_count",
                "below_stable_count",
                "all_below_stable_have_disclosure",
                "breach_count",
                "waived_breach_count",
                "blocking_confounder_count"
            ],
            "properties": {
                "profile_compare_card_count": { "type": "integer", "minimum": 0 },
                "threshold_state_count": { "type": "integer", "minimum": 0 },
                "waiver_state_count": { "type": "integer", "minimum": 0 },
                "confounder_disclosure_count": { "type": "integer", "minimum": 0 },
                "stable_count": { "type": "integer", "minimum": 0 },
                "below_stable_count": { "type": "integer", "minimum": 0 },
                "all_below_stable_have_disclosure": { "type": "boolean" },
                "breach_count": { "type": "integer", "minimum": 0 },
                "waived_breach_count": { "type": "integer", "minimum": 0 },
                "blocking_confounder_count": { "type": "integer", "minimum": 0 }
            }
        }
    }
}
