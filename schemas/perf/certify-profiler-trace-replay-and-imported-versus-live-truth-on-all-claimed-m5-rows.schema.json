{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://aureline.dev/schemas/perf/certify-profiler-trace-replay-and-imported-versus-live-truth-on-all-claimed-m5-rows.schema.json",
    "title": "Certify Profiler, Trace, Replay, and Imported-Versus-Live Truth on All Claimed M5 Rows",
    "description": "Schema for the M5 certification qualification packet that governs certification rows, imported-versus-live truth rows, and downgrade rule rows for all claimed B4 M5 rows.",
    "type": "object",
    "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "as_of",
        "release_doc_ref",
        "help_doc_ref",
        "schema_ref",
        "surfaces",
        "certifications",
        "imported_versus_live_truths",
        "downgrade_rules",
        "summary"
    ],
    "properties": {
        "schema_version": {
            "type": "integer",
            "minimum": 1,
            "description": "Schema version for this packet family."
        },
        "record_kind": {
            "type": "string",
            "const": "certify_profiler_trace_replay_and_imported_versus_live_truth_on_all_claimed_m5_rows",
            "description": "Stable record-kind tag."
        },
        "packet_id": {
            "type": "string",
            "description": "Stable packet identifier."
        },
        "as_of": {
            "type": "string",
            "format": "date",
            "description": "Date the packet was captured."
        },
        "release_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the release reviewer document."
        },
        "help_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the help projection."
        },
        "schema_ref": {
            "type": "string",
            "description": "Repo-relative path to this schema."
        },
        "surfaces": {
            "type": "array",
            "items": { "$ref": "#/definitions/CertificationSurfaceQualificationRow" }
        },
        "certifications": {
            "type": "array",
            "items": { "$ref": "#/definitions/CertificationRow" }
        },
        "imported_versus_live_truths": {
            "type": "array",
            "items": { "$ref": "#/definitions/ImportedVersusLiveTruthRow" }
        },
        "downgrade_rules": {
            "type": "array",
            "items": { "$ref": "#/definitions/DowngradeRuleRow" }
        },
        "summary": {
            "$ref": "#/definitions/CertificationQualificationSummary"
        }
    },
    "definitions": {
        "CertificationQualificationLabel": {
            "type": "string",
            "enum": [
                "stable",
                "preview",
                "labs",
                "inspect_only",
                "import_only"
            ]
        },
        "CertificationSurfaceKind": {
            "type": "string",
            "enum": [
                "certification_dashboard",
                "imported_versus_live_inspector",
                "trace_comparison_basis_viewer",
                "profile_provenance_auditor",
                "regression_baseline_certification_viewer",
                "support_bundle_certification_viewer"
            ]
        },
        "CertificationStatus": {
            "type": "string",
            "enum": [
                "certified",
                "pending",
                "stale",
                "underqualified",
                "policy_blocked",
                "rolled_back"
            ]
        },
        "OriginClass": {
            "type": "string",
            "enum": [
                "live_capture",
                "imported_artifact",
                "cached_replay",
                "support_bundle",
                "unknown"
            ]
        },
        "MappingFidelity": {
            "type": "string",
            "enum": [
                "exact",
                "approximate",
                "partial",
                "unavailable",
                "stale",
                "mismatched"
            ]
        },
        "BaselineComparability": {
            "type": "string",
            "enum": [
                "comparable",
                "partial",
                "stale",
                "mismatch",
                "unknown"
            ]
        },
        "CertificationQualificationProof": {
            "type": "object",
            "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at"],
            "properties": {
                "packet_id": { "type": "string" },
                "packet_ref": { "type": "string" },
                "proof_index_ref": { "type": "string" },
                "captured_at": { "type": "string", "format": "date" },
                "evidence_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        },
        "CertificationSurfaceGuardSet": {
            "type": "object",
            "required": [
                "certification_status_visible",
                "imported_versus_live_visible",
                "provenance_chain_visible",
                "build_identity_visible",
                "mapping_fidelity_visible",
                "comparison_basis_visible",
                "downgrade_rules_visible",
                "stale_warning_visible"
            ],
            "properties": {
                "certification_status_visible": { "type": "boolean" },
                "imported_versus_live_visible": { "type": "boolean" },
                "provenance_chain_visible": { "type": "boolean" },
                "build_identity_visible": { "type": "boolean" },
                "mapping_fidelity_visible": { "type": "boolean" },
                "comparison_basis_visible": { "type": "boolean" },
                "downgrade_rules_visible": { "type": "boolean" },
                "stale_warning_visible": { "type": "boolean" }
            }
        },
        "CertificationSurfaceQualificationRow": {
            "type": "object",
            "required": [
                "surface_id",
                "title",
                "surface_kind",
                "promoted_build_surface",
                "claim_label",
                "displayed_label",
                "qualification_packet",
                "guards",
                "downgrade_if_missing",
                "rationale"
            ],
            "properties": {
                "surface_id": { "type": "string" },
                "title": { "type": "string" },
                "surface_kind": { "$ref": "#/definitions/CertificationSurfaceKind" },
                "promoted_build_surface": { "type": "boolean" },
                "claim_label": { "$ref": "#/definitions/CertificationQualificationLabel" },
                "displayed_label": { "type": "string" },
                "qualification_packet": { "$ref": "#/definitions/CertificationQualificationProof" },
                "guards": { "$ref": "#/definitions/CertificationSurfaceGuardSet" },
                "downgrade_if_missing": { "type": "boolean" },
                "rationale": { "type": "string" }
            }
        },
        "CertificationRow": {
            "type": "object",
            "required": [
                "certification_id",
                "title",
                "m5_row_ref",
                "packet_ref",
                "certification_status",
                "last_certified_at",
                "required_for_m5_ship",
                "downgrade_if_stale",
                "shows_certification_status",
                "shows_packet_ref"
            ],
            "properties": {
                "certification_id": { "type": "string" },
                "title": { "type": "string" },
                "m5_row_ref": { "type": "string" },
                "packet_ref": { "type": "string" },
                "certification_status": { "$ref": "#/definitions/CertificationStatus" },
                "last_certified_at": { "type": "string" },
                "required_for_m5_ship": { "type": "boolean" },
                "downgrade_if_stale": { "type": "boolean" },
                "shows_certification_status": { "type": "boolean" },
                "shows_packet_ref": { "type": "boolean" }
            }
        },
        "ImportedVersusLiveTruthRow": {
            "type": "object",
            "required": [
                "truth_id",
                "title",
                "origin_class",
                "build_identity_ref",
                "mapping_fidelity",
                "baseline_comparability",
                "shows_imported_label",
                "shows_live_indicator",
                "shows_provenance_chain",
                "warns_on_identity_mismatch",
                "promoted_build_surface"
            ],
            "properties": {
                "truth_id": { "type": "string" },
                "title": { "type": "string" },
                "origin_class": { "$ref": "#/definitions/OriginClass" },
                "build_identity_ref": { "type": "string" },
                "capture_timestamp": { "type": ["string", "null"] },
                "import_timestamp": { "type": ["string", "null"] },
                "provenance_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "mapping_fidelity": { "$ref": "#/definitions/MappingFidelity" },
                "baseline_comparability": { "$ref": "#/definitions/BaselineComparability" },
                "shows_imported_label": { "type": "boolean" },
                "shows_live_indicator": { "type": "boolean" },
                "shows_provenance_chain": { "type": "boolean" },
                "warns_on_identity_mismatch": { "type": "boolean" },
                "promoted_build_surface": { "type": "boolean" }
            }
        },
        "DowngradeRuleRow": {
            "type": "object",
            "required": [
                "rule_id",
                "title",
                "trigger_status",
                "affected_m5_row_refs",
                "resulting_label",
                "active",
                "shows_rule"
            ],
            "properties": {
                "rule_id": { "type": "string" },
                "title": { "type": "string" },
                "trigger_status": { "$ref": "#/definitions/CertificationStatus" },
                "affected_surface_kinds": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/CertificationSurfaceKind" }
                },
                "affected_m5_row_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "resulting_label": { "$ref": "#/definitions/CertificationQualificationLabel" },
                "active": { "type": "boolean" },
                "shows_rule": { "type": "boolean" }
            }
        },
        "CertificationQualificationSummary": {
            "type": "object",
            "required": [
                "certification_count",
                "imported_versus_live_truth_count",
                "downgrade_rule_count",
                "stable_count",
                "below_stable_count",
                "all_below_stable_have_disclosure",
                "certified_count",
                "honest_origin_count",
                "active_downgrade_rule_count"
            ],
            "properties": {
                "certification_count": { "type": "integer", "minimum": 0 },
                "imported_versus_live_truth_count": { "type": "integer", "minimum": 0 },
                "downgrade_rule_count": { "type": "integer", "minimum": 0 },
                "stable_count": { "type": "integer", "minimum": 0 },
                "below_stable_count": { "type": "integer", "minimum": 0 },
                "all_below_stable_have_disclosure": { "type": "boolean" },
                "certified_count": { "type": "integer", "minimum": 0 },
                "honest_origin_count": { "type": "integer", "minimum": 0 },
                "active_downgrade_rule_count": { "type": "integer", "minimum": 0 }
            }
        }
    }
}
