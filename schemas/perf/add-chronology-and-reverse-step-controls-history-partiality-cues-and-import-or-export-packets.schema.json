{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://aureline.dev/schemas/perf/add-chronology-and-reverse-step-controls-history-partiality-cues-and-import-or-export-packets.schema.json",
    "title": "Chronology and Reverse-Step Controls, History Partiality Cues, and Import or Export Packets",
    "description": "Schema for the M5 chronology qualification packet that governs chronology control rows, reverse-step action rows, history partiality cue rows, import/export packet rows, and surface guard sets.",
    "type": "object",
    "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "as_of",
        "release_doc_ref",
        "help_doc_ref",
        "schema_ref",
        "surfaces",
        "chronology_controls",
        "reverse_step_actions",
        "history_partiality_cues",
        "import_export_packets",
        "summary"
    ],
    "properties": {
        "schema_version": {
            "type": "integer",
            "minimum": 1,
            "description": "Schema version for this packet family."
        },
        "record_kind": {
            "type": "string",
            "const": "add_chronology_and_reverse_step_controls_history_partiality_cues_and_import_or_export_packets",
            "description": "Stable record-kind tag."
        },
        "packet_id": {
            "type": "string",
            "description": "Stable packet identifier."
        },
        "as_of": {
            "type": "string",
            "format": "date",
            "description": "Date the packet was captured."
        },
        "release_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the release reviewer document."
        },
        "help_doc_ref": {
            "type": "string",
            "description": "Repo-relative path to the help projection."
        },
        "schema_ref": {
            "type": "string",
            "description": "Repo-relative path to this schema."
        },
        "surfaces": {
            "type": "array",
            "items": { "$ref": "#/definitions/ChronologySurfaceQualificationRow" }
        },
        "chronology_controls": {
            "type": "array",
            "items": { "$ref": "#/definitions/ChronologyControlRow" }
        },
        "reverse_step_actions": {
            "type": "array",
            "items": { "$ref": "#/definitions/ReverseStepActionRow" }
        },
        "history_partiality_cues": {
            "type": "array",
            "items": { "$ref": "#/definitions/HistoryPartialityCueRow" }
        },
        "import_export_packets": {
            "type": "array",
            "items": { "$ref": "#/definitions/ImportExportPacketRow" }
        },
        "summary": {
            "$ref": "#/definitions/ChronologyQualificationSummary"
        }
    },
    "definitions": {
        "ChronologyQualificationLabel": {
            "type": "string",
            "enum": [
                "stable",
                "preview",
                "labs",
                "inspect_only",
                "import_only"
            ]
        },
        "ChronologySurfaceKind": {
            "type": "string",
            "enum": [
                "chronology_control_bar",
                "reverse_step_toolbar",
                "history_partiality_indicator",
                "import_packet_dialog",
                "export_packet_dialog",
                "packet_integrity_review"
            ]
        },
        "ChronologyControlKind": {
            "type": "string",
            "enum": [
                "play",
                "pause",
                "step_forward",
                "step_backward",
                "jump_to_time",
                "speed_control",
                "scrub"
            ]
        },
        "ReverseStepActionKind": {
            "type": "string",
            "enum": [
                "reverse_continue",
                "reverse_step_over",
                "reverse_step_into",
                "reverse_step_out",
                "reverse_run_to_cursor"
            ]
        },
        "HistoryPartialityCueKind": {
            "type": "string",
            "enum": [
                "truncated_start",
                "truncated_end",
                "filtered_out",
                "missing_mapping",
                "sampling_gap",
                "policy_redacted"
            ]
        },
        "PartialitySeverity": {
            "type": "string",
            "enum": [
                "info",
                "warning",
                "critical"
            ]
        },
        "PacketDirection": {
            "type": "string",
            "enum": [
                "import",
                "export"
            ]
        },
        "PacketFormatKind": {
            "type": "string",
            "enum": [
                "trace_bundle",
                "profile_snapshot",
                "regression_baseline",
                "notebook_archive",
                "replay_capture"
            ]
        },
        "ChronologyQualificationProof": {
            "type": "object",
            "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at"],
            "properties": {
                "packet_id": { "type": "string" },
                "packet_ref": { "type": "string" },
                "proof_index_ref": { "type": "string" },
                "captured_at": { "type": "string", "format": "date" },
                "evidence_refs": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        },
        "ChronologySurfaceGuardSet": {
            "type": "object",
            "required": [
                "chronology_controls_visible",
                "reverse_step_actions_visible",
                "history_partiality_cues_visible",
                "import_export_packets_visible",
                "mapping_quality_visible",
                "degraded_state_label_visible",
                "integrity_check_visible"
            ],
            "properties": {
                "chronology_controls_visible": { "type": "boolean" },
                "reverse_step_actions_visible": { "type": "boolean" },
                "history_partiality_cues_visible": { "type": "boolean" },
                "import_export_packets_visible": { "type": "boolean" },
                "mapping_quality_visible": { "type": "boolean" },
                "degraded_state_label_visible": { "type": "boolean" },
                "integrity_check_visible": { "type": "boolean" }
            }
        },
        "ChronologySurfaceQualificationRow": {
            "type": "object",
            "required": [
                "surface_id",
                "title",
                "surface_kind",
                "promoted_build_surface",
                "claim_label",
                "displayed_label",
                "qualification_packet",
                "guards",
                "downgrade_if_missing",
                "rationale"
            ],
            "properties": {
                "surface_id": { "type": "string" },
                "title": { "type": "string" },
                "surface_kind": { "$ref": "#/definitions/ChronologySurfaceKind" },
                "promoted_build_surface": { "type": "boolean" },
                "claim_label": { "$ref": "#/definitions/ChronologyQualificationLabel" },
                "displayed_label": { "type": "string" },
                "qualification_packet": { "$ref": "#/definitions/ChronologyQualificationProof" },
                "guards": { "$ref": "#/definitions/ChronologySurfaceGuardSet" },
                "downgrade_if_missing": { "type": "boolean" },
                "rationale": { "type": "string" }
            }
        },
        "ChronologyControlRow": {
            "type": "object",
            "required": [
                "control_id",
                "title",
                "control_kind",
                "enabled",
                "shows_enabled_state",
                "shows_degraded_label"
            ],
            "properties": {
                "control_id": { "type": "string" },
                "title": { "type": "string" },
                "control_kind": { "$ref": "#/definitions/ChronologyControlKind" },
                "enabled": { "type": "boolean" },
                "shows_enabled_state": { "type": "boolean" },
                "shows_degraded_label": { "type": "boolean" }
            }
        },
        "ReverseStepActionRow": {
            "type": "object",
            "required": [
                "action_id",
                "title",
                "action_kind",
                "enabled",
                "mapping_quality",
                "shows_enabled_state",
                "shows_mapping_quality",
                "shows_degraded_label"
            ],
            "properties": {
                "action_id": { "type": "string" },
                "title": { "type": "string" },
                "action_kind": { "$ref": "#/definitions/ReverseStepActionKind" },
                "enabled": { "type": "boolean" },
                "target_event_ref": { "type": ["string", "null"] },
                "mapping_quality": { "type": "string" },
                "shows_enabled_state": { "type": "boolean" },
                "shows_mapping_quality": { "type": "boolean" },
                "shows_degraded_label": { "type": "boolean" }
            }
        },
        "HistoryPartialityCueRow": {
            "type": "object",
            "required": [
                "cue_id",
                "title",
                "cue_kind",
                "time_range_start_ns",
                "time_range_end_ns",
                "severity",
                "shows_severity",
                "shows_explanation",
                "explanation",
                "shows_degraded_label"
            ],
            "properties": {
                "cue_id": { "type": "string" },
                "title": { "type": "string" },
                "cue_kind": { "$ref": "#/definitions/HistoryPartialityCueKind" },
                "time_range_start_ns": { "type": "integer", "minimum": 0 },
                "time_range_end_ns": { "type": "integer", "minimum": 0 },
                "severity": { "$ref": "#/definitions/PartialitySeverity" },
                "shows_severity": { "type": "boolean" },
                "shows_explanation": { "type": "boolean" },
                "explanation": { "type": "string" },
                "shows_degraded_label": { "type": "boolean" }
            }
        },
        "ImportExportPacketRow": {
            "type": "object",
            "required": [
                "packet_row_id",
                "title",
                "direction",
                "format_kind",
                "format_version",
                "provenance",
                "integrity_hash",
                "created_at",
                "size_bytes",
                "content_summary",
                "shows_provenance",
                "shows_integrity_hash",
                "shows_format_version",
                "shows_degraded_label"
            ],
            "properties": {
                "packet_row_id": { "type": "string" },
                "title": { "type": "string" },
                "direction": { "$ref": "#/definitions/PacketDirection" },
                "format_kind": { "$ref": "#/definitions/PacketFormatKind" },
                "format_version": { "type": "string" },
                "provenance": { "type": "string" },
                "integrity_hash": { "type": "string" },
                "created_at": { "type": "string" },
                "size_bytes": { "type": "integer", "minimum": 0 },
                "content_summary": { "type": "string" },
                "shows_provenance": { "type": "boolean" },
                "shows_integrity_hash": { "type": "boolean" },
                "shows_format_version": { "type": "boolean" },
                "shows_degraded_label": { "type": "boolean" }
            }
        },
        "ChronologyQualificationSummary": {
            "type": "object",
            "required": [
                "chronology_control_count",
                "reverse_step_action_count",
                "history_partiality_cue_count",
                "import_export_packet_count",
                "stable_count",
                "below_stable_count",
                "all_below_stable_have_disclosure",
                "control_showing_degraded_count",
                "reverse_step_showing_degraded_count",
                "partiality_cue_showing_degraded_count",
                "packet_showing_degraded_count"
            ],
            "properties": {
                "chronology_control_count": { "type": "integer", "minimum": 0 },
                "reverse_step_action_count": { "type": "integer", "minimum": 0 },
                "history_partiality_cue_count": { "type": "integer", "minimum": 0 },
                "import_export_packet_count": { "type": "integer", "minimum": 0 },
                "stable_count": { "type": "integer", "minimum": 0 },
                "below_stable_count": { "type": "integer", "minimum": 0 },
                "all_below_stable_have_disclosure": { "type": "boolean" },
                "control_showing_degraded_count": { "type": "integer", "minimum": 0 },
                "reverse_step_showing_degraded_count": { "type": "integer", "minimum": 0 },
                "partiality_cue_showing_degraded_count": { "type": "integer", "minimum": 0 },
                "packet_showing_degraded_count": { "type": "integer", "minimum": 0 }
            }
        }
    }
}
