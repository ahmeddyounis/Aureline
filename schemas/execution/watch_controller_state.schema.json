{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/execution/watch_controller_state.schema.json",
  "title": "Aureline test watch-controller state record",
  "description": "Boundary schema for the watch_controller_state_record frozen in docs/execution/test_watch_and_environment_contract.md. The record makes live test-watch fidelity durable across editor inline results, test tree rows, CLI/export output, support bundles, and release evidence. It cites the existing run / attempt / discovery / context rails rather than minting a private watch truth model. Raw command lines, raw stdout or stderr bytes, raw environment bodies, raw absolute paths, raw URLs, raw secret values, raw test names, raw assertion bodies, raw artifact bytes, and raw stack traces MUST NOT cross this boundary; rows carry opaque refs, counts, class labels, and timestamps only. Adding a new optional field or enum member is additive-minor; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/watch_controller_state_record" }
  ],
  "$defs": {
    "watch_controller_state_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for this watch-controller state family."
    },
    "record_kind": {
      "type": "string",
      "enum": ["watch_controller_state_record"]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for logs, RPC, support bundles, and release packets."
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque ref to another record owned by its registry."
    },
    "opaque_ref_nullable": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "timestamp_nullable": {
      "oneOf": [
        { "$ref": "#/$defs/timestamp" },
        { "type": "null" }
      ]
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480,
      "description": "Short reviewable sentence. Raw code, raw paths, raw secrets, raw tool arguments, raw test names, and raw runner payloads are forbidden."
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_and_hashes_only",
        "support_bundle_scoped",
        "broadened_capture"
      ],
      "description": "Redaction posture for the record. broadened_capture requires an approval-ticket ref."
    },
    "host_boundary_class": {
      "type": "string",
      "enum": [
        "local_host_runtime",
        "ssh_remote_runtime",
        "remote_workspace_agent_runtime",
        "managed_workspace_agent_runtime",
        "container_local_runtime",
        "devcontainer_runtime",
        "provider_remote_agent_runtime",
        "compatibility_bridge_remote_runtime",
        "ai_sandbox_runtime",
        "host_boundary_unknown_requires_review"
      ],
      "description": "Re-export of the execution host-boundary vocabulary."
    },
    "watch_state_class": {
      "type": "string",
      "enum": [
        "live",
        "reduced",
        "polling",
        "paused",
        "degraded",
        "backlog",
        "unavailable",
        "watch_state_unknown_requires_review"
      ],
      "description": "Closed watch-state vocabulary. live is event-driven and within evidence window; reduced continues with a known fidelity narrowing; polling is interval or scan driven; paused is intentionally stopped; degraded continues with known health limitations; backlog exceeds cycle budget; unavailable cannot produce new cycles; unknown fails closed."
    },
    "degradation_reason_class": {
      "type": "string",
      "enum": [
        "none",
        "workspace_watcher_polling_fallback",
        "watcher_event_loss_suspected",
        "watcher_overflow_or_root_rescan",
        "adapter_lost_or_crashed",
        "remote_agent_latency_or_disconnect",
        "target_context_unhealthy",
        "power_saver_or_thermal_throttle",
        "policy_limited_watch_scope",
        "debounce_or_batch_window_extended",
        "backlog_exceeds_cycle_budget",
        "notebook_kernel_not_live",
        "provider_imported_read_only",
        "degradation_reason_unknown_requires_review"
      ],
      "description": "Reason the controller is narrowed from ideal live watch. none is required when state_class is live and no downgrade is active."
    },
    "debounce_policy_class": {
      "type": "string",
      "enum": [
        "event_driven_debounce",
        "adaptive_debounce",
        "fixed_interval_polling_debounce",
        "manual_refresh_only",
        "debounce_unknown_requires_review"
      ]
    },
    "batch_policy_class": {
      "type": "string",
      "enum": [
        "single_change_cycle",
        "bounded_batch",
        "coalesced_batch",
        "backlog_drain_batch",
        "batching_paused",
        "batch_unknown_requires_review"
      ]
    },
    "power_state_class": {
      "type": "string",
      "enum": [
        "normal_power",
        "battery_saver_reduced",
        "thermal_throttled",
        "background_suspended",
        "remote_power_state_unknown",
        "power_state_unknown_requires_review"
      ]
    },
    "remote_state_class": {
      "type": "string",
      "enum": [
        "local_no_remote",
        "remote_healthy",
        "remote_latency_degraded",
        "remote_reconnecting",
        "remote_disconnected",
        "provider_read_only_import",
        "remote_state_unknown_requires_review"
      ]
    },
    "latency_bucket_class": {
      "type": "string",
      "enum": [
        "not_applicable_local",
        "latency_low",
        "latency_medium",
        "latency_high",
        "latency_unmeasured",
        "latency_bucket_unknown_requires_review"
      ]
    },
    "target_health_class": {
      "type": "string",
      "enum": [
        "target_healthy",
        "target_rebuilding",
        "target_stale_snapshot",
        "target_context_drift_detected",
        "target_adapter_missing",
        "target_policy_blocked",
        "target_unavailable",
        "target_health_unknown_requires_review"
      ]
    },
    "watcher_health_class": {
      "type": "string",
      "enum": [
        "watcher_healthy",
        "watcher_reduced_metadata",
        "watcher_polling",
        "watcher_overflowed",
        "watcher_stalled",
        "watcher_unavailable",
        "watcher_health_unknown_requires_review"
      ]
    },
    "adapter_health_class": {
      "type": "string",
      "enum": [
        "adapter_healthy",
        "adapter_starting",
        "adapter_degraded",
        "adapter_backlogged",
        "adapter_crashed",
        "adapter_unsupported",
        "adapter_health_unknown_requires_review"
      ]
    },
    "cycle_freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "warm_cached",
        "degraded_cached",
        "stale",
        "no_successful_cycle",
        "cycle_freshness_unknown_requires_review"
      ]
    },
    "pause_reason_class": {
      "type": "string",
      "enum": [
        "not_paused",
        "paused_by_user",
        "paused_by_policy",
        "paused_by_power_state",
        "paused_by_remote_disconnect",
        "paused_by_adapter_unavailable",
        "paused_by_workspace_trust",
        "pause_reason_unknown_requires_review"
      ]
    },
    "result_surface_class": {
      "type": "string",
      "enum": [
        "editor_inline_results",
        "test_tree",
        "test_summary",
        "status_bar",
        "cli_output",
        "support_export",
        "release_packet"
      ]
    },
    "denial_reason_class": {
      "type": "string",
      "enum": [
        "watch_controller_state_record_must_cite_test_session_ref",
        "watch_controller_state_record_must_cite_discovery_state_ref",
        "watch_controller_state_record_must_cite_context_snapshot_ref",
        "watch_controller_state_record_must_carry_typed_watch_state",
        "watch_controller_state_record_must_carry_degradation_reason",
        "watch_controller_state_record_must_carry_debounce_policy",
        "watch_controller_state_record_must_carry_batch_policy",
        "watch_controller_state_record_must_carry_backlog_summary",
        "watch_controller_state_record_must_carry_power_remote_and_target_health",
        "watch_controller_state_record_must_surface_degradation_where_results_are_consumed",
        "watch_controller_state_record_must_not_store_degradation_only_in_hidden_diagnostics",
        "watch_controller_state_record_unknown_state_requires_review",
        "watch_controller_state_record_degradation_reason_unknown_requires_review"
      ]
    },
    "audit_event_id": {
      "type": "string",
      "enum": [
        "watch_controller_state_record_published",
        "watch_controller_state_record_state_transitioned",
        "watch_controller_state_record_degradation_narrowed",
        "watch_controller_state_record_backlog_updated",
        "watch_controller_state_record_paused",
        "watch_controller_state_record_resumed",
        "watch_controller_state_record_unavailable",
        "watch_controller_state_record_result_surface_disclosure_updated",
        "watch_controller_state_record_hidden_degradation_forbidden_denial",
        "watch_controller_state_record_audit_denial_emitted"
      ]
    },
    "debounce_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "debounce_policy_class",
        "quiet_period_ms",
        "max_delay_ms",
        "policy_source_ref"
      ],
      "properties": {
        "debounce_policy_class": { "$ref": "#/$defs/debounce_policy_class" },
        "quiet_period_ms": { "$ref": "#/$defs/non_negative_integer" },
        "max_delay_ms": { "$ref": "#/$defs/non_negative_integer" },
        "policy_source_ref": { "$ref": "#/$defs/opaque_ref_nullable" }
      }
    },
    "batch_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "batch_policy_class",
        "max_change_count",
        "max_test_item_count",
        "max_cycle_age_ms",
        "coalescing_key_ref"
      ],
      "properties": {
        "batch_policy_class": { "$ref": "#/$defs/batch_policy_class" },
        "max_change_count": { "$ref": "#/$defs/non_negative_integer" },
        "max_test_item_count": { "$ref": "#/$defs/non_negative_integer" },
        "max_cycle_age_ms": { "$ref": "#/$defs/non_negative_integer" },
        "coalescing_key_ref": { "$ref": "#/$defs/opaque_ref_nullable" }
      }
    },
    "backlog_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pending_change_count",
        "pending_test_item_count",
        "oldest_pending_age_ms",
        "backlog_budget_breached"
      ],
      "properties": {
        "pending_change_count": { "$ref": "#/$defs/non_negative_integer" },
        "pending_test_item_count": { "$ref": "#/$defs/non_negative_integer" },
        "oldest_pending_age_ms": { "$ref": "#/$defs/non_negative_integer" },
        "backlog_budget_breached": { "type": "boolean" }
      }
    },
    "power_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "power_state_class",
        "power_saver_active",
        "thermal_throttle_active"
      ],
      "properties": {
        "power_state_class": { "$ref": "#/$defs/power_state_class" },
        "power_saver_active": { "type": "boolean" },
        "thermal_throttle_active": { "type": "boolean" },
        "power_policy_ref": { "$ref": "#/$defs/opaque_ref_nullable" }
      }
    },
    "remote_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "remote_state_class",
        "host_boundary_class",
        "latency_bucket_class",
        "last_heartbeat_at",
        "remote_capability_ref"
      ],
      "properties": {
        "remote_state_class": { "$ref": "#/$defs/remote_state_class" },
        "host_boundary_class": { "$ref": "#/$defs/host_boundary_class" },
        "latency_bucket_class": { "$ref": "#/$defs/latency_bucket_class" },
        "last_heartbeat_at": { "$ref": "#/$defs/timestamp_nullable" },
        "remote_capability_ref": { "$ref": "#/$defs/opaque_ref_nullable" }
      }
    },
    "target_health_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_health_class",
        "watcher_health_class",
        "adapter_health_class",
        "target_context_snapshot_ref",
        "drift_summary_ref"
      ],
      "properties": {
        "target_health_class": { "$ref": "#/$defs/target_health_class" },
        "watcher_health_class": { "$ref": "#/$defs/watcher_health_class" },
        "adapter_health_class": { "$ref": "#/$defs/adapter_health_class" },
        "target_context_snapshot_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "drift_summary_ref": { "$ref": "#/$defs/opaque_ref_nullable" }
      }
    },
    "last_successful_cycle": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cycle_id",
            "attempt_ref",
            "completed_at",
            "cycle_freshness_class"
          ],
          "properties": {
            "cycle_id": { "$ref": "#/$defs/opaque_id" },
            "attempt_ref": { "$ref": "#/$defs/opaque_ref" },
            "completed_at": { "$ref": "#/$defs/timestamp" },
            "cycle_freshness_class": { "$ref": "#/$defs/cycle_freshness_class" }
          }
        }
      ]
    },
    "pause_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "is_paused",
        "pause_reason_class",
        "paused_at",
        "paused_by_actor_ref",
        "resume_action_ref"
      ],
      "properties": {
        "is_paused": { "type": "boolean" },
        "pause_reason_class": { "$ref": "#/$defs/pause_reason_class" },
        "paused_at": { "$ref": "#/$defs/timestamp_nullable" },
        "paused_by_actor_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "resume_action_ref": { "$ref": "#/$defs/opaque_ref_nullable" }
      }
    },
    "result_surface_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "degradation_visible_to_result_consumers",
        "hidden_diagnostics_only",
        "surface_classes",
        "status_item_ref",
        "support_export_ref",
        "disclosure_summary"
      ],
      "properties": {
        "degradation_visible_to_result_consumers": {
          "type": "boolean",
          "const": true,
          "description": "Degradation must be shown where results are consumed."
        },
        "hidden_diagnostics_only": {
          "type": "boolean",
          "const": false,
          "description": "Watch degradation may not exist only in hidden diagnostics or logs."
        },
        "surface_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/result_surface_class" },
          "uniqueItems": true
        },
        "status_item_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "support_export_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "disclosure_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "watch_controller_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "watch_controller_state_schema_version",
        "watch_controller_state_record_id",
        "test_session_ref",
        "selection_ref",
        "discovery_state_ref",
        "latest_run_ref",
        "latest_attempt_ref",
        "context_snapshot_ref",
        "state_class",
        "degradation_reason_class",
        "debounce_policy",
        "batch_policy",
        "backlog_summary",
        "power_summary",
        "remote_summary",
        "target_health_summary",
        "last_successful_cycle",
        "pause_summary",
        "result_surface_disclosure",
        "audit_event_refs",
        "denial_reason_class",
        "captured_at",
        "redaction_class",
        "approval_ticket_ref"
      ],
      "properties": {
        "record_kind": { "const": "watch_controller_state_record" },
        "watch_controller_state_schema_version": { "$ref": "#/$defs/watch_controller_state_schema_version" },
        "watch_controller_state_record_id": { "$ref": "#/$defs/opaque_id" },
        "test_session_ref": { "$ref": "#/$defs/opaque_ref" },
        "selection_ref": { "$ref": "#/$defs/opaque_ref" },
        "discovery_state_ref": { "$ref": "#/$defs/opaque_ref" },
        "latest_run_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "latest_attempt_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "context_snapshot_ref": { "$ref": "#/$defs/opaque_ref" },
        "state_class": { "$ref": "#/$defs/watch_state_class" },
        "degradation_reason_class": { "$ref": "#/$defs/degradation_reason_class" },
        "debounce_policy": { "$ref": "#/$defs/debounce_policy" },
        "batch_policy": { "$ref": "#/$defs/batch_policy" },
        "backlog_summary": { "$ref": "#/$defs/backlog_summary" },
        "power_summary": { "$ref": "#/$defs/power_summary" },
        "remote_summary": { "$ref": "#/$defs/remote_summary" },
        "target_health_summary": { "$ref": "#/$defs/target_health_summary" },
        "last_successful_cycle": { "$ref": "#/$defs/last_successful_cycle" },
        "pause_summary": { "$ref": "#/$defs/pause_summary" },
        "result_surface_disclosure": { "$ref": "#/$defs/result_surface_disclosure" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/audit_event_id" },
          "uniqueItems": true
        },
        "denial_reason_class": {
          "oneOf": [
            { "$ref": "#/$defs/denial_reason_class" },
            { "type": "null" }
          ]
        },
        "captured_at": { "$ref": "#/$defs/timestamp" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "approval_ticket_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "notes": { "$ref": "#/$defs/short_sentence" }
      }
    }
  }
}
