{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/execution/m5-execution-certification.schema.json",
  "title": "Aureline M5 execution-certification matrix",
  "description": "Schema for the m5_execution_certification_matrix packet. The packet aggregates the B16 execution-truth lanes into one qualification report, freezing one certification row per claimed M5 execution or ops-adjacent depth lane (build-intelligence, target-context discovery, host-boundary, managed-workspace lifecycle, cluster-context infrastructure, mutation/handoff review, live-resource context). Each row certifies its lane against the canonical execution-truth packet it draws evidence from and records the owner, how fresh that evidence is (fresh, recent, stale, expired), how much of the claimed profile it covers (full, partial, minimal, absent), how its qualification drills came out (passed, partially-passed, inconclusive, failed), and how the evidence was attested (verified, attested, unverified, unverifiable); it surfaces the supported deployment-profile or provider-family labels, caveats, stale or missing fields, the source packet, a machine-readable certification receipt, and release-evidence, service-health, docs-badge, and support-export refs so those surfaces ingest the same packet rather than parallel spreadsheets. A non-inheriting certification gate derives the qualification level that may be published: stale or expired evidence, partial or absent coverage, a regressed or failed drill, or unverified or unverifiable evidence cannot publish a certified claim, and the certification decision records whether the gate certified, qualified to a narrower profile, provisioned to a narrower lifecycle, or withdrew it. A lane never graduates a blanket claim by inertia, one row is required per claimed lane so no lane inherits a certified claim, and the recorded published qualification, decision, and downgrade reasons must equal the recomputed gate decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "lanes",
    "qualification_levels",
    "evidence_freshness_states",
    "profile_coverage_states",
    "drill_outcomes",
    "evidence_provenance_states",
    "downgrade_paths",
    "downgrade_reasons",
    "certification_decisions",
    "certifications",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_execution_certification_matrix" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "lanes": { "type": "array", "items": { "$ref": "#/$defs/lane" } },
    "qualification_levels": {
      "type": "array",
      "items": { "$ref": "#/$defs/qualification_level" }
    },
    "evidence_freshness_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_freshness" }
    },
    "profile_coverage_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/profile_coverage" }
    },
    "drill_outcomes": { "type": "array", "items": { "$ref": "#/$defs/drill_outcome" } },
    "evidence_provenance_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_provenance" }
    },
    "downgrade_paths": { "type": "array", "items": { "$ref": "#/$defs/downgrade_path" } },
    "downgrade_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/downgrade_reason" }
    },
    "certification_decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/certification_decision" }
    },
    "certifications": { "type": "array", "items": { "$ref": "#/$defs/certification" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "lane": {
      "enum": [
        "build_intelligence",
        "target_context_discovery",
        "host_boundary",
        "managed_workspace_lifecycle",
        "cluster_context_infrastructure",
        "mutation_handoff_review",
        "live_resource_context"
      ]
    },
    "qualification_level": {
      "enum": ["certified", "profile_qualified", "lifecycle_provisional", "withdrawn"]
    },
    "evidence_freshness": {
      "enum": ["fresh", "recent", "stale", "expired"]
    },
    "profile_coverage": {
      "enum": ["full", "partial", "minimal", "absent"]
    },
    "drill_outcome": {
      "enum": ["passed", "partially_passed", "inconclusive", "failed"]
    },
    "evidence_provenance": {
      "enum": ["verified", "attested", "unverified", "unverifiable"]
    },
    "downgrade_path": {
      "enum": ["refresh_evidence", "narrow_profile", "narrow_lifecycle", "withdraw_claim", "none"]
    },
    "downgrade_reason": {
      "enum": [
        "stale_evidence",
        "partial_profile_coverage",
        "drill_regression",
        "unverified_evidence"
      ]
    },
    "certification_decision": {
      "enum": ["certify", "qualify_profile", "provision_lifecycle", "withdraw"]
    },
    "certification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_id",
        "lane",
        "owner",
        "evidence_freshness",
        "profile_coverage",
        "drill_outcome",
        "evidence_provenance",
        "declared_qualification",
        "published_qualification",
        "certification_decision",
        "downgrade_path",
        "packet_ref",
        "drill_ref",
        "evidence_ref",
        "certification_receipt_ref",
        "release_evidence_ref",
        "service_health_ref",
        "docs_badge_ref",
        "support_export_ref",
        "note"
      ],
      "properties": {
        "lane_id": { "$ref": "#/$defs/non_empty_string" },
        "lane": { "$ref": "#/$defs/lane" },
        "owner": { "$ref": "#/$defs/non_empty_string" },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness" },
        "profile_coverage": { "$ref": "#/$defs/profile_coverage" },
        "drill_outcome": { "$ref": "#/$defs/drill_outcome" },
        "evidence_provenance": { "$ref": "#/$defs/evidence_provenance" },
        "declared_qualification": { "$ref": "#/$defs/qualification_level" },
        "published_qualification": { "$ref": "#/$defs/qualification_level" },
        "certification_decision": { "$ref": "#/$defs/certification_decision" },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason" }
        },
        "downgrade_path": { "$ref": "#/$defs/downgrade_path" },
        "supported_profiles": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "caveats": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "stale_or_missing_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "drill_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "certification_receipt_ref": { "$ref": "#/$defs/non_empty_string" },
        "release_evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "service_health_ref": { "$ref": "#/$defs/non_empty_string" },
        "docs_badge_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_lanes",
        "lane_count",
        "certified_lanes",
        "profile_qualified_lanes",
        "lifecycle_provisional_lanes",
        "withdrawn_lanes",
        "certify_decisions",
        "qualify_profile_decisions",
        "provision_lifecycle_decisions",
        "withdraw_decisions",
        "downgraded_lanes",
        "ops_adjacent_lanes",
        "stale_evidence_lanes",
        "lanes_with_downgrade_reasons"
      ],
      "properties": {
        "total_lanes": { "type": "integer", "minimum": 0 },
        "lane_count": { "type": "integer", "minimum": 0 },
        "certified_lanes": { "type": "integer", "minimum": 0 },
        "profile_qualified_lanes": { "type": "integer", "minimum": 0 },
        "lifecycle_provisional_lanes": { "type": "integer", "minimum": 0 },
        "withdrawn_lanes": { "type": "integer", "minimum": 0 },
        "certify_decisions": { "type": "integer", "minimum": 0 },
        "qualify_profile_decisions": { "type": "integer", "minimum": 0 },
        "provision_lifecycle_decisions": { "type": "integer", "minimum": 0 },
        "withdraw_decisions": { "type": "integer", "minimum": 0 },
        "downgraded_lanes": { "type": "integer", "minimum": 0 },
        "ops_adjacent_lanes": { "type": "integer", "minimum": 0 },
        "stale_evidence_lanes": { "type": "integer", "minimum": 0 },
        "lanes_with_downgrade_reasons": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
