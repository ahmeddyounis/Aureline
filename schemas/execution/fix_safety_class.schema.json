{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/execution/fix_safety_class.schema.json",
  "title": "Aureline fix-safety class boundary",
  "description": "Boundary schema for fix-safety class definitions and evaluations frozen in docs/execution/save_participant_and_fix_safety_contract.md. The record family lets editor UI, CLI/headless save output, review sheets, support exports, and hot-path instrumentation distinguish safe local edits from workspace-wide preview, generated companion updates, policy blocks, disclosed whole-file rewrites, and external-change conflicts. Raw source text, raw patches, raw paths, raw tool arguments, raw provider logs, and secrets never cross this boundary; records carry opaque refs, class ids, counts, posture, and reviewable summaries only.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/fix_safety_class_definition_record" },
    { "$ref": "#/$defs/fix_safety_evaluation_record" }
  ],
  "$defs": {
    "fix_safety_class_schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "opaque_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "opaque_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "nullable_opaque_ref": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 640,
      "description": "Reviewable summary safe for UI, CLI, support, and release exports. Raw source text, raw paths, raw patches, raw logs, and secrets are forbidden."
    },
    "fix_safety_class": {
      "type": "string",
      "enum": [
        "safe_local_text_edit",
        "workspace_wide_preview_required",
        "generated_companion_update",
        "policy_blocked",
        "whole_file_rewrite_disclosed",
        "external_change_conflict_requires_review",
        "fix_safety_unknown_requires_review"
      ]
    },
    "output_origin_class": {
      "type": "string",
      "enum": [
        "exact_rule",
        "imported_config",
        "heuristic_fallback",
        "generated_lineage",
        "policy_decision",
        "ai_suggestion",
        "read_only_validation",
        "origin_unknown_requires_review"
      ]
    },
    "review_trigger_class": {
      "type": "string",
      "enum": [
        "not_required",
        "whole_file_rewrite",
        "generated_artifact_impact",
        "multi_file_edit",
        "external_change_race",
        "policy_or_trust_narrowing",
        "provider_dependency_or_semantic_freshness_gap",
        "source_fidelity_conversion",
        "output_origin_heuristic_or_ai",
        "unknown_requires_review"
      ]
    },
    "apply_posture_class": {
      "type": "string",
      "enum": [
        "auto_apply_allowed",
        "inline_disclosure_required",
        "preview_required",
        "manual_review_required",
        "blocked_no_write"
      ]
    },
    "mutation_scope_ceiling_class": {
      "type": "string",
      "enum": [
        "no_mutation",
        "single_file_localized",
        "single_file_whole_document",
        "generated_companion",
        "multi_file_workspace",
        "policy_or_trust_blocked",
        "scope_unknown_requires_review"
      ]
    },
    "checkpoint_requirement_class": {
      "type": "string",
      "enum": [
        "none_required",
        "recovery_journal",
        "local_history_checkpoint",
        "workspace_mutation_checkpoint_group",
        "generator_regeneration_checkpoint",
        "metadata_only_checkpoint",
        "checkpoint_blocked_no_write"
      ]
    },
    "compare_requirement_class": {
      "type": "string",
      "enum": [
        "compare_before_write_token_required",
        "external_generation_revalidation_required",
        "no_durable_write_until_review",
        "not_applicable_no_write"
      ]
    },
    "fix_safety_class_definition_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "fix_safety_class_schema_version",
        "fix_safety_class",
        "class_label",
        "default_apply_posture_class",
        "mutation_scope_ceiling_class",
        "allowed_output_origin_classes",
        "required_review_trigger_classes",
        "checkpoint_requirement_class",
        "compare_requirement_class",
        "required_disclosure_fields",
        "reviewer_summary"
      ],
      "properties": {
        "__fixture__": {
          "type": "object",
          "additionalProperties": true
        },
        "record_kind": {
          "const": "fix_safety_class_definition_record"
        },
        "fix_safety_class_schema_version": {
          "$ref": "#/$defs/fix_safety_class_schema_version"
        },
        "fix_safety_class": {
          "$ref": "#/$defs/fix_safety_class"
        },
        "class_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "default_apply_posture_class": {
          "$ref": "#/$defs/apply_posture_class"
        },
        "mutation_scope_ceiling_class": {
          "$ref": "#/$defs/mutation_scope_ceiling_class"
        },
        "allowed_output_origin_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/output_origin_class"
          },
          "uniqueItems": true
        },
        "required_review_trigger_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/review_trigger_class"
          },
          "uniqueItems": true
        },
        "checkpoint_requirement_class": {
          "$ref": "#/$defs/checkpoint_requirement_class"
        },
        "compare_requirement_class": {
          "$ref": "#/$defs/compare_requirement_class"
        },
        "required_disclosure_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        },
        "reviewer_summary": {
          "$ref": "#/$defs/short_sentence"
        }
      }
    },
    "fix_safety_evaluation_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "fix_safety_class_schema_version",
        "fix_safety_evaluation_id",
        "fix_safety_class",
        "participant_ref",
        "target_scope_ref",
        "output_origin_class",
        "review_trigger_classes",
        "final_apply_posture_class",
        "checkpoint_requirement_class",
        "compare_requirement_class",
        "generated_artifact_lineage_ref",
        "policy_decision_ref",
        "external_change_event_ref",
        "preview_or_review_ref",
        "evaluated_at",
        "summary"
      ],
      "properties": {
        "__fixture__": {
          "type": "object",
          "additionalProperties": true
        },
        "record_kind": {
          "const": "fix_safety_evaluation_record"
        },
        "fix_safety_class_schema_version": {
          "$ref": "#/$defs/fix_safety_class_schema_version"
        },
        "fix_safety_evaluation_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "fix_safety_class": {
          "$ref": "#/$defs/fix_safety_class"
        },
        "participant_ref": {
          "$ref": "#/$defs/opaque_ref"
        },
        "target_scope_ref": {
          "$ref": "#/$defs/opaque_ref"
        },
        "output_origin_class": {
          "$ref": "#/$defs/output_origin_class"
        },
        "review_trigger_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/review_trigger_class"
          },
          "uniqueItems": true
        },
        "final_apply_posture_class": {
          "$ref": "#/$defs/apply_posture_class"
        },
        "checkpoint_requirement_class": {
          "$ref": "#/$defs/checkpoint_requirement_class"
        },
        "compare_requirement_class": {
          "$ref": "#/$defs/compare_requirement_class"
        },
        "generated_artifact_lineage_ref": {
          "$ref": "#/$defs/nullable_opaque_ref"
        },
        "policy_decision_ref": {
          "$ref": "#/$defs/nullable_opaque_ref"
        },
        "external_change_event_ref": {
          "$ref": "#/$defs/nullable_opaque_ref"
        },
        "preview_or_review_ref": {
          "$ref": "#/$defs/nullable_opaque_ref"
        },
        "evaluated_at": {
          "$ref": "#/$defs/timestamp"
        },
        "summary": {
          "$ref": "#/$defs/short_sentence"
        }
      }
    }
  }
}
