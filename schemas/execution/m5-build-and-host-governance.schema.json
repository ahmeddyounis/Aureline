{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/execution/m5-build-and-host-governance.schema.json",
  "title": "Aureline M5 build-and-host governance matrix",
  "description": "Schema for the m5_build_and_host_governance_matrix packet. The packet freezes one governance row per marketed M5 execution surface (local build target, framework-pack build, remote preview session, managed-workspace runtime, connector-backed service, cluster-context execution, live-resource target, incident-replay target). Each row names how the target was discovered, the adapter confidence, the host boundary (execution origin), the control-plane owner of mutable truth, the managed-workspace lifecycle state, the preview/runtime mutation class, the preview/approval state, evidence freshness, rollback posture, and the live-resource persistence and expiry classes. A non-inheriting claim gate derives the execution claim that may be published: a surface with an undiscovered target, unverified adapter confidence, an unbound host, an unknown control-plane owner, an unavailable workspace, a destructive mutation, a bypassed approval, stale evidence, or an incomplete rollback cannot publish an authoritative claim, and its claim decision records whether the gate published, narrowed to a qualified or provisional claim, or withheld it. One row is required per claimed surface so a verified local target never lends a claim to a live-resource mutation or external cluster context, and the recorded published claim, decision, and narrowing reasons must equal the recomputed gate decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "execution_surfaces",
    "execution_claims",
    "target_discovery_classes",
    "adapter_confidences",
    "host_boundaries",
    "control_plane_ownerships",
    "managed_workspace_lifecycles",
    "mutation_classes",
    "approval_states",
    "evidence_freshness_classes",
    "rollback_postures",
    "persistence_classes",
    "expiry_classes",
    "narrowing_reasons",
    "claim_decisions",
    "surfaces",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_build_and_host_governance_matrix" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "execution_surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/execution_surface" }
    },
    "execution_claims": { "type": "array", "items": { "$ref": "#/$defs/execution_claim" } },
    "target_discovery_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/target_discovery_class" }
    },
    "adapter_confidences": {
      "type": "array",
      "items": { "$ref": "#/$defs/adapter_confidence" }
    },
    "host_boundaries": { "type": "array", "items": { "$ref": "#/$defs/host_boundary" } },
    "control_plane_ownerships": {
      "type": "array",
      "items": { "$ref": "#/$defs/control_plane_ownership" }
    },
    "managed_workspace_lifecycles": {
      "type": "array",
      "items": { "$ref": "#/$defs/managed_workspace_lifecycle" }
    },
    "mutation_classes": { "type": "array", "items": { "$ref": "#/$defs/mutation_class" } },
    "approval_states": { "type": "array", "items": { "$ref": "#/$defs/approval_state" } },
    "evidence_freshness_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_freshness" }
    },
    "rollback_postures": { "type": "array", "items": { "$ref": "#/$defs/rollback_posture" } },
    "persistence_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/persistence_class" }
    },
    "expiry_classes": { "type": "array", "items": { "$ref": "#/$defs/expiry_class" } },
    "narrowing_reasons": { "type": "array", "items": { "$ref": "#/$defs/narrowing_reason" } },
    "claim_decisions": { "type": "array", "items": { "$ref": "#/$defs/claim_decision" } },
    "surfaces": { "type": "array", "items": { "$ref": "#/$defs/surface" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "execution_surface": {
      "enum": [
        "local_build_target",
        "framework_pack_build",
        "remote_preview_session",
        "managed_workspace_runtime",
        "connector_backed_service",
        "cluster_context_exec",
        "live_resource_target",
        "incident_replay_target"
      ]
    },
    "execution_claim": {
      "enum": ["authoritative", "qualified", "provisional", "withheld"]
    },
    "target_discovery_class": {
      "enum": [
        "declared_manifest",
        "workspace_probe",
        "adapter_inferred",
        "control_plane_listed",
        "user_supplied",
        "undiscovered"
      ]
    },
    "adapter_confidence": {
      "enum": ["verified", "high", "heuristic", "unverified"]
    },
    "host_boundary": {
      "enum": [
        "local_host",
        "managed_workspace",
        "remote_attached",
        "cluster_context",
        "bridged_host",
        "unbound_host"
      ]
    },
    "control_plane_ownership": {
      "enum": ["product_owned", "co_owned", "external_owned", "unknown_owner"]
    },
    "managed_workspace_lifecycle": {
      "enum": [
        "active",
        "provisioning",
        "suspended",
        "draining",
        "terminated",
        "not_applicable"
      ]
    },
    "mutation_class": {
      "enum": [
        "read_only",
        "preview_only",
        "reversible_apply",
        "irreversible_apply",
        "destructive_apply"
      ]
    },
    "approval_state": {
      "enum": ["not_required", "approved", "preview_pending", "approval_required_unmet", "bypassed"]
    },
    "evidence_freshness": {
      "enum": ["current", "stale", "expired", "unknown"]
    },
    "rollback_posture": {
      "enum": [
        "reversible_verified",
        "reversible_unverified",
        "compensating_only",
        "irreversible",
        "not_applicable"
      ]
    },
    "persistence_class": {
      "enum": ["durable", "session_scoped", "ephemeral", "unknown"]
    },
    "expiry_class": {
      "enum": ["no_expiry", "scheduled_expiry", "expired", "unknown"]
    },
    "narrowing_reason": {
      "enum": [
        "target_undiscovered",
        "adapter_confidence_low",
        "host_unbound",
        "control_plane_unknown",
        "workspace_unavailable",
        "unsafe_mutation",
        "approval_bypassed",
        "evidence_stale",
        "rollback_incomplete"
      ]
    },
    "claim_decision": {
      "enum": ["publish", "narrow_to_qualified", "narrow_to_provisional", "withhold"]
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "execution_surface",
        "target_discovery_class",
        "adapter_confidence",
        "host_boundary",
        "control_plane_ownership",
        "managed_workspace_lifecycle",
        "mutation_class",
        "approval_state",
        "evidence_freshness",
        "rollback_posture",
        "persistence_class",
        "expiry_class",
        "declared_claim",
        "published_claim",
        "claim_decision",
        "target_identity_ref",
        "host_boundary_ref",
        "control_plane_ref",
        "mutation_preview_ref",
        "rollback_ref",
        "support_export_ref",
        "note"
      ],
      "properties": {
        "surface_id": { "$ref": "#/$defs/non_empty_string" },
        "execution_surface": { "$ref": "#/$defs/execution_surface" },
        "target_discovery_class": { "$ref": "#/$defs/target_discovery_class" },
        "adapter_confidence": { "$ref": "#/$defs/adapter_confidence" },
        "host_boundary": { "$ref": "#/$defs/host_boundary" },
        "control_plane_ownership": { "$ref": "#/$defs/control_plane_ownership" },
        "managed_workspace_lifecycle": { "$ref": "#/$defs/managed_workspace_lifecycle" },
        "mutation_class": { "$ref": "#/$defs/mutation_class" },
        "approval_state": { "$ref": "#/$defs/approval_state" },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness" },
        "rollback_posture": { "$ref": "#/$defs/rollback_posture" },
        "persistence_class": { "$ref": "#/$defs/persistence_class" },
        "expiry_class": { "$ref": "#/$defs/expiry_class" },
        "declared_claim": { "$ref": "#/$defs/execution_claim" },
        "published_claim": { "$ref": "#/$defs/execution_claim" },
        "claim_decision": { "$ref": "#/$defs/claim_decision" },
        "narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        },
        "target_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "host_boundary_ref": { "$ref": "#/$defs/non_empty_string" },
        "control_plane_ref": { "$ref": "#/$defs/non_empty_string" },
        "mutation_preview_ref": { "$ref": "#/$defs/non_empty_string" },
        "rollback_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_surfaces",
        "surface_count",
        "authoritative_surfaces",
        "qualified_surfaces",
        "provisional_surfaces",
        "withheld_surfaces",
        "publishable_surfaces",
        "narrowed_surfaces",
        "withheld_decision_surfaces",
        "current_evidence_surfaces",
        "low_confidence_surfaces",
        "unbound_host_surfaces",
        "external_control_plane_surfaces",
        "surfaces_with_narrowing_reasons"
      ],
      "properties": {
        "total_surfaces": { "type": "integer", "minimum": 0 },
        "surface_count": { "type": "integer", "minimum": 0 },
        "authoritative_surfaces": { "type": "integer", "minimum": 0 },
        "qualified_surfaces": { "type": "integer", "minimum": 0 },
        "provisional_surfaces": { "type": "integer", "minimum": 0 },
        "withheld_surfaces": { "type": "integer", "minimum": 0 },
        "publishable_surfaces": { "type": "integer", "minimum": 0 },
        "narrowed_surfaces": { "type": "integer", "minimum": 0 },
        "withheld_decision_surfaces": { "type": "integer", "minimum": 0 },
        "current_evidence_surfaces": { "type": "integer", "minimum": 0 },
        "low_confidence_surfaces": { "type": "integer", "minimum": 0 },
        "unbound_host_surfaces": { "type": "integer", "minimum": 0 },
        "external_control_plane_surfaces": { "type": "integer", "minimum": 0 },
        "surfaces_with_narrowing_reasons": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
