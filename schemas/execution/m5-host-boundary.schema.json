{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/execution/m5-host-boundary.schema.json",
  "title": "Aureline M5 host-boundary matrix",
  "description": "Schema for the m5_host_boundary_matrix packet. The packet freezes one host-boundary row per M5 execution lane that can cross from the local shell to a remote, container, managed-workspace, browser-bridge, or service-plane host (notebook run, preview session, framework action, profiler capture, request/browser-runtime mutation, incident/resource action, managed-workspace run, service-plane action). Each row names which host kind the work ran on, which origin locus its execution-origin receipt may claim, whether an origin receipt was captured, the live connection state, whether the host/target identity is stably bound, and whether that identity survives into desktop/CLI/support exports. A non-inheriting attribution gate derives the attribution confidence that may be published: a missing origin receipt, a bridged or reconnecting connection, a stale context, an unbound host, or a broken export continuity cannot publish a confirmed origin, and the boundary decision records whether the gate published, narrowed, flagged for review, or withheld it. The published origin locus is pinned to the host kind so a remote, managed, bridged, or service-plane host can never imply local execution, one row is required per claimed lane so no lane inherits a confirmed origin, and the recorded published attribution, locus, decision, and narrowing reasons must equal the recomputed gate decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "execution_lanes",
    "host_kinds",
    "origin_loci",
    "attribution_confidences",
    "origin_receipt_states",
    "connection_states",
    "host_binding_states",
    "export_continuity_states",
    "narrowing_reasons",
    "boundary_decisions",
    "lanes",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_host_boundary_matrix" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "execution_lanes": { "type": "array", "items": { "$ref": "#/$defs/execution_lane" } },
    "host_kinds": { "type": "array", "items": { "$ref": "#/$defs/host_kind" } },
    "origin_loci": { "type": "array", "items": { "$ref": "#/$defs/origin_locus" } },
    "attribution_confidences": {
      "type": "array",
      "items": { "$ref": "#/$defs/attribution_confidence" }
    },
    "origin_receipt_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/origin_receipt_state" }
    },
    "connection_states": { "type": "array", "items": { "$ref": "#/$defs/connection_state" } },
    "host_binding_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/host_binding_state" }
    },
    "export_continuity_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/export_continuity_state" }
    },
    "narrowing_reasons": { "type": "array", "items": { "$ref": "#/$defs/narrowing_reason" } },
    "boundary_decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/boundary_decision" }
    },
    "lanes": { "type": "array", "items": { "$ref": "#/$defs/lane" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "string_array": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
    "execution_lane": {
      "enum": [
        "notebook_run",
        "preview_session",
        "framework_action",
        "profiler_capture",
        "request_runtime_mutation",
        "incident_resource_action",
        "managed_workspace_run",
        "service_plane_action"
      ]
    },
    "host_kind": {
      "enum": [
        "local",
        "ssh",
        "container",
        "managed_workspace",
        "browser_bridge",
        "service_plane"
      ]
    },
    "origin_locus": {
      "enum": ["local", "remote", "managed", "bridged", "service_plane"]
    },
    "attribution_confidence": {
      "enum": ["confirmed", "attributed", "provisional", "stale", "unattributed"]
    },
    "origin_receipt_state": {
      "enum": ["signed", "recorded", "inferred", "missing"]
    },
    "connection_state": {
      "enum": ["connected", "bridged", "reconnecting", "stale"]
    },
    "host_binding_state": {
      "enum": ["bound", "rebound", "unbound"]
    },
    "export_continuity_state": {
      "enum": ["continuous", "partial", "broken"]
    },
    "narrowing_reason": {
      "enum": [
        "missing_origin_receipt",
        "bridged_boundary",
        "reconnecting_host",
        "stale_context",
        "unbound_host",
        "export_continuity_broken"
      ]
    },
    "boundary_decision": {
      "enum": ["publish", "narrow", "flag_for_review", "withhold"]
    },
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_id",
        "execution_lane",
        "host_kind",
        "published_locus",
        "origin_receipt_state",
        "connection_state",
        "host_binding_state",
        "export_continuity_state",
        "declared_attribution",
        "published_attribution",
        "boundary_decision",
        "host_identity_ref",
        "origin_receipt_ref",
        "context_strip_ref",
        "execution_ref",
        "support_export_ref",
        "note"
      ],
      "properties": {
        "lane_id": { "$ref": "#/$defs/non_empty_string" },
        "execution_lane": { "$ref": "#/$defs/execution_lane" },
        "host_kind": { "$ref": "#/$defs/host_kind" },
        "published_locus": { "$ref": "#/$defs/origin_locus" },
        "origin_receipt_state": { "$ref": "#/$defs/origin_receipt_state" },
        "connection_state": { "$ref": "#/$defs/connection_state" },
        "host_binding_state": { "$ref": "#/$defs/host_binding_state" },
        "export_continuity_state": { "$ref": "#/$defs/export_continuity_state" },
        "declared_attribution": { "$ref": "#/$defs/attribution_confidence" },
        "published_attribution": { "$ref": "#/$defs/attribution_confidence" },
        "boundary_decision": { "$ref": "#/$defs/boundary_decision" },
        "narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        },
        "host_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "previous_host_ref": { "type": "string" },
        "rebind_diff_ref": { "type": "string" },
        "origin_receipt_ref": { "$ref": "#/$defs/non_empty_string" },
        "context_strip_ref": { "$ref": "#/$defs/non_empty_string" },
        "execution_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_lanes",
        "lane_count",
        "confirmed_lanes",
        "attributed_lanes",
        "provisional_lanes",
        "stale_lanes",
        "unattributed_lanes",
        "publishable_lanes",
        "narrowed_lanes",
        "flagged_lanes",
        "withheld_lanes",
        "local_lanes",
        "boundary_crossing_lanes",
        "rebound_lanes",
        "bridged_lanes",
        "missing_receipt_lanes",
        "lanes_with_narrowing_reasons"
      ],
      "properties": {
        "total_lanes": { "type": "integer", "minimum": 0 },
        "lane_count": { "type": "integer", "minimum": 0 },
        "confirmed_lanes": { "type": "integer", "minimum": 0 },
        "attributed_lanes": { "type": "integer", "minimum": 0 },
        "provisional_lanes": { "type": "integer", "minimum": 0 },
        "stale_lanes": { "type": "integer", "minimum": 0 },
        "unattributed_lanes": { "type": "integer", "minimum": 0 },
        "publishable_lanes": { "type": "integer", "minimum": 0 },
        "narrowed_lanes": { "type": "integer", "minimum": 0 },
        "flagged_lanes": { "type": "integer", "minimum": 0 },
        "withheld_lanes": { "type": "integer", "minimum": 0 },
        "local_lanes": { "type": "integer", "minimum": 0 },
        "boundary_crossing_lanes": { "type": "integer", "minimum": 0 },
        "rebound_lanes": { "type": "integer", "minimum": 0 },
        "bridged_lanes": { "type": "integer", "minimum": 0 },
        "missing_receipt_lanes": { "type": "integer", "minimum": 0 },
        "lanes_with_narrowing_reasons": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
