{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/execution/env_inspect.schema.json",
  "title": "Aureline env-inspect contract",
  "description": "Boundary schema for the env-inspect snapshot and its support-export wrapper. One snapshot projects a freshly resolved execution_context_record into a fixed set of core fields and typed degradation labels every claimed beta surface renders identically (chrome inspector, headless CLI, support-export packet, reviewer docs). Raw environment bodies, raw command lines, secrets, and unmanaged credentials are out of scope; the redaction class is pinned to structured_tokens_only and is the only valid value. Adding a section, severity, or core field is additive-minor and bumps schema_version; repurposing a field is breaking. The runtime Rust crate at /crates/aureline-runtime/src/env_inspect/ is the schema of record; this file is the cross-tool boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/env_inspect_snapshot_record" },
    { "$ref": "#/$defs/env_inspect_support_export_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Env-inspect schema version. Bumped on breaking payload changes; additive-optional fields do not bump this version."
    },
    "execution_context_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Execution-context schema version the snapshot was projected from. Mirrors the seed crate version."
    },
    "section": {
      "type": "string",
      "enum": [
        "lane",
        "target",
        "toolchain",
        "environment_capsule",
        "policy_and_trust",
        "scope",
        "cache",
        "prebuild",
        "mixed_version",
        "target_confidence",
        "provenance"
      ],
      "description": "Closed render-order section vocabulary. Consumers MUST emit sections in this order."
    },
    "severity": {
      "type": "string",
      "enum": ["notice", "warning", "blocking"],
      "description": "Closed severity band for degradation labels. notice = honesty marker; warning = review required; blocking = dispatch must be re-authorised."
    },
    "redaction_class": {
      "type": "string",
      "enum": ["structured_tokens_only"],
      "description": "Only structured tokens, hashes, ids, and class labels are emitted. Reviewer / support flows MAY embed the payload verbatim."
    },
    "lane": {
      "type": "string",
      "enum": ["local_host", "remote_attach", "container", "request_workspace"],
      "description": "Beta execution-context lane the canonical context resolves onto."
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "terminal",
        "task",
        "debug",
        "test",
        "notebook_kernel",
        "scaffolding",
        "ai_tool_call",
        "doctor_repair",
        "import_probe",
        "replay_probe"
      ]
    },
    "target_class": {
      "type": "string",
      "enum": [
        "local_host",
        "ssh_remote",
        "container_local",
        "devcontainer",
        "remote_workspace_vm",
        "prebuild_runtime",
        "managed_workspace",
        "notebook_kernel_local",
        "notebook_kernel_remote",
        "ai_sandbox"
      ]
    },
    "reachability_state": {
      "type": "string",
      "enum": ["reachable", "warming", "degraded", "unreachable", "policy_blocked"]
    },
    "toolchain_class": {
      "type": "string",
      "enum": [
        "interpreter",
        "compiler_toolchain",
        "package_manager_runner",
        "containerised_runtime",
        "notebook_kernel_runtime",
        "language_server_process",
        "debug_adapter_runtime",
        "test_runner_runtime",
        "build_driver_runtime",
        "ai_tool_runtime",
        "login_shell"
      ]
    },
    "activation_strategy": {
      "type": "string",
      "enum": [
        "ambient_path",
        "env_manager_shim",
        "venv_activation",
        "nix_shell",
        "nix_flake",
        "direnv",
        "devcontainer_build",
        "oci_image_ref",
        "explicit_override",
        "fallback_resolution"
      ]
    },
    "capsule_drift_state": {
      "type": "string",
      "enum": [
        "in_sync",
        "stale_inputs",
        "generator_changed",
        "manually_diverged",
        "unknown_lineage"
      ]
    },
    "trust_state": {
      "type": "string",
      "enum": ["trusted", "restricted", "pending_evaluation"]
    },
    "identity_mode": {
      "type": "string",
      "enum": ["account_free_local", "self_hosted_org", "managed_convenience"]
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "current_root",
        "named_workset",
        "sparse_slice",
        "full_workspace",
        "policy_limited_view",
        "review_workspace",
        "companion_surface"
      ]
    },
    "cache_disposition": {
      "type": "string",
      "enum": [
        "cold",
        "warm",
        "prebuild_reused",
        "capsule_reused",
        "rejected_drift",
        "rejected_policy",
        "rejected_trust"
      ]
    },
    "prebuild_reuse_state": {
      "type": "string",
      "enum": [
        "not_applicable",
        "candidate",
        "reused",
        "rejected_drift",
        "rejected_policy",
        "rejected_trust"
      ]
    },
    "prebuild_invalidation_reason": {
      "type": "string",
      "enum": [
        "capsule_drift",
        "policy_epoch_advanced",
        "trust_state_restricted",
        "trust_state_pending",
        "target_class_changed"
      ]
    },
    "mixed_version_state": {
      "type": "string",
      "enum": ["not_applicable", "aligned", "not_negotiated", "drift_detected"]
    },
    "mixed_version_reason": {
      "type": "string",
      "enum": [
        "local_only",
        "helper_boundary_not_negotiated",
        "protocols_aligned",
        "protocol_skew_detected"
      ]
    },
    "confidence_level": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "target_confidence_reason": {
      "type": "string",
      "enum": [
        "exact_local_target",
        "surface_requested_target",
        "explicit_target_override",
        "workspace_default_target",
        "resolver_fallback_target",
        "conflicting_target_sources",
        "remote_or_managed_boundary",
        "trust_pending",
        "trust_restricted",
        "policy_blocked_reachability",
        "capsule_drift",
        "prebuild_runtime",
        "mixed_version_unchecked"
      ]
    },
    "degraded_field_reason": {
      "type": "string",
      "enum": [
        "toolchain_fallback",
        "activator_blocked_by_trust",
        "activator_blocked_by_policy",
        "activator_unsupported_on_target",
        "capsule_unresolved",
        "capsule_drift_detected",
        "target_unreachable",
        "policy_epoch_stale",
        "trust_state_unresolved",
        "workset_member_unavailable",
        "provenance_gap",
        "confidence_low",
        "remote_agent_scope_mismatch"
      ]
    },
    "environment_capsule_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capsule_id", "capsule_hash", "resolved_schema_version", "drift_state"],
      "properties": {
        "capsule_id": { "type": "string", "minLength": 1 },
        "capsule_hash": { "type": "string", "minLength": 1 },
        "resolved_schema_version": { "type": "string", "minLength": 1 },
        "drift_state": { "$ref": "#/$defs/capsule_drift_state" }
      }
    },
    "core_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section", "section_token", "field_path", "label"],
      "properties": {
        "section": { "$ref": "#/$defs/section" },
        "section_token": { "type": "string", "minLength": 1 },
        "field_path": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "value_token": { "type": "string" }
      }
    },
    "degradation_label": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_path",
        "reason",
        "reason_token",
        "severity",
        "severity_token",
        "label"
      ],
      "properties": {
        "field_path": { "type": "string", "minLength": 1 },
        "reason": { "$ref": "#/$defs/degraded_field_reason" },
        "reason_token": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/$defs/severity" },
        "severity_token": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "repair_hook_ref": { "type": "string", "minLength": 1 }
      }
    },
    "env_inspect_snapshot_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "execution_context_schema_version",
        "execution_context_id",
        "workspace_id",
        "surface",
        "surface_token",
        "lane",
        "lane_token",
        "lane_label",
        "boundary_cue_visible",
        "target_class",
        "target_class_token",
        "canonical_target_id",
        "reachability_state",
        "reachability_state_token",
        "toolchain_class",
        "toolchain_class_token",
        "toolchain_id",
        "resolved_version",
        "activation_strategy",
        "activation_strategy_token",
        "toolchain_degraded_fallback",
        "environment_capsule_ref",
        "trust_state",
        "trust_state_token",
        "identity_mode",
        "identity_mode_token",
        "policy_epoch",
        "workset_scope_class",
        "workset_scope_class_token",
        "cache_disposition",
        "cache_disposition_token",
        "prebuild_reuse_state",
        "prebuild_reuse_state_token",
        "prebuild_compatibility_fingerprint",
        "mixed_version_state",
        "mixed_version_state_token",
        "mixed_version_reason",
        "mixed_version_reason_token",
        "client_protocol",
        "target_confidence_level",
        "target_confidence_level_token",
        "target_confidence_reasons",
        "target_confidence_reason_tokens",
        "provenance_record_ref",
        "resolver_version",
        "recorded_at",
        "core_fields",
        "degradation_labels"
      ],
      "properties": {
        "record_kind": { "const": "env_inspect_snapshot_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "execution_context_schema_version": {
          "$ref": "#/$defs/execution_context_schema_version"
        },
        "execution_context_id": { "type": "string", "minLength": 1 },
        "workspace_id": { "type": "string", "minLength": 1 },
        "surface": { "$ref": "#/$defs/surface_class" },
        "surface_token": { "type": "string", "minLength": 1 },
        "lane": { "$ref": "#/$defs/lane" },
        "lane_token": { "type": "string", "minLength": 1 },
        "lane_label": { "type": "string", "minLength": 1 },
        "boundary_cue_visible": { "type": "boolean" },
        "target_class": { "$ref": "#/$defs/target_class" },
        "target_class_token": { "type": "string", "minLength": 1 },
        "canonical_target_id": { "type": "string", "minLength": 1 },
        "working_directory": { "type": "string", "minLength": 1 },
        "reachability_state": { "$ref": "#/$defs/reachability_state" },
        "reachability_state_token": { "type": "string", "minLength": 1 },
        "toolchain_class": { "$ref": "#/$defs/toolchain_class" },
        "toolchain_class_token": { "type": "string", "minLength": 1 },
        "toolchain_id": { "type": "string", "minLength": 1 },
        "resolved_version": { "type": "string", "minLength": 1 },
        "activation_strategy": { "$ref": "#/$defs/activation_strategy" },
        "activation_strategy_token": { "type": "string", "minLength": 1 },
        "toolchain_degraded_fallback": { "type": "boolean" },
        "environment_capsule_ref": { "$ref": "#/$defs/environment_capsule_ref" },
        "trust_state": { "$ref": "#/$defs/trust_state" },
        "trust_state_token": { "type": "string", "minLength": 1 },
        "identity_mode": { "$ref": "#/$defs/identity_mode" },
        "identity_mode_token": { "type": "string", "minLength": 1 },
        "policy_epoch": { "type": "integer", "minimum": 0 },
        "workset_scope_class": { "$ref": "#/$defs/scope_class" },
        "workset_scope_class_token": { "type": "string", "minLength": 1 },
        "cache_disposition": { "$ref": "#/$defs/cache_disposition" },
        "cache_disposition_token": { "type": "string", "minLength": 1 },
        "prebuild_reuse_state": { "$ref": "#/$defs/prebuild_reuse_state" },
        "prebuild_reuse_state_token": { "type": "string", "minLength": 1 },
        "prebuild_snapshot_ref": { "type": "string", "minLength": 1 },
        "prebuild_compatibility_fingerprint": { "type": "string", "minLength": 1 },
        "prebuild_invalidation_reason": { "$ref": "#/$defs/prebuild_invalidation_reason" },
        "mixed_version_state": { "$ref": "#/$defs/mixed_version_state" },
        "mixed_version_state_token": { "type": "string", "minLength": 1 },
        "mixed_version_reason": { "$ref": "#/$defs/mixed_version_reason" },
        "mixed_version_reason_token": { "type": "string", "minLength": 1 },
        "client_protocol": { "type": "string", "minLength": 1 },
        "helper_protocol": { "type": "string", "minLength": 1 },
        "target_confidence_level": { "$ref": "#/$defs/confidence_level" },
        "target_confidence_level_token": { "type": "string", "minLength": 1 },
        "target_confidence_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/target_confidence_reason" }
        },
        "target_confidence_reason_tokens": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "provenance_record_ref": { "type": "string", "minLength": 1 },
        "resolver_version": { "type": "string", "minLength": 1 },
        "recorded_at": { "type": "string", "minLength": 1 },
        "core_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/core_field" },
          "minItems": 1
        },
        "degradation_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/degradation_label" }
        }
      }
    },
    "env_inspect_support_export_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "execution_context_schema_version",
        "manifest_id",
        "generated_at",
        "snapshots",
        "redaction_class",
        "redaction_class_token",
        "any_degradation",
        "any_requires_review",
        "any_blocks_dispatch"
      ],
      "properties": {
        "record_kind": { "const": "env_inspect_support_export_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "execution_context_schema_version": {
          "$ref": "#/$defs/execution_context_schema_version"
        },
        "manifest_id": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "minLength": 1 },
        "snapshots": {
          "type": "array",
          "items": { "$ref": "#/$defs/env_inspect_snapshot_record" },
          "minItems": 1
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "redaction_class_token": { "type": "string", "minLength": 1 },
        "any_degradation": { "type": "boolean" },
        "any_requires_review": { "type": "boolean" },
        "any_blocks_dispatch": { "type": "boolean" }
      }
    }
  }
}
