{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/execution/environment_matrix_row.schema.json",
  "title": "Aureline test environment-matrix row record",
  "description": "Boundary schema for the environment_matrix_row_record frozen in docs/execution/test_watch_and_environment_contract.md. The record keeps local, container, remote, CI, notebook, and provider-backed test results separate with explicit authority, freshness, comparability, target identity, runtime/toolchain/build refs, artifact refs, and rerun posture. It composes with run / attempt, context snapshot, test run-summary, artifact event, inline test-result, and watch-controller records rather than collapsing environments into one generic pass/fail row. Raw command lines, raw stdout or stderr bytes, raw environment bodies, raw absolute paths, raw URLs, raw secret values, raw test names, raw assertion bodies, raw artifact bytes, raw notebook cell bodies, and raw stack traces MUST NOT cross this boundary; rows carry opaque refs, class labels, counts, and timestamps only. Adding a new optional field or enum member is additive-minor; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/environment_matrix_row_record" }
  ],
  "$defs": {
    "environment_matrix_row_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for this environment-matrix row family."
    },
    "record_kind": {
      "type": "string",
      "enum": ["environment_matrix_row_record"]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for logs, RPC, support bundles, and release packets."
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque ref to another record owned by its registry."
    },
    "opaque_ref_nullable": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480,
      "description": "Short reviewable sentence. Raw code, raw paths, raw secrets, raw tool arguments, raw test names, and raw runner payloads are forbidden."
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_and_hashes_only",
        "support_bundle_scoped",
        "broadened_capture"
      ],
      "description": "Redaction posture for the record. broadened_capture requires an approval-ticket ref."
    },
    "target_environment_class": {
      "type": "string",
      "enum": [
        "local_environment",
        "container_environment",
        "remote_environment",
        "ci_environment",
        "notebook_environment",
        "provider_backed_environment",
        "target_environment_unknown_requires_review"
      ],
      "description": "Environment family for this row. Rows remain distinct even when result state matches."
    },
    "authority_class": {
      "type": "string",
      "enum": [
        "local_authoritative_live",
        "local_cached",
        "container_authoritative_live",
        "remote_agent_authoritative_live",
        "ci_imported_read_only",
        "notebook_kernel_authoritative",
        "provider_backed_read_only",
        "merged_multi_environment_authority",
        "authority_unknown_requires_review"
      ],
      "description": "Who owns the result truth represented by this row. Imported CI and provider-backed rows are read-only unless a separate local/compatible parity row is present."
    },
    "comparability_class": {
      "type": "string",
      "enum": [
        "exact_target",
        "compatible_rerun",
        "comparable_with_caution",
        "manual_re_resolve_required",
        "comparison_blocked_incompatible",
        "comparison_pending",
        "comparability_unknown_requires_review"
      ],
      "description": "How this row may be compared with another environment row."
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "imported_current_for_source_environment",
        "imported_stale_for_local_environment",
        "stale_target_drift",
        "stale_artifact_expired",
        "freshness_unknown_requires_review"
      ]
    },
    "result_source_class": {
      "type": "string",
      "enum": [
        "local_execution_authoritative",
        "local_execution_cached",
        "provider_imported_only",
        "provider_imported_with_local_parity_validation",
        "merged_local_and_provider_with_parity_validation",
        "ai_assisted_filter_then_local_execution",
        "test_result_source_unknown_requires_review"
      ],
      "description": "Re-export of the test run-summary result-source vocabulary."
    },
    "parity_validation_class": {
      "type": "string",
      "enum": [
        "parity_not_attempted",
        "parity_validated_local_matches_provider",
        "parity_drift_detected_minor",
        "parity_drift_detected_major",
        "parity_validation_pending_local_rerun",
        "parity_validation_skipped_under_policy",
        "parity_validation_unknown_requires_review"
      ],
      "description": "Re-export of the test run-summary parity-validation vocabulary."
    },
    "result_state_class": {
      "type": "string",
      "enum": [
        "queued",
        "preparing",
        "running",
        "waiting_input",
        "partially_complete",
        "passed",
        "failed",
        "cancelled",
        "stale_output",
        "unsupported_on_this_environment",
        "result_state_unknown_requires_review"
      ]
    },
    "divergence_class": {
      "type": "string",
      "enum": [
        "no_known_divergence",
        "local_vs_container_divergence",
        "local_vs_remote_divergence",
        "local_vs_ci_divergence_minor",
        "local_vs_ci_divergence_major",
        "notebook_vs_file_divergence",
        "provider_vs_local_parity_pending",
        "incompatible_environment_comparison_blocked",
        "divergence_unknown_requires_review"
      ]
    },
    "denial_reason_class": {
      "type": "string",
      "enum": [
        "environment_matrix_row_record_must_cite_target_environment_class",
        "environment_matrix_row_record_must_cite_authority_class",
        "environment_matrix_row_record_must_cite_comparability_class",
        "environment_matrix_row_record_must_cite_execution_context_ref",
        "environment_matrix_row_record_must_cite_runtime_toolchain_or_build_refs",
        "environment_matrix_row_record_must_cite_artifact_refs_when_imported_or_completed",
        "environment_matrix_row_record_must_not_collapse_multiple_environments_into_one_row",
        "environment_matrix_row_record_must_not_compare_incompatible_targets_as_pass_fail",
        "environment_matrix_row_record_must_mark_imported_ci_read_only",
        "environment_matrix_row_record_requires_manual_reresolve_before_rerun",
        "environment_matrix_row_record_unknown_authority_requires_review",
        "environment_matrix_row_record_unknown_comparability_requires_review"
      ]
    },
    "audit_event_id": {
      "type": "string",
      "enum": [
        "environment_matrix_row_record_published",
        "environment_matrix_row_record_refreshed",
        "environment_matrix_row_record_authority_narrowed",
        "environment_matrix_row_record_comparability_updated",
        "environment_matrix_row_record_artifact_refs_updated",
        "environment_matrix_row_record_comparison_blocked",
        "environment_matrix_row_record_imported_ci_marked_read_only",
        "environment_matrix_row_record_collapse_forbidden_denial",
        "environment_matrix_row_record_incompatible_comparison_forbidden_denial",
        "environment_matrix_row_record_audit_denial_emitted"
      ]
    },
    "by_state_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed_count",
        "failed_count",
        "errored_count",
        "timed_out_count",
        "skipped_count",
        "quarantined_count",
        "filtered_out_count",
        "disabled_by_policy_count",
        "unsupported_here_count",
        "stale_partial_count",
        "unknown_requires_review_count"
      ],
      "properties": {
        "passed_count": { "$ref": "#/$defs/non_negative_integer" },
        "failed_count": { "$ref": "#/$defs/non_negative_integer" },
        "errored_count": { "$ref": "#/$defs/non_negative_integer" },
        "timed_out_count": { "$ref": "#/$defs/non_negative_integer" },
        "skipped_count": { "$ref": "#/$defs/non_negative_integer" },
        "quarantined_count": { "$ref": "#/$defs/non_negative_integer" },
        "filtered_out_count": { "$ref": "#/$defs/non_negative_integer" },
        "disabled_by_policy_count": { "$ref": "#/$defs/non_negative_integer" },
        "unsupported_here_count": { "$ref": "#/$defs/non_negative_integer" },
        "stale_partial_count": { "$ref": "#/$defs/non_negative_integer" },
        "unknown_requires_review_count": { "$ref": "#/$defs/non_negative_integer" }
      },
      "description": "Result-count projection using the same count vocabulary as test_run_summary_record."
    },
    "artifact_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "structured_test_report_artifact_event_ref",
        "coverage_artifact_event_ref",
        "log_artifact_event_ref",
        "support_bundle_ref",
        "additional_artifact_event_refs"
      ],
      "properties": {
        "structured_test_report_artifact_event_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "coverage_artifact_event_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "log_artifact_event_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "support_bundle_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "additional_artifact_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        }
      }
    },
    "comparison_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compare_to_environment_matrix_row_refs",
        "divergence_class",
        "comparability_class",
        "comparison_evidence_ref",
        "caution_summary"
      ],
      "properties": {
        "compare_to_environment_matrix_row_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "divergence_class": { "$ref": "#/$defs/divergence_class" },
        "comparability_class": { "$ref": "#/$defs/comparability_class" },
        "comparison_evidence_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "caution_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "action_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rerun_action_ref",
        "debug_action_ref",
        "manual_re_resolve_required",
        "re_resolve_target_action_ref"
      ],
      "properties": {
        "rerun_action_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "debug_action_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "manual_re_resolve_required": { "type": "boolean" },
        "re_resolve_target_action_ref": { "$ref": "#/$defs/opaque_ref_nullable" }
      }
    },
    "environment_matrix_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "environment_matrix_row_schema_version",
        "environment_matrix_row_record_id",
        "test_session_ref",
        "verdict_ref",
        "test_item_ref",
        "run_ref",
        "attempt_ref",
        "test_run_summary_ref",
        "execution_context_ref",
        "context_snapshot_ref",
        "target_environment_class",
        "target_identity_ref",
        "runtime_ref",
        "toolchain_ref",
        "build_ref",
        "environment_fingerprint_ref",
        "authority_class",
        "comparability_class",
        "freshness_class",
        "result_source_class",
        "parity_validation_class",
        "result_state_class",
        "by_state_counts",
        "artifact_refs",
        "comparison_summary",
        "action_posture",
        "audit_event_refs",
        "denial_reason_class",
        "captured_at",
        "redaction_class",
        "approval_ticket_ref"
      ],
      "properties": {
        "record_kind": { "const": "environment_matrix_row_record" },
        "environment_matrix_row_schema_version": { "$ref": "#/$defs/environment_matrix_row_schema_version" },
        "environment_matrix_row_record_id": { "$ref": "#/$defs/opaque_id" },
        "test_session_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "verdict_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "test_item_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "run_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "attempt_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "test_run_summary_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "execution_context_ref": { "$ref": "#/$defs/opaque_ref" },
        "context_snapshot_ref": { "$ref": "#/$defs/opaque_ref" },
        "target_environment_class": { "$ref": "#/$defs/target_environment_class" },
        "target_identity_ref": { "$ref": "#/$defs/opaque_ref" },
        "runtime_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "toolchain_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "build_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "environment_fingerprint_ref": { "$ref": "#/$defs/opaque_ref" },
        "authority_class": { "$ref": "#/$defs/authority_class" },
        "comparability_class": { "$ref": "#/$defs/comparability_class" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "result_source_class": { "$ref": "#/$defs/result_source_class" },
        "parity_validation_class": { "$ref": "#/$defs/parity_validation_class" },
        "result_state_class": { "$ref": "#/$defs/result_state_class" },
        "by_state_counts": { "$ref": "#/$defs/by_state_counts" },
        "artifact_refs": { "$ref": "#/$defs/artifact_refs" },
        "comparison_summary": { "$ref": "#/$defs/comparison_summary" },
        "action_posture": { "$ref": "#/$defs/action_posture" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/audit_event_id" },
          "uniqueItems": true
        },
        "denial_reason_class": {
          "oneOf": [
            { "$ref": "#/$defs/denial_reason_class" },
            { "type": "null" }
          ]
        },
        "captured_at": { "$ref": "#/$defs/timestamp" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "approval_ticket_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "notes": { "$ref": "#/$defs/short_sentence" }
      }
    }
  }
}
