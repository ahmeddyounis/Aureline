{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/quality/materialize-artifact-family-quality-governance.schema.json",
  "title": "Aureline artifact-family quality governance packet",
  "description": "Schema for the artifact_family_quality_governance_record packet. The packet materializes the effective quality profile that won, the ordered save participants, quality-action safety classes, and the suppression-or-baseline debt records for the newer code-adjacent artifact families (notebooks, request files, scaffolded outputs, framework generators, and data-adjacent artifacts). It keeps suppressed distinct from baselined, never lets a save participant become an invisible broad write, and surfaces policy overrides rather than masking them. It embeds no raw source, raw tool arguments, raw paths, provider payloads, or secrets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "artifact_family_classes",
    "suppressions",
    "baselines",
    "families",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "artifact_family_quality_governance_record" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "artifact_family_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_family_class" }
    },
    "suppressions": {
      "type": "array",
      "items": { "$ref": "#/$defs/governed_suppression" }
    },
    "baselines": {
      "type": "array",
      "items": { "$ref": "#/$defs/governed_baseline" }
    },
    "families": {
      "type": "array",
      "items": { "$ref": "#/$defs/family_materialization" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "artifact_family_class": {
      "enum": [
        "notebook",
        "request_file",
        "scaffolded_output",
        "framework_generator",
        "data_adjacent_artifact"
      ]
    },
    "target_scope_class": {
      "enum": [
        "current_file",
        "current_selection",
        "current_root",
        "selected_workset",
        "workspace",
        "review_diff",
        "baseline_family",
        "release_candidate"
      ]
    },
    "owner_class": {
      "enum": [
        "workspace_owner",
        "codebase_team_owner",
        "security_owner",
        "admin_policy_owner",
        "imported_baseline_owner"
      ]
    },
    "reopen_rule_class": {
      "enum": [
        "reopen_on_expiry",
        "reopen_on_rule_change",
        "reopen_on_anchor_remap_failure",
        "reopen_on_profile_or_target_drift",
        "manual_review_only"
      ]
    },
    "policy_lock_state_class": {
      "enum": [
        "editable_local",
        "editable_with_review",
        "read_only_policy_locked",
        "expiry_managed_by_policy"
      ]
    },
    "baseline_compatibility_state_class": {
      "enum": [
        "compatible",
        "tool_or_rule_pack_drift_blocked",
        "profile_drift_blocked",
        "target_drift_blocked",
        "unknown_requires_review"
      ]
    },
    "profile_source_layer": {
      "enum": [
        "policy_lock_or_managed_profile",
        "per_command_override",
        "repository_quality_config",
        "workspace_quality_settings",
        "workspace_profile_override",
        "remote_or_container_default",
        "user_or_profile_default",
        "imported_tool_config",
        "fallback_default",
        "system_auto_detection"
      ]
    },
    "profile_source_state_class": {
      "enum": [
        "selected_winner",
        "shadowed_by_higher_precedence",
        "policy_overridden",
        "downgraded_incompatible",
        "unavailable_in_environment",
        "rejected_invalid",
        "imported_read_only",
        "detected_default"
      ]
    },
    "save_participant_phase_class": {
      "enum": [
        "preflight",
        "format_fix",
        "generated_artifact_update",
        "validation",
        "compare_before_write",
        "durable_write",
        "post_save_indexing_refresh"
      ]
    },
    "action_class": {
      "enum": [
        "format_range",
        "format_document",
        "organize_imports",
        "quick_fix_single",
        "fix_all_rule",
        "lint_autofix_batch",
        "suppression_proposal",
        "baseline_update",
        "scanner_read_only",
        "validation_recheck"
      ]
    },
    "fix_safety_class": {
      "enum": [
        "safe_local_text_edit",
        "whole_file_rewrite_disclosed",
        "generated_companion_update",
        "workspace_wide_preview_required",
        "external_change_conflict_requires_review",
        "policy_blocked",
        "fix_safety_unknown_requires_review"
      ]
    },
    "preview_requirement_class": {
      "enum": [
        "not_required",
        "inline_summary",
        "structured_diff",
        "batch_scope_preview",
        "policy_or_repo_mutation_preview_required",
        "issue_link_or_typed_review_required"
      ]
    },
    "apply_posture_class": {
      "enum": [
        "auto_apply_allowed",
        "preview_before_apply",
        "blocked_pending_user_review",
        "blocked_pending_policy_or_trust",
        "read_only_action"
      ]
    },
    "mutation_scope_class": {
      "enum": [
        "no_mutation_read_only",
        "single_anchor",
        "single_file_localized",
        "single_file_whole_document",
        "multi_file_same_module",
        "multi_file_workspace",
        "generated_family",
        "protected_or_policy_scoped"
      ]
    },
    "debt_state_class": {
      "enum": [
        "suppressed",
        "baselined",
        "waived",
        "new",
        "resolved",
        "unmapped"
      ]
    },
    "governed_suppression": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suppression_id",
        "scope_class",
        "owner_class",
        "owner_ref",
        "created_at",
        "reason",
        "reopen_rule_class",
        "policy_lock_state_class",
        "release_visible",
        "summary"
      ],
      "properties": {
        "suppression_id": { "$ref": "#/$defs/non_empty_string" },
        "scope_class": { "$ref": "#/$defs/target_scope_class" },
        "rule_refs": { "type": "array", "items": { "type": "string" } },
        "finding_refs": { "type": "array", "items": { "type": "string" } },
        "owner_class": { "$ref": "#/$defs/owner_class" },
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "created_at": { "$ref": "#/$defs/non_empty_string" },
        "expires_at": { "type": "string" },
        "reason": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "reopen_rule_class": { "$ref": "#/$defs/reopen_rule_class" },
        "policy_lock_state_class": { "$ref": "#/$defs/policy_lock_state_class" },
        "release_visible": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "governed_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_id",
        "compatible_profile_family_ref",
        "target_scope_class",
        "owner_class",
        "owner_ref",
        "created_at",
        "compatibility_state_class",
        "policy_lock_state_class",
        "reopen_rule_class",
        "release_visible",
        "summary"
      ],
      "properties": {
        "baseline_id": { "$ref": "#/$defs/non_empty_string" },
        "compatible_profile_family_ref": { "$ref": "#/$defs/non_empty_string" },
        "target_scope_class": { "$ref": "#/$defs/target_scope_class" },
        "accepted_finding_refs": { "type": "array", "items": { "type": "string" } },
        "owner_class": { "$ref": "#/$defs/owner_class" },
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "created_at": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "review_refs": { "type": "array", "items": { "type": "string" } },
        "compatibility_state_class": { "$ref": "#/$defs/baseline_compatibility_state_class" },
        "policy_lock_state_class": { "$ref": "#/$defs/policy_lock_state_class" },
        "reopen_rule_class": { "$ref": "#/$defs/reopen_rule_class" },
        "release_visible": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "profile_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effective_profile_ref",
        "winning_source_ref",
        "winning_source_layer",
        "winning_source_state",
        "imported_config_mapped",
        "unmapped_imported_key_count",
        "policy_overridden_key_count",
        "policy_locked",
        "summary"
      ],
      "properties": {
        "effective_profile_ref": { "$ref": "#/$defs/non_empty_string" },
        "winning_source_ref": { "$ref": "#/$defs/non_empty_string" },
        "winning_source_layer": { "$ref": "#/$defs/profile_source_layer" },
        "winning_source_state": { "$ref": "#/$defs/profile_source_state_class" },
        "imported_config_mapped": { "type": "boolean" },
        "unmapped_imported_key_count": { "type": "integer", "minimum": 0 },
        "policy_overridden_key_count": { "type": "integer", "minimum": 0 },
        "policy_locked": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "save_participant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "participant_id",
        "phase_class",
        "phase_order",
        "action_class",
        "fix_safety_class",
        "preview_requirement_class",
        "apply_posture_class",
        "mutation_scope_class",
        "auto_apply_allowed",
        "preview_first_required",
        "apply_blocked",
        "summary"
      ],
      "properties": {
        "participant_id": { "$ref": "#/$defs/non_empty_string" },
        "phase_class": { "$ref": "#/$defs/save_participant_phase_class" },
        "phase_order": { "type": "integer", "minimum": 0 },
        "action_class": { "$ref": "#/$defs/action_class" },
        "fix_safety_class": { "$ref": "#/$defs/fix_safety_class" },
        "preview_requirement_class": { "$ref": "#/$defs/preview_requirement_class" },
        "apply_posture_class": { "$ref": "#/$defs/apply_posture_class" },
        "mutation_scope_class": { "$ref": "#/$defs/mutation_scope_class" },
        "auto_apply_allowed": { "type": "boolean" },
        "preview_first_required": { "type": "boolean" },
        "apply_blocked": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "debt_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "debt_row_id",
        "debt_state_class",
        "owner_ref",
        "release_visible",
        "summary"
      ],
      "properties": {
        "debt_row_id": { "$ref": "#/$defs/non_empty_string" },
        "debt_state_class": { "$ref": "#/$defs/debt_state_class" },
        "suppression_ref": { "type": "string" },
        "baseline_ref": { "type": "string" },
        "finding_refs": { "type": "array", "items": { "type": "string" } },
        "rule_refs": { "type": "array", "items": { "type": "string" } },
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "release_visible": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "family_materialization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_class",
        "family_label",
        "representative_target_ref",
        "profile",
        "save_participants",
        "debt_rows",
        "summary"
      ],
      "properties": {
        "family_class": { "$ref": "#/$defs/artifact_family_class" },
        "family_label": { "$ref": "#/$defs/non_empty_string" },
        "representative_target_ref": { "$ref": "#/$defs/non_empty_string" },
        "profile": { "$ref": "#/$defs/profile_resolution" },
        "save_participants": {
          "type": "array",
          "items": { "$ref": "#/$defs/save_participant" }
        },
        "debt_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/debt_row" }
        },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_families",
        "total_save_participants",
        "auto_apply_participants",
        "preview_first_participants",
        "blocked_participants",
        "suppressed_debt_rows",
        "baselined_debt_rows",
        "waived_debt_rows",
        "new_debt_rows",
        "total_suppressions",
        "total_baselines"
      ],
      "properties": {
        "total_families": { "type": "integer", "minimum": 0 },
        "total_save_participants": { "type": "integer", "minimum": 0 },
        "auto_apply_participants": { "type": "integer", "minimum": 0 },
        "preview_first_participants": { "type": "integer", "minimum": 0 },
        "blocked_participants": { "type": "integer", "minimum": 0 },
        "suppressed_debt_rows": { "type": "integer", "minimum": 0 },
        "baselined_debt_rows": { "type": "integer", "minimum": 0 },
        "waived_debt_rows": { "type": "integer", "minimum": 0 },
        "new_debt_rows": { "type": "integer", "minimum": 0 },
        "total_suppressions": { "type": "integer", "minimum": 0 },
        "total_baselines": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
