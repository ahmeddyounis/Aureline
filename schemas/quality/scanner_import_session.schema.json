{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/quality/scanner_import_session.schema.json",
  "title": "Aureline scanner import session",
  "description": "Boundary schema for scanner import sessions and their CLI, support, and release projections. SARIF and structured scanner feeds preserve tool/version/provenance, source format, freshness, baseline family, mapping fidelity, raw-payload backlink policy, and imported-versus-live truth without embedding raw source, raw payload bodies, raw paths, URLs, logs, command lines, provider payloads, or secrets.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/scanner_import_session" },
    { "$ref": "#/$defs/scanner_import_cli_projection" },
    { "$ref": "#/$defs/scanner_import_release_packet" },
    { "$ref": "#/$defs/imported_scanner_support_export" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "opaque_ref": { "type": "string", "minLength": 1 },
    "opaque_ref_nullable": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 900
    },
    "source_format_class": {
      "type": "string",
      "enum": ["sarif_2_1_0", "structured_scanner_json", "unknown_requires_review"]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "imported_snapshot",
        "stale_imported_snapshot",
        "superseded_imported_snapshot",
        "unverified_imported_snapshot"
      ]
    },
    "raw_payload_backlink_policy": {
      "type": "string",
      "enum": [
        "opaque_refs_only",
        "redacted_by_policy",
        "omitted_unavailable",
        "explicit_opt_in_restricted"
      ]
    },
    "truth_class": {
      "type": "string",
      "enum": ["imported_only", "locally_confirmed"]
    },
    "fidelity_class": {
      "type": "string",
      "enum": [
        "imported_static",
        "locally_confirmed",
        "stale_imported",
        "remapped_contextual",
        "unmapped_anchor",
        "baseline_mismatch",
        "redacted_payload"
      ]
    },
    "delta_state_class": {
      "type": "string",
      "enum": ["new", "resolved", "persisting", "suppressed", "waived", "unmapped"]
    },
    "compatibility_class": {
      "type": "string",
      "enum": [
        "compatible_exact",
        "compatible_with_local_confirmation",
        "blocked_profile_or_tool_mismatch",
        "blocked_rule_pack_mismatch",
        "blocked_anchor_mapping_uncertain",
        "not_comparable_unknown_requires_review"
      ]
    },
    "remap_state_class": {
      "type": "string",
      "enum": ["exact", "contextual", "stale", "unmapped", "imported_static", "not_applicable"]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "delta_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "new_count",
        "resolved_count",
        "persisting_count",
        "suppressed_count",
        "waived_count",
        "unmapped_count"
      ],
      "properties": {
        "new_count": { "type": "integer", "minimum": 0 },
        "resolved_count": { "type": "integer", "minimum": 0 },
        "persisting_count": { "type": "integer", "minimum": 0 },
        "suppressed_count": { "type": "integer", "minimum": 0 },
        "waived_count": { "type": "integer", "minimum": 0 },
        "unmapped_count": { "type": "integer", "minimum": 0 }
      }
    },
    "projection_row": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "finding_id",
        "diagnostic_id",
        "rule_id_ref",
        "truth_class",
        "fidelity_state_class",
        "delta_state_class",
        "remap_state_class",
        "import_freshness_class",
        "read_only",
        "export_safe_summary"
      ],
      "properties": {
        "finding_id": { "$ref": "#/$defs/opaque_ref" },
        "diagnostic_id": { "$ref": "#/$defs/opaque_ref" },
        "rule_id_ref": { "$ref": "#/$defs/opaque_ref" },
        "truth_class": { "$ref": "#/$defs/truth_class" },
        "fidelity_state_class": { "$ref": "#/$defs/fidelity_class" },
        "delta_state_class": { "$ref": "#/$defs/delta_state_class" },
        "remap_state_class": { "$ref": "#/$defs/remap_state_class" },
        "import_freshness_class": { "$ref": "#/$defs/freshness_class" },
        "read_only": { "type": "boolean", "const": true },
        "raw_payload_backlink_policy": { "$ref": "#/$defs/raw_payload_backlink_policy" },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "scanner_import_session": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "record_kind",
        "scanner_import_schema_version",
        "import_id",
        "media_type",
        "source_artifact_ref",
        "raw_payload_refs",
        "import_freshness_class",
        "raw_payload_backlink_policy",
        "run_descriptors",
        "findings",
        "delta_packet",
        "review_packet",
        "redaction_class",
        "imported_at",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": { "const": "scanner_import_session_alpha" },
        "scanner_import_schema_version": { "$ref": "#/$defs/schema_version" },
        "import_id": { "$ref": "#/$defs/opaque_ref" },
        "media_type": { "$ref": "#/$defs/opaque_ref" },
        "source_artifact_ref": { "$ref": "#/$defs/opaque_ref" },
        "raw_payload_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "import_freshness_class": { "$ref": "#/$defs/freshness_class" },
        "raw_payload_backlink_policy": { "$ref": "#/$defs/raw_payload_backlink_policy" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "imported_at": { "$ref": "#/$defs/timestamp" },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "scanner_import_cli_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "scanner_import_schema_version",
        "projection_id",
        "import_session_ref",
        "source_format_class",
        "import_freshness_class",
        "compatibility_class",
        "delta_counts",
        "imported_finding_count",
        "locally_confirmed_count",
        "read_only_count",
        "exact_delta_claim_blocked",
        "raw_payload_refs",
        "raw_payload_backlink_policy",
        "rows",
        "redaction_class",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": { "const": "scanner_import_cli_projection" },
        "scanner_import_schema_version": { "$ref": "#/$defs/schema_version" },
        "projection_id": { "$ref": "#/$defs/opaque_ref" },
        "import_session_ref": { "$ref": "#/$defs/opaque_ref" },
        "source_format_class": { "$ref": "#/$defs/source_format_class" },
        "import_freshness_class": { "$ref": "#/$defs/freshness_class" },
        "compatibility_class": { "$ref": "#/$defs/compatibility_class" },
        "delta_counts": { "$ref": "#/$defs/delta_counts" },
        "imported_finding_count": { "type": "integer", "minimum": 0 },
        "locally_confirmed_count": { "type": "integer", "minimum": 0 },
        "read_only_count": { "type": "integer", "minimum": 0 },
        "exact_delta_claim_blocked": { "type": "boolean" },
        "raw_payload_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "raw_payload_backlink_policy": { "$ref": "#/$defs/raw_payload_backlink_policy" },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/projection_row" }
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "scanner_import_release_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "scanner_import_schema_version",
        "packet_id",
        "release_scope_ref",
        "import_session_ref",
        "diagnostic_delta_packet_ref",
        "suppression_baseline_register_ref",
        "review_packet_ref",
        "source_format_class",
        "import_freshness_class",
        "compatibility_class",
        "baseline_family_ref",
        "delta_counts",
        "active_suppression_or_waiver_count",
        "release_visible_baseline_count",
        "imported_finding_count",
        "locally_confirmed_count",
        "imported_findings_read_only",
        "exact_delta_claim_blocked",
        "raw_payload_backlink_policy",
        "raw_payload_refs",
        "parity_note",
        "redaction_class",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": { "const": "scanner_import_release_packet" },
        "scanner_import_schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/opaque_ref" },
        "release_scope_ref": { "$ref": "#/$defs/opaque_ref" },
        "import_session_ref": { "$ref": "#/$defs/opaque_ref" },
        "diagnostic_delta_packet_ref": { "$ref": "#/$defs/opaque_ref" },
        "suppression_baseline_register_ref": { "$ref": "#/$defs/opaque_ref" },
        "review_packet_ref": { "$ref": "#/$defs/opaque_ref" },
        "source_format_class": { "$ref": "#/$defs/source_format_class" },
        "import_freshness_class": { "$ref": "#/$defs/freshness_class" },
        "compatibility_class": { "$ref": "#/$defs/compatibility_class" },
        "baseline_family_ref": { "$ref": "#/$defs/opaque_ref" },
        "delta_counts": { "$ref": "#/$defs/delta_counts" },
        "active_suppression_or_waiver_count": { "type": "integer", "minimum": 0 },
        "release_visible_baseline_count": { "type": "integer", "minimum": 0 },
        "imported_finding_count": { "type": "integer", "minimum": 0 },
        "locally_confirmed_count": { "type": "integer", "minimum": 0 },
        "imported_findings_read_only": { "type": "boolean", "const": true },
        "exact_delta_claim_blocked": { "type": "boolean" },
        "raw_payload_backlink_policy": { "$ref": "#/$defs/raw_payload_backlink_policy" },
        "raw_payload_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "parity_note": { "$ref": "#/$defs/short_sentence" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "imported_scanner_support_export": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "record_kind",
        "scanner_import_schema_version",
        "export_id",
        "import_session_ref",
        "diagnostic_delta_packet_ref",
        "review_packet_ref",
        "delta_counts",
        "raw_payload_backlink_policy",
        "payload_backlinks_redacted",
        "raw_private_material_excluded",
        "rows",
        "redaction_class",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": { "const": "imported_scanner_support_export_alpha" },
        "scanner_import_schema_version": { "$ref": "#/$defs/schema_version" },
        "export_id": { "$ref": "#/$defs/opaque_ref" },
        "import_session_ref": { "$ref": "#/$defs/opaque_ref" },
        "diagnostic_delta_packet_ref": { "$ref": "#/$defs/opaque_ref" },
        "review_packet_ref": { "$ref": "#/$defs/opaque_ref" },
        "delta_counts": { "$ref": "#/$defs/delta_counts" },
        "raw_payload_backlink_policy": { "$ref": "#/$defs/raw_payload_backlink_policy" },
        "payload_backlinks_redacted": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/projection_row" }
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    }
  }
}
