{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/quality/quality_action_proposal.schema.json",
  "title": "Aureline quality-action proposal",
  "description": "Boundary schema for the quality_action_proposal_record emitted before any quality mutation runs. The record normalizes format, organize-imports, quick fix, fix-all, suppression, baseline, scanner, and validation proposals into one safety, scope, preview, apply, and rollback vocabulary across UI, CLI, review, and support surfaces. Raw patches, raw source text, raw tool arguments, raw logs, raw paths, and raw secrets do not cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "proposal_id",
    "action_class",
    "action_token",
    "target_scope_class",
    "target_scope_token",
    "mutation_scope_class",
    "mutation_scope_token",
    "safety_class",
    "safety_token",
    "disclosure_class",
    "disclosure_token",
    "preview_requirement_class",
    "preview_requirement_token",
    "apply_posture_class",
    "apply_posture_token",
    "rollback_boundary_class",
    "rollback_boundary_token",
    "effective_profile_ref",
    "triggering_finding_refs",
    "rule_refs",
    "policy_lock_refs",
    "affected_file_count",
    "affected_anchor_count",
    "generated_path_count",
    "protected_path_count",
    "blocked_path_count",
    "checkpoint_ref",
    "preview_ref",
    "revert_plan_ref",
    "validation_refs",
    "preview_first_required",
    "apply_blocked",
    "summary"
  ],
  "properties": {
    "record_kind": { "const": "quality_action_proposal_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "proposal_id": { "$ref": "#/$defs/opaque_id" },
    "action_class": { "$ref": "#/$defs/action_class" },
    "action_token": { "$ref": "#/$defs/action_class" },
    "target_scope_class": { "$ref": "#/$defs/target_scope_class" },
    "target_scope_token": { "$ref": "#/$defs/target_scope_class" },
    "mutation_scope_class": { "$ref": "#/$defs/mutation_scope_class" },
    "mutation_scope_token": { "$ref": "#/$defs/mutation_scope_class" },
    "safety_class": { "$ref": "#/$defs/safety_class" },
    "safety_token": { "$ref": "#/$defs/safety_class" },
    "disclosure_class": { "$ref": "#/$defs/disclosure_class" },
    "disclosure_token": { "$ref": "#/$defs/disclosure_class" },
    "preview_requirement_class": { "$ref": "#/$defs/preview_requirement_class" },
    "preview_requirement_token": { "$ref": "#/$defs/preview_requirement_class" },
    "apply_posture_class": { "$ref": "#/$defs/apply_posture_class" },
    "apply_posture_token": { "$ref": "#/$defs/apply_posture_class" },
    "rollback_boundary_class": { "$ref": "#/$defs/rollback_boundary_class" },
    "rollback_boundary_token": { "$ref": "#/$defs/rollback_boundary_class" },
    "effective_profile_ref": { "$ref": "#/$defs/opaque_ref" },
    "triggering_finding_refs": { "$ref": "#/$defs/opaque_ref_list" },
    "rule_refs": { "$ref": "#/$defs/opaque_ref_list" },
    "policy_lock_refs": { "$ref": "#/$defs/opaque_ref_list" },
    "affected_file_count": { "$ref": "#/$defs/non_negative_integer" },
    "affected_anchor_count": { "$ref": "#/$defs/non_negative_integer" },
    "generated_path_count": { "$ref": "#/$defs/non_negative_integer" },
    "protected_path_count": { "$ref": "#/$defs/non_negative_integer" },
    "blocked_path_count": { "$ref": "#/$defs/non_negative_integer" },
    "checkpoint_ref": { "$ref": "#/$defs/nullable_ref" },
    "preview_ref": { "$ref": "#/$defs/nullable_ref" },
    "revert_plan_ref": { "$ref": "#/$defs/nullable_ref" },
    "validation_refs": { "$ref": "#/$defs/opaque_ref_list" },
    "preview_first_required": { "type": "boolean" },
    "apply_blocked": { "type": "boolean" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "opaque_id": { "type": "string", "minLength": 1 },
    "opaque_ref": { "type": "string", "minLength": 1 },
    "nullable_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_ref" }
      ]
    },
    "opaque_ref_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_ref" },
      "uniqueItems": true
    },
    "summary": { "type": "string", "minLength": 1, "maxLength": 480 },
    "non_negative_integer": { "type": "integer", "minimum": 0 },
    "target_scope_class": {
      "type": "string",
      "enum": [
        "current_file",
        "current_selection",
        "current_root",
        "selected_workset",
        "workspace",
        "review_diff",
        "baseline_family",
        "release_candidate"
      ]
    },
    "action_class": {
      "type": "string",
      "enum": [
        "format_range",
        "format_document",
        "organize_imports",
        "quick_fix_single",
        "fix_all_rule",
        "lint_autofix_batch",
        "suppression_proposal",
        "baseline_update",
        "scanner_read_only",
        "validation_recheck"
      ]
    },
    "mutation_scope_class": {
      "type": "string",
      "enum": [
        "no_mutation_read_only",
        "single_anchor",
        "single_file_localized",
        "single_file_whole_document",
        "multi_file_same_module",
        "multi_file_workspace",
        "generated_family",
        "protected_or_policy_scoped"
      ]
    },
    "safety_class": {
      "type": "string",
      "enum": [
        "trivia_safe",
        "local_syntax_safe",
        "semantic_local",
        "cross_file_semantic",
        "generated_or_protected",
        "unknown_or_unstable"
      ]
    },
    "disclosure_class": {
      "type": "string",
      "enum": [
        "trivia_only",
        "semantic",
        "broad",
        "blocked",
        "policy_escalated",
        "read_only"
      ]
    },
    "preview_requirement_class": {
      "type": "string",
      "enum": [
        "not_required",
        "inline_summary",
        "structured_diff",
        "batch_scope_preview",
        "policy_or_repo_mutation_preview_required",
        "issue_link_or_typed_review_required"
      ]
    },
    "apply_posture_class": {
      "type": "string",
      "enum": [
        "auto_apply_allowed",
        "preview_before_apply",
        "blocked_pending_user_review",
        "blocked_pending_policy_or_trust",
        "read_only_action"
      ]
    },
    "rollback_boundary_class": {
      "type": "string",
      "enum": [
        "no_mutation",
        "current_buffer_undo",
        "single_file_checkpoint",
        "grouped_workspace_checkpoint",
        "policy_audit_only",
        "manual_recovery_required"
      ]
    }
  }
}
