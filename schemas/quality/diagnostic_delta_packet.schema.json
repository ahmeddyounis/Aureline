{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/quality/diagnostic_delta_packet.schema.json",
  "title": "Aureline diagnostic delta packet",
  "description": "Boundary schema for scanner diagnostic delta packets. The packet compares imported, local-confirmed, baseline, suppression, waiver, and unmapped states using opaque refs and compatibility labels only; raw source, raw payload bodies, raw paths, URLs, logs, command lines, provider payloads, and secrets are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "diagnostic_delta_schema_version",
    "delta_packet_id",
    "import_session_ref",
    "baseline_family_ref",
    "compatibility_class",
    "delta_counts",
    "finding_deltas",
    "redaction_class",
    "export_safe_summary"
  ],
  "properties": {
    "record_kind": { "const": "diagnostic_delta_alpha_record" },
    "diagnostic_delta_schema_version": { "type": "integer", "const": 1 },
    "delta_packet_id": { "$ref": "#/$defs/opaque_ref" },
    "import_session_ref": { "$ref": "#/$defs/opaque_ref" },
    "baseline_family_ref": { "$ref": "#/$defs/opaque_ref" },
    "compatibility_class": { "$ref": "#/$defs/compatibility_class" },
    "delta_counts": { "$ref": "#/$defs/delta_counts" },
    "finding_deltas": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/finding_delta" }
    },
    "redaction_class": { "$ref": "#/$defs/redaction_class" },
    "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
  },
  "$defs": {
    "opaque_ref": { "type": "string", "minLength": 1 },
    "opaque_ref_nullable": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 900
    },
    "delta_state_class": {
      "type": "string",
      "enum": ["new", "resolved", "persisting", "suppressed", "waived", "unmapped"]
    },
    "compatibility_class": {
      "type": "string",
      "enum": [
        "compatible_exact",
        "compatible_with_local_confirmation",
        "blocked_profile_or_tool_mismatch",
        "blocked_rule_pack_mismatch",
        "blocked_anchor_mapping_uncertain",
        "not_comparable_unknown_requires_review"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "delta_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "new_count",
        "resolved_count",
        "persisting_count",
        "suppressed_count",
        "waived_count",
        "unmapped_count"
      ],
      "properties": {
        "new_count": { "type": "integer", "minimum": 0 },
        "resolved_count": { "type": "integer", "minimum": 0 },
        "persisting_count": { "type": "integer", "minimum": 0 },
        "suppressed_count": { "type": "integer", "minimum": 0 },
        "waived_count": { "type": "integer", "minimum": 0 },
        "unmapped_count": { "type": "integer", "minimum": 0 }
      }
    },
    "finding_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "delta_id",
        "delta_state_class",
        "current_finding_ref",
        "baseline_ref",
        "suppression_ref",
        "local_confirmation_ref",
        "compatibility_note",
        "supporting_evidence_refs",
        "export_safe_summary"
      ],
      "properties": {
        "delta_id": { "$ref": "#/$defs/opaque_ref" },
        "delta_state_class": { "$ref": "#/$defs/delta_state_class" },
        "current_finding_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "baseline_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "suppression_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "local_confirmation_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "compatibility_note": { "$ref": "#/$defs/short_sentence" },
        "supporting_evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    }
  }
}
