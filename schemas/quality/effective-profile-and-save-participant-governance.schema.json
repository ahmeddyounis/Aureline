{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/quality/effective-profile-and-save-participant-governance.schema.json",
  "title": "Aureline effective profile, save participant, and release debt governance packet",
  "description": "Boundary schema for the quality_release_debt_packet_record emitted by stable quality lanes. The packet links the winning effective profile, ordered save participants, fix-safety classes, preview/apply posture, and release-visible debt rows without embedding raw source, raw logs, raw tool arguments, raw paths, provider payloads, or secrets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "release_ref",
    "generated_at",
    "effective_profile_ref",
    "winning_source_ref",
    "quality_session_ref",
    "save_participants",
    "debt_rows",
    "debt_counts",
    "any_preview_first_required",
    "any_apply_blocked",
    "reconstructable_without_local_editor_state",
    "reviewable_mutation_required",
    "support_export_refs",
    "release_evidence_refs",
    "summary"
  ],
  "properties": {
    "record_kind": { "const": "quality_release_debt_packet_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "$ref": "#/$defs/opaque_ref" },
    "release_ref": { "$ref": "#/$defs/opaque_ref" },
    "generated_at": { "$ref": "#/$defs/timestamp" },
    "effective_profile_ref": { "$ref": "#/$defs/opaque_ref" },
    "winning_source_ref": { "$ref": "#/$defs/opaque_ref" },
    "quality_session_ref": { "$ref": "#/$defs/opaque_ref" },
    "save_participants": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/save_participant" }
    },
    "debt_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/debt_row" }
    },
    "debt_counts": { "$ref": "#/$defs/debt_counts" },
    "any_preview_first_required": { "type": "boolean" },
    "any_apply_blocked": { "type": "boolean" },
    "reconstructable_without_local_editor_state": { "type": "boolean", "const": true },
    "reviewable_mutation_required": { "type": "boolean" },
    "support_export_refs": { "$ref": "#/$defs/opaque_ref_list" },
    "release_evidence_refs": { "$ref": "#/$defs/opaque_ref_list" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "opaque_ref": { "type": "string", "minLength": 1 },
    "nullable_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_ref" }
      ]
    },
    "opaque_ref_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_ref" },
      "uniqueItems": true
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "summary": { "type": "string", "minLength": 1, "maxLength": 600 },
    "non_negative_integer": { "type": "integer", "minimum": 0 },
    "phase_class": {
      "type": "string",
      "enum": [
        "preflight",
        "format_fix",
        "generated_artifact_update",
        "validation",
        "compare_before_write",
        "durable_write",
        "post_save_indexing_refresh"
      ]
    },
    "action_class": {
      "type": "string",
      "enum": [
        "format_range",
        "format_document",
        "organize_imports",
        "quick_fix_single",
        "fix_all_rule",
        "lint_autofix_batch",
        "suppression_proposal",
        "baseline_update",
        "scanner_read_only",
        "validation_recheck"
      ]
    },
    "fix_safety_class": {
      "type": "string",
      "enum": [
        "safe_local_text_edit",
        "whole_file_rewrite_disclosed",
        "generated_companion_update",
        "workspace_wide_preview_required",
        "external_change_conflict_requires_review",
        "policy_blocked",
        "fix_safety_unknown_requires_review"
      ]
    },
    "preview_requirement_class": {
      "type": "string",
      "enum": [
        "not_required",
        "inline_summary",
        "structured_diff",
        "batch_scope_preview",
        "policy_or_repo_mutation_preview_required",
        "issue_link_or_typed_review_required"
      ]
    },
    "apply_posture_class": {
      "type": "string",
      "enum": [
        "auto_apply_allowed",
        "preview_before_apply",
        "blocked_pending_user_review",
        "blocked_pending_policy_or_trust",
        "read_only_action"
      ]
    },
    "mutation_scope_class": {
      "type": "string",
      "enum": [
        "no_mutation_read_only",
        "single_anchor",
        "single_file_localized",
        "single_file_whole_document",
        "multi_file_same_module",
        "multi_file_workspace",
        "generated_family",
        "protected_or_policy_scoped"
      ]
    },
    "debt_state_class": {
      "type": "string",
      "enum": ["suppressed", "baselined", "waived", "new", "resolved", "unmapped"]
    },
    "save_participant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "participant_id",
        "proposal_ref",
        "phase_class",
        "phase_token",
        "phase_order",
        "action_class",
        "action_token",
        "fix_safety_class",
        "fix_safety_token",
        "preview_requirement_class",
        "preview_requirement_token",
        "apply_posture_class",
        "apply_posture_token",
        "mutation_scope_class",
        "mutation_scope_token",
        "effective_profile_ref",
        "checkpoint_ref",
        "preview_ref",
        "revert_plan_ref",
        "auto_apply_allowed",
        "preview_first_required",
        "apply_blocked",
        "summary"
      ],
      "properties": {
        "participant_id": { "$ref": "#/$defs/opaque_ref" },
        "proposal_ref": { "$ref": "#/$defs/opaque_ref" },
        "phase_class": { "$ref": "#/$defs/phase_class" },
        "phase_token": { "$ref": "#/$defs/phase_class" },
        "phase_order": { "$ref": "#/$defs/non_negative_integer" },
        "action_class": { "$ref": "#/$defs/action_class" },
        "action_token": { "$ref": "#/$defs/action_class" },
        "fix_safety_class": { "$ref": "#/$defs/fix_safety_class" },
        "fix_safety_token": { "$ref": "#/$defs/fix_safety_class" },
        "preview_requirement_class": { "$ref": "#/$defs/preview_requirement_class" },
        "preview_requirement_token": { "$ref": "#/$defs/preview_requirement_class" },
        "apply_posture_class": { "$ref": "#/$defs/apply_posture_class" },
        "apply_posture_token": { "$ref": "#/$defs/apply_posture_class" },
        "mutation_scope_class": { "$ref": "#/$defs/mutation_scope_class" },
        "mutation_scope_token": { "$ref": "#/$defs/mutation_scope_class" },
        "effective_profile_ref": { "$ref": "#/$defs/opaque_ref" },
        "checkpoint_ref": { "$ref": "#/$defs/nullable_ref" },
        "preview_ref": { "$ref": "#/$defs/nullable_ref" },
        "revert_plan_ref": { "$ref": "#/$defs/nullable_ref" },
        "auto_apply_allowed": { "type": "boolean" },
        "preview_first_required": { "type": "boolean" },
        "apply_blocked": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/summary" }
      }
    },
    "debt_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "debt_row_id",
        "debt_state_class",
        "debt_state_token",
        "finding_refs",
        "rule_refs",
        "suppression_ref",
        "baseline_ref",
        "waiver_refs",
        "owner_ref",
        "reason",
        "release_visible",
        "lineage_refs",
        "summary"
      ],
      "properties": {
        "debt_row_id": { "$ref": "#/$defs/opaque_ref" },
        "debt_state_class": { "$ref": "#/$defs/debt_state_class" },
        "debt_state_token": { "$ref": "#/$defs/debt_state_class" },
        "finding_refs": { "$ref": "#/$defs/opaque_ref_list" },
        "rule_refs": { "$ref": "#/$defs/opaque_ref_list" },
        "suppression_ref": { "$ref": "#/$defs/nullable_ref" },
        "baseline_ref": { "$ref": "#/$defs/nullable_ref" },
        "waiver_refs": { "$ref": "#/$defs/opaque_ref_list" },
        "owner_ref": { "$ref": "#/$defs/opaque_ref" },
        "reason": { "$ref": "#/$defs/summary" },
        "release_visible": { "type": "boolean" },
        "lineage_refs": { "$ref": "#/$defs/opaque_ref_list" },
        "summary": { "$ref": "#/$defs/summary" }
      }
    },
    "debt_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suppressed_count",
        "baselined_count",
        "waived_count",
        "new_count",
        "resolved_count",
        "unmapped_count"
      ],
      "properties": {
        "suppressed_count": { "$ref": "#/$defs/non_negative_integer" },
        "baselined_count": { "$ref": "#/$defs/non_negative_integer" },
        "waived_count": { "$ref": "#/$defs/non_negative_integer" },
        "new_count": { "$ref": "#/$defs/non_negative_integer" },
        "resolved_count": { "$ref": "#/$defs/non_negative_integer" },
        "unmapped_count": { "$ref": "#/$defs/non_negative_integer" }
      }
    }
  }
}
