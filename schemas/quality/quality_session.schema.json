{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/quality/quality_session.schema.json",
  "title": "Aureline quality session",
  "description": "Boundary schema for the quality_session_record emitted for analyze, format, lint, fix, suppression, baseline, review, CLI, CI, and support replay sessions. The session binds trigger, target scope, effective profile, proposal refs, outcome, validation refs, and rollback refs so UI, CLI, review, and support exports agree on what ran and why.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "session_id",
    "trigger_class",
    "trigger_token",
    "target_scope_class",
    "target_scope_token",
    "effective_profile_ref",
    "execution_context_ref",
    "started_at",
    "ended_at",
    "proposal_refs",
    "proposals",
    "outcome_class",
    "outcome_token",
    "validation_refs",
    "rollback_refs",
    "any_preview_first_required",
    "any_apply_blocked",
    "summary"
  ],
  "properties": {
    "record_kind": { "const": "quality_session_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "session_id": { "$ref": "#/$defs/opaque_id" },
    "trigger_class": { "$ref": "#/$defs/trigger_class" },
    "trigger_token": { "$ref": "#/$defs/trigger_class" },
    "target_scope_class": { "$ref": "#/$defs/target_scope_class" },
    "target_scope_token": { "$ref": "#/$defs/target_scope_class" },
    "effective_profile_ref": { "$ref": "#/$defs/opaque_ref" },
    "execution_context_ref": { "$ref": "#/$defs/nullable_ref" },
    "started_at": { "$ref": "#/$defs/timestamp" },
    "ended_at": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/timestamp" }
      ]
    },
    "proposal_refs": { "$ref": "#/$defs/opaque_ref_list" },
    "proposals": {
      "type": "array",
      "items": { "$ref": "https://aureline.dev/schemas/quality/quality_action_proposal.schema.json" }
    },
    "outcome_class": { "$ref": "#/$defs/outcome_class" },
    "outcome_token": { "$ref": "#/$defs/outcome_class" },
    "validation_refs": { "$ref": "#/$defs/opaque_ref_list" },
    "rollback_refs": { "$ref": "#/$defs/opaque_ref_list" },
    "any_preview_first_required": { "type": "boolean" },
    "any_apply_blocked": { "type": "boolean" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "opaque_id": { "type": "string", "minLength": 1 },
    "opaque_ref": { "type": "string", "minLength": 1 },
    "nullable_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_ref" }
      ]
    },
    "opaque_ref_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_ref" },
      "uniqueItems": true
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "summary": { "type": "string", "minLength": 1, "maxLength": 480 },
    "target_scope_class": {
      "type": "string",
      "enum": [
        "current_file",
        "current_selection",
        "current_root",
        "selected_workset",
        "workspace",
        "review_diff",
        "baseline_family",
        "release_candidate"
      ]
    },
    "trigger_class": {
      "type": "string",
      "enum": [
        "on_save",
        "manual_command",
        "cli_headless",
        "review",
        "local_ci",
        "managed_ci",
        "support_replay"
      ]
    },
    "outcome_class": {
      "type": "string",
      "enum": [
        "applied",
        "preview_required",
        "skipped",
        "timed_out",
        "rebase_required",
        "blocked_by_policy",
        "failed",
        "reverted"
      ]
    }
  }
}
