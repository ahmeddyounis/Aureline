{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/quality/review_quality_packet.schema.json",
  "title": "Aureline review quality packet",
  "description": "Boundary schema for diff-scoped review quality packets. The packet preserves imported/local labels, local-confirmation actions, baseline and delta state, active suppression or waiver refs, mapping fidelity, freshness, raw-payload backlink policy, and profile drift notes without embedding raw source, raw payload bodies, raw paths, URLs, logs, command lines, provider payloads, or secrets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "scanner_import_schema_version",
    "packet_id",
    "change_scope_ref",
    "import_session_ref",
    "diagnostic_delta_packet_ref",
    "suppression_baseline_register_ref",
    "included_finding_ids",
    "finding_rows",
    "quality_action_refs",
    "local_confirmation_actions",
    "imported_finding_count",
    "locally_confirmed_finding_count",
    "release_visible_debt_count",
    "delta_counts",
    "raw_payload_backlink_policy",
    "profile_drift_note",
    "redaction_class",
    "export_safe_summary"
  ],
  "properties": {
    "record_kind": { "const": "diagnostic_review_packet_alpha" },
    "scanner_import_schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "$ref": "#/$defs/opaque_ref" },
    "change_scope_ref": { "$ref": "#/$defs/opaque_ref" },
    "import_session_ref": { "$ref": "#/$defs/opaque_ref" },
    "diagnostic_delta_packet_ref": { "$ref": "#/$defs/opaque_ref" },
    "suppression_baseline_register_ref": { "$ref": "#/$defs/opaque_ref" },
    "included_finding_ids": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_ref" },
      "uniqueItems": true
    },
    "finding_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding_row" }
    },
    "quality_action_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_ref" },
      "uniqueItems": true
    },
    "local_confirmation_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/local_confirmation_action" }
    },
    "imported_finding_count": { "type": "integer", "minimum": 0 },
    "locally_confirmed_finding_count": { "type": "integer", "minimum": 0 },
    "release_visible_debt_count": { "type": "integer", "minimum": 0 },
    "delta_counts": { "$ref": "#/$defs/delta_counts" },
    "raw_payload_backlink_policy": { "$ref": "#/$defs/raw_payload_backlink_policy" },
    "profile_drift_note": { "$ref": "#/$defs/short_sentence" },
    "redaction_class": { "$ref": "#/$defs/redaction_class" },
    "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
  },
  "$defs": {
    "opaque_ref": { "type": "string", "minLength": 1 },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 900
    },
    "truth_class": {
      "type": "string",
      "enum": ["imported_only", "locally_confirmed"]
    },
    "fidelity_class": {
      "type": "string",
      "enum": [
        "imported_static",
        "locally_confirmed",
        "stale_imported",
        "remapped_contextual",
        "unmapped_anchor",
        "baseline_mismatch",
        "redacted_payload"
      ]
    },
    "delta_state_class": {
      "type": "string",
      "enum": ["new", "resolved", "persisting", "suppressed", "waived", "unmapped"]
    },
    "remap_state_class": {
      "type": "string",
      "enum": ["exact", "contextual", "stale", "unmapped", "imported_static", "not_applicable"]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "imported_snapshot",
        "stale_imported_snapshot",
        "superseded_imported_snapshot",
        "unverified_imported_snapshot"
      ]
    },
    "raw_payload_backlink_policy": {
      "type": "string",
      "enum": [
        "opaque_refs_only",
        "redacted_by_policy",
        "omitted_unavailable",
        "explicit_opt_in_restricted"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "finding_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "diagnostic_id",
        "rule_id_ref",
        "truth_class",
        "fidelity_state_class",
        "delta_state_class",
        "remap_state_class",
        "import_freshness_class",
        "read_only",
        "raw_payload_backlink_policy",
        "export_safe_summary"
      ],
      "properties": {
        "finding_id": { "$ref": "#/$defs/opaque_ref" },
        "diagnostic_id": { "$ref": "#/$defs/opaque_ref" },
        "rule_id_ref": { "$ref": "#/$defs/opaque_ref" },
        "truth_class": { "$ref": "#/$defs/truth_class" },
        "fidelity_state_class": { "$ref": "#/$defs/fidelity_class" },
        "delta_state_class": { "$ref": "#/$defs/delta_state_class" },
        "remap_state_class": { "$ref": "#/$defs/remap_state_class" },
        "import_freshness_class": { "$ref": "#/$defs/freshness_class" },
        "read_only": { "type": "boolean", "const": true },
        "raw_payload_backlink_policy": { "$ref": "#/$defs/raw_payload_backlink_policy" },
        "export_safe_summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "local_confirmation_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_ref",
        "rule_family_ref",
        "local_provider_ref",
        "local_rule_ref",
        "required_before_mutation",
        "summary"
      ],
      "properties": {
        "action_ref": { "$ref": "#/$defs/opaque_ref" },
        "rule_family_ref": { "$ref": "#/$defs/opaque_ref" },
        "local_provider_ref": { "$ref": "#/$defs/opaque_ref" },
        "local_rule_ref": { "$ref": "#/$defs/opaque_ref" },
        "required_before_mutation": { "type": "boolean", "const": true },
        "summary": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "delta_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "new_count",
        "resolved_count",
        "persisting_count",
        "suppressed_count",
        "waived_count",
        "unmapped_count"
      ],
      "properties": {
        "new_count": { "type": "integer", "minimum": 0 },
        "resolved_count": { "type": "integer", "minimum": 0 },
        "persisting_count": { "type": "integer", "minimum": 0 },
        "suppressed_count": { "type": "integer", "minimum": 0 },
        "waived_count": { "type": "integer", "minimum": 0 },
        "unmapped_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
