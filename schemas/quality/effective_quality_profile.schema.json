{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/quality/effective_quality_profile.schema.json",
  "title": "Aureline effective quality profile",
  "description": "Boundary schema for the effective_quality_profile_record emitted by aureline-runtime's quality module. The record resolves policy locks, per-command overrides, repository/workspace settings, imported tool-native config, and fallback/default sources into one inspectable profile for save-participant UI, Problems, review, CLI explain, support export, CI, and release surfaces. Raw source text, raw tool arguments, raw logs, raw absolute paths, raw scanner payloads, and raw secrets do not cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "effective_profile_id",
    "workspace_ref",
    "target_scope_class",
    "target_scope_token",
    "resolved_at",
    "profile_fingerprint",
    "winning_source_ref",
    "winning_profile_ref",
    "lock_state_class",
    "lock_state_token",
    "lock_reason_class",
    "lock_reason_token",
    "source_chain",
    "selected_tool_refs",
    "suppression_policy_refs",
    "baseline_refs",
    "surface_projections",
    "has_unmapped_imported_config",
    "has_policy_overrides",
    "resolution_summary"
  ],
  "properties": {
    "record_kind": { "const": "effective_quality_profile_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "effective_profile_id": { "$ref": "#/$defs/opaque_id" },
    "workspace_ref": { "$ref": "#/$defs/opaque_ref" },
    "target_scope_class": { "$ref": "#/$defs/target_scope_class" },
    "target_scope_token": { "$ref": "#/$defs/target_scope_token" },
    "resolved_at": { "$ref": "#/$defs/timestamp" },
    "profile_fingerprint": { "$ref": "#/$defs/opaque_ref" },
    "winning_source_ref": { "$ref": "#/$defs/opaque_ref" },
    "winning_profile_ref": { "$ref": "#/$defs/opaque_ref" },
    "lock_state_class": { "$ref": "#/$defs/lock_state_class" },
    "lock_state_token": { "$ref": "#/$defs/lock_state_token" },
    "lock_reason_class": { "$ref": "#/$defs/lock_reason_class" },
    "lock_reason_token": { "$ref": "#/$defs/lock_reason_token" },
    "source_chain": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source_row" }
    },
    "selected_tool_refs": { "$ref": "#/$defs/opaque_ref_list" },
    "suppression_policy_refs": { "$ref": "#/$defs/opaque_ref_list" },
    "baseline_refs": { "$ref": "#/$defs/opaque_ref_list" },
    "surface_projections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surface_projection" }
    },
    "has_unmapped_imported_config": { "type": "boolean" },
    "has_policy_overrides": { "type": "boolean" },
    "resolution_summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "opaque_id": { "type": "string", "minLength": 1 },
    "opaque_ref": { "type": "string", "minLength": 1 },
    "opaque_ref_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_ref" },
      "uniqueItems": true
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "summary": { "type": "string", "minLength": 1, "maxLength": 480 },
    "non_negative_integer": { "type": "integer", "minimum": 0 },
    "target_scope_class": {
      "type": "string",
      "enum": [
        "current_file",
        "current_selection",
        "current_root",
        "selected_workset",
        "workspace",
        "review_diff",
        "baseline_family",
        "release_candidate"
      ]
    },
    "target_scope_token": { "$ref": "#/$defs/target_scope_class" },
    "surface_class": {
      "type": "string",
      "enum": [
        "save_participant_ui",
        "problems",
        "review",
        "cli_explain",
        "support_export",
        "local_ci",
        "managed_ci"
      ]
    },
    "source_layer_class": {
      "type": "string",
      "enum": [
        "policy_lock_or_managed_profile",
        "per_command_override",
        "repository_quality_config",
        "workspace_quality_settings",
        "workspace_profile_override",
        "remote_or_container_default",
        "user_or_profile_default",
        "imported_tool_config",
        "fallback_default",
        "system_auto_detection"
      ]
    },
    "source_state_class": {
      "type": "string",
      "enum": [
        "selected_winner",
        "shadowed_by_higher_precedence",
        "policy_overridden",
        "downgraded_incompatible",
        "unavailable_in_environment",
        "rejected_invalid",
        "imported_read_only",
        "detected_default"
      ]
    },
    "tool_family_class": {
      "type": "string",
      "enum": [
        "formatter",
        "linter",
        "organize_imports",
        "style_checker",
        "type_checker",
        "security_scanner",
        "secret_scanner",
        "dependency_scanner",
        "license_scanner",
        "policy_checker",
        "mixed_quality_pack"
      ]
    },
    "lock_state_class": {
      "type": "string",
      "enum": [
        "unlocked",
        "policy_locked",
        "policy_constrained",
        "provider_authoritative",
        "read_only_imported",
        "capability_locked"
      ]
    },
    "lock_state_token": { "$ref": "#/$defs/lock_state_class" },
    "lock_reason_class": {
      "type": "string",
      "enum": [
        "none",
        "admin_policy_pins_tool",
        "admin_policy_pins_rule_pack",
        "admin_policy_disables_mutation",
        "regulated_profile_requires_scanner",
        "workspace_trust_restricted",
        "imported_evidence_read_only",
        "tool_missing_or_version_mismatch",
        "unsupported_host_or_target"
      ]
    },
    "lock_reason_token": { "$ref": "#/$defs/lock_reason_class" },
    "source_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "precedence_rank",
        "source_layer",
        "source_layer_token",
        "source_state_class",
        "source_state_token",
        "source_ref",
        "candidate_profile_ref",
        "tool_family_class",
        "tool_family_token",
        "lock_state_class",
        "lock_state_token",
        "lock_reason_class",
        "lock_reason_token",
        "unmapped_key_count",
        "policy_overridden_key_count",
        "summary"
      ],
      "properties": {
        "precedence_rank": { "$ref": "#/$defs/non_negative_integer" },
        "source_layer": { "$ref": "#/$defs/source_layer_class" },
        "source_layer_token": { "$ref": "#/$defs/source_layer_class" },
        "source_state_class": { "$ref": "#/$defs/source_state_class" },
        "source_state_token": { "$ref": "#/$defs/source_state_class" },
        "source_ref": { "$ref": "#/$defs/opaque_ref" },
        "candidate_profile_ref": { "$ref": "#/$defs/opaque_ref" },
        "tool_family_class": { "$ref": "#/$defs/tool_family_class" },
        "tool_family_token": { "$ref": "#/$defs/tool_family_class" },
        "lock_state_class": { "$ref": "#/$defs/lock_state_class" },
        "lock_state_token": { "$ref": "#/$defs/lock_state_class" },
        "lock_reason_class": { "$ref": "#/$defs/lock_reason_class" },
        "lock_reason_token": { "$ref": "#/$defs/lock_reason_class" },
        "unmapped_key_count": { "$ref": "#/$defs/non_negative_integer" },
        "policy_overridden_key_count": { "$ref": "#/$defs/non_negative_integer" },
        "summary": { "$ref": "#/$defs/summary" }
      }
    },
    "surface_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "surface_token",
        "effective_profile_ref",
        "winning_source_ref",
        "policy_state_visible",
        "source_chain_inspectable",
        "explanation_summary"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "surface_token": { "$ref": "#/$defs/surface_class" },
        "effective_profile_ref": { "$ref": "#/$defs/opaque_ref" },
        "winning_source_ref": { "$ref": "#/$defs/opaque_ref" },
        "policy_state_visible": { "type": "boolean" },
        "source_chain_inspectable": { "type": "boolean" },
        "explanation_summary": { "$ref": "#/$defs/summary" }
      }
    }
  }
}
