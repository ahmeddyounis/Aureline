{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/quality/suppression_record.schema.json",
  "title": "Aureline governed suppression and baseline records",
  "description": "Boundary schema for suppression_record and baseline_record emitted by aureline-runtime's quality module. Suppressions and baselines carry reason, actor, owner, expiry or policy-managed review timing, evidence refs, reopen behavior, policy-lock state, and release visibility. They are governed debt records, not hidden permanent toggles. Raw source text, raw suppression files, raw baseline bodies, raw policy bundles, raw paths, and raw secrets do not cross this boundary.",
  "oneOf": [
    { "$ref": "#/$defs/suppression_record" },
    { "$ref": "#/$defs/baseline_record" }
  ],
  "$defs": {
    "opaque_id": { "type": "string", "minLength": 1 },
    "opaque_ref": { "type": "string", "minLength": 1 },
    "opaque_ref_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_ref" },
      "uniqueItems": true
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "nullable_timestamp": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/timestamp" }
      ]
    },
    "summary": { "type": "string", "minLength": 1, "maxLength": 480 },
    "target_scope_class": {
      "type": "string",
      "enum": [
        "current_file",
        "current_selection",
        "current_root",
        "selected_workset",
        "workspace",
        "review_diff",
        "baseline_family",
        "release_candidate"
      ]
    },
    "truth_mutation_class": {
      "type": "string",
      "enum": [
        "local_session_visibility_only",
        "workspace_repo_artifact",
        "managed_policy_artifact",
        "imported_baseline_artifact"
      ]
    },
    "policy_lock_state_class": {
      "type": "string",
      "enum": [
        "editable_local",
        "editable_with_review",
        "read_only_policy_locked",
        "expiry_managed_by_policy"
      ]
    },
    "reopen_rule_class": {
      "type": "string",
      "enum": [
        "reopen_on_expiry",
        "reopen_on_rule_change",
        "reopen_on_anchor_remap_failure",
        "reopen_on_profile_or_target_drift",
        "manual_review_only"
      ]
    },
    "owner_class": {
      "type": "string",
      "enum": [
        "workspace_owner",
        "codebase_team_owner",
        "security_owner",
        "admin_policy_owner",
        "imported_baseline_owner"
      ]
    },
    "actor_class": {
      "type": "string",
      "enum": [
        "local_user",
        "collaboration_remote_user",
        "automation_recipe",
        "admin_policy_service",
        "import_session_actor"
      ]
    },
    "baseline_compatibility_state_class": {
      "type": "string",
      "enum": [
        "compatible",
        "tool_or_rule_pack_drift_blocked",
        "profile_drift_blocked",
        "target_drift_blocked",
        "unknown_requires_review"
      ]
    },
    "suppression_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "suppression_id",
        "scope_class",
        "scope_token",
        "rule_refs",
        "finding_refs",
        "truth_mutation_class",
        "truth_mutation_token",
        "policy_lock_state_class",
        "policy_lock_state_token",
        "owner_class",
        "owner_token",
        "owner_ref",
        "actor_class",
        "actor_token",
        "actor_ref",
        "created_at",
        "expires_at",
        "reason",
        "evidence_refs",
        "reopen_rule_class",
        "reopen_rule_token",
        "release_visible",
        "hidden_permanent_toggle_denied",
        "summary"
      ],
      "properties": {
        "record_kind": { "const": "suppression_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "suppression_id": { "$ref": "#/$defs/opaque_id" },
        "scope_class": { "$ref": "#/$defs/target_scope_class" },
        "scope_token": { "$ref": "#/$defs/target_scope_class" },
        "rule_refs": { "$ref": "#/$defs/opaque_ref_list" },
        "finding_refs": { "$ref": "#/$defs/opaque_ref_list" },
        "truth_mutation_class": { "$ref": "#/$defs/truth_mutation_class" },
        "truth_mutation_token": { "$ref": "#/$defs/truth_mutation_class" },
        "policy_lock_state_class": { "$ref": "#/$defs/policy_lock_state_class" },
        "policy_lock_state_token": { "$ref": "#/$defs/policy_lock_state_class" },
        "owner_class": { "$ref": "#/$defs/owner_class" },
        "owner_token": { "$ref": "#/$defs/owner_class" },
        "owner_ref": { "$ref": "#/$defs/opaque_ref" },
        "actor_class": { "$ref": "#/$defs/actor_class" },
        "actor_token": { "$ref": "#/$defs/actor_class" },
        "actor_ref": { "$ref": "#/$defs/opaque_ref" },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "expires_at": { "$ref": "#/$defs/nullable_timestamp" },
        "reason": { "$ref": "#/$defs/summary" },
        "evidence_refs": { "$ref": "#/$defs/opaque_ref_list" },
        "reopen_rule_class": { "$ref": "#/$defs/reopen_rule_class" },
        "reopen_rule_token": { "$ref": "#/$defs/reopen_rule_class" },
        "release_visible": { "type": "boolean" },
        "hidden_permanent_toggle_denied": { "type": "boolean", "const": true },
        "summary": { "$ref": "#/$defs/summary" }
      }
    },
    "baseline_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "baseline_id",
        "compatible_profile_family_ref",
        "target_scope_ref",
        "target_scope_class",
        "target_scope_token",
        "accepted_finding_refs",
        "created_at",
        "actor_class",
        "actor_token",
        "actor_ref",
        "owner_class",
        "owner_token",
        "owner_ref",
        "evidence_refs",
        "review_refs",
        "supersedes_refs",
        "compatibility_state_class",
        "compatibility_state_token",
        "policy_lock_state_class",
        "policy_lock_state_token",
        "reopen_rule_class",
        "reopen_rule_token",
        "release_visible",
        "summary"
      ],
      "properties": {
        "record_kind": { "const": "baseline_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "baseline_id": { "$ref": "#/$defs/opaque_id" },
        "compatible_profile_family_ref": { "$ref": "#/$defs/opaque_ref" },
        "target_scope_ref": { "$ref": "#/$defs/opaque_ref" },
        "target_scope_class": { "$ref": "#/$defs/target_scope_class" },
        "target_scope_token": { "$ref": "#/$defs/target_scope_class" },
        "accepted_finding_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "actor_class": { "$ref": "#/$defs/actor_class" },
        "actor_token": { "$ref": "#/$defs/actor_class" },
        "actor_ref": { "$ref": "#/$defs/opaque_ref" },
        "owner_class": { "$ref": "#/$defs/owner_class" },
        "owner_token": { "$ref": "#/$defs/owner_class" },
        "owner_ref": { "$ref": "#/$defs/opaque_ref" },
        "evidence_refs": { "$ref": "#/$defs/opaque_ref_list" },
        "review_refs": { "$ref": "#/$defs/opaque_ref_list" },
        "supersedes_refs": { "$ref": "#/$defs/opaque_ref_list" },
        "compatibility_state_class": { "$ref": "#/$defs/baseline_compatibility_state_class" },
        "compatibility_state_token": { "$ref": "#/$defs/baseline_compatibility_state_class" },
        "policy_lock_state_class": { "$ref": "#/$defs/policy_lock_state_class" },
        "policy_lock_state_token": { "$ref": "#/$defs/policy_lock_state_class" },
        "reopen_rule_class": { "$ref": "#/$defs/reopen_rule_class" },
        "reopen_rule_token": { "$ref": "#/$defs/reopen_rule_class" },
        "release_visible": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/summary" }
      }
    }
  }
}
