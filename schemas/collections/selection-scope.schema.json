{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/collections/selection-scope.schema.json",
  "title": "Aureline dense-collection selection scope and batch-result truth",
  "description": "Stable boundary schema for selection-scope objects, query-backed batch review, hidden-member counts, stale snapshots, execution origin, and mixed per-item batch outcomes. Raw row text, raw query bodies, provider cursors, URLs, absolute paths, and secret-bearing values must not appear in records emitted against this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "source_contract_refs",
    "selection_scopes",
    "batch_reviews",
    "consumer_projections",
    "promotion_state",
    "validation_findings"
  ],
  "properties": {
    "record_kind": { "const": "selection_scope_batch_truth_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/opaque_id" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_contract_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "selection_scopes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/selection_scope_object" }
    },
    "batch_reviews": {
      "type": "array",
      "items": { "$ref": "#/$defs/batch_review_truth" }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/consumer_projection" }
    },
    "promotion_state": {
      "type": "string",
      "enum": ["stable", "narrowed_below_stable", "blocks_stable"]
    },
    "validation_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" }
    }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for logs, RPC, exports, and support bundles."
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Redaction-aware display label; never raw row text or query body."
    },
    "selection_scope_class": {
      "type": "string",
      "enum": [
        "current_item_only",
        "visible_range",
        "loaded_set",
        "all_matching_query",
        "explicit_custom_set"
      ]
    },
    "surface_family": {
      "type": "string",
      "enum": ["search", "provider_review_admin", "package_test_data_grid"]
    },
    "dataset_posture": {
      "type": "string",
      "enum": [
        "client_complete",
        "paged_or_windowed",
        "streaming_live",
        "provider_limited",
        "snapshot_basis"
      ]
    },
    "execution_origin": {
      "type": "string",
      "enum": ["local_client", "provider_authoritative", "mixed_client_provider"]
    },
    "basis_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["query_session_id_ref", "scope_ref"],
      "properties": {
        "query_session_id_ref": { "$ref": "#/$defs/opaque_id" },
        "query_snapshot_id_ref": { "$ref": "#/$defs/opaque_id" },
        "scope_ref": { "$ref": "#/$defs/opaque_id" },
        "workset_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "stable_item_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stable_item_id", "source_ref", "review_label"],
      "properties": {
        "stable_item_id": { "$ref": "#/$defs/opaque_id" },
        "source_ref": { "$ref": "#/$defs/opaque_id" },
        "review_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "range_traversal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "visible_traversal_order",
        "collapsed_descendants_excluded_by_default",
        "subtree_scope_requires_explicit_action"
      ],
      "properties": {
        "visible_traversal_order": { "const": true },
        "collapsed_descendants_excluded_by_default": { "const": true },
        "subtree_scope_requires_explicit_action": { "const": true }
      }
    },
    "selection_scope_object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selection_id",
        "surface_family",
        "scope_class",
        "dataset_posture",
        "basis_refs",
        "selected_items",
        "selected_count",
        "hidden_member_count",
        "blocked_member_count",
        "filtered_out_member_count",
        "stale_snapshot",
        "execution_origin",
        "select_all_expansion_was_explicit",
        "preserves_stable_item_identity",
        "range_traversal",
        "accessibility_summary"
      ],
      "properties": {
        "selection_id": { "$ref": "#/$defs/opaque_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "scope_class": { "$ref": "#/$defs/selection_scope_class" },
        "dataset_posture": { "$ref": "#/$defs/dataset_posture" },
        "basis_refs": { "$ref": "#/$defs/basis_refs" },
        "selected_items": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_item_ref" }
        },
        "anchor_item_id_ref": { "$ref": "#/$defs/opaque_id" },
        "selected_count": { "type": "integer", "minimum": 0 },
        "hidden_member_count": { "type": "integer", "minimum": 0 },
        "blocked_member_count": { "type": "integer", "minimum": 0 },
        "filtered_out_member_count": { "type": "integer", "minimum": 0 },
        "stale_snapshot": { "type": "boolean" },
        "execution_origin": { "$ref": "#/$defs/execution_origin" },
        "select_all_expansion_was_explicit": { "type": "boolean" },
        "preserves_stable_item_identity": { "const": true },
        "range_traversal": { "$ref": "#/$defs/range_traversal" },
        "accessibility_summary": { "$ref": "#/$defs/reviewable_label" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "scope_class": { "const": "all_matching_query" } },
            "required": ["scope_class"]
          },
          "then": {
            "properties": { "select_all_expansion_was_explicit": { "const": true } }
          }
        }
      ]
    },
    "batch_member_disposition": {
      "type": "string",
      "enum": ["included", "excluded", "blocked", "hidden", "skipped", "query_derived"]
    },
    "batch_item_outcome": {
      "type": "string",
      "enum": ["succeeded", "failed", "skipped", "blocked"]
    },
    "batch_privacy_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted"
      ]
    },
    "count_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["term", "exact", "value"],
      "properties": {
        "term": {
          "type": "string",
          "enum": ["included", "excluded", "blocked", "hidden", "skipped", "query_derived"]
        },
        "exact": { "type": "boolean" },
        "value": { "type": "integer", "minimum": 0 }
      }
    },
    "batch_review_member": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item", "disposition", "reason_label"],
      "properties": {
        "item": { "$ref": "#/$defs/stable_item_ref" },
        "disposition": { "$ref": "#/$defs/batch_member_disposition" },
        "reason_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "batch_item_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stable_item_id_ref", "outcome", "outcome_label"],
      "properties": {
        "stable_item_id_ref": { "$ref": "#/$defs/opaque_id" },
        "outcome": { "$ref": "#/$defs/batch_item_outcome" },
        "outcome_label": { "$ref": "#/$defs/reviewable_label" },
        "follow_up_action_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "batch_review_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "batch_review_id",
        "selection_id_ref",
        "action_id",
        "action_label",
        "execution_origin",
        "privacy_class",
        "included_count",
        "excluded_count",
        "blocked_count",
        "hidden_count",
        "skipped_count",
        "query_derived_count",
        "counts",
        "members",
        "rollback_retry_guidance",
        "review_required",
        "focus_return_preserved",
        "item_results",
        "mixed_outcome_summary"
      ],
      "properties": {
        "batch_review_id": { "$ref": "#/$defs/opaque_id" },
        "selection_id_ref": { "$ref": "#/$defs/opaque_id" },
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "action_label": { "$ref": "#/$defs/reviewable_label" },
        "execution_origin": { "$ref": "#/$defs/execution_origin" },
        "privacy_class": { "$ref": "#/$defs/batch_privacy_class" },
        "included_count": { "type": "integer", "minimum": 0 },
        "excluded_count": { "type": "integer", "minimum": 0 },
        "blocked_count": { "type": "integer", "minimum": 0 },
        "hidden_count": { "type": "integer", "minimum": 0 },
        "skipped_count": { "type": "integer", "minimum": 0 },
        "query_derived_count": { "type": "integer", "minimum": 0 },
        "counts": { "type": "array", "items": { "$ref": "#/$defs/count_truth" } },
        "members": { "type": "array", "items": { "$ref": "#/$defs/batch_review_member" } },
        "rollback_retry_guidance": { "$ref": "#/$defs/reviewable_label" },
        "review_required": { "const": true },
        "focus_return_preserved": { "const": true },
        "item_results": { "type": "array", "items": { "$ref": "#/$defs/batch_item_result" } },
        "mixed_outcome_summary": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer_projection",
        "projection_id",
        "packet_id_ref",
        "exposes_count_and_scope",
        "exposes_hidden_member_count",
        "exposes_stale_snapshot_state",
        "exposes_visible_loaded_matching_scope",
        "preserves_mixed_outcome_results",
        "preserves_packet_without_recomputed_counts"
      ],
      "properties": {
        "consumer_projection": {
          "type": "string",
          "enum": ["desktop_ui", "cli_headless", "export_packet", "support_capture", "accessibility_tree"]
        },
        "projection_id": { "$ref": "#/$defs/opaque_id" },
        "packet_id_ref": { "$ref": "#/$defs/opaque_id" },
        "exposes_count_and_scope": { "const": true },
        "exposes_hidden_member_count": { "const": true },
        "exposes_stale_snapshot_state": { "const": true },
        "exposes_visible_loaded_matching_scope": { "const": true },
        "preserves_mixed_outcome_results": { "const": true },
        "preserves_packet_without_recomputed_counts": { "const": true }
      }
    },
    "validation_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_kind", "severity", "message"],
      "properties": {
        "finding_kind": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["warning", "blocker"] },
        "message": { "$ref": "#/$defs/reviewable_label" }
      }
    }
  }
}
