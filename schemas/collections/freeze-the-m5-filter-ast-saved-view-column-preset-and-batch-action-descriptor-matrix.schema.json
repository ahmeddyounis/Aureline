{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/collections/freeze-the-m5-filter-ast-saved-view-column-preset-and-batch-action-descriptor-matrix.schema.json",
  "title": "Aureline M5 filter-AST, saved-view, column-preset, selection-scope, result-counter, and batch-action-descriptor matrix",
  "description": "Export-safe matrix binding every claimed M5 dense collection surface (pipeline run lists, review queues, incident lists, graph lists, marketplace results, activity rows, provider/admin tables, query-backed result sets) to its filter-AST class, selection-scope class, result-counter class, batch-action scope class, scope-counter vocabulary, saved-view contract, column-preset contract, and batch-action descriptors. The matrix reuses the frozen selection-scope and scope-counter vocabularies and adds the matrix-level filter-AST, result-counter, batch-action scope, and batch-action-kind vocabularies it owns. A claimed row that cannot identify its filter-AST, selection-scope, result-counter, or batch-action class auto-downgrades to an effective qualification strictly below its claim, with a recorded downgrade trigger and a precise degraded label. Durable selection survives by stable identity, never a row highlight; provider or policy narrowing is always visible, never hidden in a generic filter chip; visible / loaded / matching / selected counts never blur; visible rows are never treated as all matching rows without an explicit step; and broad batch actions never bypass preview because the list is virtualized or provider-backed. Raw query text, raw filter literal bytes, provider cursors, credentials, and raw row bodies never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "matrix_label",
    "rows",
    "guardrails",
    "consumer_projection",
    "evidence_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "freeze_the_m5_filter_ast_saved_view_column_preset_and_batch_action_descriptor_matrix"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "matrix_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/collection_qualification_row"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "evidence_freshness": {
      "$ref": "#/$defs/evidence_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "dense_collection_surface": {
      "type": "string",
      "enum": [
        "pipeline_run_list",
        "review_queue",
        "incident_list",
        "graph_list",
        "marketplace_results",
        "activity_rows",
        "provider_admin_table",
        "query_backed_result_set",
        "support_export_projection"
      ]
    },
    "filter_ast_class": {
      "type": "string",
      "enum": [
        "typed_clause_ast",
        "saved_query_snapshot",
        "provider_delegated_query",
        "free_text_scoped"
      ]
    },
    "selection_scope_class": {
      "type": "string",
      "enum": [
        "current_item_only",
        "visible_range",
        "loaded_set",
        "all_matching_query",
        "explicit_custom_set"
      ]
    },
    "result_counter_class": {
      "type": "string",
      "enum": [
        "exact_count",
        "approximate_count",
        "provider_limited_count",
        "partial_streaming_count"
      ]
    },
    "batch_action_scope_class": {
      "type": "string",
      "enum": [
        "local_reversible_batch",
        "mixed_client_provider_batch",
        "provider_authoritative_batch",
        "destructive_gated_batch",
        "inspect_only_no_batch"
      ]
    },
    "batch_action_kind": {
      "type": "string",
      "enum": [
        "export",
        "copy",
        "suppress",
        "install",
        "update",
        "delete",
        "rerun",
        "share",
        "approve"
      ]
    },
    "scope_counter_vocabulary_term": {
      "type": "string",
      "enum": [
        "visible",
        "loaded",
        "matching",
        "selected",
        "approx",
        "exact",
        "hidden_by_policy",
        "outside_current_filter"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "held",
        "unavailable"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "unidentified_filter_ast",
        "unidentified_selection_scope",
        "unidentified_result_counter",
        "unidentified_batch_action",
        "provider_narrowed",
        "policy_narrowed",
        "partial_data_limited",
        "upstream_dependency_narrowed"
      ]
    },
    "batch_action_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "action_kind",
        "mutates_state",
        "provider_backed",
        "reversible",
        "requires_preview",
        "scope_receipt_required"
      ],
      "properties": {
        "action_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "action_kind": {
          "$ref": "#/$defs/batch_action_kind"
        },
        "mutates_state": {
          "type": "boolean"
        },
        "provider_backed": {
          "type": "boolean"
        },
        "reversible": {
          "type": "boolean"
        },
        "requires_preview": {
          "type": "boolean"
        },
        "scope_receipt_required": {
          "type": "boolean"
        }
      }
    },
    "saved_view_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "saved_view_id",
        "owner_scope_token",
        "privacy_class_token",
        "fallback_behavior_token",
        "captures_selection",
        "captures_provider_cursor",
        "reopen_rebind_supported"
      ],
      "properties": {
        "saved_view_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "owner_scope_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "privacy_class_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "fallback_behavior_token": {
          "$ref": "#/$defs/non_empty_string"
        },
        "captures_selection": {
          "type": "boolean"
        },
        "captures_provider_cursor": {
          "type": "boolean"
        },
        "reopen_rebind_supported": {
          "type": "boolean"
        }
      }
    },
    "column_preset_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "column_preset_id",
        "visible_column_ids",
        "required_identity_column_ids",
        "pinned_column_ids",
        "density_mode_token"
      ],
      "properties": {
        "column_preset_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "visible_column_ids": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "required_identity_column_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "pinned_column_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "density_mode_token": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "collection_qualification_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "surface",
        "label_summary",
        "scope_vocabulary_terms",
        "saved_view",
        "column_preset",
        "batch_action_descriptors",
        "selection_survives_by_stable_identity",
        "provider_policy_narrowing_disclosed",
        "visible_distinct_from_all_matching",
        "claimed_qualification",
        "effective_qualification",
        "evidence_refs",
        "source_contract_refs"
      ],
      "properties": {
        "row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface": {
          "$ref": "#/$defs/dense_collection_surface"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "filter_ast_class": {
          "$ref": "#/$defs/filter_ast_class"
        },
        "selection_scope_class": {
          "$ref": "#/$defs/selection_scope_class"
        },
        "result_counter_class": {
          "$ref": "#/$defs/result_counter_class"
        },
        "batch_action_class": {
          "$ref": "#/$defs/batch_action_scope_class"
        },
        "scope_vocabulary_terms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scope_counter_vocabulary_term"
          }
        },
        "saved_view": {
          "$ref": "#/$defs/saved_view_declaration"
        },
        "column_preset": {
          "$ref": "#/$defs/column_preset_declaration"
        },
        "batch_action_descriptors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/batch_action_descriptor"
          }
        },
        "selection_survives_by_stable_identity": {
          "type": "boolean"
        },
        "provider_policy_narrowing_disclosed": {
          "type": "boolean"
        },
        "visible_distinct_from_all_matching": {
          "type": "boolean"
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "effective_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "downgrade_trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "degraded_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selection_durable_by_stable_identity",
        "provider_policy_narrowing_always_visible",
        "visible_loaded_matching_counts_never_blur",
        "visible_never_all_matching_without_explicit_step",
        "broad_batch_actions_never_bypass_preview",
        "rows_auto_downgrade_on_unidentified_semantics"
      ],
      "properties": {
        "selection_durable_by_stable_identity": {
          "type": "boolean"
        },
        "provider_policy_narrowing_always_visible": {
          "type": "boolean"
        },
        "visible_loaded_matching_counts_never_blur": {
          "type": "boolean"
        },
        "visible_never_all_matching_without_explicit_step": {
          "type": "boolean"
        },
        "broad_batch_actions_never_bypass_preview": {
          "type": "boolean"
        },
        "rows_auto_downgrade_on_unidentified_semantics": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_matrix",
        "docs_help_ingests_matrix",
        "diagnostics_ingests_matrix",
        "accessibility_ingests_matrix",
        "release_control_ingests_matrix",
        "downgraded_rows_labeled_below_current"
      ],
      "properties": {
        "product_ingests_matrix": {
          "type": "boolean"
        },
        "docs_help_ingests_matrix": {
          "type": "boolean"
        },
        "diagnostics_ingests_matrix": {
          "type": "boolean"
        },
        "accessibility_ingests_matrix": {
          "type": "boolean"
        },
        "release_control_ingests_matrix": {
          "type": "boolean"
        },
        "downgraded_rows_labeled_below_current": {
          "type": "boolean"
        }
      }
    },
    "evidence_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_freshness_slo_hours",
        "last_evidence_refresh",
        "auto_downgrade_on_stale"
      ],
      "properties": {
        "evidence_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_evidence_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_downgrade_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
