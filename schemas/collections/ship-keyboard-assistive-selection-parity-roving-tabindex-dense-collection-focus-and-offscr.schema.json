{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/collections/ship-keyboard-assistive-selection-parity-roving-tabindex-dense-collection-focus-and-offscr.schema.json",
  "title": "Aureline M5 assistive-selection-parity packet",
  "description": "Export-safe packet that makes keyboard and assistive-technology selection parity a canonical product object for the first real M5 dense collection surfaces (pipeline run list, review queue, incident list, graph list, marketplace results, provider/admin table). Each profile pins a surface, view kind, and data mode to a roving dense-focus model (roving tabindex or aria-activedescendant) tracked by stable item identity; the full keyboard/screen-reader command set (select-current, extend-range, clear-selection, inspect-hidden-count, open-batch-review) with no pointer-only control; a live-region announcement contract that exposes the selection count and the hidden-selected count to assistive technology; per-event focus/selection churn resilience proving streaming inserts, background refreshes, sort/filter changes, and virtualization recycling never steal focus or corrupt durable selection; and offscreen-selection durability proving selection of virtualized members persists by stable identity. Raw row bodies, provider payloads, and credentials never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "packet_label",
    "profiles",
    "guardrails",
    "consumer_projection",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "m5_assistive_selection_parity_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "packet_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/assistive_selection_profile"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "dense_collection_surface": {
      "enum": [
        "pipeline_run_list",
        "review_queue",
        "incident_list",
        "graph_list",
        "marketplace_results",
        "activity_rows",
        "provider_admin_table",
        "query_backed_result_set",
        "support_export_projection"
      ]
    },
    "collection_view_kind": {
      "enum": ["list", "tree", "table", "queue"]
    },
    "collection_data_mode": {
      "enum": [
        "static_complete",
        "filtered_sorted",
        "streaming",
        "virtualized",
        "paginated"
      ]
    },
    "focus_model_kind": {
      "enum": ["roving_tabindex", "aria_activedescendant"]
    },
    "assistive_command_kind": {
      "enum": [
        "select_current",
        "extend_range",
        "clear_selection",
        "inspect_hidden_count",
        "open_batch_review"
      ]
    },
    "focus_churn_event": {
      "enum": [
        "streaming_insert",
        "background_refresh",
        "sort_or_filter_change",
        "virtualization_recycle"
      ]
    },
    "focus_durability_outcome": {
      "enum": ["focus_held_by_identity", "focus_reanchored_visible"]
    },
    "live_region_politeness": {
      "enum": ["polite", "assertive"]
    },
    "roving_focus_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "single_tabstop",
        "focus_tracked_by_stable_identity",
        "focus_visible_indicator",
        "arrow_key_navigation",
        "navigation_bound_label"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/focus_model_kind"
        },
        "single_tabstop": {
          "const": true
        },
        "focus_tracked_by_stable_identity": {
          "const": true
        },
        "focus_visible_indicator": {
          "const": true
        },
        "arrow_key_navigation": {
          "const": true
        },
        "navigation_bound_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "assistive_command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "keyboard_binding",
        "accessible_name",
        "announcement",
        "keyboard_reachable",
        "screen_reader_reachable",
        "pointer_only"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/assistive_command_kind"
        },
        "keyboard_binding": {
          "$ref": "#/$defs/non_empty_string"
        },
        "accessible_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "announcement": {
          "$ref": "#/$defs/non_empty_string"
        },
        "keyboard_reachable": {
          "const": true
        },
        "screen_reader_reachable": {
          "const": true
        },
        "pointer_only": {
          "const": false
        }
      }
    },
    "selection_announcement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "politeness",
        "announces_selection_count",
        "announces_hidden_selected_count",
        "announces_batch_review_open",
        "sample_announcement"
      ],
      "properties": {
        "politeness": {
          "$ref": "#/$defs/live_region_politeness"
        },
        "announces_selection_count": {
          "const": true
        },
        "announces_hidden_selected_count": {
          "const": true
        },
        "announces_batch_review_open": {
          "type": "boolean"
        },
        "sample_announcement": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "focus_churn_resilience": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event",
        "outcome",
        "selection_preserved",
        "focus_not_stolen",
        "change_announced",
        "detail_label"
      ],
      "properties": {
        "event": {
          "$ref": "#/$defs/focus_churn_event"
        },
        "outcome": {
          "$ref": "#/$defs/focus_durability_outcome"
        },
        "selection_preserved": {
          "const": true
        },
        "focus_not_stolen": {
          "const": true
        },
        "change_announced": {
          "const": true
        },
        "detail_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "offscreen_selection_durability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selection_survives_virtualization_recycle",
        "offscreen_members_tracked_by_identity",
        "hidden_selected_count_exposed_to_at",
        "offscreen_selected_count",
        "detail_label"
      ],
      "properties": {
        "selection_survives_virtualization_recycle": {
          "const": true
        },
        "offscreen_members_tracked_by_identity": {
          "const": true
        },
        "hidden_selected_count_exposed_to_at": {
          "const": true
        },
        "offscreen_selected_count": {
          "type": "integer",
          "minimum": 0
        },
        "detail_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "assistive_selection_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "surface",
        "view_kind",
        "data_mode",
        "label_summary",
        "focus_model",
        "commands",
        "announcement",
        "churn_resilience",
        "offscreen_durability",
        "evidence_refs"
      ],
      "properties": {
        "profile_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface": {
          "$ref": "#/$defs/dense_collection_surface"
        },
        "view_kind": {
          "$ref": "#/$defs/collection_view_kind"
        },
        "data_mode": {
          "$ref": "#/$defs/collection_data_mode"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "focus_model": {
          "$ref": "#/$defs/roving_focus_model"
        },
        "commands": {
          "type": "array",
          "minItems": 5,
          "items": {
            "$ref": "#/$defs/assistive_command"
          }
        },
        "announcement": {
          "$ref": "#/$defs/selection_announcement"
        },
        "churn_resilience": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/focus_churn_resilience"
          }
        },
        "offscreen_durability": {
          "$ref": "#/$defs/offscreen_selection_durability"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_pointer_only_selection_controls",
        "focus_not_stolen_by_streaming_or_virtualization",
        "selection_survives_sort_filter_virtualization_by_identity",
        "hidden_selected_count_exposed_to_assistive_tech",
        "roving_focus_tracked_by_stable_identity",
        "broad_action_review_keyboard_reachable"
      ],
      "properties": {
        "no_pointer_only_selection_controls": {
          "const": true
        },
        "focus_not_stolen_by_streaming_or_virtualization": {
          "const": true
        },
        "selection_survives_sort_filter_virtualization_by_identity": {
          "const": true
        },
        "hidden_selected_count_exposed_to_assistive_tech": {
          "const": true
        },
        "roving_focus_tracked_by_stable_identity": {
          "const": true
        },
        "broad_action_review_keyboard_reachable": {
          "const": true
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_renders_assistive_selection",
        "diagnostics_reconstructs_parity",
        "support_export_reuses_records",
        "accessibility_evidence_reuses_records"
      ],
      "properties": {
        "product_renders_assistive_selection": {
          "const": true
        },
        "diagnostics_reconstructs_parity": {
          "const": true
        },
        "support_export_reuses_records": {
          "const": true
        },
        "accessibility_evidence_reuses_records": {
          "const": true
        }
      }
    }
  }
}
