{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/collections/certify-filter-saved-view-selection-and-batch-action-truth-on-every-claimed-m5-dense-colle.schema.json",
  "title": "Aureline M5 dense-collection certification of filter, saved-view, result-count, selection, and batch-action truth",
  "description": "Export-safe, release-bearing certification that gates every claimed M5 dense collection surface (pipeline run lists, review queues, incident lists, graph lists, marketplace results, activity rows, provider/admin tables, query-backed result sets) on current proof of filter-AST, saved-view, result-count, selection-scope, and batch-action truth. A claimed row that cannot present current proof on every required dimension auto-narrows to a certified qualification strictly below its claim, with a precise narrowed label. A row that regresses a release-gating invariant — erasing the hidden-selected count, losing stale-snapshot review, hiding provider or policy narrowing, blurring visible versus all-matching counts, bypassing batch preview, or letting a row highlight stand in for durable selection — is blocked from promotion and visibly narrowed. The certification reuses the frozen dense-collection-surface and qualification-class vocabularies and adds the proof-dimension, proof-status, verdict, and regression-class vocabularies it owns. Raw query text, raw filter literal bytes, provider cursors, credentials, and raw row bodies never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "certification_label",
    "rows",
    "guardrails",
    "consumer_projection",
    "release_gate",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "certify_filter_saved_view_selection_and_batch_action_truth_on_m5_dense_collections"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "certification_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/certification_row"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "release_gate": {
      "$ref": "#/$defs/release_gate"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "dense_collection_surface": {
      "type": "string",
      "enum": [
        "pipeline_run_list",
        "review_queue",
        "incident_list",
        "graph_list",
        "marketplace_results",
        "activity_rows",
        "provider_admin_table",
        "query_backed_result_set",
        "support_export_projection"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "held",
        "unavailable"
      ]
    },
    "proof_dimension": {
      "type": "string",
      "enum": [
        "filter_ast",
        "saved_view",
        "result_count",
        "selection_scope",
        "batch_action"
      ]
    },
    "proof_status": {
      "type": "string",
      "enum": [
        "current",
        "stale",
        "missing"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "certified",
        "auto_narrowed",
        "blocked"
      ]
    },
    "regression_class": {
      "type": "string",
      "enum": [
        "hidden_selected_count_erased",
        "stale_snapshot_review_lost",
        "provider_policy_narrowing_erased",
        "visible_versus_matching_blurred",
        "batch_preview_bypassed",
        "selection_durability_lost"
      ]
    },
    "certification_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension",
        "status"
      ],
      "properties": {
        "dimension": {
          "$ref": "#/$defs/proof_dimension"
        },
        "status": {
          "$ref": "#/$defs/proof_status"
        },
        "backing_record_kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "proof_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "certification_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "surface",
        "label_summary",
        "matrix_row_ref",
        "claimed_qualification",
        "certified_qualification",
        "proofs",
        "verdict",
        "selection_survives_by_stable_identity",
        "provider_policy_narrowing_disclosed",
        "visible_distinct_from_all_matching",
        "broad_actions_preview_before_commit",
        "evidence_refs",
        "source_contract_refs"
      ],
      "properties": {
        "row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface": {
          "$ref": "#/$defs/dense_collection_surface"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "matrix_row_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "certified_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "proofs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/certification_proof"
          }
        },
        "verdict": {
          "$ref": "#/$defs/verdict"
        },
        "regression": {
          "$ref": "#/$defs/regression_class"
        },
        "narrowed_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "selection_survives_by_stable_identity": {
          "type": "boolean"
        },
        "provider_policy_narrowing_disclosed": {
          "type": "boolean"
        },
        "visible_distinct_from_all_matching": {
          "type": "boolean"
        },
        "broad_actions_preview_before_commit": {
          "type": "boolean"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_highlight_never_substitutes_durable_selection",
        "provider_policy_narrowing_never_hidden",
        "visible_never_all_matching_without_explicit_step",
        "broad_actions_never_bypass_preview",
        "rows_without_current_proof_auto_narrow",
        "regressions_block_or_visibly_narrow"
      ],
      "properties": {
        "row_highlight_never_substitutes_durable_selection": {
          "type": "boolean"
        },
        "provider_policy_narrowing_never_hidden": {
          "type": "boolean"
        },
        "visible_never_all_matching_without_explicit_step": {
          "type": "boolean"
        },
        "broad_actions_never_bypass_preview": {
          "type": "boolean"
        },
        "rows_without_current_proof_auto_narrow": {
          "type": "boolean"
        },
        "regressions_block_or_visibly_narrow": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_certification",
        "docs_help_ingests_certification",
        "accessibility_ingests_certification",
        "release_control_ingests_certification",
        "narrowed_rows_labeled_below_current"
      ],
      "properties": {
        "product_ingests_certification": {
          "type": "boolean"
        },
        "docs_help_ingests_certification": {
          "type": "boolean"
        },
        "accessibility_ingests_certification": {
          "type": "boolean"
        },
        "release_control_ingests_certification": {
          "type": "boolean"
        },
        "narrowed_rows_labeled_below_current": {
          "type": "boolean"
        }
      }
    },
    "release_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blocks_promotion_on_blocked_row",
        "blocks_promotion_on_uncertified_claim",
        "stale_evidence_auto_narrows",
        "evidence_freshness_slo_hours",
        "last_evidence_refresh"
      ],
      "properties": {
        "blocks_promotion_on_blocked_row": {
          "type": "boolean"
        },
        "blocks_promotion_on_uncertified_claim": {
          "type": "boolean"
        },
        "stale_evidence_auto_narrows": {
          "type": "boolean"
        },
        "evidence_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_evidence_refresh": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
