{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/collections/batch_review_alpha.schema.json",
  "title": "Aureline collection batch-review sheet alpha contract",
  "description": "Portable batch-review sheet emitted before consequential dense-collection actions. The sheet distinguishes included, excluded, blocked, hidden, and stale members and carries visible, loaded, all-matching, selected, blocked, and hidden count truth.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_kind",
    "schema_version",
    "batch_review_id",
    "collection_view_id_ref",
    "action_id",
    "action_label",
    "action_class",
    "selection_scope_class",
    "execution_origin_class",
    "counters",
    "included_item_id_refs",
    "excluded_item_id_refs",
    "blocked_item_id_refs",
    "hidden_item_id_refs",
    "stale_item_id_refs",
    "members",
    "recovery_guidance",
    "review_required",
    "continue_action_id",
    "cancel_action_id"
  ],
  "properties": {
    "record_kind": { "const": "collection_batch_review_sheet_alpha" },
    "schema_version": { "type": "integer", "const": 1 },
    "batch_review_id": { "$ref": "#/$defs/opaque_id" },
    "collection_view_id_ref": { "$ref": "#/$defs/opaque_id" },
    "action_id": { "$ref": "#/$defs/opaque_id" },
    "action_label": { "$ref": "#/$defs/reviewable_label" },
    "action_class": {
      "type": "string",
      "enum": [
        "routine_non_mutating",
        "local_reversible",
        "remote_mutation",
        "destructive_mutation",
        "export_or_share",
        "provider_owned_mutation"
      ]
    },
    "selection_scope_class": {
      "type": "string",
      "enum": [
        "current_item_only",
        "visible_range",
        "loaded_set",
        "all_matching_query",
        "explicit_custom_set",
        "provider_side_query"
      ]
    },
    "execution_origin_class": {
      "type": "string",
      "enum": [
        "client_local_execution",
        "provider_authoritative_execution",
        "mixed_client_then_provider"
      ]
    },
    "included_item_id_refs": { "$ref": "#/$defs/id_list" },
    "excluded_item_id_refs": { "$ref": "#/$defs/id_list" },
    "blocked_item_id_refs": { "$ref": "#/$defs/id_list" },
    "hidden_item_id_refs": { "$ref": "#/$defs/id_list" },
    "stale_item_id_refs": { "$ref": "#/$defs/id_list" },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["item", "disposition", "reason_label"],
        "properties": {
          "disposition": {
            "type": "string",
            "enum": ["included", "excluded", "blocked", "hidden", "stale"]
          },
          "reason_label": { "$ref": "#/$defs/reviewable_label" }
        }
      }
    },
    "recovery_guidance": { "$ref": "#/$defs/reviewable_label" },
    "review_required": { "type": "boolean" },
    "continue_action_id": { "$ref": "#/$defs/opaque_id" },
    "cancel_action_id": { "$ref": "#/$defs/opaque_id" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "id_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_id" },
      "uniqueItems": true
    }
  }
}
