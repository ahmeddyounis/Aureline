{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/collections/saved_view_alpha.schema.json",
  "title": "Aureline saved collection view alpha contract",
  "description": "Versioned saved-view artifact for dense collections. Saved views persist filter, scope, sort, and column state while refusing transient row selection, stale provider cursors, and unredacted local-only literals outside local-private privacy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "saved_view_id",
    "name",
    "owner_scope",
    "privacy_class",
    "fallback_behavior",
    "filter_ast",
    "visible_column_ids",
    "pinned_column_ids",
    "scope_label",
    "captures_selection",
    "captures_provider_cursor",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "record_kind": { "const": "saved_collection_view_alpha" },
    "schema_version": { "type": "integer", "const": 1 },
    "saved_view_id": { "$ref": "#/$defs/opaque_id" },
    "name": { "$ref": "#/$defs/reviewable_label" },
    "owner_scope": {
      "type": "string",
      "enum": ["user", "workspace", "shared", "policy_pinned", "provider_owned"]
    },
    "privacy_class": {
      "type": "string",
      "enum": [
        "local_only_private",
        "workspace_portable",
        "shared_redacted",
        "policy_governed",
        "provider_owned"
      ]
    },
    "fallback_behavior": {
      "type": "string",
      "enum": [
        "preserve_and_label_degraded",
        "load_portable_subset_with_labels",
        "refuse_until_rebound",
        "provider_rebind_required"
      ]
    },
    "filter_ast": {
      "$ref": "filter_ast_alpha.schema.json"
    },
    "visible_column_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/opaque_id" },
      "uniqueItems": true
    },
    "pinned_column_ids": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_id" },
      "uniqueItems": true
    },
    "sort_keys": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field_id", "descending"],
        "properties": {
          "field_id": { "$ref": "#/$defs/opaque_id" },
          "descending": { "type": "boolean" }
        }
      }
    },
    "scope_label": { "$ref": "#/$defs/reviewable_label" },
    "captures_selection": { "type": "boolean", "const": false },
    "captures_provider_cursor": { "type": "boolean", "const": false },
    "stale_or_degraded_labels": {
      "type": "array",
      "items": { "$ref": "#/$defs/reviewable_label" }
    },
    "created_at": { "$ref": "#/$defs/timestamp_or_fixture_time" },
    "updated_at": { "$ref": "#/$defs/timestamp_or_fixture_time" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "timestamp_or_fixture_time": {
      "type": "string",
      "minLength": 1
    }
  }
}
