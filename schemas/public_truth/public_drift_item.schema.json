{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/public_truth/public_drift_item.schema.json",
  "title": "Aureline public-drift-ledger item, closure-SLA, and escalation contract",
  "description": "Boundary schema for one public_drift_item_record frozen in docs/public_truth/help_about_service_health_audit_packet.md. The drift item is the projection that the milestone scorecard, the ship-room dashboard, the release-evidence packet, the claim-manifest review, the support handoff bundle, the public-proof index, and the weekly governance review all read so they answer 'is the public story still aligned with the canonical owner artifacts and the claim manifest?' with the same row identities, the same severity vocabulary, the same closure SLA, and the same escalation rules. Every drift item pins the typed audited-surface class plus the source surface and canonical owner artifact refs, the affected claim row plus known-limit and evidence refs, the typed mismatch-category class mirrored from drift_blocking_rules.md verbatim and the typed severity class with schema-enforced category-severity pairing, the typed narrowing-path class, the typed closure-SLA class with sla_due_at chronology, the typed escalation-state class with sla_breached_release_blocking and sla_breached_widening_frozen pairings, the typed escalation-owner-role class, the typed ledger-state class and the typed closure-action class with linked change-set / late-copy / waiver refs, the typed audience plus matching redaction-profile class, the typed linked-artifact-family floor with surface-pairing requirements, and the typed consuming-surface parity floor. Raw screenshots, raw page-body bytes, raw user identifiers, and raw waiver justifications MUST NOT appear; the record carries opaque refs, typed vocabulary, and bounded reviewable summaries only. Adding a new audited-surface class, mismatch-category class, severity class, narrowing-path class, closure-SLA class, escalation-state class, escalation-owner-role class, ledger-state class, closure-action class, audience class, or redaction-profile class is additive-minor and bumps public_drift_item_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "$ref": "#/$defs/public_drift_item_record",
  "$defs": {
    "public_drift_item_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the public-drift-item payload shape. Current value is 1. Bumped only on breaking payload changes; additive-optional fields do not bump this version."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable identifier safe for live surfaces, support bundles, public-proof packets, claim manifests, release packets, governance packets, and screenshots. Raw URLs, raw absolute paths, raw email addresses, raw phone numbers, raw chat-room URLs, raw on-call rotation entries, and raw secret material MUST NOT appear here."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_id" },
      "uniqueItems": true
    },
    "non_empty_ref_array": {
      "allOf": [
        { "$ref": "#/$defs/ref_array" },
        { "minItems": 1 }
      ]
    },
    "utc_datetime": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 UTC timestamp."
    },
    "nullable_utc_datetime": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/utc_datetime" }
      ]
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Bounded reviewable display label."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "description": "Short reviewable sentence. Raw screenshots, raw page-body bytes, raw user identifiers, raw support-case bodies, and raw waiver justifications MUST NOT appear."
    },
    "nullable_reviewable_sentence": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/reviewable_sentence" }
      ]
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario", "contract_sections"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "contract_sections": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "exercised_axes": { "type": "object", "additionalProperties": true }
      }
    },

    "window_kind_class": {
      "type": "string",
      "enum": [
        "milestone_close_window",
        "release_train_window",
        "weekly_governance_review_window",
        "ad_hoc_review_window"
      ],
      "description": "Closed four-class window-kind vocabulary mirroring docs/public_truth/help_about_service_health_audit_packet.md §3."
    },
    "audited_surface_class": {
      "type": "string",
      "enum": [
        "help_pane",
        "about_pane",
        "service_health_pane",
        "release_notes_card",
        "known_limits_section",
        "public_proof_packet",
        "cli_help_text",
        "support_export_card"
      ],
      "description": "Closed eight-class audited-surface vocabulary. A drift whose source surface cannot be typed denies with audited_surface_class_unresolved rather than collapsing to help_pane."
    },
    "mismatch_category_class": {
      "type": "string",
      "enum": [
        "owner_row_missing",
        "projection_broader_than_owner",
        "policy_disabled_hidden",
        "support_window_mismatch",
        "known_limit_missing",
        "compatibility_or_skew_alias_drift",
        "proof_packet_out_of_sync"
      ],
      "description": "Closed seven-class mismatch-category vocabulary mirroring docs/governance/drift_blocking_rules.md verbatim."
    },
    "severity_class": {
      "type": "string",
      "enum": [
        "release_blocking_overclaim",
        "same_change_blocker",
        "time_boxed_truth_defect",
        "seed_gap_review_required"
      ],
      "description": "Closed four-class severity vocabulary mirroring docs/governance/drift_blocking_rules.md verbatim."
    },
    "narrowing_path_class": {
      "type": "string",
      "enum": [
        "same_change_set_owner_correction",
        "public_copy_narrowing",
        "claim_row_narrowing",
        "public_claim_retirement",
        "seed_gap_internal_only"
      ],
      "description": "Closed five-class narrowing-path vocabulary."
    },
    "closure_sla_class": {
      "type": "string",
      "enum": [
        "same_change_set_required",
        "time_boxed_24h",
        "time_boxed_next_channel_move",
        "internal_only_no_sla",
        "claim_narrowed_no_sla"
      ],
      "description": "Closed five-class closure-SLA vocabulary."
    },
    "escalation_state_class": {
      "type": "string",
      "enum": [
        "within_sla",
        "sla_warning",
        "sla_breached",
        "sla_breached_release_blocking",
        "sla_breached_widening_frozen"
      ],
      "description": "Closed five-class escalation-state vocabulary."
    },
    "escalation_owner_role_class": {
      "type": "string",
      "enum": [
        "docs_public_truth_owner",
        "claim_manifest_owner",
        "release_council",
        "shiproom_executive",
        "support_lane_owner",
        "governance_council"
      ],
      "description": "Closed six-class escalation-owner-role vocabulary."
    },
    "ledger_state_class": {
      "type": "string",
      "enum": [
        "open_under_review",
        "open_blocking_widening",
        "open_blocking_release",
        "closed_via_owner_correction",
        "closed_via_public_copy_narrowing",
        "closed_via_claim_narrowing",
        "closed_no_change_required"
      ],
      "description": "Closed seven-class ledger-state vocabulary."
    },
    "closure_action_class": {
      "type": "string",
      "enum": [
        "owner_artifact_updated",
        "public_copy_narrowed_in_release",
        "public_copy_narrowed_via_late_copy_packet",
        "claim_row_effective_posture_narrowed",
        "claim_row_retired_from_public_lane",
        "held_under_active_waiver",
        "held_internal_only_seed_gap",
        "closed_no_change_required"
      ],
      "description": "Closed eight-class closure-action vocabulary."
    },
    "nullable_closure_action_class": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/closure_action_class" }
      ]
    },
    "audience_class": {
      "type": "string",
      "enum": [
        "engineering_internal",
        "support_handoff",
        "enterprise_audit",
        "release_readiness",
        "public_proof_safe"
      ],
      "description": "Closed five-class audience vocabulary mirroring the records-governance packet contract."
    },
    "redaction_profile_class": {
      "type": "string",
      "enum": [
        "engineering_internal_only",
        "support_handoff_redacted",
        "enterprise_audit_redacted",
        "release_readiness_summary",
        "public_proof_safe_zero_payload"
      ],
      "description": "Closed five-class redaction-profile vocabulary. The schema enforces redaction_profile_class matches audience_class per §12."
    },

    "redaction_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redaction_profile_class",
        "redaction_profile_ref",
        "raw_screenshots_excluded",
        "raw_page_body_bytes_excluded",
        "raw_user_identifiers_excluded",
        "raw_waiver_justifications_excluded",
        "redaction_profile_summary"
      ],
      "properties": {
        "redaction_profile_class": { "$ref": "#/$defs/redaction_profile_class" },
        "redaction_profile_ref": { "$ref": "#/$defs/opaque_id" },
        "raw_screenshots_excluded": { "type": "boolean", "const": true },
        "raw_page_body_bytes_excluded": { "type": "boolean", "const": true },
        "raw_user_identifiers_excluded": { "type": "boolean", "const": true },
        "raw_waiver_justifications_excluded": { "type": "boolean", "const": true },
        "redaction_profile_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "linked_artifact_families": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_manifest_row_refs",
        "destination_descriptor_row_refs",
        "whats_new_card_row_refs",
        "help_pane_state_refs",
        "public_proof_row_refs",
        "support_export_packet_refs",
        "evidence_packet_refs",
        "late_copy_change_packet_refs"
      ],
      "properties": {
        "claim_manifest_row_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "destination_descriptor_row_refs": { "$ref": "#/$defs/ref_array" },
        "whats_new_card_row_refs": { "$ref": "#/$defs/ref_array" },
        "help_pane_state_refs": { "$ref": "#/$defs/ref_array" },
        "public_proof_row_refs": { "$ref": "#/$defs/ref_array" },
        "support_export_packet_refs": { "$ref": "#/$defs/ref_array" },
        "evidence_packet_refs": { "$ref": "#/$defs/ref_array" },
        "late_copy_change_packet_refs": { "$ref": "#/$defs/ref_array" }
      }
    },

    "consuming_surface_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "render_on_dashboard",
        "render_on_milestone_scorecard",
        "render_on_release_packet",
        "render_on_support_export",
        "render_on_governance_packet",
        "render_on_claim_manifest_review",
        "render_on_public_proof_index",
        "render_on_weekly_governance_review"
      ],
      "properties": {
        "render_on_dashboard": { "type": "boolean" },
        "render_on_milestone_scorecard": { "type": "boolean" },
        "render_on_release_packet": { "type": "boolean" },
        "render_on_support_export": { "type": "boolean" },
        "render_on_governance_packet": { "type": "boolean" },
        "render_on_claim_manifest_review": { "type": "boolean" },
        "render_on_public_proof_index": { "type": "boolean" },
        "render_on_weekly_governance_review": { "type": "boolean" }
      },
      "description": "Visual / export parity floor. Every consuming surface that renders the drift item MUST render the same drift_item_id, audit_packet_ref, detected_at, last_observed_at, closed_at, audited_surface_class, source_surface_ref, canonical_owner_artifact_ref, affected_claim_row_refs, affected_known_limit_refs, mismatch_category_class, severity_class, narrowing_path_class, channel_widening_blocked, claim_narrowing_required, closure_sla_class, sla_due_at, escalation_state_class, escalation_owner_role_class, ledger_state_class, closure_action_class, closure_notes, audience_class, redaction_profile_class, headline_label, and drift_item_summary."
    },

    "audit_packet_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_kind_class",
        "window_ref",
        "baseline_evaluated_at",
        "window_summary"
      ],
      "properties": {
        "window_kind_class": { "$ref": "#/$defs/window_kind_class" },
        "window_ref": { "$ref": "#/$defs/opaque_id" },
        "baseline_evaluated_at": { "$ref": "#/$defs/utc_datetime" },
        "window_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "public_drift_item_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_drift_item_schema_version",
        "record_kind",
        "drift_item_id",
        "audit_packet_ref",
        "audit_packet_window",
        "claim_manifest_baseline_ref",
        "detected_at",
        "last_observed_at",
        "closed_at",
        "audited_surface_class",
        "source_surface_ref",
        "canonical_owner_artifact_ref",
        "conflicting_wording_summary",
        "canonical_owner_wording_summary",
        "affected_claim_row_refs",
        "affected_known_limit_refs",
        "affected_evidence_refs",
        "mismatch_category_class",
        "severity_class",
        "narrowing_path_class",
        "channel_widening_blocked",
        "claim_narrowing_required",
        "closure_sla_class",
        "sla_due_at",
        "escalation_state_class",
        "escalation_owner_role_class",
        "ledger_state_class",
        "closure_action_class",
        "closure_notes",
        "linked_change_set_refs",
        "linked_late_copy_packet_refs",
        "linked_waiver_register_refs",
        "audience_class",
        "redaction_profile",
        "linked_artifact_families",
        "consuming_surface_parity",
        "headline_label",
        "drift_item_summary",
        "contract_doc_ref",
        "claim_manifest_contract_ref",
        "public_truth_parity_matrix_ref",
        "drift_blocking_rules_ref",
        "notes"
      ],
      "properties": {
        "public_drift_item_schema_version": { "$ref": "#/$defs/public_drift_item_schema_version" },
        "record_kind": {
          "type": "string",
          "const": "public_drift_item_record"
        },
        "drift_item_id": {
          "type": "string",
          "pattern": "^public_drift_item:[a-z0-9]+(?:[._-][a-z0-9]+)*$",
          "description": "Stable, machine-readable id quoted by every consuming surface."
        },
        "audit_packet_ref": {
          "type": "string",
          "pattern": "^public_truth_audit_packet:[a-z0-9]+(?:[._-][a-z0-9]+)*$",
          "description": "Stable opaque ref into the audit packet this drift item participates in. Every drift item in one audit window MUST cite the same audit_packet_ref."
        },
        "audit_packet_window": { "$ref": "#/$defs/audit_packet_window" },
        "claim_manifest_baseline_ref": { "$ref": "#/$defs/opaque_id" },
        "detected_at": { "$ref": "#/$defs/utc_datetime" },
        "last_observed_at": { "$ref": "#/$defs/utc_datetime" },
        "closed_at": { "$ref": "#/$defs/nullable_utc_datetime" },
        "audited_surface_class": { "$ref": "#/$defs/audited_surface_class" },
        "source_surface_ref": { "$ref": "#/$defs/opaque_id" },
        "canonical_owner_artifact_ref": { "$ref": "#/$defs/opaque_id" },
        "conflicting_wording_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "canonical_owner_wording_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "affected_claim_row_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "affected_known_limit_refs": { "$ref": "#/$defs/ref_array" },
        "affected_evidence_refs": { "$ref": "#/$defs/ref_array" },
        "mismatch_category_class": { "$ref": "#/$defs/mismatch_category_class" },
        "severity_class": { "$ref": "#/$defs/severity_class" },
        "narrowing_path_class": { "$ref": "#/$defs/narrowing_path_class" },
        "channel_widening_blocked": { "type": "boolean" },
        "claim_narrowing_required": { "type": "boolean" },
        "closure_sla_class": { "$ref": "#/$defs/closure_sla_class" },
        "sla_due_at": { "$ref": "#/$defs/nullable_utc_datetime" },
        "escalation_state_class": { "$ref": "#/$defs/escalation_state_class" },
        "escalation_owner_role_class": { "$ref": "#/$defs/escalation_owner_role_class" },
        "ledger_state_class": { "$ref": "#/$defs/ledger_state_class" },
        "closure_action_class": { "$ref": "#/$defs/nullable_closure_action_class" },
        "closure_notes": { "$ref": "#/$defs/nullable_reviewable_sentence" },
        "linked_change_set_refs": { "$ref": "#/$defs/ref_array" },
        "linked_late_copy_packet_refs": { "$ref": "#/$defs/ref_array" },
        "linked_waiver_register_refs": { "$ref": "#/$defs/ref_array" },
        "audience_class": { "$ref": "#/$defs/audience_class" },
        "redaction_profile": { "$ref": "#/$defs/redaction_profile" },
        "linked_artifact_families": { "$ref": "#/$defs/linked_artifact_families" },
        "consuming_surface_parity": { "$ref": "#/$defs/consuming_surface_parity" },
        "headline_label": { "$ref": "#/$defs/reviewable_label" },
        "drift_item_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "contract_doc_ref": {
          "type": "string",
          "const": "docs/public_truth/help_about_service_health_audit_packet.md"
        },
        "claim_manifest_contract_ref": {
          "type": "string",
          "const": "docs/governance/claim_manifest_contract.md"
        },
        "public_truth_parity_matrix_ref": {
          "type": "string",
          "const": "artifacts/governance/public_truth_parity_matrix.yaml"
        },
        "drift_blocking_rules_ref": {
          "type": "string",
          "const": "docs/governance/drift_blocking_rules.md"
        },
        "notes": { "$ref": "#/$defs/nullable_reviewable_sentence" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" }
      },
      "allOf": [
        {
          "description": "audience_class = engineering_internal pairs with redaction_profile_class = engineering_internal_only.",
          "if": {
            "properties": { "audience_class": { "const": "engineering_internal" } },
            "required": ["audience_class"]
          },
          "then": {
            "properties": {
              "redaction_profile": {
                "properties": { "redaction_profile_class": { "const": "engineering_internal_only" } },
                "required": ["redaction_profile_class"]
              }
            }
          }
        },
        {
          "description": "audience_class = support_handoff pairs with redaction_profile_class = support_handoff_redacted.",
          "if": {
            "properties": { "audience_class": { "const": "support_handoff" } },
            "required": ["audience_class"]
          },
          "then": {
            "properties": {
              "redaction_profile": {
                "properties": { "redaction_profile_class": { "const": "support_handoff_redacted" } },
                "required": ["redaction_profile_class"]
              }
            }
          }
        },
        {
          "description": "audience_class = enterprise_audit pairs with redaction_profile_class = enterprise_audit_redacted.",
          "if": {
            "properties": { "audience_class": { "const": "enterprise_audit" } },
            "required": ["audience_class"]
          },
          "then": {
            "properties": {
              "redaction_profile": {
                "properties": { "redaction_profile_class": { "const": "enterprise_audit_redacted" } },
                "required": ["redaction_profile_class"]
              }
            }
          }
        },
        {
          "description": "audience_class = release_readiness pairs with redaction_profile_class = release_readiness_summary.",
          "if": {
            "properties": { "audience_class": { "const": "release_readiness" } },
            "required": ["audience_class"]
          },
          "then": {
            "properties": {
              "redaction_profile": {
                "properties": { "redaction_profile_class": { "const": "release_readiness_summary" } },
                "required": ["redaction_profile_class"]
              }
            }
          }
        },
        {
          "description": "audience_class = public_proof_safe pairs with redaction_profile_class = public_proof_safe_zero_payload.",
          "if": {
            "properties": { "audience_class": { "const": "public_proof_safe" } },
            "required": ["audience_class"]
          },
          "then": {
            "properties": {
              "redaction_profile": {
                "properties": { "redaction_profile_class": { "const": "public_proof_safe_zero_payload" } },
                "required": ["redaction_profile_class"]
              }
            }
          }
        },

        {
          "description": "mismatch_category_class = owner_row_missing pairs with severity_class = same_change_blocker.",
          "if": {
            "properties": { "mismatch_category_class": { "const": "owner_row_missing" } },
            "required": ["mismatch_category_class"]
          },
          "then": {
            "properties": { "severity_class": { "const": "same_change_blocker" } }
          }
        },
        {
          "description": "mismatch_category_class = projection_broader_than_owner pairs with severity_class = release_blocking_overclaim.",
          "if": {
            "properties": { "mismatch_category_class": { "const": "projection_broader_than_owner" } },
            "required": ["mismatch_category_class"]
          },
          "then": {
            "properties": { "severity_class": { "const": "release_blocking_overclaim" } }
          }
        },
        {
          "description": "mismatch_category_class = policy_disabled_hidden pairs with severity_class = release_blocking_overclaim.",
          "if": {
            "properties": { "mismatch_category_class": { "const": "policy_disabled_hidden" } },
            "required": ["mismatch_category_class"]
          },
          "then": {
            "properties": { "severity_class": { "const": "release_blocking_overclaim" } }
          }
        },
        {
          "description": "mismatch_category_class = support_window_mismatch pairs with severity_class = same_change_blocker.",
          "if": {
            "properties": { "mismatch_category_class": { "const": "support_window_mismatch" } },
            "required": ["mismatch_category_class"]
          },
          "then": {
            "properties": { "severity_class": { "const": "same_change_blocker" } }
          }
        },
        {
          "description": "mismatch_category_class = known_limit_missing pairs with severity_class = same_change_blocker.",
          "if": {
            "properties": { "mismatch_category_class": { "const": "known_limit_missing" } },
            "required": ["mismatch_category_class"]
          },
          "then": {
            "properties": { "severity_class": { "const": "same_change_blocker" } }
          }
        },
        {
          "description": "mismatch_category_class = compatibility_or_skew_alias_drift pairs with severity_class = release_blocking_overclaim.",
          "if": {
            "properties": { "mismatch_category_class": { "const": "compatibility_or_skew_alias_drift" } },
            "required": ["mismatch_category_class"]
          },
          "then": {
            "properties": { "severity_class": { "const": "release_blocking_overclaim" } }
          }
        },
        {
          "description": "mismatch_category_class = proof_packet_out_of_sync admits severity_class in {time_boxed_truth_defect, release_blocking_overclaim}.",
          "if": {
            "properties": { "mismatch_category_class": { "const": "proof_packet_out_of_sync" } },
            "required": ["mismatch_category_class"]
          },
          "then": {
            "properties": {
              "severity_class": {
                "enum": ["time_boxed_truth_defect", "release_blocking_overclaim"]
              }
            }
          }
        },

        {
          "description": "narrowing_path_class = claim_row_narrowing requires claim_narrowing_required = true.",
          "if": {
            "properties": { "narrowing_path_class": { "const": "claim_row_narrowing" } },
            "required": ["narrowing_path_class"]
          },
          "then": {
            "properties": { "claim_narrowing_required": { "const": true } }
          }
        },
        {
          "description": "narrowing_path_class = public_claim_retirement requires claim_narrowing_required = true.",
          "if": {
            "properties": { "narrowing_path_class": { "const": "public_claim_retirement" } },
            "required": ["narrowing_path_class"]
          },
          "then": {
            "properties": { "claim_narrowing_required": { "const": true } }
          }
        },

        {
          "description": "closure_sla_class = same_change_set_required, time_boxed_24h, or time_boxed_next_channel_move requires non-null sla_due_at.",
          "if": {
            "properties": {
              "closure_sla_class": {
                "enum": ["same_change_set_required", "time_boxed_24h", "time_boxed_next_channel_move"]
              }
            },
            "required": ["closure_sla_class"]
          },
          "then": {
            "properties": { "sla_due_at": { "not": { "type": "null" } } }
          }
        },
        {
          "description": "closure_sla_class = internal_only_no_sla or claim_narrowed_no_sla pairs with sla_due_at = null.",
          "if": {
            "properties": {
              "closure_sla_class": {
                "enum": ["internal_only_no_sla", "claim_narrowed_no_sla"]
              }
            },
            "required": ["closure_sla_class"]
          },
          "then": {
            "properties": { "sla_due_at": { "type": "null" } }
          }
        },

        {
          "description": "escalation_state_class = sla_breached_release_blocking requires severity_class in {release_blocking_overclaim, same_change_blocker}.",
          "if": {
            "properties": { "escalation_state_class": { "const": "sla_breached_release_blocking" } },
            "required": ["escalation_state_class"]
          },
          "then": {
            "properties": {
              "severity_class": {
                "enum": ["release_blocking_overclaim", "same_change_blocker"]
              }
            }
          }
        },
        {
          "description": "escalation_state_class = sla_breached_widening_frozen requires channel_widening_blocked = true.",
          "if": {
            "properties": { "escalation_state_class": { "const": "sla_breached_widening_frozen" } },
            "required": ["escalation_state_class"]
          },
          "then": {
            "properties": { "channel_widening_blocked": { "const": true } }
          }
        },

        {
          "description": "ledger_state_class = closed_via_owner_correction, closed_via_public_copy_narrowing, closed_via_claim_narrowing, or closed_no_change_required requires non-null closed_at, non-null closure_notes, and non-null closure_action_class.",
          "if": {
            "properties": {
              "ledger_state_class": {
                "enum": [
                  "closed_via_owner_correction",
                  "closed_via_public_copy_narrowing",
                  "closed_via_claim_narrowing",
                  "closed_no_change_required"
                ]
              }
            },
            "required": ["ledger_state_class"]
          },
          "then": {
            "properties": {
              "closed_at": { "not": { "type": "null" } },
              "closure_notes": { "not": { "type": "null" } },
              "closure_action_class": { "not": { "type": "null" } }
            }
          }
        },
        {
          "description": "ledger_state_class = open_under_review, open_blocking_widening, or open_blocking_release pairs with closed_at = null and closure_action_class = null (the closure path is decided at closure time).",
          "if": {
            "properties": {
              "ledger_state_class": {
                "enum": [
                  "open_under_review",
                  "open_blocking_widening",
                  "open_blocking_release"
                ]
              }
            },
            "required": ["ledger_state_class"]
          },
          "then": {
            "properties": {
              "closed_at": { "type": "null" },
              "closure_action_class": { "type": "null" }
            }
          }
        },
        {
          "description": "ledger_state_class = open_blocking_widening requires channel_widening_blocked = true.",
          "if": {
            "properties": { "ledger_state_class": { "const": "open_blocking_widening" } },
            "required": ["ledger_state_class"]
          },
          "then": {
            "properties": { "channel_widening_blocked": { "const": true } }
          }
        },
        {
          "description": "ledger_state_class = open_blocking_release requires severity_class in {release_blocking_overclaim, same_change_blocker}.",
          "if": {
            "properties": { "ledger_state_class": { "const": "open_blocking_release" } },
            "required": ["ledger_state_class"]
          },
          "then": {
            "properties": {
              "severity_class": {
                "enum": ["release_blocking_overclaim", "same_change_blocker"]
              }
            }
          }
        },

        {
          "description": "closure_action_class = owner_artifact_updated pairs with ledger_state_class = closed_via_owner_correction.",
          "if": {
            "properties": { "closure_action_class": { "const": "owner_artifact_updated" } },
            "required": ["closure_action_class"]
          },
          "then": {
            "properties": { "ledger_state_class": { "const": "closed_via_owner_correction" } }
          }
        },
        {
          "description": "closure_action_class = public_copy_narrowed_in_release pairs with ledger_state_class = closed_via_public_copy_narrowing.",
          "if": {
            "properties": { "closure_action_class": { "const": "public_copy_narrowed_in_release" } },
            "required": ["closure_action_class"]
          },
          "then": {
            "properties": { "ledger_state_class": { "const": "closed_via_public_copy_narrowing" } }
          }
        },
        {
          "description": "closure_action_class = public_copy_narrowed_via_late_copy_packet requires non-empty linked_late_copy_packet_refs and pairs with ledger_state_class = closed_via_public_copy_narrowing.",
          "if": {
            "properties": { "closure_action_class": { "const": "public_copy_narrowed_via_late_copy_packet" } },
            "required": ["closure_action_class"]
          },
          "then": {
            "properties": {
              "linked_late_copy_packet_refs": { "minItems": 1 },
              "ledger_state_class": { "const": "closed_via_public_copy_narrowing" }
            }
          }
        },
        {
          "description": "closure_action_class = claim_row_effective_posture_narrowed requires narrowing_path_class = claim_row_narrowing and pairs with ledger_state_class = closed_via_claim_narrowing.",
          "if": {
            "properties": { "closure_action_class": { "const": "claim_row_effective_posture_narrowed" } },
            "required": ["closure_action_class"]
          },
          "then": {
            "properties": {
              "narrowing_path_class": { "const": "claim_row_narrowing" },
              "ledger_state_class": { "const": "closed_via_claim_narrowing" }
            }
          }
        },
        {
          "description": "closure_action_class = claim_row_retired_from_public_lane requires narrowing_path_class = public_claim_retirement and pairs with ledger_state_class = closed_via_claim_narrowing.",
          "if": {
            "properties": { "closure_action_class": { "const": "claim_row_retired_from_public_lane" } },
            "required": ["closure_action_class"]
          },
          "then": {
            "properties": {
              "narrowing_path_class": { "const": "public_claim_retirement" },
              "ledger_state_class": { "const": "closed_via_claim_narrowing" }
            }
          }
        },
        {
          "description": "closure_action_class = held_under_active_waiver requires non-empty linked_waiver_register_refs.",
          "if": {
            "properties": { "closure_action_class": { "const": "held_under_active_waiver" } },
            "required": ["closure_action_class"]
          },
          "then": {
            "properties": { "linked_waiver_register_refs": { "minItems": 1 } }
          }
        },

        {
          "description": "audited_surface_class in {help_pane, about_pane, service_health_pane} requires non-empty linked_artifact_families.destination_descriptor_row_refs.",
          "if": {
            "properties": {
              "audited_surface_class": {
                "enum": ["help_pane", "about_pane", "service_health_pane"]
              }
            },
            "required": ["audited_surface_class"]
          },
          "then": {
            "properties": {
              "linked_artifact_families": {
                "properties": {
                  "destination_descriptor_row_refs": { "minItems": 1 }
                }
              }
            }
          }
        },
        {
          "description": "audited_surface_class = release_notes_card requires non-empty linked_artifact_families.whats_new_card_row_refs.",
          "if": {
            "properties": { "audited_surface_class": { "const": "release_notes_card" } },
            "required": ["audited_surface_class"]
          },
          "then": {
            "properties": {
              "linked_artifact_families": {
                "properties": {
                  "whats_new_card_row_refs": { "minItems": 1 }
                }
              }
            }
          }
        },
        {
          "description": "audited_surface_class = help_pane requires non-empty linked_artifact_families.help_pane_state_refs.",
          "if": {
            "properties": { "audited_surface_class": { "const": "help_pane" } },
            "required": ["audited_surface_class"]
          },
          "then": {
            "properties": {
              "linked_artifact_families": {
                "properties": {
                  "help_pane_state_refs": { "minItems": 1 }
                }
              }
            }
          }
        },
        {
          "description": "audited_surface_class = public_proof_packet requires non-empty linked_artifact_families.public_proof_row_refs.",
          "if": {
            "properties": { "audited_surface_class": { "const": "public_proof_packet" } },
            "required": ["audited_surface_class"]
          },
          "then": {
            "properties": {
              "linked_artifact_families": {
                "properties": {
                  "public_proof_row_refs": { "minItems": 1 }
                }
              }
            }
          }
        },
        {
          "description": "audited_surface_class = support_export_card requires non-empty linked_artifact_families.support_export_packet_refs.",
          "if": {
            "properties": { "audited_surface_class": { "const": "support_export_card" } },
            "required": ["audited_surface_class"]
          },
          "then": {
            "properties": {
              "linked_artifact_families": {
                "properties": {
                  "support_export_packet_refs": { "minItems": 1 }
                }
              }
            }
          }
        }
      ]
    }
  }
}
