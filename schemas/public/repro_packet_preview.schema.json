{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/public/repro_packet_preview.schema.json",
  "title": "Aureline public reproduction-packet preview contract",
  "description": "Boundary schema for one repro_packet_preview_record the user reviews before a report leaves the shell. The preview summarizes which diagnostics are selected (and which are included), the redaction posture applied to the packet, the attachment list, and the exact anchor/object identity the report is about. Raw secrets and raw screenshots MUST always be excluded, and every attachment MUST be redaction-applied before share. The preview carries a preview_confirmed_before_share gate so a handoff can only open the system browser after the user has actually seen what will be shared. Raw URLs, raw email addresses, and raw secret material MUST NOT appear; the record carries opaque refs and bounded reviewable summaries only. The compatibility between the redaction posture and the chosen target visibility is enforced by the bundling handoff_review_sheet record, not here. Adding a new diagnostic kind, attachment kind, or redaction posture is additive-minor and bumps repro_packet_preview_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "$ref": "#/$defs/repro_packet_preview_record",
  "$defs": {
    "repro_packet_preview_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version. Current value is 1."
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[^\\s]+$",
      "not": { "pattern": "://|@" },
      "description": "Opaque, stable identifier safe for live surfaces and support exports. Raw URLs, raw absolute paths, raw email addresses, and raw secret material MUST NOT appear here."
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "description": "Bounded reviewable sentence. Raw URLs, raw page-body bytes, raw user identifiers, and raw secrets MUST NOT appear."
    },
    "nullable_reviewable_sentence": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/reviewable_sentence" }
      ]
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario", "contract_sections"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "contract_sections": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "redaction_posture_class": {
      "type": "string",
      "enum": [
        "fully_redacted_public_safe",
        "redacted_support_scoped",
        "security_channel_only",
        "metadata_refs_only"
      ],
      "description": "Closed redaction-posture vocabulary applied to the packet. fully_redacted_public_safe and metadata_refs_only are safe for world-readable targets; redacted_support_scoped is private support; security_channel_only is security disclosure only."
    },
    "diagnostic_kind_class": {
      "type": "string",
      "enum": [
        "build_identity",
        "environment_capsule",
        "redacted_log_tail",
        "sanitized_config_snapshot",
        "repro_steps_text",
        "anchor_object_ref",
        "performance_trace"
      ],
      "description": "Closed diagnostic-kind vocabulary for the selected-diagnostics summary."
    },
    "attachment_kind_class": {
      "type": "string",
      "enum": [
        "build_context_export_block",
        "redacted_log_bundle",
        "minimal_repro_project",
        "sanitized_config_bundle",
        "anchor_object_snapshot"
      ],
      "description": "Closed attachment-kind vocabulary for the previewed attachment list."
    },

    "diagnostic_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind_class", "included", "summary"],
      "properties": {
        "kind_class": { "$ref": "#/$defs/diagnostic_kind_class" },
        "included": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "repro_attachment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind_class", "attachment_ref", "redaction_applied", "summary"],
      "properties": {
        "kind_class": { "$ref": "#/$defs/attachment_kind_class" },
        "attachment_ref": { "$ref": "#/$defs/opaque_ref" },
        "redaction_applied": { "type": "boolean", "const": true },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "exact_anchor_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anchor_ref", "object_ref", "anchor_label"],
      "properties": {
        "anchor_ref": { "$ref": "#/$defs/opaque_ref" },
        "object_ref": { "$ref": "#/$defs/opaque_ref" },
        "anchor_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },

    "repro_packet_preview_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repro_packet_preview_schema_version",
        "record_kind",
        "packet_id",
        "redaction_posture_class",
        "selected_diagnostics",
        "attachments",
        "anchor_identity",
        "preview_confirmed_before_share",
        "raw_secrets_excluded",
        "raw_screenshots_excluded",
        "headline_label",
        "packet_summary",
        "contract_doc_ref",
        "notes"
      ],
      "properties": {
        "repro_packet_preview_schema_version": {
          "$ref": "#/$defs/repro_packet_preview_schema_version"
        },
        "record_kind": {
          "type": "string",
          "const": "repro_packet_preview_record"
        },
        "packet_id": {
          "type": "string",
          "pattern": "^repro_packet_preview:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
        },
        "redaction_posture_class": { "$ref": "#/$defs/redaction_posture_class" },
        "selected_diagnostics": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/diagnostic_selection" },
          "contains": {
            "properties": { "included": { "const": true } },
            "required": ["included"]
          }
        },
        "attachments": {
          "type": "array",
          "items": { "$ref": "#/$defs/repro_attachment" }
        },
        "anchor_identity": { "$ref": "#/$defs/exact_anchor_identity" },
        "preview_confirmed_before_share": { "type": "boolean" },
        "raw_secrets_excluded": { "type": "boolean", "const": true },
        "raw_screenshots_excluded": { "type": "boolean", "const": true },
        "headline_label": { "$ref": "#/$defs/reviewable_label" },
        "packet_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "contract_doc_ref": {
          "type": "string",
          "const": "docs/public/m3/handoff_and_repro_boundary.md"
        },
        "notes": { "$ref": "#/$defs/nullable_reviewable_sentence" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" }
      }
    }
  }
}
