{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/entry/recovery_choice.schema.json",
  "title": "Aureline entry unavailable-target recovery choice",
  "description": "Boundary schema for exportable unavailable-target recovery choice sets, decisions, and outcomes used by recent-work, restore prompts, workspace switchers, and system/protocol reentry. The contract ensures every recovery route carries identity, trust, stale-state, and write-safety disclosures so missing/offline targets never look like ordinary local opens. See artifacts/entry/unavailable_target_actions.md.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/entry_recovery_choice_set_record" },
    { "$ref": "#/$defs/entry_recovery_choice_decision_record" },
    { "$ref": "#/$defs/entry_recovery_choice_outcome_record" }
  ],
  "$defs": {
    "entry_recovery_choice_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this entry recovery-choice contract."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional worked-example prelude carried on fixtures under __fixture__. Production consumers ignore this object."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque id safe for logs, support bundles, and exports. Raw paths, raw URLs with embedded credentials, and secrets never appear here."
    },
    "monotonic_timestamp": {
      "type": "string",
      "minLength": 1,
      "description": "Producer-local monotonic timestamp. Consumers do not infer ordering beyond producer ordering."
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "recent_work_row",
        "restore_prompt",
        "workspace_switcher",
        "system_open",
        "protocol_handler",
        "deep_link",
        "other"
      ],
      "description": "Which entry surface is rendering or exporting the recovery choice."
    },
    "unavailable_target_situation_class": {
      "type": "string",
      "enum": [
        "missing_folder",
        "moved_workspace_file",
        "disconnected_network_share",
        "missing_mount",
        "offline_ssh_host",
        "expired_managed_session",
        "revoked_permission"
      ],
      "description": "Human-reviewable unavailable-target situation label used to keep fixture coverage explicit across surfaces."
    },
    "target_kind": {
      "$ref": "../ux/recent_work_row.schema.json#/$defs/target_kind",
      "description": "Re-exported target_kind from schemas/ux/recent_work_row.schema.json."
    },
    "root_kind": {
      "$ref": "../ux/recent_work_row.schema.json#/$defs/root_kind",
      "description": "Re-exported root_kind from schemas/ux/recent_work_row.schema.json."
    },
    "target_state": {
      "$ref": "../ux/recent_work_row.schema.json#/$defs/target_state",
      "description": "Re-exported target_state from schemas/ux/recent_work_row.schema.json."
    },
    "unavailable_reason": {
      "$ref": "../ux/recent_work_row.schema.json#/$defs/unavailable_reason",
      "description": "Re-exported unavailable_reason from schemas/ux/recent_work_row.schema.json."
    },
    "trust_state": {
      "$ref": "../ux/recent_work_row.schema.json#/$defs/trust_state",
      "description": "Re-exported trust_state from schemas/ux/recent_work_row.schema.json."
    },
    "freshness_class": {
      "$ref": "../ux/recent_work_row.schema.json#/$defs/freshness_class",
      "description": "Re-exported freshness_class from schemas/ux/recent_work_row.schema.json."
    },
    "write_safety_badge": {
      "$ref": "../ux/recent_work_row.schema.json#/$defs/write_safety_badge",
      "description": "Re-exported write_safety_badge from schemas/ux/recent_work_row.schema.json."
    },
    "recovery_action_id": {
      "$ref": "../ux/recent_work_row.schema.json#/$defs/recovery_action_id",
      "description": "Re-exported recovery_action_id from schemas/ux/recent_work_row.schema.json."
    },
    "action_role": {
      "$ref": "../ux/recent_work_row.schema.json#/$defs/action_role",
      "description": "Re-exported action_role from schemas/ux/recent_work_row.schema.json."
    },
    "identity_disclosure_class": {
      "type": "string",
      "enum": [
        "identity_known",
        "identity_stale_cache_only",
        "identity_missing_requires_locate",
        "identity_remote_requires_reconnect",
        "identity_ambiguous_requires_review"
      ],
      "description": "Compact identity disclosure token carried on each recovery route so consumers render 'what object is this action about' honestly."
    },
    "recovery_badge_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity_disclosure_class",
        "trust_state",
        "freshness_class",
        "write_safety_badge"
      ],
      "properties": {
        "identity_disclosure_class": { "$ref": "#/$defs/identity_disclosure_class" },
        "trust_state": { "$ref": "#/$defs/trust_state" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "write_safety_badge": { "$ref": "#/$defs/write_safety_badge" },
        "summary": {
          "type": ["string", "null"],
          "maxLength": 1024,
          "description": "Optional short redaction-aware summary explaining the badge set."
        }
      },
      "description": "The four required disclosure axes carried on every recovery route: identity, trust, stale-state, and write safety."
    },
    "recovery_choice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["choice_id", "action_id", "action_role", "enabled", "badges"],
      "properties": {
        "choice_id": { "$ref": "#/$defs/opaque_id" },
        "action_id": { "$ref": "#/$defs/recovery_action_id" },
        "action_role": { "$ref": "#/$defs/action_role" },
        "enabled": { "type": "boolean" },
        "requires_confirmation": {
          "type": "boolean",
          "description": "True when the surface must require an explicit confirmation step before committing the action."
        },
        "requires_target_revalidation": {
          "type": "boolean",
          "description": "True when identity/trust must be revalidated before the action can widen authority or enable writes."
        },
        "badges": { "$ref": "#/$defs/recovery_badge_set" },
        "presentation_label": {
          "type": ["string", "null"],
          "maxLength": 1024,
          "description": "Optional redaction-aware label. Consumers must not treat this as canonical vocabulary; action_id is canonical."
        }
      },
      "description": "One offered recovery route shown to the user."
    },
    "entry_recovery_choice_set_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "entry_recovery_choice_schema_version",
        "choice_set_id",
        "surface_class",
        "situation_class",
        "target_kind",
        "root_kind",
        "target_state",
        "unavailable_reason",
        "trust_state",
        "freshness_class",
        "write_safety_badge",
        "choices",
        "emitted_at"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "entry_recovery_choice_set_record" },
        "entry_recovery_choice_schema_version": { "$ref": "#/$defs/entry_recovery_choice_schema_version" },
        "choice_set_id": { "$ref": "#/$defs/opaque_id" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "situation_class": { "$ref": "#/$defs/unavailable_target_situation_class" },
        "target_kind": { "$ref": "#/$defs/target_kind" },
        "root_kind": { "$ref": "#/$defs/root_kind" },
        "target_state": { "$ref": "#/$defs/target_state" },
        "unavailable_reason": { "$ref": "#/$defs/unavailable_reason" },
        "trust_state": { "$ref": "#/$defs/trust_state" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "write_safety_badge": { "$ref": "#/$defs/write_safety_badge" },
        "source_record_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Opaque linkage to the upstream record(s) this choice set wraps (recent-work id, restore prompt ref, switcher row id, packet id, intent id, etc.)."
        },
        "choices": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/recovery_choice" },
          "uniqueItems": true
        },
        "emitted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "description": "One unavailable-target recovery choice set rendered by an entry surface."
    },
    "decision_actor_class": {
      "type": "string",
      "enum": ["user", "system_default", "policy_enforced", "other"],
      "description": "Who selected the recovery route. Used for support chronology."
    },
    "entry_recovery_choice_decision_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "entry_recovery_choice_schema_version",
        "decision_id",
        "choice_set_ref",
        "surface_class",
        "situation_class",
        "chosen_action_id",
        "actor_class",
        "decision_at"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "entry_recovery_choice_decision_record" },
        "entry_recovery_choice_schema_version": { "$ref": "#/$defs/entry_recovery_choice_schema_version" },
        "decision_id": { "$ref": "#/$defs/opaque_id" },
        "choice_set_ref": { "$ref": "#/$defs/opaque_id" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "situation_class": { "$ref": "#/$defs/unavailable_target_situation_class" },
        "chosen_choice_id": {
          "type": ["string", "null"],
          "description": "Optional choice_id reference into the originating set; null when only action_id was retained."
        },
        "chosen_action_id": { "$ref": "#/$defs/recovery_action_id" },
        "actor_class": { "$ref": "#/$defs/decision_actor_class" },
        "decision_context_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Optional additional linkage refs (support packet, audit event, deep-link intent, system-open packet, etc.)."
        },
        "decision_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "description": "One exported decision event indicating which unavailable-target recovery action was chosen."
    },
    "recovery_outcome_class": {
      "type": "string",
      "enum": [
        "succeeded_target_reanchored",
        "succeeded_reconnected",
        "succeeded_opened_read_only_cached_view",
        "succeeded_removed_from_recents",
        "succeeded_deferred_retry",
        "succeeded_opened_clean",
        "canceled_no_change",
        "failed_still_unavailable",
        "failed_blocked_by_policy",
        "failed_identity_mismatch",
        "failed_other"
      ],
      "description": "Outcome class for the chosen recovery route."
    },
    "entry_recovery_choice_outcome_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "entry_recovery_choice_schema_version",
        "outcome_id",
        "decision_ref",
        "choice_set_ref",
        "surface_class",
        "situation_class",
        "outcome_class",
        "observed_target_state",
        "emitted_at"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "entry_recovery_choice_outcome_record" },
        "entry_recovery_choice_schema_version": { "$ref": "#/$defs/entry_recovery_choice_schema_version" },
        "outcome_id": { "$ref": "#/$defs/opaque_id" },
        "decision_ref": { "$ref": "#/$defs/opaque_id" },
        "choice_set_ref": { "$ref": "#/$defs/opaque_id" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "situation_class": { "$ref": "#/$defs/unavailable_target_situation_class" },
        "outcome_class": { "$ref": "#/$defs/recovery_outcome_class" },
        "observed_target_state": { "$ref": "#/$defs/target_state" },
        "notes": {
          "type": ["string", "null"],
          "maxLength": 1024,
          "description": "Optional redaction-aware note for support chronology."
        },
        "emitted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "description": "One exported outcome event indicating what happened after the chosen unavailable-target recovery action."
    }
  }
}

