{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/aureline-shell/m5-start-center-and-switcher.schema.json",
  "title": "M5 Start Center and workspace-switcher parity packet",
  "description": "Truth packet projecting the canonical recent-work model through the live Start Center and in-workspace switcher so target kind, trust, restore, and missing-root state stay consistent across the new M5 entry surfaces. Produced by crate aureline-shell module m5_start_center_and_switcher.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "packet_id",
    "headline",
    "rows",
    "diagnostics",
    "surface_class_coverage",
    "all_rows_in_both_surfaces",
    "no_target_kind_collapsed",
    "no_trust_widened",
    "full_parity",
    "release_evidence_refs",
    "readiness_review_refs",
    "published_audit_ref",
    "docs_help_refs",
    "support_export_refs",
    "generated_at"
  ],
  "properties": {
    "record_kind": { "const": "shell_m5_start_center_and_switcher_packet_record" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "shared_contract_ref": { "type": "string" },
    "packet_id": { "type": "string" },
    "headline": { "type": "string" },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/row" }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    },
    "surface_class_coverage": { "$ref": "#/$defs/coverage" },
    "all_rows_in_both_surfaces": { "type": "boolean" },
    "no_target_kind_collapsed": { "type": "boolean" },
    "no_trust_widened": { "type": "boolean" },
    "full_parity": { "type": "boolean" },
    "release_evidence_refs": { "type": "array", "items": { "type": "string" } },
    "readiness_review_refs": { "type": "array", "items": { "type": "string" } },
    "published_audit_ref": { "type": "string" },
    "docs_help_refs": { "type": "array", "items": { "type": "string" } },
    "support_export_refs": { "type": "array", "items": { "type": "string" } },
    "generated_at": { "type": "string" }
  },
  "$defs": {
    "surface_class": {
      "type": "string",
      "enum": [
        "local_folder",
        "workspace_file",
        "multi_root_workspace",
        "ssh_target",
        "container_or_devcontainer",
        "managed_workspace",
        "import_packet",
        "bundle_backed_entry"
      ]
    },
    "trust_state": {
      "type": "string",
      "enum": ["trusted", "restricted", "pending_evaluation"]
    },
    "restore_availability": {
      "type": "string",
      "enum": ["exact", "compatible", "layout_only", "evidence_only", "none"]
    },
    "failure_state": {
      "type": "string",
      "enum": [
        "ready",
        "missing_path",
        "moved_root",
        "reconnect_required",
        "inspect_only",
        "blocked",
        "unknown"
      ]
    },
    "root_state": {
      "type": "string",
      "enum": [
        "root_resolved",
        "missing_root",
        "relocated_root",
        "stale_root",
        "remote_host_unreachable",
        "blocked_root",
        "unknown_root"
      ]
    },
    "diagnostic_class": {
      "type": "string",
      "enum": [
        "missing_root",
        "relocated_workspace",
        "stale_target",
        "remote_host_unreachable",
        "partial_restore"
      ]
    },
    "safe_recovery_action": {
      "type": "string",
      "enum": [
        "open",
        "open_in_new_window",
        "open_restricted",
        "locate_missing_target",
        "reconnect",
        "reauth",
        "open_read_only_cached_view",
        "retry_later",
        "compare_before_restore",
        "open_without_restore",
        "unpin",
        "pin",
        "remove_from_recents",
        "reveal_in_explorer"
      ]
    },
    "parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_kind_parity",
        "trust_parity",
        "restore_parity",
        "failure_parity",
        "recovery_action_parity"
      ],
      "properties": {
        "target_kind_parity": { "type": "boolean" },
        "trust_parity": { "type": "boolean" },
        "restore_parity": { "type": "boolean" },
        "failure_parity": { "type": "boolean" },
        "recovery_action_parity": { "type": "boolean" }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "recent_work_id",
        "presentation_label",
        "location_subtitle",
        "surface_class",
        "target_kind",
        "target_kind_label",
        "canonical_trust_state",
        "start_center_trust_state",
        "switcher_trust_state",
        "canonical_restore_availability",
        "start_center_restore_availability",
        "switcher_restore_availability",
        "target_state",
        "failure_state",
        "root_state",
        "present_in_start_center",
        "present_in_switcher",
        "pinned",
        "keyboard_complete",
        "pin_action_available",
        "remove_action_available",
        "reconnect_or_locate_available",
        "start_center_safe_actions",
        "switcher_safe_actions",
        "parity",
        "diagnostic_class"
      ],
      "properties": {
        "record_kind": { "const": "shell_m5_start_center_and_switcher_row_record" },
        "schema_version": { "type": "integer", "minimum": 1 },
        "shared_contract_ref": { "type": "string" },
        "recent_work_id": { "type": "string" },
        "presentation_label": { "type": "string" },
        "location_subtitle": { "type": ["string", "null"] },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "target_kind": { "type": "string" },
        "target_kind_label": { "type": "string" },
        "canonical_trust_state": { "$ref": "#/$defs/trust_state" },
        "start_center_trust_state": { "$ref": "#/$defs/trust_state" },
        "switcher_trust_state": { "$ref": "#/$defs/trust_state" },
        "canonical_restore_availability": { "$ref": "#/$defs/restore_availability" },
        "start_center_restore_availability": { "$ref": "#/$defs/restore_availability" },
        "switcher_restore_availability": { "$ref": "#/$defs/restore_availability" },
        "target_state": { "type": "string" },
        "failure_state": { "$ref": "#/$defs/failure_state" },
        "root_state": { "$ref": "#/$defs/root_state" },
        "present_in_start_center": { "type": "boolean" },
        "present_in_switcher": { "type": "boolean" },
        "pinned": { "type": "boolean" },
        "keyboard_complete": { "type": "boolean" },
        "pin_action_available": { "type": "boolean" },
        "remove_action_available": { "type": "boolean" },
        "reconnect_or_locate_available": { "type": "boolean" },
        "start_center_safe_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/safe_recovery_action" }
        },
        "switcher_safe_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/safe_recovery_action" }
        },
        "parity": { "$ref": "#/$defs/parity" },
        "diagnostic_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/diagnostic_class" }
          ]
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "diagnostic_id",
        "recent_work_id",
        "diagnostic_class",
        "surface_class",
        "target_kind",
        "redacted_location",
        "target_state",
        "failure_state",
        "root_state",
        "trust_state",
        "restore_availability",
        "recovery_actions",
        "export_safe"
      ],
      "properties": {
        "record_kind": { "const": "shell_m5_start_center_and_switcher_diagnostic_record" },
        "schema_version": { "type": "integer", "minimum": 1 },
        "shared_contract_ref": { "type": "string" },
        "diagnostic_id": { "type": "string" },
        "recent_work_id": { "type": "string" },
        "diagnostic_class": { "$ref": "#/$defs/diagnostic_class" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "target_kind": { "type": "string" },
        "redacted_location": { "type": "string" },
        "target_state": { "type": "string" },
        "failure_state": { "$ref": "#/$defs/failure_state" },
        "root_state": { "$ref": "#/$defs/root_state" },
        "trust_state": { "$ref": "#/$defs/trust_state" },
        "restore_availability": { "$ref": "#/$defs/restore_availability" },
        "recovery_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/safe_recovery_action" }
        },
        "export_safe": { "const": true }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "covered_classes",
        "total_required_classes",
        "covered_diagnostic_classes"
      ],
      "properties": {
        "covered_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_class" }
        },
        "total_required_classes": { "type": "integer", "minimum": 0 },
        "covered_diagnostic_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic_class" }
        }
      }
    }
  }
}
