{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/storage/workspace_storage_detail.schema.json",
  "title": "Aureline workspace-storage detail row record",
  "description": "Boundary schema for the workspace_storage_detail_row_record frozen in docs/storage/workspace_storage_detail_contract.md. Each row drills the storage-inspector card into one entry-level disclosure on one workspace, workset, profile, tenant, slice, or device-total scope. The row carries the storage_class_id, the entry's class and opaque ref, the size_bytes, the last_used_at timestamp, the embedded rebuild_cost_hint_record (offline-rebuild-risk class, startup-impact class, provenance-continuity class, rebuild-inputs-required closed list, and rebuild-safety summary class), the pin_state with its pin-source breakdown, the sensitivity_class, the freshness_state, the corruption_state, the policy_protection_state, the detail_authority_posture_class (disposable_derived_state / correctness_relevant_derived_state / imported_durable_artifact / authoritative_user_owned_state / policy_held_evidence_state), and the typed clear_action and export_action that the surface offers verbatim. Schema rules pair the storage class, authority class, origin class, protection class, and rebuild-cost class with the detail-authority posture and the clear / export action so a workspace-detail surface cannot describe authoritative user-owned recovery state with the same authority language as a disposable hot-cache row, cannot describe a mirrored offline pack as a generic disposable cache, and cannot offer a generic clear over an evidence row without naming the class-specific review path. The row mints no new storage_class_id, authority_class, rebuild_cost_class, gc_policy_class, sensitivity_class, pin_source_class, mirror_or_import_origin_class, or clear_cache_protection_class value; those re-export verbatim from /artifacts/runtime/storage_classes.yaml, /schemas/runtime/cache_entry_manifest.schema.json, and /schemas/storage/storage_class_breakdown.schema.json. The rebuild_cost_hint_record shape re-exports verbatim from /schemas/storage/rebuild_cost_hint.schema.json. Adding a value to a closed vocabulary is additive-minor and bumps workspace_storage_detail_row_schema_version; repurposing a value or relaxing the authority-posture / clear-action / export-action pairings is breaking and requires a new decision row.",
  "type": "object",
  "$ref": "#/$defs/workspace_storage_detail_row_record",
  "$defs": {
    "workspace_storage_detail_row_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the workspace-storage detail row payload shape. Current value is 1."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable identifier safe to log, safe on RPC, safe in manifests, support bundles, and admin exports. Raw URLs, raw hostnames, raw absolute paths, raw policy rule bodies, and raw secret material never appear here."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 UTC timestamp from a producer-local monotonic clock."
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Bounded, redaction-aware display label. May contain user-facing names but never raw URLs, raw hostnames, raw absolute paths, raw policy rule bodies, raw command lines, or raw secret material."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "description": "Short reviewable sentence. Raw payload bytes, raw paths, raw URLs, raw secret material MUST NOT appear."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario", "contract_sections"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "contract_sections": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "exercised_axes": { "type": "object", "additionalProperties": true }
      },
      "description": "Optional worked-example prelude carried on fixtures; never part of the runtime record."
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "storage_class_id": {
      "type": "string",
      "enum": [
        "interactive_hot_cache",
        "knowledge_cache",
        "artifact_cache",
        "prebuild_environment_cache",
        "evidence_support_cache",
        "user_owned_recovery_state"
      ]
    },
    "authority_class": {
      "type": "string",
      "enum": [
        "user_authored_durable_truth",
        "user_owned_recovery_state",
        "admin_or_control_artifact",
        "disposable_derived_cache"
      ]
    },
    "rebuild_cost_class": {
      "type": "string",
      "enum": [
        "authoritative_no_rebuild",
        "high_rebuild_cost",
        "medium_rebuild_cost",
        "low_rebuild_cost"
      ]
    },
    "sensitivity_class": {
      "type": "string",
      "enum": [
        "t0_metadata_only",
        "t1_low_risk_derived",
        "t2_code_bearing_bounded",
        "t3_secret_adjacent_not_reusable_cache"
      ],
      "description": "Re-export of sensitivity_class from /artifacts/runtime/storage_classes.yaml. t3 is admissible only on evidence_support_cache."
    },
    "pin_source_class": {
      "type": "string",
      "enum": [
        "explicit_user_pin",
        "explicit_admin_policy_pin",
        "release_artifact_graph_ref",
        "case_reference_ref",
        "review_pack_ref",
        "offline_bundle_ref",
        "certified_archetype_or_template_ref",
        "policy_bundle_last_known_good_ref",
        "support_export_assembly_ref",
        "retention_window_ref"
      ]
    },
    "mirror_or_import_origin_class": {
      "type": "string",
      "enum": [
        "local_authoritative",
        "local_disposable_cache",
        "local_evidence_capture",
        "mirrored_copy",
        "offline_bundle_local",
        "vendor_signed_offline_local",
        "customer_signed_mirror_local",
        "policy_protected_admin_artifact",
        "not_applicable"
      ]
    },
    "clear_cache_protection_class": {
      "type": "string",
      "enum": [
        "generic_clear_always_allowed",
        "generic_clear_with_pin_exclusions",
        "protected_requires_class_specific_review",
        "protected_never_generic_clear"
      ]
    },
    "entry_class": {
      "type": "string",
      "enum": [
        "workspace_index_corpus",
        "workspace_history_lane",
        "workspace_recovery_journal",
        "workset_session_restore_state",
        "extension_pack",
        "docs_pack_corpus",
        "model_pack_blob",
        "update_pack_blob",
        "policy_bundle_blob",
        "prebuild_layer_blob",
        "template_or_archetype_pack",
        "evidence_packet_blob",
        "support_export_assembly_in_flight",
        "terminal_restore_metadata_store",
        "mirror_snapshot_segment",
        "offline_bundle_segment",
        "interactive_hot_cache_shard",
        "aggregated_remainder_other"
      ],
      "description": "Re-export of consumer_class from /schemas/storage/storage_class_breakdown.schema.json plus the interactive_hot_cache_shard entry-level value the storage-inspector aggregates under workspace_index_corpus on the card breakdown."
    },
    "inspector_scope_class": {
      "type": "string",
      "enum": [
        "device_total",
        "workspace_only",
        "workset_only",
        "profile_only",
        "tenant_only",
        "slice_only"
      ]
    },
    "detail_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_class", "scope_ref", "scope_label"],
      "properties": {
        "scope_class": { "$ref": "#/$defs/inspector_scope_class" },
        "scope_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "scope_label": { "$ref": "#/$defs/reviewable_label" }
      },
      "allOf": [
        {
          "description": "device_total scope carries a null scope_ref; every other scope class carries a non-null ref.",
          "if": {
            "properties": { "scope_class": { "const": "device_total" } },
            "required": ["scope_class"]
          },
          "then": {
            "properties": {
              "scope_ref": { "type": "null" }
            }
          },
          "else": {
            "properties": {
              "scope_ref": { "not": { "type": "null" } }
            }
          }
        }
      ]
    },
    "detail_authority_posture_class": {
      "type": "string",
      "enum": [
        "disposable_derived_state",
        "correctness_relevant_derived_state",
        "imported_durable_artifact",
        "policy_held_evidence_state",
        "authoritative_user_owned_state"
      ],
      "description": "Closed authority-posture vocabulary the workspace-detail surface uses to render rebuild and clear copy. disposable_derived_state describes a hot disposable cache row whose removal is reversible at low cost; correctness_relevant_derived_state describes a knowledge / prebuild / artifact-cache row whose removal preserves correctness only after a (potentially slow) rebuild and where the surface MUST name the rebuild cost; imported_durable_artifact describes mirrored / offline-bundle / vendor-signed / customer-signed / policy-protected admin artifacts whose removal is unsafe under air-gapped or network-degraded conditions and whose surface copy MUST name the mirror or offline-bundle dependency; policy_held_evidence_state describes evidence-cache rows held under a retention window or open case and whose surface copy MUST link the class-specific review path; authoritative_user_owned_state describes user-owned recovery-state rows whose generic clear is refused outright and whose surface copy MUST refuse to render disposable language."
    },
    "freshness_state_class": {
      "type": "string",
      "enum": [
        "fresh_within_window",
        "stale_within_extended_window",
        "stale_past_extended_window",
        "unknown_no_scan_yet",
        "not_applicable_no_freshness_signal"
      ],
      "description": "Closed freshness state. Workspace-detail surfaces render staleness verbatim instead of hiding it under a single 'last used' label so a degraded knowledge cache or a partially-scanned evidence row is visibly stale rather than silently rendered."
    },
    "corruption_state_class": {
      "type": "string",
      "enum": [
        "not_corrupt",
        "suspected_corrupt_pending_revalidation",
        "confirmed_corrupt_quarantined",
        "confirmed_corrupt_pending_rebuild_or_replace",
        "unknown_low_privilege_scan"
      ],
      "description": "Closed corruption state. confirmed_corrupt rows MUST stay visible (the row is not silently dropped) and MUST surface the corruption-rescue path through the linked review action; unknown_low_privilege_scan rows MUST surface the consent affordance instead of rendering a clean state."
    },
    "policy_protection_state_class": {
      "type": "string",
      "enum": [
        "not_policy_protected",
        "protected_admin_policy_pin",
        "protected_tenant_policy_pin",
        "protected_retention_window",
        "protected_evidence_case_or_review",
        "protected_user_owned_authoritative"
      ],
      "description": "Closed policy-protection state. Workspace-detail rows render the policy-protection state verbatim so a row protected by an admin pin, a tenant pin, a retention window, an open case, or user-owned authority is visibly typed."
    },
    "pin_state_class": {
      "type": "string",
      "enum": [
        "unpinned_no_sources",
        "pinned_user_only",
        "pinned_admin_or_tenant_policy_only",
        "pinned_release_or_offline_bundle_only",
        "pinned_evidence_case_or_review_only",
        "pinned_retention_window_only",
        "pinned_multiple_classes",
        "not_applicable_authoritative_state"
      ],
      "description": "Closed pin-state vocabulary. unpinned_no_sources is the reclaimable-by-default state; the policy / release / evidence / retention pin states match the upstream pin_source_class vocabulary; pinned_multiple_classes is admissible when more than one source pins the entry; not_applicable_authoritative_state is required on user_owned_recovery_state rows whose authority refuses pin semantics for generic clear paths."
    },
    "pin_source_breakdown_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pin_source_class", "pin_ref_summary_id"],
      "properties": {
        "pin_source_class": { "$ref": "#/$defs/pin_source_class" },
        "pin_ref_summary_id": { "$ref": "#/$defs/opaque_id" },
        "pin_label": { "$ref": "#/$defs/reviewable_label" },
        "notes": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "clear_action_class": {
      "type": "string",
      "enum": [
        "clear_admissible_generic",
        "clear_admissible_after_pin_release",
        "clear_requires_class_specific_review",
        "clear_refused_authoritative_user_owned",
        "clear_refused_policy_held"
      ],
      "description": "Closed clear-action class. clear_admissible_generic is admitted only on disposable / hot / unpinned rows; clear_admissible_after_pin_release names rows where the user must release a pin first; clear_requires_class_specific_review names evidence rows; clear_refused_authoritative_user_owned names user-owned recovery state; clear_refused_policy_held names rows whose retention window or admin pin holds the bytes."
    },
    "export_action_class": {
      "type": "string",
      "enum": [
        "export_offered_metadata_safe",
        "export_offered_operator_only",
        "export_required_before_clear",
        "export_unsupported_already_local_only_disposable",
        "export_unsupported_class"
      ],
      "description": "Closed export-action class. export_offered_metadata_safe is the safe baseline; export_offered_operator_only is admitted on operator-only rows; export_required_before_clear is required on authoritative_no_rebuild evidence rows so the user is offered an export before any class-specific clear; export_unsupported_already_local_only_disposable is the disposable-cache posture where there is nothing meaningful to export; export_unsupported_class is the policy-bound posture where export is refused outright."
    },
    "inspect_only_open_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "label",
        "scope_class",
        "authority_class",
        "consent_class",
        "side_effects",
        "preserves_evidence_context",
        "modal_prohibited",
        "revalidation_on_open"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "label": { "$ref": "#/$defs/reviewable_label" },
        "scope_class": { "type": "string", "const": "scope_local_only" },
        "authority_class": { "type": "string", "const": "user_local_authority" },
        "consent_class": { "type": "string", "const": "no_consent_required_safe_default" },
        "side_effects": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "type": "string", "const": "no_side_effect_inspect_only" }
        },
        "preserves_evidence_context": { "type": "boolean", "const": true },
        "modal_prohibited": { "type": "boolean", "const": true },
        "revalidation_on_open": {
          "type": "string",
          "enum": ["none_already_fresh", "snapshot_open_read_only"]
        }
      }
    },
    "rebuild_cost_hint_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "rebuild_cost_hint_schema_version",
        "rebuild_cost_class",
        "offline_rebuild_risk_class",
        "startup_impact_class",
        "provenance_continuity_class",
        "rebuild_inputs_required",
        "rebuild_safety_summary_class",
        "rebuild_explanation"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "rebuild_cost_hint_record" },
        "rebuild_cost_hint_schema_version": { "type": "integer", "const": 1 },
        "rebuild_cost_class": { "$ref": "#/$defs/rebuild_cost_class" },
        "offline_rebuild_risk_class": {
          "type": "string",
          "enum": [
            "safe_to_remove_offline",
            "rebuild_requires_network_resync",
            "rebuild_requires_mirror_or_offline_bundle",
            "rebuild_requires_admin_or_policy_signed_pack",
            "not_rebuildable_after_removal"
          ]
        },
        "startup_impact_class": {
          "type": "string",
          "enum": [
            "no_user_visible_impact",
            "slower_first_open_until_warm",
            "slower_first_query_until_reindexed",
            "slower_first_build_until_prebuilt",
            "feature_unavailable_until_rebuilt",
            "not_applicable_authoritative_state"
          ]
        },
        "provenance_continuity_class": {
          "type": "string",
          "enum": [
            "provenance_preserved_rebuild_from_local_truth",
            "provenance_preserved_rebuild_from_signed_source",
            "provenance_breaks_until_resigned_or_re_imported",
            "authoritative_provenance_irreplaceable",
            "not_applicable_disposable_no_provenance"
          ]
        },
        "rebuild_inputs_required": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "local_workspace_source",
              "local_history_journal",
              "network_provider_or_index",
              "customer_operated_mirror",
              "vendor_published_mirror",
              "offline_bundle_local",
              "vendor_signed_offline_bundle",
              "customer_signed_mirror",
              "policy_signed_pack",
              "no_input_authoritative_state"
            ]
          }
        },
        "rebuild_safety_summary_class": {
          "type": "string",
          "enum": [
            "cheap_to_rebuild_safe_to_remove",
            "expensive_to_rebuild_but_safe",
            "impossible_to_rebuild_offline",
            "dangerous_to_delete_authoritative"
          ]
        },
        "rebuild_explanation": { "$ref": "#/$defs/reviewable_sentence" },
        "notes": { "type": "string" }
      },
      "allOf": [
        {
          "description": "Authoritative no-rebuild cost forces dangerous-to-delete summary plus authoritative offline-risk / startup-impact / provenance / inputs.",
          "if": {
            "properties": { "rebuild_cost_class": { "const": "authoritative_no_rebuild" } },
            "required": ["rebuild_cost_class"]
          },
          "then": {
            "properties": {
              "rebuild_safety_summary_class": { "const": "dangerous_to_delete_authoritative" },
              "offline_rebuild_risk_class": { "const": "not_rebuildable_after_removal" },
              "startup_impact_class": { "const": "not_applicable_authoritative_state" },
              "provenance_continuity_class": { "const": "authoritative_provenance_irreplaceable" },
              "rebuild_inputs_required": {
                "type": "array",
                "minItems": 1,
                "maxItems": 1,
                "items": { "const": "no_input_authoritative_state" }
              }
            }
          }
        },
        {
          "description": "Dangerous-to-delete summary requires authoritative no-rebuild cost.",
          "if": {
            "properties": { "rebuild_safety_summary_class": { "const": "dangerous_to_delete_authoritative" } },
            "required": ["rebuild_safety_summary_class"]
          },
          "then": {
            "properties": {
              "rebuild_cost_class": { "const": "authoritative_no_rebuild" },
              "offline_rebuild_risk_class": { "const": "not_rebuildable_after_removal" },
              "startup_impact_class": { "const": "not_applicable_authoritative_state" },
              "provenance_continuity_class": { "const": "authoritative_provenance_irreplaceable" }
            }
          }
        },
        {
          "description": "Cheap-to-rebuild summary requires safe-offline risk, low-impact startup, preserved-from-local-truth or no-provenance continuity, and a low / medium rebuild cost.",
          "if": {
            "properties": { "rebuild_safety_summary_class": { "const": "cheap_to_rebuild_safe_to_remove" } },
            "required": ["rebuild_safety_summary_class"]
          },
          "then": {
            "properties": {
              "offline_rebuild_risk_class": { "const": "safe_to_remove_offline" },
              "startup_impact_class": {
                "enum": ["no_user_visible_impact", "slower_first_open_until_warm"]
              },
              "provenance_continuity_class": {
                "enum": [
                  "provenance_preserved_rebuild_from_local_truth",
                  "not_applicable_disposable_no_provenance"
                ]
              },
              "rebuild_cost_class": {
                "enum": ["low_rebuild_cost", "medium_rebuild_cost"]
              }
            }
          }
        },
        {
          "description": "Expensive-but-safe summary requires safe-offline or network-resync risk plus a slower-rebuild startup-impact class plus a preserved-provenance continuity class.",
          "if": {
            "properties": { "rebuild_safety_summary_class": { "const": "expensive_to_rebuild_but_safe" } },
            "required": ["rebuild_safety_summary_class"]
          },
          "then": {
            "properties": {
              "offline_rebuild_risk_class": {
                "enum": [
                  "safe_to_remove_offline",
                  "rebuild_requires_network_resync"
                ]
              },
              "startup_impact_class": {
                "enum": [
                  "slower_first_query_until_reindexed",
                  "slower_first_build_until_prebuilt",
                  "slower_first_open_until_warm"
                ]
              },
              "provenance_continuity_class": {
                "enum": [
                  "provenance_preserved_rebuild_from_local_truth",
                  "provenance_preserved_rebuild_from_signed_source"
                ]
              },
              "rebuild_cost_class": {
                "enum": ["medium_rebuild_cost", "high_rebuild_cost"]
              }
            }
          }
        },
        {
          "description": "Impossible-to-rebuild-offline summary requires a mirror or signed-pack offline-risk class.",
          "if": {
            "properties": { "rebuild_safety_summary_class": { "const": "impossible_to_rebuild_offline" } },
            "required": ["rebuild_safety_summary_class"]
          },
          "then": {
            "properties": {
              "offline_rebuild_risk_class": {
                "enum": [
                  "rebuild_requires_mirror_or_offline_bundle",
                  "rebuild_requires_admin_or_policy_signed_pack"
                ]
              },
              "startup_impact_class": {
                "enum": [
                  "slower_first_query_until_reindexed",
                  "slower_first_build_until_prebuilt",
                  "feature_unavailable_until_rebuilt"
                ]
              },
              "provenance_continuity_class": {
                "enum": [
                  "provenance_preserved_rebuild_from_signed_source",
                  "provenance_breaks_until_resigned_or_re_imported"
                ]
              },
              "rebuild_cost_class": {
                "enum": ["high_rebuild_cost", "medium_rebuild_cost"]
              }
            }
          }
        },
        {
          "description": "Authoritative no-input rebuild list cannot mix non-authoritative inputs.",
          "if": {
            "properties": {
              "rebuild_inputs_required": {
                "type": "array",
                "contains": { "const": "no_input_authoritative_state" }
              }
            },
            "required": ["rebuild_inputs_required"]
          },
          "then": {
            "properties": {
              "rebuild_inputs_required": {
                "type": "array",
                "minItems": 1,
                "maxItems": 1,
                "items": { "const": "no_input_authoritative_state" }
              },
              "rebuild_cost_class": { "const": "authoritative_no_rebuild" }
            }
          }
        }
      ]
    },
    "workspace_storage_detail_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "workspace_storage_detail_row_schema_version",
        "row_id",
        "card_id_ref",
        "breakdown_row_id_ref",
        "detail_scope",
        "storage_class_id",
        "entry_class",
        "entry_ref",
        "entry_label",
        "size_bytes",
        "last_used_at",
        "rebuild_cost_hint",
        "authority_class",
        "detail_authority_posture_class",
        "mirror_or_import_origin_class",
        "sensitivity_class",
        "freshness_state",
        "corruption_state",
        "policy_protection_state",
        "pin_state",
        "pin_source_breakdown",
        "clear_cache_protection_class",
        "clear_action",
        "export_action",
        "inspect_only_open_action",
        "redaction_class",
        "export_safe",
        "note"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "type": "string", "const": "workspace_storage_detail_row_record" },
        "workspace_storage_detail_row_schema_version": { "$ref": "#/$defs/workspace_storage_detail_row_schema_version" },
        "row_id": { "$ref": "#/$defs/opaque_id" },
        "card_id_ref": { "$ref": "#/$defs/opaque_id" },
        "breakdown_row_id_ref": { "$ref": "#/$defs/opaque_id" },
        "detail_scope": { "$ref": "#/$defs/detail_scope" },
        "storage_class_id": { "$ref": "#/$defs/storage_class_id" },
        "entry_class": { "$ref": "#/$defs/entry_class" },
        "entry_ref": { "$ref": "#/$defs/opaque_id" },
        "entry_label": { "$ref": "#/$defs/reviewable_label" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "last_used_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/monotonic_timestamp" }
          ],
          "description": "Last-used timestamp from a producer-local monotonic clock. Required null when freshness_state is unknown_no_scan_yet or not_applicable_no_freshness_signal; required non-null otherwise."
        },
        "rebuild_cost_hint": { "$ref": "#/$defs/rebuild_cost_hint_record" },
        "authority_class": { "$ref": "#/$defs/authority_class" },
        "detail_authority_posture_class": { "$ref": "#/$defs/detail_authority_posture_class" },
        "mirror_or_import_origin_class": { "$ref": "#/$defs/mirror_or_import_origin_class" },
        "mirror_offline_artifact_row_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Opaque ref into a mirror_offline_artifact_row_record (deployment summary contract). Required non-null when mirror_or_import_origin_class is mirrored_copy / offline_bundle_local / vendor_signed_offline_local / customer_signed_mirror_local; required null otherwise."
        },
        "sensitivity_class": { "$ref": "#/$defs/sensitivity_class" },
        "freshness_state": { "$ref": "#/$defs/freshness_state_class" },
        "corruption_state": { "$ref": "#/$defs/corruption_state_class" },
        "policy_protection_state": { "$ref": "#/$defs/policy_protection_state_class" },
        "pin_state": { "$ref": "#/$defs/pin_state_class" },
        "pin_source_breakdown": {
          "type": "array",
          "items": { "$ref": "#/$defs/pin_source_breakdown_row" },
          "description": "Required non-empty whenever pin_state is anything other than unpinned_no_sources or not_applicable_authoritative_state."
        },
        "clear_cache_protection_class": { "$ref": "#/$defs/clear_cache_protection_class" },
        "clear_action": { "$ref": "#/$defs/clear_action_class" },
        "export_action": { "$ref": "#/$defs/export_action_class" },
        "inspect_only_open_action": { "$ref": "#/$defs/inspect_only_open_action" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "export_safe": { "type": "boolean" },
        "note": { "$ref": "#/$defs/reviewable_sentence" },
        "linked_clear_cache_preview_ref": { "$ref": "#/$defs/opaque_id" },
        "linked_class_specific_review_ref": { "$ref": "#/$defs/opaque_id" },
        "linked_pin_manager_route_ref": { "$ref": "#/$defs/opaque_id" },
        "linked_low_disk_drill_ref": { "$ref": "#/$defs/opaque_id" },
        "linked_deployment_summary_card_ref": { "$ref": "#/$defs/opaque_id" },
        "linked_corruption_rescue_ref": { "$ref": "#/$defs/opaque_id" }
      },
      "allOf": [
        {
          "description": "user_authored_durable_truth authority is never registered as a workspace-storage detail row (those bytes route through the profile/state-map storage path).",
          "not": {
            "properties": {
              "authority_class": { "const": "user_authored_durable_truth" }
            },
            "required": ["authority_class"]
          }
        },
        {
          "description": "user_owned_recovery_state class binds authoritative_user_owned_state posture, protected_never_generic_clear protection, the authoritative pin / clear / export actions, and the class-specific review link.",
          "if": {
            "properties": { "storage_class_id": { "const": "user_owned_recovery_state" } },
            "required": ["storage_class_id"]
          },
          "then": {
            "properties": {
              "authority_class": { "const": "user_owned_recovery_state" },
              "detail_authority_posture_class": { "const": "authoritative_user_owned_state" },
              "clear_cache_protection_class": { "const": "protected_never_generic_clear" },
              "policy_protection_state": { "const": "protected_user_owned_authoritative" },
              "pin_state": { "const": "not_applicable_authoritative_state" },
              "clear_action": { "const": "clear_refused_authoritative_user_owned" },
              "export_action": {
                "enum": ["export_required_before_clear", "export_offered_metadata_safe", "export_offered_operator_only"]
              },
              "mirror_or_import_origin_class": { "const": "local_authoritative" }
            },
            "required": ["linked_class_specific_review_ref"]
          }
        },
        {
          "description": "evidence_support_cache class binds policy_held_evidence_state posture, protected_requires_class_specific_review protection, and the class-specific review link.",
          "if": {
            "properties": { "storage_class_id": { "const": "evidence_support_cache" } },
            "required": ["storage_class_id"]
          },
          "then": {
            "properties": {
              "detail_authority_posture_class": { "const": "policy_held_evidence_state" },
              "clear_cache_protection_class": { "const": "protected_requires_class_specific_review" },
              "clear_action": { "const": "clear_requires_class_specific_review" },
              "policy_protection_state": {
                "enum": [
                  "protected_evidence_case_or_review",
                  "protected_retention_window",
                  "protected_admin_policy_pin",
                  "protected_tenant_policy_pin"
                ]
              },
              "authority_class": {
                "enum": ["admin_or_control_artifact", "user_owned_recovery_state"]
              }
            },
            "required": ["linked_class_specific_review_ref"]
          }
        },
        {
          "description": "Authoritative_user_owned_state posture binds the user_owned_recovery_state class.",
          "if": {
            "properties": { "detail_authority_posture_class": { "const": "authoritative_user_owned_state" } },
            "required": ["detail_authority_posture_class"]
          },
          "then": {
            "properties": {
              "storage_class_id": { "const": "user_owned_recovery_state" }
            }
          }
        },
        {
          "description": "Policy_held_evidence_state posture binds the evidence_support_cache class.",
          "if": {
            "properties": { "detail_authority_posture_class": { "const": "policy_held_evidence_state" } },
            "required": ["detail_authority_posture_class"]
          },
          "then": {
            "properties": {
              "storage_class_id": { "const": "evidence_support_cache" }
            }
          }
        },
        {
          "description": "Imported_durable_artifact posture binds a mirror / offline-bundle / policy-protected origin class and forbids generic_clear_always_allowed protection.",
          "if": {
            "properties": { "detail_authority_posture_class": { "const": "imported_durable_artifact" } },
            "required": ["detail_authority_posture_class"]
          },
          "then": {
            "properties": {
              "mirror_or_import_origin_class": {
                "enum": [
                  "mirrored_copy",
                  "offline_bundle_local",
                  "vendor_signed_offline_local",
                  "customer_signed_mirror_local",
                  "policy_protected_admin_artifact"
                ]
              },
              "clear_cache_protection_class": {
                "not": { "const": "generic_clear_always_allowed" }
              }
            }
          }
        },
        {
          "description": "Disposable_derived_state posture binds the disposable_derived_cache authority class and admits only local-disposable-cache origin.",
          "if": {
            "properties": { "detail_authority_posture_class": { "const": "disposable_derived_state" } },
            "required": ["detail_authority_posture_class"]
          },
          "then": {
            "properties": {
              "authority_class": { "const": "disposable_derived_cache" },
              "mirror_or_import_origin_class": { "const": "local_disposable_cache" }
            }
          }
        },
        {
          "description": "Correctness_relevant_derived_state posture binds the disposable_derived_cache authority class and admits local-disposable-cache origin only.",
          "if": {
            "properties": { "detail_authority_posture_class": { "const": "correctness_relevant_derived_state" } },
            "required": ["detail_authority_posture_class"]
          },
          "then": {
            "properties": {
              "authority_class": { "const": "disposable_derived_cache" },
              "mirror_or_import_origin_class": { "const": "local_disposable_cache" }
            }
          }
        },
        {
          "description": "Mirror or offline-bundle origin requires a non-null mirror_offline_artifact_row_ref and forbids generic_clear_always_allowed protection.",
          "if": {
            "properties": {
              "mirror_or_import_origin_class": {
                "enum": [
                  "mirrored_copy",
                  "offline_bundle_local",
                  "vendor_signed_offline_local",
                  "customer_signed_mirror_local"
                ]
              }
            },
            "required": ["mirror_or_import_origin_class"]
          },
          "then": {
            "properties": {
              "mirror_offline_artifact_row_ref": { "not": { "type": "null" } },
              "clear_cache_protection_class": {
                "not": { "const": "generic_clear_always_allowed" }
              }
            },
            "required": ["mirror_offline_artifact_row_ref"]
          }
        },
        {
          "description": "Non-mirror origins carry a null mirror_offline_artifact_row_ref.",
          "if": {
            "properties": {
              "mirror_or_import_origin_class": {
                "enum": [
                  "local_authoritative",
                  "local_disposable_cache",
                  "local_evidence_capture",
                  "policy_protected_admin_artifact",
                  "not_applicable"
                ]
              }
            },
            "required": ["mirror_or_import_origin_class"]
          },
          "then": {
            "properties": {
              "mirror_offline_artifact_row_ref": { "type": "null" }
            }
          }
        },
        {
          "description": "Local_authoritative origin pairs only with user_owned_recovery_state class.",
          "if": {
            "properties": { "mirror_or_import_origin_class": { "const": "local_authoritative" } },
            "required": ["mirror_or_import_origin_class"]
          },
          "then": {
            "properties": {
              "storage_class_id": { "const": "user_owned_recovery_state" }
            }
          }
        },
        {
          "description": "Local_evidence_capture origin pairs only with evidence_support_cache class.",
          "if": {
            "properties": { "mirror_or_import_origin_class": { "const": "local_evidence_capture" } },
            "required": ["mirror_or_import_origin_class"]
          },
          "then": {
            "properties": {
              "storage_class_id": { "const": "evidence_support_cache" }
            }
          }
        },
        {
          "description": "Pinned-state classes require a non-empty pin_source_breakdown.",
          "if": {
            "properties": {
              "pin_state": {
                "enum": [
                  "pinned_user_only",
                  "pinned_admin_or_tenant_policy_only",
                  "pinned_release_or_offline_bundle_only",
                  "pinned_evidence_case_or_review_only",
                  "pinned_retention_window_only",
                  "pinned_multiple_classes"
                ]
              }
            },
            "required": ["pin_state"]
          },
          "then": {
            "properties": {
              "pin_source_breakdown": { "type": "array", "minItems": 1 }
            }
          }
        },
        {
          "description": "Unpinned or not-applicable pin states carry an empty pin_source_breakdown.",
          "if": {
            "properties": {
              "pin_state": {
                "enum": ["unpinned_no_sources", "not_applicable_authoritative_state"]
              }
            },
            "required": ["pin_state"]
          },
          "then": {
            "properties": {
              "pin_source_breakdown": { "type": "array", "maxItems": 0 }
            }
          }
        },
        {
          "description": "clear_admissible_generic clear-action requires generic_clear_always_allowed protection plus unpinned state plus disposable derived authority.",
          "if": {
            "properties": { "clear_action": { "const": "clear_admissible_generic" } },
            "required": ["clear_action"]
          },
          "then": {
            "properties": {
              "clear_cache_protection_class": { "const": "generic_clear_always_allowed" },
              "pin_state": { "const": "unpinned_no_sources" },
              "authority_class": { "const": "disposable_derived_cache" }
            }
          }
        },
        {
          "description": "clear_admissible_after_pin_release clear-action requires generic_clear_with_pin_exclusions protection plus a pinned state.",
          "if": {
            "properties": { "clear_action": { "const": "clear_admissible_after_pin_release" } },
            "required": ["clear_action"]
          },
          "then": {
            "properties": {
              "clear_cache_protection_class": { "const": "generic_clear_with_pin_exclusions" },
              "pin_state": {
                "enum": [
                  "pinned_user_only",
                  "pinned_admin_or_tenant_policy_only",
                  "pinned_release_or_offline_bundle_only",
                  "pinned_evidence_case_or_review_only",
                  "pinned_retention_window_only",
                  "pinned_multiple_classes"
                ]
              }
            }
          }
        },
        {
          "description": "clear_requires_class_specific_review clear-action requires evidence_support_cache class.",
          "if": {
            "properties": { "clear_action": { "const": "clear_requires_class_specific_review" } },
            "required": ["clear_action"]
          },
          "then": {
            "properties": {
              "storage_class_id": { "const": "evidence_support_cache" }
            },
            "required": ["linked_class_specific_review_ref"]
          }
        },
        {
          "description": "clear_refused_authoritative_user_owned clear-action requires user_owned_recovery_state class.",
          "if": {
            "properties": { "clear_action": { "const": "clear_refused_authoritative_user_owned" } },
            "required": ["clear_action"]
          },
          "then": {
            "properties": {
              "storage_class_id": { "const": "user_owned_recovery_state" }
            },
            "required": ["linked_class_specific_review_ref"]
          }
        },
        {
          "description": "clear_refused_policy_held clear-action requires a policy-protected protection / origin posture.",
          "if": {
            "properties": { "clear_action": { "const": "clear_refused_policy_held" } },
            "required": ["clear_action"]
          },
          "then": {
            "properties": {
              "policy_protection_state": {
                "enum": [
                  "protected_admin_policy_pin",
                  "protected_tenant_policy_pin",
                  "protected_retention_window"
                ]
              },
              "clear_cache_protection_class": {
                "enum": [
                  "generic_clear_with_pin_exclusions",
                  "protected_requires_class_specific_review",
                  "protected_never_generic_clear"
                ]
              }
            }
          }
        },
        {
          "description": "export_required_before_clear export-action requires authoritative_no_rebuild rebuild cost so a non-authoritative entry cannot be falsely escalated to export-before-clear.",
          "if": {
            "properties": { "export_action": { "const": "export_required_before_clear" } },
            "required": ["export_action"]
          },
          "then": {
            "properties": {
              "rebuild_cost_hint": {
                "properties": {
                  "rebuild_cost_class": { "const": "authoritative_no_rebuild" }
                },
                "required": ["rebuild_cost_class"]
              }
            }
          }
        },
        {
          "description": "export_unsupported_already_local_only_disposable export-action requires disposable_derived_cache authority.",
          "if": {
            "properties": { "export_action": { "const": "export_unsupported_already_local_only_disposable" } },
            "required": ["export_action"]
          },
          "then": {
            "properties": {
              "authority_class": { "const": "disposable_derived_cache" }
            }
          }
        },
        {
          "description": "Sensitivity t3 is admissible only on evidence_support_cache rows.",
          "if": {
            "properties": { "sensitivity_class": { "const": "t3_secret_adjacent_not_reusable_cache" } },
            "required": ["sensitivity_class"]
          },
          "then": {
            "properties": {
              "storage_class_id": { "const": "evidence_support_cache" }
            }
          }
        },
        {
          "description": "Confirmed-corrupt rows MUST link the corruption-rescue path so the surface can route the user to inspect / rebuild / replace.",
          "if": {
            "properties": {
              "corruption_state": {
                "enum": [
                  "confirmed_corrupt_quarantined",
                  "confirmed_corrupt_pending_rebuild_or_replace"
                ]
              }
            },
            "required": ["corruption_state"]
          },
          "then": {
            "required": ["linked_corruption_rescue_ref"]
          }
        },
        {
          "description": "Unknown-no-scan-yet or not-applicable freshness states carry a null last_used_at; every other freshness state carries a non-null timestamp.",
          "if": {
            "properties": {
              "freshness_state": {
                "enum": ["unknown_no_scan_yet", "not_applicable_no_freshness_signal"]
              }
            },
            "required": ["freshness_state"]
          },
          "then": {
            "properties": {
              "last_used_at": { "type": "null" }
            }
          },
          "else": {
            "properties": {
              "last_used_at": { "not": { "type": "null" } }
            }
          }
        },
        {
          "description": "Exported rows preserve redaction; widening to internal_support_restricted or signing_evidence_only is non-conforming.",
          "if": {
            "properties": { "export_safe": { "const": true } },
            "required": ["export_safe"]
          },
          "then": {
            "properties": {
              "redaction_class": {
                "enum": ["metadata_safe_default", "operator_only_restricted"]
              }
            }
          }
        },
        {
          "description": "Authoritative rebuild-cost rows force the dangerous-to-delete summary class on the embedded rebuild_cost_hint.",
          "if": {
            "properties": {
              "storage_class_id": {
                "enum": ["user_owned_recovery_state"]
              }
            },
            "required": ["storage_class_id"]
          },
          "then": {
            "properties": {
              "rebuild_cost_hint": {
                "properties": {
                  "rebuild_safety_summary_class": { "const": "dangerous_to_delete_authoritative" }
                },
                "required": ["rebuild_safety_summary_class"]
              }
            }
          }
        }
      ]
    }
  }
}
