{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/data/certify-api-database-and-browser-runtime-workflows-with-mutation-redaction-and-scale-drills.schema.json",
  "title": "Aureline API, database, and browser-runtime workflow certification with mutation, redaction, and scale drills packet",
  "description": "Boundary schema for certification qualification records covering API workflows, database workflows, and browser-runtime workflows with mutation drills, redaction drills, and scale drills. Raw secrets, raw credentials, raw connection strings, and unbounded result sets do not appear in this packet; payloads require explicit drill-down or export review.",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "as_of",
    "release_doc_ref",
    "help_doc_ref",
    "schema_ref",
    "surfaces",
    "mutation_drills",
    "redaction_drills",
    "scale_drills",
    "upstream_packet_refs",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "certify_api_database_and_browser_runtime_workflows_with_mutation_redaction_and_scale_drills" },
    "packet_id": { "$ref": "#/$defs/opaque_id" },
    "as_of": { "type": "string", "format": "date" },
    "release_doc_ref": { "$ref": "#/$defs/path_ref" },
    "help_doc_ref": { "$ref": "#/$defs/path_ref" },
    "schema_ref": { "$ref": "#/$defs/path_ref" },
    "surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/certification_surface_qualification_row" }
    },
    "mutation_drills": {
      "type": "array",
      "items": { "$ref": "#/$defs/mutation_drill_row" }
    },
    "redaction_drills": {
      "type": "array",
      "items": { "$ref": "#/$defs/redaction_drill_row" }
    },
    "scale_drills": {
      "type": "array",
      "items": { "$ref": "#/$defs/scale_drill_row" }
    },
    "upstream_packet_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/upstream_packet_ref_row" }
    },
    "summary": { "$ref": "#/$defs/certification_qualification_summary" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "path_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "reviewable": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },
    "certification_qualification_label": {
      "type": "string",
      "enum": ["stable", "preview", "labs", "inspect_only", "import_only"]
    },
    "certification_surface_kind": {
      "type": "string",
      "enum": [
        "api_workflow_certification",
        "database_workflow_certification",
        "browser_runtime_certification",
        "mutation_drill",
        "redaction_drill",
        "scale_drill"
      ]
    },
    "mutation_drill_class": {
      "type": "string",
      "enum": [
        "preview_required",
        "confirmation_required",
        "rollback_path_visible",
        "write_posture_explicit",
        "step_up_flow_completed"
      ]
    },
    "redaction_drill_class": {
      "type": "string",
      "enum": [
        "auth_source_redacted",
        "secret_safe_storage",
        "export_redaction_applied",
        "support_bundle_safe",
        "history_redacted"
      ]
    },
    "scale_drill_class": {
      "type": "string",
      "enum": [
        "row_count_bounded",
        "result_set_limited",
        "virtualization_active",
        "timeout_enforced",
        "memory_cap_enforced"
      ]
    },
    "certification_qualification_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at", "evidence_refs"],
      "properties": {
        "packet_id": { "type": "string" },
        "packet_ref": { "type": "string" },
        "proof_index_ref": { "type": "string" },
        "captured_at": { "type": "string" },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "certification_surface_guard_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "api_workflow_visible",
        "database_workflow_visible",
        "browser_runtime_visible",
        "mutation_drill_visible",
        "redaction_drill_visible",
        "scale_drill_visible",
        "upstream_packet_refs_visible",
        "downgrade_rules_visible"
      ],
      "properties": {
        "api_workflow_visible": { "type": "boolean" },
        "database_workflow_visible": { "type": "boolean" },
        "browser_runtime_visible": { "type": "boolean" },
        "mutation_drill_visible": { "type": "boolean" },
        "redaction_drill_visible": { "type": "boolean" },
        "scale_drill_visible": { "type": "boolean" },
        "upstream_packet_refs_visible": { "type": "boolean" },
        "downgrade_rules_visible": { "type": "boolean" }
      }
    },
    "certification_surface_qualification_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "qualification_packet",
        "guards",
        "downgrade_if_missing",
        "rationale"
      ],
      "properties": {
        "surface_id": { "type": "string" },
        "title": { "type": "string" },
        "surface_kind": { "$ref": "#/$defs/certification_surface_kind" },
        "promoted_build_surface": { "type": "boolean" },
        "claim_label": { "$ref": "#/$defs/certification_qualification_label" },
        "displayed_label": { "$ref": "#/$defs/certification_qualification_label" },
        "qualification_packet": { "oneOf": [{ "$ref": "#/$defs/certification_qualification_proof" }, { "type": "null" }] },
        "guards": { "$ref": "#/$defs/certification_surface_guard_set" },
        "downgrade_if_missing": { "type": "boolean" },
        "rationale": { "type": "string" }
      }
    },
    "mutation_drill_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["drill_id", "drill_class", "target_surface_kind", "pass", "rationale"],
      "properties": {
        "drill_id": { "type": "string" },
        "drill_class": { "$ref": "#/$defs/mutation_drill_class" },
        "target_surface_kind": { "$ref": "#/$defs/certification_surface_kind" },
        "pass": { "type": "boolean" },
        "rationale": { "type": "string" }
      }
    },
    "redaction_drill_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["drill_id", "drill_class", "target_surface_kind", "pass", "rationale"],
      "properties": {
        "drill_id": { "type": "string" },
        "drill_class": { "$ref": "#/$defs/redaction_drill_class" },
        "target_surface_kind": { "$ref": "#/$defs/certification_surface_kind" },
        "pass": { "type": "boolean" },
        "rationale": { "type": "string" }
      }
    },
    "scale_drill_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["drill_id", "drill_class", "target_surface_kind", "pass", "rationale"],
      "properties": {
        "drill_id": { "type": "string" },
        "drill_class": { "$ref": "#/$defs/scale_drill_class" },
        "target_surface_kind": { "$ref": "#/$defs/certification_surface_kind" },
        "pass": { "type": "boolean" },
        "rationale": { "type": "string" }
      }
    },
    "upstream_packet_ref_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_id", "upstream_record_kind", "upstream_packet_path", "upstream_schema_path", "integration_verified", "rationale"],
      "properties": {
        "ref_id": { "type": "string" },
        "upstream_record_kind": { "type": "string" },
        "upstream_packet_path": { "type": "string" },
        "upstream_schema_path": { "type": "string" },
        "integration_verified": { "type": "boolean" },
        "rationale": { "type": "string" }
      }
    },
    "certification_qualification_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promoted_surface_count",
        "stable_surface_count",
        "narrowed_surface_count",
        "mutation_drill_count",
        "redaction_drill_count",
        "scale_drill_count",
        "upstream_packet_ref_count",
        "integration_pass_count"
      ],
      "properties": {
        "promoted_surface_count": { "type": "integer", "minimum": 0 },
        "stable_surface_count": { "type": "integer", "minimum": 0 },
        "narrowed_surface_count": { "type": "integer", "minimum": 0 },
        "mutation_drill_count": { "type": "integer", "minimum": 0 },
        "redaction_drill_count": { "type": "integer", "minimum": 0 },
        "scale_drill_count": { "type": "integer", "minimum": 0 },
        "upstream_packet_ref_count": { "type": "integer", "minimum": 0 },
        "integration_pass_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
