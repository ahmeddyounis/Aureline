{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/data/add-the-statement-safety-classifier-write-mode-bar-and-protected-target-step-up-flows.schema.json",
  "title": "Aureline statement-safety classifier, write-mode bar, and protected-target step-up flow qualification boundary",
  "description": "Boundary schema for the statement-safety classifier, write-mode bar, and protected-target step-up flow qualification packet frozen in docs/data/m5/add-the-statement-safety-classifier-write-mode-bar-and-protected-target-step-up-flows.md. Every database tool surface that admits, blocks, or annotates a statement emits exactly one qualification packet per promoted build. The packet carries opaque statement refs, typed enum values, integer-bucket counts, and reviewable sentences only. Raw statement bodies, raw template texts, raw user-supplied literals, raw object names that disclose tenant identity, and raw bind values never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "as_of",
    "release_doc_ref",
    "help_doc_ref",
    "schema_ref",
    "surfaces",
    "classifiers",
    "write_mode_bars",
    "protected_target_step_ups",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "add_the_statement_safety_classifier_write_mode_bar_and_protected_target_step_up_flows"
    },
    "packet_id": {
      "$ref": "#/$defs/opaque_id"
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "release_doc_ref": {
      "type": "string",
      "minLength": 1
    },
    "help_doc_ref": {
      "type": "string",
      "minLength": 1
    },
    "schema_ref": {
      "type": "string",
      "minLength": 1
    },
    "surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_qualification_row" }
    },
    "classifiers": {
      "type": "array",
      "items": { "$ref": "#/$defs/statement_safety_classifier_row" }
    },
    "write_mode_bars": {
      "type": "array",
      "items": { "$ref": "#/$defs/write_mode_bar_row" }
    },
    "protected_target_step_ups": {
      "type": "array",
      "items": { "$ref": "#/$defs/protected_target_step_up_row" }
    },
    "summary": {
      "$ref": "#/$defs/qualification_summary"
    }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$",
      "description": "Opaque, stable, snake_case-safe id. Raw URLs, raw absolute paths, raw user names, raw secret bytes, raw statement bodies, and raw bind-value bytes never appear here."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480,
      "description": "Short, reviewable sentence safe for banners, admin exports, and support packets. Raw statement bodies, raw bind values, and raw secret material MUST NOT appear."
    },
    "qualification_label": {
      "type": "string",
      "enum": [
        "stable",
        "preview",
        "labs",
        "inspect_only",
        "import_only"
      ]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "statement_safety_classifier",
        "write_mode_bar",
        "protected_target_step_up"
      ]
    },
    "statement_safety_class": {
      "type": "string",
      "enum": [
        "read_only_query",
        "read_only_pure_metadata_introspection",
        "data_manipulation_insert",
        "data_manipulation_update",
        "data_manipulation_delete",
        "data_manipulation_merge_or_upsert",
        "data_definition_create",
        "data_definition_alter",
        "data_definition_drop",
        "data_definition_truncate",
        "data_control_grant_or_revoke",
        "session_setting_change",
        "transaction_control_statement",
        "explain_or_plan_only_no_execution",
        "stored_procedure_or_function_call_unknown_side_effects",
        "multi_statement_script_mixed_classes",
        "ambiguous_class_user_review_required",
        "blocked_class_not_admissible_on_this_connection"
      ]
    },
    "transaction_context_class": {
      "type": "string",
      "enum": [
        "implicit_autocommit_no_transaction",
        "explicit_transaction_open",
        "savepoint_within_transaction",
        "transaction_will_open_for_this_statement",
        "transaction_will_commit_after_this_statement",
        "transaction_will_rollback_after_this_statement",
        "transaction_context_unknown_requires_review",
        "transaction_context_not_applicable_explain_only"
      ]
    },
    "object_impact_class": {
      "type": "string",
      "enum": [
        "no_object_impact_read_only",
        "rows_only_no_schema_change",
        "schema_change_table_or_view",
        "schema_change_index_or_constraint",
        "schema_change_role_or_grant",
        "schema_change_extension_or_database",
        "object_impact_unknown_requires_review",
        "object_impact_not_applicable_explain_only"
      ]
    },
    "multi_statement_posture_class": {
      "type": "string",
      "enum": [
        "single_statement",
        "multi_statement_script_homogeneous_read_only",
        "multi_statement_script_homogeneous_dml",
        "multi_statement_script_homogeneous_ddl",
        "multi_statement_script_mixed_classes",
        "multi_statement_script_unknown_requires_review"
      ]
    },
    "ambiguity_reason_class": {
      "type": "string",
      "enum": [
        "no_ambiguity_classification_confident",
        "dialect_specific_construct_unparsed",
        "dynamic_sql_or_string_concatenation_observed",
        "stored_procedure_body_not_visible_to_classifier",
        "user_defined_function_with_unknown_side_effects",
        "comment_only_or_empty_payload",
        "ambiguity_reason_unknown_requires_review"
      ]
    },
    "blocked_reason_class": {
      "type": "string",
      "enum": [
        "not_blocked_admissible",
        "blocked_write_on_read_only_connection",
        "blocked_destructive_ddl_without_consent_ticket",
        "blocked_truncate_or_drop_on_production_blast_radius_high",
        "blocked_grant_or_revoke_outside_admin_console",
        "blocked_session_setting_change_locked_by_policy",
        "blocked_multi_statement_mixed_classes_without_user_admit",
        "blocked_pending_workspace_trust",
        "blocked_pending_policy",
        "blocked_unknown_classification_requires_user_review"
      ]
    },
    "step_up_kind": {
      "type": "string",
      "enum": [
        "platform_authenticator",
        "system_browser_reauth",
        "enterprise_mfa",
        "local_session_password",
        "admin_override_ticket"
      ]
    },
    "step_up_state": {
      "type": "string",
      "enum": [
        "not_required",
        "required_pending",
        "in_progress",
        "satisfied",
        "denied",
        "blocked_by_policy"
      ]
    },
    "write_posture": {
      "type": "string",
      "enum": [
        "read_only",
        "write_capable",
        "policy_blocked"
      ]
    },
    "execution_origin": {
      "type": "string",
      "enum": [
        "desktop_sql_editor",
        "cli_runner",
        "ai_tool_review_surface",
        "automation_run_review_surface",
        "extension_host_runner",
        "support_export_reader",
        "admin_audit_reader",
        "hosted_review_reader"
      ]
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "captured_at",
        "evidence_refs"
      ],
      "properties": {
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "packet_ref": { "type": "string", "minLength": 1 },
        "proof_index_ref": { "type": "string", "minLength": 1 },
        "captured_at": { "type": "string", "format": "date" },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "surface_guard_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement_safety_visible",
        "transaction_context_visible",
        "write_posture_visible",
        "object_impact_visible",
        "multi_statement_posture_visible",
        "ambiguity_reason_visible",
        "blocked_reason_visible",
        "step_up_state_visible",
        "consent_ticket_visible"
      ],
      "properties": {
        "statement_safety_visible": { "type": "boolean" },
        "transaction_context_visible": { "type": "boolean" },
        "write_posture_visible": { "type": "boolean" },
        "object_impact_visible": { "type": "boolean" },
        "multi_statement_posture_visible": { "type": "boolean" },
        "ambiguity_reason_visible": { "type": "boolean" },
        "blocked_reason_visible": { "type": "boolean" },
        "step_up_state_visible": { "type": "boolean" },
        "consent_ticket_visible": { "type": "boolean" }
      }
    },
    "surface_qualification_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "guards",
        "downgrade_if_missing",
        "rationale"
      ],
      "properties": {
        "surface_id": { "$ref": "#/$defs/opaque_id" },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "promoted_build_surface": { "type": "boolean" },
        "claim_label": { "$ref": "#/$defs/qualification_label" },
        "displayed_label": { "$ref": "#/$defs/qualification_label" },
        "qualification_packet": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/proof_packet" }
          ]
        },
        "guards": { "$ref": "#/$defs/surface_guard_set" },
        "downgrade_if_missing": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "per_statement_class_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordinal",
        "statement_safety_class"
      ],
      "properties": {
        "ordinal": { "type": "integer", "minimum": 0 },
        "statement_safety_class": { "$ref": "#/$defs/statement_safety_class" },
        "object_impact_class": { "$ref": "#/$defs/object_impact_class" },
        "body_label_opaque_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "object_impact_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_impact_class",
        "affected_object_count_bucket"
      ],
      "properties": {
        "object_impact_class": { "$ref": "#/$defs/object_impact_class" },
        "affected_object_count_bucket": { "type": "integer", "minimum": 0 },
        "affected_object_label_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "row_estimate_bucket": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "string",
              "enum": [
                "row_estimate_unknown",
                "row_estimate_zero",
                "row_estimate_tens",
                "row_estimate_hundreds",
                "row_estimate_thousands",
                "row_estimate_tens_of_thousands",
                "row_estimate_hundreds_of_thousands_or_more"
              ]
            }
          ]
        },
        "object_impact_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "transaction_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transaction_context_class"
      ],
      "properties": {
        "transaction_context_class": { "$ref": "#/$defs/transaction_context_class" },
        "transaction_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "savepoint_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "transaction_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "statement_safety_classifier_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classifier_id",
        "execution_origin",
        "statement_safety_class",
        "multi_statement_posture_class",
        "per_statement_class_set",
        "transaction_context",
        "object_impact",
        "ambiguity_reason_class",
        "blocked_reason_class",
        "write_posture",
        "visible_in_ui"
      ],
      "properties": {
        "classifier_id": { "$ref": "#/$defs/opaque_id" },
        "execution_origin": { "$ref": "#/$defs/execution_origin" },
        "statement_safety_class": { "$ref": "#/$defs/statement_safety_class" },
        "multi_statement_posture_class": { "$ref": "#/$defs/multi_statement_posture_class" },
        "per_statement_class_set": {
          "type": "array",
          "items": { "$ref": "#/$defs/per_statement_class_descriptor" }
        },
        "transaction_context": { "$ref": "#/$defs/transaction_envelope" },
        "object_impact": { "$ref": "#/$defs/object_impact_envelope" },
        "ambiguity_reason_class": { "$ref": "#/$defs/ambiguity_reason_class" },
        "blocked_reason_class": { "$ref": "#/$defs/blocked_reason_class" },
        "write_posture": { "$ref": "#/$defs/write_posture" },
        "consent_ticket_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "body_label_opaque_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "visible_in_ui": { "type": "boolean" }
      }
    },
    "write_mode_bar_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bar_id",
        "transaction_context_class",
        "write_posture",
        "autocommit_risk_disclosed",
        "explicit_transaction_scope_shown",
        "rollback_posture_shown",
        "write_guarded_label_shown",
        "affected_schema_disclosed",
        "open_mutation_review_available",
        "visible_before_execution",
        "visible_in_ui"
      ],
      "properties": {
        "bar_id": { "$ref": "#/$defs/opaque_id" },
        "transaction_context_class": { "$ref": "#/$defs/transaction_context_class" },
        "write_posture": { "$ref": "#/$defs/write_posture" },
        "autocommit_risk_disclosed": { "type": "boolean" },
        "explicit_transaction_scope_shown": { "type": "boolean" },
        "rollback_posture_shown": { "type": "boolean" },
        "write_guarded_label_shown": { "type": "boolean" },
        "affected_schema_disclosed": { "type": "boolean" },
        "open_mutation_review_available": { "type": "boolean" },
        "visible_before_execution": { "type": "boolean" },
        "visible_in_ui": { "type": "boolean" }
      }
    },
    "protected_target_step_up_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_up_id",
        "step_up_kind",
        "step_up_state",
        "protected_target",
        "mutation_triggers_step_up",
        "destructive_ddl_triggers_step_up",
        "ambiguous_triggers_step_up",
        "multi_statement_mixed_triggers_step_up",
        "denies_action_not_session",
        "audit_events_emitted",
        "consent_ticket_required_for_destructive_ddl",
        "visible_in_ui"
      ],
      "properties": {
        "step_up_id": { "$ref": "#/$defs/opaque_id" },
        "step_up_kind": { "$ref": "#/$defs/step_up_kind" },
        "step_up_state": { "$ref": "#/$defs/step_up_state" },
        "protected_target": { "type": "boolean" },
        "mutation_triggers_step_up": { "type": "boolean" },
        "destructive_ddl_triggers_step_up": { "type": "boolean" },
        "ambiguous_triggers_step_up": { "type": "boolean" },
        "multi_statement_mixed_triggers_step_up": { "type": "boolean" },
        "denies_action_not_session": { "type": "boolean" },
        "audit_events_emitted": { "type": "boolean" },
        "consent_ticket_required_for_destructive_ddl": { "type": "boolean" },
        "visible_in_ui": { "type": "boolean" }
      }
    },
    "qualification_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promoted_surface_count",
        "stable_surface_count",
        "narrowed_surface_count",
        "classifier_row_count",
        "write_mode_bar_row_count",
        "protected_target_step_up_row_count"
      ],
      "properties": {
        "promoted_surface_count": { "type": "integer", "minimum": 0 },
        "stable_surface_count": { "type": "integer", "minimum": 0 },
        "narrowed_surface_count": { "type": "integer", "minimum": 0 },
        "classifier_row_count": { "type": "integer", "minimum": 0 },
        "write_mode_bar_row_count": { "type": "integer", "minimum": 0 },
        "protected_target_step_up_row_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
