{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/data/ship-result-grid-virtualization-typed-copy-or-export-filter-and-sort-state-and-row-count-boundary-truth.schema.json",
  "title": "Aureline result-grid virtualization, typed copy or export, filter and sort state, and row-count boundary truth packet",
  "description": "Boundary schema for result-grid virtualization, typed copy or export, filter and sort state, and row-count boundary truth qualification records. Raw row bodies, raw cell values, raw column-comment bodies, raw fully-qualified object names, and raw connection-string fragments do not appear in this packet.",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "as_of",
    "release_doc_ref",
    "help_doc_ref",
    "schema_ref",
    "surfaces",
    "result_grid_viewers",
    "typed_copy_actions",
    "typed_export_actions",
    "filter_sort_state_panels",
    "row_count_boundary_chips",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "ship_result_grid_virtualization_typed_copy_or_export_filter_and_sort_state_and_row_count_boundary_truth" },
    "packet_id": { "$ref": "#/$defs/opaque_id" },
    "as_of": { "type": "string", "format": "date" },
    "release_doc_ref": { "$ref": "#/$defs/path_ref" },
    "help_doc_ref": { "$ref": "#/$defs/path_ref" },
    "schema_ref": { "$ref": "#/$defs/path_ref" },
    "surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/result_grid_surface_qualification_row" }
    },
    "result_grid_viewers": {
      "type": "array",
      "items": { "$ref": "#/$defs/result_grid_viewer_row" }
    },
    "typed_copy_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/typed_copy_action_row" }
    },
    "typed_export_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/typed_export_action_row" }
    },
    "filter_sort_state_panels": {
      "type": "array",
      "items": { "$ref": "#/$defs/filter_sort_state_panel_row" }
    },
    "row_count_boundary_chips": {
      "type": "array",
      "items": { "$ref": "#/$defs/row_count_boundary_chip_row" }
    },
    "summary": { "$ref": "#/$defs/result_grid_qualification_summary" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "path_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "reviewable": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },
    "result_grid_qualification_label": {
      "type": "string",
      "enum": ["stable", "preview", "labs", "inspect_only", "import_only"]
    },
    "result_grid_surface_kind": {
      "type": "string",
      "enum": [
        "result_grid_viewer",
        "typed_copy_action",
        "typed_export_action",
        "filter_sort_state_panel",
        "row_count_boundary_chip"
      ]
    },
    "virtualization_posture_class": {
      "type": "string",
      "enum": [
        "inline_no_virtualization_small_result",
        "row_virtualized_columns_inline",
        "row_and_column_virtualized",
        "open_in_detail_for_large_cell",
        "blocked_active_content_in_cell",
        "textual_fallback_no_grid",
        "virtualization_posture_unknown_requires_review"
      ]
    },
    "truncation_state_class": {
      "type": "string",
      "enum": [
        "no_truncation_full_result_set",
        "row_truncated_user_admit_required_to_continue",
        "row_truncated_engine_capped",
        "row_truncated_provider_capped",
        "row_truncated_size_budget_capped",
        "row_truncated_time_budget_capped",
        "cell_truncated_open_in_detail",
        "result_set_paged_more_pages_available",
        "result_set_streaming_open_buffer",
        "result_set_streaming_buffer_dropped_oldest",
        "truncation_state_unknown_requires_review"
      ]
    },
    "truncation_reason_class": {
      "type": "string",
      "enum": [
        "no_truncation_reason_full_result",
        "user_row_limit_applied",
        "engine_max_rows_or_max_size_reached",
        "provider_quota_or_billing_cap_reached",
        "session_memory_budget_reached",
        "session_time_budget_reached",
        "viewer_inline_size_budget_reached",
        "blob_or_lob_size_budget_reached",
        "active_content_blocked_no_render",
        "schema_drift_partial_result_typed",
        "truncation_reason_unknown_requires_review"
      ]
    },
    "row_count_truth_class": {
      "type": "string",
      "enum": [
        "row_count_exact_total_known",
        "row_count_exact_returned_only_total_unknown",
        "row_count_estimate_engine_provided",
        "row_count_estimate_planner_provided",
        "row_count_unknown_streaming_in_flight",
        "row_count_truth_class_unknown_requires_review"
      ]
    },
    "export_posture_class": {
      "type": "string",
      "enum": [
        "export_admissible_full_result_typed",
        "export_admissible_visible_rows_only_typed",
        "export_admissible_visible_rows_only_textual_fallback",
        "export_blocked_pending_consent",
        "export_blocked_pending_policy",
        "export_blocked_redaction_class_too_high",
        "export_blocked_active_content_present",
        "export_blocked_provider_does_not_permit_export",
        "export_posture_unknown_requires_review"
      ]
    },
    "export_format_class": {
      "type": "string",
      "enum": [
        "csv_with_typed_header",
        "tsv_with_typed_header",
        "json_lines_typed",
        "json_array_typed",
        "parquet_typed",
        "arrow_ipc_typed",
        "sql_insert_script_typed",
        "markdown_table_textual_fallback",
        "html_table_textual_fallback",
        "clipboard_textual_fallback",
        "notebook_handoff_typed",
        "export_format_unknown_requires_review"
      ]
    },
    "type_coercion_state_class": {
      "type": "string",
      "enum": [
        "no_coercion_engine_typed_preserved",
        "lossless_coercion_documented",
        "lossy_coercion_explicit_user_choice",
        "lossy_coercion_textual_fallback_only",
        "coercion_blocked_for_high_redaction_class",
        "type_coercion_state_unknown_requires_review"
      ]
    },
    "notebook_handoff_state_class": {
      "type": "string",
      "enum": [
        "no_notebook_handoff",
        "notebook_handoff_proposed_pending_user_admit",
        "notebook_handoff_admitted_dataframe_typed",
        "notebook_handoff_admitted_textual_fallback_only",
        "notebook_handoff_blocked_pending_policy",
        "notebook_handoff_blocked_redaction_class_too_high",
        "notebook_handoff_unknown_requires_review"
      ]
    },
    "column_type_class": {
      "type": "string",
      "enum": [
        "boolean_logical",
        "integer_signed",
        "integer_unsigned",
        "decimal_or_numeric",
        "floating_point",
        "string_text",
        "string_bounded_varchar",
        "binary_bytes",
        "uuid_or_guid",
        "json_or_jsonb_document",
        "xml_document",
        "date_only",
        "time_only",
        "timestamp_no_timezone",
        "timestamp_with_timezone",
        "interval_or_duration",
        "geometry_or_geography",
        "array_of_typed_values",
        "user_defined_or_struct_record",
        "enum_named_value",
        "vector_embedding",
        "blob_or_lob_handle",
        "column_type_unknown_requires_review"
      ]
    },
    "column_provenance_class": {
      "type": "string",
      "enum": [
        "from_base_table_or_view",
        "from_subquery_or_cte",
        "computed_expression",
        "aggregate_or_window_function",
        "literal_constant",
        "engine_pseudo_column",
        "column_provenance_unknown_requires_review"
      ]
    },
    "filter_evaluation_locus": {
      "type": "string",
      "enum": [
        "engine_side_filter_pushed_down",
        "client_side_filter_over_returned_rows_only",
        "mixed_filter_locus_user_review_required",
        "filter_evaluation_locus_unknown_requires_review"
      ]
    },
    "result_grid_qualification_proof": {
      "type": "object",
      "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at", "evidence_refs"],
      "additionalProperties": false,
      "properties": {
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "packet_ref": { "$ref": "#/$defs/path_ref" },
        "proof_index_ref": { "$ref": "#/$defs/path_ref" },
        "captured_at": { "type": "string", "format": "date" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/path_ref" }
        }
      }
    },
    "result_grid_surface_guard_set": {
      "type": "object",
      "required": [
        "virtualization_posture_visible",
        "truncation_state_visible",
        "typed_copy_visible",
        "typed_export_visible",
        "filter_sort_state_visible",
        "row_count_truth_visible",
        "export_format_visible",
        "notebook_handoff_visible"
      ],
      "additionalProperties": false,
      "properties": {
        "virtualization_posture_visible": { "type": "boolean" },
        "truncation_state_visible": { "type": "boolean" },
        "typed_copy_visible": { "type": "boolean" },
        "typed_export_visible": { "type": "boolean" },
        "filter_sort_state_visible": { "type": "boolean" },
        "row_count_truth_visible": { "type": "boolean" },
        "export_format_visible": { "type": "boolean" },
        "notebook_handoff_visible": { "type": "boolean" }
      }
    },
    "result_grid_surface_qualification_row": {
      "type": "object",
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "qualification_packet",
        "guards",
        "downgrade_if_missing",
        "rationale"
      ],
      "additionalProperties": false,
      "properties": {
        "surface_id": { "$ref": "#/$defs/opaque_id" },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "surface_kind": { "$ref": "#/$defs/result_grid_surface_kind" },
        "promoted_build_surface": { "type": "boolean" },
        "claim_label": { "$ref": "#/$defs/result_grid_qualification_label" },
        "displayed_label": { "$ref": "#/$defs/result_grid_qualification_label" },
        "qualification_packet": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/result_grid_qualification_proof" }
          ]
        },
        "guards": { "$ref": "#/$defs/result_grid_surface_guard_set" },
        "downgrade_if_missing": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/reviewable" }
      }
    },
    "result_grid_viewer_row": {
      "type": "object",
      "required": [
        "viewer_id",
        "virtualization_postures",
        "truncation_states",
        "row_count_truth_classes",
        "export_postures",
        "export_formats",
        "type_coercion_states",
        "notebook_handoff_states",
        "max_rows_before_virtualization",
        "max_inline_cell_bytes",
        "active_content_blocked",
        "visible_in_ui"
      ],
      "additionalProperties": false,
      "properties": {
        "viewer_id": { "$ref": "#/$defs/opaque_id" },
        "virtualization_postures": {
          "type": "array",
          "items": { "$ref": "#/$defs/virtualization_posture_class" }
        },
        "truncation_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/truncation_state_class" }
        },
        "row_count_truth_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/row_count_truth_class" }
        },
        "export_postures": {
          "type": "array",
          "items": { "$ref": "#/$defs/export_posture_class" }
        },
        "export_formats": {
          "type": "array",
          "items": { "$ref": "#/$defs/export_format_class" }
        },
        "type_coercion_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/type_coercion_state_class" }
        },
        "notebook_handoff_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/notebook_handoff_state_class" }
        },
        "max_rows_before_virtualization": { "type": "integer", "minimum": 0 },
        "max_inline_cell_bytes": { "type": "integer", "minimum": 0 },
        "active_content_blocked": { "type": "boolean" },
        "visible_in_ui": { "type": "boolean" }
      }
    },
    "typed_copy_action_row": {
      "type": "object",
      "required": [
        "action_id",
        "copy_formats",
        "preserves_typed_columns",
        "preserves_truncation_disclosure",
        "preserves_provenance_chip",
        "type_coercion_state",
        "visible_in_ui",
        "requires_review"
      ],
      "additionalProperties": false,
      "properties": {
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "copy_formats": {
          "type": "array",
          "items": { "$ref": "#/$defs/export_format_class" }
        },
        "preserves_typed_columns": { "type": "boolean" },
        "preserves_truncation_disclosure": { "type": "boolean" },
        "preserves_provenance_chip": { "type": "boolean" },
        "type_coercion_state": { "$ref": "#/$defs/type_coercion_state_class" },
        "visible_in_ui": { "type": "boolean" },
        "requires_review": { "type": "boolean" }
      }
    },
    "typed_export_action_row": {
      "type": "object",
      "required": [
        "action_id",
        "export_formats",
        "preserves_typed_columns",
        "preserves_truncation_disclosure",
        "preserves_provenance_chip",
        "type_coercion_state",
        "visible_in_ui",
        "requires_review"
      ],
      "additionalProperties": false,
      "properties": {
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "export_formats": {
          "type": "array",
          "items": { "$ref": "#/$defs/export_format_class" }
        },
        "preserves_typed_columns": { "type": "boolean" },
        "preserves_truncation_disclosure": { "type": "boolean" },
        "preserves_provenance_chip": { "type": "boolean" },
        "type_coercion_state": { "$ref": "#/$defs/type_coercion_state_class" },
        "visible_in_ui": { "type": "boolean" },
        "requires_review": { "type": "boolean" }
      }
    },
    "filter_sort_state_panel_row": {
      "type": "object",
      "required": [
        "panel_id",
        "filter_evaluation_loci",
        "shows_filter_predicate_count",
        "shows_sort_key_count",
        "visible_in_ui",
        "discloses_client_side_only_locus"
      ],
      "additionalProperties": false,
      "properties": {
        "panel_id": { "$ref": "#/$defs/opaque_id" },
        "filter_evaluation_loci": {
          "type": "array",
          "items": { "$ref": "#/$defs/filter_evaluation_locus" }
        },
        "shows_filter_predicate_count": { "type": "boolean" },
        "shows_sort_key_count": { "type": "boolean" },
        "visible_in_ui": { "type": "boolean" },
        "discloses_client_side_only_locus": { "type": "boolean" }
      }
    },
    "row_count_boundary_chip_row": {
      "type": "object",
      "required": [
        "chip_id",
        "row_count_truth_classes",
        "shows_returned_count",
        "shows_total_exact_when_known",
        "shows_total_estimate_when_known",
        "discloses_streaming_state",
        "visible_in_ui"
      ],
      "additionalProperties": false,
      "properties": {
        "chip_id": { "$ref": "#/$defs/opaque_id" },
        "row_count_truth_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/row_count_truth_class" }
        },
        "shows_returned_count": { "type": "boolean" },
        "shows_total_exact_when_known": { "type": "boolean" },
        "shows_total_estimate_when_known": { "type": "boolean" },
        "discloses_streaming_state": { "type": "boolean" },
        "visible_in_ui": { "type": "boolean" }
      }
    },
    "result_grid_qualification_summary": {
      "type": "object",
      "required": [
        "promoted_surface_count",
        "stable_surface_count",
        "narrowed_surface_count",
        "result_grid_viewer_count",
        "typed_copy_action_count",
        "typed_export_action_count",
        "filter_sort_state_panel_count",
        "row_count_boundary_chip_count"
      ],
      "additionalProperties": false,
      "properties": {
        "promoted_surface_count": { "type": "integer", "minimum": 0 },
        "stable_surface_count": { "type": "integer", "minimum": 0 },
        "narrowed_surface_count": { "type": "integer", "minimum": 0 },
        "result_grid_viewer_count": { "type": "integer", "minimum": 0 },
        "typed_copy_action_count": { "type": "integer", "minimum": 0 },
        "typed_export_action_count": { "type": "integer", "minimum": 0 },
        "filter_sort_state_panel_count": { "type": "integer", "minimum": 0 },
        "row_count_boundary_chip_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
