{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/data/ship-rest-and-graphql-response-viewers-assertions-timing-tabs-and-browser-runtime-trust-classes.schema.json",
  "title": "Aureline REST and GraphQL response viewers, assertions, timing tabs, and browser-runtime trust class packet",
  "description": "Boundary schema for REST and GraphQL response viewers, assertion panels, timing breakdowns, and browser-runtime trust classes. Raw endpoint URLs, raw secrets, raw credential bodies, raw response bodies, and raw cookie or token values do not appear in this packet; payloads require explicit drill-down or export review.",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "as_of",
    "release_doc_ref",
    "help_doc_ref",
    "schema_ref",
    "surfaces",
    "response_viewers",
    "assertions",
    "timing_tabs",
    "browser_runtime_trusts",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "ship_rest_and_graphql_response_viewers_assertions_timing_tabs_and_browser_runtime_trust_classes" },
    "packet_id": { "$ref": "#/$defs/opaque_id" },
    "as_of": { "type": "string", "format": "date" },
    "release_doc_ref": { "$ref": "#/$defs/path_ref" },
    "help_doc_ref": { "$ref": "#/$defs/path_ref" },
    "schema_ref": { "$ref": "#/$defs/path_ref" },
    "surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/response_viewer_surface_qualification_row" }
    },
    "response_viewers": {
      "type": "array",
      "items": { "$ref": "#/$defs/response_viewer_row" }
    },
    "assertions": {
      "type": "array",
      "items": { "$ref": "#/$defs/assertion_row" }
    },
    "timing_tabs": {
      "type": "array",
      "items": { "$ref": "#/$defs/timing_tab_row" }
    },
    "browser_runtime_trusts": {
      "type": "array",
      "items": { "$ref": "#/$defs/browser_runtime_trust_row" }
    },
    "summary": { "$ref": "#/$defs/response_viewer_qualification_summary" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "path_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "reviewable": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },
    "response_viewer_qualification_label": {
      "type": "string",
      "enum": ["stable", "preview", "labs", "inspect_only", "import_only"]
    },
    "response_viewer_surface_kind": {
      "type": "string",
      "enum": [
        "rest_response_viewer",
        "graphql_response_viewer",
        "assertion_panel",
        "timing_tab",
        "browser_runtime_trust_panel"
      ]
    },
    "response_viewer_kind": {
      "type": "string",
      "enum": ["rest_response", "graphql_response"]
    },
    "assertion_outcome": {
      "type": "string",
      "enum": ["pass", "fail", "error", "skipped", "blocked", "timeout"]
    },
    "timing_phase_kind": {
      "type": "string",
      "enum": ["dns", "connect", "tls", "ttfb", "download", "total"]
    },
    "browser_runtime_trust_class": {
      "type": "string",
      "enum": ["sanitized_rich", "raw_text", "metadata_only", "sandbox_preview", "trusted_local"]
    },
    "browser_runtime_surface_kind": {
      "type": "string",
      "enum": ["dom_inspector", "storage_inspector", "network_inspector", "console_inspector"]
    },
    "response_preview_class": {
      "type": "string",
      "enum": ["json_tree", "raw_text", "sanitized_rich", "metadata_only", "digest_only", "large_payload_summary", "redacted"]
    },
    "response_viewer_qualification_proof": {
      "type": "object",
      "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at", "evidence_refs"],
      "additionalProperties": false,
      "properties": {
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "packet_ref": { "$ref": "#/$defs/path_ref" },
        "proof_index_ref": { "$ref": "#/$defs/path_ref" },
        "captured_at": { "type": "string", "format": "date" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/path_ref" }
        }
      }
    },
    "response_viewer_surface_guard_set": {
      "type": "object",
      "required": [
        "response_preview_visible",
        "raw_view_visible",
        "structured_view_visible",
        "assertion_results_visible",
        "timing_breakdown_visible",
        "export_redaction_visible",
        "browser_runtime_trust_visible",
        "rendered_view_safety_visible"
      ],
      "additionalProperties": false,
      "properties": {
        "response_preview_visible": { "type": "boolean" },
        "raw_view_visible": { "type": "boolean" },
        "structured_view_visible": { "type": "boolean" },
        "assertion_results_visible": { "type": "boolean" },
        "timing_breakdown_visible": { "type": "boolean" },
        "export_redaction_visible": { "type": "boolean" },
        "browser_runtime_trust_visible": { "type": "boolean" },
        "rendered_view_safety_visible": { "type": "boolean" }
      }
    },
    "response_viewer_surface_qualification_row": {
      "type": "object",
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "qualification_packet",
        "guards",
        "downgrade_if_missing",
        "rationale"
      ],
      "additionalProperties": false,
      "properties": {
        "surface_id": { "$ref": "#/$defs/opaque_id" },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "surface_kind": { "$ref": "#/$defs/response_viewer_surface_kind" },
        "promoted_build_surface": { "type": "boolean" },
        "claim_label": { "$ref": "#/$defs/response_viewer_qualification_label" },
        "displayed_label": { "$ref": "#/$defs/response_viewer_qualification_label" },
        "qualification_packet": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/response_viewer_qualification_proof" }
          ]
        },
        "guards": { "$ref": "#/$defs/response_viewer_surface_guard_set" },
        "downgrade_if_missing": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/reviewable" }
      }
    },
    "response_viewer_row": {
      "type": "object",
      "required": [
        "viewer_id",
        "viewer_kind",
        "preview_classes",
        "raw_view_supported",
        "structured_view_supported",
        "rendered_view_supported",
        "assertion_results_visible",
        "timing_visible",
        "export_redaction_visible",
        "body_size_limit_bytes",
        "grants_ambient_execution"
      ],
      "additionalProperties": false,
      "properties": {
        "viewer_id": { "$ref": "#/$defs/opaque_id" },
        "viewer_kind": { "$ref": "#/$defs/response_viewer_kind" },
        "preview_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/response_preview_class" }
        },
        "raw_view_supported": { "type": "boolean" },
        "structured_view_supported": { "type": "boolean" },
        "rendered_view_supported": { "type": "boolean" },
        "assertion_results_visible": { "type": "boolean" },
        "timing_visible": { "type": "boolean" },
        "export_redaction_visible": { "type": "boolean" },
        "body_size_limit_bytes": { "type": "integer", "minimum": 0 },
        "grants_ambient_execution": { "type": "boolean" }
      }
    },
    "assertion_row": {
      "type": "object",
      "required": [
        "assertion_id",
        "outcome",
        "assertion_kind",
        "request_identity_ref",
        "response_identity_ref",
        "visible_before_export",
        "support_bundle_safe",
        "failure_redaction_class"
      ],
      "additionalProperties": false,
      "properties": {
        "assertion_id": { "$ref": "#/$defs/opaque_id" },
        "outcome": { "$ref": "#/$defs/assertion_outcome" },
        "assertion_kind": { "type": "string", "minLength": 1 },
        "request_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "response_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "visible_before_export": { "type": "boolean" },
        "support_bundle_safe": { "type": "boolean" },
        "failure_redaction_class": { "type": "string", "minLength": 1 }
      }
    },
    "timing_tab_row": {
      "type": "object",
      "required": [
        "timing_tab_id",
        "phases",
        "request_identity_ref",
        "visible_in_response_viewer",
        "preserved_in_history",
        "export_safe"
      ],
      "additionalProperties": false,
      "properties": {
        "timing_tab_id": { "$ref": "#/$defs/opaque_id" },
        "phases": {
          "type": "array",
          "items": { "$ref": "#/$defs/timing_phase_kind" }
        },
        "request_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "visible_in_response_viewer": { "type": "boolean" },
        "preserved_in_history": { "type": "boolean" },
        "export_safe": { "type": "boolean" }
      }
    },
    "browser_runtime_trust_row": {
      "type": "object",
      "required": [
        "trust_row_id",
        "surface_kind",
        "trust_class",
        "visible_in_ui",
        "visible_in_export",
        "mutation_requires_review",
        "cross_origin_disclosed",
        "session_identity_ref"
      ],
      "additionalProperties": false,
      "properties": {
        "trust_row_id": { "$ref": "#/$defs/opaque_id" },
        "surface_kind": { "$ref": "#/$defs/browser_runtime_surface_kind" },
        "trust_class": { "$ref": "#/$defs/browser_runtime_trust_class" },
        "visible_in_ui": { "type": "boolean" },
        "visible_in_export": { "type": "boolean" },
        "mutation_requires_review": { "type": "boolean" },
        "cross_origin_disclosed": { "type": "boolean" },
        "session_identity_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "response_viewer_qualification_summary": {
      "type": "object",
      "required": [
        "promoted_surface_count",
        "stable_surface_count",
        "narrowed_surface_count",
        "response_viewer_count",
        "assertion_count",
        "timing_tab_count",
        "browser_runtime_trust_count"
      ],
      "additionalProperties": false,
      "properties": {
        "promoted_surface_count": { "type": "integer", "minimum": 0 },
        "stable_surface_count": { "type": "integer", "minimum": 0 },
        "narrowed_surface_count": { "type": "integer", "minimum": 0 },
        "response_viewer_count": { "type": "integer", "minimum": 0 },
        "assertion_count": { "type": "integer", "minimum": 0 },
        "timing_tab_count": { "type": "integer", "minimum": 0 },
        "browser_runtime_trust_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
