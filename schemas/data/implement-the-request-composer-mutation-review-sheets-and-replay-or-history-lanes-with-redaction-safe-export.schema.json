{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/data/implement-the-request-composer-mutation-review-sheets-and-replay-or-history-lanes-with-redaction-safe-export.schema.json",
  "title": "Aureline request composer, mutation-review sheets, replay and history lanes, and redaction-safe export packet",
  "description": "Boundary schema for request composers, mutation-review sheets, history lanes, replay configurations, and redaction-safe exports. Raw endpoint URLs, raw secrets, raw credential bodies, raw response bodies, and raw cookie or token values do not appear in this packet; payloads require explicit drill-down or export review.",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "as_of",
    "release_doc_ref",
    "help_doc_ref",
    "schema_ref",
    "surfaces",
    "composers",
    "mutation_review_sheets",
    "history_lanes",
    "replay_configs",
    "redaction_safe_exports",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "request_composer_mutation_review_sheets_and_replay_or_history_lanes_with_redaction_safe_export" },
    "packet_id": { "$ref": "#/$defs/opaque_id" },
    "as_of": { "type": "string", "format": "date" },
    "release_doc_ref": { "$ref": "#/$defs/path_ref" },
    "help_doc_ref": { "$ref": "#/$defs/path_ref" },
    "schema_ref": { "$ref": "#/$defs/path_ref" },
    "surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/composer_surface_qualification_row" }
    },
    "composers": {
      "type": "array",
      "items": { "$ref": "#/$defs/request_composer_row" }
    },
    "mutation_review_sheets": {
      "type": "array",
      "items": { "$ref": "#/$defs/mutation_review_sheet_row" }
    },
    "history_lanes": {
      "type": "array",
      "items": { "$ref": "#/$defs/history_lane_row" }
    },
    "replay_configs": {
      "type": "array",
      "items": { "$ref": "#/$defs/replay_config_row" }
    },
    "redaction_safe_exports": {
      "type": "array",
      "items": { "$ref": "#/$defs/redaction_safe_export_row" }
    },
    "summary": { "$ref": "#/$defs/composer_qualification_summary" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "path_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "reviewable": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },
    "composer_qualification_label": {
      "type": "string",
      "enum": ["stable", "preview", "labs", "inspect_only", "import_only"]
    },
    "composer_surface_kind": {
      "type": "string",
      "enum": [
        "request_composer",
        "mutation_review_sheet",
        "history_lane",
        "replay_lane",
        "export_review",
        "response_viewer"
      ]
    },
    "request_composer_kind": {
      "type": "string",
      "enum": ["http_request", "graphql_operation"]
    },
    "mutation_risk_class": {
      "type": "string",
      "enum": [
        "read_only",
        "idempotent_mutation",
        "destructive_mutation",
        "ambiguous",
        "policy_blocked"
      ]
    },
    "replay_mode": {
      "type": "string",
      "enum": [
        "exact_rerun",
        "rerun_with_current_context",
        "rerun_with_current_auth",
        "template_replay",
        "review_only",
        "blocked"
      ]
    },
    "export_redaction_class": {
      "type": "string",
      "enum": [
        "full_redaction",
        "metadata_only",
        "safe_preview",
        "unredacted_local_only"
      ]
    },
    "history_retention_posture": {
      "type": "string",
      "enum": [
        "local_first",
        "bounded",
        "pinned",
        "ephemeral"
      ]
    },
    "response_stream_state": {
      "type": "string",
      "enum": [
        "connecting",
        "headers_received",
        "streaming",
        "truncated",
        "complete",
        "partial",
        "timed_out",
        "policy_blocked"
      ]
    },
    "composer_qualification_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at", "evidence_refs"],
      "properties": {
        "packet_id": { "type": "string" },
        "packet_ref": { "type": "string" },
        "proof_index_ref": { "type": "string" },
        "captured_at": { "type": "string" },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "composer_surface_guard_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "composer_fields_visible",
        "mutation_review_visible",
        "history_identity_visible",
        "replay_mode_visible",
        "export_redaction_visible",
        "response_stream_visible",
        "auth_scope_visible",
        "target_class_visible"
      ],
      "properties": {
        "composer_fields_visible": { "type": "boolean" },
        "mutation_review_visible": { "type": "boolean" },
        "history_identity_visible": { "type": "boolean" },
        "replay_mode_visible": { "type": "boolean" },
        "export_redaction_visible": { "type": "boolean" },
        "response_stream_visible": { "type": "boolean" },
        "auth_scope_visible": { "type": "boolean" },
        "target_class_visible": { "type": "boolean" }
      }
    },
    "composer_surface_qualification_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "qualification_packet",
        "guards",
        "downgrade_if_missing",
        "rationale"
      ],
      "properties": {
        "surface_id": { "type": "string" },
        "title": { "type": "string" },
        "surface_kind": { "$ref": "#/$defs/composer_surface_kind" },
        "promoted_build_surface": { "type": "boolean" },
        "claim_label": { "$ref": "#/$defs/composer_qualification_label" },
        "displayed_label": { "$ref": "#/$defs/composer_qualification_label" },
        "qualification_packet": { "oneOf": [{ "$ref": "#/$defs/composer_qualification_proof" }, { "type": "null" }] },
        "guards": { "$ref": "#/$defs/composer_surface_guard_set" },
        "downgrade_if_missing": { "type": "boolean" },
        "rationale": { "type": "string" }
      }
    },
    "request_composer_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "composer_id",
        "composer_kind",
        "method_kind",
        "path_template",
        "header_refs",
        "body_ref",
        "variable_refs",
        "assertion_refs",
        "environment_set_ref",
        "auth_source_ref",
        "mutation_risk_class",
        "diffable",
        "cli_reusable"
      ],
      "properties": {
        "composer_id": { "type": "string" },
        "composer_kind": { "$ref": "#/$defs/request_composer_kind" },
        "method_kind": { "type": "string" },
        "path_template": { "type": "string" },
        "header_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "body_ref": { "type": "string" },
        "variable_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assertion_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "environment_set_ref": { "type": "string" },
        "auth_source_ref": { "type": "string" },
        "mutation_risk_class": { "$ref": "#/$defs/mutation_risk_class" },
        "schema_snapshot_ref": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "diffable": { "type": "boolean" },
        "cli_reusable": { "type": "boolean" }
      }
    },
    "mutation_review_sheet_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sheet_id",
        "target_endpoint_ref",
        "side_effect_class",
        "auth_scope_ref",
        "request_body_mode",
        "confirmation_required",
        "replay_consequences_disclosed",
        "previewable_before_send",
        "rollback_path_visible"
      ],
      "properties": {
        "sheet_id": { "type": "string" },
        "target_endpoint_ref": { "type": "string" },
        "side_effect_class": { "type": "string" },
        "auth_scope_ref": { "type": "string" },
        "request_body_mode": { "type": "string" },
        "confirmation_required": { "type": "boolean" },
        "replay_consequences_disclosed": { "type": "boolean" },
        "previewable_before_send": { "type": "boolean" },
        "rollback_path_visible": { "type": "boolean" }
      }
    },
    "history_lane_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_id",
        "request_identity_ref",
        "environment_ref",
        "auth_class_ref",
        "response_class_ref",
        "retention_posture",
        "replay_mode_ref",
        "redaction_safe_export_ref",
        "last_executed_at",
        "pinned"
      ],
      "properties": {
        "lane_id": { "type": "string" },
        "request_identity_ref": { "type": "string" },
        "environment_ref": { "type": "string" },
        "auth_class_ref": { "type": "string" },
        "response_class_ref": { "type": "string" },
        "retention_posture": { "$ref": "#/$defs/history_retention_posture" },
        "replay_mode_ref": { "type": "string" },
        "redaction_safe_export_ref": { "type": "string" },
        "last_executed_at": { "type": "string" },
        "pinned": { "type": "boolean" }
      }
    },
    "replay_config_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config_id",
        "replay_mode",
        "context_resolution_disclosed",
        "auth_reuse_disclosed",
        "environment_reuse_disclosed",
        "requires_fresh_review"
      ],
      "properties": {
        "config_id": { "type": "string" },
        "replay_mode": { "$ref": "#/$defs/replay_mode" },
        "context_resolution_disclosed": { "type": "boolean" },
        "auth_reuse_disclosed": { "type": "boolean" },
        "environment_reuse_disclosed": { "type": "boolean" },
        "requires_fresh_review": { "type": "boolean" },
        "exact_rerun_attestation_ref": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      }
    },
    "redaction_safe_export_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_id",
        "export_redaction_class",
        "includes_raw_secrets",
        "includes_raw_response_body",
        "portable_format_ref",
        "redaction_rationale",
        "support_bundle_safe"
      ],
      "properties": {
        "export_id": { "type": "string" },
        "export_redaction_class": { "$ref": "#/$defs/export_redaction_class" },
        "includes_raw_secrets": { "type": "boolean" },
        "includes_raw_response_body": { "type": "boolean" },
        "portable_format_ref": { "type": "string" },
        "redaction_rationale": { "type": "string" },
        "support_bundle_safe": { "type": "boolean" }
      }
    },
    "composer_qualification_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promoted_surface_count",
        "stable_surface_count",
        "narrowed_surface_count",
        "composer_count",
        "mutation_review_sheet_count",
        "history_lane_count",
        "replay_config_count",
        "redaction_safe_export_count"
      ],
      "properties": {
        "promoted_surface_count": { "type": "integer", "minimum": 0 },
        "stable_surface_count": { "type": "integer", "minimum": 0 },
        "narrowed_surface_count": { "type": "integer", "minimum": 0 },
        "composer_count": { "type": "integer", "minimum": 0 },
        "mutation_review_sheet_count": { "type": "integer", "minimum": 0 },
        "history_lane_count": { "type": "integer", "minimum": 0 },
        "replay_config_count": { "type": "integer", "minimum": 0 },
        "redaction_safe_export_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
