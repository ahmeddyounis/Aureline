{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/data/ship-query-history-connection-profile-portability-secret-safe-auth-storage-and-mirror-or-offline-truth.schema.json",
  "title": "Aureline query history, connection-profile portability, secret-safe auth storage, and mirror or offline truth boundary",
  "description": "Boundary schema for the ship-query-history qualification packet. This packet governs surfaces that expose query history entries, connection-profile portability, secret-safe auth storage, and mirror or offline truth. Raw statement bodies, raw connection strings, raw secrets, raw credential bodies, raw endpoint URLs, and raw hostnames never cross this boundary.",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "as_of",
    "release_doc_ref",
    "help_doc_ref",
    "schema_ref",
    "surfaces",
    "query_history_entries",
    "connection_profile_portabilities",
    "secret_safe_auth_storages",
    "mirror_or_offline_truths",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "ship_query_history_connection_profile_portability_secret_safe_auth_storage_and_mirror_or_offline_truth"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "release_doc_ref": {
      "type": "string",
      "minLength": 1
    },
    "help_doc_ref": {
      "type": "string",
      "minLength": 1
    },
    "schema_ref": {
      "type": "string",
      "minLength": 1
    },
    "surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_qualification_row" }
    },
    "query_history_entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/query_history_entry_row" }
    },
    "connection_profile_portabilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/connection_profile_portability_row" }
    },
    "secret_safe_auth_storages": {
      "type": "array",
      "items": { "$ref": "#/$defs/secret_safe_auth_storage_row" }
    },
    "mirror_or_offline_truths": {
      "type": "array",
      "items": { "$ref": "#/$defs/mirror_or_offline_truth_row" }
    },
    "summary": {
      "$ref": "#/$defs/qualification_summary"
    }
  },
  "$defs": {
    "qualification_label": {
      "type": "string",
      "enum": ["stable", "preview", "labs", "inspect_only", "import_only"]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "query_history_viewer",
        "connection_profile_portability",
        "secret_safe_auth_storage",
        "mirror_or_offline_truth"
      ]
    },
    "retention_posture": {
      "type": "string",
      "enum": ["local_first", "bounded", "pinned", "ephemeral", "audit_only"]
    },
    "replay_drift_risk": {
      "type": "string",
      "enum": ["no_drift", "low_drift", "moderate_drift", "high_drift", "blocked"]
    },
    "portability_posture": {
      "type": "string",
      "enum": ["local_only", "redacted_export", "full_migration", "blocked"]
    },
    "auth_storage_mode": {
      "type": "string",
      "enum": ["local_encrypted", "secret_broker_only", "managed_rotation", "policy_locked"]
    },
    "mirror_or_offline_state_class": {
      "type": "string",
      "enum": [
        "online_default",
        "online_replica",
        "offline_grace_window",
        "offline_local_only",
        "network_disabled"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": ["metadata_safe", "operator_only", "internal_support", "signing_evidence"]
    },
    "qualification_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at", "evidence_refs"],
      "properties": {
        "packet_id": { "type": "string", "minLength": 1 },
        "packet_ref": { "type": "string", "minLength": 1 },
        "proof_index_ref": { "type": "string", "minLength": 1 },
        "captured_at": { "type": "string", "format": "date" },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "surface_guard_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query_history_identity_visible",
        "connection_profile_portability_visible",
        "secret_safe_auth_storage_visible",
        "mirror_or_offline_truth_visible",
        "auth_scope_visible",
        "write_posture_visible",
        "retention_redaction_visible",
        "replay_drift_risk_visible"
      ],
      "properties": {
        "query_history_identity_visible": { "type": "boolean" },
        "connection_profile_portability_visible": { "type": "boolean" },
        "secret_safe_auth_storage_visible": { "type": "boolean" },
        "mirror_or_offline_truth_visible": { "type": "boolean" },
        "auth_scope_visible": { "type": "boolean" },
        "write_posture_visible": { "type": "boolean" },
        "retention_redaction_visible": { "type": "boolean" },
        "replay_drift_risk_visible": { "type": "boolean" }
      }
    },
    "surface_qualification_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "guards",
        "downgrade_if_missing",
        "rationale"
      ],
      "properties": {
        "surface_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "promoted_build_surface": { "type": "boolean" },
        "claim_label": { "$ref": "#/$defs/qualification_label" },
        "displayed_label": { "$ref": "#/$defs/qualification_label" },
        "qualification_packet": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/qualification_proof" }
          ]
        },
        "guards": { "$ref": "#/$defs/surface_guard_set" },
        "downgrade_if_missing": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "query_history_entry_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "connection_profile_ref",
        "statement_body_ref",
        "statement_safety_result_ref",
        "result_size_class",
        "row_count_truth_class",
        "retention_posture",
        "replay_drift_risk",
        "export_safe",
        "redaction_class",
        "last_executed_at",
        "pinned"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "connection_profile_ref": { "type": "string", "minLength": 1 },
        "statement_body_ref": { "type": "string", "minLength": 1 },
        "statement_safety_result_ref": { "type": "string", "minLength": 1 },
        "result_size_class": { "type": "string", "minLength": 1 },
        "row_count_truth_class": { "type": "string", "minLength": 1 },
        "retention_posture": { "$ref": "#/$defs/retention_posture" },
        "replay_drift_risk": { "$ref": "#/$defs/replay_drift_risk" },
        "export_safe": { "type": "boolean" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "last_executed_at": { "type": "string", "minLength": 1 },
        "pinned": { "type": "boolean" }
      }
    },
    "connection_profile_portability_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "portability_id",
        "source_profile_ref",
        "target_format",
        "includes_raw_secrets",
        "includes_raw_endpoint",
        "auth_handle_migration_visible",
        "export_posture",
        "import_posture"
      ],
      "properties": {
        "portability_id": { "type": "string", "minLength": 1 },
        "source_profile_ref": { "type": "string", "minLength": 1 },
        "target_format": { "type": "string", "minLength": 1 },
        "includes_raw_secrets": { "type": "boolean" },
        "includes_raw_endpoint": { "type": "boolean" },
        "auth_handle_migration_visible": { "type": "boolean" },
        "export_posture": { "$ref": "#/$defs/portability_posture" },
        "import_posture": { "$ref": "#/$defs/portability_posture" }
      }
    },
    "secret_safe_auth_storage_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "storage_id",
        "auth_handle_class",
        "secret_broker_ref",
        "encryption_at_rest",
        "rotation_policy_visible",
        "raw_secret_observed",
        "storage_mode",
        "export_safe"
      ],
      "properties": {
        "storage_id": { "type": "string", "minLength": 1 },
        "auth_handle_class": { "type": "string", "minLength": 1 },
        "secret_broker_ref": { "type": "string", "minLength": 1 },
        "encryption_at_rest": { "type": "boolean" },
        "rotation_policy_visible": { "type": "boolean" },
        "raw_secret_observed": { "type": "boolean" },
        "storage_mode": { "$ref": "#/$defs/auth_storage_mode" },
        "export_safe": { "type": "boolean" }
      }
    },
    "mirror_or_offline_truth_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truth_id",
        "mirror_or_offline_state_class",
        "cache_warmth",
        "fallback_posture",
        "connectivity_disclosure"
      ],
      "properties": {
        "truth_id": { "type": "string", "minLength": 1 },
        "mirror_or_offline_state_class": { "$ref": "#/$defs/mirror_or_offline_state_class" },
        "replica_endpoint_ref": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "offline_since": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "cache_warmth": { "type": "string", "minLength": 1 },
        "fallback_posture": { "type": "string", "minLength": 1 },
        "connectivity_disclosure": { "type": "string", "minLength": 1 }
      }
    },
    "qualification_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promoted_surface_count",
        "stable_surface_count",
        "narrowed_surface_count",
        "query_history_entry_count",
        "connection_profile_portability_count",
        "secret_safe_auth_storage_count",
        "mirror_or_offline_truth_count"
      ],
      "properties": {
        "promoted_surface_count": { "type": "integer", "minimum": 0 },
        "stable_surface_count": { "type": "integer", "minimum": 0 },
        "narrowed_surface_count": { "type": "integer", "minimum": 0 },
        "query_history_entry_count": { "type": "integer", "minimum": 0 },
        "connection_profile_portability_count": { "type": "integer", "minimum": 0 },
        "secret_safe_auth_storage_count": { "type": "integer", "minimum": 0 },
        "mirror_or_offline_truth_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
