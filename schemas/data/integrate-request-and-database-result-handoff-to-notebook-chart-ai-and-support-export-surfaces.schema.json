{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/data/integrate-request-and-database-result-handoff-to-notebook-chart-ai-and-support-export-surfaces.schema.json",
  "title": "Aureline request and database result handoff to notebook, chart, AI, and support-export surfaces packet",
  "description": "Boundary schema for handoff qualification records that govern how result sets move from request and database surfaces to notebook, chart, AI, and support-export destinations. Raw row bodies, raw cell values, raw credentials, raw connection-string fragments, and raw secret material do not appear in this packet.",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "as_of",
    "release_doc_ref",
    "help_doc_ref",
    "schema_ref",
    "surfaces",
    "notebook_handoffs",
    "chart_handoffs",
    "ai_handoffs",
    "support_exports",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "integrate_request_and_database_result_handoff_to_notebook_chart_ai_and_support_export_surfaces" },
    "packet_id": { "$ref": "#/$defs/opaque_id" },
    "as_of": { "type": "string", "format": "date" },
    "release_doc_ref": { "$ref": "#/$defs/path_ref" },
    "help_doc_ref": { "$ref": "#/$defs/path_ref" },
    "schema_ref": { "$ref": "#/$defs/path_ref" },
    "surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/handoff_surface_qualification_row" }
    },
    "notebook_handoffs": {
      "type": "array",
      "items": { "$ref": "#/$defs/notebook_handoff_row" }
    },
    "chart_handoffs": {
      "type": "array",
      "items": { "$ref": "#/$defs/chart_handoff_row" }
    },
    "ai_handoffs": {
      "type": "array",
      "items": { "$ref": "#/$defs/ai_handoff_row" }
    },
    "support_exports": {
      "type": "array",
      "items": { "$ref": "#/$defs/support_export_row" }
    },
    "summary": { "$ref": "#/$defs/handoff_qualification_summary" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "path_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "reviewable": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },
    "handoff_qualification_label": {
      "type": "string",
      "enum": ["stable", "preview", "labs", "inspect_only", "import_only"]
    },
    "handoff_surface_kind": {
      "type": "string",
      "enum": [
        "notebook_handoff_surface",
        "chart_handoff_surface",
        "ai_handoff_surface",
        "support_export_surface"
      ]
    },
    "notebook_handoff_state_class": {
      "type": "string",
      "enum": [
        "no_notebook_handoff",
        "notebook_handoff_proposed_pending_user_admit",
        "notebook_handoff_admitted_dataframe_typed",
        "notebook_handoff_admitted_textual_fallback_only",
        "notebook_handoff_blocked_pending_policy",
        "notebook_handoff_blocked_redaction_class_too_high",
        "notebook_handoff_unknown_requires_review"
      ]
    },
    "chart_handoff_state_class": {
      "type": "string",
      "enum": [
        "no_chart_handoff",
        "chart_handoff_proposed_pending_user_admit",
        "chart_handoff_admitted_typed",
        "chart_handoff_admitted_textual_fallback_only",
        "chart_handoff_blocked_pending_policy",
        "chart_handoff_blocked_redaction_class_too_high",
        "chart_handoff_unknown_requires_review"
      ]
    },
    "ai_handoff_state_class": {
      "type": "string",
      "enum": [
        "no_ai_handoff",
        "ai_handoff_proposed_pending_user_admit",
        "ai_handoff_admitted_typed_with_context",
        "ai_handoff_admitted_textual_fallback_only",
        "ai_handoff_blocked_pending_policy",
        "ai_handoff_blocked_redaction_class_too_high",
        "ai_handoff_blocked_secret_boundary_violation",
        "ai_handoff_unknown_requires_review"
      ]
    },
    "support_export_posture_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "result_set_origin_class": {
      "type": "string",
      "enum": [
        "desktop_sql_editor",
        "cli_runner",
        "ai_tool_review_surface",
        "automation_run_review_surface",
        "extension_host_runner",
        "support_export_reader",
        "admin_audit_reader",
        "hosted_review_reader",
        "notebook_kernel_handoff_target"
      ]
    },
    "handoff_qualification_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at", "evidence_refs"],
      "properties": {
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "packet_ref": { "$ref": "#/$defs/path_ref" },
        "proof_index_ref": { "$ref": "#/$defs/path_ref" },
        "captured_at": { "type": "string", "format": "date" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/path_ref" }
        }
      }
    },
    "handoff_surface_guard_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "notebook_handoff_visible",
        "chart_handoff_visible",
        "ai_handoff_visible",
        "support_export_visible",
        "truncation_disclosure_visible",
        "provenance_chip_visible",
        "secret_boundaries_visible",
        "redaction_class_visible"
      ],
      "properties": {
        "notebook_handoff_visible": { "type": "boolean" },
        "chart_handoff_visible": { "type": "boolean" },
        "ai_handoff_visible": { "type": "boolean" },
        "support_export_visible": { "type": "boolean" },
        "truncation_disclosure_visible": { "type": "boolean" },
        "provenance_chip_visible": { "type": "boolean" },
        "secret_boundaries_visible": { "type": "boolean" },
        "redaction_class_visible": { "type": "boolean" }
      }
    },
    "handoff_surface_qualification_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "guards",
        "downgrade_if_missing",
        "rationale"
      ],
      "properties": {
        "surface_id": { "$ref": "#/$defs/opaque_id" },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "surface_kind": { "$ref": "#/$defs/handoff_surface_kind" },
        "promoted_build_surface": { "type": "boolean" },
        "claim_label": { "$ref": "#/$defs/handoff_qualification_label" },
        "displayed_label": { "$ref": "#/$defs/handoff_qualification_label" },
        "qualification_packet": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/handoff_qualification_proof" }
          ]
        },
        "guards": { "$ref": "#/$defs/handoff_surface_guard_set" },
        "downgrade_if_missing": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/reviewable" }
      }
    },
    "notebook_handoff_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff_id",
        "supported_states",
        "preserves_typed_columns",
        "preserves_truncation_disclosure",
        "preserves_provenance_chip",
        "requires_target_ref",
        "visible_in_ui"
      ],
      "properties": {
        "handoff_id": { "$ref": "#/$defs/opaque_id" },
        "supported_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/notebook_handoff_state_class" }
        },
        "preserves_typed_columns": { "type": "boolean" },
        "preserves_truncation_disclosure": { "type": "boolean" },
        "preserves_provenance_chip": { "type": "boolean" },
        "requires_target_ref": { "type": "boolean" },
        "visible_in_ui": { "type": "boolean" }
      }
    },
    "chart_handoff_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff_id",
        "supported_states",
        "preserves_typed_columns",
        "preserves_truncation_disclosure",
        "preserves_provenance_chip",
        "visible_in_ui"
      ],
      "properties": {
        "handoff_id": { "$ref": "#/$defs/opaque_id" },
        "supported_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/chart_handoff_state_class" }
        },
        "preserves_typed_columns": { "type": "boolean" },
        "preserves_truncation_disclosure": { "type": "boolean" },
        "preserves_provenance_chip": { "type": "boolean" },
        "visible_in_ui": { "type": "boolean" }
      }
    },
    "ai_handoff_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff_id",
        "supported_states",
        "preserves_typed_columns",
        "preserves_truncation_disclosure",
        "preserves_provenance_chip",
        "preserves_secret_boundaries",
        "visible_in_ui"
      ],
      "properties": {
        "handoff_id": { "$ref": "#/$defs/opaque_id" },
        "supported_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/ai_handoff_state_class" }
        },
        "preserves_typed_columns": { "type": "boolean" },
        "preserves_truncation_disclosure": { "type": "boolean" },
        "preserves_provenance_chip": { "type": "boolean" },
        "preserves_secret_boundaries": { "type": "boolean" },
        "visible_in_ui": { "type": "boolean" }
      }
    },
    "support_export_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_id",
        "supported_postures",
        "default_redaction_class",
        "includes_row_data_requires_consent",
        "includes_credentials_requires_consent",
        "preserves_provenance_chip",
        "preserves_truncation_disclosure",
        "visible_in_ui"
      ],
      "properties": {
        "export_id": { "$ref": "#/$defs/opaque_id" },
        "supported_postures": {
          "type": "array",
          "items": { "$ref": "#/$defs/support_export_posture_class" }
        },
        "default_redaction_class": { "$ref": "#/$defs/support_export_posture_class" },
        "includes_row_data_requires_consent": { "type": "boolean" },
        "includes_credentials_requires_consent": { "type": "boolean" },
        "preserves_provenance_chip": { "type": "boolean" },
        "preserves_truncation_disclosure": { "type": "boolean" },
        "visible_in_ui": { "type": "boolean" }
      }
    },
    "handoff_qualification_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promoted_surface_count",
        "stable_surface_count",
        "narrowed_surface_count",
        "notebook_handoff_count",
        "chart_handoff_count",
        "ai_handoff_count",
        "support_export_count"
      ],
      "properties": {
        "promoted_surface_count": { "type": "integer", "minimum": 0 },
        "stable_surface_count": { "type": "integer", "minimum": 0 },
        "narrowed_surface_count": { "type": "integer", "minimum": 0 },
        "notebook_handoff_count": { "type": "integer", "minimum": 0 },
        "chart_handoff_count": { "type": "integer", "minimum": 0 },
        "ai_handoff_count": { "type": "integer", "minimum": 0 },
        "support_export_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
