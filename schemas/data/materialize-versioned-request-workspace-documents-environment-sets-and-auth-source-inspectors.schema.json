{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/data/materialize-versioned-request-workspace-documents-environment-sets-and-auth-source-inspectors.schema.json",
  "title": "Aureline versioned request-workspace documents, environment sets, and auth-source inspectors packet",
  "description": "Boundary schema for versioned request-workspace documents, layered environment sets, auth-source inspectors, effective-request inspectors, and schema snapshots. Raw endpoint URLs, raw secrets, raw credential bodies, and raw cookie or token values do not appear in this packet; payloads require explicit drill-down or export review.",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "as_of",
    "release_doc_ref",
    "help_doc_ref",
    "schema_ref",
    "surfaces",
    "documents",
    "environment_sets",
    "auth_sources",
    "effective_inspectors",
    "schema_snapshots",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "versioned_request_workspace_documents_environment_sets_and_auth_source_inspectors" },
    "packet_id": { "$ref": "#/$defs/opaque_id" },
    "as_of": { "type": "string", "format": "date" },
    "release_doc_ref": { "$ref": "#/$defs/path_ref" },
    "help_doc_ref": { "$ref": "#/$defs/path_ref" },
    "schema_ref": { "$ref": "#/$defs/path_ref" },
    "surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/request_surface_qualification_row" }
    },
    "documents": {
      "type": "array",
      "items": { "$ref": "#/$defs/request_workspace_document_row" }
    },
    "environment_sets": {
      "type": "array",
      "items": { "$ref": "#/$defs/environment_set_row" }
    },
    "auth_sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/auth_source_inspector_row" }
    },
    "effective_inspectors": {
      "type": "array",
      "items": { "$ref": "#/$defs/effective_request_inspector_row" }
    },
    "schema_snapshots": {
      "type": "array",
      "items": { "$ref": "#/$defs/schema_snapshot_row" }
    },
    "summary": { "$ref": "#/$defs/request_qualification_summary" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "path_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "reviewable": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },
    "request_qualification_label": {
      "type": "string",
      "enum": ["stable", "preview", "labs", "inspect_only", "import_only"]
    },
    "request_surface_kind": {
      "type": "string",
      "enum": [
        "request_editor",
        "environment_picker",
        "auth_inspector",
        "send_bar",
        "history_row",
        "export_review",
        "schema_inspector",
        "effective_request_inspector"
      ]
    },
    "request_document_kind": {
      "type": "string",
      "enum": ["http_request", "graphql_operation"]
    },
    "request_write_posture": {
      "type": "string",
      "enum": ["read_only", "write_capable", "policy_blocked"]
    },
    "auth_source_mode": {
      "type": "string",
      "enum": [
        "no_auth",
        "secret_broker_handle",
        "delegated_identity",
        "policy_injected_credential",
        "managed_service_identity",
        "mtls",
        "imported_no_live_auth",
        "policy_blocked"
      ]
    },
    "auth_source_provenance": {
      "type": "string",
      "enum": [
        "request_file",
        "workspace_default",
        "policy_injection",
        "ad_hoc_override",
        "secret_broker"
      ]
    },
    "environment_layer_kind": {
      "type": "string",
      "enum": [
        "request_file",
        "workspace_default",
        "policy_injection",
        "ad_hoc_override",
        "secret_handle"
      ]
    },
    "response_safe_preview_class": {
      "type": "string",
      "enum": [
        "json_tree",
        "raw_text",
        "sanitized_rich",
        "metadata_only",
        "digest_only",
        "large_payload_summary",
        "redacted"
      ]
    },
    "request_qualification_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at", "evidence_refs"],
      "properties": {
        "packet_id": { "type": "string" },
        "packet_ref": { "type": "string" },
        "proof_index_ref": { "type": "string" },
        "captured_at": { "type": "string" },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "request_surface_guard_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_kind_visible",
        "endpoint_identity_visible",
        "auth_source_visible",
        "environment_layers_visible",
        "effective_inspector_visible",
        "write_posture_visible",
        "schema_freshness_visible",
        "response_preview_visible",
        "export_redaction_visible"
      ],
      "properties": {
        "document_kind_visible": { "type": "boolean" },
        "endpoint_identity_visible": { "type": "boolean" },
        "auth_source_visible": { "type": "boolean" },
        "environment_layers_visible": { "type": "boolean" },
        "effective_inspector_visible": { "type": "boolean" },
        "write_posture_visible": { "type": "boolean" },
        "schema_freshness_visible": { "type": "boolean" },
        "response_preview_visible": { "type": "boolean" },
        "export_redaction_visible": { "type": "boolean" }
      }
    },
    "request_surface_qualification_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "qualification_packet",
        "guards",
        "downgrade_if_missing",
        "rationale"
      ],
      "properties": {
        "surface_id": { "type": "string" },
        "title": { "type": "string" },
        "surface_kind": { "$ref": "#/$defs/request_surface_kind" },
        "promoted_build_surface": { "type": "boolean" },
        "claim_label": { "$ref": "#/$defs/request_qualification_label" },
        "displayed_label": { "$ref": "#/$defs/request_qualification_label" },
        "qualification_packet": { "oneOf": [{ "$ref": "#/$defs/request_qualification_proof" }, { "type": "null" }] },
        "guards": { "$ref": "#/$defs/request_surface_guard_set" },
        "downgrade_if_missing": { "type": "boolean" },
        "rationale": { "type": "string" }
      }
    },
    "request_document_version": {
      "type": "object",
      "additionalProperties": false,
      "required": ["major", "minor", "patch"],
      "properties": {
        "major": { "type": "integer", "minimum": 0 },
        "minor": { "type": "integer", "minimum": 0 },
        "patch": { "type": "integer", "minimum": 0 }
      }
    },
    "request_workspace_document_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_id",
        "document_kind",
        "document_version",
        "method_kind",
        "path_template",
        "header_refs",
        "body_ref",
        "variable_refs",
        "assertion_refs",
        "collection_tags",
        "environment_set_ref",
        "auth_source_ref",
        "write_posture",
        "diffable",
        "cli_reusable"
      ],
      "properties": {
        "document_id": { "type": "string" },
        "document_kind": { "$ref": "#/$defs/request_document_kind" },
        "document_version": { "$ref": "#/$defs/request_document_version" },
        "method_kind": { "type": "string" },
        "path_template": { "type": "string" },
        "header_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "body_ref": { "type": "string" },
        "variable_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assertion_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "collection_tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "environment_set_ref": { "type": "string" },
        "auth_source_ref": { "type": "string" },
        "write_posture": { "$ref": "#/$defs/request_write_posture" },
        "schema_snapshot_ref": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "diffable": { "type": "boolean" },
        "cli_reusable": { "type": "boolean" }
      }
    },
    "environment_layer_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer_id", "layer_kind", "variable_keys", "provenance", "overrides_lower"],
      "properties": {
        "layer_id": { "type": "string" },
        "layer_kind": { "$ref": "#/$defs/environment_layer_kind" },
        "variable_keys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "provenance": { "$ref": "#/$defs/auth_source_provenance" },
        "overrides_lower": { "type": "boolean" }
      }
    },
    "environment_set_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment_id",
        "base_url_ref",
        "layers",
        "secret_handle_refs",
        "effective_fingerprint_ref",
        "previewable",
        "excludes_raw_secrets_from_export"
      ],
      "properties": {
        "environment_id": { "type": "string" },
        "base_url_ref": { "type": "string" },
        "layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/environment_layer_row" }
        },
        "secret_handle_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "effective_fingerprint_ref": { "type": "string" },
        "previewable": { "type": "boolean" },
        "excludes_raw_secrets_from_export": { "type": "boolean" }
      }
    },
    "auth_source_inspector_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auth_source_id",
        "auth_mode",
        "broker_handle_refs",
        "refresh_metadata_visible",
        "mtls_signing_refs",
        "visible_without_secret",
        "provenance"
      ],
      "properties": {
        "auth_source_id": { "type": "string" },
        "auth_mode": { "$ref": "#/$defs/auth_source_mode" },
        "broker_handle_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "refresh_metadata_visible": { "type": "boolean" },
        "mtls_signing_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "visible_without_secret": { "type": "boolean" },
        "provenance": { "$ref": "#/$defs/auth_source_provenance" },
        "policy_blocked_reason": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      }
    },
    "effective_request_inspector_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "shows_document_values",
        "shows_workspace_defaults",
        "shows_policy_injected",
        "shows_ad_hoc_overrides",
        "shows_secret_handles",
        "visible_before_send",
        "preserves_provenance_in_export"
      ],
      "properties": {
        "case_id": { "type": "string" },
        "shows_document_values": { "type": "boolean" },
        "shows_workspace_defaults": { "type": "boolean" },
        "shows_policy_injected": { "type": "boolean" },
        "shows_ad_hoc_overrides": { "type": "boolean" },
        "shows_secret_handles": { "type": "boolean" },
        "visible_before_send": { "type": "boolean" },
        "preserves_provenance_in_export": { "type": "boolean" }
      }
    },
    "schema_snapshot_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_id",
        "source_kind",
        "digest_ref",
        "freshness_state",
        "target_endpoint_ref",
        "stale_labeled",
        "may_masquerade_as_live"
      ],
      "properties": {
        "snapshot_id": { "type": "string" },
        "source_kind": { "type": "string" },
        "digest_ref": { "type": "string" },
        "freshness_state": { "type": "string" },
        "target_endpoint_ref": { "type": "string" },
        "stale_labeled": { "type": "boolean" },
        "may_masquerade_as_live": { "type": "boolean" }
      }
    },
    "request_qualification_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promoted_surface_count",
        "stable_surface_count",
        "narrowed_surface_count",
        "document_count",
        "environment_set_count",
        "auth_source_count",
        "effective_inspector_count",
        "schema_snapshot_count"
      ],
      "properties": {
        "promoted_surface_count": { "type": "integer", "minimum": 0 },
        "stable_surface_count": { "type": "integer", "minimum": 0 },
        "narrowed_surface_count": { "type": "integer", "minimum": 0 },
        "document_count": { "type": "integer", "minimum": 0 },
        "environment_set_count": { "type": "integer", "minimum": 0 },
        "auth_source_count": { "type": "integer", "minimum": 0 },
        "effective_inspector_count": { "type": "integer", "minimum": 0 },
        "schema_snapshot_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
