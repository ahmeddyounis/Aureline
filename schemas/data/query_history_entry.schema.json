{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/data/query_history_entry.schema.json",
  "title": "Aureline database query-history entry boundary",
  "description": "Boundary schema for one database query_history_entry_record frozen in docs/data/sql_query_history_contract.md and composed with docs/data/database_tooling_contract.md. Every database tool surface that records a previously-run SQL statement, replay baseline, or AI-tool-proposed statement-pending-admit emits exactly this shape so reviewers can see the captured connection class, engine and version, execution origin, statement template posture, parameter-placeholder posture, statement safety class, result-size summary, replay drift risk, retention bounds, clear-history scopes, and privacy/redaction state before a replay, export, notebook handoff, incident handoff, or audit packet is produced. Raw statement bodies, raw user-supplied literals, raw bind-value bytes, raw fully-qualified object names that disclose tenant identity, raw connection strings, raw auth handles, and raw row payloads never cross this boundary. Statement bodies are kept in a local statement-body store and surfaced through body_label_opaque_ref into a redaction-aware label registry; bind values are kept by reference through bind_value_set_label_opaque_ref. Composes with schemas/data/connection_profile.schema.json by reference, schemas/data/statement_safety_result.schema.json by reference, schemas/data/result_grid.schema.json by reference, and schemas/data/query_replay_mode.schema.json by reference. Adding a new entry_source_class, execution_origin_class, statement_template_posture_class, parameter_placeholder_posture_class, replay_drift_risk_class, retention_class, sharing_posture_class, redactable_literal_handling_class, history_storage_mode_class, retention_limit_class, clear_history_scope_class, support_export_behavior_class, link_copy_policy_class, audit_event_id, or denial_reason_class is additive-minor and bumps query_history_entry_schema_version; repurposing an existing value is breaking and requires a new decision row co-signed by security_trust_review and product_scope_review.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/query_history_entry_record" },
    { "$ref": "#/$defs/query_history_entry_audit_event_record" }
  ],
  "$defs": {
    "query_history_entry_schema_version": {
      "type": "integer",
      "const": 2
    },

    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$",
      "description": "Opaque, stable id safe to log, export, and include in support packets. Raw URLs, hostnames, IPs, ports, user names, statement bodies, literals, bind values, row payloads, raw auth material, and absolute paths never appear here."
    },

    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },

    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 720,
      "description": "Short reviewer-facing sentence safe for local history, export previews, support packets, and audit packets. Raw statement bodies, raw bind values, raw row payloads, raw object names that disclose tenant identity, and raw secret material MUST NOT appear."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "execution_origin_class": {
      "type": "string",
      "enum": [
        "desktop_sql_editor",
        "cli_runner",
        "ai_tool_review_surface",
        "automation_run_review_surface",
        "extension_host_runner",
        "support_export_reader",
        "admin_audit_reader",
        "hosted_review_reader",
        "notebook_kernel_handoff_target"
      ]
    },

    "entry_source_class": {
      "type": "string",
      "enum": [
        "user_authored_local",
        "workspace_shared_committed",
        "ai_tool_proposed_pending_user_admit",
        "captured_from_replay_baseline",
        "captured_from_support_export",
        "captured_from_automation_run",
        "captured_from_hosted_review",
        "imported_from_export_bundle",
        "session_restore_replay"
      ]
    },

    "connection_class": {
      "type": "string",
      "enum": [
        "user_authored_local_profile",
        "workspace_shared_committed_profile",
        "org_curated_admin_published_profile",
        "managed_workspace_provisioned_profile",
        "imported_from_export_bundle_profile",
        "ad_hoc_session_profile",
        "ai_tool_proposed_profile_pending_review"
      ]
    },

    "engine_class": {
      "type": "string",
      "enum": [
        "postgres",
        "mysql_or_mariadb",
        "sqlserver",
        "oracle_database",
        "sqlite_local_file",
        "duckdb_local_file",
        "snowflake_warehouse",
        "bigquery_warehouse",
        "redshift_warehouse",
        "databricks_warehouse",
        "clickhouse",
        "cockroachdb",
        "mongodb_document_store",
        "cassandra_or_scylla",
        "engine_class_unknown_requires_review"
      ]
    },

    "environment_class": {
      "type": "string",
      "enum": [
        "production_environment",
        "staging_environment",
        "qa_environment",
        "development_environment",
        "ephemeral_review_environment",
        "local_workstation_environment",
        "shared_demo_environment",
        "environment_class_unknown_requires_review"
      ]
    },

    "boundary_label_class": {
      "type": "string",
      "enum": [
        "internal_safe_default",
        "internal_sensitive_data",
        "regulated_pii_or_phi",
        "regulated_financial_or_payment",
        "production_blast_radius_high",
        "production_blast_radius_low_read_only_replica",
        "shared_demo_seeded_data_only",
        "ephemeral_disposable_environment",
        "boundary_label_unknown_requires_review"
      ]
    },

    "write_capability_posture_class": {
      "type": "string",
      "enum": [
        "read_only_capability_only",
        "read_only_with_session_override",
        "write_capable_with_safety_net",
        "write_capable_no_safety_net",
        "write_capable_unknown_requires_review"
      ]
    },

    "statement_template_posture_class": {
      "type": "string",
      "enum": [
        "template_only_no_literals_inlined",
        "template_with_named_bind_values",
        "template_with_positional_bind_values",
        "literal_inlined_no_template",
        "mixed_template_and_inlined_literals_user_review_required",
        "statement_template_posture_unknown_requires_review"
      ],
      "description": "Closed statement-template-vs-literal posture. Template rows keep user-supplied literals out of the statement body; literal_inlined_no_template carries literals inside a local-only body store and forces redaction handling; mixed posture denies share/export until resolved."
    },

    "parameter_placeholder_posture_class": {
      "type": "string",
      "enum": [
        "no_parameters_present",
        "named_placeholders_preserved",
        "positional_placeholders_preserved",
        "driver_native_placeholders_preserved",
        "literals_parameterized_by_history_store",
        "mixed_placeholders_and_inlined_literals_review_required",
        "placeholder_posture_unknown_requires_review"
      ],
      "description": "Closed placeholder posture. It distinguishes a template that genuinely preserves placeholders from a statement whose literals were later parameterized by the history store, and from mixed inlined/placeholder states that require review."
    },

    "statement_safety_class": {
      "type": "string",
      "enum": [
        "read_only_query",
        "read_only_pure_metadata_introspection",
        "data_manipulation_insert",
        "data_manipulation_update",
        "data_manipulation_delete",
        "data_manipulation_merge_or_upsert",
        "data_definition_create",
        "data_definition_alter",
        "data_definition_drop",
        "data_definition_truncate",
        "data_control_grant_or_revoke",
        "session_setting_change",
        "transaction_control_statement",
        "explain_or_plan_only_no_execution",
        "stored_procedure_or_function_call_unknown_side_effects",
        "multi_statement_script_mixed_classes",
        "ambiguous_class_user_review_required",
        "blocked_class_not_admissible_on_this_connection"
      ]
    },

    "replay_drift_risk_class": {
      "type": "string",
      "enum": [
        "no_drift_risk_pure_read_only_metadata",
        "low_drift_risk_pure_select_idempotent",
        "moderate_drift_risk_select_with_now_or_random",
        "moderate_drift_risk_select_against_changing_dataset",
        "high_drift_risk_dml_or_ddl_will_re_execute",
        "high_drift_risk_engine_or_version_changed_since_capture",
        "high_drift_risk_connection_class_changed_since_capture",
        "high_drift_risk_auth_context_changed_since_capture",
        "high_drift_risk_policy_epoch_expired_since_capture",
        "drift_risk_unknown_requires_review"
      ],
      "description": "Closed replay-drift risk class. The replay surface paints this next to every rerun/review option; mutation, engine/version drift, connection-class drift, auth-context drift, and policy-epoch expiry never collapse into a generic rerun label."
    },

    "row_count_truth_class": {
      "type": "string",
      "enum": [
        "row_count_exact_total_known",
        "row_count_exact_returned_only_total_unknown",
        "row_count_estimate_engine_provided",
        "row_count_estimate_planner_provided",
        "row_count_unknown_streaming_in_flight",
        "row_count_truth_class_unknown_requires_review"
      ]
    },

    "truncation_state_class": {
      "type": "string",
      "enum": [
        "no_truncation_full_result_set",
        "row_truncated_user_admit_required_to_continue",
        "row_truncated_engine_capped",
        "row_truncated_provider_capped",
        "row_truncated_size_budget_capped",
        "row_truncated_time_budget_capped",
        "cell_truncated_open_in_detail",
        "result_set_paged_more_pages_available",
        "result_set_streaming_open_buffer",
        "result_set_streaming_buffer_dropped_oldest",
        "truncation_state_unknown_requires_review"
      ]
    },

    "result_size_class": {
      "type": "string",
      "enum": [
        "no_result_returned",
        "small_result_bounded",
        "medium_result_bounded",
        "large_result_bounded",
        "large_result_truncated",
        "streaming_result_partial",
        "mutation_count_only",
        "result_size_unknown_requires_review"
      ]
    },

    "returned_row_count_bucket": {
      "type": "string",
      "enum": [
        "row_count_zero",
        "row_count_one",
        "row_count_tens",
        "row_count_hundreds",
        "row_count_thousands",
        "row_count_tens_of_thousands",
        "row_count_hundreds_of_thousands_or_more",
        "row_count_unknown"
      ]
    },

    "byte_size_bucket": {
      "type": "string",
      "enum": [
        "bytes_none",
        "bytes_under_64_kib",
        "bytes_64_kib_to_10_mib",
        "bytes_10_mib_to_1_gib",
        "bytes_over_1_gib",
        "bytes_unknown"
      ]
    },

    "retention_class": {
      "type": "string",
      "enum": [
        "local_only_default_no_remote_retention",
        "local_only_redactable_on_user_request",
        "workspace_shared_committed_explicit_admit",
        "workspace_shared_with_literal_redaction_required",
        "support_export_redacted_only",
        "managed_admin_published_read_only_no_export",
        "audit_only_no_user_facing_replay",
        "retention_class_unknown_requires_review"
      ],
      "description": "Closed retention-class vocabulary. local_only_default_no_remote_retention is the default. user_authored_local entry sources MUST resolve to local_only_* . support_export_redacted_only forces a non-disclosing literal-handling class and support-export projection storage."
    },

    "sharing_posture_class": {
      "type": "string",
      "enum": [
        "local_only_no_share",
        "workspace_share_explicit_admit_required",
        "org_share_admin_governed",
        "support_export_redacted_only",
        "managed_admin_published_read_only_no_export",
        "share_disabled_by_policy"
      ]
    },

    "redactable_literal_handling_class": {
      "type": "string",
      "enum": [
        "literal_redacted_at_boundary_default",
        "literal_hashed_with_local_salt",
        "literal_kept_in_local_store_only",
        "literal_disclosed_with_explicit_user_opt_in",
        "literal_handling_unknown_requires_review"
      ],
      "description": "Closed literal-handling vocabulary. literal_redacted_at_boundary_default is the default at the boundary; literal_kept_in_local_store_only keeps literals in the per-workspace store and never crosses the boundary; literal_disclosed_with_explicit_user_opt_in is admissible only on user-authored local entries."
    },

    "history_storage_mode_class": {
      "type": "string",
      "enum": [
        "local_first_workspace_store_default",
        "local_first_user_profile_store",
        "workspace_shared_committed_store_explicit_admit",
        "managed_policy_audit_reference_only",
        "support_export_projection_redacted",
        "storage_mode_unknown_requires_review"
      ],
      "description": "Closed storage-mode projection for query history. Local-first storage is the default; support export uses a redacted projection rather than copying the local history store."
    },

    "retention_limit_class": {
      "type": "string",
      "enum": [
        "bounded_by_count_and_age_default",
        "bounded_by_session_window",
        "user_pinned_until_clear",
        "admin_policy_locked_until_expiry",
        "support_export_packet_lifetime",
        "audit_only_policy_retained",
        "retention_limit_unknown_requires_review"
      ]
    },

    "clear_history_scope_class": {
      "type": "string",
      "enum": [
        "clear_selected_entry_only",
        "clear_current_connection_history",
        "clear_current_workspace_history",
        "clear_all_local_query_history",
        "clear_support_export_projection",
        "clear_policy_locked_not_user_clearable"
      ]
    },

    "support_export_behavior_class": {
      "type": "string",
      "enum": [
        "support_export_metadata_only_default",
        "support_export_redacted_template_and_refs",
        "support_export_hashed_literals_with_local_salt",
        "support_export_requires_explicit_literal_opt_in",
        "support_export_blocked_by_policy",
        "support_export_not_applicable_local_only"
      ]
    },

    "link_copy_policy_class": {
      "type": "string",
      "enum": [
        "refs_only_no_raw_literals_default",
        "redacted_summaries_only",
        "explicit_user_opt_in_required_for_literal_copy",
        "blocked_by_policy"
      ],
      "description": "Closed linkage copy policy. Downstream explain-plan views, exports, notebooks, incidents, and audit packets cite refs by default instead of copying raw statements, raw literals, row payloads, or credentials."
    },

    "audit_event_id": {
      "type": "string",
      "enum": [
        "query_history_entry_recorded",
        "query_history_entry_replayed",
        "query_history_entry_replay_blocked_pending_drift_review",
        "query_history_entry_opened_for_review_only",
        "query_history_entry_shared",
        "query_history_entry_share_blocked",
        "query_history_entry_clear_scope_applied",
        "query_history_entry_clear_blocked_by_policy",
        "query_history_entry_support_export_projected",
        "query_history_entry_audit_denial_emitted",
        "query_history_entry_redacted_for_export"
      ]
    },

    "denial_reason_class": {
      "type": "string",
      "enum": [
        "replay_must_disclose_drift_risk",
        "replay_must_pin_connection_profile_id",
        "replay_must_pin_captured_engine_version",
        "replay_must_pin_auth_context",
        "share_must_redact_inlined_literals",
        "share_must_resolve_mixed_template_posture",
        "managed_admin_published_must_not_carry_user_editable_literal",
        "ai_tool_proposed_must_not_replay_pending_user_admit",
        "support_export_literal_disclosure_requires_explicit_opt_in",
        "support_export_must_use_redacted_projection",
        "clear_scope_locked_by_policy",
        "policy_epoch_expired_re_evaluation_required",
        "workspace_trust_unset_or_restricted"
      ]
    },

    "captured_engine_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captured_engine_class",
        "captured_engine_version_label",
        "captured_at"
      ],
      "properties": {
        "captured_engine_class": { "$ref": "#/$defs/engine_class" },
        "captured_engine_version_label": {
          "$ref": "#/$defs/reviewable_sentence",
          "description": "Engine-version label observed at capture time. Used by the replay path to compute drift against the currently bound connection's engine version."
        },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    },

    "captured_connection_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captured_connection_profile_id_ref",
        "captured_connection_class",
        "captured_environment_class",
        "captured_boundary_label_class",
        "captured_write_capability_posture_class",
        "captured_engine_class",
        "captured_engine_version_label",
        "captured_at",
        "connection_context_disclosure"
      ],
      "properties": {
        "captured_connection_profile_id_ref": { "$ref": "#/$defs/opaque_id" },
        "captured_connection_label_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "captured_connection_class": { "$ref": "#/$defs/connection_class" },
        "captured_environment_class": { "$ref": "#/$defs/environment_class" },
        "captured_boundary_label_class": { "$ref": "#/$defs/boundary_label_class" },
        "captured_write_capability_posture_class": { "$ref": "#/$defs/write_capability_posture_class" },
        "captured_engine_class": { "$ref": "#/$defs/engine_class" },
        "captured_engine_version_label": { "$ref": "#/$defs/reviewable_sentence" },
        "captured_auth_context_fingerprint_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "captured_policy_epoch_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "connection_context_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "description": "Production captures must retain a production or regulated boundary label.",
          "if": {
            "properties": {
              "captured_environment_class": { "const": "production_environment" }
            },
            "required": [ "captured_environment_class" ]
          },
          "then": {
            "properties": {
              "captured_boundary_label_class": {
                "enum": [
                  "production_blast_radius_high",
                  "production_blast_radius_low_read_only_replica",
                  "regulated_pii_or_phi",
                  "regulated_financial_or_payment"
                ]
              }
            }
          }
        },
        {
          "description": "Production low-blast-radius read replica labels require read-only capability.",
          "if": {
            "properties": {
              "captured_boundary_label_class": { "const": "production_blast_radius_low_read_only_replica" }
            },
            "required": [ "captured_boundary_label_class" ]
          },
          "then": {
            "properties": {
              "captured_write_capability_posture_class": { "const": "read_only_capability_only" }
            }
          }
        }
      ]
    },

    "captured_safety_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement_safety_class",
        "statement_safety_result_id_ref",
        "safety_disclosure"
      ],
      "properties": {
        "statement_safety_class": { "$ref": "#/$defs/statement_safety_class" },
        "statement_safety_result_id_ref": { "$ref": "#/$defs/opaque_id" },
        "safety_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "result_size_summary_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_size_class",
        "row_count_truth_class",
        "returned_row_count_bucket",
        "byte_size_bucket",
        "truncation_state_class",
        "result_summary_disclosure"
      ],
      "properties": {
        "result_size_class": { "$ref": "#/$defs/result_size_class" },
        "row_count_truth_class": { "$ref": "#/$defs/row_count_truth_class" },
        "returned_row_count_bucket": { "$ref": "#/$defs/returned_row_count_bucket" },
        "byte_size_bucket": { "$ref": "#/$defs/byte_size_bucket" },
        "truncation_state_class": { "$ref": "#/$defs/truncation_state_class" },
        "result_grid_id_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "result_summary_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "replay_baseline_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replay_drift_risk_class",
        "captured_engine",
        "drift_disclosure"
      ],
      "properties": {
        "replay_drift_risk_class": { "$ref": "#/$defs/replay_drift_risk_class" },
        "captured_engine": { "$ref": "#/$defs/captured_engine_envelope" },
        "captured_connection_profile_id_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "captured_statement_safety_class_label": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ],
          "description": "Reviewable label naming the statement_safety_class observed at capture time. Used by the replay path to disclose drift against the current classification before a rerun executes."
        },
        "drift_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "retention_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "retention_class",
        "sharing_posture_class",
        "redactable_literal_handling_class",
        "history_storage_mode_class",
        "retention_limit_class",
        "max_retained_entries",
        "max_age_days",
        "clear_history_scope_classes",
        "support_export_behavior_class",
        "retention_disclosure",
        "privacy_disclosure"
      ],
      "properties": {
        "retention_class": { "$ref": "#/$defs/retention_class" },
        "sharing_posture_class": { "$ref": "#/$defs/sharing_posture_class" },
        "redactable_literal_handling_class": { "$ref": "#/$defs/redactable_literal_handling_class" },
        "history_storage_mode_class": { "$ref": "#/$defs/history_storage_mode_class" },
        "retention_limit_class": { "$ref": "#/$defs/retention_limit_class" },
        "max_retained_entries": {
          "type": "integer",
          "minimum": 0,
          "description": "Upper bound on retained entries for the applicable scope. Zero is allowed only for audit-only or projection rows that retain no local runnable history body."
        },
        "max_age_days": {
          "type": "integer",
          "minimum": 0,
          "description": "Upper bound on local retention age in days. Zero means the row is projection-only or controlled by an external audit/support packet lifetime."
        },
        "clear_history_scope_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/clear_history_scope_class" }
        },
        "support_export_behavior_class": { "$ref": "#/$defs/support_export_behavior_class" },
        "retention_disclosure": { "$ref": "#/$defs/reviewable_sentence" },
        "privacy_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "description": "support_export_redacted_only retention uses a redacted projection store and non-disclosing export behavior.",
          "if": {
            "properties": {
              "retention_class": { "const": "support_export_redacted_only" }
            },
            "required": [ "retention_class" ]
          },
          "then": {
            "properties": {
              "history_storage_mode_class": { "const": "support_export_projection_redacted" },
              "support_export_behavior_class": {
                "enum": [
                  "support_export_metadata_only_default",
                  "support_export_redacted_template_and_refs",
                  "support_export_hashed_literals_with_local_salt"
                ]
              },
              "redactable_literal_handling_class": {
                "enum": [
                  "literal_redacted_at_boundary_default",
                  "literal_hashed_with_local_salt",
                  "literal_kept_in_local_store_only"
                ]
              }
            }
          }
        }
      ]
    },

    "linkage_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "copy_policy_class",
        "explain_plan_view_refs",
        "result_export_refs",
        "notebook_refs",
        "incident_refs",
        "audit_packet_refs"
      ],
      "properties": {
        "copy_policy_class": { "$ref": "#/$defs/link_copy_policy_class" },
        "explain_plan_view_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "result_export_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "notebook_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "incident_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "audit_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "linkage_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "query_history_entry_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "query_history_entry_id",
        "bound_connection_profile_id_ref",
        "actor_ref",
        "command_id_ref",
        "execution_origin_class",
        "entry_source_class",
        "captured_connection",
        "statement_template_posture_class",
        "parameter_placeholder_posture_class",
        "body_label_opaque_ref",
        "replay_baseline",
        "replay_mode_refs",
        "captured_safety",
        "result_size_summary",
        "retention",
        "linkages",
        "redaction_class",
        "captured_at",
        "narrative_refs"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/query_history_entry_schema_version" },
        "record_kind": {
          "type": "string",
          "const": "query_history_entry_record"
        },
        "query_history_entry_id": { "$ref": "#/$defs/opaque_id" },
        "bound_connection_profile_id_ref": { "$ref": "#/$defs/opaque_id" },
        "actor_ref": { "$ref": "#/$defs/opaque_id" },
        "command_id_ref": { "$ref": "#/$defs/opaque_id" },
        "execution_origin_class": { "$ref": "#/$defs/execution_origin_class" },
        "entry_source_class": { "$ref": "#/$defs/entry_source_class" },
        "captured_connection": { "$ref": "#/$defs/captured_connection_envelope" },
        "statement_template_posture_class": { "$ref": "#/$defs/statement_template_posture_class" },
        "parameter_placeholder_posture_class": { "$ref": "#/$defs/parameter_placeholder_posture_class" },
        "body_label_opaque_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque ref into the per-workspace statement-body label registry. Raw statement bodies, raw bind values, and raw user-supplied literals MUST NOT appear here."
        },
        "bind_value_set_label_opaque_ref": {
          "$ref": "#/$defs/nullable_opaque_id",
          "description": "Required non-null when placeholder or template posture indicates bind values or history-store parameterization. Raw bind-value bytes MUST NOT appear here."
        },
        "replay_baseline": { "$ref": "#/$defs/replay_baseline_envelope" },
        "replay_mode_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" },
          "description": "Refs to query_replay_mode_record rows that declare exact rerun, current-context rerun, review-only, or blocked replay posture."
        },
        "captured_safety": { "$ref": "#/$defs/captured_safety_envelope" },
        "result_size_summary": { "$ref": "#/$defs/result_size_summary_envelope" },
        "retention": { "$ref": "#/$defs/retention_envelope" },
        "linkages": { "$ref": "#/$defs/linkage_envelope" },
        "last_statement_safety_result_id_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "last_result_grid_id_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "linked_run_record_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "export_safe": { "type": "boolean", "default": true },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "last_replay_record_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "last_replayed_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/monotonic_timestamp" }
          ],
          "description": "Timestamp of the most recent admitted replay. The matched replay-mode or audit record is cited through last_replay_record_ref."
        },
        "narrative_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "notes": { "type": "string" },
        "__fixture__": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "description": "user_authored_local entry sources MUST resolve to local-only retention, local-first storage, and local-only sharing.",
          "if": {
            "properties": {
              "entry_source_class": { "const": "user_authored_local" }
            },
            "required": [ "entry_source_class" ]
          },
          "then": {
            "properties": {
              "retention": {
                "properties": {
                  "retention_class": {
                    "enum": [
                      "local_only_default_no_remote_retention",
                      "local_only_redactable_on_user_request"
                    ]
                  },
                  "sharing_posture_class": { "const": "local_only_no_share" },
                  "history_storage_mode_class": {
                    "enum": [
                      "local_first_workspace_store_default",
                      "local_first_user_profile_store"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "description": "captured_from_support_export entry source MUST resolve to support_export_redacted_only retention and a non-disclosing literal-handling class.",
          "if": {
            "properties": {
              "entry_source_class": { "const": "captured_from_support_export" }
            },
            "required": [ "entry_source_class" ]
          },
          "then": {
            "properties": {
              "retention": {
                "properties": {
                  "retention_class": { "const": "support_export_redacted_only" },
                  "history_storage_mode_class": { "const": "support_export_projection_redacted" },
                  "redactable_literal_handling_class": {
                    "enum": [
                      "literal_redacted_at_boundary_default",
                      "literal_hashed_with_local_salt",
                      "literal_kept_in_local_store_only"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "description": "ai_tool_proposed_pending_user_admit entry source MUST NOT carry replay timestamps; the entry is non-executable until user admission.",
          "if": {
            "properties": {
              "entry_source_class": { "const": "ai_tool_proposed_pending_user_admit" }
            },
            "required": [ "entry_source_class" ]
          },
          "then": {
            "properties": {
              "last_replay_record_ref": { "type": "null" },
              "last_replayed_at": { "type": "null" }
            }
          }
        },
        {
          "description": "Template-posture with named or positional bind values MUST cite a non-null bind_value_set_label_opaque_ref.",
          "if": {
            "properties": {
              "statement_template_posture_class": {
                "enum": [
                  "template_with_named_bind_values",
                  "template_with_positional_bind_values"
                ]
              }
            },
            "required": [ "statement_template_posture_class" ]
          },
          "then": {
            "required": [ "bind_value_set_label_opaque_ref" ],
            "properties": {
              "bind_value_set_label_opaque_ref": { "not": { "type": "null" } }
            }
          }
        },
        {
          "description": "Placeholder posture that preserves or creates parameters MUST cite a non-null bind_value_set_label_opaque_ref.",
          "if": {
            "properties": {
              "parameter_placeholder_posture_class": {
                "enum": [
                  "named_placeholders_preserved",
                  "positional_placeholders_preserved",
                  "driver_native_placeholders_preserved",
                  "literals_parameterized_by_history_store"
                ]
              }
            },
            "required": [ "parameter_placeholder_posture_class" ]
          },
          "then": {
            "required": [ "bind_value_set_label_opaque_ref" ],
            "properties": {
              "bind_value_set_label_opaque_ref": { "not": { "type": "null" } }
            }
          }
        },
        {
          "description": "literal_inlined_no_template and mixed-template postures forbid org-share and managed-published sharing so literals never silently cross a workspace or org boundary.",
          "if": {
            "properties": {
              "statement_template_posture_class": {
                "enum": [
                  "literal_inlined_no_template",
                  "mixed_template_and_inlined_literals_user_review_required"
                ]
              }
            },
            "required": [ "statement_template_posture_class" ]
          },
          "then": {
            "properties": {
              "retention": {
                "properties": {
                  "sharing_posture_class": {
                    "enum": [
                      "local_only_no_share",
                      "workspace_share_explicit_admit_required",
                      "support_export_redacted_only",
                      "share_disabled_by_policy"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "description": "literal_disclosed_with_explicit_user_opt_in is admissible only when entry_source_class is user_authored_local.",
          "if": {
            "properties": {
              "retention": {
                "properties": {
                  "redactable_literal_handling_class": { "const": "literal_disclosed_with_explicit_user_opt_in" }
                },
                "required": [ "redactable_literal_handling_class" ]
              }
            },
            "required": [ "retention" ]
          },
          "then": {
            "properties": {
              "entry_source_class": { "const": "user_authored_local" }
            }
          }
        }
      ]
    },

    "query_history_entry_audit_event_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "audit_event_id",
        "bound_query_history_entry_id_ref",
        "actor_ref",
        "command_id_ref",
        "event_note",
        "recorded_at",
        "redaction_class",
        "narrative_refs"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/query_history_entry_schema_version" },
        "record_kind": {
          "type": "string",
          "const": "query_history_entry_audit_event_record"
        },
        "audit_event_id": { "$ref": "#/$defs/audit_event_id" },
        "bound_query_history_entry_id_ref": { "$ref": "#/$defs/opaque_id" },
        "actor_ref": { "$ref": "#/$defs/opaque_id" },
        "command_id_ref": { "$ref": "#/$defs/opaque_id" },
        "denial_reason_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/denial_reason_class" }
          ]
        },
        "event_note": { "$ref": "#/$defs/reviewable_sentence" },
        "recorded_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "export_safe": { "type": "boolean", "default": true },
        "narrative_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "notes": { "type": "string" },
        "__fixture__": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "description": "Denial-class audit events MUST cite a non-null denial_reason_class.",
          "if": {
            "properties": {
              "audit_event_id": {
                "enum": [
                  "query_history_entry_replay_blocked_pending_drift_review",
                  "query_history_entry_share_blocked",
                  "query_history_entry_clear_blocked_by_policy",
                  "query_history_entry_audit_denial_emitted"
                ]
              }
            },
            "required": [ "audit_event_id" ]
          },
          "then": {
            "required": [ "denial_reason_class" ],
            "properties": {
              "denial_reason_class": { "not": { "type": "null" } }
            }
          }
        },
        {
          "description": "Non-denial audit events MUST leave denial_reason_class null so denial vocabulary is never used as a generic free-text channel.",
          "if": {
            "properties": {
              "audit_event_id": {
                "enum": [
                  "query_history_entry_recorded",
                  "query_history_entry_replayed",
                  "query_history_entry_opened_for_review_only",
                  "query_history_entry_shared",
                  "query_history_entry_clear_scope_applied",
                  "query_history_entry_support_export_projected",
                  "query_history_entry_redacted_for_export"
                ]
              }
            },
            "required": [ "audit_event_id" ]
          },
          "then": {
            "properties": {
              "denial_reason_class": { "type": "null" }
            }
          }
        }
      ]
    }
  }
}
