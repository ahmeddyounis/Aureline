{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/data/implement-connection-browsers-schema-trees-and-target-context-envelopes-for-database-tooling.schema.json",
  "title": "Aureline connection browsers, schema trees, and target-context envelope packet",
  "description": "Boundary schema for connection browsers, schema trees, and target-context envelopes for database tooling. Raw endpoint URLs, raw secrets, raw credential bodies, and raw connection strings do not appear in this packet; payloads require explicit drill-down or export review.",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "as_of",
    "release_doc_ref",
    "help_doc_ref",
    "schema_ref",
    "surfaces",
    "connection_browsers",
    "schema_trees",
    "target_context_envelopes",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "connection_browsers_schema_trees_and_target_context_envelopes_for_database_tooling" },
    "packet_id": { "$ref": "#/$defs/opaque_id" },
    "as_of": { "type": "string", "format": "date" },
    "release_doc_ref": { "$ref": "#/$defs/path_ref" },
    "help_doc_ref": { "$ref": "#/$defs/path_ref" },
    "schema_ref": { "$ref": "#/$defs/path_ref" },
    "surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/database_browser_surface_qualification_row" }
    },
    "connection_browsers": {
      "type": "array",
      "items": { "$ref": "#/$defs/connection_browser_row" }
    },
    "schema_trees": {
      "type": "array",
      "items": { "$ref": "#/$defs/schema_tree_row" }
    },
    "target_context_envelopes": {
      "type": "array",
      "items": { "$ref": "#/$defs/target_context_envelope_row" }
    },
    "summary": { "$ref": "#/$defs/database_browser_qualification_summary" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "path_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "reviewable": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },
    "database_browser_qualification_label": {
      "type": "string",
      "enum": ["stable", "preview", "labs", "inspect_only", "import_only"]
    },
    "database_browser_surface_kind": {
      "type": "string",
      "enum": [
        "connection_browser",
        "schema_tree",
        "target_context_envelope"
      ]
    },
    "database_browser_connection_class": {
      "type": "string",
      "enum": [
        "embedded_local",
        "local_network_container_dev",
        "remote_controlled_env",
        "cloud_warehouse",
        "imported_snapshot"
      ]
    },
    "database_browser_auth_source_mode": {
      "type": "string",
      "enum": [
        "no_auth_local_file",
        "secret_broker_handle",
        "delegated_identity",
        "policy_injected_credential",
        "managed_service_identity",
        "imported_no_live_auth",
        "policy_blocked"
      ]
    },
    "database_browser_write_posture": {
      "type": "string",
      "enum": ["read_only", "write_capable", "policy_blocked"]
    },
    "database_browser_statement_safety_class": {
      "type": "string",
      "enum": [
        "read_only_query",
        "dml",
        "ddl",
        "session_affecting",
        "multi_statement",
        "ambiguous",
        "blocked"
      ]
    },
    "database_browser_transaction_posture": {
      "type": "string",
      "enum": [
        "autocommit",
        "explicit_transaction",
        "explain_only",
        "not_executable",
        "unknown_requires_review"
      ]
    },
    "database_browser_result_scope": {
      "type": "string",
      "enum": [
        "full_result",
        "visible_rows_only",
        "truncated",
        "streaming_unknown_total",
        "imported_snapshot"
      ]
    },
    "database_browser_redaction_mode": {
      "type": "string",
      "enum": [
        "metadata_only",
        "redacted_typed",
        "reviewed_visible_values",
        "policy_blocked"
      ]
    },
    "database_browser_qualification_proof": {
      "type": "object",
      "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at", "evidence_refs"],
      "additionalProperties": false,
      "properties": {
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "packet_ref": { "$ref": "#/$defs/path_ref" },
        "proof_index_ref": { "$ref": "#/$defs/path_ref" },
        "captured_at": { "type": "string", "format": "date" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/path_ref" }
        }
      }
    },
    "database_browser_surface_guard_set": {
      "type": "object",
      "required": [
        "connection_class_visible",
        "auth_source_visible",
        "write_posture_visible",
        "target_identity_visible",
        "schema_tree_visible",
        "target_context_envelope_visible",
        "statement_safety_visible",
        "export_redaction_visible"
      ],
      "additionalProperties": false,
      "properties": {
        "connection_class_visible": { "type": "boolean" },
        "auth_source_visible": { "type": "boolean" },
        "write_posture_visible": { "type": "boolean" },
        "target_identity_visible": { "type": "boolean" },
        "schema_tree_visible": { "type": "boolean" },
        "target_context_envelope_visible": { "type": "boolean" },
        "statement_safety_visible": { "type": "boolean" },
        "export_redaction_visible": { "type": "boolean" }
      }
    },
    "database_browser_surface_qualification_row": {
      "type": "object",
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "qualification_packet",
        "guards",
        "downgrade_if_missing",
        "rationale"
      ],
      "additionalProperties": false,
      "properties": {
        "surface_id": { "$ref": "#/$defs/opaque_id" },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "surface_kind": { "$ref": "#/$defs/database_browser_surface_kind" },
        "promoted_build_surface": { "type": "boolean" },
        "claim_label": { "$ref": "#/$defs/database_browser_qualification_label" },
        "displayed_label": { "$ref": "#/$defs/database_browser_qualification_label" },
        "qualification_packet": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/database_browser_qualification_proof" }
          ]
        },
        "guards": { "$ref": "#/$defs/database_browser_surface_guard_set" },
        "downgrade_if_missing": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/reviewable" }
      }
    },
    "connection_browser_row": {
      "type": "object",
      "required": [
        "browser_id",
        "connection_class",
        "auth_source_mode",
        "write_posture",
        "target_identity_ref",
        "engine",
        "current_database_or_schema_ref",
        "schema_tree_supported",
        "target_context_envelope_supported",
        "visible_in_ui"
      ],
      "additionalProperties": false,
      "properties": {
        "browser_id": { "$ref": "#/$defs/opaque_id" },
        "connection_class": { "$ref": "#/$defs/database_browser_connection_class" },
        "auth_source_mode": { "$ref": "#/$defs/database_browser_auth_source_mode" },
        "write_posture": { "$ref": "#/$defs/database_browser_write_posture" },
        "target_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "engine": { "type": "string", "minLength": 1 },
        "current_database_or_schema_ref": { "type": "string", "minLength": 1 },
        "schema_tree_supported": { "type": "boolean" },
        "target_context_envelope_supported": { "type": "boolean" },
        "visible_in_ui": { "type": "boolean" }
      }
    },
    "schema_tree_row": {
      "type": "object",
      "required": [
        "tree_id",
        "source_kind",
        "root_node_ref",
        "depth_limit",
        "node_count_limit",
        "freshness_state",
        "stale_labeled",
        "may_masquerade_as_live",
        "visible_in_ui"
      ],
      "additionalProperties": false,
      "properties": {
        "tree_id": { "$ref": "#/$defs/opaque_id" },
        "source_kind": { "type": "string", "minLength": 1 },
        "root_node_ref": { "type": "string", "minLength": 1 },
        "depth_limit": { "type": "integer", "minimum": 0 },
        "node_count_limit": { "type": "integer", "minimum": 0 },
        "freshness_state": { "type": "string", "minLength": 1 },
        "stale_labeled": { "type": "boolean" },
        "may_masquerade_as_live": { "type": "boolean" },
        "visible_in_ui": { "type": "boolean" }
      }
    },
    "target_context_envelope_row": {
      "type": "object",
      "required": [
        "envelope_id",
        "target_endpoint_ref",
        "connection_class",
        "auth_source_mode",
        "write_posture",
        "statement_safety_class",
        "transaction_posture",
        "result_scope",
        "redaction_mode",
        "visible_before_send",
        "visible_in_ui"
      ],
      "additionalProperties": false,
      "properties": {
        "envelope_id": { "$ref": "#/$defs/opaque_id" },
        "target_endpoint_ref": { "$ref": "#/$defs/opaque_id" },
        "connection_class": { "$ref": "#/$defs/database_browser_connection_class" },
        "auth_source_mode": { "$ref": "#/$defs/database_browser_auth_source_mode" },
        "write_posture": { "$ref": "#/$defs/database_browser_write_posture" },
        "statement_safety_class": { "$ref": "#/$defs/database_browser_statement_safety_class" },
        "transaction_posture": { "$ref": "#/$defs/database_browser_transaction_posture" },
        "result_scope": { "$ref": "#/$defs/database_browser_result_scope" },
        "redaction_mode": { "$ref": "#/$defs/database_browser_redaction_mode" },
        "visible_before_send": { "type": "boolean" },
        "visible_in_ui": { "type": "boolean" }
      }
    },
    "database_browser_qualification_summary": {
      "type": "object",
      "required": [
        "promoted_surface_count",
        "stable_surface_count",
        "narrowed_surface_count",
        "connection_browser_count",
        "schema_tree_count",
        "target_context_envelope_count"
      ],
      "additionalProperties": false,
      "properties": {
        "promoted_surface_count": { "type": "integer", "minimum": 0 },
        "stable_surface_count": { "type": "integer", "minimum": 0 },
        "narrowed_surface_count": { "type": "integer", "minimum": 0 },
        "connection_browser_count": { "type": "integer", "minimum": 0 },
        "schema_tree_count": { "type": "integer", "minimum": 0 },
        "target_context_envelope_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
