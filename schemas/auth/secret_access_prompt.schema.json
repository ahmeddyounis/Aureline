{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/auth/secret_access_prompt.schema.json",
  "title": "Aureline secret-access prompt contract",
  "description": "Boundary schema for secret_access_prompt_record entries frozen in docs/auth/credential_state_and_secret_prompt_contract.md. A prompt records who is asking for secret authority, which target and scope are affected, which storage and projection posture will be used, how long the authority lasts, what export posture applies, which decision options are available, and the no-raw-secret-echo rules. Raw secret material, passwords, private keys, refresh tokens, OAuth codes, PKCE verifiers, client-certificate private bytes, device secrets, raw request headers, and ambient delegated credentials never appear in prompt records.",
  "$ref": "#/$defs/secret_access_prompt_record",
  "$defs": {
    "secret_access_prompt_schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for logs, RPC, support exports, admin exports, and prompt fixtures."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_timestamp": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/monotonic_timestamp" }
      ]
    },
    "export_safe_label": {
      "type": "string",
      "minLength": 1,
      "description": "Short label safe for UI, logs, support exports, admin exports, and release evidence. Raw secret material and raw provider payloads do not appear."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Short prompt or diagnostics sentence safe for support and admin exports."
    },
    "prompt_action_class": {
      "type": "string",
      "enum": [
        "read_secret",
        "write_secret",
        "rebind_handle",
        "import_credential",
        "unlock_store",
        "approve_step_up_access"
      ],
      "description": "Closed prompt action vocabulary. These are the operations a prompt admits or denies."
    },
    "prompt_initiator_class": {
      "type": "string",
      "enum": [
        "user_initiated",
        "admin_initiated",
        "policy_initiated",
        "system_initiated_repair",
        "automation_requested_pending_user",
        "ai_requested_pending_user"
      ]
    },
    "raw_reveal_posture_class": {
      "type": "string",
      "enum": [
        "not_requested",
        "handle_only_available",
        "protocol_required_projection",
        "reveal_on_demand_user_initiated",
        "forbidden_by_secret_class",
        "blocked_by_policy"
      ]
    },
    "decision_option_class": {
      "type": "string",
      "enum": [
        "allow_once",
        "allow_until_expiry",
        "allow_by_policy",
        "deny",
        "continue_without_secret",
        "unlock_store",
        "import_credential",
        "rebind_handle",
        "open_policy_detail",
        "start_browser_handoff",
        "use_device_code_handoff",
        "contact_admin"
      ]
    },
    "prompt_actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_class",
        "actor_ref",
        "actor_label",
        "surface_ref",
        "consumer_identity_ref",
        "initiator_class"
      ],
      "properties": {
        "actor_class": { "$ref": "./credential_state.schema.json#/$defs/actor_class" },
        "actor_ref": { "$ref": "#/$defs/opaque_id" },
        "actor_label": { "$ref": "#/$defs/export_safe_label" },
        "surface_ref": { "$ref": "#/$defs/opaque_id" },
        "consumer_identity_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "initiator_class": { "$ref": "#/$defs/prompt_initiator_class" }
      }
    },
    "prompt_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_class",
        "target_ref",
        "target_label",
        "secret_class",
        "scope_ref",
        "scope_label",
        "audience_label",
        "target_boundary_note"
      ],
      "properties": {
        "target_class": { "$ref": "./credential_state.schema.json#/$defs/target_class" },
        "target_ref": { "$ref": "#/$defs/opaque_id" },
        "target_label": { "$ref": "#/$defs/export_safe_label" },
        "secret_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "../security/secret_class_rows.schema.json#/$defs/secret_class" }
          ]
        },
        "scope_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "scope_label": { "$ref": "#/$defs/export_safe_label" },
        "audience_label": { "$ref": "#/$defs/export_safe_label" },
        "target_boundary_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "storage_and_projection_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_storage_mode",
        "store_source_class",
        "requested_projection_mode",
        "allowed_projection_modes",
        "raw_material_requested",
        "raw_reveal_posture",
        "handle_only_path_available",
        "source_alias_ref",
        "handle_ref",
        "storage_projection_note"
      ],
      "properties": {
        "requested_storage_mode": { "$ref": "./credential_state.schema.json#/$defs/storage_mode_class" },
        "store_source_class": { "$ref": "./credential_state.schema.json#/$defs/store_source_class" },
        "requested_projection_mode": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "../security/secret_class_rows.schema.json#/$defs/projection_mode" }
          ]
        },
        "allowed_projection_modes": {
          "type": "array",
          "items": { "$ref": "../security/secret_class_rows.schema.json#/$defs/projection_mode" },
          "uniqueItems": true
        },
        "raw_material_requested": { "type": "boolean" },
        "raw_reveal_posture": { "$ref": "#/$defs/raw_reveal_posture_class" },
        "handle_only_path_available": { "type": "boolean" },
        "source_alias_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "handle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "storage_projection_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "lifetime_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lifetime_class",
        "requested_duration_label",
        "expires_at",
        "remember_decision_allowed",
        "renewable_ticket_required",
        "lifetime_note"
      ],
      "properties": {
        "lifetime_class": { "$ref": "./credential_state.schema.json#/$defs/lifetime_class" },
        "requested_duration_label": { "$ref": "#/$defs/export_safe_label" },
        "expires_at": { "$ref": "#/$defs/nullable_timestamp" },
        "remember_decision_allowed": { "type": "boolean" },
        "renewable_ticket_required": { "type": "boolean" },
        "lifetime_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "prompt_export_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handles_aliases_source_labels_may_travel",
        "raw_secret_material_may_travel",
        "private_keys_may_travel",
        "refresh_tokens_may_travel",
        "ambient_delegated_credentials_may_travel",
        "support_export_posture",
        "automation_export_posture",
        "export_note"
      ],
      "properties": {
        "handles_aliases_source_labels_may_travel": { "type": "boolean" },
        "raw_secret_material_may_travel": { "type": "boolean", "const": false },
        "private_keys_may_travel": { "type": "boolean", "const": false },
        "refresh_tokens_may_travel": { "type": "boolean", "const": false },
        "ambient_delegated_credentials_may_travel": { "type": "boolean", "const": false },
        "support_export_posture": { "$ref": "./credential_state.schema.json#/$defs/support_export_posture_class" },
        "automation_export_posture": { "$ref": "./credential_state.schema.json#/$defs/automation_export_posture_class" },
        "export_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "no_raw_secret_echo_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_secret_material_must_not_be_rendered",
        "raw_secret_material_must_not_be_logged",
        "raw_secret_material_must_not_enter_support_exports",
        "prompt_must_not_prepopulate_secret_value",
        "prompt_may_render_alias_handle_source_label",
        "no_raw_secret_echo_note"
      ],
      "properties": {
        "raw_secret_material_must_not_be_rendered": { "type": "boolean", "const": true },
        "raw_secret_material_must_not_be_logged": { "type": "boolean", "const": true },
        "raw_secret_material_must_not_enter_support_exports": { "type": "boolean", "const": true },
        "prompt_must_not_prepopulate_secret_value": { "type": "boolean", "const": true },
        "prompt_may_render_alias_handle_source_label": { "type": "boolean" },
        "no_raw_secret_echo_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "decision_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_options",
        "default_decision",
        "approval_ticket_ref",
        "policy_check_refs",
        "deny_reason_if_declined",
        "local_continuity_note"
      ],
      "properties": {
        "decision_options": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/decision_option_class" },
          "uniqueItems": true
        },
        "default_decision": { "$ref": "#/$defs/decision_option_class" },
        "approval_ticket_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "policy_check_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "deny_reason_if_declined": { "$ref": "#/$defs/reviewable_sentence" },
        "local_continuity_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "prompt_outcome_class": {
      "type": "string",
      "enum": [
        "pending",
        "allowed_once",
        "allowed_until_expiry",
        "allowed_by_policy",
        "denied_by_user",
        "denied_by_policy",
        "cancelled_continue_without_secret",
        "superseded"
      ]
    },
    "secret_access_prompt_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "secret_access_prompt_schema_version",
        "prompt_id",
        "credential_state_ref",
        "action_class",
        "actor",
        "target",
        "storage_and_projection",
        "lifetime",
        "export_posture",
        "no_raw_secret_echo_rules",
        "decision_policy",
        "outcome_class",
        "surface_redaction_class",
        "secret_redaction_class_refs",
        "prompted_at"
      ],
      "properties": {
        "record_kind": { "const": "secret_access_prompt_record" },
        "secret_access_prompt_schema_version": { "$ref": "#/$defs/secret_access_prompt_schema_version" },
        "prompt_id": { "$ref": "#/$defs/opaque_id" },
        "credential_state_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "action_class": { "$ref": "#/$defs/prompt_action_class" },
        "actor": { "$ref": "#/$defs/prompt_actor" },
        "target": { "$ref": "#/$defs/prompt_target" },
        "storage_and_projection": { "$ref": "#/$defs/storage_and_projection_request" },
        "lifetime": { "$ref": "#/$defs/lifetime_request" },
        "export_posture": { "$ref": "#/$defs/prompt_export_posture" },
        "no_raw_secret_echo_rules": { "$ref": "#/$defs/no_raw_secret_echo_rules" },
        "decision_policy": { "$ref": "#/$defs/decision_policy" },
        "outcome_class": { "$ref": "#/$defs/prompt_outcome_class" },
        "surface_redaction_class": { "$ref": "./credential_state.schema.json#/$defs/surface_redaction_class" },
        "secret_redaction_class_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "../security/secret_class_rows.schema.json#/$defs/redaction_class" },
          "uniqueItems": true
        },
        "prompted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    }
  }
}
