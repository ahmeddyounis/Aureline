{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/auth/managed_session_state.schema.json",
  "title": "Aureline managed session state record",
  "description": "Boundary schema for one managed_session_state_record frozen in docs/auth/managed_auth_and_session_continuity_contract.md. The record represents managed authentication as additive capability, not a hidden prerequisite. Every state carries required copy, local edit/save/undo/export continuity rules, managed capability posture, reauth detail when applicable, diagnostic cause separation, and export/offboarding guidance. Raw tokens, raw cookies, raw provider URLs, raw passkey material, raw directory attributes, raw account identifiers, and raw IdP error bodies never cross this boundary.",
  "$ref": "#/$defs/managed_session_state_record",
  "$defs": {
    "managed_session_state_schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for logs, support exports, admin exports, and release evidence."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 UTC timestamp produced from an authoritative or monotonic timestamp source."
    },
    "nullable_timestamp": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/monotonic_timestamp" }
      ]
    },
    "export_safe_label": {
      "type": "string",
      "minLength": 1,
      "description": "Short label safe for UI, support, admin, and release-evidence surfaces. Raw secret, tenant, account, URL, and provider-error payloads MUST NOT appear."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Short reviewable sentence safe for product copy, diagnostics, and support export."
    },
    "identity_mode": {
      "type": "string",
      "enum": [
        "account_free_local",
        "self_hosted_org",
        "managed_workspace"
      ]
    },
    "account_boundary_class": {
      "type": "string",
      "enum": [
        "local_only",
        "self_hosted",
        "managed",
        "restricted_managed_only",
        "grace_degraded_managed",
        "unknown_boundary"
      ]
    },
    "deployment_profile_class": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "managed_cloud",
        "air_gapped"
      ]
    },
    "workspace_trust_state": {
      "type": "string",
      "enum": [
        "trusted",
        "restricted"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "managed_session_state_class": {
      "type": "string",
      "enum": [
        "local_only",
        "signed_in",
        "reauth_required",
        "session_expiring",
        "managed_blocked",
        "revoked",
        "seat_lost",
        "deprovisioned"
      ]
    },
    "flow_class": {
      "type": "string",
      "enum": [
        "managed_sign_in",
        "step_up_auth",
        "session_expiry_dirty_buffers",
        "session_expiry_clean",
        "sign_out",
        "org_switch",
        "seat_transfer",
        "seat_removal",
        "account_deprovisioning",
        "local_only_start",
        "credential_recovery",
        "not_applicable"
      ]
    },
    "flow_posture_class": {
      "type": "string",
      "enum": [
        "system_browser_first",
        "passkey_capable_system_browser",
        "device_code_fallback",
        "local_only_no_auth",
        "policy_update_consumed_locally",
        "admin_provisioning_update",
        "no_silent_signout_review"
      ]
    },
    "system_browser_posture_class": {
      "type": "string",
      "enum": [
        "required",
        "managed_approved_browser_allowed",
        "blocked_visible_recovery",
        "not_applicable_local_only"
      ]
    },
    "embedded_auth_posture_class": {
      "type": "string",
      "enum": [
        "forbidden",
        "approved_exception_visible",
        "not_applicable"
      ]
    },
    "passkey_availability_class": {
      "type": "string",
      "enum": [
        "supported",
        "unsupported_deployment_stack",
        "unsupported_platform_or_authenticator",
        "policy_disabled",
        "unknown_disclose_fallback",
        "not_applicable"
      ]
    },
    "passkey_fallback_rule_class": {
      "type": "string",
      "enum": [
        "system_browser_oidc",
        "device_code_or_equivalent",
        "admin_assisted_recovery",
        "continue_local_only",
        "no_fallback_required",
        "policy_exception_required"
      ]
    },
    "local_artifacts_safety_class": {
      "type": "string",
      "enum": [
        "local_artifacts_safe",
        "local_artifacts_safe_managed_paused",
        "local_artifacts_safe_export_available",
        "local_artifacts_safe_policy_narrowed"
      ]
    },
    "managed_continuation_mode_class": {
      "type": "string",
      "enum": [
        "local_only",
        "managed_current",
        "managed_paused_local_continue",
        "managed_blocked_local_continue",
        "deprovisioned_local_continue"
      ]
    },
    "support_export_failure_class": {
      "type": "string",
      "enum": [
        "none",
        "network_failure",
        "tenant_policy_denied",
        "missing_credential",
        "authenticator_incompatibility",
        "revoked_session",
        "seat_loss",
        "account_deprovisioned",
        "credential_store_locked",
        "callback_mismatch",
        "unknown_auth_error_denied"
      ]
    },
    "export_path_class": {
      "type": "string",
      "enum": [
        "local_export_available",
        "support_export_available",
        "admin_export_available",
        "offboarding_export_available_without_live_seat",
        "not_applicable"
      ]
    },
    "offboarding_path_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "admin_transfer",
        "seat_transfer",
        "account_deprovisioning",
        "local_archive_only",
        "appeal_or_rebind"
      ]
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity_mode",
        "policy_epoch",
        "trust_state",
        "execution_context_id"
      ],
      "properties": {
        "identity_mode": { "$ref": "#/$defs/identity_mode" },
        "policy_epoch": { "$ref": "#/$defs/opaque_id" },
        "trust_state": { "$ref": "#/$defs/workspace_trust_state" },
        "execution_context_id": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "flow_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "flow_class",
        "flow_posture",
        "system_browser_posture",
        "embedded_auth_posture",
        "no_silent_signout_guarantee",
        "triggered_by_user_action",
        "flow_note"
      ],
      "properties": {
        "flow_class": { "$ref": "#/$defs/flow_class" },
        "flow_posture": { "$ref": "#/$defs/flow_posture_class" },
        "system_browser_posture": { "$ref": "#/$defs/system_browser_posture_class" },
        "embedded_auth_posture": { "$ref": "#/$defs/embedded_auth_posture_class" },
        "no_silent_signout_guarantee": {
          "type": "boolean",
          "const": true,
          "description": "Managed-auth state transitions never silently sign the user out of local work."
        },
        "triggered_by_user_action": { "type": "boolean" },
        "flow_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "passkey_availability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "availability_class",
        "disclosure_label",
        "fallback_rule",
        "fallback_accessibility_note"
      ],
      "properties": {
        "availability_class": { "$ref": "#/$defs/passkey_availability_class" },
        "disclosure_label": { "$ref": "#/$defs/export_safe_label" },
        "fallback_rule": { "$ref": "#/$defs/passkey_fallback_rule_class" },
        "fallback_accessibility_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "session_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issued_at",
        "expires_at",
        "refresh_due_at",
        "last_verified_at",
        "expiry_note",
        "dirty_buffer_count",
        "unsaved_local_artifacts_present"
      ],
      "properties": {
        "issued_at": { "$ref": "#/$defs/nullable_timestamp" },
        "expires_at": { "$ref": "#/$defs/nullable_timestamp" },
        "refresh_due_at": { "$ref": "#/$defs/nullable_timestamp" },
        "last_verified_at": { "$ref": "#/$defs/nullable_timestamp" },
        "expiry_note": { "$ref": "#/$defs/reviewable_sentence" },
        "dirty_buffer_count": {
          "type": "integer",
          "minimum": 0
        },
        "unsaved_local_artifacts_present": { "type": "boolean" }
      }
    },
    "required_copy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headline_label",
        "summary_label",
        "primary_action_label",
        "secondary_action_label",
        "local_continuity_label",
        "export_path_label",
        "screen_reader_announcement"
      ],
      "properties": {
        "headline_label": { "$ref": "#/$defs/export_safe_label" },
        "summary_label": { "$ref": "#/$defs/reviewable_sentence" },
        "primary_action_label": { "$ref": "#/$defs/export_safe_label" },
        "secondary_action_label": { "$ref": "#/$defs/export_safe_label" },
        "local_continuity_label": { "$ref": "#/$defs/reviewable_sentence" },
        "export_path_label": { "$ref": "#/$defs/export_safe_label" },
        "screen_reader_announcement": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "continuity_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edit_local_artifacts",
        "save_local_artifacts",
        "undo_redo_local_artifacts",
        "export_user_owned_artifacts",
        "local_git_available",
        "local_tasks_available",
        "diagnostics_available"
      ],
      "properties": {
        "edit_local_artifacts": {
          "type": "boolean",
          "const": true
        },
        "save_local_artifacts": {
          "type": "boolean",
          "const": true
        },
        "undo_redo_local_artifacts": {
          "type": "boolean",
          "const": true
        },
        "export_user_owned_artifacts": {
          "type": "boolean",
          "const": true
        },
        "local_git_available": { "type": "boolean" },
        "local_tasks_available": { "type": "boolean" },
        "diagnostics_available": { "type": "boolean" }
      },
      "description": "The four local artifact operations are fixed true for this contract: managed auth state may not imply local files, unsaved edits, undo history, or user-owned exports are unsafe."
    },
    "preserved_local_work": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_artifacts_safety_class",
        "safety_note",
        "continuity_rules",
        "retained_capabilities",
        "paused_managed_capabilities"
      ],
      "properties": {
        "local_artifacts_safety_class": { "$ref": "#/$defs/local_artifacts_safety_class" },
        "safety_note": { "$ref": "#/$defs/reviewable_sentence" },
        "continuity_rules": { "$ref": "#/$defs/continuity_rules" },
        "retained_capabilities": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/export_safe_label" },
          "uniqueItems": true
        },
        "paused_managed_capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/export_safe_label" },
          "uniqueItems": true
        }
      }
    },
    "managed_capability_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "continuation_mode",
        "available_managed_capabilities",
        "paused_managed_capabilities",
        "blocked_managed_actions",
        "posture_note"
      ],
      "properties": {
        "continuation_mode": { "$ref": "#/$defs/managed_continuation_mode_class" },
        "available_managed_capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/export_safe_label" },
          "uniqueItems": true
        },
        "paused_managed_capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/export_safe_label" },
          "uniqueItems": true
        },
        "blocked_managed_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/export_safe_label" },
          "uniqueItems": true
        },
        "posture_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_failure_class",
        "diagnostic_event_refs",
        "diagnostic_summary",
        "support_export_fields"
      ],
      "properties": {
        "primary_failure_class": { "$ref": "#/$defs/support_export_failure_class" },
        "diagnostic_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "diagnostic_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "support_export_fields": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "network_failure_ref",
            "tenant_policy_ref",
            "missing_credential_ref",
            "authenticator_incompatibility_ref",
            "revoked_session_ref",
            "seat_loss_ref",
            "account_deprovisioning_ref",
            "credential_store_ref",
            "support_summary_label",
            "redaction_class"
          ],
          "properties": {
            "network_failure_ref": { "$ref": "#/$defs/nullable_opaque_id" },
            "tenant_policy_ref": { "$ref": "#/$defs/nullable_opaque_id" },
            "missing_credential_ref": { "$ref": "#/$defs/nullable_opaque_id" },
            "authenticator_incompatibility_ref": { "$ref": "#/$defs/nullable_opaque_id" },
            "revoked_session_ref": { "$ref": "#/$defs/nullable_opaque_id" },
            "seat_loss_ref": { "$ref": "#/$defs/nullable_opaque_id" },
            "account_deprovisioning_ref": { "$ref": "#/$defs/nullable_opaque_id" },
            "credential_store_ref": { "$ref": "#/$defs/nullable_opaque_id" },
            "support_summary_label": { "$ref": "#/$defs/export_safe_label" },
            "redaction_class": { "$ref": "#/$defs/redaction_class" }
          }
        }
      }
    },
    "export_and_offboarding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_path_class",
        "offboarding_path_class",
        "requires_live_managed_seat",
        "export_refs",
        "offboarding_note"
      ],
      "properties": {
        "export_path_class": { "$ref": "#/$defs/export_path_class" },
        "offboarding_path_class": { "$ref": "#/$defs/offboarding_path_class" },
        "requires_live_managed_seat": {
          "type": "boolean",
          "description": "Whether this export/offboarding path requires a currently active managed seat. User-owned local artifact export should set false."
        },
        "export_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "offboarding_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_ref",
        "callback_packet_ref",
        "related_auth_callback_packet_refs",
        "related_entitlement_snapshot_refs",
        "support_packet_refs"
      ],
      "properties": {
        "contract_ref": { "$ref": "#/$defs/opaque_id" },
        "callback_packet_ref": { "$ref": "#/$defs/opaque_id" },
        "related_auth_callback_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "related_entitlement_snapshot_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "support_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },
    "managed_session_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "managed_session_state_schema_version",
        "session_state_id",
        "state_class",
        "identity_mode",
        "account_boundary_class",
        "deployment_profile_scope",
        "tenant_or_org_ref",
        "actor_subject_ref",
        "active_org_ref",
        "flow_context",
        "passkey_availability",
        "session_window",
        "required_copy",
        "preserved_local_work",
        "managed_capability_posture",
        "reauth_requirement",
        "diagnostics",
        "export_and_offboarding",
        "policy_context",
        "redaction_class",
        "links",
        "minted_at"
      ],
      "properties": {
        "$schema": {
          "type": "string",
          "format": "uri-reference"
        },
        "__fixture__": {
          "type": "object",
          "additionalProperties": true
        },
        "record_kind": {
          "type": "string",
          "const": "managed_session_state_record"
        },
        "managed_session_state_schema_version": { "$ref": "#/$defs/managed_session_state_schema_version" },
        "session_state_id": { "$ref": "#/$defs/opaque_id" },
        "state_class": { "$ref": "#/$defs/managed_session_state_class" },
        "identity_mode": { "$ref": "#/$defs/identity_mode" },
        "account_boundary_class": { "$ref": "#/$defs/account_boundary_class" },
        "deployment_profile_scope": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_class" },
          "uniqueItems": true
        },
        "tenant_or_org_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "actor_subject_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "active_org_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "flow_context": { "$ref": "#/$defs/flow_context" },
        "passkey_availability": { "$ref": "#/$defs/passkey_availability" },
        "session_window": { "$ref": "#/$defs/session_window" },
        "required_copy": { "$ref": "#/$defs/required_copy" },
        "preserved_local_work": { "$ref": "#/$defs/preserved_local_work" },
        "managed_capability_posture": { "$ref": "#/$defs/managed_capability_posture" },
        "reauth_requirement": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "https://aureline.dev/schemas/auth/reauth_requirement.schema.json#/$defs/reauth_requirement_record" }
          ]
        },
        "diagnostics": { "$ref": "#/$defs/diagnostics" },
        "export_and_offboarding": { "$ref": "#/$defs/export_and_offboarding" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "links": { "$ref": "#/$defs/links" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state_class": {
                "enum": [
                  "reauth_required",
                  "session_expiring",
                  "managed_blocked"
                ]
              }
            },
            "required": ["state_class"]
          },
          "then": {
            "properties": {
              "reauth_requirement": {
                "not": { "type": "null" }
              }
            }
          }
        }
      ]
    }
  }
}
