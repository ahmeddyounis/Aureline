{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/auth/system_browser_return_paths_beta.schema.json",
  "title": "System-browser default + passkey step-up + return-path labeling (beta) page",
  "description": "Reviewer-facing audit page that proves every claimed identity row defaults to system-browser auth (unless an explicit policy exception is named), preserves the workspace / target / requested-action labels on return, keeps granted scope from widening the requested scope, and quotes a closed passkey step-up posture when passkey capability is claimed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "page_label",
    "generated_at",
    "summary",
    "rows",
    "support_rows",
    "defects"
  ],
  "properties": {
    "record_kind": { "const": "auth_system_browser_return_paths_beta_page_record" },
    "schema_version": { "const": 1 },
    "shared_contract_ref": { "const": "auth:system_browser_return_paths_beta:v1" },
    "page_id": { "type": "string", "minLength": 1 },
    "page_label": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "summary": { "$ref": "#/$defs/summary" },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/row" }
    },
    "support_rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/support_row" }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/defect" }
    }
  },
  "$defs": {
    "policy_exception_token": {
      "type": "string",
      "enum": [
        "system_browser_default_no_exception",
        "admin_policy_device_code_required",
        "admin_policy_manual_resume_required",
        "browser_launch_unavailable_use_device_code",
        "browser_launch_offline_use_stay_local",
        "account_free_local_no_auth_required"
      ]
    },
    "passkey_posture_token": {
      "type": "string",
      "enum": [
        "passkey_required",
        "passkey_capable_offered",
        "passkey_unavailable_with_fallback",
        "passkey_not_applicable"
      ]
    },
    "authority_scope_token": {
      "type": "string",
      "enum": [
        "no_scope_granted",
        "read_only_scope",
        "step_up_scope",
        "read_write_scope",
        "workspace_admin_scope",
        "tenant_admin_scope"
      ]
    },
    "return_mode_token": {
      "type": "string",
      "enum": [
        "loopback_http_return",
        "platform_deep_link_return",
        "device_code_poll_return",
        "manual_return_resume",
        "not_applicable"
      ]
    },
    "return_origin_validation_token": {
      "type": "string",
      "enum": [
        "strict_origin_match_required",
        "loopback_port_pinned",
        "deep_link_scheme_pinned",
        "device_code_poll_only",
        "manual_resume_only"
      ]
    },
    "return_match_rule_token": {
      "type": "string",
      "enum": [
        "must_match_bound_workspace_and_tenant",
        "must_match_bound_tenant",
        "must_match_bound_workspace",
        "no_tenant_or_workspace_binding"
      ]
    },
    "axis_token": {
      "type": "string",
      "enum": [
        "system_browser_default_unless_explicit_exception",
        "exact_return_path_label_preserved",
        "workspace_target_action_identity_preserved",
        "passkey_capable_step_up_when_claimed",
        "support_export_vocabulary_parity"
      ]
    },
    "defect_kind_token": {
      "type": "string",
      "enum": [
        "system_browser_not_default_without_explicit_exception",
        "policy_exception_label_missing",
        "return_path_workspace_drift",
        "return_path_target_drift",
        "return_path_action_drift",
        "return_anchor_ref_missing",
        "return_widens_authority_scope",
        "passkey_claimed_without_step_up_block",
        "passkey_unavailable_without_honest_fallback",
        "passkey_not_applicable_mislabeled",
        "support_row_vocabulary_drift",
        "system_browser_default_inconsistent_with_blocked_launch"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_count",
        "support_row_count",
        "defect_count",
        "system_browser_default_row_count",
        "explicit_exception_row_count",
        "passkey_capable_row_count",
        "return_modes_present",
        "policy_exceptions_present",
        "passkey_postures_present"
      ],
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "support_row_count": { "type": "integer", "minimum": 0 },
        "defect_count": { "type": "integer", "minimum": 0 },
        "system_browser_default_row_count": { "type": "integer", "minimum": 0 },
        "explicit_exception_row_count": { "type": "integer", "minimum": 0 },
        "passkey_capable_row_count": { "type": "integer", "minimum": 0 },
        "return_modes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/return_mode_token" }
        },
        "policy_exceptions_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_exception_token" }
        },
        "passkey_postures_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/passkey_posture_token" }
        }
      }
    },
    "return_path_label": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_label",
        "target_label",
        "requested_action_label",
        "return_mode_token",
        "return_anchor_ref",
        "return_origin_validation_token",
        "return_tenant_or_workspace_match_rule_token"
      ],
      "properties": {
        "workspace_label": { "type": "string" },
        "target_label": { "type": "string" },
        "requested_action_label": { "type": "string" },
        "return_mode_token": { "$ref": "#/$defs/return_mode_token" },
        "return_anchor_ref": { "type": "string" },
        "return_origin_validation_token": {
          "$ref": "#/$defs/return_origin_validation_token"
        },
        "return_tenant_or_workspace_match_rule_token": {
          "$ref": "#/$defs/return_match_rule_token"
        }
      }
    },
    "passkey_step_up": {
      "type": "object",
      "additionalProperties": false,
      "required": ["posture_token", "reason_label"],
      "properties": {
        "posture_token": { "$ref": "#/$defs/passkey_posture_token" },
        "reason_label": { "type": "string" },
        "fallback_retry_path_token": {
          "type": "string",
          "enum": [
            "retry_in_system_browser",
            "switch_to_device_code",
            "resume_after_step_up",
            "resume_after_credential_store_unlock",
            "request_admin_policy_change",
            "continue_local_without_sign_in",
            "import_signed_session_snapshot",
            "return_to_account_free_local",
            "contact_support_with_export",
            "no_recovery_without_superseding_action"
          ]
        },
        "fallback_retry_path_label": { "type": "string" }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "case_id",
        "row_id",
        "source_claim_row_ref",
        "account_boundary_class_token",
        "identity_mode_token",
        "trust_state_token",
        "provider_label",
        "provider_domain_label",
        "provider_scope_label",
        "default_action_token",
        "system_browser_default",
        "policy_exception_token",
        "policy_exception_label",
        "browser_launch_policy_class_token",
        "return_path_label",
        "requested_authority_scope_token",
        "granted_authority_scope_token",
        "authority_scope_summary_label",
        "passkey_capability_claimed",
        "passkey_step_up",
        "promised_audit_axes",
        "plain_language_summary",
        "redaction_class_token"
      ],
      "properties": {
        "record_kind": { "const": "auth_system_browser_return_paths_beta_row_record" },
        "schema_version": { "const": 1 },
        "shared_contract_ref": { "const": "auth:system_browser_return_paths_beta:v1" },
        "case_id": { "type": "string", "minLength": 1 },
        "row_id": { "type": "string", "minLength": 1 },
        "source_claim_row_ref": { "type": "string", "minLength": 1 },
        "account_boundary_class_token": {
          "type": "string",
          "enum": [
            "local_only",
            "self_hosted",
            "managed",
            "restricted_managed_only",
            "grace_degraded_managed",
            "unknown_boundary"
          ]
        },
        "identity_mode_token": {
          "type": "string",
          "enum": [
            "account_free_local",
            "self_hosted_org",
            "managed_convenience"
          ]
        },
        "trust_state_token": {
          "type": "string",
          "enum": ["trusted", "restricted", "pending_evaluation"]
        },
        "provider_label": { "type": "string" },
        "provider_domain_label": { "type": "string" },
        "provider_scope_label": { "type": "string" },
        "bound_workspace_ref": { "type": "string" },
        "bound_tenant_or_org_ref": { "type": "string" },
        "bound_actor_subject_ref": { "type": "string" },
        "default_action_token": {
          "type": "string",
          "enum": [
            "open_system_browser",
            "use_device_code",
            "continue_local_without_sign_in",
            "inspect_policy_or_support",
            "no_auth_required"
          ]
        },
        "system_browser_default": { "type": "boolean" },
        "policy_exception_token": { "$ref": "#/$defs/policy_exception_token" },
        "policy_exception_label": { "type": "string" },
        "browser_launch_policy_class_token": {
          "type": "string",
          "enum": [
            "system_default_browser_required",
            "managed_approved_browser_allowed",
            "separately_approved_boundary_contract",
            "browser_launch_policy_blocked"
          ]
        },
        "return_path_label": { "$ref": "#/$defs/return_path_label" },
        "requested_authority_scope_token": { "$ref": "#/$defs/authority_scope_token" },
        "granted_authority_scope_token": { "$ref": "#/$defs/authority_scope_token" },
        "authority_scope_summary_label": { "type": "string" },
        "passkey_capability_claimed": { "type": "boolean" },
        "passkey_step_up": { "$ref": "#/$defs/passkey_step_up" },
        "promised_audit_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/axis_token" }
        },
        "plain_language_summary": { "type": "string" },
        "redaction_class_token": { "type": "string", "minLength": 1 }
      }
    },
    "support_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "case_id",
        "row_id",
        "account_boundary_class_token",
        "identity_mode_token",
        "trust_state_token",
        "default_action_token",
        "policy_exception_token",
        "return_mode_token",
        "return_origin_validation_token",
        "return_tenant_or_workspace_match_rule_token",
        "return_anchor_ref",
        "workspace_label",
        "target_label",
        "requested_action_label",
        "requested_authority_scope_token",
        "granted_authority_scope_token",
        "passkey_step_up_posture_token",
        "redaction_class_token"
      ],
      "properties": {
        "record_kind": {
          "const": "auth_system_browser_return_paths_beta_support_row_record"
        },
        "schema_version": { "const": 1 },
        "shared_contract_ref": { "const": "auth:system_browser_return_paths_beta:v1" },
        "case_id": { "type": "string", "minLength": 1 },
        "row_id": { "type": "string", "minLength": 1 },
        "account_boundary_class_token": { "type": "string" },
        "identity_mode_token": { "type": "string" },
        "trust_state_token": { "type": "string" },
        "default_action_token": { "type": "string" },
        "policy_exception_token": { "$ref": "#/$defs/policy_exception_token" },
        "return_mode_token": { "$ref": "#/$defs/return_mode_token" },
        "return_origin_validation_token": {
          "$ref": "#/$defs/return_origin_validation_token"
        },
        "return_tenant_or_workspace_match_rule_token": {
          "$ref": "#/$defs/return_match_rule_token"
        },
        "return_anchor_ref": { "type": "string" },
        "workspace_label": { "type": "string" },
        "target_label": { "type": "string" },
        "requested_action_label": { "type": "string" },
        "requested_authority_scope_token": { "$ref": "#/$defs/authority_scope_token" },
        "granted_authority_scope_token": { "$ref": "#/$defs/authority_scope_token" },
        "passkey_step_up_posture_token": { "$ref": "#/$defs/passkey_posture_token" },
        "passkey_fallback_retry_path_token": { "type": "string" },
        "redaction_class_token": { "type": "string", "minLength": 1 }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "defect_kind",
        "defect_kind_token",
        "row_id",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": {
          "const": "auth_system_browser_return_paths_beta_defect_record"
        },
        "schema_version": { "const": 1 },
        "shared_contract_ref": { "const": "auth:system_browser_return_paths_beta:v1" },
        "defect_id": { "type": "string", "minLength": 1 },
        "defect_kind": { "$ref": "#/$defs/defect_kind_token" },
        "defect_kind_token": { "$ref": "#/$defs/defect_kind_token" },
        "row_id": { "type": "string", "minLength": 1 },
        "field": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 }
      }
    }
  }
}
