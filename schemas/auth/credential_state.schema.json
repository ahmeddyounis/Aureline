{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/auth/credential_state.schema.json",
  "title": "Aureline credential-state and store-capability contract",
  "description": "Boundary schema for credential_state_record, store_capability_record, and store_capability_matrix_record entries frozen in docs/auth/credential_state_and_secret_prompt_contract.md. These records explain what credential authority exists, where it is stored or delegated, which capabilities are available or blocked, what prompt or repair path is safe, and what can be exported without exposing raw secret material. Raw secret material, passwords, private keys, refresh tokens, OAuth codes, PKCE verifiers, client-certificate private bytes, device secrets, raw request headers, and ambient delegated credentials never cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/credential_state_record" },
    { "$ref": "#/$defs/store_capability_record" },
    { "$ref": "#/$defs/store_capability_matrix_record" }
  ],
  "$defs": {
    "credential_state_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this credential-state contract. Bump on breaking payload changes."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "credential_state_record",
        "store_capability_record",
        "store_capability_matrix_record"
      ]
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "description": "Optional fixture-only metadata used by worked examples."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for logs, RPC, support exports, admin exports, and fixture references. Raw secret material and provider payloads never appear here."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic or authoritative clock source."
    },
    "nullable_timestamp": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/monotonic_timestamp" }
      ]
    },
    "export_safe_label": {
      "type": "string",
      "minLength": 1,
      "description": "Short label safe for UI, logs, support exports, admin exports, and release evidence. Raw secrets, raw URLs, raw tenant names, and account identifiers do not appear."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Short reviewable sentence safe for product copy, diagnostics, support exports, and admin exports."
    },
    "identity_mode": {
      "type": "string",
      "enum": [
        "account_free_local",
        "self_hosted_org",
        "managed_workspace"
      ]
    },
    "workspace_trust_state": {
      "type": "string",
      "enum": [
        "trusted",
        "restricted"
      ]
    },
    "surface_redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ],
      "description": "Product-surface redaction class used by auth, support, admin, and evidence records. Secret-broker redaction surfaces are named separately in secret_redaction_class_refs."
    },
    "credential_state_class": {
      "type": "string",
      "enum": [
        "absent",
        "handle_only",
        "available",
        "locked",
        "denied",
        "expired",
        "revoked",
        "rotated",
        "store_unavailable",
        "policy_blocked"
      ],
      "description": "Closed credential-state vocabulary. Display labels may localize, but capability implications and repair actions remain bound to these values."
    },
    "storage_mode_class": {
      "type": "string",
      "enum": [
        "system_credential_store",
        "enterprise_secret_store",
        "session_only",
        "handle_only",
        "delegated",
        "not_configured"
      ],
      "description": "Stable storage-mode vocabulary shown in product copy, docs, telemetry, support exports, and policy explanations."
    },
    "store_source_class": {
      "type": "string",
      "enum": [
        "os_keychain",
        "enterprise_vault_adapter",
        "agent_socket",
        "file_backed_secret_ref",
        "remote_session_scoped_handle",
        "hardware_backed_or_passkey_adjacent",
        "managed_policy_injector",
        "browser_device_code_handoff",
        "no_secure_store"
      ],
      "description": "User/admin-facing store or source class. Some values map to ADR-0007 trust_store_class values; others are source patterns that resolve through the broker without storing raw material."
    },
    "credential_origin_class": {
      "type": "string",
      "enum": [
        "local_secret_handle",
        "forwarded_local_credential",
        "service_issued_delegated_identity",
        "policy_injected_credential",
        "customer_managed_secret_store",
        "browser_or_device_code_handoff",
        "hardware_or_passkey_bound",
        "imported_reference_only",
        "absent"
      ],
      "description": "Origin vocabulary that keeps local, forwarded, delegated, policy-injected, customer-managed, browser/device-code, and absent identity distinct."
    },
    "target_class": {
      "type": "string",
      "enum": [
        "auth_flow",
        "package_registry",
        "remote_target",
        "ai_gateway",
        "api_request_workspace",
        "database_connection",
        "provider_connector",
        "release_or_signing",
        "automation_recipe",
        "collaboration_session",
        "browser_device_handoff",
        "support_export"
      ]
    },
    "actor_class": {
      "type": "string",
      "enum": [
        "human_user",
        "org_admin",
        "policy_service",
        "first_party_adapter",
        "extension",
        "ai_agent",
        "remote_agent",
        "service_identity",
        "automation_runner",
        "support_operator",
        "system_supervisor"
      ]
    },
    "lifetime_class": {
      "type": "string",
      "enum": [
        "operation_scoped",
        "session_only",
        "time_bounded",
        "persistent_until_revoked",
        "rotated_successor_required",
        "unavailable",
        "unknown_review_required"
      ]
    },
    "store_verification_state": {
      "type": "string",
      "enum": [
        "verified_available",
        "locked_waiting_for_unlock",
        "verified_unavailable",
        "policy_blocked",
        "degraded_session_only",
        "reference_only_unverified",
        "not_configured"
      ]
    },
    "support_export_posture_class": {
      "type": "string",
      "enum": [
        "metadata_only",
        "aliases_and_source_labels_only",
        "audit_refs_only",
        "local_only_not_exported",
        "blocked_by_policy"
      ]
    },
    "automation_export_posture_class": {
      "type": "string",
      "enum": [
        "handle_alias_only",
        "required_class_only",
        "metadata_only",
        "denied_until_prompt",
        "blocked_by_policy"
      ]
    },
    "safe_action_class": {
      "type": "string",
      "enum": [
        "use_existing_handle",
        "unlock_store",
        "read_secret_via_broker",
        "write_secret_to_store",
        "renew_handle",
        "rotate_credential",
        "rebind_handle",
        "import_credential",
        "start_browser_handoff",
        "use_device_code_handoff",
        "approve_step_up_access",
        "retry_after_store_recovery",
        "switch_to_handle_only_projection",
        "continue_without_credential",
        "use_cached_read_only_results",
        "open_policy_detail",
        "request_policy_exception",
        "contact_admin",
        "export_support_metadata",
        "no_safe_retry_available"
      ]
    },
    "credential_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_class",
        "target_ref",
        "target_label",
        "secret_class",
        "scope_label",
        "audience_label"
      ],
      "properties": {
        "target_class": { "$ref": "#/$defs/target_class" },
        "target_ref": { "$ref": "#/$defs/opaque_id" },
        "target_label": { "$ref": "#/$defs/export_safe_label" },
        "secret_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "../security/secret_class_rows.schema.json#/$defs/secret_class" }
          ]
        },
        "scope_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "scope_label": { "$ref": "#/$defs/export_safe_label" },
        "audience_label": { "$ref": "#/$defs/export_safe_label" }
      }
    },
    "authority_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "storage_mode_class",
        "store_source_class",
        "credential_origin_class",
        "authority_ref",
        "alias_ref",
        "handle_ref",
        "source_label",
        "delegated_credential_ref",
        "policy_owner_ref",
        "browser_handoff_ref",
        "raw_secret_material_present"
      ],
      "properties": {
        "storage_mode_class": { "$ref": "#/$defs/storage_mode_class" },
        "store_source_class": { "$ref": "#/$defs/store_source_class" },
        "credential_origin_class": { "$ref": "#/$defs/credential_origin_class" },
        "authority_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "alias_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "handle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "source_label": { "$ref": "#/$defs/export_safe_label" },
        "delegated_credential_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "policy_owner_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "browser_handoff_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "raw_secret_material_present": {
          "type": "boolean",
          "const": false,
          "description": "Credential-state rows never carry raw secret material. Raw material observed elsewhere is represented by a denial/audit row, not by setting this field true."
        }
      }
    },
    "storage_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust_store_class",
        "unlock_state",
        "store_capability_ref",
        "store_verification_state",
        "session_only_downgrade_visible",
        "supports_persistent_long_lived",
        "plaintext_fallback_allowed",
        "storage_note"
      ],
      "properties": {
        "trust_store_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "../security/secret_class_rows.schema.json#/$defs/trust_store_class" }
          ]
        },
        "unlock_state": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "../security/secret_class_rows.schema.json#/$defs/unlock_state" }
          ]
        },
        "store_capability_ref": { "$ref": "#/$defs/opaque_id" },
        "store_verification_state": { "$ref": "#/$defs/store_verification_state" },
        "session_only_downgrade_visible": { "type": "boolean" },
        "supports_persistent_long_lived": { "type": "boolean" },
        "plaintext_fallback_allowed": {
          "type": "boolean",
          "const": false,
          "description": "Plaintext fallback for long-lived credentials is forbidden."
        },
        "storage_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "capability_implications": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "can_read_secret",
        "can_write_secret",
        "can_rebind_handle",
        "can_import_credential",
        "can_unlock_store",
        "can_use_existing_handle",
        "can_project_raw_material",
        "local_work_continues",
        "retained_capabilities",
        "blocked_capabilities",
        "capability_note"
      ],
      "properties": {
        "can_read_secret": { "type": "boolean" },
        "can_write_secret": { "type": "boolean" },
        "can_rebind_handle": { "type": "boolean" },
        "can_import_credential": { "type": "boolean" },
        "can_unlock_store": { "type": "boolean" },
        "can_use_existing_handle": { "type": "boolean" },
        "can_project_raw_material": {
          "type": "boolean",
          "description": "True only when a separately governed reveal/projection path is active; ordinary state rows should keep this false."
        },
        "local_work_continues": { "type": "boolean" },
        "retained_capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/export_safe_label" },
          "uniqueItems": true
        },
        "blocked_capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/export_safe_label" },
          "uniqueItems": true
        },
        "capability_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "prompt_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_required",
        "prompt_action_classes",
        "prompt_ref",
        "prompt_reason",
        "handle_only_path_available"
      ],
      "properties": {
        "prompt_required": { "type": "boolean" },
        "prompt_action_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "read_secret",
              "write_secret",
              "rebind_handle",
              "import_credential",
              "unlock_store",
              "approve_step_up_access"
            ]
          },
          "uniqueItems": true
        },
        "prompt_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "prompt_reason": { "$ref": "#/$defs/reviewable_sentence" },
        "handle_only_path_available": { "type": "boolean" }
      }
    },
    "export_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handles_aliases_source_labels_may_travel",
        "raw_secret_material_may_travel",
        "private_keys_may_travel",
        "refresh_tokens_may_travel",
        "ambient_delegated_credentials_may_travel",
        "support_export_posture",
        "automation_export_posture",
        "export_note"
      ],
      "properties": {
        "handles_aliases_source_labels_may_travel": { "type": "boolean" },
        "raw_secret_material_may_travel": { "type": "boolean", "const": false },
        "private_keys_may_travel": { "type": "boolean", "const": false },
        "refresh_tokens_may_travel": { "type": "boolean", "const": false },
        "ambient_delegated_credentials_may_travel": { "type": "boolean", "const": false },
        "support_export_posture": { "$ref": "#/$defs/support_export_posture_class" },
        "automation_export_posture": { "$ref": "#/$defs/automation_export_posture_class" },
        "export_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "safe_actions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_action",
        "fallback_actions",
        "escalation_action",
        "safe_retry_allowed",
        "escalation_note"
      ],
      "properties": {
        "primary_action": { "$ref": "#/$defs/safe_action_class" },
        "fallback_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/safe_action_class" },
          "uniqueItems": true
        },
        "escalation_action": { "$ref": "#/$defs/safe_action_class" },
        "safe_retry_allowed": { "type": "boolean" },
        "escalation_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "denial_reason",
        "failure_label",
        "audit_event_refs",
        "last_checked_at",
        "support_summary"
      ],
      "properties": {
        "denial_reason": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "../security/secret_class_rows.schema.json#/$defs/denial_reason" }
          ]
        },
        "failure_label": { "$ref": "#/$defs/export_safe_label" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "last_checked_at": { "$ref": "#/$defs/nullable_timestamp" },
        "support_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity_mode",
        "policy_epoch",
        "trust_state",
        "execution_context_id"
      ],
      "properties": {
        "identity_mode": { "$ref": "#/$defs/identity_mode" },
        "policy_epoch": { "$ref": "#/$defs/opaque_id" },
        "trust_state": { "$ref": "#/$defs/workspace_trust_state" },
        "execution_context_id": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "credential_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "credential_state_schema_version",
        "credential_state_id",
        "state_class",
        "display_label",
        "subject",
        "authority",
        "storage",
        "lifetime",
        "projection_mode",
        "capability_implications",
        "prompt_policy",
        "export_rules",
        "safe_actions",
        "diagnostics",
        "policy_context",
        "surface_redaction_class",
        "secret_redaction_class_refs",
        "minted_at"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "credential_state_record" },
        "credential_state_schema_version": { "$ref": "#/$defs/credential_state_schema_version" },
        "credential_state_id": { "$ref": "#/$defs/opaque_id" },
        "state_class": { "$ref": "#/$defs/credential_state_class" },
        "display_label": { "$ref": "#/$defs/export_safe_label" },
        "subject": { "$ref": "#/$defs/credential_subject" },
        "authority": { "$ref": "#/$defs/authority_summary" },
        "storage": { "$ref": "#/$defs/storage_posture" },
        "lifetime": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "lifetime_class",
            "issued_at",
            "expires_at",
            "refresh_after",
            "revocation_path_label",
            "lifetime_note"
          ],
          "properties": {
            "lifetime_class": { "$ref": "#/$defs/lifetime_class" },
            "issued_at": { "$ref": "#/$defs/nullable_timestamp" },
            "expires_at": { "$ref": "#/$defs/nullable_timestamp" },
            "refresh_after": { "$ref": "#/$defs/nullable_timestamp" },
            "revocation_path_label": { "$ref": "#/$defs/export_safe_label" },
            "lifetime_note": { "$ref": "#/$defs/reviewable_sentence" }
          }
        },
        "projection_mode": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "../security/secret_class_rows.schema.json#/$defs/projection_mode" }
          ]
        },
        "capability_implications": { "$ref": "#/$defs/capability_implications" },
        "prompt_policy": { "$ref": "#/$defs/prompt_policy" },
        "export_rules": { "$ref": "#/$defs/export_rules" },
        "safe_actions": { "$ref": "#/$defs/safe_actions" },
        "diagnostics": { "$ref": "#/$defs/diagnostics" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "surface_redaction_class": { "$ref": "#/$defs/surface_redaction_class" },
        "secret_redaction_class_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "../security/secret_class_rows.schema.json#/$defs/redaction_class" },
          "uniqueItems": true
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    },
    "store_capability_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "credential_state_schema_version",
        "store_capability_id",
        "store_source_class",
        "display_label",
        "storage_mode_classes",
        "mapped_trust_store_classes",
        "supported_secret_classes",
        "supports_long_lived_secrets",
        "supports_handle_reference",
        "supports_raw_secret_storage",
        "supports_session_only_fallback",
        "plaintext_fallback_allowed",
        "allowed_prompt_action_classes",
        "support_export_posture",
        "automation_export_posture",
        "auditability_note",
        "fallback_note",
        "platform_limitations",
        "surface_redaction_class",
        "minted_at"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "store_capability_record" },
        "credential_state_schema_version": { "$ref": "#/$defs/credential_state_schema_version" },
        "store_capability_id": { "$ref": "#/$defs/opaque_id" },
        "store_source_class": { "$ref": "#/$defs/store_source_class" },
        "display_label": { "$ref": "#/$defs/export_safe_label" },
        "storage_mode_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/storage_mode_class" },
          "uniqueItems": true
        },
        "mapped_trust_store_classes": {
          "type": "array",
          "items": { "$ref": "../security/secret_class_rows.schema.json#/$defs/trust_store_class" },
          "uniqueItems": true
        },
        "supported_secret_classes": {
          "type": "array",
          "items": { "$ref": "../security/secret_class_rows.schema.json#/$defs/secret_class" },
          "uniqueItems": true
        },
        "supports_long_lived_secrets": { "type": "boolean" },
        "supports_handle_reference": { "type": "boolean" },
        "supports_raw_secret_storage": {
          "type": "boolean",
          "const": false,
          "description": "This contract never marks raw secret storage as exportable or product-owned in portable/workspace files."
        },
        "supports_session_only_fallback": { "type": "boolean" },
        "plaintext_fallback_allowed": { "type": "boolean", "const": false },
        "allowed_prompt_action_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "read_secret",
              "write_secret",
              "rebind_handle",
              "import_credential",
              "unlock_store",
              "approve_step_up_access"
            ]
          },
          "uniqueItems": true
        },
        "support_export_posture": { "$ref": "#/$defs/support_export_posture_class" },
        "automation_export_posture": { "$ref": "#/$defs/automation_export_posture_class" },
        "auditability_note": { "$ref": "#/$defs/reviewable_sentence" },
        "fallback_note": { "$ref": "#/$defs/reviewable_sentence" },
        "platform_limitations": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_sentence" }
        },
        "surface_redaction_class": { "$ref": "#/$defs/surface_redaction_class" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    },
    "store_capability_matrix_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "credential_state_schema_version",
        "matrix_id",
        "contract_ref",
        "rows",
        "surface_redaction_class",
        "minted_at"
      ],
      "properties": {
