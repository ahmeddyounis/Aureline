{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/auth/credential_picker_state.schema.json",
  "title": "Aureline credential-picker state contract",
  "description": "Boundary schema for credential_picker_state_record entries frozen in docs/auth/credential_picker_contract.md. The record describes the subject being credentialed (target + scope + secret class), the candidate credential sources (OS keychain, enterprise vault, session-only, reference-only workspace/env sources, delegated identity, missing/unavailable/policy-blocked states), reveal-on-demand posture, export/redaction posture, and the safe rotate/rebind/import/unlock actions available without ever serializing raw secret material. Raw secret material, passwords, private keys, refresh tokens, OAuth codes, PKCE verifiers, client-certificate private bytes, device secrets, raw request headers, and ambient delegated credentials never cross this boundary; records carry opaque refs and export-safe labels only.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/credential_picker_state_record" }
  ],
  "$defs": {
    "credential_picker_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this credential-picker state contract. Bump only on breaking payload changes."
    },

    "record_kind": {
      "type": "string",
      "enum": [
        "credential_picker_state_record"
      ],
      "description": "Discriminator for the concrete payload shape."
    },

    "instance_schema_hint": {
      "type": "string",
      "format": "uri-reference",
      "description": "Optional $schema pointer carried on worked fixtures."
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "description": "Optional worked-example prelude carried on fixtures."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for logs, RPC, support exports, admin exports, and picker fixtures. Raw secret bytes and raw provider payloads never appear here."
    },

    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic or authoritative clock source."
    },

    "nullable_timestamp": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/monotonic_timestamp" }
      ]
    },

    "export_safe_label": {
      "type": "string",
      "minLength": 1,
      "description": "Short label safe for UI, logs, support exports, admin exports, and release evidence. Raw secret material and raw provider payloads do not appear."
    },

    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Short reviewable sentence safe for product copy, diagnostics, and exports. Must not embed raw secrets or raw provider payloads."
    },

    "picker_option_class": {
      "type": "string",
      "enum": [
        "system_credential_store",
        "enterprise_secret_store",
        "session_only",
        "workspace_variable",
        "environment_passthrough",
        "delegated_identity",
        "browser_device_code_handoff",
        "missing_source",
        "policy_denied",
        "store_unavailable"
      ],
      "description": "User-visible picker option classes. These are not secret classes; they are source shapes."
    },

    "open_source_of_truth_action_class": {
      "type": "string",
      "enum": [
        "open_os_keychain",
        "open_enterprise_vault",
        "open_workspace_reference",
        "open_environment_reference",
        "open_delegated_identity_source",
        "open_policy_source",
        "open_browser_handoff_status",
        "not_applicable"
      ],
      "description": "Controlled action vocabulary for opening the upstream source-of-truth for a picker option."
    },

    "open_source_of_truth_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_class", "action_label", "action_ref"],
      "properties": {
        "action_class": { "$ref": "#/$defs/open_source_of_truth_action_class" },
        "action_label": { "$ref": "#/$defs/export_safe_label" },
        "action_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },

    "reveal_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_reveal_default",
        "reveal_on_demand_allowed",
        "clipboard_projection_allowed",
        "clipboard_lifetime_seconds",
        "reveal_note"
      ],
      "properties": {
        "raw_reveal_default": {
          "type": "string",
          "enum": ["denied", "protocol_required_header_only", "sign_only_metadata_reveal"],
          "description": "Default reveal posture for the subject's secret class (derived from the secret-class matrix)."
        },
        "reveal_on_demand_allowed": {
          "type": "boolean",
          "description": "Whether a user-initiated reveal-on-demand flow may be offered for this option, subject to policy and class rules."
        },
        "clipboard_projection_allowed": {
          "type": "boolean",
          "description": "Whether the picker may offer a clipboard projection for a revealed value. Remote clipboard bridges remain denied by default."
        },
        "clipboard_lifetime_seconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Bounded clipboard timer seconds. Zero means clipboard projection is not offered."
        },
        "reveal_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "credential_picker_option_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "option_id",
        "option_class",
        "availability_class",
        "display_label",
        "source_label",
        "scope_label",
        "storage_mode_class",
        "store_source_class",
        "credential_origin_class",
        "alias_ref",
        "handle_ref",
        "delegated_credential_ref",
        "policy_owner_ref",
        "browser_handoff_ref",
        "expires_at",
        "refresh_after",
        "reveal_policy",
        "export_rules",
        "safe_actions",
        "open_source_of_truth_action",
        "audit_event_refs",
        "option_note"
      ],
      "properties": {
        "option_id": { "$ref": "#/$defs/opaque_id" },
        "option_class": { "$ref": "#/$defs/picker_option_class" },
        "availability_class": { "$ref": "./credential_state.schema.json#/$defs/credential_state_class" },
        "display_label": { "$ref": "#/$defs/export_safe_label" },
        "source_label": { "$ref": "#/$defs/export_safe_label" },
        "scope_label": { "$ref": "#/$defs/export_safe_label" },
        "storage_mode_class": { "$ref": "./credential_state.schema.json#/$defs/storage_mode_class" },
        "store_source_class": { "$ref": "./credential_state.schema.json#/$defs/store_source_class" },
        "credential_origin_class": { "$ref": "./credential_state.schema.json#/$defs/credential_origin_class" },
        "alias_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "handle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "delegated_credential_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "policy_owner_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "browser_handoff_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "expires_at": { "$ref": "#/$defs/nullable_timestamp" },
        "refresh_after": { "$ref": "#/$defs/nullable_timestamp" },
        "reveal_policy": { "$ref": "#/$defs/reveal_policy" },
        "export_rules": { "$ref": "./credential_state.schema.json#/$defs/export_rules" },
        "safe_actions": { "$ref": "./credential_state.schema.json#/$defs/safe_actions" },
        "open_source_of_truth_action": { "$ref": "#/$defs/open_source_of_truth_action" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Metadata-only audit event refs related to this option (issue/use/deny/revoke/reveal), never secret material."
        },
        "option_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "credential_picker_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "credential_picker_schema_version",
        "picker_state_id",
        "display_label",
        "subject",
        "selected_option_id",
        "options",
        "audit_event_refs",
        "policy_context",
        "surface_redaction_class",
        "secret_redaction_class_refs",
        "minted_at"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "credential_picker_state_record" },
        "credential_picker_schema_version": { "$ref": "#/$defs/credential_picker_schema_version" },
        "picker_state_id": { "$ref": "#/$defs/opaque_id" },
        "display_label": { "$ref": "#/$defs/export_safe_label" },
        "subject": { "$ref": "./credential_state.schema.json#/$defs/credential_subject" },
        "selected_option_id": { "$ref": "#/$defs/nullable_opaque_id" },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/credential_picker_option_record" }
        },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Metadata-only audit event refs for the picker session (open/select/deny), never secret material."
        },
        "policy_context": { "$ref": "./credential_state.schema.json#/$defs/policy_context" },
        "surface_redaction_class": { "$ref": "./credential_state.schema.json#/$defs/surface_redaction_class" },
        "secret_redaction_class_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "../security/secret_class_rows.schema.json#/$defs/redaction_class" },
          "uniqueItems": true
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    }
  }
}

