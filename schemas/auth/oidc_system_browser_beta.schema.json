{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/auth/oidc_system_browser_beta.schema.json",
  "title": "OIDC system-browser sign-in, recovery, and session-continuity (beta) page",
  "description": "Reviewer-facing audit page that proves every claimed enterprise OIDC row discloses its issuer source, tenant + workspace binding, and return-path; degrades truthfully on identity outage or denial; preserves local editing through sign-out and refresh; and keeps the support row aligned with the live row on every closed-vocabulary token.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "page_label",
    "generated_at",
    "summary",
    "rows",
    "support_rows",
    "defects"
  ],
  "properties": {
    "record_kind": { "const": "auth_oidc_system_browser_beta_page_record" },
    "schema_version": { "const": 1 },
    "shared_contract_ref": { "const": "auth:oidc_system_browser_beta:v1" },
    "page_id": { "type": "string", "minLength": 1 },
    "page_label": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "summary": { "$ref": "#/$defs/summary" },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/row" }
    },
    "support_rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/support_row" }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/defect" }
    }
  },
  "$defs": {
    "profile_token": {
      "type": "string",
      "enum": ["connected", "mirror_only", "offline", "enterprise_managed"]
    },
    "issuer_source_token": {
      "type": "string",
      "enum": [
        "managed_enterprise_issuer",
        "customer_self_hosted_issuer",
        "signed_mirror_issuer",
        "manual_signed_file_import",
        "not_applicable_account_free_local"
      ]
    },
    "tenant_binding_token": {
      "type": "string",
      "enum": [
        "workspace_and_tenant_bound",
        "tenant_only_bound",
        "workspace_only_bound",
        "no_tenant_binding_account_free_local"
      ]
    },
    "session_state_token": {
      "type": "string",
      "enum": [
        "signed_in_active",
        "refresh_pending_managed_narrowed",
        "refresh_expired_managed_blocked",
        "signed_out_local_intact",
        "identity_outage_managed_blocked",
        "auth_denial_managed_blocked",
        "account_free_local_no_auth_required"
      ]
    },
    "sign_out_continuity_token": {
      "type": "string",
      "enum": [
        "signed_in_active_no_sign_out_yet",
        "local_editing_preserved_managed_narrowed",
        "local_editing_preserved_managed_blocked",
        "account_free_local_passthrough"
      ]
    },
    "outage_token": {
      "type": "string",
      "enum": [
        "no_outage",
        "issuer_unreachable_local_only",
        "issuer_degraded_refresh_deferred",
        "issuer_offline_snapshot_only",
        "not_applicable_account_free_local"
      ]
    },
    "recovery_action_token": {
      "type": "string",
      "enum": [
        "no_recovery_required",
        "resume_in_system_browser",
        "retry_refresh_in_system_browser",
        "switch_to_device_code",
        "continue_local_without_sign_in",
        "inspect_admin_policy",
        "contact_support_with_export"
      ]
    },
    "authority_scope_token": {
      "type": "string",
      "enum": [
        "no_scope_granted",
        "read_only_scope",
        "step_up_scope",
        "read_write_scope",
        "workspace_admin_scope",
        "tenant_admin_scope"
      ]
    },
    "return_mode_token": {
      "type": "string",
      "enum": [
        "loopback_http_return",
        "platform_deep_link_return",
        "device_code_poll_return",
        "manual_return_resume",
        "not_applicable"
      ]
    },
    "return_origin_validation_token": {
      "type": "string",
      "enum": [
        "strict_origin_match_required",
        "loopback_port_pinned",
        "deep_link_scheme_pinned",
        "device_code_poll_only",
        "manual_resume_only"
      ]
    },
    "return_match_rule_token": {
      "type": "string",
      "enum": [
        "must_match_bound_workspace_and_tenant",
        "must_match_bound_tenant",
        "must_match_bound_workspace",
        "no_tenant_or_workspace_binding"
      ]
    },
    "axis_token": {
      "type": "string",
      "enum": [
        "enterprise_issuer_source_disclosed",
        "tenant_and_workspace_binding_disclosed",
        "return_path_labels_preserved",
        "session_continuity_preserves_local_editing",
        "identity_outage_degrades_truthfully",
        "no_authority_widening_on_return",
        "support_export_vocabulary_parity"
      ]
    },
    "defect_kind_token": {
      "type": "string",
      "enum": [
        "issuer_label_missing",
        "issuer_domain_label_missing",
        "jwks_source_label_missing",
        "public_issuer_fallback_used",
        "tenant_binding_missing",
        "workspace_binding_missing",
        "return_anchor_ref_missing",
        "return_mode_missing",
        "sign_out_or_outage_loses_local_editing",
        "identity_outage_missing_class",
        "outage_recovery_action_missing",
        "signed_in_active_without_granted_scope",
        "return_widens_authority_scope",
        "managed_session_state_ref_missing",
        "support_row_vocabulary_drift",
        "account_free_local_mislabeled"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_count",
        "support_row_count",
        "defect_count",
        "claimed_enterprise_row_count",
        "outage_or_denial_row_count",
        "signed_out_row_count",
        "profiles_present",
        "issuer_sources_present",
        "session_states_present",
        "recovery_actions_present"
      ],
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "support_row_count": { "type": "integer", "minimum": 0 },
        "defect_count": { "type": "integer", "minimum": 0 },
        "claimed_enterprise_row_count": { "type": "integer", "minimum": 0 },
        "outage_or_denial_row_count": { "type": "integer", "minimum": 0 },
        "signed_out_row_count": { "type": "integer", "minimum": 0 },
        "profiles_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/profile_token" }
        },
        "issuer_sources_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/issuer_source_token" }
        },
        "session_states_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/session_state_token" }
        },
        "recovery_actions_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/recovery_action_token" }
        }
      }
    },
    "issuer_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_token",
        "issuer_label",
        "issuer_domain_label",
        "jwks_source_label",
        "public_issuer_fallback_used"
      ],
      "properties": {
        "source_token": { "$ref": "#/$defs/issuer_source_token" },
        "issuer_label": { "type": "string" },
        "issuer_domain_label": { "type": "string" },
        "jwks_source_label": { "type": "string" },
        "public_issuer_fallback_used": { "type": "boolean" },
        "discovery_ref": { "type": "string" }
      }
    },
    "tenant_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binding_token"],
      "properties": {
        "binding_token": { "$ref": "#/$defs/tenant_binding_token" },
        "bound_tenant_or_org_ref": { "type": "string" },
        "bound_workspace_ref": { "type": "string" },
        "bound_actor_subject_ref": { "type": "string" }
      }
    },
    "return_path_label": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_label",
        "target_label",
        "requested_action_label",
        "return_mode_token",
        "return_origin_validation_token",
        "return_tenant_or_workspace_match_rule_token",
        "return_anchor_ref"
      ],
      "properties": {
        "workspace_label": { "type": "string" },
        "target_label": { "type": "string" },
        "requested_action_label": { "type": "string" },
        "return_mode_token": { "$ref": "#/$defs/return_mode_token" },
        "return_origin_validation_token": { "$ref": "#/$defs/return_origin_validation_token" },
        "return_tenant_or_workspace_match_rule_token": {
          "$ref": "#/$defs/return_match_rule_token"
        },
        "return_anchor_ref": { "type": "string" }
      }
    },
    "session_continuity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_state_token",
        "sign_out_continuity_token",
        "local_editing_summary_label",
        "managed_action_narrowing_label",
        "local_editing_preserved",
        "managed_actions_narrowed"
      ],
      "properties": {
        "session_state_token": { "$ref": "#/$defs/session_state_token" },
        "sign_out_continuity_token": { "$ref": "#/$defs/sign_out_continuity_token" },
        "local_editing_summary_label": { "type": "string" },
        "managed_action_narrowing_label": { "type": "string" },
        "local_editing_preserved": { "type": "boolean" },
        "managed_actions_narrowed": { "type": "boolean" },
        "managed_session_state_ref": { "type": "string" }
      }
    },
    "identity_outage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outage_token",
        "reason_label",
        "recovery_action_token",
        "recovery_action_label"
      ],
      "properties": {
        "outage_token": { "$ref": "#/$defs/outage_token" },
        "reason_label": { "type": "string" },
        "recovery_action_token": { "$ref": "#/$defs/recovery_action_token" },
        "recovery_action_label": { "type": "string" }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "case_id",
        "row_id",
        "source_claim_row_ref",
        "profile_token",
        "issuer",
        "tenant_binding",
        "return_path_label",
        "session_continuity",
        "identity_outage",
        "requested_authority_scope_token",
        "granted_authority_scope_token",
        "authority_scope_summary_label",
        "promised_audit_axes",
        "plain_language_summary",
        "redaction_class_token"
      ],
      "properties": {
        "record_kind": { "const": "auth_oidc_system_browser_beta_row_record" },
        "schema_version": { "const": 1 },
        "shared_contract_ref": { "const": "auth:oidc_system_browser_beta:v1" },
        "case_id": { "type": "string", "minLength": 1 },
        "row_id": { "type": "string", "minLength": 1 },
        "source_claim_row_ref": { "type": "string", "minLength": 1 },
        "profile_token": { "$ref": "#/$defs/profile_token" },
        "issuer": { "$ref": "#/$defs/issuer_disclosure" },
        "tenant_binding": { "$ref": "#/$defs/tenant_binding" },
        "return_path_label": { "$ref": "#/$defs/return_path_label" },
        "session_continuity": { "$ref": "#/$defs/session_continuity" },
        "identity_outage": { "$ref": "#/$defs/identity_outage" },
        "requested_authority_scope_token": { "$ref": "#/$defs/authority_scope_token" },
        "granted_authority_scope_token": { "$ref": "#/$defs/authority_scope_token" },
        "authority_scope_summary_label": { "type": "string" },
        "promised_audit_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/axis_token" }
        },
        "plain_language_summary": { "type": "string" },
        "redaction_class_token": { "type": "string", "minLength": 1 }
      }
    },
    "support_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "case_id",
        "row_id",
        "profile_token",
        "issuer_source_token",
        "issuer_label",
        "issuer_domain_label",
        "jwks_source_label",
        "public_issuer_fallback_used",
        "tenant_binding_token",
        "return_mode_token",
        "return_origin_validation_token",
        "return_tenant_or_workspace_match_rule_token",
        "return_anchor_ref",
        "workspace_label",
        "target_label",
        "requested_action_label",
        "session_state_token",
        "sign_out_continuity_token",
        "outage_token",
        "recovery_action_token",
        "requested_authority_scope_token",
        "granted_authority_scope_token",
        "redaction_class_token"
      ],
      "properties": {
        "record_kind": { "const": "auth_oidc_system_browser_beta_support_row_record" },
        "schema_version": { "const": 1 },
        "shared_contract_ref": { "const": "auth:oidc_system_browser_beta:v1" },
        "case_id": { "type": "string", "minLength": 1 },
        "row_id": { "type": "string", "minLength": 1 },
        "profile_token": { "$ref": "#/$defs/profile_token" },
        "issuer_source_token": { "$ref": "#/$defs/issuer_source_token" },
        "issuer_label": { "type": "string" },
        "issuer_domain_label": { "type": "string" },
        "jwks_source_label": { "type": "string" },
        "public_issuer_fallback_used": { "type": "boolean" },
        "tenant_binding_token": { "$ref": "#/$defs/tenant_binding_token" },
        "bound_tenant_or_org_ref": { "type": "string" },
        "bound_workspace_ref": { "type": "string" },
        "return_mode_token": { "$ref": "#/$defs/return_mode_token" },
        "return_origin_validation_token": { "$ref": "#/$defs/return_origin_validation_token" },
        "return_tenant_or_workspace_match_rule_token": {
          "$ref": "#/$defs/return_match_rule_token"
        },
        "return_anchor_ref": { "type": "string" },
        "workspace_label": { "type": "string" },
        "target_label": { "type": "string" },
        "requested_action_label": { "type": "string" },
        "session_state_token": { "$ref": "#/$defs/session_state_token" },
        "sign_out_continuity_token": { "$ref": "#/$defs/sign_out_continuity_token" },
        "outage_token": { "$ref": "#/$defs/outage_token" },
        "recovery_action_token": { "$ref": "#/$defs/recovery_action_token" },
        "requested_authority_scope_token": { "$ref": "#/$defs/authority_scope_token" },
        "granted_authority_scope_token": { "$ref": "#/$defs/authority_scope_token" },
        "redaction_class_token": { "type": "string", "minLength": 1 }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "defect_kind",
        "defect_kind_token",
        "row_id",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": { "const": "auth_oidc_system_browser_beta_defect_record" },
        "schema_version": { "const": 1 },
        "shared_contract_ref": { "const": "auth:oidc_system_browser_beta:v1" },
        "defect_id": { "type": "string", "minLength": 1 },
        "defect_kind": { "$ref": "#/$defs/defect_kind_token" },
        "defect_kind_token": { "$ref": "#/$defs/defect_kind_token" },
        "row_id": { "type": "string", "minLength": 1 },
        "field": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 }
      }
    }
  }
}
