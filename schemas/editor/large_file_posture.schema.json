{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/editor/large_file_posture.schema.json",
  "title": "Aureline large-file posture",
  "description": "Boundary schema for the governed, export-safe large-file posture record that stabilizes large-file mode, binary-safe preview, and the restricted-write posture into one record per posture. The record is projected from the at-open large-file classification observation and the limited-mode file record. It proves source fidelity (byte-faithful read, binary-safe preview, BOM preserved), canonical-path truth (canonical write target resolved), restore-no-rerun behavior (whole-file participant writes blocked, reviewed range-only writes, disclosed override route), and lineage/export honesty, and auto-narrows below Stable with a named reason when a claim cannot be proven. Raw source bytes are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "large_file_posture_schema_version",
    "schema_ref",
    "posture_id",
    "workspace_ref",
    "document_ref",
    "limited_mode_file_ref",
    "canonical_uri",
    "bytes_on_disk",
    "activation",
    "preview_fidelity",
    "write_posture",
    "evaluated_capabilities",
    "reduced_capability_count",
    "inspection_hooks",
    "stable_qualification",
    "raw_payload_excluded",
    "summary"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": {
      "const": "large_file_posture_record"
    },
    "large_file_posture_schema_version": {
      "type": "integer",
      "const": 1
    },
    "schema_ref": {
      "const": "schemas/editor/large_file_posture.schema.json"
    },
    "posture_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "workspace_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "document_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "limited_mode_file_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "canonical_uri": {
      "type": "string"
    },
    "bytes_on_disk": {
      "type": "integer",
      "minimum": 0
    },
    "activation": {
      "$ref": "#/$defs/activation_summary"
    },
    "preview_fidelity": {
      "$ref": "#/$defs/preview_fidelity_summary"
    },
    "write_posture": {
      "$ref": "#/$defs/restricted_write_posture"
    },
    "evaluated_capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/capability_record"
      }
    },
    "reduced_capability_count": {
      "type": "integer",
      "minimum": 0
    },
    "inspection_hooks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/inspection_hook"
      }
    },
    "stable_qualification": {
      "$ref": "#/$defs/stable_qualification"
    },
    "raw_payload_excluded": {
      "const": true
    },
    "summary": {
      "$ref": "#/$defs/short_sentence"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 700
    },
    "file_mode": {
      "type": "string",
      "enum": ["normal", "large_file"]
    },
    "activation_trigger": {
      "type": "string",
      "enum": [
        "size_threshold",
        "resource_pressure",
        "classification",
        "decode_posture",
        "operator_override"
      ]
    },
    "bom_kind": {
      "type": "string",
      "enum": [
        "utf_8",
        "utf_16_le",
        "utf_16_be",
        "utf_32_le",
        "utf_32_be"
      ]
    },
    "safe_preview_class": {
      "type": "string",
      "enum": ["paged_raw_text_preview", "binary_safe_preview"]
    },
    "edit_policy_class": {
      "type": "string",
      "enum": ["read_only_by_default", "range_constrained"]
    },
    "write_policy_class": {
      "type": "string",
      "enum": ["whole_file_participants_blocked", "range_only_reviewed_writes"]
    },
    "capability_state": {
      "type": "string",
      "enum": ["allowed", "downgraded", "denied"]
    },
    "inspection_hook_class": {
      "type": "string",
      "enum": ["compare", "checkpoint", "export", "repair"]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "source_read_not_byte_faithful",
        "preview_not_binary_safe",
        "canonical_target_unresolved",
        "whole_file_write_not_restricted",
        "override_route_not_disclosed",
        "destructive_action_no_checkpoint",
        "posture_export_unsafe"
      ]
    },
    "activation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "reason",
        "looks_binary",
        "looks_minified",
        "matches_pack_suffix",
        "has_null_bytes",
        "sniff_bytes",
        "non_printable_per_mille"
      ],
      "properties": {
        "mode": { "$ref": "#/$defs/file_mode" },
        "trigger_class": { "$ref": "#/$defs/activation_trigger" },
        "reason": { "$ref": "#/$defs/non_empty_string" },
        "looks_binary": { "type": "boolean" },
        "looks_minified": { "type": "boolean" },
        "matches_pack_suffix": { "type": "boolean" },
        "bom_kind": { "$ref": "#/$defs/bom_kind" },
        "has_null_bytes": { "type": "boolean" },
        "sniff_bytes": { "type": "integer", "minimum": 0 },
        "non_printable_per_mille": { "type": "integer", "minimum": 0, "maximum": 1000 }
      }
    },
    "preview_fidelity_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "safe_preview_class",
        "byte_faithful_read",
        "whole_file_load_blocked",
        "binary_safe_preview_selected",
        "bom_preserved",
        "source_fidelity_proven"
      ],
      "properties": {
        "safe_preview_class": { "$ref": "#/$defs/safe_preview_class" },
        "byte_faithful_read": { "type": "boolean" },
        "whole_file_load_blocked": { "type": "boolean" },
        "binary_safe_preview_selected": { "type": "boolean" },
        "bom_preserved": { "type": "boolean" },
        "source_fidelity_proven": { "type": "boolean" }
      }
    },
    "restricted_write_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edit_policy_class",
        "write_policy_class",
        "whole_file_participants_blocked",
        "range_only_reviewed_writes",
        "override_action_id",
        "override_disclosed",
        "canonical_target_resolved",
        "restricted_write_proven"
      ],
      "properties": {
        "edit_policy_class": { "$ref": "#/$defs/edit_policy_class" },
        "write_policy_class": { "$ref": "#/$defs/write_policy_class" },
        "whole_file_participants_blocked": { "type": "boolean" },
        "range_only_reviewed_writes": { "type": "boolean" },
        "override_action_id": { "$ref": "#/$defs/non_empty_string" },
        "override_disclosed": { "type": "boolean" },
        "canonical_target_resolved": { "type": "boolean" },
        "restricted_write_proven": { "type": "boolean" }
      }
    },
    "capability_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability_id", "state", "disclosure"],
      "properties": {
        "capability_id": { "$ref": "#/$defs/non_empty_string" },
        "state": { "$ref": "#/$defs/capability_state" },
        "disclosure": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "inspection_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hook_class", "action_id", "label", "available", "disclosure"],
      "properties": {
        "hook_class": { "$ref": "#/$defs/inspection_hook_class" },
        "action_id": { "$ref": "#/$defs/non_empty_string" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "available": { "type": "boolean" },
        "disclosure": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qualified", "level", "narrow_reasons"],
      "properties": {
        "qualified": { "type": "boolean" },
        "level": {
          "type": "string",
          "enum": ["stable", "narrowed_below_stable"]
        },
        "narrow_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason" },
          "uniqueItems": true
        }
      }
    }
  }
}
