{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/editor/mode_state_record.schema.json",
  "title": "Aureline modal-editing safety packet",
  "description": "Boundary schema for the governed, export-safe modal-editing safety packet that composes editor mode-state, surface downgrade truth, and keymap import regression records. It proves that modal state is product state, register routes fail closed, macro replays are bounded, sequence states are visible, recovery paths exist, surface downgrades are labeled and reversible, and import regressions use a closed vocabulary. Raw editor text, raw macro payloads, raw clipboard contents, raw keymaps, and private host payloads are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "schema_ref",
    "packet_id",
    "mode_state",
    "surface_downgrades",
    "import_regressions",
    "command_graph_unified",
    "latency_budget_micros",
    "support_export_refs"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": {
      "const": "modal_editing_safety_packet"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "schema_ref": {
      "const": "schemas/editor/mode_state_record.schema.json"
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "mode_state": {
      "$ref": "#/$defs/editor_mode_state_record"
    },
    "surface_downgrades": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/surface_downgrade_record"
      }
    },
    "import_regressions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/keymap_import_regression_record"
      }
    },
    "command_graph_unified": {
      "type": "boolean",
      "const": true
    },
    "latency_budget_micros": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "support_export_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "editor_mode_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "mode_state_id",
        "current_mode",
        "source_preset_ref",
        "source_preset_label",
        "keymap_source_kind",
        "read_write_posture",
        "surface_ref",
        "platform_class",
        "sequence_guides",
        "register_routes",
        "pending_operator",
        "macro_replay_reviews",
        "recovery_actions",
        "accessibility_announcements",
        "support_export_refs"
      ],
      "properties": {
        "record_kind": {
          "const": "editor_mode_state_record"
        },
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "mode_state_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "current_mode": {
          "enum": ["insert", "normal", "visual", "command", "modeless"]
        },
        "source_preset_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_preset_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "keymap_source_kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "read_write_posture": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "platform_class": {
          "$ref": "#/$defs/non_empty_string"
        },
        "sequence_guides": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sequence_guide_record"
          }
        },
        "register_routes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/register_route_record"
          }
        },
        "pending_operator": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/pending_operator_record" }
          ]
        },
        "macro_replay_reviews": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/macro_replay_review_record"
          }
        },
        "recovery_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/mode_recovery_action"
          }
        },
        "accessibility_announcements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "support_export_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "sequence_guide_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "guide_id",
        "typed_prefix",
        "sequence_state",
        "source_preset_ref",
        "timeout_posture",
        "available_next_keys",
        "diagnostics_route_ref",
        "accessibility_announcement"
      ],
      "properties": {
        "guide_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "typed_prefix": {
          "$ref": "#/$defs/non_empty_string"
        },
        "sequence_state": {
          "enum": ["ready", "partial", "ambiguous", "blocked", "unsupported_surface"]
        },
        "source_preset_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "timeout_posture": {
          "$ref": "#/$defs/non_empty_string"
        },
        "available_next_keys": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sequence_guide_option"
          }
        },
        "unsupported_or_blocked_note": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/non_empty_string" }
          ]
        },
        "conflict_review_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/non_empty_string" }
          ]
        },
        "diagnostics_route_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "accessibility_announcement": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "sequence_guide_option": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "next_key_label",
        "source_label",
        "state"
      ],
      "properties": {
        "next_key_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "command_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/non_empty_string" }
          ]
        },
        "source_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "state": {
          "enum": ["ready", "partial", "ambiguous", "blocked", "unsupported_surface"]
        }
      }
    },
    "register_route_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_ref",
        "route_kind",
        "route_label",
        "target_ref",
        "availability",
        "destructive_action_requires_review",
        "fail_closed",
        "visible_reason",
        "review_action_ref",
        "accessibility_label"
      ],
      "properties": {
        "route_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "route_kind": {
          "enum": [
            "editor_local",
            "system_clipboard",
            "remote_clipboard_bridge",
            "named_register",
            "search_register",
            "macro_register",
            "policy_blocked"
          ]
        },
        "route_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "availability": {
          "enum": ["available", "requires_review", "blocked_by_policy", "unsupported"]
        },
        "destructive_action_requires_review": {
          "type": "boolean"
        },
        "fail_closed": {
          "type": "boolean"
        },
        "visible_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "review_action_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "accessibility_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "pending_operator_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pending_operator_ref",
        "operator_label",
        "object_class",
        "scope_preview_ref",
        "destructive",
        "cancel_route_ref"
      ],
      "properties": {
        "pending_operator_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "operator_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "count": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 1 }
          ]
        },
        "object_class": {
          "$ref": "#/$defs/non_empty_string"
        },
        "scope_preview_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "command_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/non_empty_string" }
          ]
        },
        "destructive": {
          "type": "boolean"
        },
        "cancel_route_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "macro_replay_review_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_ref",
        "source_register_ref",
        "target_scope_class",
        "write_classes_touched",
        "crosses_files",
        "invokes_run_capable_commands",
        "mutates_settings",
        "relies_on_unstable_timing",
        "outcome_class",
        "visible_reason",
        "next_safe_actions"
      ],
      "properties": {
        "review_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_register_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_scope_class": {
          "$ref": "#/$defs/non_empty_string"
        },
        "write_classes_touched": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "crosses_files": {
          "type": "boolean"
        },
        "invokes_run_capable_commands": {
          "type": "boolean"
        },
        "mutates_settings": {
          "type": "boolean"
        },
        "relies_on_unstable_timing": {
          "type": "boolean"
        },
        "outcome_class": {
          "enum": ["local_editor_only", "requires_review", "rejected"]
        },
        "visible_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "next_safe_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/mode_recovery_action"
          }
        }
      }
    },
    "mode_recovery_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_ref",
        "label",
        "keyboard_route"
      ],
      "properties": {
        "action_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "command_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/non_empty_string" }
          ]
        },
        "keyboard_route": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "surface_downgrade_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "downgrade_ref",
        "downgrade_kind",
        "surface_ref",
        "visible_label",
        "visible_reason",
        "reversible",
        "keyboard_route_to_restore",
        "accessibility_announcement"
      ],
      "properties": {
        "downgrade_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "downgrade_kind": {
          "enum": ["ime", "accessibility", "browser_companion", "restricted_mode", "large_file"]
        },
        "surface_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "visible_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "visible_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reversible": {
          "type": "boolean"
        },
        "keyboard_route_to_restore": {
          "$ref": "#/$defs/non_empty_string"
        },
        "accessibility_announcement": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "keymap_import_regression_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "regression_ref",
        "source_preset_ref",
        "sequence_or_command_ref",
        "outcome_class",
        "visible_reason",
        "diagnostics_route_ref"
      ],
      "properties": {
        "regression_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_preset_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "sequence_or_command_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "outcome_class": {
          "enum": ["exact", "translated", "partial", "shimmed", "unsupported"]
        },
        "visible_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "fallback_command_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/non_empty_string" }
          ]
        },
        "diagnostics_route_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
