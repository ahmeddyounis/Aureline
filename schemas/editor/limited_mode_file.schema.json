{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/editor/limited_mode_file.schema.json",
  "title": "Aureline limited-mode file record",
  "description": "Boundary schema for files opened in limited mode because size, resource pressure, content classification, decode posture, or explicit user choice makes the normal editor path unsafe. Records carry safe-preview posture, constrained edit/write policy, capability reductions, override disclosure, and support-safe summary only; raw source bytes and raw paths beyond the resolved URI are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "limited_mode_file_schema_version",
    "schema_ref",
    "limited_mode_file_id",
    "workspace_ref",
    "document_ref",
    "canonical_uri",
    "bytes_on_disk",
    "activation_trigger_class",
    "activation_reason",
    "safe_preview_class",
    "edit_policy_class",
    "write_policy_class",
    "override_action",
    "capabilities",
    "raw_payload_excluded",
    "support_summary"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": {
      "const": "limited_mode_file_record"
    },
    "limited_mode_file_schema_version": {
      "type": "integer",
      "const": 1
    },
    "schema_ref": {
      "const": "schemas/editor/limited_mode_file.schema.json"
    },
    "limited_mode_file_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "workspace_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "document_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "canonical_uri": {
      "$ref": "#/$defs/non_empty_string"
    },
    "bytes_on_disk": {
      "type": "integer",
      "minimum": 0
    },
    "activation_trigger_class": {
      "oneOf": [
        { "$ref": "#/$defs/activation_trigger_class" },
        { "type": "null" }
      ]
    },
    "activation_reason": {
      "$ref": "#/$defs/short_sentence"
    },
    "safe_preview_class": {
      "$ref": "#/$defs/safe_preview_class"
    },
    "edit_policy_class": {
      "$ref": "#/$defs/edit_policy_class"
    },
    "write_policy_class": {
      "$ref": "#/$defs/write_policy_class"
    },
    "override_action": {
      "$ref": "#/$defs/override_action"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/capability_record"
      }
    },
    "raw_payload_excluded": {
      "const": true
    },
    "support_summary": {
      "$ref": "#/$defs/short_sentence"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 700
    },
    "activation_trigger_class": {
      "type": "string",
      "enum": [
        "size_threshold",
        "resource_pressure",
        "classification",
        "decode_posture",
        "operator_override"
      ]
    },
    "safe_preview_class": {
      "type": "string",
      "enum": [
        "paged_raw_text_preview",
        "binary_safe_preview"
      ]
    },
    "edit_policy_class": {
      "type": "string",
      "enum": [
        "read_only_by_default",
        "range_constrained"
      ]
    },
    "write_policy_class": {
      "type": "string",
      "enum": [
        "whole_file_participants_blocked",
        "range_only_reviewed_writes"
      ]
    },
    "capability_state": {
      "type": "string",
      "enum": [
        "allowed",
        "downgraded",
        "denied"
      ]
    },
    "override_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "label",
        "disclosure"
      ],
      "properties": {
        "action_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "disclosure": {
          "$ref": "#/$defs/short_sentence"
        }
      }
    },
    "capability_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_id",
        "state",
        "disclosure"
      ],
      "properties": {
        "capability_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "state": {
          "$ref": "#/$defs/capability_state"
        },
        "disclosure": {
          "$ref": "#/$defs/short_sentence"
        }
      }
    }
  }
}
