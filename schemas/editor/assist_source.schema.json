{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/editor/assist_source.schema.json",
  "title": "Aureline editor assist source-label projection",
  "description": "Boundary schema for the source-label projection shared by completion rows, snippet strips, AI inline assist, telemetry, support export, and docs. The projection carries controlled source classes and export-safe labels only; raw completion payloads, source text, model output, logs, file paths, URLs, and secrets never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "assist_schema_version",
    "source_descriptor_id",
    "source_family",
    "source_label_class",
    "source_label",
    "telemetry_token",
    "ui_badge_label",
    "support_export_label",
    "docs_label_ref",
    "requires_visual_distinction",
    "captured_at",
    "export_safe_summary"
  ],
  "properties": {
    "record_kind": { "const": "assist_source_label_projection" },
    "assist_schema_version": { "type": "integer", "const": 2 },
    "source_descriptor_id": { "$ref": "#/$defs/opaque_ref" },
    "source_family": { "$ref": "#/$defs/assist_source_family" },
    "source_label_class": { "$ref": "#/$defs/assist_source_label_class" },
    "source_label": { "$ref": "#/$defs/short_label" },
    "telemetry_token": { "$ref": "#/$defs/opaque_ref" },
    "ui_badge_label": { "$ref": "#/$defs/short_label" },
    "support_export_label": { "$ref": "#/$defs/short_summary" },
    "docs_label_ref": { "$ref": "#/$defs/opaque_ref" },
    "requires_visual_distinction": { "type": "boolean" },
    "captured_at": { "$ref": "#/$defs/timestamp" },
    "export_safe_summary": { "$ref": "#/$defs/short_summary" }
  },
  "$defs": {
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "short_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "short_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 640
    },
    "assist_source_family": {
      "type": "string",
      "enum": [
        "language_server",
        "fallback_lexical",
        "snippet",
        "project_graph",
        "framework_pack",
        "ai_assist",
        "tool_adapter"
      ]
    },
    "assist_source_label_class": {
      "type": "string",
      "enum": [
        "deterministic_language",
        "cached_fallback",
        "snippet_origin",
        "ai_inline_assist",
        "project_graph",
        "framework_provider",
        "tool_adapter"
      ]
    }
  }
}
