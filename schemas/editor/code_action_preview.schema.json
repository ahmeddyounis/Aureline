{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/editor/code_action_preview.schema.json",
  "title": "Aureline editor code-action preview and tainted-evidence admission",
  "description": "Boundary schema for editor quick-fix and code-action preview records. It preserves provider attribution, mutation scope counts, preview or approval posture, rollback readiness, and tainted-evidence fences without exporting raw patches, raw source text, raw logs, raw paths, raw tool arguments, URLs, or secrets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "code_action_preview_schema_version",
    "preview_id",
    "code_action_id",
    "action_label",
    "provider_label",
    "evidence_trust_class",
    "tainted_context_ref",
    "trusted_promotion_ref",
    "preview_requirement_class",
    "apply_posture_class",
    "decision_class",
    "direct_apply_block_reason_refs",
    "preview_required",
    "approval_required",
    "rollback_required",
    "grouped_undo_required",
    "rollback_route_available",
    "mutation_counts",
    "blocking_reason_classes",
    "undo_group_ref",
    "checkpoint_ref",
    "review_packet_ref",
    "validation_plan",
    "redaction_class",
    "captured_at",
    "accessibility_summary",
    "export_safe_summary"
  ],
  "properties": {
    "record_kind": { "const": "editor_code_action_preview_record" },
    "code_action_preview_schema_version": { "type": "integer", "const": 1 },
    "preview_id": { "$ref": "#/$defs/opaque_ref" },
    "code_action_id": { "$ref": "#/$defs/opaque_ref" },
    "action_label": { "$ref": "#/$defs/short_label" },
    "provider_label": { "$ref": "#/$defs/short_label" },
    "evidence_trust_class": { "$ref": "#/$defs/evidence_trust_class" },
    "tainted_context_ref": { "$ref": "#/$defs/nullable_ref" },
    "trusted_promotion_ref": { "$ref": "#/$defs/nullable_ref" },
    "preview_requirement_class": { "$ref": "#/$defs/preview_requirement_class" },
    "apply_posture_class": { "$ref": "#/$defs/apply_posture_class" },
    "decision_class": { "$ref": "#/$defs/decision_class" },
    "direct_apply_block_reason_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_ref" },
      "uniqueItems": true
    },
    "preview_required": { "type": "boolean" },
    "approval_required": { "type": "boolean" },
    "rollback_required": { "type": "boolean" },
    "grouped_undo_required": { "type": "boolean" },
    "rollback_route_available": { "type": "boolean" },
    "mutation_counts": { "$ref": "#/$defs/mutation_counts" },
    "blocking_reason_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/blocking_reason_class" }
    },
    "undo_group_ref": { "$ref": "#/$defs/nullable_ref" },
    "checkpoint_ref": { "$ref": "#/$defs/nullable_ref" },
    "review_packet_ref": { "$ref": "#/$defs/nullable_ref" },
    "validation_plan": { "$ref": "#/$defs/validation_plan" },
    "redaction_class": { "$ref": "#/$defs/redaction_class" },
    "captured_at": { "$ref": "#/$defs/timestamp" },
    "accessibility_summary": { "$ref": "#/$defs/short_summary" },
    "export_safe_summary": { "$ref": "#/$defs/short_summary" }
  },
  "$defs": {
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "nullable_ref": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "short_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "short_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 800
    },
    "evidence_trust_class": {
      "type": "string",
      "enum": [
        "trusted_semantic",
        "trusted_parser_promoted",
        "user_promoted",
        "tainted_terminal_output",
        "tainted_build_log",
        "tainted_runtime_log",
        "tainted_imported_diagnostic",
        "unknown_untrusted"
      ]
    },
    "preview_requirement_class": {
      "type": "string",
      "enum": [
        "not_required",
        "inline_summary",
        "structured_diff",
        "batch_scope_preview",
        "generated_or_protected_preview_required",
        "policy_or_repo_mutation_preview_required"
      ]
    },
    "apply_posture_class": {
      "type": "string",
      "enum": [
        "apply_inline_allowed",
        "preview_before_apply",
        "blocked_pending_user_review",
        "blocked_pending_policy_or_trust",
        "not_applicable_read_only"
      ]
    },
    "decision_class": {
      "type": "string",
      "enum": [
        "inline_apply_allowed",
        "preview_required",
        "approval_required",
        "blocked_tainted_evidence",
        "inspect_only"
      ]
    },
    "blocking_reason_class": {
      "type": "string",
      "enum": [
        "generated_paths_present",
        "protected_paths_present",
        "provider_freshness_unmet",
        "semantic_epoch_mismatch",
        "imported_snapshot_only",
        "policy_denied",
        "runtime_evidence_only_no_safe_edit",
        "content_integrity_cue_present"
      ]
    },
    "validation_hint_class": {
      "type": "string",
      "enum": [
        "rerun_diagnostic_producer",
        "rerun_build_or_test",
        "refresh_semantic_snapshot",
        "review_generated_outputs",
        "inspect_protected_paths",
        "compare_imported_baseline_delta",
        "no_automatic_validation_available"
      ]
    },
    "replay_hint_class": {
      "type": "string",
      "enum": [
        "replay_against_same_execution_context",
        "replay_against_new_semantic_epoch",
        "export_review_packet",
        "attach_support_bundle_evidence",
        "requires_rule_metadata_refresh"
      ]
    },
    "mutation_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "affected_diagnostic_count",
        "affected_file_count",
        "affected_anchor_count",
        "generated_path_count",
        "protected_path_count",
        "blocked_path_count",
        "configuration_mutation_count",
        "dependency_mutation_count"
      ],
      "properties": {
        "affected_diagnostic_count": { "type": "integer", "minimum": 0 },
        "affected_file_count": { "type": "integer", "minimum": 0 },
        "affected_anchor_count": { "type": "integer", "minimum": 0 },
        "generated_path_count": { "type": "integer", "minimum": 0 },
        "protected_path_count": { "type": "integer", "minimum": 0 },
        "blocked_path_count": { "type": "integer", "minimum": 0 },
        "configuration_mutation_count": { "type": "integer", "minimum": 0 },
        "dependency_mutation_count": { "type": "integer", "minimum": 0 }
      }
    },
    "validation_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validation_hint_classes",
        "replay_hint_classes",
        "validation_summary"
      ],
      "properties": {
        "validation_hint_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/validation_hint_class" }
        },
        "replay_hint_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/replay_hint_class" }
        },
        "validation_summary": { "$ref": "#/$defs/short_summary" }
      }
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    }
  }
}
