{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/editor/refactor_preview.schema.json",
  "title": "Aureline refactor / replace preview packet contract",
  "description": "Boundary schema for the refactor_preview_record frozen in docs/editor/refactor_and_replace_transaction_contract.md. The record is the governed preview packet every find/replace, workspace replace, rename, refactor / move / extract, and imported or generated patch apply surface assembles before the matching refactor_transaction_record may transition into apply. It captures match counts, excluded scope and exclusion reasons, file-state warnings, affected file and symbol counts, generated / protected / blocked path counts, import and config change counts, current index freshness and semantic-layer state, checkpoint and rollback path posture, and the preview completeness class. Raw match text, raw replacement text, raw diff bodies, raw patch hunks, raw paths, raw symbol bodies, raw provider logs, and raw secret material never cross this boundary; the record carries opaque ids, typed vocabulary, epoch bindings, and export-safe summaries only. Adding a new exclusion-reason class, file-state warning class, completeness class, rollback-path class, freshness class, semantic-layer state, source-kind class, support class, language provider family, locality class, redaction class, or epoch role is additive-minor and bumps refactor_preview_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/refactor_preview_record"
    }
  ],
  "$defs": {
    "refactor_preview_schema_version": {
      "type": "integer",
      "const": 1
    },

    "record_kind": {
      "type": "string",
      "const": "refactor_preview_record"
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1
    },

    "timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "reviewable_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    },

    "non_negative_int": {
      "type": "integer",
      "minimum": 0
    },

    "operation_class": {
      "type": "string",
      "enum": [
        "find_replace_in_file",
        "workspace_replace",
        "rename_symbol",
        "refactor_move_or_extract",
        "imported_or_generated_patch_apply"
      ]
    },

    "preview_completeness_class": {
      "type": "string",
      "enum": [
        "preview_complete_for_full_scope",
        "preview_partial_due_to_index_floor",
        "preview_partial_due_to_provider_quarantine",
        "preview_partial_due_to_imported_patch_unverified",
        "preview_partial_due_to_excluded_paths",
        "preview_blocked_pending_user_review"
      ]
    },

    "exclusion_reason_class": {
      "type": "string",
      "enum": [
        "excluded_by_user_path_filter",
        "excluded_by_workspace_excludes",
        "excluded_by_vcs_ignore",
        "excluded_as_generated_pair_path",
        "excluded_as_protected_or_policy_path",
        "excluded_due_to_provider_freshness_floor",
        "excluded_due_to_semantic_index_partial",
        "excluded_due_to_imported_patch_anchor_unresolved",
        "excluded_due_to_external_modification",
        "excluded_due_to_open_buffer_dirty",
        "excluded_due_to_merge_conflict",
        "excluded_due_to_binary_or_unsupported_encoding",
        "excluded_due_to_symlink_policy",
        "excluded_due_to_unloaded_root"
      ]
    },

    "file_state_warning_class": {
      "type": "string",
      "enum": [
        "open_buffer_dirty_uncommitted",
        "external_modification_detected",
        "merge_conflict_detected",
        "case_only_path_collision",
        "encoding_mixed_or_uncertain",
        "line_ending_mixed_or_uncertain",
        "binary_or_large_file_threshold",
        "generated_pair_path_present",
        "protected_or_policy_path_present",
        "imported_patch_anchor_drifted",
        "symlink_traversal_present"
      ]
    },

    "rollback_path_class": {
      "type": "string",
      "enum": [
        "exact_undo_via_local_history_checkpoint",
        "compensating_revert_via_workspace_diff",
        "regenerate_first_then_replay",
        "manual_review_required_no_automatic_path",
        "imported_patch_inverse_required",
        "no_safe_rollback_available"
      ]
    },

    "freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "recent",
        "stale",
        "superseded",
        "imported_snapshot",
        "unverifiable"
      ]
    },

    "semantic_layer_state_class": {
      "type": "string",
      "enum": [
        "semantic_current_exact",
        "semantic_current_remapped",
        "semantic_narrowed_scope",
        "semantic_cached_recent",
        "semantic_stale_epoch_mismatch",
        "syntactic_or_text_only",
        "structural_or_ast_only",
        "imported_patch_only",
        "policy_asserted_non_semantic"
      ]
    },

    "source_kind_class": {
      "type": "string",
      "enum": [
        "compiler_or_build",
        "language_server",
        "linter_formatter_style",
        "framework_or_schema_analyzer",
        "runtime_test_or_debug",
        "policy_trust_or_security",
        "editor_text_engine",
        "automation_or_recipe",
        "imported_patch_source",
        "generator_source_bridge"
      ]
    },

    "support_class": {
      "type": "string",
      "enum": [
        "first_party_supported",
        "first_party_best_effort",
        "external_tooling",
        "policy_governed",
        "imported_static_only"
      ]
    },

    "language_provider_family": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "enum": [
            "syntax",
            "project_graph",
            "language_server",
            "framework_pack",
            "notebook_adapter",
            "generated_source_bridge",
            "ai_assist",
            "editor_text_engine",
            "imported_patch_engine"
          ]
        }
      ]
    },

    "locality_class": {
      "type": "string",
      "enum": [
        "local_in_process",
        "local_sidecar",
        "workspace_remote_agent",
        "managed_service",
        "imported_snapshot"
      ]
    },

    "epoch_role_class": {
      "type": "string",
      "enum": [
        "workspace_scope",
        "language_semantic_model",
        "build_graph",
        "execution_run",
        "imported_scan",
        "imported_patch",
        "anchor_remap_family",
        "policy_bundle",
        "search_index_epoch",
        "generated_artifact_lineage"
      ]
    },

    "trust_state": {
      "type": "string",
      "enum": [
        "trusted",
        "restricted"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_epoch",
        "trust_state",
        "execution_context_id"
      ],
      "properties": {
        "policy_epoch": {
          "$ref": "#/$defs/opaque_id"
        },
        "trust_state": {
          "$ref": "#/$defs/trust_state"
        },
        "execution_context_id": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },

    "epoch_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "epoch_role_class",
        "epoch_ref"
      ],
      "properties": {
        "epoch_role_class": {
          "$ref": "#/$defs/epoch_role_class"
        },
        "epoch_ref": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },

    "match_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_match_count",
        "matched_file_count",
        "matched_symbol_count",
        "skipped_match_count",
        "ambiguous_match_count"
      ],
      "properties": {
        "total_match_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "matched_file_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "matched_symbol_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "skipped_match_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "ambiguous_match_count": {
          "$ref": "#/$defs/non_negative_int"
        }
      }
    },

    "exclusion_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exclusion_reason_class",
        "excluded_path_count",
        "excluded_match_count",
        "excluded_path_set_ref",
        "summary"
      ],
      "properties": {
        "exclusion_reason_class": {
          "$ref": "#/$defs/exclusion_reason_class"
        },
        "excluded_path_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "excluded_match_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "excluded_path_set_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },

    "file_state_warning_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file_state_warning_class",
        "warned_path_count",
        "warned_path_set_ref",
        "summary"
      ],
      "properties": {
        "file_state_warning_class": {
          "$ref": "#/$defs/file_state_warning_class"
        },
        "warned_path_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "warned_path_set_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },

    "impact_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "affected_file_count",
        "affected_symbol_count",
        "affected_anchor_count",
        "generated_path_count",
        "protected_path_count",
        "blocked_path_count",
        "import_or_config_change_count",
        "downstream_consumer_count"
      ],
      "properties": {
        "affected_file_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "affected_symbol_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "affected_anchor_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "generated_path_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "protected_path_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "blocked_path_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "import_or_config_change_count": {
          "$ref": "#/$defs/non_negative_int"
        },
        "downstream_consumer_count": {
          "$ref": "#/$defs/non_negative_int"
        }
      }
    },

    "index_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness_class",
        "semantic_layer_state_class",
        "language_provider_family",
        "locality_class",
        "current_epoch_bindings",
        "summary"
      ],
      "properties": {
        "freshness_class": {
          "$ref": "#/$defs/freshness_class"
        },
        "semantic_layer_state_class": {
          "$ref": "#/$defs/semantic_layer_state_class"
        },
        "language_provider_family": {
          "$ref": "#/$defs/language_provider_family"
        },
        "locality_class": {
          "$ref": "#/$defs/locality_class"
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          }
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },

    "checkpoint_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_required",
        "checkpoint_ref",
        "rollback_path_class",
        "summary"
      ],
      "properties": {
        "checkpoint_required": {
          "type": "boolean"
        },
        "checkpoint_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "rollback_path_class": {
          "$ref": "#/$defs/rollback_path_class"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      }
    },

    "refactor_preview_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "refactor_preview_schema_version",
        "preview_id",
        "transaction_ref",
        "operation_class",
        "preview_completeness_class",
        "match_counts",
        "exclusion_rows",
        "file_state_warnings",
        "impact_counts",
        "index_freshness",
        "checkpoint_descriptor",
        "current_epoch_bindings",
        "policy_context",
        "redaction_class",
        "captured_at",
        "export_safe_summary"
      ],
      "properties": {
        "record_kind": {
          "$ref": "#/$defs/record_kind"
        },
        "refactor_preview_schema_version": {
          "$ref": "#/$defs/refactor_preview_schema_version"
        },
        "preview_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "transaction_ref": {
          "$ref": "#/$defs/opaque_id"
        },
        "operation_class": {
          "$ref": "#/$defs/operation_class"
        },
        "preview_completeness_class": {
          "$ref": "#/$defs/preview_completeness_class"
        },
        "match_counts": {
          "$ref": "#/$defs/match_counts"
        },
        "exclusion_rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/exclusion_row"
          },
          "uniqueItems": true
        },
        "file_state_warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/file_state_warning_row"
          },
          "uniqueItems": true
        },
        "impact_counts": {
          "$ref": "#/$defs/impact_counts"
        },
        "index_freshness": {
          "$ref": "#/$defs/index_freshness"
        },
        "checkpoint_descriptor": {
          "$ref": "#/$defs/checkpoint_descriptor"
        },
        "current_epoch_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epoch_binding"
          }
        },
        "policy_context": {
          "$ref": "#/$defs/policy_context"
        },
        "redaction_class": {
          "$ref": "#/$defs/redaction_class"
        },
        "captured_at": {
          "$ref": "#/$defs/timestamp"
        },
        "export_safe_summary": {
          "$ref": "#/$defs/reviewable_summary"
        }
      },
      "allOf": [
        {
          "description": "A preview that names any non-zero generated_path_count, protected_path_count, blocked_path_count, or import_or_config_change_count MUST resolve preview_completeness_class outside preview_complete_for_full_scope when those counts come from exclusions or partial coverage; preview_complete_for_full_scope is reserved for previews whose full scope materialised without provider, index, or imported-patch shortfall.",
          "if": {
            "properties": {
              "preview_completeness_class": {
                "const": "preview_complete_for_full_scope"
              }
            }
          },
          "then": {
            "properties": {
              "exclusion_rows": {
                "not": {
                  "contains": {
                    "properties": {
                      "exclusion_reason_class": {
                        "enum": [
                          "excluded_due_to_provider_freshness_floor",
                          "excluded_due_to_semantic_index_partial",
                          "excluded_due_to_imported_patch_anchor_unresolved",
                          "excluded_due_to_unloaded_root"
                        ]
                      }
                    },
                    "required": [
                      "exclusion_reason_class"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "description": "Operations that mutate beyond a single buffer (workspace_replace, rename_symbol, refactor_move_or_extract, imported_or_generated_patch_apply) MUST require a checkpoint via checkpoint_required = true so the rollback path is attributable.",
          "if": {
            "properties": {
              "operation_class": {
                "enum": [
                  "workspace_replace",
                  "rename_symbol",
                  "refactor_move_or_extract",
                  "imported_or_generated_patch_apply"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "checkpoint_descriptor": {
                "properties": {
                  "checkpoint_required": {
                    "const": true
                  }
                },
                "required": [
                  "checkpoint_required"
                ]
              }
            }
          }
        },
        {
          "description": "checkpoint_required = true MUST resolve checkpoint_ref to a non-null opaque id and rollback_path_class away from no_safe_rollback_available.",
          "if": {
            "properties": {
              "checkpoint_descriptor": {
                "properties": {
                  "checkpoint_required": {
                    "const": true
                  }
                },
                "required": [
                  "checkpoint_required"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "checkpoint_descriptor": {
                "properties": {
                  "checkpoint_ref": {
                    "type": "string"
                  },
                  "rollback_path_class": {
                    "not": {
                      "const": "no_safe_rollback_available"
                    }
                  }
                },
                "required": [
                  "checkpoint_ref"
                ]
              }
            }
          }
        }
      ]
    }
  }
}
