{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/editor/fold_summary_state.schema.json",
  "title": "Aureline editor fold summary state record",
  "description": "Boundary schema for one fold-summary truth row. A fold may collapse diagnostics, merge conflicts, trust warnings, staged hunks, search hits, review threads, or fold-hidden-state markers; this record makes the hidden marker counts, critical-state preservation, keyboard toggle command, detail route, focus-return route, and accessibility label explicit so editor, diff, and review surfaces cannot make a file appear cleaner than it is. Raw source text, raw paths, raw search queries, raw provider payloads, and secrets must not appear here.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "fold_id",
    "label",
    "visibility_state",
    "hidden_line_count",
    "hidden_marker_counts",
    "critical_state_preserved",
    "keyboard_toggle_command",
    "detail_route_ref",
    "focus_return_route_ref",
    "accessibility_label"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": { "const": "fold_summary_state_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "fold_id": { "$ref": "#/$defs/opaque_id" },
    "label": { "$ref": "#/$defs/short_label_text" },
    "visibility_state": { "$ref": "#/$defs/fold_visibility_state" },
    "hidden_line_count": { "type": "integer", "minimum": 0 },
    "hidden_marker_counts": {
      "type": "array",
      "items": { "$ref": "#/$defs/hidden_marker_count" }
    },
    "critical_state_preserved": { "type": "boolean" },
    "keyboard_toggle_command": { "$ref": "#/$defs/opaque_id" },
    "detail_route_ref": { "$ref": "#/$defs/opaque_id" },
    "focus_return_route_ref": { "$ref": "#/$defs/opaque_id" },
    "accessibility_label": { "$ref": "#/$defs/short_sentence" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 700
    },
    "marker_family_class": {
      "type": "string",
      "enum": [
        "diagnostic_error",
        "diagnostic_warning",
        "diagnostic_info",
        "diagnostic_hint",
        "merge_conflict",
        "staged_hunk",
        "vcs_change",
        "search_hit",
        "review_thread",
        "trust_or_policy_warning",
        "breakpoint",
        "fold_hidden_state",
        "generated_or_read_only",
        "freshness_or_stale"
      ]
    },
    "fold_visibility_state": {
      "type": "string",
      "enum": [
        "expanded",
        "folded",
        "summary_only",
        "disabled_large_file",
        "disabled_low_resource",
        "disabled_by_setting"
      ]
    },
    "hidden_marker_count": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "count"],
      "properties": {
        "family": { "$ref": "#/$defs/marker_family_class" },
        "count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
