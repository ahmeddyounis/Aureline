{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/editor/document_state_badge.schema.json",
  "title": "Aureline editor document-state badge and identity projection contract",
  "description": "Boundary schema for document_state_badge_catalog_record and document_state_projection_record instances frozen in docs/ux/editor_document_state_contract.md. The records give tabs, document headers, breadcrumb/context rows, status surfaces, compare sheets, preview sheets, support bundles, accessibility labels, and docs screenshots one vocabulary for dirty, pinned, compare, recovered_snapshot, generated_output, imported_patch, read_only, mirrored, policy_locked, live_preview, conflict, and stale document states. Raw file bodies, raw absolute paths, raw URLs, raw preview DOM, raw provider payloads, raw policy bodies, raw patches, and secret material never cross this boundary; records carry opaque refs, bounded labels, typed placement, and action metadata only. Adding a new document state class, badge class, action class, surface class, editability effect, target relation, or identity transition class is additive-minor and requires a document_state_badge_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/document_state_badge_catalog_record" },
    { "$ref": "#/$defs/document_state_projection_record" }
  ],
  "$defs": {
    "document_state_badge_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for editor document-state badge payloads. Current value is 1."
    },
    "instance_schema_hint": {
      "type": "string",
      "format": "uri-reference",
      "description": "Optional schema hint carried on worked fixtures."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "record_kinds_exercised": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "description": "Optional worked-example prelude carried on fixtures."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests, and safe in support bundles. Raw paths, raw payloads, raw capability tickets, raw policy bodies, and secrets never appear here."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "redaction_aware_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Bounded, redaction-aware display text. Raw absolute paths, raw URLs, raw policy bodies, raw preview DOM, raw provider payloads, raw patches, and secret material must not appear."
    },
    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "description": "Short redaction-aware label suitable for compact editor chrome."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced by the emitting subsystem."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "document_state_badge_catalog_record",
        "document_state_projection_record"
      ],
      "description": "Discriminator for the concrete payload shape."
    },
    "document_state_class": {
      "type": "string",
      "enum": [
        "dirty",
        "pinned",
        "compare",
        "recovered_snapshot",
        "generated_output",
        "imported_patch",
        "read_only",
        "mirrored",
        "policy_locked",
        "live_preview",
        "conflict",
        "stale"
      ],
      "description": "Closed editor document-state and badge-class vocabulary."
    },
    "state_badge_class_matches_state": {
      "allOf": [
        {
          "if": { "properties": { "state_class": { "const": "dirty" } }, "required": ["state_class"] },
          "then": { "properties": { "badge_class": { "const": "dirty" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "pinned" } }, "required": ["state_class"] },
          "then": { "properties": { "badge_class": { "const": "pinned" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "compare" } }, "required": ["state_class"] },
          "then": { "properties": { "badge_class": { "const": "compare" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "recovered_snapshot" } }, "required": ["state_class"] },
          "then": { "properties": { "badge_class": { "const": "recovered_snapshot" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "generated_output" } }, "required": ["state_class"] },
          "then": { "properties": { "badge_class": { "const": "generated_output" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "imported_patch" } }, "required": ["state_class"] },
          "then": { "properties": { "badge_class": { "const": "imported_patch" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "read_only" } }, "required": ["state_class"] },
          "then": { "properties": { "badge_class": { "const": "read_only" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "mirrored" } }, "required": ["state_class"] },
          "then": { "properties": { "badge_class": { "const": "mirrored" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "policy_locked" } }, "required": ["state_class"] },
          "then": { "properties": { "badge_class": { "const": "policy_locked" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "live_preview" } }, "required": ["state_class"] },
          "then": { "properties": { "badge_class": { "const": "live_preview" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "conflict" } }, "required": ["state_class"] },
          "then": { "properties": { "badge_class": { "const": "conflict" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "stale" } }, "required": ["state_class"] },
          "then": { "properties": { "badge_class": { "const": "stale" } } }
        }
      ],
      "description": "Reusable assertion that badge_class exactly matches state_class."
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "tab",
        "document_header",
        "breadcrumb_context",
        "status_surface",
        "compare_sheet",
        "preview_sheet",
        "overflow_row",
        "command_palette",
        "inspector",
        "accessibility_label",
        "docs_screenshot",
        "support_export"
      ],
      "description": "Surface where a document-state badge, label, action, or export projection appears."
    },
    "cue_modality_class": {
      "type": "string",
      "enum": [
        "text_label",
        "section_position",
        "shape_or_border",
        "role_label",
        "expanded_overflow_row",
        "sheet_title",
        "status_text",
        "accessible_name",
        "screenshot_caption",
        "icon_reinforcement",
        "color_reinforcement"
      ],
      "description": "How the state is communicated. icon_reinforcement and color_reinforcement may only supplement non-icon cues."
    },
    "action_class": {
      "type": "string",
      "enum": [
        "open_source",
        "compare_against_source",
        "regenerate_review",
        "reopen_writable_source",
        "inspect_restore_provenance",
        "review_imported_patch",
        "inspect_policy",
        "inspect_mirror_provenance",
        "reconnect_preview",
        "resolve_conflict",
        "pin",
        "unpin",
        "save",
        "discard",
        "promote_preview_to_tab",
        "export_support_summary"
      ],
      "description": "Closed action-class vocabulary for document-state recovery, source navigation, and review routing."
    },
    "editability_effect": {
      "type": "string",
      "enum": [
        "none",
        "writable_source",
        "source_required",
        "inspect_only",
        "read_only",
        "compare_only",
        "preview_only",
        "blocked_by_policy",
        "conflict_review_required",
        "generated_review_required",
        "imported_review_required"
      ],
      "description": "Effect the state has on write, inspect, compare, preview, or review posture."
    },
    "document_kind": {
      "type": "string",
      "enum": [
        "source_text",
        "generated_artifact",
        "recovered_snapshot",
        "imported_patch",
        "mirrored_artifact",
        "live_preview_projection",
        "compare_view",
        "notebook_document",
        "structured_artifact",
        "unknown_document"
      ],
      "description": "Coarse document kind projected into editor chrome."
    },
    "target_relation": {
      "type": "string",
      "enum": [
        "current_document",
        "canonical_source",
        "compare_counterpart",
        "restore_provenance",
        "generator_plan",
        "policy_detail",
        "mirror_origin",
        "preview_runtime",
        "imported_patch",
        "conflict_resolution",
        "support_export"
      ],
      "description": "Where an action routes relative to the current document identity."
    },
    "action_enabled_state": {
      "type": "string",
      "enum": [
        "enabled",
        "disabled_with_reason",
        "hidden_not_applicable"
      ]
    },
    "identity_transition_class": {
      "type": "string",
      "enum": [
        "split_or_move",
        "restore_rehydrate",
        "compare_projection",
        "transient_preview_promoted",
        "support_export",
        "reopen_related_source"
      ],
      "description": "Transition where document identity must remain explicit."
    },
    "placement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "label_text",
        "non_icon_cues",
        "icon_only_forbidden",
        "keyboard_detail_route_ref",
        "visible_to_screenshot",
        "included_in_accessibility_label"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/surface_class" },
        "label_text": { "$ref": "#/$defs/short_label_text" },
        "non_icon_cues": {
          "type": "array",
          "items": { "$ref": "#/$defs/cue_modality_class" },
          "minItems": 1,
          "uniqueItems": true
        },
        "icon_only_forbidden": { "type": "boolean", "const": true },
        "keyboard_detail_route_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "visible_to_screenshot": { "type": "boolean" },
        "included_in_accessibility_label": { "type": "boolean" },
        "detail_summary": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "state_badge": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [{ "$ref": "#/$defs/state_badge_class_matches_state" }],
      "required": [
        "state_class",
        "badge_class",
        "label_text",
        "editability_effect",
        "authority_refs",
        "required_surfaces",
        "visible_placements",
        "required_action_classes",
        "icon_only_forbidden",
        "accessibility_label",
        "screenshot_label",
        "support_export_key"
      ],
      "properties": {
        "state_class": { "$ref": "#/$defs/document_state_class" },
        "badge_class": { "$ref": "#/$defs/document_state_class" },
        "label_text": { "$ref": "#/$defs/short_label_text" },
        "editability_effect": { "$ref": "#/$defs/editability_effect" },
        "authority_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "minItems": 1,
          "uniqueItems": true
        },
        "source_relation_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "required_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_class" },
          "minItems": 1,
          "uniqueItems": true
        },
        "visible_placements": {
          "type": "array",
          "items": { "$ref": "#/$defs/placement" },
          "minItems": 1
        },
        "required_action_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/action_class" },
          "uniqueItems": true
        },
        "icon_only_forbidden": { "type": "boolean", "const": true },
        "accessibility_label": { "$ref": "#/$defs/redaction_aware_text" },
        "screenshot_label": { "$ref": "#/$defs/short_label_text" },
        "support_export_key": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "surface_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "visible_state_classes",
        "visible_labels",
        "non_icon_cues",
        "accessible_summary",
        "primary_action_refs",
        "detail_route_ref",
        "screenshot_safe"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/surface_class" },
        "visible_state_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/document_state_class" },
          "minItems": 1,
          "uniqueItems": true
        },
        "visible_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/short_label_text" },
          "minItems": 1
        },
        "non_icon_cues": {
          "type": "array",
          "items": { "$ref": "#/$defs/cue_modality_class" },
          "minItems": 1,
          "uniqueItems": true
        },
        "accessible_summary": { "$ref": "#/$defs/redaction_aware_text" },
        "primary_action_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "detail_route_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "screenshot_safe": { "type": "boolean" }
      }
    },
    "canonical_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_ref",
        "action_class",
        "command_id_ref",
        "label",
        "applies_to_state_classes",
        "target_relation",
        "target_ref",
        "enabled_state",
        "preserves_document_identity",
        "opens_related_source_identity",
        "mints_new_document_identity",
        "review_required",
        "visible_on_surfaces"
      ],
      "properties": {
        "action_ref": { "$ref": "#/$defs/opaque_id" },
        "action_class": { "$ref": "#/$defs/action_class" },
        "command_id_ref": { "$ref": "#/$defs/opaque_id" },
        "label": { "$ref": "#/$defs/short_label_text" },
        "applies_to_state_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/document_state_class" },
          "minItems": 1,
          "uniqueItems": true
        },
        "target_relation": { "$ref": "#/$defs/target_relation" },
        "target_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "enabled_state": { "$ref": "#/$defs/action_enabled_state" },
        "disabled_reason_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "preserves_document_identity": { "type": "boolean" },
        "opens_related_source_identity": { "type": "boolean" },
        "mints_new_document_identity": { "type": "boolean" },
        "review_required": { "type": "boolean" },
        "visible_on_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_class" },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "document_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_document_ref",
        "stable_content_ref",
        "document_kind",
        "display_label",
        "full_title",
        "workspace_authority_ref",
        "tab_id_ref",
        "pane_id_ref",
        "group_id_ref",
        "source_authority_ref"
      ],
      "properties": {
        "stable_document_ref": { "$ref": "#/$defs/opaque_id" },
        "stable_content_ref": { "$ref": "#/$defs/opaque_id" },
        "document_kind": { "$ref": "#/$defs/document_kind" },
        "display_label": { "$ref": "#/$defs/short_label_text" },
        "full_title": { "$ref": "#/$defs/redaction_aware_text" },
        "workspace_authority_ref": { "$ref": "#/$defs/opaque_id" },
        "tab_id_ref": { "$ref": "#/$defs/opaque_id" },
        "pane_id_ref": { "$ref": "#/$defs/opaque_id" },
        "group_id_ref": { "$ref": "#/$defs/opaque_id" },
        "source_authority_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "canonical_source_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "buffer_authority_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "restore_provenance_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "generated_lineage_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "mirror_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "preview_runtime_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "import_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "compare_basis_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "identity_transition_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transition_class",
        "transition_ref",
        "preserved_identity_refs",
        "newly_minted_view_refs",
        "forbidden_outcomes_absent",
        "summary"
      ],
      "properties": {
        "transition_class": { "$ref": "#/$defs/identity_transition_class" },
        "transition_ref": { "$ref": "#/$defs/opaque_id" },
        "preserved_identity_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "minItems": 1,
          "uniqueItems": true
        },
        "newly_minted_view_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "forbidden_outcomes_absent": {
          "type": "array",
          "items": { "$ref": "#/$defs/redaction_aware_text" },
          "minItems": 1
        },
        "summary": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "identity_preservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_identity_preserved",
        "transition_records",
        "support_reconstruction_refs"
      ],
      "properties": {
        "stable_identity_preserved": { "type": "boolean", "const": true },
        "transition_records": {
          "type": "array",
          "items": { "$ref": "#/$defs/identity_transition_record" },
          "minItems": 1
        },
        "support_reconstruction_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "accessibility_and_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_names_match_badge_classes",
        "icon_only_forbidden",
        "accessible_name",
        "screenshot_caption",
        "support_export_ref",
        "localized_label_policy"
      ],
      "properties": {
        "state_names_match_badge_classes": { "type": "boolean", "const": true },
        "icon_only_forbidden": { "type": "boolean", "const": true },
        "accessible_name": { "$ref": "#/$defs/redaction_aware_text" },
        "screenshot_caption": { "$ref": "#/$defs/redaction_aware_text" },
        "support_export_ref": { "$ref": "#/$defs/opaque_id" },
        "localized_label_policy": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "state_definition": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [{ "$ref": "#/$defs/state_badge_class_matches_state" }],
      "required": [
        "state_class",
        "badge_class",
        "compact_label",
        "meaning",
        "editability_effect",
        "required_surfaces",
        "required_action_classes",
        "icon_only_forbidden"
      ],
      "properties": {
        "state_class": { "$ref": "#/$defs/document_state_class" },
        "badge_class": { "$ref": "#/$defs/document_state_class" },
        "compact_label": { "$ref": "#/$defs/short_label_text" },
        "meaning": { "$ref": "#/$defs/redaction_aware_text" },
        "editability_effect": { "$ref": "#/$defs/editability_effect" },
        "required_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_class" },
          "minItems": 1,
          "uniqueItems": true
        },
        "required_action_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/action_class" },
          "uniqueItems": true
        },
        "icon_only_forbidden": { "type": "boolean", "const": true }
      }
    },
    "surface_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_class",
        "must_appear_on",
        "may_appear_on",
        "forbidden_collapse",
        "sheet_required_when"
      ],
      "properties": {
        "state_class": { "$ref": "#/$defs/document_state_class" },
        "must_appear_on": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_class" },
          "minItems": 1,
          "uniqueItems": true
        },
        "may_appear_on": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_class" },
          "uniqueItems": true
        },
        "forbidden_collapse": { "$ref": "#/$defs/redaction_aware_text" },
        "sheet_required_when": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "document_state_badge_catalog_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "document_state_badge_schema_version",
        "catalog_id",
        "state_definitions",
        "surface_rules",
        "identity_transition_classes"
      ],
      "properties": {
        "$schema": { "$ref": "#/$defs/instance_schema_hint" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": {
          "type": "string",
          "const": "document_state_badge_catalog_record"
        },
        "document_state_badge_schema_version": { "$ref": "#/$defs/document_state_badge_schema_version" },
        "catalog_id": { "$ref": "#/$defs/opaque_id" },
        "state_definitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/state_definition" },
          "minItems": 1
        },
        "surface_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_rule" },
          "minItems": 1
        },
        "identity_transition_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/identity_transition_class" },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "document_state_projection_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "document_state_badge_schema_version",
        "document_state_id",
        "captured_at",
        "document_identity",
        "active_state_classes",
        "state_badges",
        "surface_projections",
        "canonical_actions",
