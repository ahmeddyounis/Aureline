{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/editor/orientation_aid_state.schema.json",
  "title": "Aureline editor beta orientation-aid state record",
  "description": "Boundary schema for the beta orientation-aid truth model shared by editor, diff, and review surfaces. Multi-cursor and column-selection attribution, fold summaries, breadcrumb path continuity, the shared gutter rail, and minimap or overview-ruler aids all project from the same closed marker-family vocabulary, expose explicit degraded-state classes for large-file, reduced-motion, high-contrast, battery-saver, restricted, low-resource, and user-disabled postures, and preserve keyboard-reachable alternate routes with back/forward continuity. Raw source text, raw paths, raw search queries, raw provider payloads, and secrets must not appear; records carry opaque refs and bounded labels only. Adding a new marker family, surface class, availability class, or undo-grouping class is additive-minor and requires a schema_version bump; repurposing an existing value is breaking.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "orientation_state_id",
    "surface_class",
    "document_ref",
    "surface_ref",
    "multi_cursor",
    "fold_summaries",
    "breadcrumb",
    "gutter",
    "overview_aids",
    "shared_marker_families",
    "degraded_mode_classes",
    "support_export_refs"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": { "const": "orientation_aid_state_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "orientation_state_id": { "$ref": "#/$defs/opaque_id" },
    "surface_class": { "$ref": "#/$defs/surface_class" },
    "document_ref": { "$ref": "#/$defs/opaque_id" },
    "surface_ref": { "$ref": "#/$defs/opaque_id" },
    "multi_cursor": { "$ref": "#/$defs/multi_cursor_attribution_record" },
    "fold_summaries": {
      "type": "array",
      "items": { "$ref": "#/$defs/fold_summary_state_record" }
    },
    "breadcrumb": { "$ref": "#/$defs/breadcrumb_continuity_state_record" },
    "gutter": { "$ref": "#/$defs/gutter_marker_state_record" },
    "overview_aids": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/overview_aid_state_record" }
    },
    "shared_marker_families": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/marker_family_class" }
    },
    "degraded_mode_classes": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/availability_class" }
    },
    "support_export_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/opaque_id" }
    }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "description": "Opaque stable id safe in manifests, RPC payloads, and support bundles. Raw source text, raw file paths, raw search queries, raw URLs, credentials, and secret material never appear here."
    },
    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 700
    },
    "surface_class": {
      "type": "string",
      "enum": ["editor_source", "editor_diff", "review_thread"]
    },
    "marker_family_class": {
      "type": "string",
      "enum": [
        "diagnostic_error",
        "diagnostic_warning",
        "diagnostic_info",
        "diagnostic_hint",
        "merge_conflict",
        "staged_hunk",
        "vcs_change",
        "search_hit",
        "review_thread",
        "trust_or_policy_warning",
        "breakpoint",
        "fold_hidden_state",
        "generated_or_read_only",
        "freshness_or_stale"
      ]
    },
    "availability_class": {
      "type": "string",
      "enum": [
        "available",
        "reduced",
        "disabled_large_file",
        "disabled_low_resource",
        "disabled_reduced_motion",
        "disabled_high_contrast",
        "disabled_battery_saver",
        "disabled_restricted_mode",
        "disabled_by_setting"
      ]
    },
    "fold_visibility_state": {
      "type": "string",
      "enum": [
        "expanded",
        "folded",
        "summary_only",
        "disabled_large_file",
        "disabled_low_resource",
        "disabled_by_setting"
      ]
    },
    "multi_cursor_mode_posture": {
      "type": "string",
      "enum": ["single_caret", "multiple_carets", "column_selection"]
    },
    "undo_grouping_class": {
      "type": "string",
      "enum": [
        "single_caret_edit",
        "multi_cursor_single_group",
        "structural_batched_transaction",
        "unsupported_atomicity"
      ]
    },
    "overview_aid_kind_class": {
      "type": "string",
      "enum": ["minimap", "overview_ruler", "gutter_rail", "breadcrumb"]
    },
    "hidden_marker_count": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "count"],
      "properties": {
        "family": { "$ref": "#/$defs/marker_family_class" },
        "count": { "type": "integer", "minimum": 0 }
      }
    },
    "multi_cursor_attribution_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "indicator_ref",
        "mode_posture",
        "caret_count",
        "primary_caret_label",
        "column_mode_active",
        "undo_grouping_class",
        "group_undo_visible",
        "alternate_command_refs",
        "accessibility_label"
      ],
      "properties": {
        "indicator_ref": { "$ref": "#/$defs/opaque_id" },
        "mode_posture": { "$ref": "#/$defs/multi_cursor_mode_posture" },
        "caret_count": { "type": "integer", "minimum": 0 },
        "primary_caret_label": { "$ref": "#/$defs/short_label_text" },
        "column_mode_active": { "type": "boolean" },
        "undo_grouping_class": { "$ref": "#/$defs/undo_grouping_class" },
        "group_undo_visible": { "type": "boolean" },
        "unsupported_note": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/short_sentence" }]
        },
        "alternate_command_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "accessibility_label": { "$ref": "#/$defs/short_sentence" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "mode_posture": { "enum": ["multiple_carets", "column_selection"] } },
            "required": ["mode_posture"]
          },
          "then": {
            "properties": {
              "caret_count": { "type": "integer", "minimum": 2 },
              "group_undo_visible": { "const": true }
            }
          }
        },
        {
          "if": {
            "properties": { "mode_posture": { "const": "column_selection" } },
            "required": ["mode_posture"]
          },
          "then": {
            "properties": { "column_mode_active": { "const": true } }
          }
        }
      ]
    },
    "fold_summary_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "fold_id",
        "label",
        "visibility_state",
        "hidden_line_count",
        "hidden_marker_counts",
        "critical_state_preserved",
        "keyboard_toggle_command",
        "detail_route_ref",
        "focus_return_route_ref",
        "accessibility_label"
      ],
      "properties": {
        "record_kind": { "const": "fold_summary_state_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "fold_id": { "$ref": "#/$defs/opaque_id" },
        "label": { "$ref": "#/$defs/short_label_text" },
        "visibility_state": { "$ref": "#/$defs/fold_visibility_state" },
        "hidden_line_count": { "type": "integer", "minimum": 0 },
        "hidden_marker_counts": {
          "type": "array",
          "items": { "$ref": "#/$defs/hidden_marker_count" }
        },
        "critical_state_preserved": { "type": "boolean" },
        "keyboard_toggle_command": { "$ref": "#/$defs/opaque_id" },
        "detail_route_ref": { "$ref": "#/$defs/opaque_id" },
        "focus_return_route_ref": { "$ref": "#/$defs/opaque_id" },
        "accessibility_label": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "breadcrumb_continuity_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "breadcrumb_ref",
        "file_identity_ref",
        "symbol_path_state",
        "back_forward_preserved",
        "focus_return_route_ref",
        "alternate_command_refs",
        "visible_state_note",
        "accessibility_label"
      ],
      "properties": {
        "breadcrumb_ref": { "$ref": "#/$defs/opaque_id" },
        "file_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "symbol_path_state": { "$ref": "#/$defs/short_label_text" },
        "back_forward_preserved": { "type": "boolean", "const": true },
        "focus_return_route_ref": { "$ref": "#/$defs/opaque_id" },
        "alternate_command_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "visible_state_note": { "$ref": "#/$defs/short_sentence" },
        "accessibility_label": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "gutter_marker_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gutter_ref",
        "marker_families",
        "availability",
        "degraded_state_message",
        "alternate_route_refs",
        "accessibility_label"
      ],
      "properties": {
        "gutter_ref": { "$ref": "#/$defs/opaque_id" },
        "marker_families": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/marker_family_class" }
        },
        "availability": { "$ref": "#/$defs/availability_class" },
        "degraded_state_message": { "$ref": "#/$defs/short_sentence" },
        "alternate_route_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "accessibility_label": { "$ref": "#/$defs/short_sentence" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "availability": {
                "enum": [
                  "reduced",
                  "disabled_large_file",
                  "disabled_low_resource",
                  "disabled_reduced_motion",
                  "disabled_high_contrast",
                  "disabled_battery_saver",
                  "disabled_restricted_mode",
                  "disabled_by_setting"
                ]
              }
            },
            "required": ["availability"]
          },
          "then": {
            "properties": {
              "alternate_route_refs": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "overview_aid_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aid_ref",
        "aid_kind",
        "marker_families",
        "availability",
        "degraded_state_message",
        "replacement_route_refs",
        "focus_return_route_ref",
        "accessibility_label"
      ],
      "properties": {
        "aid_ref": { "$ref": "#/$defs/opaque_id" },
        "aid_kind": { "$ref": "#/$defs/overview_aid_kind_class" },
        "marker_families": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/marker_family_class" }
        },
        "availability": { "$ref": "#/$defs/availability_class" },
        "degraded_state_message": { "$ref": "#/$defs/short_sentence" },
        "replacement_route_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "focus_return_route_ref": { "$ref": "#/$defs/opaque_id" },
        "accessibility_label": { "$ref": "#/$defs/short_sentence" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "availability": {
                "enum": [
                  "reduced",
                  "disabled_large_file",
                  "disabled_low_resource",
                  "disabled_reduced_motion",
                  "disabled_high_contrast",
                  "disabled_battery_saver",
                  "disabled_restricted_mode",
                  "disabled_by_setting"
                ]
              }
            },
            "required": ["availability"]
          },
          "then": {
            "properties": {
              "replacement_route_refs": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      ]
    }
  }
}
