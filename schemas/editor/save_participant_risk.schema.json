{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/editor/save_participant_risk.schema.json",
  "title": "Aureline save-participant risk review",
  "description": "Boundary schema for staged-save participant risk review. The record discloses formatter, organize-imports, code-action, validation, scanner, and AI apply participant classes; declared and actual file effects; whole-file rewrite posture; source-fidelity adjustments; external-change race state; checkpoint posture; and support-safe summaries. Raw source text, raw patches, raw tool logs, raw provider prompts, and secrets are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "save_participant_risk_schema_version",
    "schema_ref",
    "save_participant_risk_review_id",
    "save_packet_ref",
    "outcome_class",
    "checkpoint_ref",
    "external_change_event_ref",
    "source_fidelity_adjustments",
    "participant_entries",
    "raw_payload_excluded",
    "summary"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": {
      "const": "save_participant_risk_review_record"
    },
    "save_participant_risk_schema_version": {
      "type": "integer",
      "const": 1
    },
    "schema_ref": {
      "const": "schemas/editor/save_participant_risk.schema.json"
    },
    "save_participant_risk_review_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "save_packet_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "outcome_class": {
      "$ref": "#/$defs/outcome_class"
    },
    "checkpoint_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "external_change_event_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "source_fidelity_adjustments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_fidelity_adjustment"
      },
      "uniqueItems": true
    },
    "participant_entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/participant_entry"
      }
    },
    "raw_payload_excluded": {
      "const": true
    },
    "summary": {
      "$ref": "#/$defs/short_sentence"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_ref": {
      "oneOf": [
        { "$ref": "#/$defs/non_empty_string" },
        { "type": "null" }
      ]
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 700
    },
    "participant_class": {
      "type": "string",
      "enum": [
        "formatter",
        "organize_imports",
        "code_action",
        "ai_apply",
        "validation_after_apply",
        "scanner_read_only",
        "participant_unknown_requires_review"
      ]
    },
    "output_origin_class": {
      "type": "string",
      "enum": [
        "exact_rule",
        "imported_config",
        "heuristic_fallback",
        "generated_lineage",
        "policy_decision",
        "ai_suggestion",
        "read_only_validation",
        "origin_unknown_requires_review"
      ]
    },
    "fix_safety_class": {
      "type": "string",
      "enum": [
        "safe_local_text_edit",
        "workspace_wide_preview_required",
        "generated_companion_update",
        "policy_blocked",
        "whole_file_rewrite_disclosed",
        "external_change_conflict_requires_review",
        "fix_safety_unknown_requires_review"
      ]
    },
    "review_trigger_class": {
      "type": "string",
      "enum": [
        "not_required",
        "whole_file_rewrite",
        "generated_artifact_impact",
        "multi_file_edit",
        "external_change_race",
        "policy_or_trust_narrowing",
        "provider_dependency_or_semantic_freshness_gap",
        "source_fidelity_conversion",
        "output_origin_heuristic_or_ai",
        "unknown_requires_review"
      ]
    },
    "run_state_class": {
      "type": "string",
      "enum": [
        "planned",
        "ran",
        "failed",
        "held_for_review",
        "blocked_before_run"
      ]
    },
    "source_fidelity_rewrite_class": {
      "type": "string",
      "enum": [
        "no_write_needed",
        "targeted_content_patch",
        "whole_file_rewrite_declared",
        "whole_file_rewrite_fallback",
        "generator_regeneration_write",
        "merge_resolution_write",
        "blocked_no_write"
      ]
    },
    "checkpoint_policy_class": {
      "type": "string",
      "enum": [
        "none_required",
        "recovery_journal",
        "local_history_checkpoint",
        "workspace_mutation_checkpoint_group",
        "generator_regeneration_checkpoint",
        "metadata_only_checkpoint",
        "checkpoint_blocked_no_write"
      ]
    },
    "outcome_class": {
      "type": "string",
      "enum": [
        "safe_to_run",
        "review_required_before_mutation",
        "review_required_before_commit",
        "rebase_required",
        "blocked_no_write",
        "participant_failed",
        "committed"
      ]
    },
    "source_fidelity_adjustment": {
      "type": "string",
      "enum": [
        "line_ending_posture_preserved",
        "final_newline_posture_preserved"
      ]
    },
    "file_effect_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files_touched",
        "files_created",
        "files_deleted",
        "changed_bytes",
        "whole_file_rewrite",
        "generated_artifacts_touched",
        "protected_paths_touched",
        "may_touch_outside_visible_file"
      ],
      "properties": {
        "files_touched": { "type": "integer", "minimum": 0 },
        "files_created": { "type": "integer", "minimum": 0 },
        "files_deleted": { "type": "integer", "minimum": 0 },
        "changed_bytes": { "type": "integer", "minimum": 0 },
        "whole_file_rewrite": { "type": "boolean" },
        "generated_artifacts_touched": { "type": "integer", "minimum": 0 },
        "protected_paths_touched": { "type": "integer", "minimum": 0 },
        "may_touch_outside_visible_file": { "type": "boolean" }
      }
    },
    "participant_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "participant_id",
        "participant_class",
        "run_state_class",
        "output_origin_class",
        "fix_safety_class",
        "declared_file_effect_summary",
        "actual_file_effect_summary",
        "source_fidelity_rewrite_class",
        "review_trigger_classes",
        "checkpoint_policy_class",
        "reviewed_ticket_ref",
        "visible_disclosure"
      ],
      "properties": {
        "participant_id": { "$ref": "#/$defs/non_empty_string" },
        "participant_class": { "$ref": "#/$defs/participant_class" },
        "run_state_class": { "$ref": "#/$defs/run_state_class" },
        "output_origin_class": { "$ref": "#/$defs/output_origin_class" },
        "fix_safety_class": { "$ref": "#/$defs/fix_safety_class" },
        "declared_file_effect_summary": { "$ref": "#/$defs/file_effect_summary" },
        "actual_file_effect_summary": {
          "oneOf": [
            { "$ref": "#/$defs/file_effect_summary" },
            { "type": "null" }
          ]
        },
        "source_fidelity_rewrite_class": {
          "$ref": "#/$defs/source_fidelity_rewrite_class"
        },
        "review_trigger_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/review_trigger_class"
          },
          "uniqueItems": true
        },
        "checkpoint_policy_class": {
          "$ref": "#/$defs/checkpoint_policy_class"
        },
        "reviewed_ticket_ref": {
          "$ref": "#/$defs/nullable_ref"
        },
        "visible_disclosure": {
          "$ref": "#/$defs/short_sentence"
        }
      }
    }
  }
}
