{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/editor/save_fidelity_lineage.schema.json",
  "title": "Aureline save-fidelity lineage",
  "description": "Boundary schema for the governed, export-safe source-fidelity save lineage record. The record is projected from a save-participant risk review and the open-time source-fidelity record. It pins each participant to a canonical hot-save-path stage (format, organize-imports, lint, code-action-apply, scan, validate), classifies each fix action (safe-inline, preview-required, multi-file, generated-scope, semantically-broad), records whether preview-plus-checkpoint was enforced once a fix action crossed the safe-inline threshold, maps each participant to a recovery action (exact-undo, compensation, regeneration, checkpoint-restore, none-no-write), and auto-narrows below Stable with a named reason. Raw source text, raw patches, raw tool logs, raw provider prompts, and secrets are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "save_fidelity_lineage_schema_version",
    "schema_ref",
    "lineage_id",
    "save_packet_ref",
    "risk_review_ref",
    "outcome_class",
    "source_fidelity",
    "source_fidelity_adjustments",
    "external_change_event_ref",
    "checkpoint_ref",
    "preview_and_checkpoint_enforced",
    "participant_order_canonical",
    "entries",
    "stable_qualification",
    "raw_payload_excluded",
    "summary"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true
    },
    "record_kind": {
      "const": "save_fidelity_lineage_record"
    },
    "save_fidelity_lineage_schema_version": {
      "type": "integer",
      "const": 1
    },
    "schema_ref": {
      "const": "schemas/editor/save_fidelity_lineage.schema.json"
    },
    "lineage_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "save_packet_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "risk_review_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "outcome_class": {
      "$ref": "#/$defs/outcome_class"
    },
    "source_fidelity": {
      "$ref": "#/$defs/source_fidelity_summary"
    },
    "source_fidelity_adjustments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_fidelity_adjustment"
      },
      "uniqueItems": true
    },
    "external_change_event_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "checkpoint_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "preview_and_checkpoint_enforced": {
      "type": "boolean"
    },
    "participant_order_canonical": {
      "type": "boolean"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lineage_entry"
      }
    },
    "stable_qualification": {
      "$ref": "#/$defs/stable_qualification"
    },
    "raw_payload_excluded": {
      "const": true
    },
    "summary": {
      "$ref": "#/$defs/short_sentence"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_ref": {
      "oneOf": [
        { "$ref": "#/$defs/non_empty_string" },
        { "type": "null" }
      ]
    },
    "short_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 700
    },
    "participant_class": {
      "type": "string",
      "enum": [
        "formatter",
        "organize_imports",
        "code_action",
        "ai_apply",
        "validation_after_apply",
        "scanner_read_only",
        "participant_unknown_requires_review"
      ]
    },
    "run_state_class": {
      "type": "string",
      "enum": [
        "planned",
        "ran",
        "failed",
        "held_for_review",
        "blocked_before_run"
      ]
    },
    "outcome_class": {
      "type": "string",
      "enum": [
        "safe_to_run",
        "review_required_before_mutation",
        "review_required_before_commit",
        "rebase_required",
        "blocked_no_write",
        "participant_failed",
        "committed"
      ]
    },
    "participant_stage": {
      "type": "string",
      "enum": [
        "format",
        "organize_imports",
        "lint",
        "code_action_apply",
        "scan",
        "validate_after_apply",
        "unsequenced"
      ]
    },
    "fix_action_class": {
      "type": "string",
      "enum": [
        "safe_inline",
        "preview_required",
        "multi_file",
        "generated_scope",
        "semantically_broad"
      ]
    },
    "preview_reason": {
      "type": "string",
      "enum": [
        "not_required_safe_inline",
        "whole_file_or_representation",
        "multi_file_scope",
        "generated_scope",
        "semantically_broad"
      ]
    },
    "recovery_action_class": {
      "type": "string",
      "enum": [
        "exact_undo",
        "compensation",
        "regeneration",
        "checkpoint_restore",
        "none_no_write"
      ]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "participant_failed",
        "participant_ordering_violation",
        "preview_or_checkpoint_not_enforced",
        "source_fidelity_unprovable"
      ]
    },
    "detected_encoding": {
      "type": "string",
      "enum": [
        "utf8",
        "utf8_bom",
        "utf16le_bom",
        "utf16be_bom",
        "utf32le_bom",
        "utf32be_bom",
        "unknown_binary_like"
      ]
    },
    "detection_source": {
      "type": "string",
      "enum": [
        "bom",
        "utf8_heuristic",
        "decode_failed_no_choice"
      ]
    },
    "bom_state": {
      "type": "string",
      "enum": [
        "present",
        "absent",
        "unknown_or_degraded"
      ]
    },
    "newline_mode": {
      "type": "string",
      "enum": [
        "lf",
        "crlf",
        "cr_only",
        "mixed",
        "unknown_or_degraded"
      ]
    },
    "final_newline": {
      "type": "string",
      "enum": [
        "present",
        "absent",
        "unknown_or_degraded"
      ]
    },
    "executable_intent": {
      "type": "string",
      "enum": [
        "executable",
        "non_executable",
        "unknown_or_degraded"
      ]
    },
    "source_fidelity_adjustment": {
      "type": "string",
      "enum": [
        "line_ending_posture_preserved",
        "final_newline_posture_preserved"
      ]
    },
    "source_fidelity_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detected_encoding",
        "detection_source",
        "bom_state_detected",
        "newline_mode_detected",
        "final_newline_detected",
        "executable_intent",
        "round_trip_provable"
      ],
      "properties": {
        "detected_encoding": { "$ref": "#/$defs/detected_encoding" },
        "detection_source": { "$ref": "#/$defs/detection_source" },
        "bom_state_detected": { "$ref": "#/$defs/bom_state" },
        "newline_mode_detected": { "$ref": "#/$defs/newline_mode" },
        "final_newline_detected": { "$ref": "#/$defs/final_newline" },
        "executable_intent": { "$ref": "#/$defs/executable_intent" },
        "round_trip_provable": { "type": "boolean" }
      }
    },
    "file_effect_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files_touched",
        "files_created",
        "files_deleted",
        "changed_bytes",
        "whole_file_rewrite",
        "generated_artifacts_touched",
        "protected_paths_touched",
        "may_touch_outside_visible_file"
      ],
      "properties": {
        "files_touched": { "type": "integer", "minimum": 0 },
        "files_created": { "type": "integer", "minimum": 0 },
        "files_deleted": { "type": "integer", "minimum": 0 },
        "changed_bytes": { "type": "integer", "minimum": 0 },
        "whole_file_rewrite": { "type": "boolean" },
        "generated_artifacts_touched": { "type": "integer", "minimum": 0 },
        "protected_paths_touched": { "type": "integer", "minimum": 0 },
        "may_touch_outside_visible_file": { "type": "boolean" }
      }
    },
    "lineage_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "order_index",
        "stage",
        "participant_id",
        "participant_class",
        "run_state_class",
        "fix_action_class",
        "preview_required",
        "preview_reason",
        "checkpoint_required",
        "recovery_action_class",
        "declared_file_effect_summary",
        "actual_file_effect_summary",
        "visible_disclosure"
      ],
      "properties": {
        "order_index": { "type": "integer", "minimum": 0, "maximum": 255 },
        "stage": { "$ref": "#/$defs/participant_stage" },
        "participant_id": { "$ref": "#/$defs/non_empty_string" },
        "participant_class": { "$ref": "#/$defs/participant_class" },
        "run_state_class": { "$ref": "#/$defs/run_state_class" },
        "fix_action_class": { "$ref": "#/$defs/fix_action_class" },
        "preview_required": { "type": "boolean" },
        "preview_reason": { "$ref": "#/$defs/preview_reason" },
        "checkpoint_required": { "type": "boolean" },
        "recovery_action_class": { "$ref": "#/$defs/recovery_action_class" },
        "declared_file_effect_summary": { "$ref": "#/$defs/file_effect_summary" },
        "actual_file_effect_summary": {
          "oneOf": [
            { "$ref": "#/$defs/file_effect_summary" },
            { "type": "null" }
          ]
        },
        "visible_disclosure": { "$ref": "#/$defs/short_sentence" }
      }
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "qualified",
        "level",
        "narrow_reasons"
      ],
      "properties": {
        "qualified": { "type": "boolean" },
        "level": {
          "type": "string",
          "enum": ["stable", "narrowed_below_stable"]
        },
        "narrow_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrow_reason" },
          "uniqueItems": true
        }
      }
    }
  }
}
