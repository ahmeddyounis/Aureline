{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/sync/conflict_packet_alpha.schema.json",
  "title": "Aureline alpha profile and sync conflict-review packet",
  "description": "Alpha conflict-review packet for settings, keymaps, and saved views. It composes with the settings sync packet and profile conflict journal schemas, and adds keymap / saved-view artifact metadata, owner scope, privacy class, portability labels, per-source revision attribution, explicit Keep local / Keep synced / Compare action offers, and non-widening verdicts. Raw secrets, delegated credentials, machine-local paths, transient selection, stale provider cursors, secret-bearing filter parameters, and admin policy payloads never appear.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "artifact_class",
    "artifact_id",
    "owner_scope",
    "privacy_class",
    "portability_label",
    "conflict_class",
    "local_revision",
    "incoming_revision",
    "field_diffs",
    "action_offers",
    "non_widening_verdict"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_class": {
      "type": "string",
      "enum": ["setting", "keymap", "saved_view"]
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "owner_scope": {
      "type": "string",
      "enum": ["user", "workspace", "shared", "policy_pinned", "provider_owned"]
    },
    "privacy_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "secret_bearing_excluded"
      ]
    },
    "portability_label": {
      "type": "string",
      "enum": ["portable", "local_only", "downgraded", "excluded"],
      "description": "Explains whether the artifact can round-trip unchanged, remains local-only, downgrades with disclosure, or is excluded."
    },
    "conflict_class": {
      "type": "string",
      "enum": [
        "same_key_divergence",
        "policy_locked",
        "missing_capability",
        "delete_vs_modify",
        "stale_remote"
      ],
      "description": "Closed conflict classes the alpha review surface distinguishes."
    },
    "local_revision": {
      "$ref": "#/$defs/revision"
    },
    "incoming_revision": {
      "$ref": "#/$defs/revision"
    },
    "winning_revision": {
      "oneOf": [{ "$ref": "#/$defs/revision" }, { "type": "null" }]
    },
    "field_diffs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/field_diff" }
    },
    "action_offers": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/action_offer" },
      "allOf": [
        {
          "contains": {
            "properties": { "action": { "const": "keep_local" } },
            "required": ["action"]
          }
        },
        {
          "contains": {
            "properties": { "action": { "const": "keep_synced" } },
            "required": ["action"]
          }
        },
        {
          "contains": {
            "properties": { "action": { "const": "compare" } },
            "required": ["action"]
          }
        }
      ]
    },
    "non_widening_verdict": {
      "$ref": "#/$defs/non_widening_verdict"
    },
    "missing_capability_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "$defs": {
    "source_posture": {
      "type": "string",
      "enum": ["local_only", "synced", "imported", "policy_pinned", "provider_owned"],
      "description": "State origin. Review surfaces distinguish local-only, synced, imported, policy-pinned, and provider-owned revisions instead of treating all incoming state as user-owned."
    },
    "revision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision_ref", "source_posture", "source_ref"],
      "properties": {
        "revision_ref": { "type": "string", "minLength": 1 },
        "source_posture": { "$ref": "#/$defs/source_posture" },
        "source_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Opaque source ref. Never a raw URL, hostname, path, credential, or provider payload."
        },
        "source_device_ref": {
          "type": ["string", "null"],
          "description": "Opaque device ref when available. Provider and policy-owned revisions may use source_ref without a device ref."
        }
      }
    },
    "field_diff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_path", "change_kind", "summary"],
      "properties": {
        "field_path": { "type": "string", "minLength": 1 },
        "change_kind": {
          "type": "string",
          "enum": ["added", "removed", "replaced", "reordered", "blocked", "redacted"]
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    },
    "action_offer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "available"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["keep_local", "keep_synced", "compare"]
        },
        "available": { "type": "boolean" },
        "disabled_reason": {
          "type": ["string", "null"],
          "maxLength": 1024
        }
      }
    },
    "widening_vector": {
      "type": "string",
      "enum": [
        "none",
        "workspace_trust",
        "extension_permission",
        "managed_entitlement",
        "ai_egress",
        "network_egress",
        "credential_exposure",
        "managed_ownership"
      ]
    },
    "non_widening_verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["would_widen", "blocked_vectors", "managed_ownership_would_widen", "note"],
      "properties": {
        "would_widen": { "type": "boolean" },
        "blocked_vectors": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/widening_vector" },
          "uniqueItems": true
        },
        "managed_ownership_would_widen": { "type": "boolean" },
        "note": { "type": "string", "maxLength": 1024 }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "conflict_class": { "const": "missing_capability" } },
        "required": ["conflict_class"]
      },
      "then": {
        "required": ["missing_capability_ids"],
        "properties": {
          "missing_capability_ids": { "minItems": 1 }
        }
      }
    }
  ]
}
