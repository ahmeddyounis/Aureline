{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/trust/safe-preview-trust-class.schema.json",
  "title": "Aureline stable safe-preview trust-class packet",
  "description": "Machine-readable stable contract for safe-preview trust classes, consumer-surface rows, raw-versus-rendered transfer cases, and downgrade truth across trusted and embedded surfaces. Raw content, raw URLs, credentials, and secret material are not carried here.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "schema_ref",
    "doc_ref",
    "trust_class_contracts",
    "surface_matrix",
    "transfer_cases"
  ],
  "properties": {
    "record_kind": { "const": "stable_safe_preview_trust_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": { "const": "content-safety:stable_safe_preview_trust:v1" },
    "schema_ref": { "const": "schemas/trust/safe-preview-trust-class.schema.json" },
    "doc_ref": { "const": "docs/trust/m4/stabilize-safe-preview-trust-classes.md" },
    "trust_class_contracts": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/trust_class_contract" }
    },
    "surface_matrix": {
      "type": "array",
      "minItems": 12,
      "items": { "$ref": "#/$defs/surface_matrix_row" }
    },
    "transfer_cases": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/transfer_case" }
    }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "trust_class": {
      "type": "string",
      "enum": [
        "RawText",
        "SanitizedRich",
        "TrustedLocalActive",
        "IsolatedRemoteActive"
      ]
    },
    "representation_action_id": {
      "type": "string",
      "enum": [
        "copy_raw",
        "copy_rendered",
        "copy_escaped",
        "export_sanitized_snapshot",
        "export_metadata_only"
      ]
    },
    "representation_class": {
      "type": "string",
      "enum": [
        "raw",
        "rendered",
        "escaped",
        "sanitized",
        "blocked_metadata_only"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "editor",
        "docs_help_preview",
        "notebook_rich_output",
        "preview_runtime",
        "marketplace_account_webview",
        "browser_runtime_viewer",
        "support_export",
        "install_review",
        "attach_review",
        "approval_review",
        "publish_review",
        "delete_review"
      ]
    },
    "surface_qualification": {
      "type": "string",
      "enum": ["stable", "below_stable"]
    },
    "allowed_behavior": {
      "type": "string",
      "enum": [
        "render_exact_bytes",
        "render_sanitized_markup",
        "run_local_active_content",
        "run_isolated_remote_active_content",
        "show_inline_warning_overlays",
        "reveal_raw_source",
        "reveal_escaped_source",
        "open_static_snapshot",
        "block_active_content"
      ]
    },
    "visible_trust_cue": {
      "type": "string",
      "enum": [
        "trust_class_badge",
        "representation_label",
        "raw_view_path",
        "owner_identity",
        "origin_boundary",
        "capability_summary",
        "permission_summary",
        "downgrade_explanation"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "trust_loss",
        "policy_deny",
        "disconnect",
        "origin_loss",
        "unsupported_host",
        "blocked_active_capability",
        "support_export_boundary"
      ]
    },
    "downgrade_state": {
      "type": "string",
      "enum": [
        "none",
        "sanitized",
        "static_snapshot",
        "metadata_only",
        "blocked"
      ]
    },
    "origin_boundary": {
      "type": "string",
      "enum": [
        "local_workspace",
        "local_docs_pack",
        "trusted_local_runtime",
        "remote_provider_origin",
        "embedded_marketplace_origin",
        "browser_runtime_origin",
        "support_export_snapshot"
      ]
    },
    "evidence_carrier": {
      "type": "string",
      "enum": [
        "screenshot",
        "support_bundle",
        "exported_evidence",
        "diagnostics"
      ]
    },
    "transfer_case_kind": {
      "type": "string",
      "enum": [
        "raw_only",
        "sanitized",
        "trusted_local",
        "isolated_remote",
        "downgrade",
        "blocked"
      ]
    },
    "trust_class_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust_class",
        "allowed_behaviors",
        "visible_cues",
        "default_transfer_actions",
        "upgrade_requirements",
        "downgrade_triggers",
        "fallback_states"
      ],
      "properties": {
        "trust_class": { "$ref": "#/$defs/trust_class" },
        "allowed_behaviors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/allowed_behavior" }
        },
        "visible_cues": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/visible_trust_cue" }
        },
        "default_transfer_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/representation_action_id" }
        },
        "upgrade_requirements": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/downgrade_trigger" }
        },
        "fallback_states": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/downgrade_state" }
        }
      }
    },
    "surface_matrix_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "surface",
        "qualification",
        "consumed_contract_ref",
        "trust_class",
        "visible_representation",
        "raw_rendered_distinction_meaningful",
        "source_representation_available",
        "raw_view_path_visible",
        "origin_boundary",
        "owner_identity_visible",
        "origin_identity_visible",
        "trust_class_visible",
        "representation_label_visible",
        "capability_summary_visible",
        "permission_summary_visible",
        "transfer_actions",
        "handled_downgrade_triggers",
        "effective_downgrade_state",
        "auto_upgrade_blocked",
        "evidence_carriers"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/opaque_id" },
        "surface": { "$ref": "#/$defs/consumer_surface" },
        "qualification": { "$ref": "#/$defs/surface_qualification" },
        "consumed_contract_ref": { "const": "content-safety:stable_safe_preview_trust:v1" },
        "trust_class": { "$ref": "#/$defs/trust_class" },
        "visible_representation": { "$ref": "#/$defs/representation_class" },
        "raw_rendered_distinction_meaningful": { "type": "boolean" },
        "source_representation_available": { "type": "boolean" },
        "raw_view_path_visible": { "type": "boolean" },
        "origin_boundary": { "$ref": "#/$defs/origin_boundary" },
        "owner_identity_visible": { "type": "boolean" },
        "origin_identity_visible": { "type": "boolean" },
        "trust_class_visible": { "type": "boolean" },
        "representation_label_visible": { "type": "boolean" },
        "capability_summary_visible": { "type": "boolean" },
        "permission_summary_visible": { "type": "boolean" },
        "transfer_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/representation_action_id" }
        },
        "handled_downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/downgrade_trigger" }
        },
        "effective_downgrade_state": { "$ref": "#/$defs/downgrade_state" },
        "auto_upgrade_blocked": { "type": "boolean" },
        "evidence_carriers": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidence_carrier" }
        }
      }
    },
    "transfer_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "case_kind",
        "surface",
        "source_trust_class",
        "action_id",
        "representation_class",
        "visible_label",
        "preserves_raw_rendered_choice",
        "trust_class_lineage_preserved",
        "origin_truth_preserved",
        "permission_truth_preserved",
        "effective_downgrade_state",
        "support_export_safe"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "case_kind": { "$ref": "#/$defs/transfer_case_kind" },
        "surface": { "$ref": "#/$defs/consumer_surface" },
        "source_trust_class": { "$ref": "#/$defs/trust_class" },
        "action_id": { "$ref": "#/$defs/representation_action_id" },
        "representation_class": { "$ref": "#/$defs/representation_class" },
        "visible_label": { "type": "string", "minLength": 1, "maxLength": 240 },
        "preserves_raw_rendered_choice": { "type": "boolean" },
        "trust_class_lineage_preserved": { "type": "boolean" },
        "origin_truth_preserved": { "type": "boolean" },
        "permission_truth_preserved": { "type": "boolean" },
        "downgrade_trigger": {
          "oneOf": [
            { "$ref": "#/$defs/downgrade_trigger" },
            { "type": "null" }
          ]
        },
        "effective_downgrade_state": { "$ref": "#/$defs/downgrade_state" },
        "support_export_safe": { "type": "boolean" }
      }
    }
  }
}
