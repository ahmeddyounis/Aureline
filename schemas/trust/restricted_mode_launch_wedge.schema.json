{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/trust/restricted_mode_launch_wedge.schema.json",
  "title": "Aureline restricted-mode launch wedge packet",
  "description": "Boundary schema for restricted_mode_launch_wedge_packet_record. The packet is the alpha trust disclosure emitted when a launch-wedge workspace opens or remains under restricted, revoked, recovery, identity-gated, or policy-degraded trust posture. It keeps local read/edit/search/save capability visible while execution, mutation, install/update, provider, remote, and AI apply capability rows carry source, scope, authority, and recovery actions. Raw paths, raw policy payloads, raw secrets, raw URLs, and raw provider tokens must not appear in this record.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "workspace_root_ref",
    "workspace_display_scope",
    "identity_mode",
    "binary_trust_state",
    "effective_trust_state",
    "effective_trust_state_token",
    "entry_transition",
    "entry_transition_token",
    "layout_restore_suspended",
    "trust_source",
    "capability_gates",
    "decision_receipt",
    "issued_at"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "record_kind": { "const": "restricted_mode_launch_wedge_packet_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "$ref": "#/$defs/opaque_id" },
    "workspace_root_ref": { "$ref": "#/$defs/opaque_id" },
    "workspace_display_scope": { "$ref": "#/$defs/reviewable_sentence" },
    "identity_mode": {
      "type": "string",
      "enum": ["account_free_local", "self_hosted_org", "managed_convenience"]
    },
    "binary_trust_state": {
      "type": "string",
      "enum": ["trusted", "restricted", "pending_evaluation"]
    },
    "effective_trust_state": { "$ref": "#/$defs/trust_state" },
    "effective_trust_state_token": { "$ref": "#/$defs/trust_state" },
    "prior_trust_state": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/trust_state" }]
    },
    "prior_trust_state_token": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/trust_state" }]
    },
    "entry_transition": { "$ref": "#/$defs/entry_transition" },
    "entry_transition_token": { "$ref": "#/$defs/entry_transition" },
    "layout_restore_suspended": { "type": "boolean" },
    "trust_source": { "$ref": "#/$defs/trust_source" },
    "capability_gates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability_gate" }
    },
    "decision_receipt": { "$ref": "#/$defs/decision_receipt" },
    "issued_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque id safe for logs, CLI output, support bundles, and evidence packets."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    },
    "trust_state": {
      "type": "string",
      "enum": [
        "untrusted_unknown",
        "restricted",
        "trusted",
        "trusted_time_bounded",
        "trusted_policy_degraded",
        "restricted_recovery_fallback",
        "restricted_extension_quarantine",
        "trust_revoked",
        "trust_unavailable_identity_gate"
      ]
    },
    "entry_transition": {
      "type": "string",
      "enum": [
        "initial_open_untrusted",
        "open_in_restricted_mode",
        "continue_in_restricted_mode",
        "open_without_restore",
        "safe_mode_workspace_restricted",
        "extension_quarantine_restricted",
        "grant_trust_session",
        "grant_trust_remembered",
        "grant_trust_admin_prebinding",
        "revoke_trust",
        "policy_narrow_to_degraded",
        "policy_restore_trusted",
        "emergency_action_force_restricted",
        "identity_gate_unavailable"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "local_user",
        "local_admin",
        "managed_admin",
        "signed_repo_allowance",
        "emergency_action_signer",
        "recovery_ladder_application",
        "policy_epoch_roll",
        "identity_gate_unavailable_system",
        "no_remembered_decision"
      ]
    },
    "reason_class": {
      "type": "string",
      "enum": [
        "first_open_no_remembered_decision",
        "explicit_user_decline",
        "explicit_user_grant",
        "explicit_user_revoke",
        "session_expired",
        "admin_policy_narrowed",
        "admin_policy_restored",
        "emergency_action_applied",
        "recovery_ladder_fallback",
        "extension_quarantine_applied",
        "identity_gate_unavailable",
        "policy_epoch_roll_required_reprompt"
      ]
    },
    "remembered_scope": {
      "type": "string",
      "enum": [
        "session_only",
        "per_workspace_per_user",
        "per_parent_directory_per_user",
        "admin_policy_scope",
        "never_remembered",
        "not_remembered_system_issued"
      ]
    },
    "trust_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "source_class_token",
        "source_ref",
        "source_label",
        "reason_class",
        "reason_class_token",
        "remembered_decision_scope",
        "remembered_decision_scope_token"
      ],
      "properties": {
        "source_class": { "$ref": "#/$defs/source_class" },
        "source_class_token": { "$ref": "#/$defs/source_class" },
        "source_ref": { "$ref": "#/$defs/opaque_id" },
        "source_label": { "$ref": "#/$defs/reviewable_sentence" },
        "reason_class": { "$ref": "#/$defs/reason_class" },
        "reason_class_token": { "$ref": "#/$defs/reason_class" },
        "remembered_decision_scope": { "$ref": "#/$defs/remembered_scope" },
        "remembered_decision_scope_token": { "$ref": "#/$defs/remembered_scope" },
        "policy_epoch_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_id" }]
        },
        "source_reason_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      }
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "workspace_open_restore",
        "editor_read_write",
        "search_local",
        "local_git_read",
        "local_git_write",
        "shell_command_palette",
        "tasks_run",
        "terminal_manual_open",
        "terminal_repo_recipe_launch",
        "debug_launch",
        "notebook_kernel_connect",
        "notebook_cell_execute",
        "ai_context_read",
        "ai_apply_mutation",
        "ai_tool_call_mutating",
        "extension_activation",
        "extension_install",
        "environment_activator_run",
        "package_install_helper",
        "connected_provider_open",
        "connected_provider_tool_call",
        "remote_attach",
        "mcp_server_launch",
        "support_bundle_export",
        "admin_policy_read"
      ]
    },
    "authority": {
      "type": "string",
      "enum": [
        "allowed",
        "read_only",
        "degraded_preview_only",
        "blocked_pending_trust",
        "blocked_pending_approval",
        "approval_required_per_invocation",
        "policy_denied",
        "quarantine_denied",
        "not_applicable"
      ]
    },
    "effect": {
      "type": "string",
      "enum": [
        "local_only_no_external_effect",
        "local_process_launch",
        "workspace_mutation",
        "network_or_provider_egress",
        "hosted_dependency",
        "secret_or_identity_use",
        "install_or_update_mutation"
      ]
    },
    "recovery_action": {
      "type": "string",
      "enum": [
        "request_trust_grant",
        "request_trust_grant_session_only",
        "request_approval_ticket",
        "request_admin_policy_change",
        "open_policy_details",
        "open_capability_details",
        "route_to_support_bundle_export",
        "continue_restricted_no_elevation",
        "use_local_read_only_alternative"
      ]
    },
    "capability_gate": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "capability_ref",
        "surface_family",
        "surface_family_token",
        "capability_label",
        "authority",
        "authority_token",
        "external_effect_class",
        "external_effect_token",
        "decision_source",
        "scope",
        "explanation_label",
        "recovery_actions",
        "recovery_action_tokens",
        "visible_on_launch",
        "sticky_after_open",
        "hosted_dependency_disclosed",
        "plaintext_secret_fallback_allowed",
        "install_or_update_review_required"
      ],
      "properties": {
        "capability_ref": { "$ref": "#/$defs/opaque_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "surface_family_token": { "$ref": "#/$defs/surface_family" },
        "capability_label": { "$ref": "#/$defs/reviewable_sentence" },
        "authority": { "$ref": "#/$defs/authority" },
        "authority_token": { "$ref": "#/$defs/authority" },
        "external_effect_class": { "$ref": "#/$defs/effect" },
        "external_effect_token": { "$ref": "#/$defs/effect" },
        "explanation_label": { "$ref": "#/$defs/reviewable_sentence" },
        "recovery_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/recovery_action" }
        },
        "recovery_action_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/recovery_action" }
        },
        "recovery_label": { "type": "string" },
        "visible_on_launch": { "type": "boolean" },
        "sticky_after_open": { "type": "boolean" },
        "hosted_dependency_disclosed": { "type": "boolean" },
        "plaintext_secret_fallback_allowed": { "type": "boolean" },
        "install_or_update_review_required": { "type": "boolean" }
      }
    },
    "decision_receipt": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "audit_event_class",
        "audit_event_token",
        "transition_id",
        "transition_token",
        "affected_surface_tokens",
        "escalation_cues",
        "escalation_cue_tokens",
        "visible_after_open_required",
        "redaction_class"
      ],
      "properties": {
        "visible_after_open_required": { "type": "boolean" },
        "redaction_class": { "const": "metadata_safe_default" }
      }
    }
  }
}
