{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/help/community-handoff-packet.schema.json",
  "title": "Aureline Help/About community handoff packet",
  "description": "Canonical packet contract for Help/About public issue, security disclosure, docs feedback, RFC/discussion, community support, and vendor/private support handoffs. Each packet states destination class, visibility boundary, authentication expectation, data-exit boundary, exact origin anchor, redaction preview, and durable blocked/offline continuity before any browser launch. Raw URLs, raw local paths, raw usernames, raw hostnames, tokens, raw diagnostics, private endpoints, and user text bodies do not appear.",
  "$ref": "#/$defs/community_handoff_packet",
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "destination_class": {
      "type": "string",
      "enum": [
        "public",
        "official_authenticated",
        "community",
        "vendor_managed",
        "local_only"
      ]
    },
    "packet_class": {
      "type": "string",
      "enum": [
        "public_issue_filing",
        "security_disclosure",
        "docs_feedback",
        "rfc_discussion",
        "community_support",
        "vendor_private_support"
      ]
    },
    "continuity_state": {
      "type": "string",
      "enum": [
        "ready_to_launch",
        "browser_launch_failed",
        "browser_blocked",
        "offline_saved_local"
      ]
    },
    "redaction_rule_class": {
      "type": "string",
      "enum": [
        "local_paths",
        "usernames",
        "hostnames",
        "tokens",
        "extension_inventory",
        "deployment_profile",
        "selected_diagnostics"
      ]
    },
    "origin_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin_surface_class",
        "originating_object_ref",
        "anchor_ref",
        "return_path_ref"
      ],
      "properties": {
        "origin_surface_class": { "$ref": "#/$defs/non_empty_string" },
        "originating_object_ref": { "$ref": "#/$defs/non_empty_string" },
        "anchor_ref": { "$ref": "#/$defs/non_empty_string" },
        "return_path_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "redaction_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_class_token",
        "preview_before_share_required",
        "raw_material_excluded_by_default",
        "disclosure"
      ],
      "properties": {
        "rule_class_token": { "$ref": "#/$defs/redaction_rule_class" },
        "preview_before_share_required": { "type": "boolean", "const": true },
        "raw_material_excluded_by_default": { "type": "boolean", "const": true },
        "disclosure": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "redaction_preview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_ref",
        "preview_before_share_required",
        "local_first",
        "raw_sensitive_material_leaves_implicitly",
        "rules"
      ],
      "properties": {
        "profile_ref": { "$ref": "#/$defs/non_empty_string" },
        "preview_before_share_required": { "type": "boolean", "const": true },
        "local_first": { "type": "boolean", "const": true },
        "raw_sensitive_material_leaves_implicitly": { "type": "boolean", "const": false },
        "rules": {
          "type": "array",
          "minItems": 7,
          "items": { "$ref": "#/$defs/redaction_rule" }
        }
      }
    },
    "continuity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_token",
        "drafted_text_retained",
        "selected_attachments_retained",
        "redaction_settings_retained",
        "target_class_retained",
        "retry_action_ref",
        "export_action_ref",
        "open_later_action_ref"
      ],
      "properties": {
        "state_token": { "$ref": "#/$defs/continuity_state" },
        "drafted_text_retained": { "type": "boolean", "const": true },
        "selected_attachments_retained": { "type": "boolean", "const": true },
        "redaction_settings_retained": { "type": "boolean", "const": true },
        "target_class_retained": { "type": "boolean", "const": true },
        "retry_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "export_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "open_later_action_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "community_handoff_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "packet_class_token",
        "destination_class_token",
        "fallback_destination_class_token",
        "visibility_boundary",
        "auth_expectation",
        "data_exit_boundary",
        "destination_route_ref",
        "build_identity_ref",
        "service_health_ref",
        "provenance_ref",
        "origin_anchor",
        "redaction_preview",
        "continuity"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "community_handoff_packet_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "packet_id": { "type": "string", "pattern": "^community_handoff_packet:[a-z0-9_]+$" },
        "packet_class_token": { "$ref": "#/$defs/packet_class" },
        "destination_class_token": { "$ref": "#/$defs/destination_class" },
        "fallback_destination_class_token": { "type": "string", "const": "local_only" },
        "visibility_boundary": { "$ref": "#/$defs/non_empty_string" },
        "auth_expectation": { "$ref": "#/$defs/non_empty_string" },
        "data_exit_boundary": { "$ref": "#/$defs/non_empty_string" },
        "destination_route_ref": { "$ref": "#/$defs/non_empty_string" },
        "build_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "service_health_ref": { "$ref": "#/$defs/non_empty_string" },
        "provenance_ref": { "$ref": "#/$defs/non_empty_string" },
        "origin_anchor": { "$ref": "#/$defs/origin_anchor" },
        "redaction_preview": { "$ref": "#/$defs/redaction_preview" },
        "continuity": { "$ref": "#/$defs/continuity" }
      },
      "allOf": [
        {
          "if": { "properties": { "packet_class_token": { "const": "security_disclosure" } } },
          "then": {
            "properties": {
              "destination_class_token": { "enum": ["official_authenticated", "local_only"] }
            }
          }
        },
        {
          "if": { "properties": { "packet_class_token": { "enum": ["public_issue_filing", "docs_feedback"] } } },
          "then": {
            "properties": {
              "destination_class_token": { "enum": ["public", "local_only"] }
            }
          }
        },
        {
          "if": { "properties": { "packet_class_token": { "enum": ["rfc_discussion", "community_support"] } } },
          "then": {
            "properties": {
              "destination_class_token": { "enum": ["community", "local_only"] }
            }
          }
        }
      ]
    }
  }
}
