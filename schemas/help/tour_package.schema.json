{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/help/tour_package.schema.json",
  "title": "Aureline beta tour package",
  "description": "Versioned guided-tour and guided-exercise package contract. Package steps cite stable command, file, symbol, docs, graph, or surface object IDs; mutation-capable teaching uses command IDs, preview sheets, approval paths, rollback semantics, and evidence refs; degraded docs, cached, and graph-unavailable states remain explicit.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "package_id",
    "package_version_ref",
    "package_revision_ref",
    "release_label",
    "source_class",
    "source_ref",
    "source_version_ref",
    "availability_state",
    "degradation_state",
    "freshness_class",
    "docs_pack_ref",
    "docs_pack_revision_ref",
    "command_graph_ref",
    "semantic_graph_ref",
    "citation_refs",
    "independent_downgrade_group",
    "downgrade_allowed",
    "tours",
    "steps"
  ],
  "properties": {
    "package_id": { "$ref": "#/$defs/stable_id" },
    "package_version_ref": { "$ref": "#/$defs/stable_id" },
    "package_revision_ref": { "$ref": "#/$defs/stable_id" },
    "release_label": { "type": "string", "enum": ["beta", "preview"] },
    "source_class": {
      "type": "string",
      "enum": ["project_docs", "mirrored_official_docs", "curated_knowledge_pack", "semantic_graph"]
    },
    "source_ref": { "$ref": "#/$defs/stable_id" },
    "source_version_ref": { "$ref": "#/$defs/stable_id" },
    "availability_state": {
      "type": "string",
      "enum": ["installed", "local_only", "cached", "mirror_only", "not_installed", "graph_unavailable"]
    },
    "degradation_state": {
      "type": "string",
      "enum": [
        "no_degradation",
        "local_only_disclosed",
        "cached_disclosed",
        "mirror_only_disclosed",
        "not_installed_placeholder",
        "graph_unavailable_placeholder"
      ]
    },
    "freshness_class": { "type": "string", "enum": ["current", "cached", "stale_disclosed"] },
    "docs_pack_ref": { "$ref": "#/$defs/stable_id" },
    "docs_pack_revision_ref": { "$ref": "#/$defs/stable_id" },
    "graph_epoch_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }] },
    "command_graph_ref": { "$ref": "#/$defs/stable_id" },
    "semantic_graph_ref": { "$ref": "#/$defs/stable_id" },
    "citation_refs": { "$ref": "#/$defs/non_empty_ref_array" },
    "independent_downgrade_group": { "$ref": "#/$defs/stable_id" },
    "downgrade_allowed": { "type": "boolean", "const": true },
    "tours": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/tour" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    }
  },
  "$defs": {
    "stable_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:._@#/-]*$"
    },
    "command_id": {
      "type": "string",
      "pattern": "^cmd:[A-Za-z0-9_.:]+$"
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/stable_id" },
      "uniqueItems": true
    },
    "non_empty_ref_array": {
      "allOf": [{ "$ref": "#/$defs/ref_array" }, { "minItems": 1 }]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_kind"],
      "properties": {
        "target_kind": {
          "type": "string",
          "enum": [
            "command_id",
            "file_object_id",
            "symbol_object_id",
            "docs_node_id",
            "graph_node_id",
            "surface_object_id"
          ]
        },
        "command_id": { "$ref": "#/$defs/command_id" },
        "file_object_id": { "$ref": "#/$defs/stable_id" },
        "symbol_object_id": { "$ref": "#/$defs/stable_id" },
        "docs_node_id": { "$ref": "#/$defs/stable_id" },
        "graph_node_id": { "$ref": "#/$defs/stable_id" },
        "surface_object_id": { "$ref": "#/$defs/stable_id" }
      },
      "allOf": [
        {
          "if": { "properties": { "target_kind": { "const": "command_id" } }, "required": ["target_kind"] },
          "then": { "required": ["command_id"] }
        },
        {
          "if": { "properties": { "target_kind": { "const": "file_object_id" } }, "required": ["target_kind"] },
          "then": { "required": ["file_object_id"] }
        },
        {
          "if": { "properties": { "target_kind": { "const": "symbol_object_id" } }, "required": ["target_kind"] },
          "then": { "required": ["symbol_object_id"] }
        },
        {
          "if": { "properties": { "target_kind": { "const": "docs_node_id" } }, "required": ["target_kind"] },
          "then": { "required": ["docs_node_id"] }
        },
        {
          "if": { "properties": { "target_kind": { "const": "graph_node_id" } }, "required": ["target_kind"] },
          "then": { "required": ["graph_node_id"] }
        },
        {
          "if": { "properties": { "target_kind": { "const": "surface_object_id" } }, "required": ["target_kind"] },
          "then": { "required": ["surface_object_id"] }
        }
      ]
    },
    "source_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "claim_class", "source_refs", "confidence_class"],
      "properties": {
        "claim_id": { "$ref": "#/$defs/stable_id" },
        "claim_class": { "type": "string", "enum": ["product_truth", "repo_truth", "inference_limit"] },
        "source_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "confidence_class": { "type": "string", "minLength": 1 }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "label_ref",
        "verb_class",
        "command_metadata_source",
        "action_safety_class",
        "explain_and_apply_separate",
        "mutates_workspace"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/stable_id" },
        "label_ref": { "$ref": "#/$defs/stable_id" },
        "verb_class": {
          "type": "string",
          "enum": ["explain", "prepare_preview", "open_docs", "skip", "reset", "invoke_command", "unavailable"]
        },
        "command_id": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/command_id" }] },
        "command_metadata_source": { "type": "string", "enum": ["command_registry", "local_profile_state"] },
        "action_safety_class": {
          "type": "string",
          "enum": ["read_only", "local_profile_state_only", "mutation_requires_approval", "blocked_unavailable"]
        },
        "preview_sheet_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }] },
        "approval_path_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }] },
        "rollback_semantics_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }] },
        "evidence_packet_rule_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }] },
        "explain_and_apply_separate": { "type": "boolean", "const": true },
        "mutates_workspace": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "mutates_workspace": { "const": true } }, "required": ["mutates_workspace"] },
          "then": {
            "required": [
              "command_id",
              "preview_sheet_ref",
              "approval_path_ref",
              "rollback_semantics_ref",
              "evidence_packet_rule_ref"
            ],
            "properties": {
              "command_metadata_source": { "const": "command_registry" },
              "action_safety_class": { "const": "mutation_requires_approval" },
              "command_id": { "$ref": "#/$defs/command_id" },
              "preview_sheet_ref": { "$ref": "#/$defs/stable_id" },
              "approval_path_ref": { "$ref": "#/$defs/stable_id" },
              "rollback_semantics_ref": { "$ref": "#/$defs/stable_id" },
              "evidence_packet_rule_ref": { "$ref": "#/$defs/stable_id" }
            }
          }
        }
      ]
    },
    "tour": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tour_id",
        "package_ref",
        "title",
        "audience_class",
        "profile_ref",
        "scope_ref",
        "ordered_step_refs",
        "docs_node_refs",
        "citation_refs",
        "restart_resume_ref",
        "required_before_first_edit"
      ],
      "properties": {
        "tour_id": { "$ref": "#/$defs/stable_id" },
        "package_ref": { "$ref": "#/$defs/stable_id" },
        "title": { "type": "string", "minLength": 1 },
        "audience_class": { "$ref": "#/$defs/stable_id" },
        "profile_ref": { "$ref": "#/$defs/stable_id" },
        "scope_ref": { "$ref": "#/$defs/stable_id" },
        "ordered_step_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "docs_node_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "citation_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "restart_resume_ref": { "$ref": "#/$defs/stable_id" },
        "required_before_first_edit": { "type": "boolean", "const": false }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "tour_ref",
        "package_ref",
        "profile_ref",
        "position_index",
        "step_kind",
        "title",
        "stable_targets",
        "current_scope_ref",
        "source_claims",
        "citation_refs",
        "success_criteria",
        "hint_reveal_state_ref",
        "actions",
        "degradation_state",
        "exact_reopen_ref",
        "active"
      ],
      "properties": {
        "step_id": { "$ref": "#/$defs/stable_id" },
        "tour_ref": { "$ref": "#/$defs/stable_id" },
        "package_ref": { "$ref": "#/$defs/stable_id" },
        "profile_ref": { "$ref": "#/$defs/stable_id" },
        "position_index": { "type": "integer", "minimum": 0 },
        "step_kind": { "type": "string", "enum": ["guided_tour_step", "guided_exercise_step", "fallback_placeholder"] },
        "title": { "type": "string", "minLength": 1 },
        "stable_targets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/target" }
        },
        "current_scope_ref": { "$ref": "#/$defs/stable_id" },
        "source_claims": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source_claim" }
        },
        "citation_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "success_criteria": { "$ref": "#/$defs/non_empty_ref_array" },
        "hint_reveal_state_ref": { "$ref": "#/$defs/stable_id" },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/action" }
        },
        "degradation_state": { "$ref": "#/properties/degradation_state" },
        "exact_reopen_ref": { "$ref": "#/$defs/stable_id" },
        "active": { "type": "boolean" }
      }
    }
  }
}
