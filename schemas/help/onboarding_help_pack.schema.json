{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/help/onboarding_help_pack.schema.json",
  "title": "Aureline onboarding/help-pack beta manifest",
  "description": "Versioned beta contract for onboarding, help search, glossary, migration-center, contextual why-now, and recovery-first help-pack items. The manifest preserves stable pack and item IDs, glossary-pack IDs, citations, source/version/freshness badges, command references, locale fallback, mirror/offline posture, and support-export reconstruction metadata without raw article bodies.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "manifest_id",
    "manifest_version_ref",
    "generated_at",
    "release_channel",
    "source_contract_refs",
    "runtime_consumer_refs",
    "required_surface_classes",
    "packs",
    "items",
    "state_records",
    "diagnostics_policy",
    "protected_proofs"
  ],
  "properties": {
    "record_kind": { "const": "onboarding_help_pack_beta_manifest_record" },
    "schema_version": { "const": 1 },
    "manifest_id": { "$ref": "#/$defs/stable_id" },
    "manifest_version_ref": { "$ref": "#/$defs/stable_id" },
    "generated_at": { "type": "string", "format": "date-time" },
    "release_channel": { "type": "string", "enum": ["beta"] },
    "source_contract_refs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "runtime_consumer_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stable_id" },
      "uniqueItems": true
    },
    "required_surface_classes": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/surface_ref" },
      "uniqueItems": true
    },
    "packs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/pack" }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/item" }
    },
    "state_records": {
      "type": "array",
      "items": { "$ref": "#/$defs/state_record" }
    },
    "diagnostics_policy": { "$ref": "#/$defs/diagnostics_policy" },
    "protected_proofs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/proof" }
    }
  },
  "$defs": {
    "stable_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:._@#/-]*$"
    },
    "surface_ref": {
      "type": "string",
      "enum": [
        "surface:start_center:first_run",
        "surface:migration_center:beta",
        "surface:help_search:onboarding",
        "surface:contextual_why_now:onboarding",
        "surface:recovery_first:onboarding"
      ]
    },
    "locale": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "pack_role": {
      "type": "string",
      "enum": [
        "first_run_starter_pack",
        "migration_welcome_pack",
        "glossary_bundle",
        "guided_content_pack",
        "recovery_first_pack",
        "in_product_help_overlay_pack"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "project_docs",
        "mirrored_official_docs",
        "curated_knowledge_pack",
        "support_runbook"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": ["authoritative_live", "warm_cached", "degraded_cached"]
    },
    "version_match_state": {
      "type": "string",
      "enum": ["exact_build_match", "compatible_minor_drift"]
    },
    "install_state": {
      "type": "string",
      "enum": [
        "local_only_starter",
        "cached_snapshot_current",
        "mirror_only_verified",
        "not_installed"
      ]
    },
    "offline_posture": {
      "type": "string",
      "enum": [
        "fully_available_offline_local_build",
        "cached_snapshot_offline",
        "mirror_verified_offline",
        "not_available_offline"
      ]
    },
    "mirror_posture": {
      "type": "string",
      "enum": ["no_mirror_required", "verified_mirror_snapshot"]
    },
    "locale_availability": {
      "type": "string",
      "enum": [
        "locale_available_reviewed",
        "locale_available_stale_copy",
        "locale_missing_fallback_to_source",
        "locale_missing_not_installed"
      ]
    },
    "fallback_class": {
      "type": "string",
      "enum": [
        "no_fallback_primary_locale_only",
        "fallback_to_source_language_disclosed",
        "fallback_blocked_pack_missing"
      ]
    },
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pack_id",
        "pack_version_ref",
        "pack_role",
        "glossary_pack_ids",
        "source_class",
        "source_ref",
        "source_version_ref",
        "freshness_class",
        "version_match_state",
        "mirror_posture",
        "install_state",
        "offline_posture",
        "source_locale",
        "available_locales",
        "locale_overlay_refs",
        "citation_availability",
        "release_truth_badges",
        "client_scope",
        "support_owner_ref"
      ],
      "properties": {
        "pack_id": { "$ref": "#/$defs/stable_id" },
        "pack_version_ref": { "$ref": "#/$defs/stable_id" },
        "pack_role": { "$ref": "#/$defs/pack_role" },
        "glossary_pack_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" },
          "uniqueItems": true
        },
        "source_class": { "$ref": "#/$defs/source_class" },
        "source_ref": { "$ref": "#/$defs/stable_id" },
        "source_version_ref": { "$ref": "#/$defs/stable_id" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "version_match_state": { "$ref": "#/$defs/version_match_state" },
        "docs_pack_ref": { "type": "string", "minLength": 1 },
        "mirror_posture": { "$ref": "#/$defs/mirror_posture" },
        "install_state": { "$ref": "#/$defs/install_state" },
        "offline_posture": { "$ref": "#/$defs/offline_posture" },
        "source_locale": { "$ref": "#/$defs/locale" },
        "available_locales": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/locale" },
          "uniqueItems": true
        },
        "locale_overlay_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" },
          "uniqueItems": true
        },
        "citation_availability": { "type": "string", "enum": ["available"] },
        "release_truth_badges": { "$ref": "#/$defs/release_truth_badges" },
        "client_scope": { "type": "string", "minLength": 1 },
        "support_owner_ref": { "$ref": "#/$defs/stable_id" }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "item_kind",
        "title",
        "summary",
        "pack_id",
        "pack_version_ref",
        "docs_node_id",
        "surface_refs",
        "command_hint",
        "locale",
        "source_language_fallback",
        "offline_fallback",
        "source_truth",
        "content_render_state",
        "exact_reopen_ref",
        "support_export_identity",
        "state_refs"
      ],
      "properties": {
        "item_id": { "$ref": "#/$defs/stable_id" },
        "item_kind": {
          "type": "string",
          "enum": [
            "start_center_card",
            "keymap_bridge",
            "glossary_pack_item",
            "contextual_hint",
            "recovery_first_item",
            "future_guided_learning_ref"
          ]
        },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "pack_id": { "$ref": "#/$defs/stable_id" },
        "pack_version_ref": { "$ref": "#/$defs/stable_id" },
        "glossary_pack_id": { "$ref": "#/$defs/stable_id" },
        "glossary_item_id": { "$ref": "#/$defs/stable_id" },
        "docs_node_id": { "$ref": "#/$defs/stable_id" },
        "surface_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_ref" },
          "uniqueItems": true
        },
        "command_hint": { "$ref": "#/$defs/command_hint" },
        "locale": { "$ref": "#/$defs/locale_state" },
        "source_language_fallback": { "$ref": "#/$defs/source_language_fallback" },
        "offline_fallback": { "$ref": "#/$defs/offline_fallback" },
        "source_truth": { "$ref": "#/$defs/source_truth" },
        "content_render_state": {
          "type": "string",
          "enum": ["renderable", "placeholder_only", "blocked_not_installed"]
        },
        "exact_reopen_ref": { "$ref": "#/$defs/stable_id" },
        "support_export_identity": { "$ref": "#/$defs/support_export_identity" },
        "state_refs": { "$ref": "#/$defs/item_state_refs" }
      }
    },
    "command_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "help_anchor_id",
        "keyboard_route",
        "route_kind",
        "metadata_source",
        "canonical_action_graph_ref"
      ],
      "properties": {
        "command_id": { "type": "string", "pattern": "^cmd:[A-Za-z0-9_.:-]+$" },
        "command_revision_ref": { "type": "string", "minLength": 1 },
        "help_anchor_id": { "$ref": "#/$defs/stable_id" },
        "keyboard_route": { "type": "string", "minLength": 1 },
        "route_kind": {
          "type": "string",
          "enum": ["command", "help_search", "browser_handoff", "evidence_card"]
        },
        "metadata_source": {
          "type": "string",
          "enum": ["command_registry", "pack_owned_descriptor"]
        },
        "canonical_action_graph_ref": { "$ref": "#/$defs/stable_id" }
      }
    },
    "locale_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_locale",
        "requested_locale",
        "effective_locale",
        "locale_availability",
        "fallback_chain",
        "stale_translation_marker",
        "unresolved_locale_fallback"
      ],
      "properties": {
        "source_locale": { "$ref": "#/$defs/locale" },
        "requested_locale": { "$ref": "#/$defs/locale" },
        "effective_locale": { "$ref": "#/$defs/locale" },
        "locale_availability": { "$ref": "#/$defs/locale_availability" },
        "fallback_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "stale_translation_marker": { "type": "boolean" },
        "unresolved_locale_fallback": { "type": "boolean" },
        "translation_pack_ref": { "$ref": "#/$defs/stable_id" }
      }
    },
    "source_language_fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fallback_class",
        "unresolved_source_fallback",
        "user_visible_status"
      ],
      "properties": {
        "fallback_class": { "$ref": "#/$defs/fallback_class" },
        "source_language_item_ref": { "$ref": "#/$defs/stable_id" },
        "escape_hatch_command_id": { "type": "string", "pattern": "^cmd:[A-Za-z0-9_.:-]+$" },
        "unresolved_source_fallback": { "type": "boolean" },
        "user_visible_status": { "type": "string", "minLength": 1 }
      }
    },
    "offline_fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "connectivity_posture",
        "mirror_posture",
        "fallback_behavior",
        "content_availability",
        "explicit_user_visible_state",
        "freshness_class"
      ],
      "properties": {
        "connectivity_posture": { "type": "string", "minLength": 1 },
        "mirror_posture": { "$ref": "#/$defs/mirror_posture" },
        "fallback_behavior": { "type": "string", "minLength": 1 },
        "content_availability": { "$ref": "#/$defs/offline_posture" },
        "unavailable_reason": { "type": "string", "minLength": 1 },
        "explicit_user_visible_state": { "type": "boolean", "const": true },
        "freshness_class": { "$ref": "#/$defs/freshness_class" }
      }
    },
    "source_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "source_version_ref",
        "freshness_class",
        "version_match_state",
        "citation_refs",
        "source_strip_ref",
        "citation_drawer_ref",
        "release_truth_badges"
      ],
      "properties": {
        "source_class": { "$ref": "#/$defs/source_class" },
        "source_version_ref": { "$ref": "#/$defs/stable_id" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "version_match_state": { "$ref": "#/$defs/version_match_state" },
        "citation_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "source_strip_ref": { "$ref": "#/$defs/stable_id" },
        "citation_drawer_ref": { "$ref": "#/$defs/stable_id" },
        "release_truth_badges": { "$ref": "#/$defs/release_truth_badges" }
      }
    },
    "release_truth_badges": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_badge_family",
        "source_token",
        "version_badge_family",
        "version_token",
        "freshness_badge_family",
        "freshness_token",
        "client_scope_badge_family",
        "client_scope_token"
      ],
      "properties": {
        "source_badge_family": { "const": "docs_help_source_class" },
        "source_token": { "$ref": "#/$defs/source_class" },
        "version_badge_family": { "const": "docs_help_version_match_state" },
        "version_token": { "$ref": "#/$defs/version_match_state" },
        "freshness_badge_family": { "const": "docs_help_freshness_class" },
        "freshness_token": { "$ref": "#/$defs/freshness_class" },
        "client_scope_badge_family": { "const": "client_scope_badge_family" },
        "client_scope_token": { "type": "string", "minLength": 1 }
      }
    },
    "support_export_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_pack_item_id",
        "redaction_class",
        "raw_body_exported",
        "exact_reopen_ref",
        "active_pack_version_ref",
        "diagnostics_row_ref",
        "unresolved_locale_fallback",
        "unresolved_source_fallback",
        "dismissed_state_ref",
        "helpful_state_ref"
      ],
      "properties": {
        "support_pack_item_id": { "$ref": "#/$defs/stable_id" },
        "redaction_class": { "type": "string", "enum": ["metadata_safe_default"] },
        "raw_body_exported": { "type": "boolean", "const": false },
        "exact_reopen_ref": { "$ref": "#/$defs/stable_id" },
        "active_pack_version_ref": { "$ref": "#/$defs/stable_id" },
        "diagnostics_row_ref": { "$ref": "#/$defs/stable_id" },
        "unresolved_locale_fallback": { "type": "boolean" },
        "unresolved_source_fallback": { "type": "boolean" },
        "dismissed_state_ref": { "$ref": "#/$defs/stable_id" },
        "helpful_state_ref": { "$ref": "#/$defs/stable_id" }
      }
    },
    "item_state_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dismissed_state_ref", "helpful_state_ref"],
      "properties": {
        "dismissed_state_ref": { "$ref": "#/$defs/stable_id" },
        "helpful_state_ref": { "$ref": "#/$defs/stable_id" }
      }
    },
    "state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_item_id",
        "item_ref",
        "state_kind",
        "storage_lane",
        "reset_class",
        "export_class",
        "diagnostics_capture_class",
        "repo_mutation_allowed",
        "repo_read_access_default",
        "telemetry_read_default"
      ],
      "properties": {
        "state_item_id": { "$ref": "#/$defs/stable_id" },
        "item_ref": { "$ref": "#/$defs/stable_id" },
        "state_kind": { "type": "string", "enum": ["dismissed_hint", "helpful_vote"] },
        "storage_lane": { "type": "string", "enum": ["portable_user_profile_state"] },
        "reset_class": { "type": "string", "enum": ["resettable_per_profile"] },
        "export_class": { "type": "string", "enum": ["in_support_bundle_redacted"] },
        "diagnostics_capture_class": { "type": "string", "minLength": 1 },
        "repo_mutation_allowed": { "type": "boolean", "const": false },
        "repo_read_access_default": { "type": "boolean", "const": false },
        "telemetry_read_default": { "type": "boolean", "const": false }
      }
    },
    "diagnostics_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diagnostics_policy_id",
        "record_active_pack_version",
        "record_unresolved_locale_fallback",
        "record_unresolved_source_fallback",
        "record_dismissed_state",
        "record_helpful_state",
        "raw_body_exported",
        "bounded_material_classes",
        "omitted_material_classes"
      ],
      "properties": {
        "diagnostics_policy_id": { "$ref": "#/$defs/stable_id" },
        "record_active_pack_version": { "type": "boolean", "const": true },
        "record_unresolved_locale_fallback": { "type": "boolean", "const": true },
        "record_unresolved_source_fallback": { "type": "boolean", "const": true },
        "record_dismissed_state": { "type": "boolean", "const": true },
        "record_helpful_state": { "type": "boolean", "const": true },
        "raw_body_exported": { "type": "boolean", "const": false },
        "bounded_material_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "omitted_material_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_id", "fixture_ref", "exercised_item_refs", "exercised_states"],
      "properties": {
        "proof_id": { "$ref": "#/$defs/stable_id" },
        "fixture_ref": { "type": "string", "minLength": 1 },
        "exercised_item_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "exercised_states": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
