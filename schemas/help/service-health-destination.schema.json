{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/help/service-health-destination.schema.json",
  "title": "Aureline service-health destination truth descriptor",
  "description": "Canonical descriptor consumed by About, Help, service health, CLI/headless output, diagnostics, support export, release notes, migration notices, issue/report templates, and community handoff. The descriptor carries build identity, freshness, service-contract state, destination trust class, local-only continuity, and local-first save-later support semantics without raw diagnostics, credentials, endpoint secrets, or user-authored report bodies.",
  "$ref": "#/$defs/descriptor",
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "service_contract_state": {
      "type": "string",
      "enum": [
        "ready",
        "degraded",
        "local_only",
        "stale",
        "contract_mismatch",
        "policy_blocked",
        "unavailable"
      ]
    },
    "destination_trust_class": {
      "type": "string",
      "enum": [
        "public",
        "official_authenticated",
        "community",
        "vendor_managed",
        "local_only"
      ]
    },
    "public_proof_surface": {
      "type": "string",
      "enum": [
        "desktop_ui",
        "cli_headless",
        "about",
        "help",
        "service_health",
        "diagnostics",
        "support_export",
        "release_notes",
        "migration_notice",
        "issue_report_template",
        "community_handoff"
      ]
    },
    "freshness_state": {
      "type": "string",
      "enum": [
        "live",
        "cached",
        "mirrored",
        "offline_pack",
        "stale_cache",
        "policy_limited"
      ]
    },
    "continuity_drill_scenario": {
      "type": "string",
      "enum": [
        "offline",
        "mirrored",
        "browser_blocked",
        "degraded_service",
        "partial_service_outage"
      ]
    },
    "build_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "build_identity_ref",
        "product_name",
        "version",
        "build_id",
        "channel",
        "install_mode",
        "provenance_ref"
      ],
      "properties": {
        "build_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "product_name": { "$ref": "#/$defs/non_empty_string" },
        "version": { "$ref": "#/$defs/non_empty_string" },
        "build_id": { "$ref": "#/$defs/non_empty_string" },
        "channel": { "$ref": "#/$defs/non_empty_string" },
        "install_mode": { "$ref": "#/$defs/non_empty_string" },
        "provenance_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness_ref",
        "state",
        "source_ref",
        "last_checked_at",
        "stale_after",
        "visible_freshness_label",
        "live_reachability_claim_allowed"
      ],
      "properties": {
        "freshness_ref": { "$ref": "#/$defs/non_empty_string" },
        "state": { "$ref": "#/$defs/freshness_state" },
        "source_ref": { "$ref": "#/$defs/non_empty_string" },
        "last_checked_at": { "$ref": "#/$defs/non_empty_string" },
        "stale_after": { "$ref": "#/$defs/non_empty_string" },
        "visible_freshness_label": { "$ref": "#/$defs/non_empty_string" },
        "live_reachability_claim_allowed": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "enum": ["cached", "mirrored", "offline_pack", "stale_cache"]
              }
            }
          },
          "then": {
            "properties": {
              "live_reachability_claim_allowed": { "const": false }
            }
          }
        }
      ]
    },
    "destination_trust_class_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "destination_class",
        "visibility_boundary",
        "auth_expectation",
        "data_exit_boundary",
        "issue_template_support",
        "browser_blocked_fallback",
        "offline_fallback",
        "pre_exit_label_required"
      ],
      "properties": {
        "destination_class": { "$ref": "#/$defs/destination_trust_class" },
        "visibility_boundary": { "$ref": "#/$defs/non_empty_string" },
        "auth_expectation": { "$ref": "#/$defs/non_empty_string" },
        "data_exit_boundary": { "$ref": "#/$defs/non_empty_string" },
        "issue_template_support": { "type": "boolean" },
        "browser_blocked_fallback": { "$ref": "#/$defs/non_empty_string" },
        "offline_fallback": { "$ref": "#/$defs/non_empty_string" },
        "pre_exit_label_required": { "const": true }
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "destination_id",
        "title",
        "purpose",
        "destination_class",
        "visibility_boundary",
        "auth_expectation",
        "data_exit_boundary",
        "issue_template_support",
        "browser_blocked_fallback_ref",
        "offline_fallback_ref",
        "surfaces"
      ],
      "properties": {
        "destination_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "purpose": { "$ref": "#/$defs/non_empty_string" },
        "destination_class": { "$ref": "#/$defs/destination_trust_class" },
        "visibility_boundary": { "$ref": "#/$defs/non_empty_string" },
        "auth_expectation": { "$ref": "#/$defs/non_empty_string" },
        "data_exit_boundary": { "$ref": "#/$defs/non_empty_string" },
        "issue_template_support": { "$ref": "#/$defs/non_empty_string" },
        "browser_blocked_fallback_ref": { "$ref": "#/$defs/non_empty_string" },
        "offline_fallback_ref": { "$ref": "#/$defs/non_empty_string" },
        "surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/public_proof_surface" },
          "uniqueItems": true
        }
      }
    },
    "service_health_card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id",
        "service_family",
        "boundary_class",
        "service_contract_state",
        "affected_workflows",
        "last_checked_at",
        "freshness_ref",
        "visible_freshness_label",
        "outage_scope",
        "local_only_continuity_note",
        "diagnostics_action_ref",
        "surfaced_on"
      ],
      "properties": {
        "card_id": { "$ref": "#/$defs/non_empty_string" },
        "service_family": { "$ref": "#/$defs/non_empty_string" },
        "boundary_class": { "$ref": "#/$defs/non_empty_string" },
        "service_contract_state": { "$ref": "#/$defs/service_contract_state" },
        "affected_workflows": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "last_checked_at": { "$ref": "#/$defs/non_empty_string" },
        "freshness_ref": { "$ref": "#/$defs/non_empty_string" },
        "visible_freshness_label": { "$ref": "#/$defs/non_empty_string" },
        "outage_scope": { "$ref": "#/$defs/non_empty_string" },
        "local_only_continuity_note": { "$ref": "#/$defs/non_empty_string" },
        "diagnostics_action_ref": { "$ref": "#/$defs/non_empty_string" },
        "surfaced_on": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/public_proof_surface" },
          "uniqueItems": true
        }
      }
    },
    "surface_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "descriptor_ref",
        "build_identity_ref",
        "freshness_refs",
        "service_health_card_refs",
        "destination_refs",
        "consumes_shared_descriptor",
        "requires_sign_in_to_read",
        "cached_or_offline_label_visible",
        "local_only_continuity_visible",
        "may_overclaim_live_reachability",
        "local_continuity_note"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/public_proof_surface" },
        "descriptor_ref": { "$ref": "#/$defs/non_empty_string" },
        "build_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "freshness_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "service_health_card_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "destination_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "consumes_shared_descriptor": { "const": true },
        "requires_sign_in_to_read": { "const": false },
        "cached_or_offline_label_visible": { "const": true },
        "local_only_continuity_visible": { "const": true },
        "may_overclaim_live_reachability": { "const": false },
        "local_continuity_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "continuity_drill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drill_id",
        "scenario",
        "input_state",
        "expected_surface_refs",
        "stale_or_cached_label_visible",
        "destination_classes_preserved_before_exit",
        "local_only_continuity_visible",
        "support_save_later_verified",
        "no_implicit_upload",
        "result_summary"
      ],
      "properties": {
        "drill_id": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/continuity_drill_scenario" },
        "input_state": { "$ref": "#/$defs/non_empty_string" },
        "expected_surface_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/public_proof_surface" },
          "uniqueItems": true
        },
        "stale_or_cached_label_visible": { "const": true },
        "destination_classes_preserved_before_exit": { "const": true },
        "local_only_continuity_visible": { "const": true },
        "support_save_later_verified": { "const": true },
        "no_implicit_upload": { "const": true },
        "result_summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "support_save_later": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_contract_ref",
        "local_report_path_ref",
        "redaction_profile_ref",
        "destination_class",
        "save_later_packet_ref",
        "explicit_submit_action_refs",
        "local_first",
        "implicit_upload_allowed",
        "inspect_before_submit_required"
      ],
      "properties": {
        "support_contract_ref": { "$ref": "#/$defs/non_empty_string" },
        "local_report_path_ref": { "$ref": "#/$defs/non_empty_string" },
        "redaction_profile_ref": { "$ref": "#/$defs/non_empty_string" },
        "destination_class": { "const": "local_only" },
        "save_later_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "explicit_submit_action_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "local_first": { "const": true },
        "implicit_upload_allowed": { "const": false },
        "inspect_before_submit_required": { "const": true }
      }
    },
    "descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "descriptor_id",
        "shared_contract_ref",
        "schema_ref",
        "build_identity",
        "freshness",
        "destination_trust_classes",
        "service_health_cards",
        "destinations",
        "surface_bindings",
        "continuity_drills",
        "support_save_later"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "service_health_destination_truth_descriptor"
        },
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "descriptor_id": { "$ref": "#/$defs/non_empty_string" },
        "shared_contract_ref": {
          "type": "string",
          "const": "service_health_destination_truth:v1"
        },
        "schema_ref": {
          "type": "string",
          "const": "schemas/help/service-health-destination.schema.json"
        },
        "build_identity": { "$ref": "#/$defs/build_identity" },
        "freshness": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/freshness" }
        },
        "destination_trust_classes": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/destination_trust_class_manifest" }
        },
        "service_health_cards": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/service_health_card" }
        },
        "destinations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/destination" }
        },
        "surface_bindings": {
          "type": "array",
          "minItems": 11,
          "items": { "$ref": "#/$defs/surface_binding" }
        },
        "continuity_drills": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/continuity_drill" }
        },
        "support_save_later": { "$ref": "#/$defs/support_save_later" }
      }
    }
  }
}
