{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/help/teaching_session.schema.json",
  "title": "Aureline beta teaching/classroom session",
  "description": "Boundary schema for teaching_session_record frozen in docs/help/m3/teaching_and_classroom_conformance.md. A teaching session is the single governed object the shell uses to run a teaching or classroom walkthrough as a thin, reversible layer over existing learning mode — guided tours, exercise packs, glossary cards, and speaker notes — never a parallel collaboration product. Each segment reuses a learning-mode object (its learning_object_ref, docs_node_refs, graph_node_refs, and citation_refs are the same ids learning mode ships) and stays resumable across restart and reconnect. Each segment also carries an explicit docs_pack_state so offline, cached, mirrored, and not-installed packs stay visible instead of pretending remote enrichment is available; any state other than installed requires a docs_pack_disclosure_ref. Demonstrations are non-mutating by default; a mutation_through_fences demonstration must reuse the ordinary command id, preview sheet, approval fence, and rollback semantics. Teaching roles describe participation only: grants_mutation_authority, grants_terminal_or_debug_control, grants_broader_authority_than_workspace, establishes_private_data_ownership, creates_hidden_progress_model, and creates_cohort_or_grading_flow are always false, while demonstrations_non_mutating_by_default, preserves_source_citations, reuses_learning_mode_objects_only, and restore_on_exit_guaranteed are always true. The restore checkpoint captures the prior layout, focus, panel visibility, and accessibility posture so exit, leave, and crash recovery restore the exact prior environment. Adding a new session_kind, lifecycle_state, role, replay_policy, retention_class, segment_kind, docs_pack_state, or demonstration kind value is additive-minor and requires a schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [{ "$ref": "#/$defs/teaching_session_record" }],
  "$defs": {
    "teaching_session_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "session_id",
        "session_kind",
        "lifecycle_state",
        "local_role",
        "replay_policy",
        "retention_class",
        "exercise_pack_refs",
        "current_focus_segment_ref",
        "segments",
        "participants",
        "restore_checkpoint",
        "replay_archive_opt_in_explicit",
        "shared_retention_opt_in_explicit",
        "grants_mutation_authority",
        "grants_terminal_or_debug_control",
        "grants_broader_authority_than_workspace",
        "establishes_private_data_ownership",
        "creates_hidden_progress_model",
        "creates_cohort_or_grading_flow",
        "demonstrations_non_mutating_by_default",
        "preserves_source_citations",
        "reuses_learning_mode_objects_only",
        "restore_on_exit_guaranteed"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "teaching_session_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "shell:teaching_classroom_beta:v1" },
        "session_id": { "$ref": "#/$defs/stable_id" },
        "session_kind": { "type": "string", "enum": ["teaching", "classroom"] },
        "lifecycle_state": {
          "type": "string",
          "enum": [
            "entering",
            "active",
            "exited_restored",
            "left_restored",
            "crash_recovered_restored"
          ]
        },
        "local_role": { "$ref": "#/$defs/teaching_role" },
        "replay_policy": {
          "type": "string",
          "enum": ["ephemeral", "local_replay_user_owned", "shared_archive_opt_in"]
        },
        "retention_class": {
          "type": "string",
          "enum": ["discard_on_exit", "local_user_owned", "shared_workspace_retained"]
        },
        "exercise_pack_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "current_focus_segment_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }]
        },
        "segments": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/teaching_segment" }
        },
        "participants": {
          "type": "array",
          "items": { "$ref": "#/$defs/teaching_participant" }
        },
        "restore_checkpoint": { "$ref": "#/$defs/restore_checkpoint" },
        "replay_archive_opt_in_explicit": { "type": "boolean" },
        "shared_retention_opt_in_explicit": { "type": "boolean" },
        "grants_mutation_authority": { "type": "boolean", "const": false },
        "grants_terminal_or_debug_control": { "type": "boolean", "const": false },
        "grants_broader_authority_than_workspace": { "type": "boolean", "const": false },
        "establishes_private_data_ownership": { "type": "boolean", "const": false },
        "creates_hidden_progress_model": { "type": "boolean", "const": false },
        "creates_cohort_or_grading_flow": { "type": "boolean", "const": false },
        "demonstrations_non_mutating_by_default": { "type": "boolean", "const": true },
        "preserves_source_citations": { "type": "boolean", "const": true },
        "reuses_learning_mode_objects_only": { "type": "boolean", "const": true },
        "restore_on_exit_guaranteed": { "type": "boolean", "const": true }
      },
      "allOf": [
        {
          "comment": "A shared archive must carry an explicit replay opt-in marker.",
          "if": { "properties": { "replay_policy": { "const": "shared_archive_opt_in" } } },
          "then": { "properties": { "replay_archive_opt_in_explicit": { "const": true } } },
          "else": { "properties": { "replay_archive_opt_in_explicit": { "const": false } } }
        },
        {
          "comment": "Shared retention must carry an explicit retention opt-in marker.",
          "if": { "properties": { "retention_class": { "const": "shared_workspace_retained" } } },
          "then": { "properties": { "shared_retention_opt_in_explicit": { "const": true } } },
          "else": { "properties": { "shared_retention_opt_in_explicit": { "const": false } } }
        }
      ]
    },
    "teaching_segment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segment_id",
        "ordinal",
        "segment_kind",
        "title",
        "learning_object_ref",
        "docs_node_refs",
        "graph_node_refs",
        "citation_refs",
        "docs_pack_ref",
        "docs_pack_state",
        "docs_pack_disclosure_ref",
        "resume_ref",
        "resumable_across_restart",
        "resumable_across_reconnect",
        "demonstrated_action",
        "cites_learning_mode_object"
      ],
      "properties": {
        "segment_id": { "$ref": "#/$defs/stable_id" },
        "ordinal": { "type": "integer", "minimum": 0 },
        "segment_kind": {
          "type": "string",
          "enum": ["tour", "exercise_pack", "glossary_card", "speaker_note"]
        },
        "title": { "$ref": "#/$defs/short_text" },
        "learning_object_ref": { "$ref": "#/$defs/stable_id" },
        "docs_node_refs": { "type": "array", "items": { "$ref": "#/$defs/stable_id" } },
        "graph_node_refs": { "type": "array", "items": { "$ref": "#/$defs/stable_id" } },
        "citation_refs": { "type": "array", "items": { "$ref": "#/$defs/stable_id" } },
        "docs_pack_ref": { "$ref": "#/$defs/stable_id" },
        "docs_pack_state": {
          "type": "string",
          "enum": ["installed", "cached", "mirrored", "offline", "not_installed"]
        },
        "docs_pack_disclosure_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }]
        },
        "resume_ref": { "$ref": "#/$defs/stable_id" },
        "resumable_across_restart": { "type": "boolean", "const": true },
        "resumable_across_reconnect": { "type": "boolean", "const": true },
        "demonstrated_action": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/demonstrated_action" }]
        },
        "cites_learning_mode_object": { "type": "boolean", "const": true }
      },
      "allOf": [
        {
          "comment": "An installed, current docs pack needs no disclosure.",
          "if": { "properties": { "docs_pack_state": { "const": "installed" } } },
          "then": { "properties": { "docs_pack_disclosure_ref": { "type": "null" } } }
        },
        {
          "comment": "Any degraded docs-pack state must carry a user-visible disclosure.",
          "if": {
            "properties": {
              "docs_pack_state": {
                "enum": ["cached", "mirrored", "offline", "not_installed"]
              }
            }
          },
          "then": { "properties": { "docs_pack_disclosure_ref": { "$ref": "#/$defs/stable_id" } } }
        }
      ]
    },
    "demonstrated_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "kind",
        "command_id",
        "preview_sheet_ref",
        "approval_path_ref",
        "rollback_semantics_ref",
        "evidence_packet_rule_ref",
        "mutates_workspace",
        "reuses_ordinary_command_path"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/stable_id" },
        "kind": {
          "type": "string",
          "enum": ["explain", "open_docs", "preview_only", "mutation_through_fences"]
        },
        "command_id": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }] },
        "preview_sheet_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }] },
        "approval_path_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }] },
        "rollback_semantics_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }] },
        "evidence_packet_rule_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }]
        },
        "mutates_workspace": { "type": "boolean" },
        "reuses_ordinary_command_path": { "type": "boolean", "const": true }
      },
      "allOf": [
        {
          "comment": "A mutating demonstration must reuse the full ordinary command path.",
          "if": { "properties": { "kind": { "const": "mutation_through_fences" } } },
          "then": {
            "properties": {
              "mutates_workspace": { "const": true },
              "command_id": { "$ref": "#/$defs/stable_id" },
              "preview_sheet_ref": { "$ref": "#/$defs/stable_id" },
              "approval_path_ref": { "$ref": "#/$defs/stable_id" },
              "rollback_semantics_ref": { "$ref": "#/$defs/stable_id" }
            }
          }
        },
        {
          "comment": "A non-mutating demonstration never mutates the workspace.",
          "if": {
            "properties": { "kind": { "enum": ["explain", "open_docs", "preview_only"] } }
          },
          "then": { "properties": { "mutates_workspace": { "const": false } } }
        }
      ]
    },
    "teaching_participant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["participant_id", "role", "client_class", "is_external_guest"],
      "properties": {
        "participant_id": { "$ref": "#/$defs/stable_id" },
        "role": { "$ref": "#/$defs/teaching_role" },
        "client_class": { "type": "string", "enum": ["full", "limited", "low_bandwidth"] },
        "is_external_guest": { "type": "boolean" }
      }
    },
    "restore_checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_id",
        "prior_layout_ref",
        "prior_focus_ref",
        "prior_panel_visibility_ref",
        "accessibility_posture_ref",
        "captured_at"
      ],
      "properties": {
        "checkpoint_id": { "$ref": "#/$defs/stable_id" },
        "prior_layout_ref": { "$ref": "#/$defs/stable_id" },
        "prior_focus_ref": { "$ref": "#/$defs/stable_id" },
        "prior_panel_visibility_ref": { "$ref": "#/$defs/stable_id" },
        "accessibility_posture_ref": { "$ref": "#/$defs/stable_id" },
        "captured_at": { "type": "string", "format": "date-time" }
      }
    },
    "teaching_role": {
      "type": "string",
      "enum": ["moderator", "participant", "observer", "approver", "scribe"]
    },
    "stable_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:._@#/-]*$"
    },
    "short_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 400
    }
  }
}
