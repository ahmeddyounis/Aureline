{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/help/presentation_session.schema.json",
  "title": "Aureline beta presentation session",
  "description": "Boundary schema for presentation_session_record frozen in docs/help/m3/presentation_mode_beta.md. A presentation session is the single governed object the shell uses to drive a guided walkthrough as a thin, reversible layer over existing editor, diff, docs, graph, and notebook surfaces — never a parallel artifact type. Every waypoint binds to a stable object on an existing surface and preserves its file path, symbol anchor, branch/workspace context, and local/remote/shared boundary label, so decorative chrome never erases provenance. Leader/follow, breakaway, and return states are explicit and attributable, not inferred from cursor motion. Speaker notes default to a local scope and only become shared through an explicit promotion. The session never widens authority: grants_mutation_authority, grants_control_authority, and establishes_private_data_ownership are always false, while speaker_notes_default_local_only, preserves_source_provenance, and reuses_existing_surfaces_only are always true. The restore checkpoint captures the prior layout, focus, panel visibility, and accessibility posture so exit, cancel, and crash recovery restore the exact prior environment. Adding a new lifecycle_state, leader_follow_state, audience_scope, layout_preset, walkthrough_surface_kind, boundary_label, waypoint_completion_state, participant_role, participant_follow_state, or speaker_note_scope value is additive-minor and requires a schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [{ "$ref": "#/$defs/presentation_session_record" }],
  "$defs": {
    "presentation_session_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "session_id",
        "lifecycle_state",
        "leader_follow_state",
        "layout_preset",
        "audience_scope",
        "current_focus_waypoint_ref",
        "waypoints",
        "audience_participants",
        "restore_checkpoint",
        "grants_mutation_authority",
        "grants_control_authority",
        "establishes_private_data_ownership",
        "speaker_notes_default_local_only",
        "preserves_source_provenance",
        "reuses_existing_surfaces_only"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "presentation_session_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "shell:presentation_mode_beta:v1" },
        "session_id": { "$ref": "#/$defs/stable_id" },
        "lifecycle_state": {
          "type": "string",
          "enum": [
            "entering",
            "active",
            "exited_restored",
            "cancelled_restored",
            "crash_recovered_restored"
          ]
        },
        "leader_follow_state": {
          "type": "string",
          "enum": ["presenting", "following_presenter", "broken_away", "requesting_follow"]
        },
        "layout_preset": {
          "type": "string",
          "enum": ["inherit_current", "focused_single", "split_compare", "narrative_wide"]
        },
        "audience_scope": {
          "type": "string",
          "enum": ["solo_rehearsal", "shared_workspace", "invited_guests"]
        },
        "current_focus_waypoint_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }]
        },
        "waypoints": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/follow_waypoint" }
        },
        "audience_participants": {
          "type": "array",
          "items": { "$ref": "#/$defs/audience_participant" }
        },
        "restore_checkpoint": { "$ref": "#/$defs/restore_checkpoint" },
        "grants_mutation_authority": { "type": "boolean", "const": false },
        "grants_control_authority": { "type": "boolean", "const": false },
        "establishes_private_data_ownership": { "type": "boolean", "const": false },
        "speaker_notes_default_local_only": { "type": "boolean", "const": true },
        "preserves_source_provenance": { "type": "boolean", "const": true },
        "reuses_existing_surfaces_only": { "type": "boolean", "const": true }
      }
    },
    "follow_waypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "waypoint_id",
        "ordinal",
        "step_title",
        "surface_kind",
        "target_object_ref",
        "file_path_ref",
        "symbol_anchor_ref",
        "branch_workspace_ref",
        "boundary_label",
        "zoom_layout_hint_ref",
        "reveal_action_ref",
        "completion_state",
        "speaker_note",
        "reuses_existing_surface",
        "creates_parallel_artifact"
      ],
      "properties": {
        "waypoint_id": { "$ref": "#/$defs/stable_id" },
        "ordinal": { "type": "integer", "minimum": 0 },
        "step_title": { "$ref": "#/$defs/short_text" },
        "surface_kind": {
          "type": "string",
          "enum": ["editor", "diff", "docs", "graph", "notebook"]
        },
        "target_object_ref": { "$ref": "#/$defs/stable_id" },
        "file_path_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }] },
        "symbol_anchor_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/short_text" }] },
        "branch_workspace_ref": { "$ref": "#/$defs/stable_id" },
        "boundary_label": { "type": "string", "enum": ["local", "remote", "shared"] },
        "zoom_layout_hint_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }] },
        "reveal_action_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/stable_id" }] },
        "completion_state": { "type": "string", "enum": ["pending", "current", "visited"] },
        "speaker_note": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/speaker_note" }] },
        "reuses_existing_surface": { "type": "boolean", "const": true },
        "creates_parallel_artifact": { "type": "boolean", "const": false }
      }
    },
    "speaker_note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "note_id",
        "linked_waypoint_ref",
        "scope",
        "body_label",
        "next_step_cue_label",
        "citation_refs",
        "shared_promotion_explicit"
      ],
      "properties": {
        "note_id": { "$ref": "#/$defs/stable_id" },
        "linked_waypoint_ref": { "$ref": "#/$defs/stable_id" },
        "scope": { "type": "string", "enum": ["local", "shared"] },
        "body_label": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/short_text" }] },
        "next_step_cue_label": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/short_text" }] },
        "citation_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" }
        },
        "shared_promotion_explicit": { "type": "boolean" }
      },
      "allOf": [
        {
          "comment": "A local note never carries an explicit-promotion marker.",
          "if": { "properties": { "scope": { "const": "local" } } },
          "then": { "properties": { "shared_promotion_explicit": { "const": false } } }
        },
        {
          "comment": "A shared note must carry an explicit-promotion marker.",
          "if": { "properties": { "scope": { "const": "shared" } } },
          "then": { "properties": { "shared_promotion_explicit": { "const": true } } }
        }
      ]
    },
    "audience_participant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["participant_id", "role_badge", "follow_state", "is_external_guest"],
      "properties": {
        "participant_id": { "$ref": "#/$defs/stable_id" },
        "role_badge": { "type": "string", "enum": ["presenter", "co_presenter", "viewer"] },
        "follow_state": {
          "type": "string",
          "enum": ["following", "broken_away", "requesting_follow"]
        },
        "is_external_guest": { "type": "boolean" }
      }
    },
    "restore_checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_id",
        "prior_layout_ref",
        "prior_focus_ref",
        "prior_panel_visibility_ref",
        "accessibility_posture_ref",
        "captured_at"
      ],
      "properties": {
        "checkpoint_id": { "$ref": "#/$defs/stable_id" },
        "prior_layout_ref": { "$ref": "#/$defs/stable_id" },
        "prior_focus_ref": { "$ref": "#/$defs/stable_id" },
        "prior_panel_visibility_ref": { "$ref": "#/$defs/stable_id" },
        "accessibility_posture_ref": { "$ref": "#/$defs/stable_id" },
        "captured_at": { "type": "string", "format": "date-time" }
      }
    },
    "stable_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:._@#/-]*$"
    },
    "short_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 400
    }
  }
}
