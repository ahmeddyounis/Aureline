{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/help/learning_mode_profile.schema.json",
  "title": "Aureline beta learning-mode profile",
  "description": "User-owned profile contract for learning-mode framing. Profiles can tune tip intensity, jargon level, explanation posture, dismissals, bookmarks, pause, snooze, reset, and resume behavior, but they cannot change authority, trust, ownership, or mutation approval semantics.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "profile_scope",
    "profile_state",
    "tip_intensity_class",
    "jargon_level_class",
    "ai_explanation_posture",
    "mutation_guardrail_class",
    "explain_before_act_default",
    "authority_boundary_change_allowed",
    "data_ownership_class",
    "optional_sync_posture",
    "dismissals_state_ref",
    "bookmarks_state_ref",
    "blocking_onboarding_allowed",
    "controls"
  ],
  "properties": {
    "profile_id": { "$ref": "#/$defs/stable_id" },
    "profile_scope": { "$ref": "#/$defs/stable_id" },
    "profile_state": { "type": "string", "enum": ["disabled", "enabled", "paused", "snoozed", "reset_requested"] },
    "tip_intensity_class": {
      "type": "string",
      "enum": ["silent_inline_only", "gentle_hint", "prompted_acknowledge", "mandatory_step_required"]
    },
    "jargon_level_class": { "type": "string", "enum": ["beginner", "intermediate", "advanced", "expert"] },
    "ai_explanation_posture": {
      "type": "string",
      "enum": ["explain_only", "explain_then_prepare_preview", "preview_only_after_explicit_do"]
    },
    "mutation_guardrail_class": {
      "type": "string",
      "enum": ["explain_only", "preview_required", "approval_required", "blocked_until_trust"]
    },
    "explain_before_act_default": { "type": "boolean", "const": true },
    "authority_boundary_change_allowed": { "type": "boolean", "const": false },
    "data_ownership_class": { "type": "string", "enum": ["user_owned_portable_profile"] },
    "optional_sync_posture": {
      "type": "string",
      "enum": ["local_only_default_optional_sync", "local_only_sync_blocked_by_policy", "portable_profile_sync_enabled"]
    },
    "dismissals_state_ref": { "$ref": "#/$defs/stable_id" },
    "bookmarks_state_ref": { "$ref": "#/$defs/stable_id" },
    "blocking_onboarding_allowed": { "type": "boolean", "const": false },
    "controls": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/control" }
    }
  },
  "$defs": {
    "stable_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:._@#/-]*$"
    },
    "control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_id",
        "control_class",
        "state_transition",
        "local_state_write",
        "reversible_from_learning_digest",
        "silent_write_allowed",
        "user_visible"
      ],
      "properties": {
        "control_id": { "$ref": "#/$defs/stable_id" },
        "control_class": { "type": "string", "enum": ["enable", "pause", "snooze", "reset", "resume"] },
        "state_transition": { "type": "string", "minLength": 1 },
        "local_state_write": { "type": "boolean", "const": true },
        "reversible_from_learning_digest": { "type": "boolean", "const": true },
        "silent_write_allowed": { "type": "boolean", "const": false },
        "user_visible": { "type": "boolean", "const": true }
      }
    }
  }
}
