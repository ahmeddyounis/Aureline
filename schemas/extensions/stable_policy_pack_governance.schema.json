{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/stable_policy_pack_governance.schema.json",
  "title": "Aureline stable policy-pack governance packet",
  "description": "Cross-tool boundary schema for the stable policy-pack governance packet emitted by crates/aureline-extensions. One packet binds a stable_policy_governance_identity (governance-profile descriptor ref, row identity, package identity, policy-pack id and version, the pinned governance-profile version, the admin and publisher namespaces, the pinned governance-evidence ref, the publisher trust tier, and the lifecycle state), a stable_policy_pack_diff (base / target pack versions, diff completeness, added / removed / modified rule counts, and breaking-change acknowledgement), a stable_policy_decision_explain (governance decision, typed reason, governing-rule ref, and an explained flag), a stable_admin_governance_export (export scope, source, redaction posture, and export ref), a stable_enterprise_lane_binding (lane class, claim basis, tenancy scope, and attestation ref), a stable_policy_governance_permission_posture (declared / effective / policy-cap refs and a no-widening flag), a stable_policy_governance_compatibility (parity label, scorecard ref, verified flag), a stable_policy_governance_install_posture (install scope and disclosure, activation cost class, revocation posture, mirrorability, rollback support), the stable_policy_governance_qualification_claim after the posture is applied (with automatic narrowing below Stable), a stable_policy_governance_downgraded_banner, and an inspection projection. A stable effective tier may only render when the row pins the published profile version, is evidence-backed, keeps its trust tier out of quarantine, stays runnable, carries a complete diff with no unacknowledged breaking change, explains its decision, emits a mechanically-generated metadata-safe export at full / summary scope, attests its enterprise lane, never widens permissions beyond the declared manifest or policy cap, keeps its activation cost bounded, keeps verified non-parity-limited compatibility, discloses its install scope, keeps a clean revocation posture, stays mirrorable, and is fully attributed. A widened permission set, an unbounded activation cost, or a private export withdraws the row; a catalog-asserted basis, a hand-authored export, or an unattested enterprise lane narrows below Stable. The Rust types in crates/aureline-extensions/src/stabilize_policy_pack_diff_explain_export_and_admin/ are the source of truth. Raw policy-pack bytes, raw decision payloads, raw permission contents, and raw publisher-private data MUST NOT appear in any record; records carry refs only.",
  "type": "object",
  "$ref": "#/$defs/stable_policy_pack_governance_packet",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log and safe in support/export packets."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "trust_tier_class": {
      "type": "string",
      "enum": ["verified_publisher", "known_publisher", "community_unverified", "quarantined"]
    },
    "lifecycle_state_class": {
      "type": "string",
      "enum": [
        "installed",
        "pending_activation",
        "active",
        "recovered",
        "degraded",
        "disabled",
        "quarantined",
        "removed",
        "publisher_blocked"
      ]
    },
    "diff_completeness_class": {
      "type": "string",
      "enum": ["complete", "partial", "missing"]
    },
    "decision_class": {
      "type": "string",
      "enum": ["allowed", "constrained", "blocked", "quarantined"]
    },
    "decision_reason_class": {
      "type": "string",
      "enum": [
        "within_policy",
        "permission_capped",
        "publisher_below_trust_floor",
        "version_out_of_range",
        "on_admin_denylist",
        "superseded_by_pack"
      ]
    },
    "export_scope_class": {
      "type": "string",
      "enum": ["full", "summary", "decision_only"]
    },
    "export_source_class": {
      "type": "string",
      "enum": ["mechanically_generated", "hand_authored"]
    },
    "export_redaction_class": {
      "type": "string",
      "enum": ["metadata_safe", "contains_private"]
    },
    "enterprise_lane_class": {
      "type": "string",
      "enum": ["enterprise_managed", "enterprise_self_hosted", "enterprise_air_gapped", "standard"]
    },
    "lane_claim_basis_class": {
      "type": "string",
      "enum": ["attested", "asserted"]
    },
    "tenancy_scope_class": {
      "type": "string",
      "enum": ["single_tenant", "multi_tenant", "per_workspace"]
    },
    "activation_cost_class": {
      "type": "string",
      "enum": ["negligible", "light", "moderate", "heavy", "unbounded"]
    },
    "compatibility_label_class": {
      "type": "string",
      "enum": ["full_parity", "high_parity", "partial_parity", "limited_parity", "unsupported"]
    },
    "install_scope_class": {
      "type": "string",
      "enum": ["user", "workspace", "machine", "portable"]
    },
    "revocation_posture_class": {
      "type": "string",
      "enum": ["clean", "advisory", "quarantined", "revoked"]
    },
    "mirrorability_class": {
      "type": "string",
      "enum": ["mirrorable", "mirror_pinned", "not_mirrorable"]
    },
    "stability_tier": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "claim_basis_class": {
      "type": "string",
      "enum": ["evidence_backed", "catalog_asserted_only"]
    },
    "support_claim_class": {
      "type": "string",
      "enum": [
        "stable_governance_claim",
        "beta_governance_partial_claim",
        "preview_governance_experimental_claim",
        "withdrawn_no_governance_claim"
      ]
    },
    "downgrade_reason_class": {
      "type": "string",
      "enum": [
        "governance_profile_version_not_published",
        "catalog_only_trust_not_evidence_backed",
        "trust_tier_quarantined",
        "lifecycle_not_runnable",
        "diff_missing",
        "diff_partial",
        "diff_unacknowledged_breaking_change",
        "decision_not_explained",
        "export_not_mechanically_sourced",
        "export_scope_limited",
        "export_contains_private_data",
        "enterprise_lane_not_attested",
        "permission_widened",
        "activation_cost_unbounded",
        "compatibility_unsupported",
        "compatibility_parity_limited",
        "compatibility_not_verified",
        "install_scope_not_disclosed",
        "revocation_posture_quarantined",
        "revocation_posture_revoked",
        "revocation_posture_advisory",
        "not_mirrorable",
        "attribution_incomplete"
      ]
    },
    "consumer_surface_class": {
      "type": "string",
      "enum": [
        "admin_governance_console",
        "policy_pack_diff_view",
        "policy_decision_explainer",
        "install_review",
        "extension_detail_view",
        "diagnostics",
        "support_export",
        "docs_help_surface",
        "release_packet",
        "cli_inspector"
      ]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "governance_profile_ref",
        "row_identity_ref",
        "extension_identity",
        "extension_version",
        "package_id",
        "policy_pack_id",
        "policy_pack_version",
        "governance_profile_version",
        "admin_namespace",
        "publisher_namespace",
        "governance_evidence_ref",
        "publisher_trust_tier_class",
        "lifecycle_state_class"
      ],
      "properties": {
        "record_kind": { "const": "stable_policy_governance_identity" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "governance_profile_ref": {
          "type": "string",
          "pattern": "^governance_profile:"
        },
        "row_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "extension_identity": { "$ref": "#/$defs/opaque_id" },
        "extension_version": { "$ref": "#/$defs/opaque_id" },
        "package_id": { "$ref": "#/$defs/opaque_id" },
        "policy_pack_id": { "$ref": "#/$defs/opaque_id" },
        "policy_pack_version": { "type": "integer", "minimum": 0 },
        "governance_profile_version": { "type": "integer", "minimum": 0 },
        "admin_namespace": { "$ref": "#/$defs/opaque_id" },
        "publisher_namespace": { "$ref": "#/$defs/opaque_id" },
        "governance_evidence_ref": { "$ref": "#/$defs/opaque_id" },
        "publisher_trust_tier_class": { "$ref": "#/$defs/trust_tier_class" },
        "lifecycle_state_class": { "$ref": "#/$defs/lifecycle_state_class" }
      }
    },
    "diff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "base_pack_version",
        "target_pack_version",
        "diff_completeness_class",
        "rules_added",
        "rules_removed",
        "rules_modified",
        "breaking_change",
        "breaking_change_acknowledged",
        "diff_ref",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_policy_pack_diff" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "base_pack_version": { "type": "integer", "minimum": 0 },
        "target_pack_version": { "type": "integer", "minimum": 0 },
        "diff_completeness_class": { "$ref": "#/$defs/diff_completeness_class" },
        "rules_added": { "type": "integer", "minimum": 0 },
        "rules_removed": { "type": "integer", "minimum": 0 },
        "rules_modified": { "type": "integer", "minimum": 0 },
        "breaking_change": { "type": "boolean" },
        "breaking_change_acknowledged": { "type": "boolean" },
        "diff_ref": { "$ref": "#/$defs/opaque_id" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "explain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "decision_class",
        "reason_class",
        "governing_rule_ref",
        "decision_explained",
        "explanation_ref",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_policy_decision_explain" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "decision_class": { "$ref": "#/$defs/decision_class" },
        "reason_class": { "$ref": "#/$defs/decision_reason_class" },
        "governing_rule_ref": { "$ref": "#/$defs/opaque_id" },
        "decision_explained": { "type": "boolean" },
        "explanation_ref": { "$ref": "#/$defs/opaque_id" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "export_scope_class",
        "export_source_class",
        "export_redaction_class",
        "export_ref",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_admin_governance_export" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "export_scope_class": { "$ref": "#/$defs/export_scope_class" },
        "export_source_class": { "$ref": "#/$defs/export_source_class" },
        "export_redaction_class": { "$ref": "#/$defs/export_redaction_class" },
        "export_ref": { "$ref": "#/$defs/opaque_id" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "enterprise_lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "enterprise_lane_class",
        "lane_claim_basis_class",
        "tenancy_scope_class",
        "lane_attestation_ref",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_enterprise_lane_binding" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "enterprise_lane_class": { "$ref": "#/$defs/enterprise_lane_class" },
        "lane_claim_basis_class": { "$ref": "#/$defs/lane_claim_basis_class" },
        "tenancy_scope_class": { "$ref": "#/$defs/tenancy_scope_class" },
        "lane_attestation_ref": { "$ref": "#/$defs/opaque_id" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "permission_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "declared_permission_ref",
        "effective_permission_ref",
        "policy_cap_ref",
        "widened",
        "reconsent_required",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_policy_governance_permission_posture" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "declared_permission_ref": { "$ref": "#/$defs/opaque_id" },
        "effective_permission_ref": { "$ref": "#/$defs/opaque_id" },
        "policy_cap_ref": { "$ref": "#/$defs/opaque_id" },
        "widened": { "type": "boolean" },
        "reconsent_required": { "type": "boolean" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "compatibility_label_class",
        "scorecard_ref",
        "compatibility_verified",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_policy_governance_compatibility" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "compatibility_label_class": { "$ref": "#/$defs/compatibility_label_class" },
        "scorecard_ref": { "$ref": "#/$defs/opaque_id" },
        "compatibility_verified": { "type": "boolean" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "install_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "install_scope_class",
        "install_scope_disclosed",
        "activation_cost_class",
        "revocation_posture_class",
        "mirrorability_class",
        "rollback_supported",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_policy_governance_install_posture" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "install_scope_class": { "$ref": "#/$defs/install_scope_class" },
        "install_scope_disclosed": { "type": "boolean" },
        "activation_cost_class": { "$ref": "#/$defs/activation_cost_class" },
        "revocation_posture_class": { "$ref": "#/$defs/revocation_posture_class" },
        "mirrorability_class": { "$ref": "#/$defs/mirrorability_class" },
        "rollback_supported": { "type": "boolean" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "qualification_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "claimed_tier",
        "effective_tier",
        "support_claim_class",
        "claim_basis_class",
        "downgraded",
        "downgrade_reasons",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_policy_governance_qualification_claim" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "claimed_tier": { "$ref": "#/$defs/stability_tier" },
        "effective_tier": { "$ref": "#/$defs/stability_tier" },
        "support_claim_class": { "$ref": "#/$defs/support_claim_class" },
        "claim_basis_class": { "$ref": "#/$defs/claim_basis_class" },
        "downgraded": { "type": "boolean" },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason_class" }
        },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "downgraded_banner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_kind", "schema_version", "must_display", "summary_label"],
      "properties": {
        "record_kind": { "const": "stable_policy_governance_downgraded_banner" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "must_display": { "type": "boolean" },
        "banner_reason_class": { "$ref": "#/$defs/downgrade_reason_class" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "inspection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id_ref",
        "effective_tier",
        "stable_claim",
        "profile_version_current",
        "trust_tier_class",
        "lifecycle_runnable",
        "base_pack_version",
        "target_pack_version",
        "diff_completeness_class",
        "diff_complete",
        "decision_class",
        "decision_explained",
        "export_scope_class",
        "export_mechanically_sourced",
        "export_redaction_class",
        "enterprise_lane_class",
        "enterprise_lane_attested",
        "permissions_not_widened",
        "activation_cost_class",
        "compatibility_label_class",
        "compatibility_verified",
        "revocation_posture_class",
        "mirrorability_class",
        "downgraded",
        "downgraded_banner_required",
        "attribution_complete",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_policy_pack_governance_inspection" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id_ref": { "$ref": "#/$defs/opaque_id" },
        "effective_tier": { "$ref": "#/$defs/stability_tier" },
        "stable_claim": { "type": "boolean" },
        "profile_version_current": { "type": "boolean" },
        "trust_tier_class": { "$ref": "#/$defs/trust_tier_class" },
        "lifecycle_runnable": { "type": "boolean" },
        "base_pack_version": { "type": "integer", "minimum": 0 },
        "target_pack_version": { "type": "integer", "minimum": 0 },
        "diff_completeness_class": { "$ref": "#/$defs/diff_completeness_class" },
        "diff_complete": { "type": "boolean" },
        "decision_class": { "$ref": "#/$defs/decision_class" },
        "decision_explained": { "type": "boolean" },
        "export_scope_class": { "$ref": "#/$defs/export_scope_class" },
        "export_mechanically_sourced": { "type": "boolean" },
        "export_redaction_class": { "$ref": "#/$defs/export_redaction_class" },
        "enterprise_lane_class": { "$ref": "#/$defs/enterprise_lane_class" },
        "enterprise_lane_attested": { "type": "boolean" },
        "permissions_not_widened": { "type": "boolean" },
        "activation_cost_class": { "$ref": "#/$defs/activation_cost_class" },
        "compatibility_label_class": { "$ref": "#/$defs/compatibility_label_class" },
        "compatibility_verified": { "type": "boolean" },
        "revocation_posture_class": { "$ref": "#/$defs/revocation_posture_class" },
        "mirrorability_class": { "$ref": "#/$defs/mirrorability_class" },
        "downgraded": { "type": "boolean" },
        "downgraded_banner_required": { "type": "boolean" },
        "attribution_complete": { "type": "boolean" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "stable_policy_pack_governance_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "generated_at",
        "identity",
        "diff",
        "explain",
        "export",
        "enterprise_lane",
        "permission_posture",
        "compatibility",
        "install_posture",
        "claim",
        "downgraded_banner",
        "consumer_surfaces",
        "source_schema_refs",
        "allows_catalog_only_trust",
        "allows_ambient_extension_privilege",
        "allows_unbounded_activation_cost",
        "inspection"
      ],
      "properties": {
        "record_kind": { "const": "stable_policy_pack_governance_packet" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "identity": { "$ref": "#/$defs/identity" },
        "diff": { "$ref": "#/$defs/diff" },
        "explain": { "$ref": "#/$defs/explain" },
        "export": { "$ref": "#/$defs/export" },
        "enterprise_lane": { "$ref": "#/$defs/enterprise_lane" },
        "permission_posture": { "$ref": "#/$defs/permission_posture" },
        "compatibility": { "$ref": "#/$defs/compatibility" },
        "install_posture": { "$ref": "#/$defs/install_posture" },
        "claim": { "$ref": "#/$defs/qualification_claim" },
        "downgraded_banner": { "$ref": "#/$defs/downgraded_banner" },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/consumer_surface_class" }
        },
        "source_schema_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "allows_catalog_only_trust": { "const": false },
        "allows_ambient_extension_privilege": { "const": false },
        "allows_unbounded_activation_cost": { "const": false },
        "inspection": { "$ref": "#/$defs/inspection" }
      }
    }
  }
}
