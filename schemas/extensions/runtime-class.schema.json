{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aureline.dev/extensions/runtime-class.schema.json",
  "title": "Aureline extension runtime-class and hosted-surface truth packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "schema_ref",
    "packet_id",
    "generated_at",
    "runtime_disclosures",
    "active_inspectors",
    "downgraded_host_banners",
    "hosted_surfaces",
    "authoring_flows",
    "surface_coverage",
    "consumer_surfaces",
    "claim",
    "inspection",
    "summary_label",
    "allows_catalog_only_truth",
    "allows_hidden_hosted_surface_boundary",
    "allows_generic_extension_badge_only"
  ],
  "properties": {
    "record_kind": { "const": "extension_runtime_class_truth_packet" },
    "schema_version": { "const": 1 },
    "schema_ref": { "const": "schemas/extensions/runtime-class.schema.json" },
    "packet_id": { "$ref": "#/$defs/opaque_ref" },
    "generated_at": { "type": "string", "minLength": 1 },
    "runtime_disclosures": {
      "type": "array",
      "items": { "$ref": "#/$defs/runtime_class_disclosure" }
    },
    "active_inspectors": {
      "type": "array",
      "items": { "$ref": "#/$defs/active_contribution_inspector" }
    },
    "downgraded_host_banners": {
      "type": "array",
      "items": { "$ref": "#/$defs/downgraded_host_banner" }
    },
    "hosted_surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/hosted_surface_boundary" }
    },
    "authoring_flows": {
      "type": "array",
      "items": { "$ref": "#/$defs/authoring_flow_disclosure" }
    },
    "surface_coverage": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_truth_coverage" }
    },
    "consumer_surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/consumer_surface_class" },
      "contains": { "const": "support_export" }
    },
    "claim": { "$ref": "#/$defs/runtime_class_truth_claim" },
    "inspection": { "$ref": "#/$defs/runtime_class_truth_inspection" },
    "summary_label": { "$ref": "#/$defs/reviewable_sentence" },
    "allows_catalog_only_truth": { "const": false },
    "allows_hidden_hosted_surface_boundary": { "const": false },
    "allows_generic_extension_badge_only": { "const": false }
  },
  "$defs": {
    "opaque_ref": { "type": "string", "minLength": 1, "maxLength": 256 },
    "reviewable_sentence": { "type": "string", "maxLength": 2048 },
    "runtime_class": {
      "enum": [
        "passive_package",
        "wasm_capability_sandbox",
        "declarative_host_rendered_view",
        "external_host",
        "compatibility_bridge",
        "remote_side_component"
      ]
    },
    "runtime_class_label": {
      "enum": [
        "Passive package",
        "Wasm capability sandbox",
        "Declarative/host-rendered view",
        "External host",
        "Compatibility bridge",
        "Remote-side component"
      ]
    },
    "execution_locus_class": {
      "enum": [
        "no_code_execution",
        "local_machine",
        "remote_target",
        "managed_host",
        "external_process",
        "browser_runtime"
      ]
    },
    "trust_tier_class": {
      "enum": [
        "verified_publisher",
        "enterprise_approved",
        "known_publisher",
        "community_unverified",
        "unsigned_local",
        "quarantined"
      ]
    },
    "signature_state_class": {
      "enum": [
        "signed_verified",
        "signed_unverified",
        "unsigned_local_dev",
        "unsigned_sideload",
        "revoked_signature"
      ]
    },
    "host_health_class": {
      "enum": [
        "healthy",
        "degraded",
        "host_missing",
        "restarting",
        "quarantined",
        "unavailable"
      ]
    },
    "inspector_action_class": {
      "enum": [
        "pause",
        "restart",
        "quarantine",
        "open_logs",
        "disable",
        "review_permissions",
        "revert",
        "migrate"
      ]
    },
    "downgraded_host_reason_class": {
      "enum": [
        "native_host_unavailable",
        "platform_runtime_unavailable",
        "policy_blocked_native_runtime",
        "host_crash_loop",
        "sandbox_incompatible",
        "remote_host_unreachable",
        "browser_content_required"
      ]
    },
    "hosted_surface_class": {
      "enum": [
        "extension_webview",
        "hosted_dashboard",
        "account_pane",
        "browser_runtime_bridge",
        "documentation_pane"
      ]
    },
    "open_in_browser_fallback_class": {
      "enum": [
        "available",
        "recommended_safer",
        "blocked_by_policy",
        "unavailable_offline",
        "not_applicable"
      ]
    },
    "authoring_flow_class": {
      "enum": [
        "local_dev_workspace",
        "sideload_review",
        "publish_preview"
      ]
    },
    "registry_binding_class": {
      "enum": [
        "public_registry",
        "approved_mirror",
        "offline_bundle",
        "stay_local",
        "bind_to_registry_later",
        "publish_preview_pending"
      ]
    },
    "consumer_surface_class": {
      "enum": [
        "marketplace_result_row",
        "marketplace_detail_page",
        "install_review",
        "active_ui_surface",
        "active_contribution_inspector",
        "diagnostics",
        "support_export",
        "hosted_surface_chrome",
        "local_dev_workspace",
        "sideload_review",
        "publish_preview",
        "docs_help_surface"
      ]
    },
    "stability_tier": {
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "claim_basis_class": {
      "enum": ["evidence_backed", "catalog_asserted_only"]
    },
    "support_claim_class": {
      "enum": [
        "stable_runtime_class_and_hosted_surface_truth_claim",
        "beta_runtime_class_and_hosted_surface_partial_claim",
        "preview_runtime_class_and_hosted_surface_experimental_claim",
        "withdrawn_no_runtime_class_or_hosted_surface_truth_claim"
      ]
    },
    "downgrade_reason": {
      "enum": [
        "catalog_only_truth_not_evidence_backed",
        "missing_required_consumer_surface",
        "runtime_class_unverified",
        "runtime_class_vocabulary_missing",
        "surface_truth_incomplete",
        "active_contribution_inspector_missing",
        "inspector_attribution_incomplete",
        "inspector_actions_incomplete",
        "downgraded_host_banner_missing",
        "downgraded_host_active",
        "hosted_surface_boundary_undisclosed",
        "hosted_surface_handoff_missing",
        "authoring_vocabulary_drift",
        "support_export_missing"
      ]
    },
    "runtime_class_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "package_id",
        "package_version",
        "publisher_or_signature_state",
        "runtime_class",
        "runtime_class_label",
        "runtime_class_verified",
        "execution_locus_class",
        "trust_tier_class",
        "host_boundary_summary",
        "permission_summary",
        "registry_binding_class"
      ],
      "properties": {
        "record_kind": { "const": "extension_runtime_class_disclosure" },
        "schema_version": { "const": 1 },
        "package_id": { "$ref": "#/$defs/opaque_ref" },
        "package_version": { "$ref": "#/$defs/opaque_ref" },
        "publisher_or_signature_state": { "$ref": "#/$defs/signature_state_class" },
        "runtime_class": { "$ref": "#/$defs/runtime_class" },
        "runtime_class_label": { "$ref": "#/$defs/runtime_class_label" },
        "runtime_class_verified": { "type": "boolean" },
        "execution_locus_class": { "$ref": "#/$defs/execution_locus_class" },
        "trust_tier_class": { "$ref": "#/$defs/trust_tier_class" },
        "host_boundary_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "permission_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "registry_binding_class": { "$ref": "#/$defs/registry_binding_class" },
        "downgraded_from_runtime_class": { "$ref": "#/$defs/runtime_class" }
      }
    },
    "active_contribution_inspector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "inspector_id",
        "surface_ref",
        "package_id",
        "package_version",
        "publisher_or_signature_state",
        "runtime_class",
        "runtime_class_label",
        "execution_locus_class",
        "trust_tier_class",
        "permissions_used_this_session",
        "current_host_health_class",
        "host_identity_ref",
        "recent_event_refs",
        "actions"
      ],
      "properties": {
        "record_kind": { "const": "extension_active_contribution_inspector" },
        "schema_version": { "const": 1 },
        "inspector_id": { "$ref": "#/$defs/opaque_ref" },
        "surface_ref": { "$ref": "#/$defs/opaque_ref" },
        "package_id": { "$ref": "#/$defs/opaque_ref" },
        "package_version": { "$ref": "#/$defs/opaque_ref" },
        "publisher_or_signature_state": { "$ref": "#/$defs/signature_state_class" },
        "runtime_class": { "$ref": "#/$defs/runtime_class" },
        "runtime_class_label": { "$ref": "#/$defs/runtime_class_label" },
        "execution_locus_class": { "$ref": "#/$defs/execution_locus_class" },
        "trust_tier_class": { "$ref": "#/$defs/trust_tier_class" },
        "permissions_used_this_session": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "current_host_health_class": { "$ref": "#/$defs/host_health_class" },
        "host_identity_ref": { "$ref": "#/$defs/opaque_ref" },
        "recent_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/inspector_action_class" }
        }
      }
    },
    "downgraded_host_banner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "banner_id",
        "package_id",
        "surface_ref",
        "previous_runtime_class",
        "previous_runtime_label",
        "current_runtime_class",
        "current_runtime_label",
        "reason_class",
        "feature_loss_summary",
        "recovery_choices",
        "migrate_choice_available",
        "revert_choice_available"
      ],
      "properties": {
        "record_kind": { "const": "extension_downgraded_host_banner" },
        "schema_version": { "const": 1 },
        "banner_id": { "$ref": "#/$defs/opaque_ref" },
        "package_id": { "$ref": "#/$defs/opaque_ref" },
        "surface_ref": { "$ref": "#/$defs/opaque_ref" },
        "previous_runtime_class": { "$ref": "#/$defs/runtime_class" },
        "previous_runtime_label": { "$ref": "#/$defs/runtime_class_label" },
        "current_runtime_class": { "$ref": "#/$defs/runtime_class" },
        "current_runtime_label": { "$ref": "#/$defs/runtime_class_label" },
        "reason_class": { "$ref": "#/$defs/downgraded_host_reason_class" },
        "feature_loss_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "recovery_choices": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_sentence" }
        },
        "migrate_choice_available": { "type": "boolean" },
        "revert_choice_available": { "type": "boolean" }
      }
    },
    "hosted_surface_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "surface_id",
        "hosted_surface_class",
        "owner_package_id",
        "publisher_or_signature_state",
        "origin_ref",
        "runtime_class",
        "runtime_class_label",
        "owner_origin_chrome_visible",
        "boundary_egress_summary",
        "storage_cookie_posture",
        "accessibility_note",
        "theming_note",
        "open_in_browser_fallback_class",
        "safer_external_handoff_available"
      ],
      "properties": {
        "record_kind": { "const": "extension_hosted_surface_boundary" },
        "schema_version": { "const": 1 },
        "surface_id": { "$ref": "#/$defs/opaque_ref" },
        "hosted_surface_class": { "$ref": "#/$defs/hosted_surface_class" },
        "owner_package_id": { "$ref": "#/$defs/opaque_ref" },
        "publisher_or_signature_state": { "$ref": "#/$defs/signature_state_class" },
        "origin_ref": { "$ref": "#/$defs/opaque_ref" },
        "runtime_class": { "$ref": "#/$defs/runtime_class" },
        "runtime_class_label": { "$ref": "#/$defs/runtime_class_label" },
        "owner_origin_chrome_visible": { "type": "boolean" },
        "boundary_egress_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "storage_cookie_posture": { "$ref": "#/$defs/reviewable_sentence" },
        "accessibility_note": { "$ref": "#/$defs/reviewable_sentence" },
        "theming_note": { "$ref": "#/$defs/reviewable_sentence" },
        "open_in_browser_fallback_class": { "$ref": "#/$defs/open_in_browser_fallback_class" },
        "safer_external_handoff_available": { "type": "boolean" }
      }
    },
    "authoring_flow_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "flow_id",
        "flow_class",
        "package_id",
        "runtime_class",
        "runtime_class_label",
        "permission_summary",
        "rollback_binding_ref",
        "registry_binding_class",
        "uses_public_package_vocabulary"
      ],
      "properties": {
        "record_kind": { "const": "extension_authoring_flow_disclosure" },
        "schema_version": { "const": 1 },
        "flow_id": { "$ref": "#/$defs/opaque_ref" },
        "flow_class": { "$ref": "#/$defs/authoring_flow_class" },
        "package_id": { "$ref": "#/$defs/opaque_ref" },
        "runtime_class": { "$ref": "#/$defs/runtime_class" },
        "runtime_class_label": { "$ref": "#/$defs/runtime_class_label" },
        "permission_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "rollback_binding_ref": { "$ref": "#/$defs/opaque_ref" },
        "registry_binding_class": { "$ref": "#/$defs/registry_binding_class" },
        "uses_public_package_vocabulary": { "type": "boolean" }
      }
    },
    "surface_truth_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "surface_class",
        "runtime_class_visible",
        "host_boundary_visible",
        "contribution_attribution_visible"
      ],
      "properties": {
        "record_kind": { "const": "extension_surface_truth_coverage" },
        "schema_version": { "const": 1 },
        "surface_class": { "$ref": "#/$defs/consumer_surface_class" },
        "runtime_class_visible": { "type": "boolean" },
        "host_boundary_visible": { "type": "boolean" },
        "contribution_attribution_visible": { "type": "boolean" }
      }
    },
    "runtime_class_truth_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "claimed_tier",
        "effective_tier",
        "claim_basis_class",
        "support_claim_class",
        "downgrade_reasons",
        "downgraded",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "extension_runtime_class_truth_claim" },
        "schema_version": { "const": 1 },
        "claimed_tier": { "$ref": "#/$defs/stability_tier" },
        "effective_tier": { "$ref": "#/$defs/stability_tier" },
        "claim_basis_class": { "$ref": "#/$defs/claim_basis_class" },
        "support_claim_class": { "$ref": "#/$defs/support_claim_class" },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason" }
        },
        "downgraded": { "type": "boolean" },
        "summary_label": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "runtime_class_truth_inspection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id_ref",
        "effective_tier",
        "required_consumers_present",
        "runtime_classes_verified",
        "active_inspectors_present",
        "inspector_attribution_complete",
        "inspector_actions_complete",
        "downgrade_banners_complete",
        "downgraded_host_active",
        "hosted_surface_boundaries_complete",
        "hosted_surface_handoffs_complete",
        "authoring_flows_use_public_vocabulary",
        "surface_coverage_complete",
        "runtime_disclosure_count",
        "active_inspector_count",
        "downgraded_banner_count",
        "hosted_surface_count"
      ],
      "properties": {
        "record_kind": { "const": "extension_runtime_class_truth_inspection" },
        "schema_version": { "const": 1 },
        "packet_id_ref": { "$ref": "#/$defs/opaque_ref" },
        "effective_tier": { "$ref": "#/$defs/stability_tier" },
        "required_consumers_present": { "type": "boolean" },
        "runtime_classes_verified": { "type": "boolean" },
        "active_inspectors_present": { "type": "boolean" },
        "inspector_attribution_complete": { "type": "boolean" },
        "inspector_actions_complete": { "type": "boolean" },
        "downgrade_banners_complete": { "type": "boolean" },
        "downgraded_host_active": { "type": "boolean" },
        "hosted_surface_boundaries_complete": { "type": "boolean" },
        "hosted_surface_handoffs_complete": { "type": "boolean" },
        "authoring_flows_use_public_vocabulary": { "type": "boolean" },
        "surface_coverage_complete": { "type": "boolean" },
        "runtime_disclosure_count": { "type": "integer", "minimum": 0 },
        "active_inspector_count": { "type": "integer", "minimum": 0 },
        "downgraded_banner_count": { "type": "integer", "minimum": 0 },
        "hosted_surface_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
