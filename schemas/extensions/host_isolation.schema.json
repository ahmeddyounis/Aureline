{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/host_isolation.schema.json",
  "title": "Aureline extension host isolation, restart budget, resource limit, and quarantine supervision contract",
  "description": "Cross-tool boundary schema for the extension host supervision lane. One record-kind binds the runtime v1 beta admission contract to the per-axis runtime-budget evidence, the restart-budget snapshot, the supervisor's response class, the visibility posture, the discovery-ranking posture, the maintainer-coverage posture, and the recovery precondition into one typed supervision decision that the install / review surface, the permission inspector, the runtime status pill, the support export, and the partner packet template read instead of inventing per-surface 'extension stopped working' chips. The Rust types in crates/aureline-extensions/src/supervision/ are the source of truth; this schema is the typed cross-tool boundary every non-owning surface reads. Both capability-bounded Wasm extensions and separately supervised external hosts resolve through the same record. Adding a new enum value or an additive optional field is additive-minor with an extension_host_supervision_schema_version bump; repurposing an existing value is breaking and requires a new decision row. Raw manifest bytes, raw signatures, raw policy bodies, raw paths, raw tokens, raw helper-binary invocation bodies, raw bridge-shim payloads, raw runtime payload bytes, raw memory snapshots, raw core dumps, raw log bodies, and raw network payload bytes MUST NOT appear in any record; records carry refs only.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/extension_host_supervision_record" },
    { "$ref": "#/$defs/extension_host_supervision_support_export_record" }
  ],
  "$defs": {
    "extension_host_supervision_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this supervision export. Current value is 1."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "extension_host_supervision_record",
        "extension_host_supervision_support_export_record"
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "host_placement_class": {
      "type": "string",
      "enum": [
        "wasm_in_process_isolated_world",
        "wasm_isolated_subprocess",
        "external_host_supervised_process",
        "helper_binary_short_lived",
        "remote_side_component_attached",
        "compatibility_bridge_translated",
        "unknown_placement_class"
      ]
    },
    "host_supervision_class": {
      "type": "string",
      "enum": [
        "in_process_capability_sandbox",
        "separate_subprocess_supervised",
        "separate_subprocess_helper_kill_switch",
        "remote_agent_attached_envelope",
        "compatibility_bridge_translated_supervision",
        "unknown_supervision_class"
      ]
    },
    "runtime_lifecycle_state_class": {
      "type": "string",
      "enum": [
        "discovered",
        "installed",
        "disabled",
        "pending_activation",
        "active",
        "degraded",
        "quarantined",
        "recovered",
        "removed",
        "publisher_blocked"
      ]
    },
    "restart_posture_class": {
      "type": "string",
      "enum": [
        "no_restart_attempted",
        "one_warm_restart_under_budget",
        "exponential_backoff_bounded"
      ]
    },
    "degraded_state_class": {
      "type": "string",
      "enum": [
        "none_nominal",
        "throttled_background_work",
        "disabled_until_next_session",
        "disabled_until_user_explicit_reenable",
        "quarantined_pending_review",
        "publisher_blocked"
      ]
    },
    "supervision_axis_class": {
      "type": "string",
      "enum": [
        "discovery",
        "cold_activation",
        "warm_activation",
        "idle_polling",
        "memory",
        "egress",
        "crash_loop"
      ]
    },
    "budget_pressure_class": {
      "type": "string",
      "enum": [
        "nominal",
        "soft_breach",
        "hard_breach",
        "crash_loop_window_breach",
        "not_applicable"
      ]
    },
    "supervision_response_class": {
      "type": "string",
      "enum": [
        "none_nominal",
        "throttle_background_work",
        "disable_until_next_session",
        "disable_until_user_explicit_reenable",
        "quarantine"
      ]
    },
    "visibility_posture_class": {
      "type": "string",
      "enum": [
        "not_visible_nominal_row",
        "runtime_status_pill_only",
        "install_review_and_permission_inspector",
        "install_review_and_runtime_status_pill",
        "permission_inspector_and_runtime_status_pill",
        "install_review_and_permission_inspector_and_runtime_status_pill"
      ]
    },
    "discovery_ranking_posture_class": {
      "type": "string",
      "enum": [
        "unchanged_still_user_installable",
        "demoted_fair_ranked_with_visible_warning",
        "suppress_installed_in_many_workspaces_signal",
        "removed_from_ranking"
      ]
    },
    "maintainer_coverage_class": {
      "type": "string",
      "enum": [
        "not_required",
        "required_quorum_recorded",
        "required_quorum_missing"
      ]
    },
    "recovery_precondition_class": {
      "type": "string",
      "enum": [
        "none_not_recovering",
        "resource_governor_returned_to_nominal",
        "efficiency_state_returned_to_nominal_or_recovery",
        "admin_policy_cleared_quarantine",
        "publisher_continuity_row_cleared",
        "user_explicit_reenable",
        "next_session_cold_start",
        "crash_loop_window_cleared_without_breach"
      ]
    },
    "recovery_visible_projection_class": {
      "type": "string",
      "enum": ["not_recovering", "warming", "partial", "ready"]
    },
    "supervision_decision_class": {
      "type": "string",
      "enum": [
        "continue_admitted",
        "throttle_background_work",
        "disable_until_next_session",
        "disable_until_user_explicit_reenable",
        "quarantine_pending_review",
        "hold_publisher_blocked",
        "recovery_in_progress",
        "refuse_inconsistent_input"
      ]
    },
    "supervision_reason_class": {
      "type": "string",
      "enum": [
        "nominal_under_budget",
        "sustained_soft_breach_throttles_background",
        "idle_polling_hard_breach_disables_until_next_session",
        "memory_hard_cap_breach_disables_until_next_session",
        "egress_hard_breach_requires_user_reenable",
        "crash_loop_window_breach_trips_quarantine",
        "runtime_budget_quarantine_active",
        "publisher_block_active",
        "recovery_in_progress_returning_to_nominal",
        "refused_runtime_contract_not_admitted",
        "refused_maintainer_coverage_missing_on_quorum_decision",
        "refused_axis_pressure_inconsistent_with_response",
        "refused_quarantine_without_trigger_rule",
        "refused_response_visibility_missing_from_user_surfaces",
        "refused_quarantine_without_discovery_removal"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": ["metadata_safe_default"]
    },
    "axis_budget_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axis_class", "pressure_class"],
      "properties": {
        "axis_class": { "$ref": "#/$defs/supervision_axis_class" },
        "pressure_class": { "$ref": "#/$defs/budget_pressure_class" }
      }
    },
    "restart_budget_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "restart_posture_class",
        "attempts_used",
        "attempts_remaining",
        "crash_loop_window_distinct_failures",
        "crash_loop_trip_disable_threshold",
        "crash_loop_trip_quarantine_threshold"
      ],
      "properties": {
        "restart_posture_class": { "$ref": "#/$defs/restart_posture_class" },
        "attempts_used": { "type": "integer", "minimum": 0 },
        "attempts_remaining": { "type": "integer", "minimum": 0 },
        "crash_loop_window_distinct_failures": { "type": "integer", "minimum": 0 },
        "crash_loop_trip_disable_threshold": { "type": "integer", "minimum": 0 },
        "crash_loop_trip_quarantine_threshold": { "type": "integer", "minimum": 0 }
      }
    },
    "extension_host_supervision_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "extension_host_supervision_schema_version",
        "supervision_id",
        "contract_ref",
        "extension_identity_ref",
        "extension_version",
        "host_placement_class",
        "host_supervision_class",
        "lifecycle_state_class",
        "restart_posture_class",
        "restart_attempt_count",
        "degraded_state_class",
        "axis_budget_entries",
        "restart_budget",
        "response_class",
        "visibility_posture_class",
        "discovery_ranking_posture_class",
        "maintainer_coverage_class",
        "recovery_precondition_class",
        "recovery_visible_projection_class",
        "trigger_rule_ref",
        "paired_audit_event_refs",
        "repair_affordance_label",
        "supervision_decision_class",
        "supervision_reason_class",
        "supervision_summary",
        "blocks_activation",
        "decided_at",
        "redaction_class"
      ],
      "properties": {
        "record_kind": { "const": "extension_host_supervision_record" },
        "extension_host_supervision_schema_version": {
          "$ref": "#/$defs/extension_host_supervision_schema_version"
        },
        "supervision_id": { "type": "string", "pattern": "^supervision:.+" },
        "contract_ref": { "type": "string", "pattern": "^runtime_v1_beta:.+" },
        "extension_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "extension_version": { "type": "string", "minLength": 1 },
        "host_placement_class": { "$ref": "#/$defs/host_placement_class" },
        "host_supervision_class": { "$ref": "#/$defs/host_supervision_class" },
        "lifecycle_state_class": { "$ref": "#/$defs/runtime_lifecycle_state_class" },
        "restart_posture_class": { "$ref": "#/$defs/restart_posture_class" },
        "restart_attempt_count": { "type": "integer", "minimum": 0 },
        "degraded_state_class": { "$ref": "#/$defs/degraded_state_class" },
        "axis_budget_entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/axis_budget_entry" }
        },
        "restart_budget": { "$ref": "#/$defs/restart_budget_snapshot" },
        "response_class": { "$ref": "#/$defs/supervision_response_class" },
        "visibility_posture_class": { "$ref": "#/$defs/visibility_posture_class" },
        "discovery_ranking_posture_class": { "$ref": "#/$defs/discovery_ranking_posture_class" },
        "maintainer_coverage_class": { "$ref": "#/$defs/maintainer_coverage_class" },
        "recovery_precondition_class": { "$ref": "#/$defs/recovery_precondition_class" },
        "recovery_visible_projection_class": {
          "$ref": "#/$defs/recovery_visible_projection_class"
        },
        "trigger_rule_ref": {
          "type": ["string", "null"],
          "pattern": "^quarantine_rule:.+"
        },
        "paired_audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "repair_affordance_label": { "type": "string", "minLength": 1 },
        "supervision_decision_class": { "$ref": "#/$defs/supervision_decision_class" },
        "supervision_reason_class": { "$ref": "#/$defs/supervision_reason_class" },
        "supervision_summary": { "type": "string", "minLength": 1 },
        "blocks_activation": { "type": "boolean" },
        "decided_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    },
    "extension_host_supervision_support_export_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "extension_host_supervision_schema_version",
        "export_id",
        "supervision_ref",
        "contract_ref",
        "extension_identity_ref",
        "extension_version",
        "host_placement_class",
        "host_supervision_class",
        "lifecycle_state_class",
        "restart_posture_class",
        "restart_attempt_count",
        "restart_attempts_remaining",
        "crash_loop_window_distinct_failures",
        "degraded_state_class",
        "worst_axis_class",
        "worst_axis_pressure_class",
        "response_class",
        "visibility_posture_class",
        "discovery_ranking_posture_class",
        "maintainer_coverage_class",
        "recovery_precondition_class",
        "recovery_visible_projection_class",
        "trigger_rule_ref",
        "repair_affordance_label",
        "supervision_decision_class",
        "supervision_reason_class",
        "blocks_activation",
        "export_safe_summary",
        "redaction_class"
      ],
      "properties": {
        "record_kind": { "const": "extension_host_supervision_support_export_record" },
        "extension_host_supervision_schema_version": {
          "$ref": "#/$defs/extension_host_supervision_schema_version"
        },
        "export_id": {
          "type": "string",
          "pattern": "^extension_host_supervision_support_export:.+"
        },
        "supervision_ref": { "type": "string", "pattern": "^supervision:.+" },
        "contract_ref": { "type": "string", "pattern": "^runtime_v1_beta:.+" },
        "extension_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "extension_version": { "type": "string", "minLength": 1 },
        "host_placement_class": { "$ref": "#/$defs/host_placement_class" },
        "host_supervision_class": { "$ref": "#/$defs/host_supervision_class" },
        "lifecycle_state_class": { "$ref": "#/$defs/runtime_lifecycle_state_class" },
        "restart_posture_class": { "$ref": "#/$defs/restart_posture_class" },
        "restart_attempt_count": { "type": "integer", "minimum": 0 },
        "restart_attempts_remaining": { "type": "integer", "minimum": 0 },
        "crash_loop_window_distinct_failures": { "type": "integer", "minimum": 0 },
        "degraded_state_class": { "$ref": "#/$defs/degraded_state_class" },
        "worst_axis_class": {
          "oneOf": [
            { "$ref": "#/$defs/supervision_axis_class" },
            { "type": "null" }
          ]
        },
        "worst_axis_pressure_class": { "$ref": "#/$defs/budget_pressure_class" },
        "response_class": { "$ref": "#/$defs/supervision_response_class" },
        "visibility_posture_class": { "$ref": "#/$defs/visibility_posture_class" },
        "discovery_ranking_posture_class": { "$ref": "#/$defs/discovery_ranking_posture_class" },
        "maintainer_coverage_class": { "$ref": "#/$defs/maintainer_coverage_class" },
        "recovery_precondition_class": { "$ref": "#/$defs/recovery_precondition_class" },
        "recovery_visible_projection_class": {
          "$ref": "#/$defs/recovery_visible_projection_class"
        },
        "trigger_rule_ref": {
          "type": ["string", "null"],
          "pattern": "^quarantine_rule:.+"
        },
        "repair_affordance_label": { "type": "string", "minLength": 1 },
        "supervision_decision_class": { "$ref": "#/$defs/supervision_decision_class" },
        "supervision_reason_class": { "$ref": "#/$defs/supervision_reason_class" },
        "blocks_activation": { "type": "boolean" },
        "export_safe_summary": { "type": "string", "minLength": 1 },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    }
  }
}
