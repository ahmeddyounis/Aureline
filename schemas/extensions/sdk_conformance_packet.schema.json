{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/sdk_conformance_packet.schema.json",
  "title": "Aureline SDK conformance packet (beta lane)",
  "description": "Cross-tool boundary schema for the per-SDK/runtime-line conformance packet. One packet binds the validator-suite report, sample-pack starter-pack outcome, lifecycle/deprecation metadata, docs-freshness findings, and bridge-compatibility scorecard refs into one inspectable record so claimed beta ecosystem rows can cite a checked-in conformance packet instead of pointing only to the validator source tree. Records carry refs only; raw stack frames, raw test outputs, raw signing-key material, raw policy bodies, and raw artifact bytes MUST NOT appear. Adding a new enum member or an additive optional field is additive-minor with an sdk_conformance_packet_schema_version bump; repurposing an existing member is breaking.",
  "type": "object",
  "$ref": "#/$defs/sdk_conformance_packet_record",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "redaction_class": {
      "type": "string",
      "const": "metadata_safe_default"
    },
    "release_channel_scope": {
      "type": "string",
      "enum": ["beta", "stable"]
    },
    "decision_class": {
      "type": "string",
      "enum": [
        "ready_for_authors",
        "partially_ready_preview_surfaces_only",
        "refused_inconsistent_input"
      ]
    },
    "reason_class": {
      "type": "string",
      "enum": [
        "all_claimed_surfaces_available_in_beta",
        "some_claimed_surfaces_preview_in_beta",
        "validator_suite_failed",
        "sample_pack_refused",
        "lifecycle_metadata_packet_failed",
        "docs_freshness_drift_detected",
        "bridge_matrix_widens_native_claim",
        "bridge_matrix_missing_required_state",
        "lifecycle_metadata_missing_required_surface"
      ]
    },
    "freshness_check_class": {
      "type": "string",
      "enum": [
        "sdk_line_semver_token",
        "lifecycle_metadata_packet_ref",
        "bridge_matrix_id",
        "bridge_matrix_path",
        "versioning_policy_ref",
        "deprecation_packet_template_ref",
        "conformance_kit_report_ref",
        "sample_pack_starter_pack_ref",
        "consuming_surface_ref"
      ]
    },
    "freshness_finding_status": {
      "type": "string",
      "enum": ["cite_present", "cite_missing", "drifted"]
    },
    "scorecard_class": {
      "type": "string",
      "enum": [
        "native_green",
        "bridge_amber",
        "shimmed_amber",
        "partial_amber",
        "unsupported_red"
      ]
    },
    "bridge_state_class": {
      "type": "string",
      "enum": ["native", "bridge", "shimmed", "partial", "unsupported"]
    },
    "validator_result_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suite_result_class",
        "case_count",
        "matched_expectation_count",
        "aggregate_blocker_count",
        "required_scenario_classes",
        "observed_scenario_classes",
        "unexpected_results"
      ],
      "properties": {
        "suite_result_class": {
          "type": "string",
          "enum": ["pass", "warn", "fail"]
        },
        "case_count": {
          "type": "integer",
          "minimum": 0
        },
        "matched_expectation_count": {
          "type": "integer",
          "minimum": 0
        },
        "aggregate_blocker_count": {
          "type": "integer",
          "minimum": 0
        },
        "required_scenario_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "observed_scenario_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "unexpected_results": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "sample_pack_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "starter_pack_id",
        "decision_class",
        "reason_class",
        "claimed_api_surface_count",
        "available_in_beta_surface_count",
        "preview_in_beta_surface_count",
        "wasm_sample_count",
        "external_host_sample_count",
        "authoring_guide_count"
      ],
      "properties": {
        "starter_pack_id": { "$ref": "#/$defs/non_empty_string" },
        "decision_class": { "$ref": "#/$defs/non_empty_string" },
        "reason_class": { "$ref": "#/$defs/non_empty_string" },
        "claimed_api_surface_count": { "type": "integer", "minimum": 0 },
        "available_in_beta_surface_count": { "type": "integer", "minimum": 0 },
        "preview_in_beta_surface_count": { "type": "integer", "minimum": 0 },
        "wasm_sample_count": { "type": "integer", "minimum": 0 },
        "external_host_sample_count": { "type": "integer", "minimum": 0 },
        "authoring_guide_count": { "type": "integer", "minimum": 0 }
      }
    },
    "lifecycle_metadata_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "policy_ref",
        "row_count",
        "deprecated_row_count",
        "beta_or_stable_row_count",
        "decision_class",
        "reason_class"
      ],
      "properties": {
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "policy_ref": { "$ref": "#/$defs/non_empty_string" },
        "row_count": { "type": "integer", "minimum": 0 },
        "deprecated_row_count": { "type": "integer", "minimum": 0 },
        "beta_or_stable_row_count": { "type": "integer", "minimum": 0 },
        "decision_class": { "$ref": "#/$defs/non_empty_string" },
        "reason_class": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "docs_freshness_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "doc_ref",
        "check_class",
        "required_token",
        "status",
        "message"
      ],
      "properties": {
        "doc_ref": { "$ref": "#/$defs/non_empty_string" },
        "check_class": { "$ref": "#/$defs/freshness_check_class" },
        "required_token": { "$ref": "#/$defs/non_empty_string" },
        "status": { "$ref": "#/$defs/freshness_finding_status" },
        "message": { "$ref": "#/$defs/non_empty_string" },
        "fix": { "type": ["string", "null"] }
      }
    },
    "bridge_lane_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "lane_label",
        "package_or_lane_id",
        "bridge_state_class",
        "compatibility_label",
        "parity_claim_class",
        "scorecard_class",
        "support_class",
        "native_runtime_check_class",
        "compatibility_bridge_check_class",
        "known_limits",
        "non_green_reasons",
        "lifecycle_row_refs",
        "consuming_surface_refs"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_label": { "$ref": "#/$defs/non_empty_string" },
        "package_or_lane_id": { "$ref": "#/$defs/non_empty_string" },
        "bridge_state_class": { "$ref": "#/$defs/bridge_state_class" },
        "compatibility_label": { "$ref": "#/$defs/non_empty_string" },
        "parity_claim_class": { "$ref": "#/$defs/non_empty_string" },
        "scorecard_class": { "$ref": "#/$defs/scorecard_class" },
        "support_class": { "$ref": "#/$defs/non_empty_string" },
        "native_runtime_check_class": {
          "type": "string",
          "enum": [
            "native_supported",
            "native_not_applicable",
            "native_unsupported"
          ]
        },
        "compatibility_bridge_check_class": {
          "type": "string",
          "enum": [
            "bridge_not_applicable",
            "bridge_translated_with_caveats",
            "bridge_shimmed_static_only",
            "bridge_partial_subset_documented",
            "bridge_unsupported"
          ]
        },
        "known_limits": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "non_green_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "lifecycle_row_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "consuming_surface_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "sdk_conformance_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "sdk_conformance_packet_schema_version",
        "packet_id",
        "sdk_line_id",
        "sdk_line_semver",
        "release_channel_scope",
        "as_of",
        "generated_at",
        "decision_class",
        "reason_class",
        "validator_report_ref",
        "validator_result_summary",
        "sample_pack_record_ref",
        "sample_pack_summary",
        "lifecycle_metadata_packet_ref",
        "lifecycle_metadata_summary",
        "bridge_matrix_ref",
        "bridge_compatibility_scorecard_ref",
        "docs_freshness_findings",
        "bridge_lane_summaries",
        "non_green_reasons",
        "known_caveats",
        "consuming_surfaces",
        "redaction_class"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "sdk_conformance_packet"
        },
        "sdk_conformance_packet_schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": {
          "type": "string",
          "pattern": "^sdk_conformance_packet:"
        },
        "sdk_line_id": {
          "type": "string",
          "pattern": "^aureline\\.sdk\\.[a-z][a-z0-9-]*[a-z0-9]$"
        },
        "sdk_line_semver": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
        },
        "release_channel_scope": { "$ref": "#/$defs/release_channel_scope" },
        "as_of": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "owner": { "$ref": "#/$defs/non_empty_string" },
        "decision_class": { "$ref": "#/$defs/decision_class" },
        "reason_class": { "$ref": "#/$defs/reason_class" },
        "validator_report_ref": { "$ref": "#/$defs/non_empty_string" },
        "validator_result_summary": { "$ref": "#/$defs/validator_result_summary" },
        "sample_pack_record_ref": { "$ref": "#/$defs/non_empty_string" },
        "sample_pack_summary": { "$ref": "#/$defs/sample_pack_summary" },
        "lifecycle_metadata_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "lifecycle_metadata_summary": { "$ref": "#/$defs/lifecycle_metadata_summary" },
        "bridge_matrix_ref": { "$ref": "#/$defs/non_empty_string" },
        "bridge_compatibility_scorecard_ref": { "$ref": "#/$defs/non_empty_string" },
        "docs_freshness_findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/docs_freshness_finding" }
        },
        "bridge_lane_summaries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bridge_lane_summary" }
        },
        "non_green_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "known_caveats": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "consuming_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      },
      "allOf": [
        {
          "description": "ready_for_authors requires all_claimed_surfaces_available_in_beta and an empty non_green_reasons list.",
          "if": {
            "properties": { "decision_class": { "const": "ready_for_authors" } },
            "required": ["decision_class"]
          },
          "then": {
            "properties": {
              "reason_class": { "const": "all_claimed_surfaces_available_in_beta" },
              "non_green_reasons": { "maxItems": 0 }
            }
          }
        },
        {
          "description": "partially_ready_preview_surfaces_only requires some_claimed_surfaces_preview_in_beta.",
          "if": {
            "properties": { "decision_class": { "const": "partially_ready_preview_surfaces_only" } },
            "required": ["decision_class"]
          },
          "then": {
            "properties": {
              "reason_class": { "const": "some_claimed_surfaces_preview_in_beta" }
            }
          }
        },
        {
          "description": "refused_inconsistent_input requires at least one non_green_reasons entry and a refused reason class.",
          "if": {
            "properties": { "decision_class": { "const": "refused_inconsistent_input" } },
            "required": ["decision_class"]
          },
          "then": {
            "properties": {
              "non_green_reasons": { "minItems": 1 },
              "reason_class": {
                "enum": [
                  "validator_suite_failed",
                  "sample_pack_refused",
                  "lifecycle_metadata_packet_failed",
                  "docs_freshness_drift_detected",
                  "bridge_matrix_widens_native_claim",
                  "bridge_matrix_missing_required_state",
                  "lifecycle_metadata_missing_required_surface"
                ]
              }
            }
          }
        }
      ]
    }
  }
}
