{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/publication_pipeline.schema.json",
  "title": "Aureline extension publication pipeline record",
  "description": "Cross-tool boundary schema for extension publication packets. A packet binds version metadata, artifact content address, signer metadata, provenance, compatibility, monotone channel promotion, rollback plan, and catalog transaction guards so registry, mirror, support, and headless surfaces read one publication truth. Raw artifact bytes, raw signing-key material, raw credentials, raw URLs, and raw attestation bodies must not appear in this record.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/extension_publication_pipeline_record" },
    { "$ref": "#/$defs/extension_publication_support_export_record" }
  ],
  "$defs": {
    "extension_publication_schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "opaque_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "redaction_class": {
      "type": "string",
      "const": "metadata_safe_default"
    },
    "content_address": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest_algorithm", "digest_hex", "digest_size_bytes"],
      "properties": {
        "digest_algorithm": {
          "type": "string",
          "enum": ["sha256", "sha384", "sha512", "blake3"]
        },
        "digest_hex": {
          "type": "string",
          "pattern": "^[0-9a-f]+$",
          "minLength": 32
        },
        "digest_size_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "signature_class": {
      "type": "string",
      "enum": [
        "publisher_signature",
        "attestation_bundle",
        "dual_signed_publisher_and_attestation",
        "unsigned_denied_on_policy"
      ]
    },
    "provenance_class": {
      "type": "string",
      "enum": [
        "verified_build_provenance",
        "publisher_asserted_provenance",
        "missing_provenance"
      ]
    },
    "channel_class": {
      "type": "string",
      "enum": ["quarantine", "approved", "production"]
    },
    "transaction_write_class": {
      "type": "string",
      "enum": ["atomic_catalog_swap", "dry_run_only", "unsafe_partial_writes"]
    },
    "decision_class": {
      "type": "string",
      "enum": ["ready_for_promotion", "held_for_review", "refused"]
    },
    "reason_class": {
      "type": "string",
      "enum": [
        "ready_signed_provenance_rollback_safe",
        "held_no_production_promotion_requested",
        "refused_publication_id_unprefixed",
        "refused_version_metadata_missing",
        "refused_artifact_metadata_missing",
        "refused_signer_missing",
        "refused_unsigned_artifact",
        "refused_provenance_missing",
        "refused_compatibility_missing",
        "refused_promotion_identity_mutation",
        "refused_promotion_evidence_missing",
        "refused_rollback_target_missing",
        "refused_transactional_write_guard_missing",
        "refused_orphaned_revocation_state",
        "refused_redaction_class_not_metadata_safe"
      ]
    },
    "version_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "extension_identity",
        "package_id",
        "publisher_id",
        "extension_version",
        "manifest_schema_version",
        "sdk_line_id",
        "sdk_line_semver",
        "aureline_version_min",
        "aureline_version_max",
        "support_class",
        "bridge_state"
      ],
      "properties": {
        "extension_identity": { "$ref": "#/$defs/non_empty_string" },
        "package_id": { "$ref": "#/$defs/non_empty_string" },
        "publisher_id": { "$ref": "#/$defs/non_empty_string" },
        "extension_version": { "$ref": "#/$defs/non_empty_string" },
        "manifest_schema_version": { "type": "integer", "minimum": 1 },
        "sdk_line_id": { "$ref": "#/$defs/non_empty_string" },
        "sdk_line_semver": { "$ref": "#/$defs/non_empty_string" },
        "aureline_version_min": { "$ref": "#/$defs/non_empty_string" },
        "aureline_version_max": { "$ref": "#/$defs/non_empty_string" },
        "support_class": { "$ref": "#/$defs/non_empty_string" },
        "bridge_state": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "artifact_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_ref",
        "extension_identity",
        "extension_version",
        "content_address",
        "registry_manifest_ref",
        "permission_manifest_ref",
        "runtime_contract_ref"
      ],
      "properties": {
        "artifact_ref": { "$ref": "#/$defs/opaque_id" },
        "extension_identity": { "$ref": "#/$defs/non_empty_string" },
        "extension_version": { "$ref": "#/$defs/non_empty_string" },
        "content_address": { "$ref": "#/$defs/content_address" },
        "registry_manifest_ref": { "$ref": "#/$defs/opaque_id" },
        "permission_manifest_ref": { "$ref": "#/$defs/opaque_id" },
        "runtime_contract_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "signer_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signer_ref",
        "signer_key_fingerprint",
        "signature_ref",
        "signature_class",
        "signed_content_address",
        "signed_at"
      ],
      "properties": {
        "signer_ref": { "$ref": "#/$defs/opaque_id" },
        "signer_key_fingerprint": { "$ref": "#/$defs/non_empty_string" },
        "signature_ref": { "$ref": "#/$defs/opaque_id" },
        "signature_class": { "$ref": "#/$defs/signature_class" },
        "transparency_log_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_id" }]
        },
        "signed_content_address": { "$ref": "#/$defs/content_address" },
        "signed_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "provenance_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provenance_ref",
        "provenance_class",
        "builder_id",
        "source_manifest_ref",
        "source_revision_ref",
        "build_run_ref",
        "conformance_report_ref",
        "sdk_release_bundle_ref",
        "subject_content_address",
        "generated_at"
      ],
      "properties": {
        "provenance_ref": { "$ref": "#/$defs/opaque_id" },
        "provenance_class": { "$ref": "#/$defs/provenance_class" },
        "builder_id": { "$ref": "#/$defs/opaque_id" },
        "source_manifest_ref": { "$ref": "#/$defs/opaque_id" },
        "source_revision_ref": { "$ref": "#/$defs/non_empty_string" },
        "build_run_ref": { "$ref": "#/$defs/opaque_id" },
        "conformance_report_ref": { "$ref": "#/$defs/opaque_id" },
        "sdk_release_bundle_ref": { "$ref": "#/$defs/opaque_id" },
        "subject_content_address": { "$ref": "#/$defs/content_address" },
        "generated_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "compatibility_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compatibility_report_ref",
        "bridge_matrix_ref",
        "bridge_matrix_row_ref",
        "host_contract_family_refs",
        "capability_world_refs",
        "target_platforms",
        "support_class",
        "bridge_state"
      ],
      "properties": {
        "compatibility_report_ref": { "$ref": "#/$defs/opaque_id" },
        "bridge_matrix_ref": { "$ref": "#/$defs/non_empty_string" },
        "bridge_matrix_row_ref": {
          "type": "string",
          "pattern": "^extension_bridge_row:"
        },
        "host_contract_family_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "capability_world_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "target_platforms": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "support_class": { "$ref": "#/$defs/non_empty_string" },
        "bridge_state": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "promotion_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_step_id",
        "registry_manifest_ref",
        "source_channel_class",
        "target_channel_class",
        "subject_content_address",
        "subject_signature_ref",
        "preserves_artifact_identity",
        "required_evidence_refs",
        "approver_refs"
      ],
      "properties": {
        "promotion_step_id": { "$ref": "#/$defs/opaque_id" },
        "registry_manifest_ref": { "$ref": "#/$defs/opaque_id" },
        "source_channel_class": { "$ref": "#/$defs/channel_class" },
        "target_channel_class": { "$ref": "#/$defs/channel_class" },
        "subject_content_address": { "$ref": "#/$defs/content_address" },
        "subject_signature_ref": { "$ref": "#/$defs/opaque_id" },
        "preserves_artifact_identity": { "type": "boolean", "const": true },
        "required_evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "approver_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      }
    },
    "rollback_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rollback_plan_id",
        "previous_extension_version",
        "previous_registry_manifest_ref",
        "previous_content_address",
        "rollback_manifest_ref",
        "preserves_prior_installable_artifact",
        "rollback_does_not_delete_prior_artifact"
      ],
      "properties": {
        "rollback_plan_id": { "$ref": "#/$defs/opaque_id" },
        "previous_extension_version": { "$ref": "#/$defs/non_empty_string" },
        "previous_registry_manifest_ref": { "$ref": "#/$defs/opaque_id" },
        "previous_content_address": { "$ref": "#/$defs/content_address" },
        "rollback_manifest_ref": { "$ref": "#/$defs/opaque_id" },
        "preserves_prior_installable_artifact": { "type": "boolean", "const": true },
        "rollback_does_not_delete_prior_artifact": { "type": "boolean", "const": true }
      }
    },
    "failure_atomicity_guard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "staging_catalog_ref",
        "target_catalog_ref",
        "transaction_write_class",
        "writes_catalog_after_artifacts_verified",
        "revocation_state_requires_catalog_commit",
        "orphaned_revocation_state_count",
        "retry_idempotency_key"
      ],
      "properties": {
        "staging_catalog_ref": { "$ref": "#/$defs/opaque_id" },
        "target_catalog_ref": { "$ref": "#/$defs/opaque_id" },
        "transaction_write_class": { "$ref": "#/$defs/transaction_write_class" },
        "writes_catalog_after_artifacts_verified": { "type": "boolean", "const": true },
        "revocation_state_requires_catalog_commit": { "type": "boolean", "const": true },
        "orphaned_revocation_state_count": { "type": "integer", "const": 0 },
        "retry_idempotency_key": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "extension_publication_pipeline_input": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "publication_id",
        "version_metadata",
        "artifact_metadata",
        "signer_metadata",
        "provenance_metadata",
        "compatibility_metadata",
        "promotion_steps",
        "rollback_plan",
        "failure_atomicity_guard",
        "generated_at"
      ],
      "properties": {
        "publication_id": {
          "type": "string",
          "pattern": "^extension_publication:"
        },
        "version_metadata": { "$ref": "#/$defs/version_metadata" },
        "artifact_metadata": { "$ref": "#/$defs/artifact_metadata" },
        "signer_metadata": { "$ref": "#/$defs/signer_metadata" },
        "provenance_metadata": { "$ref": "#/$defs/provenance_metadata" },
        "compatibility_metadata": { "$ref": "#/$defs/compatibility_metadata" },
        "promotion_steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/promotion_step" }
        },
        "rollback_plan": { "$ref": "#/$defs/rollback_plan" },
        "failure_atomicity_guard": { "$ref": "#/$defs/failure_atomicity_guard" },
        "generated_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "extension_publication_pipeline_record": {
      "allOf": [
        { "$ref": "#/$defs/extension_publication_pipeline_input" },
        {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "record_kind",
            "extension_publication_schema_version",
            "promotion_step_count",
            "required_evidence_ref_count",
            "approver_ref_count",
            "preserves_prior_installable_artifact",
            "transactional_catalog_update",
            "decision_class",
            "reason_class",
            "decision_summary",
            "redaction_class"
          ],
          "properties": {
            "record_kind": {
              "type": "string",
              "const": "extension_publication_pipeline_record"
            },
            "extension_publication_schema_version": { "$ref": "#/$defs/extension_publication_schema_version" },
            "promotion_step_count": { "type": "integer", "minimum": 0 },
            "required_evidence_ref_count": { "type": "integer", "minimum": 0 },
            "approver_ref_count": { "type": "integer", "minimum": 0 },
            "preserves_prior_installable_artifact": { "type": "boolean" },
            "transactional_catalog_update": { "type": "boolean" },
            "decision_class": { "$ref": "#/$defs/decision_class" },
            "reason_class": { "$ref": "#/$defs/reason_class" },
            "decision_summary": { "$ref": "#/$defs/non_empty_string" },
            "redaction_class": { "$ref": "#/$defs/redaction_class" }
          }
        }
      ]
    },
    "extension_publication_support_export_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "extension_publication_schema_version",
        "export_id",
        "publication_ref",
        "extension_identity",
        "extension_version",
        "artifact_ref",
        "registry_manifest_ref",
        "signature_ref",
        "provenance_ref",
        "compatibility_report_ref",
        "bridge_matrix_ref",
        "bridge_matrix_row_ref",
        "rollback_manifest_ref",
        "decision_class",
        "reason_class",
        "blocks_catalog_mutation",
        "rollback_available",
        "transactional_catalog_update",
        "export_safe_summary",
        "redaction_class"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "extension_publication_support_export_record"
        },
        "extension_publication_schema_version": { "$ref": "#/$defs/extension_publication_schema_version" },
        "export_id": {
          "type": "string",
          "pattern": "^extension_publication_support_export:"
        },
        "publication_ref": {
          "type": "string",
          "pattern": "^extension_publication:"
        },
        "extension_identity": { "$ref": "#/$defs/non_empty_string" },
        "extension_version": { "$ref": "#/$defs/non_empty_string" },
        "artifact_ref": { "$ref": "#/$defs/opaque_id" },
        "registry_manifest_ref": { "$ref": "#/$defs/opaque_id" },
        "signature_ref": { "$ref": "#/$defs/opaque_id" },
        "provenance_ref": { "$ref": "#/$defs/opaque_id" },
        "compatibility_report_ref": { "$ref": "#/$defs/opaque_id" },
        "bridge_matrix_ref": { "$ref": "#/$defs/non_empty_string" },
        "bridge_matrix_row_ref": {
          "type": "string",
          "pattern": "^extension_bridge_row:"
        },
        "rollback_manifest_ref": { "$ref": "#/$defs/opaque_id" },
        "decision_class": { "$ref": "#/$defs/decision_class" },
        "reason_class": { "$ref": "#/$defs/reason_class" },
        "blocks_catalog_mutation": { "type": "boolean" },
        "rollback_available": { "type": "boolean" },
        "transactional_catalog_update": { "type": "boolean" },
        "export_safe_summary": { "$ref": "#/$defs/non_empty_string" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    }
  }
}
