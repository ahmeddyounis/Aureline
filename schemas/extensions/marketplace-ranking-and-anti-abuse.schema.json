{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/marketplace-ranking-and-anti-abuse.schema.json",
  "title": "Aureline marketplace ranking and anti-abuse packet",
  "description": "Canonical stable-line packet for marketplace discovery ranking, anti-abuse controls, verified-publisher tiers, quarantine/revocation state, enterprise curation flows, transparency actions, and support/export projection. The Rust module crates/aureline-extensions/src/stabilize_marketplace_discovery_ranking_and_anti_abuse is the source of truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "schema_ref",
    "identity",
    "publisher",
    "ranking_signals",
    "anti_abuse_controls",
    "quarantine_revocation",
    "curation_paths",
    "surface_truth",
    "transparency_events",
    "inspection",
    "claim",
    "discovery_posture_class"
  ],
  "properties": {
    "record_kind": { "const": "marketplace_discovery_packet" },
    "schema_version": { "const": 1 },
    "schema_ref": { "const": "schemas/extensions/marketplace-ranking-and-anti-abuse.schema.json" },
    "identity": { "$ref": "#/$defs/identity" },
    "publisher": { "$ref": "#/$defs/publisher" },
    "ranking_signals": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ranking_signal" }
    },
    "anti_abuse_controls": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/anti_abuse_control" }
    },
    "quarantine_revocation": { "$ref": "#/$defs/quarantine_revocation" },
    "curation_paths": {
      "type": "array",
      "items": { "$ref": "#/$defs/curation_path" }
    },
    "surface_truth": { "$ref": "#/$defs/surface_truth" },
    "transparency_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/transparency_event" }
    },
    "inspection": { "$ref": "#/$defs/inspection" },
    "claim": { "$ref": "#/$defs/claim" },
    "discovery_posture_class": { "$ref": "#/$defs/discovery_posture_class" }
  },
  "$defs": {
    "opaque_id": { "type": "string", "minLength": 1 },
    "ranking_signal_class": {
      "type": "string",
      "enum": [
        "query_relevance",
        "category_fit",
        "current_version_compatibility",
        "runtime_health",
        "maintenance_freshness",
        "verified_or_official_status",
        "rollback_uninstall_quality",
        "docs_security_posture"
      ]
    },
    "abuse_control_class": {
      "type": "string",
      "enum": [
        "publisher_identity_verification",
        "namespace_reservation",
        "typosquat_detection",
        "look_alike_detection",
        "review_install_fraud_detection",
        "suspicious_package_quarantine",
        "malware_static_policy_scanning",
        "rapid_revocation"
      ]
    },
    "abuse_state_class": {
      "type": "string",
      "enum": ["passed", "under_review", "suspicious", "quarantined", "blocked", "revoked"]
    },
    "publisher_tier_class": {
      "type": "string",
      "enum": ["official_pack", "verified_publisher", "enterprise_approved", "community", "under_review"]
    },
    "quarantine_revocation_class": {
      "type": "string",
      "enum": ["none", "review_hold", "quarantined", "revoked", "emergency_disabled"]
    },
    "registry_lane_class": {
      "type": "string",
      "enum": ["public_registry", "quarantine_holding", "approved_mirror", "private_registry", "offline_bundle"]
    },
    "transparency_event_class": {
      "type": "string",
      "enum": ["removal", "appeal", "emergency_disable", "verified_publisher_action", "quarantine", "revocation"]
    },
    "stability_tier": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "discovery_posture_class": {
      "type": "string",
      "enum": ["prominent", "ordinary", "narrowed", "under_review", "quarantined", "revoked"]
    },
    "narrowing_reason": {
      "type": "string",
      "enum": [
        "discovery_version_not_published",
        "ranking_signal_missing",
        "ranking_reason_not_explainable",
        "ranking_uses_vanity_metric",
        "stale_compatibility",
        "crash_resource_regression",
        "maintenance_stale",
        "high_rollback_or_uninstall_rate",
        "docs_security_gap",
        "publisher_status_not_mechanical",
        "publisher_identity_unverified",
        "publisher_under_review",
        "anti_abuse_control_missing",
        "abuse_reason_not_visible",
        "lookalike_or_typosquat_under_review",
        "fraud_review_active",
        "suspicious_package_quarantined",
        "malware_policy_block",
        "revocation_active",
        "enterprise_curation_identity_gap",
        "surface_visibility_gap",
        "transparency_not_exportable"
      ]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "catalog_descriptor_ref",
        "package_id",
        "package_version",
        "artifact_ref",
        "discovery_version"
      ],
      "properties": {
        "record_kind": { "const": "marketplace_package_identity" },
        "schema_version": { "const": 1 },
        "catalog_descriptor_ref": { "$ref": "#/$defs/opaque_id" },
        "package_id": { "$ref": "#/$defs/opaque_id" },
        "package_version": { "$ref": "#/$defs/opaque_id" },
        "artifact_ref": { "$ref": "#/$defs/opaque_id" },
        "discovery_version": { "type": "integer", "minimum": 0 }
      }
    },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "publisher_id",
        "tier_class",
        "identity_verified",
        "mechanically_sourced",
        "status_model_ref",
        "namespace_ref"
      ],
      "properties": {
        "record_kind": { "const": "publisher_status" },
        "publisher_id": { "$ref": "#/$defs/opaque_id" },
        "tier_class": { "$ref": "#/$defs/publisher_tier_class" },
        "identity_verified": { "type": "boolean" },
        "mechanically_sourced": { "type": "boolean" },
        "status_model_ref": { "$ref": "#/$defs/opaque_id" },
        "namespace_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "ranking_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signal_class", "score_delta", "reason_chip", "evidence_ref", "raw_install_count_primary"],
      "properties": {
        "signal_class": { "$ref": "#/$defs/ranking_signal_class" },
        "score_delta": { "type": "integer", "minimum": -32768, "maximum": 32767 },
        "reason_chip": { "$ref": "#/$defs/opaque_id" },
        "evidence_ref": { "$ref": "#/$defs/opaque_id" },
        "raw_install_count_primary": { "type": "boolean" }
      }
    },
    "anti_abuse_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_class",
        "state_class",
        "user_visible_reason",
        "admin_visible_reason",
        "evidence_ref",
        "support_exportable",
        "mirror_safe_continuity"
      ],
      "properties": {
        "control_class": { "$ref": "#/$defs/abuse_control_class" },
        "state_class": { "$ref": "#/$defs/abuse_state_class" },
        "user_visible_reason": { "$ref": "#/$defs/opaque_id" },
        "admin_visible_reason": { "$ref": "#/$defs/opaque_id" },
        "evidence_ref": { "$ref": "#/$defs/opaque_id" },
        "support_exportable": { "type": "boolean" },
        "mirror_safe_continuity": { "type": "boolean" }
      }
    },
    "quarantine_revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status_class", "reason_class", "installed_impact", "last_known_good_ref", "mirror_visible"],
      "properties": {
        "status_class": { "$ref": "#/$defs/quarantine_revocation_class" },
        "reason_class": { "$ref": "#/$defs/opaque_id" },
        "installed_impact": { "$ref": "#/$defs/opaque_id" },
        "last_known_good_ref": { "$ref": "#/$defs/opaque_id" },
        "mirror_visible": { "type": "boolean" }
      }
    },
    "curation_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_lane",
        "target_lane",
        "identity_preserved",
        "provenance_preserved",
        "support_class_preserved",
        "approval_ref"
      ],
      "properties": {
        "source_lane": { "$ref": "#/$defs/registry_lane_class" },
        "target_lane": { "$ref": "#/$defs/registry_lane_class" },
        "identity_preserved": { "type": "boolean" },
        "provenance_preserved": { "type": "boolean" },
        "support_class_preserved": { "type": "boolean" },
        "approval_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "surface_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "marketplace_cards_explicit",
        "search_results_explicit",
        "details_views_explicit",
        "admin_review_explicit",
        "mirrored_catalogs_explicit",
        "support_export_explicit"
      ],
      "properties": {
        "marketplace_cards_explicit": { "type": "boolean" },
        "search_results_explicit": { "type": "boolean" },
        "details_views_explicit": { "type": "boolean" },
        "admin_review_explicit": { "type": "boolean" },
        "mirrored_catalogs_explicit": { "type": "boolean" },
        "support_export_explicit": { "type": "boolean" }
      }
    },
    "transparency_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_class", "actor_ref", "decision_timestamp", "notice_ref", "exportable", "mirror_visible"],
      "properties": {
        "event_class": { "$ref": "#/$defs/transparency_event_class" },
        "actor_ref": { "$ref": "#/$defs/opaque_id" },
        "decision_timestamp": { "type": "string", "format": "date-time" },
        "notice_ref": { "$ref": "#/$defs/opaque_id" },
        "exportable": { "type": "boolean" },
        "mirror_visible": { "type": "boolean" }
      }
    },
    "inspection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "ranking_score",
        "ranking_signal_count",
        "missing_ranking_signal_count",
        "ranking_explainable",
        "vanity_metric_used",
        "anti_abuse_control_count",
        "review_control_count",
        "blocking_control_count",
        "surfaces_aligned",
        "curation_identity_preserved",
        "transparency_exportable"
      ],
      "properties": {
        "record_kind": { "const": "marketplace_discovery_inspection" },
        "ranking_score": { "type": "integer" },
        "ranking_signal_count": { "type": "integer", "minimum": 0 },
        "missing_ranking_signal_count": { "type": "integer", "minimum": 0 },
        "ranking_explainable": { "type": "boolean" },
        "vanity_metric_used": { "type": "boolean" },
        "anti_abuse_control_count": { "type": "integer", "minimum": 0 },
        "review_control_count": { "type": "integer", "minimum": 0 },
        "blocking_control_count": { "type": "integer", "minimum": 0 },
        "surfaces_aligned": { "type": "boolean" },
        "curation_identity_preserved": { "type": "boolean" },
        "transparency_exportable": { "type": "boolean" }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "claimed_tier",
        "effective_tier",
        "support_claim_class",
        "narrowed",
        "narrowing_reasons"
      ],
      "properties": {
        "record_kind": { "const": "marketplace_discovery_claim" },
        "claimed_tier": { "$ref": "#/$defs/stability_tier" },
        "effective_tier": { "$ref": "#/$defs/stability_tier" },
        "support_claim_class": {
          "type": "string",
          "enum": [
            "stable_marketplace_discovery_claim",
            "beta_marketplace_discovery_narrowed",
            "preview_marketplace_discovery_review",
            "withdrawn_marketplace_discovery_blocked"
          ]
        },
        "narrowed": { "type": "boolean" },
        "narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        }
      }
    }
  }
}
