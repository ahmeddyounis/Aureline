{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/marketplace_fact_grid.schema.json",
  "title": "Aureline marketplace fact grid",
  "description": "Boundary schema for the shared marketplace fact grid used by result rows, detail pages, install/update/rollback review sheets, compatibility reports, diagnostics, and support exports. The grid preserves client scope, source lane, compatibility, script/native-build risk, manifest changes, permission deltas, lockfile impact, revocation posture, rollback posture, and activation budget across public, mirrored, offline, and manual-import catalog paths.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/marketplace_fact_grid_record" },
    { "$ref": "#/$defs/marketplace_fact_grid_support_export_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "redaction_class": {
      "type": "string",
      "const": "metadata_safe_default"
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "result_row",
        "detail_page",
        "install_review_sheet",
        "update_review_sheet",
        "rollback_review_sheet",
        "support_export",
        "compatibility_report",
        "manual_import_review",
        "offline_registry_row"
      ]
    },
    "client_scope_class": {
      "type": "string",
      "enum": [
        "desktop",
        "browser_companion",
        "desktop_plus_browser_companion",
        "headless_only",
        "unsupported"
      ]
    },
    "registry_source_class": {
      "type": "string",
      "enum": [
        "public_registry",
        "approved_mirror",
        "private_registry",
        "offline_bundle",
        "local_archive",
        "quarantined_local_copy"
      ]
    },
    "mirrorability_class": {
      "type": "string",
      "enum": [
        "mirrorable_verified",
        "mirrorable_capped_trust",
        "mirrorable_pending_reverify",
        "mirror_blocked_digest_or_signature",
        "mirror_blocked_source_not_allowed"
      ]
    },
    "catalog_lifecycle_state_class": {
      "type": "string",
      "enum": ["staged", "approved", "limited", "deprecated", "revoked", "quarantined"]
    },
    "catalog_decision_class": {
      "type": "string",
      "enum": ["ready_for_catalog", "staged_for_review", "limited", "refused"]
    },
    "badge_class": {
      "type": "string",
      "enum": [
        "preview",
        "beta",
        "stable",
        "deprecated",
        "limited",
        "revoked",
        "mirrored",
        "retest_pending"
      ]
    },
    "compatibility_label_class": {
      "type": "string",
      "enum": ["compatible", "limited", "needs_bridge", "unsupported", "retest_pending"]
    },
    "support_chip_class": {
      "type": "string",
      "enum": [
        "certified",
        "supported",
        "limited",
        "community",
        "experimental",
        "retest_pending",
        "evidence_stale",
        "unsupported"
      ]
    },
    "trust_chip_class": {
      "type": "string",
      "enum": [
        "verified_publisher",
        "organisational_publisher",
        "community_publisher",
        "unverified_publisher",
        "quarantined_publisher",
        "public_registry",
        "approved_mirror",
        "private_registry",
        "offline_bundle",
        "local_archive",
        "quarantined_local_copy",
        "trust_capped_by_source",
        "mirrorable"
      ]
    },
    "script_risk_class": {
      "type": "string",
      "enum": [
        "no_scripts_or_native_build",
        "lifecycle_scripts_declared",
        "native_build_required",
        "external_helper_or_host",
        "unknown_script_risk_blocked"
      ]
    },
    "manifest_change_class": {
      "type": "string",
      "enum": [
        "added",
        "removed",
        "changed",
        "permission_delta",
        "metadata_only",
        "no_change_declared"
      ]
    },
    "lockfile_impact_class": {
      "type": "string",
      "enum": [
        "no_lockfile_change",
        "lockfile_churn_expected",
        "generated_files_expected",
        "regenerate_and_review",
        "unknown_blocked"
      ]
    },
    "permission_scope_class": {
      "type": "string",
      "enum": [
        "filesystem_read",
        "filesystem_write",
        "shell_execute",
        "network_egress",
        "ai_provider_access",
        "connected_provider_access",
        "secret_handle_use",
        "workspace_settings_read",
        "workspace_settings_write",
        "execution_context_bind",
        "subscription_subscribe",
        "ui_command_contribute",
        "capability_inherit"
      ]
    },
    "permission_diff_class": {
      "type": "string",
      "enum": [
        "unchanged",
        "narrowed",
        "denied",
        "step_up_required",
        "widening_attempted_blocked"
      ]
    },
    "runtime_cost_class": {
      "type": "string",
      "enum": [
        "runtime_cost_low_nominal",
        "runtime_cost_nominal",
        "runtime_cost_elevated_warm_or_idle_polling_breach",
        "runtime_cost_unknown_pending_evidence",
        "runtime_cost_quarantined_under_crash_loop_or_egress_breach"
      ]
    },
    "runtime_cost_evidence_class": {
      "type": "string",
      "enum": [
        "activation_evidence_packet_present",
        "activation_evidence_packet_absent_pending_first_session",
        "benchmark_archive_present",
        "benchmark_archive_absent",
        "self_reported_only_unverified"
      ]
    },
    "revocation_state_class": {
      "type": "string",
      "enum": [
        "no_known_revocation",
        "revoked",
        "quarantined",
        "emergency_disabled",
        "mirror_promotion_revoked",
        "pending_reverify"
      ]
    },
    "revocation_snapshot_age_class": {
      "type": "string",
      "enum": ["fresh", "warm_cached", "degraded_cached", "stale", "unverified_no_snapshot"]
    },
    "install_review_decision_class": {
      "type": "string",
      "enum": [
        "admit_after_native_review",
        "awaiting_user_review",
        "awaiting_admin_review",
        "denied"
      ]
    },
    "install_review_decision_reason_class": {
      "type": "string",
      "enum": [
        "admitted_after_native_review",
        "missing_required_disclosure",
        "owner_origin_scope_network_boundary_missing",
        "hosted_consumer_cannot_approve",
        "native_review_packet_required",
        "upstream_review_denied",
        "upstream_review_pending",
        "effective_permission_widening_attempted",
        "compatibility_evidence_missing",
        "compatibility_mismatch",
        "compatibility_limited_requires_review",
        "compatibility_label_claim_refused",
        "activation_budget_evidence_missing",
        "activation_budget_blocks_mutation",
        "install_topology_missing"
      ]
    },
    "string_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "script_risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script_risk_class",
        "risk_source_refs",
        "native_build_requirement_refs",
        "policy_block_refs",
        "summary"
      ],
      "properties": {
        "script_risk_class": { "$ref": "#/$defs/script_risk_class" },
        "risk_source_refs": { "$ref": "#/$defs/string_array" },
        "native_build_requirement_refs": { "$ref": "#/$defs/string_array" },
        "policy_block_refs": { "$ref": "#/$defs/string_array" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "manifest_change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "change_id",
        "change_class",
        "manifest_ref",
        "field_path",
        "review_required",
        "summary"
      ],
      "properties": {
        "change_id": { "$ref": "#/$defs/non_empty_string" },
        "change_class": { "$ref": "#/$defs/manifest_change_class" },
        "manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "field_path": { "$ref": "#/$defs/non_empty_string" },
        "before_summary": { "$ref": "#/$defs/non_empty_string" },
        "after_summary": { "$ref": "#/$defs/non_empty_string" },
        "review_required": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "permission_delta_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_class",
        "scope_target",
        "diff_class",
        "narrowing_reason_label"
      ],
      "properties": {
        "scope_class": { "$ref": "#/$defs/permission_scope_class" },
        "scope_target": { "$ref": "#/$defs/non_empty_string" },
        "diff_class": { "$ref": "#/$defs/permission_diff_class" },
        "narrowing_reason_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "lockfile_impact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "impact_class",
        "resolver_ref",
        "affected_lockfile_refs",
        "generated_file_refs",
        "environment_factor_refs",
        "summary"
      ],
      "properties": {
        "impact_class": { "$ref": "#/$defs/lockfile_impact_class" },
        "resolver_ref": { "$ref": "#/$defs/non_empty_string" },
        "affected_lockfile_refs": { "$ref": "#/$defs/string_array" },
        "generated_file_refs": { "$ref": "#/$defs/string_array" },
        "environment_factor_refs": { "$ref": "#/$defs/string_array" },
        "rollback_checkpoint_ref": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "activation_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cpu", "memory", "startup_cost_ceiling", "opt_in_feature_gates"],
      "properties": {
        "cpu": { "$ref": "#/$defs/non_empty_string" },
        "memory": { "$ref": "#/$defs/non_empty_string" },
        "startup_cost_ceiling": { "$ref": "#/$defs/non_empty_string" },
        "opt_in_feature_gates": { "$ref": "#/$defs/string_array" }
      }
    },
    "quarantine_revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "revocation_state_class",
        "revocation_snapshot_age_class",
        "last_known_good_version",
        "rollback_manifest_ref",
        "emergency_disable_refs",
        "install_or_update_blocked"
      ],
      "properties": {
        "revocation_state_class": { "$ref": "#/$defs/revocation_state_class" },
        "revocation_snapshot_age_class": {
          "$ref": "#/$defs/revocation_snapshot_age_class"
        },
        "last_known_good_version": { "$ref": "#/$defs/non_empty_string" },
        "rollback_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "emergency_disable_refs": { "$ref": "#/$defs/string_array" },
        "install_or_update_blocked": { "type": "boolean" }
      }
    },
    "marketplace_fact_grid_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "marketplace_fact_grid_schema_version",
        "fact_grid_id",
        "surface_class",
        "marketplace_row_ref",
        "catalog_descriptor_ref",
        "install_review_ref",
        "extension_identity",
        "extension_version",
        "package_id",
        "display_name",
        "publisher_display_label",
        "client_scope_class",
        "client_scope_token",
        "client_scope_summary",
        "registry_source_class",
        "mirrorability_class",
        "catalog_lifecycle_state_class",
        "catalog_decision_class",
        "lifecycle_badges",
        "compatibility_label_class",
        "compatibility_report_row_id",
        "compatibility_report_generated_at",
        "support_chips",
        "trust_chips",
        "script_risk",
        "manifest_changes",
        "permission_delta_entries",
        "permission_delta_count",
        "lockfile_impact",
        "activation_budget",
        "runtime_cost_class",
        "runtime_cost_evidence_class",
        "activation_trigger_refs",
        "budget_axis_refs",
        "quarantine_revocation",
        "install_review_decision_class",
        "install_review_decision_reason_class",
        "mutation_allowed_by_install_review",
        "blocks_install_or_update",
        "workspace_change_summary",
        "fact_grid_summary",
        "generated_at",
        "redaction_class"
      ],
      "properties": {
        "record_kind": { "const": "marketplace_fact_grid_record" },
        "marketplace_fact_grid_schema_version": { "$ref": "#/$defs/schema_version" },
        "fact_grid_id": {
          "type": "string",
          "pattern": "^marketplace_fact_grid:"
        },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "marketplace_row_ref": {
          "type": "string",
          "pattern": "^marketplace_truth_row:"
        },
        "catalog_descriptor_ref": {
          "type": "string",
          "pattern": "^catalog_descriptor:"
        },
        "install_review_ref": {
          "type": "string",
          "pattern": "^install_review_alpha:"
        },
        "extension_identity": { "$ref": "#/$defs/non_empty_string" },
        "extension_version": { "$ref": "#/$defs/non_empty_string" },
        "package_id": { "$ref": "#/$defs/non_empty_string" },
        "display_name": { "$ref": "#/$defs/non_empty_string" },
        "publisher_display_label": { "$ref": "#/$defs/non_empty_string" },
        "client_scope_class": { "$ref": "#/$defs/client_scope_class" },
        "client_scope_token": { "$ref": "#/$defs/client_scope_class" },
        "client_scope_summary": { "$ref": "#/$defs/non_empty_string" },
        "registry_source_class": { "$ref": "#/$defs/registry_source_class" },
        "mirrorability_class": { "$ref": "#/$defs/mirrorability_class" },
        "catalog_lifecycle_state_class": {
          "$ref": "#/$defs/catalog_lifecycle_state_class"
        },
        "catalog_decision_class": { "$ref": "#/$defs/catalog_decision_class" },
        "lifecycle_badges": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/badge_class" }
        },
        "compatibility_label_class": {
          "$ref": "#/$defs/compatibility_label_class"
        },
        "compatibility_report_row_id": { "$ref": "#/$defs/non_empty_string" },
        "compatibility_report_generated_at": { "type": "string", "format": "date-time" },
        "support_chips": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/support_chip_class" }
        },
        "trust_chips": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/trust_chip_class" }
        },
        "script_risk": { "$ref": "#/$defs/script_risk" },
        "manifest_changes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/manifest_change" }
        },
        "permission_delta_entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/permission_delta_entry" }
        },
        "permission_delta_count": { "type": "integer", "minimum": 0 },
        "lockfile_impact": { "$ref": "#/$defs/lockfile_impact" },
        "activation_budget": { "$ref": "#/$defs/activation_budget" },
        "runtime_cost_class": { "$ref": "#/$defs/runtime_cost_class" },
        "runtime_cost_evidence_class": {
          "$ref": "#/$defs/runtime_cost_evidence_class"
        },
        "activation_trigger_refs": { "$ref": "#/$defs/string_array" },
        "budget_axis_refs": { "$ref": "#/$defs/string_array" },
        "quarantine_revocation": { "$ref": "#/$defs/quarantine_revocation" },
        "install_review_decision_class": {
          "$ref": "#/$defs/install_review_decision_class"
        },
        "install_review_decision_reason_class": {
          "$ref": "#/$defs/install_review_decision_reason_class"
        },
        "mutation_allowed_by_install_review": { "type": "boolean" },
        "blocks_install_or_update": { "type": "boolean" },
        "workspace_change_summary": { "$ref": "#/$defs/non_empty_string" },
        "fact_grid_summary": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    },
    "marketplace_fact_grid_support_export_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "marketplace_fact_grid_schema_version",
        "export_id",
        "fact_grid_ref",
        "marketplace_row_ref",
        "catalog_descriptor_ref",
        "install_review_ref",
        "extension_identity",
        "extension_version",
        "client_scope_class",
        "registry_source_class",
        "compatibility_label_class",
        "runtime_cost_class",
        "script_risk_class",
        "lockfile_impact_class",
        "manifest_change_count",
        "permission_delta_count",
        "revocation_state_class",
        "blocks_install_or_update",
        "export_safe_summary",
        "redaction_class"
      ],
      "properties": {
        "record_kind": {
          "const": "marketplace_fact_grid_support_export_record"
        },
        "marketplace_fact_grid_schema_version": { "$ref": "#/$defs/schema_version" },
        "export_id": {
          "type": "string",
          "pattern": "^marketplace_fact_grid_support_export:"
        },
        "fact_grid_ref": {
          "type": "string",
          "pattern": "^marketplace_fact_grid:"
        },
        "marketplace_row_ref": {
          "type": "string",
          "pattern": "^marketplace_truth_row:"
        },
        "catalog_descriptor_ref": {
          "type": "string",
          "pattern": "^catalog_descriptor:"
        },
        "install_review_ref": {
          "type": "string",
          "pattern": "^install_review_alpha:"
        },
        "extension_identity": { "$ref": "#/$defs/non_empty_string" },
        "extension_version": { "$ref": "#/$defs/non_empty_string" },
        "client_scope_class": { "$ref": "#/$defs/client_scope_class" },
        "registry_source_class": { "$ref": "#/$defs/registry_source_class" },
        "compatibility_label_class": {
          "$ref": "#/$defs/compatibility_label_class"
        },
        "runtime_cost_class": { "$ref": "#/$defs/runtime_cost_class" },
        "script_risk_class": { "$ref": "#/$defs/script_risk_class" },
        "lockfile_impact_class": { "$ref": "#/$defs/lockfile_impact_class" },
        "manifest_change_count": { "type": "integer", "minimum": 0 },
        "permission_delta_count": { "type": "integer", "minimum": 0 },
        "revocation_state_class": { "$ref": "#/$defs/revocation_state_class" },
        "blocks_install_or_update": { "type": "boolean" },
        "export_safe_summary": { "$ref": "#/$defs/non_empty_string" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    }
  }
}
