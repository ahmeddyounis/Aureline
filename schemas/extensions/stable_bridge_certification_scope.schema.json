{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/stable_bridge_certification_scope.schema.json",
  "title": "Aureline stable bridge-certification scope packet",
  "description": "Cross-tool boundary schema for the stable bridge-certification packet emitted by crates/aureline-extensions. One packet binds a stable_bridge_certification_identity (certification-scope descriptor ref, row identity, package identity, the pinned certification-scope version, the publisher namespace, the pinned certification-evidence ref, the publisher trust tier, and the lifecycle state), a stable_bridge_surface_binding (bridge kind, pinned bridge ABI version, bridge-finalized flag, enforcement-backed flag, and control-plane boundary), a stable_bridge_certification_scope (certification category, scope status, certification evidence source, and conformance-passed flag), a stable_bridge_certification_permission_posture (declared / effective refs and a no-widening flag), a stable_bridge_certification_compatibility (parity label, scorecard ref, verified flag), a stable_bridge_certification_activation_budget, a stable_bridge_certification_install_posture (install scope and disclosure, revocation posture, mirrorability, rollback support), the stable_bridge_certification_qualification_claim after the posture is applied (with automatic narrowing below Stable), a stable_bridge_certification_downgraded_banner, and an inspection projection. A stable effective tier may only render when the row pins the published certification-scope version and bridge ABI version, is evidence-backed, keeps its trust tier out of quarantine, stays runnable, finalizes its bridge contract, keeps the bridge enforcement-backed with a guarded control plane, keeps its category in the certified scope with conformance passed and non-inherited evidence, never widens permissions across the bridge, keeps verified non-parity-limited compatibility, keeps its activation cost within budget, discloses its install scope, keeps a clean revocation posture, stays mirrorable, and is fully attributed. A non-qualified category — provisional, excluded, or deprecated_scope, or with failed conformance or inherited evidence — is downgraded to preview. The Rust types in crates/aureline-extensions/src/finalize_extension_bridge_and_certification_scope_and_downgrade/ are the source of truth. Raw artifact bytes, raw evidence payloads, raw permission contents, and raw publisher-private data MUST NOT appear in any record; records carry refs only.",
  "type": "object",
  "$ref": "#/$defs/stable_bridge_certification_scope_packet",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log and safe in support/export packets."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "trust_tier_class": {
      "type": "string",
      "enum": ["verified_publisher", "known_publisher", "community_unverified", "quarantined"]
    },
    "lifecycle_state_class": {
      "type": "string",
      "enum": [
        "installed",
        "pending_activation",
        "active",
        "recovered",
        "degraded",
        "disabled",
        "quarantined",
        "removed",
        "publisher_blocked"
      ]
    },
    "bridge_kind_class": {
      "type": "string",
      "enum": [
        "language_bridge",
        "debug_bridge",
        "scm_bridge",
        "task_bridge",
        "terminal_bridge",
        "filesystem_bridge",
        "search_bridge",
        "ui_panel_bridge",
        "data_infra_bridge"
      ]
    },
    "control_plane_boundary_class": {
      "type": "string",
      "enum": ["guarded", "advisory", "unguarded"]
    },
    "certification_category_class": {
      "type": "string",
      "enum": [
        "language_tools",
        "debuggers",
        "formatters_linters",
        "scm_providers",
        "task_runners",
        "terminal_tools",
        "themes_appearance",
        "snippets",
        "keymaps",
        "data_infra_adapters",
        "ai_assist",
        "general_ui"
      ]
    },
    "scope_status_class": {
      "type": "string",
      "enum": ["certified", "provisional", "excluded", "deprecated_scope"]
    },
    "certification_evidence_source_class": {
      "type": "string",
      "enum": [
        "conformance_suite",
        "certified_workspace",
        "bridge_matrix",
        "vendor_attested",
        "inherited_from_adjacent"
      ]
    },
    "compatibility_label_class": {
      "type": "string",
      "enum": ["full_parity", "high_parity", "partial_parity", "limited_parity", "unsupported"]
    },
    "activation_budget_class": {
      "type": "string",
      "enum": ["within_budget", "over_budget", "unbounded", "not_measured"]
    },
    "install_scope_class": {
      "type": "string",
      "enum": ["user", "workspace", "machine", "portable"]
    },
    "revocation_posture_class": {
      "type": "string",
      "enum": ["clean", "advisory", "quarantined", "revoked"]
    },
    "mirrorability_class": {
      "type": "string",
      "enum": ["mirrorable", "mirror_pinned", "not_mirrorable"]
    },
    "stability_tier": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "claim_basis_class": {
      "type": "string",
      "enum": ["evidence_backed", "catalog_asserted_only"]
    },
    "support_claim_class": {
      "type": "string",
      "enum": [
        "stable_bridge_certification_claim",
        "beta_bridge_certification_partial_claim",
        "preview_bridge_certification_experimental_claim",
        "withdrawn_no_bridge_certification_claim"
      ]
    },
    "downgrade_reason_class": {
      "type": "string",
      "enum": [
        "certification_version_not_published",
        "bridge_abi_not_published",
        "catalog_only_trust_not_evidence_backed",
        "trust_tier_quarantined",
        "lifecycle_not_runnable",
        "bridge_contract_not_finalized",
        "bridge_not_enforcement_backed",
        "bridge_control_plane_unguarded",
        "bridge_control_plane_advisory",
        "category_scope_provisional",
        "category_scope_excluded",
        "category_scope_deprecated",
        "certification_conformance_failed",
        "certification_evidence_inherited",
        "bridge_permission_widened",
        "compatibility_unsupported",
        "compatibility_parity_limited",
        "compatibility_not_verified",
        "activation_cost_unbounded",
        "activation_cost_over_budget",
        "activation_cost_not_measured",
        "install_scope_not_disclosed",
        "revocation_posture_quarantined",
        "revocation_posture_revoked",
        "revocation_posture_advisory",
        "not_mirrorable",
        "attribution_incomplete"
      ]
    },
    "consumer_surface_class": {
      "type": "string",
      "enum": [
        "marketplace_result_row",
        "marketplace_detail_page",
        "install_review",
        "extension_detail_view",
        "bridge_inspector",
        "certification_dashboard",
        "diagnostics",
        "support_export",
        "docs_help_surface",
        "release_packet",
        "cli_inspector"
      ]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "certification_scope_ref",
        "row_identity_ref",
        "extension_identity",
        "extension_version",
        "package_id",
        "certification_scope_version",
        "publisher_namespace",
        "certification_evidence_ref",
        "publisher_trust_tier_class",
        "lifecycle_state_class"
      ],
      "properties": {
        "record_kind": { "const": "stable_bridge_certification_identity" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "certification_scope_ref": {
          "type": "string",
          "pattern": "^certification_scope:"
        },
        "row_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "extension_identity": { "$ref": "#/$defs/opaque_id" },
        "extension_version": { "$ref": "#/$defs/opaque_id" },
        "package_id": { "$ref": "#/$defs/opaque_id" },
        "certification_scope_version": { "type": "integer", "minimum": 0 },
        "publisher_namespace": { "$ref": "#/$defs/opaque_id" },
        "certification_evidence_ref": { "$ref": "#/$defs/opaque_id" },
        "publisher_trust_tier_class": { "$ref": "#/$defs/trust_tier_class" },
        "lifecycle_state_class": { "$ref": "#/$defs/lifecycle_state_class" }
      }
    },
    "bridge_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "bridge_kind_class",
        "bridge_abi_version",
        "bridge_surface_ref",
        "bridge_contract_finalized",
        "bridge_enforcement_backed",
        "control_plane_boundary_class",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_bridge_surface_binding" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "bridge_kind_class": { "$ref": "#/$defs/bridge_kind_class" },
        "bridge_abi_version": { "type": "integer", "minimum": 0 },
        "bridge_surface_ref": { "$ref": "#/$defs/opaque_id" },
        "bridge_contract_finalized": { "type": "boolean" },
        "bridge_enforcement_backed": { "type": "boolean" },
        "control_plane_boundary_class": { "$ref": "#/$defs/control_plane_boundary_class" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "certification_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "category_class",
        "scope_status_class",
        "certification_evidence_source_class",
        "conformance_passed",
        "conformance_report_ref",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_bridge_certification_scope" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "category_class": { "$ref": "#/$defs/certification_category_class" },
        "scope_status_class": { "$ref": "#/$defs/scope_status_class" },
        "certification_evidence_source_class": {
          "$ref": "#/$defs/certification_evidence_source_class"
        },
        "conformance_passed": { "type": "boolean" },
        "conformance_report_ref": { "$ref": "#/$defs/opaque_id" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "permission_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "declared_permission_ref",
        "effective_permission_ref",
        "widened_on_bridge",
        "reconsent_required",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_bridge_certification_permission_posture" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "declared_permission_ref": { "$ref": "#/$defs/opaque_id" },
        "effective_permission_ref": { "$ref": "#/$defs/opaque_id" },
        "widened_on_bridge": { "type": "boolean" },
        "reconsent_required": { "type": "boolean" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "compatibility_label_class",
        "scorecard_ref",
        "compatibility_verified",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_bridge_certification_compatibility" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "compatibility_label_class": { "$ref": "#/$defs/compatibility_label_class" },
        "scorecard_ref": { "$ref": "#/$defs/opaque_id" },
        "compatibility_verified": { "type": "boolean" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "activation_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "budget_class",
        "measured_cost_ref",
        "budget_ceiling_ref",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_bridge_certification_activation_budget" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "budget_class": { "$ref": "#/$defs/activation_budget_class" },
        "measured_cost_ref": { "$ref": "#/$defs/opaque_id" },
        "budget_ceiling_ref": { "$ref": "#/$defs/opaque_id" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "install_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "install_scope_class",
        "install_scope_disclosed",
        "revocation_posture_class",
        "mirrorability_class",
        "rollback_supported",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_bridge_certification_install_posture" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "install_scope_class": { "$ref": "#/$defs/install_scope_class" },
        "install_scope_disclosed": { "type": "boolean" },
        "revocation_posture_class": { "$ref": "#/$defs/revocation_posture_class" },
        "mirrorability_class": { "$ref": "#/$defs/mirrorability_class" },
        "rollback_supported": { "type": "boolean" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "qualification_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "claimed_tier",
        "effective_tier",
        "support_claim_class",
        "claim_basis_class",
        "downgraded",
        "downgrade_reasons",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_bridge_certification_qualification_claim" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "claimed_tier": { "$ref": "#/$defs/stability_tier" },
        "effective_tier": { "$ref": "#/$defs/stability_tier" },
        "support_claim_class": { "$ref": "#/$defs/support_claim_class" },
        "claim_basis_class": { "$ref": "#/$defs/claim_basis_class" },
        "downgraded": { "type": "boolean" },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason_class" }
        },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "downgraded_banner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_kind", "schema_version", "must_display", "summary_label"],
      "properties": {
        "record_kind": { "const": "stable_bridge_certification_downgraded_banner" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "must_display": { "type": "boolean" },
        "banner_reason_class": { "$ref": "#/$defs/downgrade_reason_class" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "inspection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id_ref",
        "effective_tier",
        "stable_claim",
        "scope_version_current",
        "bridge_abi_current",
        "trust_tier_class",
        "lifecycle_runnable",
        "bridge_kind_class",
        "bridge_contract_finalized",
        "bridge_enforcement_backed",
        "control_plane_guarded",
        "category_class",
        "scope_status_class",
        "in_certified_scope",
        "conformance_passed",
        "permissions_not_widened",
        "compatibility_label_class",
        "compatibility_verified",
        "activation_budget_class",
        "activation_within_budget",
        "revocation_posture_class",
        "mirrorability_class",
        "downgraded",
        "downgraded_banner_required",
        "attribution_complete",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_bridge_certification_inspection" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id_ref": { "$ref": "#/$defs/opaque_id" },
        "effective_tier": { "$ref": "#/$defs/stability_tier" },
        "stable_claim": { "type": "boolean" },
        "scope_version_current": { "type": "boolean" },
        "bridge_abi_current": { "type": "boolean" },
        "trust_tier_class": { "$ref": "#/$defs/trust_tier_class" },
        "lifecycle_runnable": { "type": "boolean" },
        "bridge_kind_class": { "$ref": "#/$defs/bridge_kind_class" },
        "bridge_contract_finalized": { "type": "boolean" },
        "bridge_enforcement_backed": { "type": "boolean" },
        "control_plane_guarded": { "type": "boolean" },
        "category_class": { "$ref": "#/$defs/certification_category_class" },
        "scope_status_class": { "$ref": "#/$defs/scope_status_class" },
        "in_certified_scope": { "type": "boolean" },
        "conformance_passed": { "type": "boolean" },
        "permissions_not_widened": { "type": "boolean" },
        "compatibility_label_class": { "$ref": "#/$defs/compatibility_label_class" },
        "compatibility_verified": { "type": "boolean" },
        "activation_budget_class": { "$ref": "#/$defs/activation_budget_class" },
        "activation_within_budget": { "type": "boolean" },
        "revocation_posture_class": { "$ref": "#/$defs/revocation_posture_class" },
        "mirrorability_class": { "$ref": "#/$defs/mirrorability_class" },
        "downgraded": { "type": "boolean" },
        "downgraded_banner_required": { "type": "boolean" },
        "attribution_complete": { "type": "boolean" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "stable_bridge_certification_scope_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "generated_at",
        "identity",
        "bridge_surface",
        "certification_scope",
        "permission_posture",
        "compatibility",
        "activation_budget",
        "install_posture",
        "claim",
        "downgraded_banner",
        "consumer_surfaces",
        "source_schema_refs",
        "allows_catalog_only_trust",
        "allows_ambient_bridge_privilege",
        "allows_unbounded_activation_cost",
        "inspection"
      ],
      "properties": {
        "record_kind": { "const": "stable_bridge_certification_scope_packet" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "identity": { "$ref": "#/$defs/identity" },
        "bridge_surface": { "$ref": "#/$defs/bridge_surface" },
        "certification_scope": { "$ref": "#/$defs/certification_scope" },
        "permission_posture": { "$ref": "#/$defs/permission_posture" },
        "compatibility": { "$ref": "#/$defs/compatibility" },
        "activation_budget": { "$ref": "#/$defs/activation_budget" },
        "install_posture": { "$ref": "#/$defs/install_posture" },
        "claim": { "$ref": "#/$defs/qualification_claim" },
        "downgraded_banner": { "$ref": "#/$defs/downgraded_banner" },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/consumer_surface_class" }
        },
        "source_schema_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "allows_catalog_only_trust": { "const": false },
        "allows_ambient_bridge_privilege": { "const": false },
        "allows_unbounded_activation_cost": { "const": false },
        "inspection": { "$ref": "#/$defs/inspection" }
      }
    }
  }
}
