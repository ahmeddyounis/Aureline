{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/marketplace_truth.schema.json",
  "title": "Aureline marketplace truth row",
  "description": "Boundary schema for marketplace rows that render lifecycle badges, compatibility labels, support-class chips, trust posture, and mirrorability before opening install review. Compatibility labels are derived from the current generated compatibility report row plus catalog descriptor state; hand-edited compatibility copy is non-conforming.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/marketplace_truth_row_record" },
    { "$ref": "#/$defs/marketplace_truth_support_export_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "redaction_class": {
      "type": "string",
      "const": "metadata_safe_default"
    },
    "badge_class": {
      "type": "string",
      "enum": [
        "preview",
        "beta",
        "stable",
        "deprecated",
        "limited",
        "revoked",
        "mirrored",
        "retest_pending"
      ]
    },
    "compatibility_label_class": {
      "type": "string",
      "enum": [
        "compatible",
        "limited",
        "needs_bridge",
        "unsupported",
        "retest_pending"
      ]
    },
    "compatibility_label_source_class": {
      "type": "string",
      "const": "generated_compatibility_report"
    },
    "support_chip_class": {
      "type": "string",
      "enum": [
        "certified",
        "supported",
        "limited",
        "community",
        "experimental",
        "retest_pending",
        "evidence_stale",
        "unsupported"
      ]
    },
    "trust_chip_class": {
      "type": "string",
      "enum": [
        "verified_publisher",
        "organisational_publisher",
        "community_publisher",
        "unverified_publisher",
        "quarantined_publisher",
        "public_registry",
        "approved_mirror",
        "private_registry",
        "offline_bundle",
        "local_archive",
        "quarantined_local_copy",
        "trust_capped_by_source",
        "mirrorable"
      ]
    },
    "catalog_compatibility_claim_class": {
      "type": "string",
      "enum": [
        "compatible_on_all_declared_targets",
        "compatible_on_subset_of_declared_targets",
        "compatibility_bridge_required",
        "compatibility_unknown_pending_reverification",
        "incompatible_blocked_on_policy"
      ]
    },
    "catalog_bridge_state_class": {
      "type": "string",
      "enum": [
        "no_bridge_required_native_match",
        "bridge_required_compatibility_bridge_profile",
        "bridge_required_capability_world_subset_only",
        "bridge_required_host_contract_family_subset_only",
        "bridge_unknown_pending_reverification",
        "bridge_unsupported_blocked_on_policy"
      ]
    },
    "catalog_rendered_compatibility_label": {
      "type": "string",
      "enum": [
        "unknown",
        "exact",
        "translated",
        "partial",
        "shimmed",
        "unsupported"
      ]
    },
    "registry_source_class": {
      "type": "string",
      "enum": [
        "public_registry",
        "approved_mirror",
        "private_registry",
        "offline_bundle",
        "local_archive",
        "quarantined_local_copy"
      ]
    },
    "catalog_lifecycle_state_class": {
      "type": "string",
      "enum": [
        "staged",
        "approved",
        "limited",
        "deprecated",
        "revoked",
        "quarantined"
      ]
    },
    "catalog_decision_class": {
      "type": "string",
      "enum": [
        "ready_for_catalog",
        "staged_for_review",
        "limited",
        "refused"
      ]
    },
    "mirrorability_class": {
      "type": "string",
      "enum": [
        "mirrorable_verified",
        "mirrorable_capped_trust",
        "mirrorable_pending_reverify",
        "mirror_blocked_digest_or_signature",
        "mirror_blocked_source_not_allowed"
      ]
    },
    "marketplace_truth_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "marketplace_truth_schema_version",
        "row_id",
        "catalog_descriptor_ref",
        "extension_identity",
        "extension_version",
        "package_id",
        "display_name",
        "publisher_display_label",
        "lifecycle_badges",
        "compatibility_label_class",
        "compatibility_label_source_class",
        "compatibility_report_revision",
        "compatibility_report_row_id",
        "compatibility_report_generated_at",
        "support_chips",
        "trust_chips",
        "report_effective_support_class",
        "report_declared_support_class",
        "report_downgrade_triggers_fired",
        "catalog_compatibility_claim_class",
        "catalog_bridge_state_class",
        "catalog_rendered_compatibility_label",
        "registry_source_class",
        "catalog_lifecycle_state_class",
        "catalog_decision_class",
        "mirrorability_class",
        "install_review_ref",
        "blocks_install_or_update",
        "compatibility_summary",
        "trust_summary",
        "support_summary",
        "generated_at",
        "redaction_class"
      ],
      "properties": {
        "record_kind": { "const": "marketplace_truth_row_record" },
        "marketplace_truth_schema_version": { "$ref": "#/$defs/schema_version" },
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "catalog_descriptor_ref": { "$ref": "#/$defs/non_empty_string" },
        "extension_identity": { "$ref": "#/$defs/non_empty_string" },
        "extension_version": { "$ref": "#/$defs/non_empty_string" },
        "package_id": { "$ref": "#/$defs/non_empty_string" },
        "display_name": { "$ref": "#/$defs/non_empty_string" },
        "publisher_display_label": { "$ref": "#/$defs/non_empty_string" },
        "lifecycle_badges": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/badge_class" }
        },
        "compatibility_label_class": { "$ref": "#/$defs/compatibility_label_class" },
        "compatibility_label_source_class": { "$ref": "#/$defs/compatibility_label_source_class" },
        "compatibility_report_revision": { "type": "integer", "minimum": 1 },
        "compatibility_report_row_id": { "$ref": "#/$defs/non_empty_string" },
        "compatibility_report_generated_at": { "type": "string", "format": "date-time" },
        "support_chips": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/support_chip_class" }
        },
        "trust_chips": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/trust_chip_class" }
        },
        "report_effective_support_class": { "$ref": "#/$defs/non_empty_string" },
        "report_declared_support_class": { "$ref": "#/$defs/non_empty_string" },
        "report_downgrade_triggers_fired": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "catalog_compatibility_claim_class": { "$ref": "#/$defs/catalog_compatibility_claim_class" },
        "catalog_bridge_state_class": { "$ref": "#/$defs/catalog_bridge_state_class" },
        "catalog_rendered_compatibility_label": { "$ref": "#/$defs/catalog_rendered_compatibility_label" },
        "registry_source_class": { "$ref": "#/$defs/registry_source_class" },
        "catalog_lifecycle_state_class": { "$ref": "#/$defs/catalog_lifecycle_state_class" },
        "catalog_decision_class": { "$ref": "#/$defs/catalog_decision_class" },
        "mirrorability_class": { "$ref": "#/$defs/mirrorability_class" },
        "install_review_ref": { "$ref": "#/$defs/non_empty_string" },
        "blocks_install_or_update": { "type": "boolean" },
        "compatibility_summary": { "$ref": "#/$defs/non_empty_string" },
        "trust_summary": { "$ref": "#/$defs/non_empty_string" },
        "support_summary": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "lifecycle_badges": {
                "contains": { "const": "retest_pending" }
              }
            },
            "required": ["lifecycle_badges"]
          },
          "then": {
            "properties": {
              "compatibility_label_class": { "const": "retest_pending" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "lifecycle_badges": {
                "contains": { "const": "revoked" }
              }
            },
            "required": ["lifecycle_badges"]
          },
          "then": {
            "properties": {
              "blocks_install_or_update": { "const": true }
            }
          }
        }
      ]
    },
    "marketplace_truth_support_export_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "marketplace_truth_schema_version",
        "export_id",
        "row_ref",
        "catalog_descriptor_ref",
        "extension_identity",
        "extension_version",
        "lifecycle_badges",
        "compatibility_label_class",
        "support_chips",
        "trust_chips",
        "compatibility_report_row_id",
        "install_review_ref",
        "blocks_install_or_update",
        "export_safe_summary",
        "redaction_class"
      ],
      "properties": {
        "record_kind": { "const": "marketplace_truth_support_export_record" },
        "marketplace_truth_schema_version": { "$ref": "#/$defs/schema_version" },
        "export_id": { "$ref": "#/$defs/non_empty_string" },
        "row_ref": { "$ref": "#/$defs/non_empty_string" },
        "catalog_descriptor_ref": { "$ref": "#/$defs/non_empty_string" },
        "extension_identity": { "$ref": "#/$defs/non_empty_string" },
        "extension_version": { "$ref": "#/$defs/non_empty_string" },
        "lifecycle_badges": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/badge_class" }
        },
        "compatibility_label_class": { "$ref": "#/$defs/compatibility_label_class" },
        "support_chips": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/support_chip_class" }
        },
        "trust_chips": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/trust_chip_class" }
        },
        "compatibility_report_row_id": { "$ref": "#/$defs/non_empty_string" },
        "install_review_ref": { "$ref": "#/$defs/non_empty_string" },
        "blocks_install_or_update": { "type": "boolean" },
        "export_safe_summary": { "$ref": "#/$defs/non_empty_string" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    }
  }
}
