{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/conformance_report.schema.json",
  "title": "Aureline extension conformance and compatibility review report",
  "description": "Author- and reviewer-facing conformance report. Renders passed/failed checks with one shared severity, repro/screenshot guidance, required fixes, and docs links, plus an inline compatibility section (target version range, deprecated APIs, required shims, removal horizons, migration impact). Produced by aureline_extensions::conformance_reports::build_conformance_report.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "conformance_report_schema_version",
    "report_id",
    "extension_identity",
    "extension_version",
    "package_id",
    "publisher_id",
    "validator_id",
    "validator_version",
    "subject_manifest_ref",
    "lifecycle_class",
    "checks",
    "compatibility",
    "summary",
    "decision_class",
    "reason_class",
    "decision_summary",
    "generated_at",
    "redaction_class"
  ],
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "extension_conformance_review_report"
    },
    "conformance_report_schema_version": {
      "type": "integer",
      "const": 1
    },
    "report_id": {
      "type": "string",
      "pattern": "^extension_conformance_report:"
    },
    "extension_identity": { "$ref": "#/$defs/non_empty" },
    "extension_version": { "$ref": "#/$defs/non_empty" },
    "package_id": { "$ref": "#/$defs/non_empty" },
    "publisher_id": { "$ref": "#/$defs/non_empty" },
    "validator_id": { "$ref": "#/$defs/non_empty" },
    "validator_version": { "$ref": "#/$defs/non_empty" },
    "subject_manifest_ref": { "$ref": "#/$defs/non_empty" },
    "lifecycle_class": { "$ref": "#/$defs/lifecycle_class" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/review_check" }
    },
    "compatibility": { "$ref": "#/$defs/compatibility_section" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed",
        "failed",
        "warnings",
        "not_applicable",
        "blockers",
        "recommendations"
      ],
      "properties": {
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "not_applicable": { "type": "integer", "minimum": 0 },
        "blockers": { "type": "integer", "minimum": 0 },
        "recommendations": { "type": "integer", "minimum": 0 }
      }
    },
    "decision_class": {
      "type": "string",
      "enum": [
        "publish_ready",
        "publish_ready_with_recommendations",
        "blocked_on_conformance"
      ]
    },
    "reason_class": {
      "type": "string",
      "enum": [
        "ready_all_checks_passed",
        "ready_with_recommendations",
        "blocked_conformance_blocker_failed",
        "blocked_compatibility_blocker"
      ]
    },
    "decision_summary": { "$ref": "#/$defs/non_empty" },
    "generated_at": { "$ref": "#/$defs/non_empty" },
    "redaction_class": {
      "type": "string",
      "const": "metadata_safe_default"
    }
  },
  "$defs": {
    "non_empty": {
      "type": "string",
      "minLength": 1
    },
    "severity_class": {
      "type": "string",
      "enum": ["blocker", "warning", "info"]
    },
    "status_class": {
      "type": "string",
      "enum": ["pass", "fail", "warn", "not_applicable"]
    },
    "lifecycle_class": {
      "type": "string",
      "enum": [
        "preview",
        "beta",
        "stable",
        "deprecated",
        "removed",
        "limited",
        "revoked"
      ]
    },
    "review_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "suite", "title", "status", "severity", "message"],
      "properties": {
        "check_id": { "$ref": "#/$defs/non_empty" },
        "suite": { "$ref": "#/$defs/non_empty" },
        "title": { "$ref": "#/$defs/non_empty" },
        "status": { "$ref": "#/$defs/status_class" },
        "severity": { "$ref": "#/$defs/severity_class" },
        "message": { "$ref": "#/$defs/non_empty" },
        "field": { "$ref": "#/$defs/non_empty" },
        "required_fix": { "$ref": "#/$defs/non_empty" },
        "repro_guidance": { "$ref": "#/$defs/non_empty" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty" }
        },
        "docs_url": { "$ref": "#/$defs/non_empty" }
      }
    },
    "deprecated_api": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "api_id",
        "replacement",
        "removal_horizon",
        "migration_impact",
        "severity"
      ],
      "properties": {
        "api_id": { "$ref": "#/$defs/non_empty" },
        "replacement": { "$ref": "#/$defs/non_empty" },
        "removal_horizon": { "$ref": "#/$defs/non_empty" },
        "migration_impact": { "$ref": "#/$defs/non_empty" },
        "severity": { "$ref": "#/$defs/severity_class" },
        "docs_url": { "$ref": "#/$defs/non_empty" }
      }
    },
    "required_shim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shim_id", "reason", "covers", "target_version_range", "severity"],
      "properties": {
        "shim_id": { "$ref": "#/$defs/non_empty" },
        "reason": { "$ref": "#/$defs/non_empty" },
        "covers": { "$ref": "#/$defs/non_empty" },
        "target_version_range": { "$ref": "#/$defs/non_empty" },
        "severity": { "$ref": "#/$defs/severity_class" },
        "docs_url": { "$ref": "#/$defs/non_empty" }
      }
    },
    "compatibility_section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_aureline_version_min",
        "target_aureline_version_max",
        "sdk_line_id",
        "bridge_state",
        "deprecated_apis",
        "required_shims",
        "migration_impact_summary"
      ],
      "properties": {
        "target_aureline_version_min": { "$ref": "#/$defs/non_empty" },
        "target_aureline_version_max": { "$ref": "#/$defs/non_empty" },
        "sdk_line_id": { "$ref": "#/$defs/non_empty" },
        "bridge_state": { "$ref": "#/$defs/non_empty" },
        "deprecated_apis": {
          "type": "array",
          "items": { "$ref": "#/$defs/deprecated_api" }
        },
        "required_shims": {
          "type": "array",
          "items": { "$ref": "#/$defs/required_shim" }
        },
        "migration_impact_summary": { "$ref": "#/$defs/non_empty" }
      }
    }
  }
}
