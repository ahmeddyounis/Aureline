{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/conformance_kit_report.schema.json",
  "title": "Aureline extension conformance validator report",
  "description": "Machine-readable output emitted by the beta extension conformance validator for one manifest or for a fixture suite.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/extension_conformance_report"
    },
    {
      "$ref": "#/$defs/extension_conformance_suite_report"
    }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty": {
      "type": "string",
      "minLength": 1
    },
    "result_class": {
      "type": "string",
      "enum": ["pass", "warn", "fail"]
    },
    "compatibility_badge_class": {
      "type": "string",
      "enum": ["compatible_on_declared_targets", "unsupported_pending_qualification"]
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "suite", "status", "severity", "message"],
      "properties": {
        "check_id": {
          "$ref": "#/$defs/non_empty"
        },
        "suite": {
          "type": "string",
          "enum": [
            "manifest_shape",
            "permission_declarations",
            "lifecycle_metadata",
            "compatibility_targets",
            "conformance_fixtures"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "warn", "not_applicable"]
        },
        "severity": {
          "type": "string",
          "enum": ["blocker", "warning", "info"]
        },
        "message": {
          "$ref": "#/$defs/non_empty"
        },
        "field": {
          "$ref": "#/$defs/non_empty"
        },
        "fix": {
          "$ref": "#/$defs/non_empty"
        }
      }
    },
    "extension_conformance_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "conformance_kit_report_schema_version",
        "validator_id",
        "validator_version",
        "generated_at",
        "subject_manifest_ref",
        "result_class",
        "compatibility_badge_class",
        "red_flag_classes",
        "summary",
        "checks"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "extension_conformance_report"
        },
        "conformance_kit_report_schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "validator_id": {
          "$ref": "#/$defs/non_empty"
        },
        "validator_version": {
          "$ref": "#/$defs/non_empty"
        },
        "generated_at": {
          "$ref": "#/$defs/non_empty"
        },
        "subject_manifest_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "package_id": {
          "type": ["string", "null"]
        },
        "publisher_id": {
          "type": ["string", "null"]
        },
        "extension_version": {
          "type": ["string", "null"]
        },
        "runtime_origin": {
          "type": ["string", "null"]
        },
        "host_contract_family": {
          "type": ["string", "null"]
        },
        "result_class": {
          "$ref": "#/$defs/result_class"
        },
        "compatibility_badge_class": {
          "$ref": "#/$defs/compatibility_badge_class"
        },
        "red_flag_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "missing_manifest_shape",
              "opaque_publisher_identity",
              "undeclared_privileged_permission",
              "missing_lifecycle_metadata",
              "incompatible_sdk_target",
              "missing_disable_or_rollback"
            ]
          }
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed", "failed", "warnings", "blockers"],
          "properties": {
            "passed": {
              "type": "integer",
              "minimum": 0
            },
            "failed": {
              "type": "integer",
              "minimum": 0
            },
            "warnings": {
              "type": "integer",
              "minimum": 0
            },
            "blockers": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/check"
          }
        }
      }
    },
    "extension_conformance_suite_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "conformance_kit_report_schema_version",
        "validator_id",
        "validator_version",
        "suite_id",
        "generated_at",
        "suite_manifest_ref",
        "suite_result_class",
        "required_scenario_classes",
        "observed_scenario_classes",
        "case_count",
        "case_results",
        "unexpected_results",
        "aggregate_blocker_count"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "extension_conformance_suite_report"
        },
        "conformance_kit_report_schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "validator_id": {
          "$ref": "#/$defs/non_empty"
        },
        "validator_version": {
          "$ref": "#/$defs/non_empty"
        },
        "suite_id": {
          "$ref": "#/$defs/non_empty"
        },
        "generated_at": {
          "$ref": "#/$defs/non_empty"
        },
        "suite_manifest_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "suite_result_class": {
          "$ref": "#/$defs/result_class"
        },
        "required_scenario_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["install", "activation", "permission_prompt", "degraded_path", "disable_rollback"]
          }
        },
        "observed_scenario_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["install", "activation", "permission_prompt", "degraded_path", "disable_rollback"]
          }
        },
        "case_count": {
          "type": "integer",
          "minimum": 1
        },
        "case_results": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "case_id",
              "manifest_ref",
              "expected_result_class",
              "observed_result_class",
              "matched_expectation",
              "blocker_count",
              "failed_check_count",
              "compatibility_badge_class",
              "red_flag_classes"
            ],
            "properties": {
              "case_id": {
                "$ref": "#/$defs/non_empty"
              },
              "manifest_ref": {
                "$ref": "#/$defs/non_empty"
              },
              "expected_result_class": {
                "$ref": "#/$defs/result_class"
              },
              "observed_result_class": {
                "$ref": "#/$defs/result_class"
              },
              "matched_expectation": {
                "type": "boolean"
              },
              "blocker_count": {
                "type": "integer",
                "minimum": 0
              },
              "failed_check_count": {
                "type": "integer",
                "minimum": 0
              },
              "compatibility_badge_class": {
                "$ref": "#/$defs/compatibility_badge_class"
              },
              "red_flag_classes": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/non_empty"
                }
              }
            }
          }
        },
        "unexpected_results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "aggregate_blocker_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
