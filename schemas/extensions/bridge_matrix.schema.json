{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/bridge_matrix.schema.json",
  "title": "Aureline extension bridge matrix",
  "description": "Machine-readable matrix for beta extension runtime, SDK, manifest, bridge compatibility windows, and lifecycle governance refs. Bridge and shimmed rows must carry explicit non-parity labels, and each row must cite lifecycle metadata so support windows and deprecations do not drift.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "matrix_id",
    "matrix_revision",
    "report_id",
    "release_channel_scope",
    "as_of",
    "generated_at",
    "source_report_ref",
    "extension_report_ref",
    "docs_projection_ref",
    "schema_ref",
    "lifecycle_metadata_ref",
    "versioning_policy_ref",
    "deprecation_packet_template_ref",
    "consuming_surfaces",
    "bridge_state_vocabulary",
    "compatibility_label_vocabulary",
    "parity_claim_vocabulary",
    "rows"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "extension_bridge_matrix" },
    "matrix_id": { "type": "string", "pattern": "^extension_bridge_matrix:" },
    "matrix_revision": { "type": "integer", "minimum": 1 },
    "report_id": { "type": "string", "pattern": "^extension_compatibility_report:" },
    "release_channel_scope": { "type": "string", "const": "beta" },
    "as_of": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "owner": { "$ref": "#/$defs/non_empty_string" },
    "source_report_ref": { "$ref": "#/$defs/non_empty_string" },
    "extension_report_ref": { "$ref": "#/$defs/non_empty_string" },
    "docs_projection_ref": { "$ref": "#/$defs/non_empty_string" },
    "schema_ref": { "$ref": "#/$defs/non_empty_string" },
    "lifecycle_metadata_ref": {
      "type": "string",
      "const": "artifacts/extensions/m3/lifecycle_metadata_packet.json"
    },
    "versioning_policy_ref": {
      "type": "string",
      "const": "docs/extensions/m3/sdk_versioning_and_deprecation.md"
    },
    "deprecation_packet_template_ref": {
      "type": "string",
      "const": "artifacts/extensions/m3/deprecation_packet_template.md"
    },
    "consuming_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "bridge_state_vocabulary": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/bridge_state_class" }
    },
    "compatibility_label_vocabulary": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/compatibility_label" }
    },
    "parity_claim_vocabulary": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/parity_claim_class" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/bridge_matrix_row" }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "bridge_state_class": {
      "type": "string",
      "enum": ["native", "bridge", "shimmed", "partial", "unsupported"]
    },
    "compatibility_label": {
      "type": "string",
      "enum": ["exact", "translated", "partial", "shimmed", "unsupported"]
    },
    "parity_claim_class": {
      "type": "string",
      "enum": [
        "native_exact_where_declared",
        "bridge_no_exact_parity",
        "shimmed_no_exact_parity",
        "partial_no_exact_parity",
        "unsupported_no_parity"
      ]
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_id",
        "version_range",
        "support_window_class",
        "downgrade_behavior",
        "out_of_window_posture",
        "contract_rule"
      ],
      "properties": {
        "window_id": { "$ref": "#/$defs/non_empty_string" },
        "version_range": { "$ref": "#/$defs/non_empty_string" },
        "support_window_class": { "$ref": "#/$defs/non_empty_string" },
        "downgrade_behavior": { "$ref": "#/$defs/non_empty_string" },
        "out_of_window_posture": { "$ref": "#/$defs/non_empty_string" },
        "contract_rule": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "bridge_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_id",
        "bridge_state_class",
        "compatibility_label",
        "parity_claim_class",
        "source_ecosystem",
        "supported_artifact_classes",
        "known_limits",
        "permission_delta",
        "performance_delta",
        "report_action_ref"
      ],
      "properties": {
        "window_id": { "$ref": "#/$defs/non_empty_string" },
        "bridge_state_class": { "$ref": "#/$defs/bridge_state_class" },
        "compatibility_label": { "$ref": "#/$defs/compatibility_label" },
        "parity_claim_class": { "$ref": "#/$defs/parity_claim_class" },
        "source_ecosystem": { "$ref": "#/$defs/non_empty_string" },
        "supported_artifact_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "known_limits": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "permission_delta": { "$ref": "#/$defs/non_empty_string" },
        "performance_delta": { "$ref": "#/$defs/non_empty_string" },
        "report_action_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "downgrade_behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_class",
        "out_of_window_posture",
        "state_preservation_note",
        "contract_rule",
        "default_repair_hints"
      ],
      "properties": {
        "support_class": { "$ref": "#/$defs/non_empty_string" },
        "out_of_window_posture": { "$ref": "#/$defs/non_empty_string" },
        "state_preservation_note": { "$ref": "#/$defs/non_empty_string" },
        "contract_rule": { "$ref": "#/$defs/non_empty_string" },
        "default_repair_hints": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "bridge_matrix_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "claimed_lane",
        "package_or_lane_id",
        "report_row_ref",
        "support_class",
        "runtime_window",
        "sdk_window",
        "manifest_window",
        "bridge_window",
        "downgrade_behavior",
        "evidence_refs",
        "lifecycle_row_refs",
        "marketplace_surface_refs",
        "sdk_doc_refs",
        "release_packet_refs",
        "support_export_refs",
        "notes"
      ],
      "properties": {
        "row_id": { "type": "string", "pattern": "^extension_bridge_row:" },
        "claimed_lane": { "$ref": "#/$defs/non_empty_string" },
        "package_or_lane_id": { "$ref": "#/$defs/non_empty_string" },
        "report_row_ref": { "type": "string", "pattern": "^compat_row:" },
        "support_class": { "$ref": "#/$defs/non_empty_string" },
        "runtime_window": { "$ref": "#/$defs/window" },
        "sdk_window": { "$ref": "#/$defs/window" },
        "manifest_window": { "$ref": "#/$defs/window" },
        "bridge_window": { "$ref": "#/$defs/bridge_window" },
        "downgrade_behavior": { "$ref": "#/$defs/downgrade_behavior" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "lifecycle_row_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^lifecycle_row:"
          }
        },
        "marketplace_surface_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "sdk_doc_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "release_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "support_export_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "bridge_window": {
                "properties": {
                  "bridge_state_class": { "const": "native" }
                },
                "required": ["bridge_state_class"]
              }
            },
            "required": ["bridge_window"]
          },
          "then": {
            "properties": {
              "bridge_window": {
                "properties": {
                  "compatibility_label": { "const": "exact" },
                  "parity_claim_class": { "const": "native_exact_where_declared" }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "bridge_window": {
                "properties": {
                  "bridge_state_class": {
                    "enum": ["bridge", "shimmed", "partial", "unsupported"]
                  }
                },
                "required": ["bridge_state_class"]
              }
            },
            "required": ["bridge_window"]
          },
          "then": {
            "properties": {
              "bridge_window": {
                "properties": {
                  "compatibility_label": {
                    "enum": ["translated", "partial", "shimmed", "unsupported"]
                  },
                  "known_limits": { "minItems": 1 }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "bridge_window": {
                "properties": {
                  "bridge_state_class": { "const": "bridge" }
                },
                "required": ["bridge_state_class"]
              }
            },
            "required": ["bridge_window"]
          },
          "then": {
            "properties": {
              "bridge_window": {
                "properties": {
                  "compatibility_label": { "const": "translated" },
                  "parity_claim_class": { "const": "bridge_no_exact_parity" }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "bridge_window": {
                "properties": {
                  "bridge_state_class": { "const": "shimmed" }
                },
                "required": ["bridge_state_class"]
              }
            },
            "required": ["bridge_window"]
          },
          "then": {
            "properties": {
              "bridge_window": {
                "properties": {
                  "compatibility_label": { "const": "shimmed" },
                  "parity_claim_class": { "const": "shimmed_no_exact_parity" }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "bridge_window": {
                "properties": {
                  "bridge_state_class": { "const": "partial" }
                },
                "required": ["bridge_state_class"]
              }
            },
            "required": ["bridge_window"]
          },
          "then": {
            "properties": {
              "bridge_window": {
                "properties": {
                  "compatibility_label": { "const": "partial" },
                  "parity_claim_class": { "const": "partial_no_exact_parity" }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "bridge_window": {
                "properties": {
                  "bridge_state_class": { "const": "unsupported" }
                },
                "required": ["bridge_state_class"]
              }
            },
            "required": ["bridge_window"]
          },
          "then": {
            "properties": {
              "bridge_window": {
                "properties": {
                  "compatibility_label": { "const": "unsupported" },
                  "parity_claim_class": { "const": "unsupported_no_parity" }
                }
              }
            }
          }
        }
      ]
    }
  }
}
