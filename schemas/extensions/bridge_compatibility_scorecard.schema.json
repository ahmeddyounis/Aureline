{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/bridge_compatibility_scorecard.schema.json",
  "title": "Aureline native vs compatibility-bridge scorecard (beta lane)",
  "description": "Machine-readable scorecard that separates native-runtime support from compatibility-bridge support per claimed ecosystem lane so release notes, marketplace surfaces, and support packets cannot collapse native and bridge rows behind one undifferentiated green label. The scorecard is generated from artifacts/compat/m3/bridge_matrix.yaml; this is the typed cross-tool boundary the SDK conformance packet, support exports, and release evidence read. Adding a new enum member or an additive optional field is additive-minor with a bridge_compatibility_scorecard_schema_version bump.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "bridge_compatibility_scorecard_schema_version",
    "scorecard_id",
    "packet_ref",
    "matrix_ref",
    "matrix_revision",
    "release_channel_scope",
    "as_of",
    "generated_at",
    "scorecard_class_vocabulary",
    "lanes",
    "redaction_class"
  ],
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "bridge_compatibility_scorecard"
    },
    "bridge_compatibility_scorecard_schema_version": {
      "type": "integer",
      "const": 1
    },
    "scorecard_id": {
      "type": "string",
      "pattern": "^bridge_compatibility_scorecard:"
    },
    "packet_ref": {
      "type": "string",
      "minLength": 1
    },
    "matrix_ref": {
      "type": "string",
      "minLength": 1
    },
    "matrix_revision": {
      "type": "integer",
      "minimum": 1
    },
    "release_channel_scope": {
      "type": "string",
      "enum": ["beta", "stable"]
    },
    "as_of": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "scorecard_class_vocabulary": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "native_green",
          "bridge_amber",
          "shimmed_amber",
          "partial_amber",
          "unsupported_red"
        ]
      }
    },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scorecard_lane" }
    },
    "redaction_class": {
      "type": "string",
      "const": "metadata_safe_default"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "scorecard_class": {
      "type": "string",
      "enum": [
        "native_green",
        "bridge_amber",
        "shimmed_amber",
        "partial_amber",
        "unsupported_red"
      ]
    },
    "bridge_state_class": {
      "type": "string",
      "enum": ["native", "bridge", "shimmed", "partial", "unsupported"]
    },
    "scorecard_lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "lane_label",
        "package_or_lane_id",
        "support_class",
        "bridge_state_class",
        "compatibility_label",
        "parity_claim_class",
        "scorecard_class",
        "native_runtime_check_class",
        "compatibility_bridge_check_class",
        "supported_artifact_classes",
        "known_limits",
        "non_green_reasons",
        "downgrade_behavior_summary",
        "lifecycle_row_refs",
        "evidence_refs",
        "consuming_surface_refs"
      ],
      "properties": {
        "row_id": {
          "type": "string",
          "pattern": "^extension_bridge_row:"
        },
        "lane_label": { "$ref": "#/$defs/non_empty_string" },
        "package_or_lane_id": { "$ref": "#/$defs/non_empty_string" },
        "support_class": { "$ref": "#/$defs/non_empty_string" },
        "bridge_state_class": { "$ref": "#/$defs/bridge_state_class" },
        "compatibility_label": { "$ref": "#/$defs/non_empty_string" },
        "parity_claim_class": { "$ref": "#/$defs/non_empty_string" },
        "scorecard_class": { "$ref": "#/$defs/scorecard_class" },
        "native_runtime_check_class": {
          "type": "string",
          "enum": [
            "native_supported",
            "native_not_applicable",
            "native_unsupported"
          ]
        },
        "compatibility_bridge_check_class": {
          "type": "string",
          "enum": [
            "bridge_not_applicable",
            "bridge_translated_with_caveats",
            "bridge_shimmed_static_only",
            "bridge_partial_subset_documented",
            "bridge_unsupported"
          ]
        },
        "supported_artifact_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "known_limits": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "non_green_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "downgrade_behavior_summary": { "$ref": "#/$defs/non_empty_string" },
        "lifecycle_row_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "consuming_surface_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      },
      "allOf": [
        {
          "description": "native rows MUST receive scorecard_class native_green, native_supported native_runtime_check_class, and bridge_not_applicable compatibility_bridge_check_class.",
          "if": {
            "properties": { "bridge_state_class": { "const": "native" } },
            "required": ["bridge_state_class"]
          },
          "then": {
            "properties": {
              "scorecard_class": { "const": "native_green" },
              "native_runtime_check_class": { "const": "native_supported" },
              "compatibility_bridge_check_class": { "const": "bridge_not_applicable" },
              "non_green_reasons": { "maxItems": 0 }
            }
          }
        },
        {
          "description": "bridge rows MUST receive scorecard_class bridge_amber and bridge_translated_with_caveats.",
          "if": {
            "properties": { "bridge_state_class": { "const": "bridge" } },
            "required": ["bridge_state_class"]
          },
          "then": {
            "properties": {
              "scorecard_class": { "const": "bridge_amber" },
              "compatibility_bridge_check_class": { "const": "bridge_translated_with_caveats" }
            }
          }
        },
        {
          "description": "shimmed rows MUST receive scorecard_class shimmed_amber and bridge_shimmed_static_only.",
          "if": {
            "properties": { "bridge_state_class": { "const": "shimmed" } },
            "required": ["bridge_state_class"]
          },
          "then": {
            "properties": {
              "scorecard_class": { "const": "shimmed_amber" },
              "compatibility_bridge_check_class": { "const": "bridge_shimmed_static_only" }
            }
          }
        },
        {
          "description": "partial rows MUST receive scorecard_class partial_amber and bridge_partial_subset_documented.",
          "if": {
            "properties": { "bridge_state_class": { "const": "partial" } },
            "required": ["bridge_state_class"]
          },
          "then": {
            "properties": {
              "scorecard_class": { "const": "partial_amber" },
              "compatibility_bridge_check_class": { "const": "bridge_partial_subset_documented" }
            }
          }
        },
        {
          "description": "unsupported rows MUST receive scorecard_class unsupported_red, native_unsupported, and bridge_unsupported.",
          "if": {
            "properties": { "bridge_state_class": { "const": "unsupported" } },
            "required": ["bridge_state_class"]
          },
          "then": {
            "properties": {
              "scorecard_class": { "const": "unsupported_red" },
              "native_runtime_check_class": { "const": "native_unsupported" },
              "compatibility_bridge_check_class": { "const": "bridge_unsupported" },
              "non_green_reasons": { "minItems": 1 }
            }
          }
        }
      ]
    }
  }
}
