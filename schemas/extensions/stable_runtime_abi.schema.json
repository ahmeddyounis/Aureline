{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/stable_runtime_abi.schema.json",
  "title": "Aureline stable extension runtime-ABI packet",
  "description": "Cross-tool boundary schema for the stable extension runtime-ABI packet emitted by crates/aureline-extensions. One packet binds a stable_runtime_abi_identity (which pins the stabilized runtime v1 beta admission contract, the published ABI contract version, the publisher trust tier, and the lifecycle state), a stable_runtime_class_declaration carrying the published runtime class (passive_package / wasm_capability_sandbox / declarative_host_rendered_view / external_host / compatibility_bridge / remote_side_component) and its execution locus, a stable_sandbox_profile_binding carrying the published sandbox_profile_id, its backend classification, and a fail-closed enforcement state, a stable_capability_envelope that never widens (granted ⊆ negotiated ⊆ declared), a stable_host_isolation_posture, a stable_runtime_activation_budget, the active-contribution inspector entries (each attributable even when quarantined, bridged, or downgraded), the stable_runtime_abi_qualification_claim after the posture is applied (with automatic narrowing below Stable), a stable_downgraded_host_banner, and an inspection projection. A stable effective tier may only render when the row pins the published ABI version, is enforcement-backed, enforces its sandbox profile as published, keeps its trust tier out of quarantine, stays runnable, keeps every contribution nominal, holds a bounded activation cost, and is fully attributed. A claimed sandboxed runtime class may never widen to ambient full-user execution; when a platform/backend cannot enforce the published profile it fails closed (fail_closed_downgraded or unenforceable_refused) and raises a downgraded-host banner. The Rust types in crates/aureline-extensions/src/stabilize_extension_runtime_v1_abi_capability_envelopes_and/ are the source of truth. Raw manifest bytes, raw signatures, raw policy bodies, raw paths, raw tokens, raw runtime payload bytes, and raw publisher-private data MUST NOT appear in any record; records carry refs only.",
  "type": "object",
  "$ref": "#/$defs/stable_runtime_abi_packet",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log and safe in support/export packets."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "runtime_class": {
      "type": "string",
      "enum": [
        "passive_package",
        "wasm_capability_sandbox",
        "declarative_host_rendered_view",
        "external_host",
        "compatibility_bridge",
        "remote_side_component"
      ]
    },
    "execution_locus_class": {
      "type": "string",
      "enum": [
        "editor_in_process_isolated",
        "dedicated_subprocess",
        "helper_binary",
        "remote_agent",
        "bridged_foreign_runtime",
        "host_rendered_no_extension_code",
        "passive_no_execution"
      ]
    },
    "backend_classification_class": {
      "type": "string",
      "enum": [
        "wasm_component_model",
        "wasm_core_module",
        "os_process_sandbox",
        "seatbelt_sandbox_profile",
        "landlock_seccomp_profile",
        "app_container_profile",
        "remote_enforced_envelope",
        "bridge_translated_profile",
        "none_passive"
      ]
    },
    "sandbox_enforcement_state_class": {
      "type": "string",
      "enum": ["enforced_as_published", "fail_closed_downgraded", "unenforceable_refused"]
    },
    "trust_tier_class": {
      "type": "string",
      "enum": ["verified_publisher", "known_publisher", "community_unverified", "quarantined"]
    },
    "lifecycle_state_class": {
      "type": "string",
      "enum": [
        "installed",
        "pending_activation",
        "active",
        "recovered",
        "degraded",
        "disabled",
        "quarantined",
        "removed",
        "publisher_blocked"
      ]
    },
    "contribution_kind_class": {
      "type": "string",
      "enum": ["command", "panel", "provider", "background_lane", "view"]
    },
    "contribution_host_state_class": {
      "type": "string",
      "enum": [
        "running_nominal",
        "bridged",
        "downgraded_narrower_profile",
        "quarantined",
        "failed"
      ]
    },
    "isolation_boundary_class": {
      "type": "string",
      "enum": [
        "in_process_capability_world",
        "process_isolated",
        "remote_envelope",
        "bridge_translated",
        "passive_none"
      ]
    },
    "restart_posture_class": {
      "type": "string",
      "enum": [
        "no_restart_attempted",
        "one_warm_restart_under_budget",
        "exponential_backoff_bounded"
      ]
    },
    "activation_budget_class": {
      "type": "string",
      "enum": ["within_budget", "approaching_budget", "over_budget_throttled", "unbounded_refused"]
    },
    "stability_tier": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "claim_basis_class": {
      "type": "string",
      "enum": ["enforcement_backed", "catalog_asserted_only"]
    },
    "support_claim_class": {
      "type": "string",
      "enum": [
        "stable_runtime_ready_claim",
        "beta_runtime_partial_claim",
        "preview_runtime_experimental_claim",
        "withdrawn_no_runtime_claim"
      ]
    },
    "downgrade_reason": {
      "type": "string",
      "enum": [
        "abi_version_mismatch",
        "catalog_only_trust_not_enforcement_backed",
        "sandbox_fail_closed_downgraded",
        "sandbox_unenforceable",
        "trust_tier_quarantined",
        "lifecycle_not_runnable",
        "contribution_quarantined",
        "contribution_host_downgraded",
        "activation_cost_over_budget",
        "activation_cost_unbounded",
        "attribution_incomplete"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "install_review",
        "runtime_inspector",
        "quarantine_flow",
        "diagnostics",
        "support_export",
        "docs_help_surface",
        "release_packet",
        "cli_inspector"
      ]
    },
    "ref_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_id" }
    },
    "stable_runtime_abi_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "runtime_contract_ref",
        "extension_identity_ref",
        "extension_version",
        "source_package_ref",
        "abi_contract_version",
        "publisher_trust_tier_class",
        "lifecycle_state_class"
      ],
      "properties": {
        "record_kind": { "const": "stable_runtime_abi_identity" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "runtime_contract_ref": {
          "type": "string",
          "pattern": "^runtime_v1_beta:"
        },
        "extension_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "extension_version": { "$ref": "#/$defs/opaque_id" },
        "source_package_ref": { "$ref": "#/$defs/opaque_id" },
        "abi_contract_version": { "type": "integer", "minimum": 0 },
        "publisher_trust_tier_class": { "$ref": "#/$defs/trust_tier_class" },
        "lifecycle_state_class": { "$ref": "#/$defs/lifecycle_state_class" }
      }
    },
    "stable_runtime_class_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_kind", "schema_version", "runtime_class", "execution_locus_class"],
      "properties": {
        "record_kind": { "const": "stable_runtime_class_declaration" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "runtime_class": { "$ref": "#/$defs/runtime_class" },
        "execution_locus_class": { "$ref": "#/$defs/execution_locus_class" }
      }
    },
    "stable_sandbox_profile_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "sandbox_profile_id",
        "backend_classification_class",
        "enforcement_state_class",
        "platform_backend_label",
        "widens_to_ambient_full_user"
      ],
      "properties": {
        "record_kind": { "const": "stable_sandbox_profile_binding" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "sandbox_profile_id": { "$ref": "#/$defs/opaque_id" },
        "backend_classification_class": { "$ref": "#/$defs/backend_classification_class" },
        "enforcement_state_class": { "$ref": "#/$defs/sandbox_enforcement_state_class" },
        "platform_backend_label": { "$ref": "#/$defs/reviewable_label" },
        "widens_to_ambient_full_user": { "const": false }
      }
    },
    "stable_capability_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "declared_capability_refs",
        "negotiated_capability_refs",
        "granted_capability_refs",
        "narrowing_reasons_recorded"
      ],
      "properties": {
        "record_kind": { "const": "stable_capability_envelope" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "declared_capability_refs": { "$ref": "#/$defs/ref_list" },
        "negotiated_capability_refs": { "$ref": "#/$defs/ref_list" },
        "granted_capability_refs": { "$ref": "#/$defs/ref_list" },
        "narrowing_reasons_recorded": { "type": "boolean" }
      }
    },
    "stable_host_isolation_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "isolation_boundary_class",
        "restart_posture_class",
        "restart_attempt_count"
      ],
      "properties": {
        "record_kind": { "const": "stable_host_isolation_posture" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "isolation_boundary_class": { "$ref": "#/$defs/isolation_boundary_class" },
        "restart_posture_class": { "$ref": "#/$defs/restart_posture_class" },
        "restart_attempt_count": { "type": "integer", "minimum": 0 }
      }
    },
    "stable_runtime_activation_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "budget_class",
        "declared_cost_ref",
        "observed_cost_ref"
      ],
      "properties": {
        "record_kind": { "const": "stable_runtime_activation_budget" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "budget_class": { "$ref": "#/$defs/activation_budget_class" },
        "declared_cost_ref": { "$ref": "#/$defs/opaque_id" },
        "observed_cost_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "stable_active_contribution_inspector_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "contribution_id",
        "contribution_kind_class",
        "source_package_ref",
        "runtime_class",
        "execution_locus_class",
        "trust_tier_class",
        "used_permission_refs",
        "last_known_good_host_ref",
        "host_state_class",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_active_contribution_inspector_entry" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "contribution_id": { "$ref": "#/$defs/opaque_id" },
        "contribution_kind_class": { "$ref": "#/$defs/contribution_kind_class" },
        "source_package_ref": { "$ref": "#/$defs/opaque_id" },
        "runtime_class": { "$ref": "#/$defs/runtime_class" },
        "execution_locus_class": { "$ref": "#/$defs/execution_locus_class" },
        "trust_tier_class": { "$ref": "#/$defs/trust_tier_class" },
        "used_permission_refs": { "$ref": "#/$defs/ref_list" },
        "last_known_good_host_ref": { "$ref": "#/$defs/opaque_id" },
        "host_state_class": { "$ref": "#/$defs/contribution_host_state_class" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "stable_runtime_abi_qualification_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "claimed_tier",
        "effective_tier",
        "support_claim_class",
        "claim_basis_class",
        "downgraded",
        "downgrade_reasons",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_runtime_abi_qualification_claim" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "claimed_tier": { "$ref": "#/$defs/stability_tier" },
        "effective_tier": { "$ref": "#/$defs/stability_tier" },
        "support_claim_class": { "$ref": "#/$defs/support_claim_class" },
        "claim_basis_class": { "$ref": "#/$defs/claim_basis_class" },
        "downgraded": { "type": "boolean" },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason" }
        },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "stable_downgraded_host_banner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_kind", "schema_version", "must_display", "summary_label"],
      "properties": {
        "record_kind": { "const": "stable_downgraded_host_banner" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "must_display": { "type": "boolean" },
        "banner_reason_class": { "$ref": "#/$defs/downgrade_reason" },
        "last_known_good_host_ref": { "$ref": "#/$defs/opaque_id" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "stable_runtime_abi_inspection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id_ref",
        "runtime_class",
        "execution_locus_class",
        "effective_tier",
        "stable_claim",
        "abi_version_current",
        "sandbox_enforced_as_published",
        "widens_to_ambient_full_user",
        "capability_envelope_well_formed",
        "trust_tier_class",
        "lifecycle_runnable",
        "downgraded",
        "downgraded_host_banner_required",
        "attribution_complete",
        "active_contribution_count",
        "quarantined_contribution_count",
        "downgraded_contribution_count",
        "declared_capability_count",
        "negotiated_capability_count",
        "granted_capability_count",
        "activation_budget_class",
        "summary_label"
      ],
      "properties": {
        "record_kind": { "const": "stable_runtime_abi_inspection" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id_ref": { "$ref": "#/$defs/opaque_id" },
        "runtime_class": { "$ref": "#/$defs/runtime_class" },
        "execution_locus_class": { "$ref": "#/$defs/execution_locus_class" },
        "effective_tier": { "$ref": "#/$defs/stability_tier" },
        "stable_claim": { "type": "boolean" },
        "abi_version_current": { "type": "boolean" },
        "sandbox_enforced_as_published": { "type": "boolean" },
        "widens_to_ambient_full_user": { "const": false },
        "capability_envelope_well_formed": { "type": "boolean" },
        "trust_tier_class": { "$ref": "#/$defs/trust_tier_class" },
        "lifecycle_runnable": { "type": "boolean" },
        "downgraded": { "type": "boolean" },
        "downgraded_host_banner_required": { "type": "boolean" },
        "attribution_complete": { "type": "boolean" },
        "active_contribution_count": { "type": "integer", "minimum": 0 },
        "quarantined_contribution_count": { "type": "integer", "minimum": 0 },
        "downgraded_contribution_count": { "type": "integer", "minimum": 0 },
        "declared_capability_count": { "type": "integer", "minimum": 0 },
        "negotiated_capability_count": { "type": "integer", "minimum": 0 },
        "granted_capability_count": { "type": "integer", "minimum": 0 },
        "activation_budget_class": { "$ref": "#/$defs/activation_budget_class" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "stable_runtime_abi_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "generated_at",
        "identity",
        "runtime_class_declaration",
        "sandbox_profile",
        "capability_envelope",
        "host_isolation",
        "activation_budget",
        "contributions",
        "claim",
        "downgraded_host_banner",
        "consumer_surfaces",
        "source_schema_refs",
        "allows_ambient_full_user_widening",
        "allows_catalog_only_trust",
        "allows_unbounded_activation_cost",
        "allows_silent_host_downgrade",
        "inspection"
      ],
      "properties": {
        "record_kind": { "const": "stable_runtime_abi_packet" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "identity": { "$ref": "#/$defs/stable_runtime_abi_identity" },
        "runtime_class_declaration": { "$ref": "#/$defs/stable_runtime_class_declaration" },
        "sandbox_profile": { "$ref": "#/$defs/stable_sandbox_profile_binding" },
        "capability_envelope": { "$ref": "#/$defs/stable_capability_envelope" },
        "host_isolation": { "$ref": "#/$defs/stable_host_isolation_posture" },
        "activation_budget": { "$ref": "#/$defs/stable_runtime_activation_budget" },
        "contributions": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_active_contribution_inspector_entry" }
        },
        "claim": { "$ref": "#/$defs/stable_runtime_abi_qualification_claim" },
        "downgraded_host_banner": { "$ref": "#/$defs/stable_downgraded_host_banner" },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/consumer_surface" }
        },
        "source_schema_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "allows_ambient_full_user_widening": { "const": false },
        "allows_catalog_only_trust": { "const": false },
        "allows_unbounded_activation_cost": { "const": false },
        "allows_silent_host_downgrade": { "const": false },
        "inspection": { "$ref": "#/$defs/stable_runtime_abi_inspection" }
      }
    }
  }
}
