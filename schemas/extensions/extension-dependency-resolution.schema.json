{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/extension-dependency-resolution.schema.json",
  "title": "Aureline stable extension dependency-resolution and publisher-continuity packet",
  "description": "Cross-tool boundary schema for deterministic extension dependency resolution, effective-permission inheritance, publisher-continuity workflows, revocation and last-known-good pinning, and deprecation propagation across public, mirrored, and enterprise-curated installs. Raw artifact bytes, raw signing keys, raw paths, raw policy bundle bytes, and private publisher material are excluded; records carry refs only.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "identity",
    "resolution",
    "permissions",
    "continuity",
    "revocation",
    "deprecation",
    "claim",
    "consumer_surfaces",
    "source_schema_refs",
    "banner_required",
    "allows_top_level_manifest_only_risk",
    "allows_silent_dependency_permission_widening",
    "allows_ungated_high_trust_auto_update_after_continuity_change",
    "inspection",
    "summary_label"
  ],
  "properties": {
    "record_kind": { "const": "extension_dependency_resolution_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/opaque_id" },
    "generated_at": { "type": "string", "format": "date-time" },
    "identity": { "$ref": "#/$defs/identity" },
    "resolution": { "$ref": "#/$defs/resolution" },
    "permissions": { "$ref": "#/$defs/permissions" },
    "continuity": { "$ref": "#/$defs/continuity" },
    "revocation": { "$ref": "#/$defs/revocation" },
    "deprecation": { "$ref": "#/$defs/deprecation" },
    "claim": { "$ref": "#/$defs/claim" },
    "consumer_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/consumer_surface" }
    },
    "source_schema_refs": {
      "type": "array",
      "minItems": 1,
      "contains": { "const": "schemas/extensions/extension-dependency-resolution.schema.json" },
      "items": { "$ref": "#/$defs/opaque_id" }
    },
    "banner_required": { "type": "boolean" },
    "allows_top_level_manifest_only_risk": { "const": false },
    "allows_silent_dependency_permission_widening": { "const": false },
    "allows_ungated_high_trust_auto_update_after_continuity_change": { "const": false },
    "inspection": { "$ref": "#/$defs/inspection" },
    "summary_label": { "$ref": "#/$defs/label" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "install_flow_class": {
      "type": "string",
      "enum": [
        "public_install",
        "public_update",
        "mirrored_install",
        "mirrored_update",
        "enterprise_curated_install",
        "enterprise_curated_update",
        "rollback",
        "mirror_promotion"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": ["public_registry", "approved_mirror", "enterprise_curated"]
    },
    "resolver_determinism_class": {
      "type": "string",
      "enum": ["deterministic", "nondeterministic", "not_resolved"]
    },
    "edge_class": {
      "type": "string",
      "enum": ["root", "hard_dependency", "optional_integration"]
    },
    "resolution_state_class": {
      "type": "string",
      "enum": ["resolved", "unresolved_missing", "version_conflict", "optional_absent"]
    },
    "reconsent_state_class": {
      "type": "string",
      "enum": ["not_required", "required_obtained", "required_pending", "required_missing"]
    },
    "continuity_workflow_class": {
      "type": "string",
      "enum": [
        "none",
        "key_rotation",
        "ownership_transfer",
        "namespace_dispute",
        "maintainer_removal",
        "orphan_adoption",
        "approved_mirror_succession"
      ]
    },
    "continuity_state_class": {
      "type": "string",
      "enum": [
        "current",
        "in_cooldown",
        "pending_review",
        "pending_notification",
        "disputed",
        "revoked",
        "stale",
        "missing"
      ]
    },
    "yank_revocation_state_class": {
      "type": "string",
      "enum": ["clean", "advisory", "yanked", "quarantined", "revoked"]
    },
    "revocation_propagation_class": {
      "type": "string",
      "enum": ["not_applicable", "propagated_all_sources", "partial", "not_propagated"]
    },
    "downgrade_hold_behavior_class": {
      "type": "string",
      "enum": ["explicit_policy_allowed", "explicit_policy_denied", "hidden_or_implicit"]
    },
    "api_deprecation_state_class": {
      "type": "string",
      "enum": ["none", "warning", "sunset_scheduled", "removed"]
    },
    "stability_tier": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "claim_basis_class": {
      "type": "string",
      "enum": ["evidence_backed", "catalog_asserted_only"]
    },
    "support_claim_class": {
      "type": "string",
      "enum": [
        "stable_dependency_resolution_claim",
        "beta_dependency_resolution_partial_claim",
        "preview_dependency_resolution_experimental_claim",
        "withdrawn_no_dependency_resolution_claim"
      ]
    },
    "downgrade_reason": {
      "type": "string",
      "enum": [
        "contract_version_not_published",
        "catalog_only_claim_basis",
        "resolver_nondeterministic",
        "resolver_not_resolved",
        "unresolved_hard_dependency",
        "version_conflict_dependency",
        "lock_export_unavailable",
        "team_rollout_unsupported",
        "air_gapped_rollout_unsupported",
        "permission_widening_without_reconsent",
        "publisher_continuity_in_cooldown",
        "publisher_continuity_pending_review",
        "publisher_continuity_pending_notification",
        "publisher_continuity_disputed",
        "publisher_continuity_revoked",
        "publisher_continuity_missing_or_stale",
        "continuity_audit_missing",
        "continuity_notification_missing",
        "high_trust_auto_update_not_gated",
        "transfer_history_missing",
        "package_identity_not_preserved",
        "revocation_not_propagated",
        "last_known_good_pin_missing",
        "hold_or_downgrade_policy_hidden",
        "deprecation_not_propagated",
        "removed_api_without_shim",
        "claim_packet_stale_or_incomplete",
        "identity_parity_missing"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "install_review",
        "update_review",
        "mirror_review",
        "rollback_review",
        "extension_inspector",
        "cli_headless",
        "support_export",
        "migration_docs",
        "claim_packet",
        "enterprise_admin_export"
      ]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_identity",
        "package_version",
        "install_flow_class",
        "resolver_contract_version",
        "identity_parity_across_sources",
        "source_classes",
        "public_row_ref",
        "mirror_row_ref",
        "enterprise_row_ref"
      ],
      "properties": {
        "package_identity": { "$ref": "#/$defs/opaque_id" },
        "package_version": { "$ref": "#/$defs/opaque_id" },
        "install_flow_class": { "$ref": "#/$defs/install_flow_class" },
        "resolver_contract_version": { "type": "integer", "minimum": 0 },
        "identity_parity_across_sources": { "type": "boolean" },
        "source_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source_class" }
        },
        "public_row_ref": { "$ref": "#/$defs/opaque_id" },
        "mirror_row_ref": { "$ref": "#/$defs/opaque_id" },
        "enterprise_row_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_id",
        "edge_class",
        "target_ref",
        "version_range_ref",
        "resolution_state_class",
        "contributed_permission_refs",
        "compatibility_range_ref"
      ],
      "properties": {
        "edge_id": { "$ref": "#/$defs/opaque_id" },
        "edge_class": { "$ref": "#/$defs/edge_class" },
        "target_ref": { "$ref": "#/$defs/opaque_id" },
        "version_range_ref": { "$ref": "#/$defs/opaque_id" },
        "resolution_state_class": { "$ref": "#/$defs/resolution_state_class" },
        "contributed_permission_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "compatibility_range_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "determinism_class",
        "api_range_ref",
        "runtime_range_ref",
        "resolution_digest_ref",
        "resolver_input_ref",
        "hard_dependencies",
        "optional_integrations",
        "lockfile_ref",
        "install_export_ref",
        "lock_export_available",
        "supports_team_rollout",
        "supports_air_gapped_rollout"
      ],
      "properties": {
        "determinism_class": { "$ref": "#/$defs/resolver_determinism_class" },
        "api_range_ref": { "$ref": "#/$defs/opaque_id" },
        "runtime_range_ref": { "$ref": "#/$defs/opaque_id" },
        "resolution_digest_ref": { "$ref": "#/$defs/opaque_id" },
        "resolver_input_ref": { "$ref": "#/$defs/opaque_id" },
        "hard_dependencies": { "type": "array", "items": { "$ref": "#/$defs/edge" } },
        "optional_integrations": { "type": "array", "items": { "$ref": "#/$defs/edge" } },
        "lockfile_ref": { "$ref": "#/$defs/opaque_id" },
        "install_export_ref": { "$ref": "#/$defs/opaque_id" },
        "lock_export_available": { "type": "boolean" },
        "supports_team_rollout": { "type": "boolean" },
        "supports_air_gapped_rollout": { "type": "boolean" },
        "hard_dependency_count": { "type": "integer", "minimum": 0 },
        "optional_integration_count": { "type": "integer", "minimum": 0 },
        "unresolved_hard_dependency_count": { "type": "integer", "minimum": 0 },
        "version_conflict_count": { "type": "integer", "minimum": 0 }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "declared_permission_refs",
        "inherited_permission_refs",
        "optional_integration_permission_refs",
        "effective_permission_refs",
        "prior_effective_permission_refs",
        "expanded_permission_refs",
        "reconsent_state_class",
        "triggered_by_dependency_permission_expansion"
      ],
      "properties": {
        "declared_permission_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_id" } },
        "inherited_permission_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_id" } },
        "optional_integration_permission_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_id" } },
        "effective_permission_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_id" } },
        "prior_effective_permission_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_id" } },
        "expanded_permission_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_id" } },
        "reconsent_state_class": { "$ref": "#/$defs/reconsent_state_class" },
        "triggered_by_dependency_permission_expansion": { "type": "boolean" },
        "consent_record_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "continuity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_class",
        "continuity_state_class",
        "delay_satisfied",
        "audit_trail_ref",
        "audit_trail_preserved",
        "user_notified",
        "admin_notified",
        "high_trust_auto_update_gated",
        "transfer_history_preserved",
        "package_identity_preserved",
        "continuity_packet_ref"
      ],
      "properties": {
        "workflow_class": { "$ref": "#/$defs/continuity_workflow_class" },
        "continuity_state_class": { "$ref": "#/$defs/continuity_state_class" },
        "delay_satisfied": { "type": "boolean" },
        "audit_trail_ref": { "$ref": "#/$defs/opaque_id" },
        "audit_trail_preserved": { "type": "boolean" },
        "user_notified": { "type": "boolean" },
        "admin_notified": { "type": "boolean" },
        "high_trust_auto_update_gated": { "type": "boolean" },
        "transfer_history_preserved": { "type": "boolean" },
        "package_identity_preserved": { "type": "boolean" },
        "continuity_packet_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "yank_revocation_state_class",
        "propagation_class",
        "policy_allows_hold_or_downgrade",
        "downgrade_hold_behavior_class",
        "rollback_export_ref"
      ],
      "properties": {
        "yank_revocation_state_class": { "$ref": "#/$defs/yank_revocation_state_class" },
        "propagation_class": { "$ref": "#/$defs/revocation_propagation_class" },
        "last_known_good_ref": { "$ref": "#/$defs/opaque_id" },
        "policy_allows_hold_or_downgrade": { "type": "boolean" },
        "downgrade_hold_behavior_class": { "$ref": "#/$defs/downgrade_hold_behavior_class" },
        "rollback_export_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "deprecation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "api_deprecation_state_class",
        "deprecated_api_refs",
        "flows_to_resolution_output",
        "flows_to_install_warning",
        "flows_to_migration_docs",
        "compatibility_shim_available",
        "migration_docs_ref",
        "claim_packet_current"
      ],
      "properties": {
        "api_deprecation_state_class": { "$ref": "#/$defs/api_deprecation_state_class" },
        "deprecated_api_refs": { "type": "array", "items": { "$ref": "#/$defs/opaque_id" } },
        "flows_to_resolution_output": { "type": "boolean" },
        "flows_to_install_warning": { "type": "boolean" },
        "flows_to_migration_docs": { "type": "boolean" },
        "compatibility_shim_available": { "type": "boolean" },
        "migration_docs_ref": { "$ref": "#/$defs/opaque_id" },
        "claim_packet_current": { "type": "boolean" }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "claimed_tier",
        "effective_tier",
        "support_claim_class",
        "claim_basis_class",
        "downgraded",
        "downgrade_reasons",
        "summary_label"
      ],
      "properties": {
        "claimed_tier": { "$ref": "#/$defs/stability_tier" },
        "effective_tier": { "$ref": "#/$defs/stability_tier" },
        "support_claim_class": { "$ref": "#/$defs/support_claim_class" },
        "claim_basis_class": { "$ref": "#/$defs/claim_basis_class" },
        "downgraded": { "type": "boolean" },
        "downgrade_reasons": { "type": "array", "items": { "$ref": "#/$defs/downgrade_reason" } },
        "summary_label": { "$ref": "#/$defs/label" }
      }
    },
    "inspection": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "packet_id_ref",
        "package_identity",
        "install_flow_class",
        "effective_tier",
        "stable_claim",
        "resolution_deterministic",
        "all_hard_dependencies_resolved",
        "effective_permission_count",
        "expanded_permission_count",
        "reconsent_satisfied",
        "continuity_workflow_class",
        "continuity_state_class",
        "high_trust_auto_update_may_resume",
        "yank_revocation_state_class",
        "revocation_propagation_class",
        "api_deprecation_state_class",
        "claim_packet_current",
        "identity_parity_across_sources",
        "banner_required"
      ],
      "properties": {
        "packet_id_ref": { "$ref": "#/$defs/opaque_id" },
        "package_identity": { "$ref": "#/$defs/opaque_id" },
        "install_flow_class": { "$ref": "#/$defs/install_flow_class" },
        "effective_tier": { "$ref": "#/$defs/stability_tier" },
        "stable_claim": { "type": "boolean" },
        "resolution_deterministic": { "type": "boolean" },
        "all_hard_dependencies_resolved": { "type": "boolean" },
        "hard_dependency_count": { "type": "integer", "minimum": 0 },
        "optional_integration_count": { "type": "integer", "minimum": 0 },
        "effective_permission_count": { "type": "integer", "minimum": 0 },
        "expanded_permission_count": { "type": "integer", "minimum": 0 },
        "reconsent_satisfied": { "type": "boolean" },
        "continuity_workflow_class": { "$ref": "#/$defs/continuity_workflow_class" },
        "continuity_state_class": { "$ref": "#/$defs/continuity_state_class" },
        "high_trust_auto_update_may_resume": { "type": "boolean" },
        "yank_revocation_state_class": { "$ref": "#/$defs/yank_revocation_state_class" },
        "revocation_propagation_class": { "$ref": "#/$defs/revocation_propagation_class" },
        "last_known_good_ref": { "$ref": "#/$defs/opaque_id" },
        "api_deprecation_state_class": { "$ref": "#/$defs/api_deprecation_state_class" },
        "claim_packet_current": { "type": "boolean" },
        "identity_parity_across_sources": { "type": "boolean" },
        "banner_required": { "type": "boolean" }
      }
    }
  }
}
