{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/extensions/manifest_editor_session.schema.json",
  "title": "Aureline extension manifest editor session",
  "description": "Cross-tool boundary schema for the native extension manifest/schema authoring session. The session carries inline validation findings with field-level JSON-pointer anchors, permission explanation chips, lifecycle-driven migration/deprecation hints, version-range targeting, open-schema/open-docs links, and a validator-parity conformance export. Blocker findings reuse the same stable check ids and severities the validator CLI and conformance kit emit; editor-only UX/performance advisories are separated into the editor_advisory suite. The shell manifest editor, CLI/headless inspect, and support exports read this session instead of relaying opaque CLI-only error text.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "manifest_editor_session_schema_version",
    "session_id",
    "generated_at",
    "subject_manifest_ref",
    "connectivity_class",
    "local_validation_only",
    "network_round_trip_required",
    "findings",
    "blocker_count",
    "advisory_count",
    "passed_count",
    "permission_chips",
    "migration_hints",
    "version_targeting",
    "conformance_export",
    "publish_readiness",
    "publish_readiness_reason",
    "publish_readiness_summary",
    "links",
    "redaction_class"
  ],
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "extension_manifest_editor_session"
    },
    "manifest_editor_session_schema_version": {
      "type": "integer",
      "const": 1
    },
    "session_id": {
      "type": "string",
      "pattern": "^extension_manifest_editor_session:"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "subject_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "connectivity_class": { "$ref": "#/$defs/connectivity_class" },
    "local_validation_only": {
      "type": "boolean",
      "const": true
    },
    "network_round_trip_required": {
      "type": "boolean",
      "const": false
    },
    "package_id": { "$ref": "#/$defs/non_empty_string" },
    "publisher_id": { "$ref": "#/$defs/non_empty_string" },
    "extension_version": { "$ref": "#/$defs/non_empty_string" },
    "runtime_origin": { "$ref": "#/$defs/non_empty_string" },
    "host_contract_family": { "$ref": "#/$defs/non_empty_string" },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "blocker_count": { "type": "integer", "minimum": 0 },
    "advisory_count": { "type": "integer", "minimum": 0 },
    "passed_count": { "type": "integer", "minimum": 0 },
    "permission_chips": {
      "type": "array",
      "items": { "$ref": "#/$defs/permission_chip" }
    },
    "migration_hints": {
      "type": "array",
      "items": { "$ref": "#/$defs/migration_hint" }
    },
    "version_targeting": { "$ref": "#/$defs/version_targeting" },
    "conformance_export": { "$ref": "#/$defs/conformance_export" },
    "publish_readiness": { "$ref": "#/$defs/publish_readiness" },
    "publish_readiness_reason": { "$ref": "#/$defs/publish_readiness_reason" },
    "publish_readiness_summary": { "$ref": "#/$defs/non_empty_string" },
    "links": { "$ref": "#/$defs/links" },
    "redaction_class": { "$ref": "#/$defs/redaction_class" }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "redaction_class": {
      "type": "string",
      "const": "metadata_safe_default"
    },
    "connectivity_class": {
      "type": "string",
      "enum": ["local_offline", "mirror_reachable", "primary_registry_reachable"]
    },
    "finding_suite": {
      "type": "string",
      "enum": [
        "manifest_shape",
        "permission_declarations",
        "lifecycle_metadata",
        "compatibility_targets",
        "conformance_fixtures",
        "editor_advisory"
      ]
    },
    "finding_status": {
      "type": "string",
      "enum": ["pass", "fail", "warn", "not_applicable"]
    },
    "finding_severity": {
      "type": "string",
      "enum": ["blocker", "warning", "info"]
    },
    "capability_class": {
      "type": "string",
      "enum": ["network", "filesystem", "process", "data", "ui", "credential"]
    },
    "deprecation_posture_class": {
      "type": "string",
      "enum": [
        "not_deprecated",
        "deprecated_with_replacement",
        "deprecated_no_direct_replacement",
        "retired"
      ]
    },
    "result_class": {
      "type": "string",
      "enum": ["pass", "warn", "fail"]
    },
    "compatibility_badge_class": {
      "type": "string",
      "enum": ["compatible_on_declared_targets", "unsupported_pending_qualification"]
    },
    "publish_readiness": {
      "type": "string",
      "enum": ["ready_to_publish", "ready_with_advisories", "blocked_on_must_fix"]
    },
    "publish_readiness_reason": {
      "type": "string",
      "enum": [
        "no_blockers_no_advisories",
        "no_blockers_advisories_present",
        "must_fix_blockers_present"
      ]
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "suite", "status", "severity", "message"],
      "properties": {
        "check_id": { "$ref": "#/$defs/non_empty_string" },
        "suite": { "$ref": "#/$defs/finding_suite" },
        "status": { "$ref": "#/$defs/finding_status" },
        "severity": { "$ref": "#/$defs/finding_severity" },
        "message": { "$ref": "#/$defs/non_empty_string" },
        "field": { "$ref": "#/$defs/non_empty_string" },
        "anchor": { "type": "string" },
        "fix": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "permission_chip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "anchor",
        "scope",
        "scope_known",
        "privileged",
        "target_count",
        "purpose_present",
        "review_required",
        "prompt_summary_present",
        "handle_only",
        "explanation"
      ],
      "properties": {
        "anchor": {
          "type": "string",
          "pattern": "^/permissions/"
        },
        "scope": { "type": "string" },
        "scope_known": { "type": "boolean" },
        "capability_class": { "$ref": "#/$defs/capability_class" },
        "privileged": { "type": "boolean" },
        "trust_mode": { "$ref": "#/$defs/non_empty_string" },
        "target_count": { "type": "integer", "minimum": 0 },
        "purpose_present": { "type": "boolean" },
        "review_required": { "type": "boolean" },
        "prompt_summary_present": { "type": "boolean" },
        "network_endpoint_class": { "$ref": "#/$defs/non_empty_string" },
        "handle_only": { "type": "boolean" },
        "explanation": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "migration_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lifecycle_row_ref",
        "field_path",
        "field_anchor",
        "deprecated_value",
        "posture",
        "guidance"
      ],
      "properties": {
        "lifecycle_row_ref": {
          "type": "string",
          "pattern": "^lifecycle_row:"
        },
        "field_path": { "$ref": "#/$defs/non_empty_string" },
        "field_anchor": { "type": "string" },
        "deprecated_value": { "$ref": "#/$defs/non_empty_string" },
        "posture": { "$ref": "#/$defs/deprecation_posture_class" },
        "replacement_value": { "$ref": "#/$defs/non_empty_string" },
        "no_direct_replacement_reason": { "$ref": "#/$defs/non_empty_string" },
        "removal_target_version": { "$ref": "#/$defs/non_empty_string" },
        "removal_target_date": { "$ref": "#/$defs/non_empty_string" },
        "migration_guide_ref": { "$ref": "#/$defs/non_empty_string" },
        "replacement_example": { "$ref": "#/$defs/non_empty_string" },
        "guidance": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "version_targeting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platforms", "required_shim", "lifecycle_metadata_refs"],
      "properties": {
        "sdk_line_id": { "$ref": "#/$defs/non_empty_string" },
        "sdk_line_semver": { "$ref": "#/$defs/non_empty_string" },
        "host_abi_window": { "$ref": "#/$defs/non_empty_string" },
        "aureline_version_min": { "$ref": "#/$defs/non_empty_string" },
        "aureline_version_max": { "$ref": "#/$defs/non_empty_string" },
        "platforms": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "support_class": { "$ref": "#/$defs/non_empty_string" },
        "bridge_state": { "$ref": "#/$defs/non_empty_string" },
        "required_shim": { "type": "boolean" },
        "shim_note": { "$ref": "#/$defs/non_empty_string" },
        "lifecycle_metadata_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "conformance_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "validator_version",
        "result_class",
        "compatibility_badge_class",
        "red_flag_classes",
        "passed",
        "failed",
        "warnings",
        "blockers"
      ],
      "properties": {
        "validator_id": { "$ref": "#/$defs/non_empty_string" },
        "validator_version": { "$ref": "#/$defs/non_empty_string" },
        "result_class": { "$ref": "#/$defs/result_class" },
        "compatibility_badge_class": { "$ref": "#/$defs/compatibility_badge_class" },
        "red_flag_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "blockers": { "type": "integer", "minimum": 0 }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_schema_ref",
        "permission_schema_ref",
        "lifecycle_schema_ref",
        "conformance_report_schema_ref",
        "validator_cli_ref",
        "versioning_policy_ref",
        "authoring_docs_ref",
        "lifecycle_packet_ref"
      ],
      "properties": {
        "manifest_schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "permission_schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "lifecycle_schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "conformance_report_schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "validator_cli_ref": { "$ref": "#/$defs/non_empty_string" },
        "versioning_policy_ref": { "$ref": "#/$defs/non_empty_string" },
        "authoring_docs_ref": { "$ref": "#/$defs/non_empty_string" },
        "lifecycle_packet_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  }
}
