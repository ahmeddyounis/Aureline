{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/providers/managed_workspace_lifecycle.schema.json",
  "title": "Aureline managed-workspace lifecycle beta record",
  "description": "Beta boundary schema for the managed_workspace_lifecycle_beta_record consumed by title bars, remote strips, activity center cards, docs/help, and support packets. The record builds on the alpha managed_workspace_alpha_record (schemas/managed/workspace_lifecycle_state.schema.json) by binding the workspace to a closed lifecycle phase (start, ready, suspend, resume, reconnect, retire), a derived state class surfaces render verbatim, a closed local-editing continuity class, and an ordered lineage of phase entries so support exports reconstruct the path the workspace took rather than just the latest state. Raw hostnames, IP addresses, endpoint URLs, paths, ports, query strings, raw provider payloads, credentials, secret values, raw container image digests, raw user emails, and raw tenant names never appear. Adding an enum value or optional field is additive-minor and bumps schema_version when the wire payload changes; repurposing an existing value is breaking and requires a new decision row.",
  "$ref": "#/$defs/managed_workspace_lifecycle_beta_record",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for logs, exports, and support packets. Raw customer, billing, provider, URL, prompt, code, container image, and volume identifiers never appear here."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 UTC timestamp."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Short product-safe sentence. Must not contain raw prompts, raw code, raw emails, raw tenant names, raw workspace volume ids, raw container image digests, raw billing ids, raw URLs, or provider account identifiers."
    },
    "lifecycle_phase_class": {
      "type": "string",
      "enum": [
        "start",
        "ready",
        "suspend",
        "resume",
        "reconnect",
        "retire"
      ]
    },
    "lifecycle_state_class": {
      "type": "string",
      "enum": [
        "starting",
        "live",
        "suspended",
        "resuming",
        "degraded",
        "reconnect_required",
        "retiring",
        "retired"
      ]
    },
    "local_editing_continuity_class": {
      "type": "string",
      "enum": [
        "preserved_full_local_editing",
        "preserved_local_only_writes",
        "inspect_only_until_recovery",
        "not_applicable"
      ]
    },
    "transition_reason_class": {
      "type": "string",
      "enum": [
        "user_requested_suspend",
        "user_requested_resume",
        "user_requested_reattach",
        "reconnect_window_elapsed",
        "target_witness_stale",
        "local_runtime_inspection"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "title_bar",
        "remote_strip",
        "activity_center",
        "docs_help",
        "support_packet"
      ]
    },
    "lineage_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "state",
        "reason",
        "observed_at",
        "summary"
      ],
      "properties": {
        "phase": { "$ref": "#/$defs/lifecycle_phase_class" },
        "state": { "$ref": "#/$defs/lifecycle_state_class" },
        "reason": { "$ref": "#/$defs/transition_reason_class" },
        "observed_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "evidence_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "managed_workspace_lifecycle_beta_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "row_id",
        "workspace_ref",
        "generated_at",
        "current_phase",
        "current_state",
        "local_editing_continuity",
        "mutation_allowed",
        "reconnect_required",
        "lineage",
        "visible_summary",
        "safe_continuation",
        "harness_expectations"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "managed_workspace_lifecycle_beta_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "row_id": {
          "type": "string",
          "pattern": "^managed-workspace-lifecycle-beta-row:[a-z0-9]+(?:[._-][a-z0-9]+)*$",
          "description": "Stable row id shared with the surface projections and the support-export bundle."
        },
        "workspace_ref": { "$ref": "#/$defs/opaque_id" },
        "workspace_instance_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "current_phase": { "$ref": "#/$defs/lifecycle_phase_class" },
        "current_state": { "$ref": "#/$defs/lifecycle_state_class" },
        "local_editing_continuity": { "$ref": "#/$defs/local_editing_continuity_class" },
        "mutation_allowed": { "type": "boolean" },
        "reconnect_required": { "type": "boolean" },
        "lineage": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/lineage_entry" }
        },
        "visible_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "safe_continuation": { "$ref": "#/$defs/reviewable_sentence" },
        "source_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "support_packet_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "surface_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/surface_class" }
        },
        "evidence_refs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_refs",
            "fixture_refs",
            "doc_refs"
          ],
          "properties": {
            "alpha_record_ref": { "$ref": "#/$defs/opaque_id" },
            "schema_refs": {
              "type": "array",
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/opaque_id" }
            },
            "fixture_refs": {
              "type": "array",
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/opaque_id" }
            },
            "doc_refs": {
              "type": "array",
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/opaque_id" }
            }
          }
        },
        "harness_expectations": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "case_id",
            "expected_current_phase",
            "expected_current_state",
            "expected_local_editing_continuity",
            "expected_mutation_allowed",
            "expected_reconnect_required",
            "expected_lineage_length",
            "acceptance_states"
          ],
          "properties": {
            "case_id": {
              "type": "string",
              "pattern": "^managed_workspace_lifecycle_beta_case:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
            },
            "expected_current_phase": { "$ref": "#/$defs/lifecycle_phase_class" },
            "expected_current_state": { "$ref": "#/$defs/lifecycle_state_class" },
            "expected_local_editing_continuity": {
              "$ref": "#/$defs/local_editing_continuity_class"
            },
            "expected_mutation_allowed": { "type": "boolean" },
            "expected_reconnect_required": { "type": "boolean" },
            "expected_lineage_length": {
              "type": "integer",
              "minimum": 1
            },
            "acceptance_states": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      },
      "allOf": [
        {
          "description": "mutation_allowed must be true if and only if current_state == 'live'.",
          "if": {
            "properties": {
              "mutation_allowed": { "const": true }
            },
            "required": ["mutation_allowed"]
          },
          "then": {
            "properties": {
              "current_state": { "const": "live" }
            }
          }
        },
        {
          "description": "reconnect_required must be true if and only if current_state == 'reconnect_required'.",
          "if": {
            "properties": {
              "reconnect_required": { "const": true }
            },
            "required": ["reconnect_required"]
          },
          "then": {
            "properties": {
              "current_state": { "const": "reconnect_required" }
            }
          }
        },
        {
          "description": "not_applicable continuity is reserved for retired or starting rows.",
          "if": {
            "properties": {
              "local_editing_continuity": { "const": "not_applicable" }
            },
            "required": ["local_editing_continuity"]
          },
          "then": {
            "properties": {
              "current_state": {
                "enum": ["starting", "retired"]
              }
            }
          }
        }
      ]
    }
  }
}
