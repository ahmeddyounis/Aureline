{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/providers/provider_scope_review.schema.json",
  "title": "Aureline provider scope-review page",
  "description": "Canonical M5 provider scope-review packet. The page keeps acting identity, authority health, requested action, target object, provider-declared scope, effective scope, policy locks, least-privilege alternatives, invalidation events, and consumer-surface projections on one typed contract. The Rust schema of record lives in /crates/aureline-provider/src/scope_review/mod.rs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "contract_refs",
    "resolutions",
    "alternatives",
    "invalidation_events",
    "consumer_projections",
    "defects",
    "summary"
  ],
  "properties": {
    "__fixture__": {
      "$ref": "#/$defs/fixture_metadata"
    },
    "record_kind": {
      "const": "providers_scope_review_page_record"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "providers:scope_review:v1"
    },
    "page_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "contract_refs": {
      "$ref": "#/$defs/contract_refs"
    },
    "resolutions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/resolution"
      }
    },
    "alternatives": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/alternative"
      }
    },
    "invalidation_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/invalidation"
      }
    },
    "consumer_projections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/consumer_projection"
      }
    },
    "defects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/defect"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "provider_family": {
      "type": "string",
      "enum": ["code_host", "issue_tracker", "ci_checks"]
    },
    "provider_actor_class": {
      "type": "string",
      "enum": [
        "human_account",
        "installation_or_app_grant",
        "delegated_user_token",
        "project_scoped_grant",
        "policy_injected_service_identity",
        "unknown_actor_class"
      ]
    },
    "provider_class": {
      "type": "string",
      "enum": [
        "code_host",
        "issue_tracker",
        "ci_checks",
        "release_publisher",
        "docs_or_portal",
        "managed_admin",
        "artifact_registry",
        "other"
      ]
    },
    "target_object_class": {
      "type": "string",
      "enum": [
        "pull_request",
        "issue_or_work_item",
        "check_run",
        "release_artifact",
        "docs_page",
        "admin_surface",
        "package_version",
        "principal_subject",
        "install_target",
        "tenant_or_org",
        "other"
      ]
    },
    "authority_health_class": {
      "type": "string",
      "enum": [
        "healthy",
        "expiring",
        "revoked",
        "suspended",
        "scope_narrowed",
        "unreachable",
        "host_mismatch",
        "org_membership_lost",
        "tenant_switch_detected"
      ]
    },
    "requested_action_class": {
      "type": "string",
      "enum": [
        "read_only_inspection",
        "human_authored_comment",
        "review_decision_publish",
        "issue_or_work_item_mutation",
        "ci_run_or_check_mutation",
        "docs_or_portal_publish",
        "package_publish",
        "release_publish",
        "consent_or_admin_delegation",
        "credential_projection"
      ]
    },
    "mutation_mode": {
      "type": "string",
      "enum": [
        "local_draft",
        "publish_now",
        "open_in_provider",
        "deferred_publish",
        "inspect_only"
      ]
    },
    "trust_posture": {
      "type": "string",
      "enum": ["trusted", "restricted"]
    },
    "decision_class": {
      "type": "string",
      "enum": ["allowed", "denied", "browser_only", "local_draft_only"]
    },
    "resolution_reason": {
      "type": "string",
      "enum": [
        "allowed",
        "allowed_with_downgrade",
        "allowed_with_browser_handoff",
        "allowed_with_deferred_publish",
        "denied_scope_missing",
        "denied_policy_bundle",
        "denied_workspace_trust",
        "denied_actor_class_forbidden",
        "denied_target_conflict",
        "denied_freshness_floor",
        "denied_revoked",
        "denied_suspended",
        "denied_host_mismatch",
        "denied_approval_ticket_missing",
        "denied_approval_ticket_expired",
        "denied_step_up_required",
        "denied_unreachable",
        "denied_unknown_actor_class"
      ]
    },
    "policy_lock_class": {
      "type": "string",
      "enum": [
        "no_local_policy_lock",
        "policy_bundle_forbids_action",
        "policy_bundle_narrows_actor_class",
        "policy_bundle_requires_browser_handoff",
        "policy_bundle_requires_deferred_publish",
        "policy_bundle_requires_step_up",
        "workspace_trust_restricted_lock",
        "managed_provider_admin_lock",
        "release_publisher_lock",
        "credential_projection_lock"
      ]
    },
    "alternative_class": {
      "type": "string",
      "enum": [
        "narrower_scope_request",
        "switch_actor_class",
        "switch_to_inspect_only",
        "switch_to_local_draft",
        "switch_to_deferred_publish",
        "route_through_browser_handoff",
        "route_through_admin_delegation",
        "request_step_up_authenticator",
        "request_workspace_trust_grant",
        "request_admin_review",
        "copy_or_export_evidence",
        "no_alternative_available"
      ]
    },
    "staleness_class": {
      "type": "string",
      "enum": ["fresh", "bounded_stale", "unbounded_stale"]
    },
    "invalidation_trigger_class": {
      "type": "string",
      "enum": [
        "actor_class_revoked",
        "actor_class_suspended",
        "actor_class_changed",
        "delegated_credential_expired",
        "host_mismatch_detected",
        "tenant_switch_detected",
        "org_membership_lost",
        "policy_epoch_rolled",
        "trust_state_downgraded",
        "freshness_floor_drifted",
        "approval_ticket_revoked",
        "provider_health_degraded"
      ]
    },
    "downgrade_action_class": {
      "type": "string",
      "enum": [
        "no_downgrade_required",
        "force_inspect_only_until_repair",
        "force_local_draft_only_until_repair",
        "force_browser_handoff_only_until_repair",
        "force_step_up_authenticator",
        "force_account_reselection",
        "force_admin_review",
        "force_disconnect_until_repair"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": ["desktop", "cli_headless", "companion", "support_export"]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_scope_review_schema_ref",
        "effective_scope_resolution_schema_ref",
        "account_scope_beta_shared_contract_ref",
        "route_resolution_beta_shared_contract_ref",
        "work_item_transition_beta_shared_contract_ref",
        "work_item_sync_beta_shared_contract_ref"
      ],
      "properties": {
        "provider_scope_review_schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "effective_scope_resolution_schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "account_scope_beta_shared_contract_ref": { "$ref": "#/$defs/non_empty_string" },
        "route_resolution_beta_shared_contract_ref": { "$ref": "#/$defs/non_empty_string" },
        "work_item_transition_beta_shared_contract_ref": { "$ref": "#/$defs/non_empty_string" },
        "work_item_sync_beta_shared_contract_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "target_object_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_class",
        "target_object_class",
        "provider_side_id",
        "provider_host_ref",
        "tenant_or_org_scope_ref",
        "target_label"
      ],
      "properties": {
        "provider_class": { "$ref": "#/$defs/provider_class" },
        "target_object_class": { "$ref": "#/$defs/target_object_class" },
        "provider_side_id": { "$ref": "#/$defs/non_empty_string" },
        "provider_host_ref": { "$ref": "#/$defs/non_empty_string" },
        "tenant_or_org_scope_ref": { "$ref": "#/$defs/non_empty_string" },
        "target_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_posture", "execution_context_id"],
      "properties": {
        "policy_epoch": { "$ref": "#/$defs/non_empty_string" },
        "trust_posture": { "$ref": "#/$defs/trust_posture" },
        "execution_context_id": { "$ref": "#/$defs/non_empty_string" },
        "policy_block_ref": { "type": "string" }
      }
    },
    "freshness_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed_at", "staleness_class"],
      "properties": {
        "observed_at": { "$ref": "#/$defs/timestamp" },
        "freshness_floor_ref": { "type": "string" },
        "staleness_class": { "$ref": "#/$defs/staleness_class" },
        "staleness_rationale": { "type": "string" }
      }
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "resolution_id",
        "connected_provider_record_id",
        "provider_family",
        "actor_class",
        "actor_subject_ref",
        "actor_display_label",
        "authority_health_class",
        "requested_action_class",
        "requested_mutation_mode",
        "target_object_identity",
        "provider_declared_scope_refs",
        "effective_scope_refs",
        "policy_lock_classes",
        "trust_posture",
        "decision_class",
        "grant_resolution_reason",
        "decision_summary",
        "policy_context",
        "least_privilege_alternative_refs",
        "computed_at",
        "audit_event_refs",
        "raw_scope_material_present",
        "redaction_class"
      ],
      "properties": {
        "record_kind": { "const": "provider_scope_review_resolution_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "providers:scope_review:v1" },
        "resolution_id": { "$ref": "#/$defs/non_empty_string" },
        "connected_provider_record_id": { "$ref": "#/$defs/non_empty_string" },
        "provider_family": { "$ref": "#/$defs/provider_family" },
        "actor_class": { "$ref": "#/$defs/provider_actor_class" },
        "actor_subject_ref": { "$ref": "#/$defs/non_empty_string" },
        "actor_display_label": { "$ref": "#/$defs/non_empty_string" },
        "authority_health_class": { "$ref": "#/$defs/authority_health_class" },
        "requested_action_class": { "$ref": "#/$defs/requested_action_class" },
        "requested_mutation_mode": { "$ref": "#/$defs/mutation_mode" },
        "target_object_identity": { "$ref": "#/$defs/target_object_identity" },
        "provider_declared_scope_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "effective_scope_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "policy_lock_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/policy_lock_class" },
          "uniqueItems": true
        },
        "trust_posture": { "$ref": "#/$defs/trust_posture" },
        "decision_class": { "$ref": "#/$defs/decision_class" },
        "grant_resolution_reason": { "$ref": "#/$defs/resolution_reason" },
        "decision_summary": { "$ref": "#/$defs/non_empty_string" },
        "freshness": { "$ref": "#/$defs/freshness_block" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "approval_ticket_ref": { "type": "string" },
        "browser_handoff_packet_ref": { "type": "string" },
        "publish_later_queue_item_ref": { "type": "string" },
        "least_privilege_alternative_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "computed_at": { "$ref": "#/$defs/timestamp" },
        "expires_at": { "$ref": "#/$defs/timestamp" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "raw_scope_material_present": { "type": "boolean" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    },
    "alternative": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "alternative_id",
        "originating_resolution_id",
        "alternative_class",
        "alternative_summary",
        "narrowed_scope_refs",
        "redaction_class"
      ],
      "properties": {
        "record_kind": { "const": "provider_scope_review_alternative_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "providers:scope_review:v1" },
        "alternative_id": { "$ref": "#/$defs/non_empty_string" },
        "originating_resolution_id": { "$ref": "#/$defs/non_empty_string" },
        "alternative_class": { "$ref": "#/$defs/alternative_class" },
        "alternative_summary": { "$ref": "#/$defs/non_empty_string" },
        "suggested_actor_class": { "$ref": "#/$defs/provider_actor_class" },
        "suggested_mutation_mode": { "$ref": "#/$defs/mutation_mode" },
        "narrowed_scope_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "repair_hook_ref": { "type": "string" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    },
    "invalidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "event_id",
        "event_time",
        "originating_resolution_id",
        "connected_provider_record_id",
        "actor_class",
        "invalidation_trigger_class",
        "downgrade_action_class",
        "rationale_summary",
        "invalidated_dependent_refs",
        "policy_epoch",
        "trust_posture",
        "redaction_class"
      ],
      "properties": {
        "record_kind": { "const": "provider_scope_review_invalidation_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "providers:scope_review:v1" },
        "event_id": { "$ref": "#/$defs/non_empty_string" },
        "event_time": { "$ref": "#/$defs/timestamp" },
        "originating_resolution_id": { "$ref": "#/$defs/non_empty_string" },
        "connected_provider_record_id": { "$ref": "#/$defs/non_empty_string" },
        "actor_class": { "$ref": "#/$defs/provider_actor_class" },
        "invalidation_trigger_class": { "$ref": "#/$defs/invalidation_trigger_class" },
        "originating_account_invalidation_event_ref": { "type": "string" },
        "downgrade_action_class": { "$ref": "#/$defs/downgrade_action_class" },
        "rationale_summary": { "$ref": "#/$defs/non_empty_string" },
        "invalidated_dependent_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "policy_epoch": { "$ref": "#/$defs/non_empty_string" },
        "trust_posture": { "$ref": "#/$defs/trust_posture" },
        "repair_hook_ref": { "type": "string" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "projection_id",
        "surface_class",
        "originating_resolution_id",
        "projected_decision_class",
        "projected_grant_resolution_reason",
        "projected_decision_summary",
        "projected_alternative_refs",
        "raw_scope_material_present"
      ],
      "properties": {
        "record_kind": { "const": "provider_scope_review_consumer_projection_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "providers:scope_review:v1" },
        "projection_id": { "$ref": "#/$defs/non_empty_string" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "originating_resolution_id": { "$ref": "#/$defs/non_empty_string" },
        "projected_decision_class": { "$ref": "#/$defs/decision_class" },
        "projected_grant_resolution_reason": { "$ref": "#/$defs/resolution_reason" },
        "projected_decision_summary": { "$ref": "#/$defs/non_empty_string" },
        "projected_alternative_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "raw_scope_material_present": { "type": "boolean" }
      }
    },
    "defect_kind": {
      "type": "string",
      "enum": [
        "duplicate_id",
        "contract_ref_missing",
        "raw_scope_material_present",
        "effective_scope_not_subset_of_declared",
        "allowed_resolution_without_effective_scope",
        "allowed_direct_write_on_closed_health",
        "decision_reason_mismatch",
        "browser_only_without_handoff_ref",
        "local_draft_only_without_queue_ref",
        "allowed_write_without_approval_ticket",
        "policy_lock_incoherent",
        "alternative_coverage_broken",
        "invalidation_broken",
        "consumer_projection_drift",
        "consumer_coverage_missing"
      ]
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_kind",
        "defect_kind_token",
        "subject_id",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": { "const": "providers_scope_review_defect_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "providers:scope_review:v1" },
        "defect_kind": { "$ref": "#/$defs/defect_kind" },
        "defect_kind_token": { "$ref": "#/$defs/defect_kind" },
        "subject_id": { "$ref": "#/$defs/non_empty_string" },
        "field": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_record_kind",
        "record_kind",
        "resolution_count",
        "alternative_count",
        "invalidation_event_count",
        "consumer_projection_count",
        "provider_families_present",
        "provider_classes_present",
        "actor_classes_present",
        "decision_classes_present",
        "alternative_classes_present",
        "invalidation_triggers_present",
        "consumer_surfaces_present",
        "resolutions_by_decision",
        "defect_count",
        "defect_counts_by_kind"
      ],
      "properties": {
        "page_record_kind": { "const": "providers_scope_review_page_record" },
        "record_kind": { "const": "providers_scope_review_summary_record" },
        "resolution_count": { "type": "integer", "minimum": 0 },
        "alternative_count": { "type": "integer", "minimum": 0 },
        "invalidation_event_count": { "type": "integer", "minimum": 0 },
        "consumer_projection_count": { "type": "integer", "minimum": 0 },
        "provider_families_present": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "provider_classes_present": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "actor_classes_present": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "decision_classes_present": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "alternative_classes_present": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "invalidation_triggers_present": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "consumer_surfaces_present": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "resolutions_by_decision": { "type": "object" },
        "defect_count": { "type": "integer", "minimum": 0 },
        "defect_counts_by_kind": { "type": "object" }
      }
    }
  }
}
