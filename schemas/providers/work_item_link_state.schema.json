{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/providers/work_item_link_state.schema.json",
  "title": "Aureline provider work-item link state beta entry point",
  "description": "Provider-facing schema for durable work-item link state records bound to the same work-item object model used by status-transition and offline-handoff records. Every link row keeps provider-owned truth, local drafts, queued publishes, offline handoffs, and conflicts on separate enum lanes. Raw provider URLs, raw provider payloads, and comment bodies are forbidden.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "link_id",
    "work_item_detail_record_id_ref",
    "provider_descriptor_ref",
    "provider_family",
    "link_kind_class",
    "link_source_class",
    "link_relation_state_class",
    "link_freshness_class",
    "link_write_scope_class",
    "link_local_draft_state_class",
    "link_sync_pending_state_class",
    "link_conflict_resolution_posture_class",
    "redaction_class",
    "raw_provider_payload_refs_present",
    "raw_provider_url_present",
    "captured_at",
    "support_export_summary"
  ],
  "properties": {
    "record_kind": { "const": "work_item_link_state_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "link_id": { "$ref": "#/$defs/opaque_id" },
    "work_item_detail_record_id_ref": { "$ref": "#/$defs/opaque_id" },
    "provider_descriptor_ref": { "$ref": "#/$defs/opaque_id" },
    "provider_family": { "$ref": "#/$defs/provider_family" },
    "link_kind_class": { "$ref": "#/$defs/link_kind_class" },
    "link_source_class": { "$ref": "#/$defs/link_source_class" },
    "link_relation_state_class": { "$ref": "#/$defs/link_relation_state_class" },
    "link_freshness_class": { "$ref": "#/$defs/link_freshness_class" },
    "link_write_scope_class": { "$ref": "#/$defs/link_write_scope_class" },
    "link_local_draft_state_class": { "$ref": "#/$defs/link_local_draft_state_class" },
    "link_sync_pending_state_class": { "$ref": "#/$defs/link_sync_pending_state_class" },
    "link_conflict_resolution_posture_class": {
      "$ref": "#/$defs/link_conflict_resolution_posture_class"
    },
    "linked_branch_local_locator_ref": { "$ref": "#/$defs/opaque_id" },
    "linked_review_workspace_record_id_ref": { "$ref": "#/$defs/opaque_id" },
    "linked_change_object_record_id_ref": { "$ref": "#/$defs/opaque_id" },
    "linked_peer_work_item_detail_record_id_ref": { "$ref": "#/$defs/opaque_id" },
    "linked_handoff_packet_record_id_ref": { "$ref": "#/$defs/opaque_id" },
    "linked_publish_later_queue_item_record_id_ref": { "$ref": "#/$defs/opaque_id" },
    "linked_offline_handoff_packet_record_id_ref": { "$ref": "#/$defs/opaque_id" },
    "linked_browser_handoff_packet_ref": { "$ref": "#/$defs/opaque_id" },
    "origin_disclosure": { "type": "object" },
    "policy_context": { "type": "object" },
    "redaction_class": { "$ref": "#/$defs/redaction_class" },
    "raw_provider_payload_refs_present": { "type": "boolean", "const": false },
    "raw_provider_url_present": { "type": "boolean", "const": false },
    "captured_at": { "type": "string", "minLength": 1 },
    "support_export_summary": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque ref safe for logs, manifests, support packets, and fixtures. Raw provider URLs and tokens are forbidden."
    },
    "provider_family": {
      "type": "string",
      "enum": ["code_host", "issue_tracker", "ci_checks"]
    },
    "link_kind_class": {
      "type": "string",
      "enum": [
        "branch_or_worktree_link",
        "review_workspace_link",
        "change_object_link",
        "work_item_peer_link",
        "handoff_packet_link"
      ]
    },
    "link_source_class": {
      "type": "string",
      "enum": [
        "provider_authoritative_overlay",
        "provider_observed_cached_shadow",
        "local_authored_no_provider_object",
        "imported_handoff_evidence_only",
        "browser_handoff_only",
        "ai_proposed_pending_user_confirmation",
        "review_bundle_snapshot"
      ]
    },
    "link_relation_state_class": {
      "type": "string",
      "enum": [
        "linked_active_provider_confirmed",
        "linked_local_draft_pending_publish",
        "linked_queued_for_publish_later",
        "linked_through_browser_handoff_only",
        "linked_imported_snapshot_no_provider_path",
        "unlink_requested_local_draft",
        "unlink_queued_for_publish_later",
        "broken_provider_rejected",
        "broken_provider_object_missing",
        "conflict_requires_review"
      ]
    },
    "link_freshness_class": {
      "type": "string",
      "enum": [
        "live_authoritative_fresh",
        "warm_within_grace",
        "degraded_beyond_grace_local_continues",
        "unverifiable_provider_unreachable",
        "imported_snapshot_no_refresh_path",
        "local_draft_never_published"
      ]
    },
    "link_write_scope_class": {
      "type": "string",
      "enum": [
        "write_admissible_provider_writeable",
        "write_admissible_through_browser_handoff_only",
        "write_admissible_queued_publish_only",
        "write_admissible_local_draft_only_no_provider_path",
        "write_blocked_provider_read_only_scope",
        "write_blocked_workspace_trust_unset_or_restricted",
        "write_blocked_provider_unreachable",
        "write_blocked_imported_evidence_only_no_provider_path",
        "write_blocked_account_mapping_pending"
      ]
    },
    "link_local_draft_state_class": {
      "type": "string",
      "enum": [
        "no_local_draft_edit",
        "local_draft_create_link_pending_publish",
        "local_draft_remove_link_pending_publish",
        "local_draft_edit_conflicts_with_provider"
      ]
    },
    "link_sync_pending_state_class": {
      "type": "string",
      "enum": [
        "in_sync_provider_observed",
        "pending_publish_local_draft",
        "pending_publish_queued",
        "pending_drain_offline_captured",
        "pending_provider_callback_after_publish",
        "stale_provider_unreachable",
        "stale_freshness_floor_unsatisfied"
      ]
    },
    "link_conflict_resolution_posture_class": {
      "type": "string",
      "enum": [
        "no_conflict_detected",
        "conflict_provider_updated_awaiting_user_choice",
        "conflict_local_edit_conflicts_awaiting_user_choice",
        "conflict_resolved_keep_provider_truth",
        "conflict_resolved_keep_local_draft",
        "conflict_resolved_merge_into_new_provider_state",
        "conflict_blocked_pending_policy"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    }
  }
}
