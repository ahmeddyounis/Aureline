{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/providers/stable_provider_account_install_grant_registry.schema.json",
  "title": "Stable provider account/install-grant registry",
  "description": "Stable registry packet combining provider account entries, installation-grant entries, and project/board/space mapping review rows. Every claimed provider lane MUST be able to answer: who is Aureline acting as, which project/board/space is targeted, what is the current health state, which object types are supported, and which action mode is available.",
  "type": "object",
  "required": ["record_kind", "schema_version", "shared_contract_ref", "packet_id", "generated_at", "registry", "provider_accounts", "install_grants", "mapping_rows", "support_export", "inspection"],
  "properties": {
    "record_kind": { "type": "string", "const": "providers_stable_account_install_grant_registry_packet" },
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": { "type": "string", "const": "providers:stable_account_install_grant_registry:v1" },
    "packet_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "registry": {
      "type": "object",
      "required": ["record_kind", "schema_version", "shared_contract_ref", "registry_id", "provider_account_count", "install_grant_count", "mapping_row_count", "invalidation_reasons", "actionable", "generated_at", "summary_label"],
      "properties": {
        "record_kind": { "type": "string", "const": "providers_stable_registry_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "providers:stable_account_install_grant_registry:v1" },
        "registry_id": { "type": "string", "minLength": 1 },
        "provider_account_count": { "type": "integer", "minimum": 0 },
        "install_grant_count": { "type": "integer", "minimum": 0 },
        "mapping_row_count": { "type": "integer", "minimum": 0 },
        "invalidation_reasons": { "type": "array", "items": { "type": "string" } },
        "actionable": { "type": "boolean" },
        "generated_at": { "type": "string", "format": "date-time" },
        "summary_label": { "type": "string", "minLength": 1 }
      }
    },
    "provider_accounts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["record_kind", "schema_version", "shared_contract_ref", "entry_id", "provider_family", "provider_family_token", "canonical_host_ref", "org_tenant_scope_ref", "acting_identity_class", "acting_identity_class_token", "health_state", "health_state_token", "supported_object_types", "action_mode", "action_mode_token", "connected_account_row_ref", "summary_label"],
        "properties": {
          "record_kind": { "type": "string", "const": "providers_stable_provider_account_record" },
          "schema_version": { "type": "integer", "const": 1 },
          "shared_contract_ref": { "type": "string", "const": "providers:stable_account_install_grant_registry:v1" },
          "entry_id": { "type": "string", "minLength": 1 },
          "provider_family": { "type": "string", "enum": ["code_host", "issue_tracker", "ci_checks"] },
          "provider_family_token": { "type": "string" },
          "canonical_host_ref": { "type": "string", "minLength": 1 },
          "org_tenant_scope_ref": { "type": "string", "minLength": 1 },
          "acting_identity_class": { "type": "string", "enum": ["connected_account", "installation_grant", "delegated_credential"] },
          "acting_identity_class_token": { "type": "string" },
          "health_state": { "type": "string", "enum": ["healthy", "degraded_stale_credentials", "degraded_limited_scope_session", "blocked_policy_locked_mapping", "blocked_provider_unreachable", "blocked_auth_loss", "offline_capture_only"] },
          "health_state_token": { "type": "string" },
          "supported_object_types": { "type": "array", "items": { "type": "string" } },
          "action_mode": { "type": "string", "enum": ["read_only", "comment_or_link", "full_edit", "offline_capture_only", "publish_later", "handoff_only"] },
          "action_mode_token": { "type": "string" },
          "connected_account_row_ref": { "type": "string", "minLength": 1 },
          "summary_label": { "type": "string", "minLength": 1 }
        }
      }
    },
    "install_grants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["record_kind", "schema_version", "shared_contract_ref", "entry_id", "provider_family", "provider_family_token", "canonical_host_ref", "org_tenant_scope_ref", "acting_identity_class", "acting_identity_class_token", "health_state", "health_state_token", "supported_object_types", "action_mode", "action_mode_token", "installation_grant_row_ref", "summary_label"],
        "properties": {
          "record_kind": { "type": "string", "const": "providers_stable_install_grant_record" },
          "schema_version": { "type": "integer", "const": 1 },
          "shared_contract_ref": { "type": "string", "const": "providers:stable_account_install_grant_registry:v1" },
          "entry_id": { "type": "string", "minLength": 1 },
          "provider_family": { "type": "string", "enum": ["code_host", "issue_tracker", "ci_checks"] },
          "provider_family_token": { "type": "string" },
          "canonical_host_ref": { "type": "string", "minLength": 1 },
          "org_tenant_scope_ref": { "type": "string", "minLength": 1 },
          "acting_identity_class": { "type": "string", "enum": ["connected_account", "installation_grant", "delegated_credential"] },
          "acting_identity_class_token": { "type": "string" },
          "health_state": { "type": "string", "enum": ["healthy", "degraded_stale_credentials", "degraded_limited_scope_session", "blocked_policy_locked_mapping", "blocked_provider_unreachable", "blocked_auth_loss", "offline_capture_only"] },
          "health_state_token": { "type": "string" },
          "supported_object_types": { "type": "array", "items": { "type": "string" } },
          "action_mode": { "type": "string", "enum": ["read_only", "comment_or_link", "full_edit", "offline_capture_only", "publish_later", "handoff_only"] },
          "action_mode_token": { "type": "string" },
          "installation_grant_row_ref": { "type": "string", "minLength": 1 },
          "summary_label": { "type": "string", "minLength": 1 }
        }
      }
    },
    "mapping_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["record_kind", "schema_version", "shared_contract_ref", "mapping_row_id", "lane", "lane_token", "target_kind", "target_kind_token", "target_ref", "stale_state", "stale_state_token", "action_mode", "action_mode_token", "policy_blocked", "stale", "beta_mapping_review_row_ref", "summary_label"],
        "properties": {
          "record_kind": { "type": "string", "const": "providers_stable_mapping_review_row_record" },
          "schema_version": { "type": "integer", "const": 1 },
          "shared_contract_ref": { "type": "string", "const": "providers:stable_account_install_grant_registry:v1" },
          "mapping_row_id": { "type": "string", "minLength": 1 },
          "lane": { "type": "string", "enum": ["issue_or_work_item", "review_decision", "incident_handoff", "publish_later"] },
          "lane_token": { "type": "string" },
          "target_kind": { "type": "string", "enum": ["board", "project", "space", "repository", "incident_queue"] },
          "target_kind_token": { "type": "string" },
          "target_ref": { "type": "string", "minLength": 1 },
          "fallback_target_ref": { "type": ["string", "null"] },
          "stale_state": { "type": "string", "enum": ["current", "stale_within_grace", "stale_blocks_mutation", "policy_blocked", "fallback_active"] },
          "stale_state_token": { "type": "string" },
          "action_mode": { "type": "string", "enum": ["read_only", "comment_or_link", "full_edit", "offline_capture_only", "publish_later", "handoff_only"] },
          "action_mode_token": { "type": "string" },
          "policy_blocked": { "type": "boolean" },
          "stale": { "type": "boolean" },
          "beta_mapping_review_row_ref": { "type": "string", "minLength": 1 },
          "summary_label": { "type": "string", "minLength": 1 }
        }
      }
    },
    "support_export": {
      "type": "object",
      "required": ["record_kind", "schema_version", "shared_contract_ref", "support_export_id", "reopen_context_ref", "consumer_surfaces", "source_schema_refs", "raw_url_export_allowed", "raw_provider_payload_export_allowed", "redaction_class", "summary_label"],
      "properties": {
        "record_kind": { "type": "string", "const": "providers_stable_registry_support_export_packet" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "providers:stable_account_install_grant_registry:v1" },
        "support_export_id": { "type": "string", "minLength": 1 },
        "reopen_context_ref": { "type": "string", "minLength": 1 },
        "consumer_surfaces": { "type": "array", "items": { "type": "string" } },
        "source_schema_refs": { "type": "array", "items": { "type": "string" } },
        "raw_url_export_allowed": { "type": "boolean", "const": false },
        "raw_provider_payload_export_allowed": { "type": "boolean", "const": false },
        "redaction_class": { "type": "string", "minLength": 1 },
        "summary_label": { "type": "string", "minLength": 1 }
      }
    },
    "inspection": {
      "type": "object",
      "required": ["record_kind", "schema_version", "shared_contract_ref", "registry_id_ref", "healthy_account_present", "degraded_account_present", "healthy_grant_present", "degraded_grant_present", "policy_blocked_mapping_present", "stale_mapping_present", "full_edit_lane_present", "publish_later_lane_present", "offline_capture_only_lane_present", "handoff_only_lane_present", "actionable", "invalidated", "provider_account_count", "install_grant_count", "mapping_row_count", "summary_label"],
      "properties": {
        "record_kind": { "type": "string", "const": "providers_stable_registry_inspection_record" },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": { "type": "string", "const": "providers:stable_account_install_grant_registry:v1" },
        "registry_id_ref": { "type": "string", "minLength": 1 },
        "healthy_account_present": { "type": "boolean" },
        "degraded_account_present": { "type": "boolean" },
        "healthy_grant_present": { "type": "boolean" },
        "degraded_grant_present": { "type": "boolean" },
        "policy_blocked_mapping_present": { "type": "boolean" },
        "stale_mapping_present": { "type": "boolean" },
        "full_edit_lane_present": { "type": "boolean" },
        "publish_later_lane_present": { "type": "boolean" },
        "offline_capture_only_lane_present": { "type": "boolean" },
        "handoff_only_lane_present": { "type": "boolean" },
        "actionable": { "type": "boolean" },
        "invalidated": { "type": "boolean" },
        "provider_account_count": { "type": "integer", "minimum": 0 },
        "install_grant_count": { "type": "integer", "minimum": 0 },
        "mapping_row_count": { "type": "integer", "minimum": 0 },
        "summary_label": { "type": "string", "minLength": 1 }
      }
    }
  }
}
