{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/providers/infrastructure_intelligence.schema.json",
  "title": "Aureline infrastructure source-intelligence alpha",
  "description": "Boundary schema for infrastructure_intelligence_alpha_page_record. The page publishes read-only relationship intelligence for claimed Terraform, Kubernetes, container, CI, and policy connectors. Resources and edges preserve source class, truth layer, freshness, provenance, partiality, and control-plane boundary labels. Raw manifests, logs, URLs, tokens, provider payloads, and mutation requests never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "captured_at",
    "contract_refs",
    "connectors",
    "resources",
    "relationships",
    "consumer_projections",
    "promotion_gate",
    "support_summary"
  ],
  "properties": {
    "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
    "record_kind": { "const": "infrastructure_intelligence_alpha_page_record" },
    "schema_version": { "const": 1 },
    "shared_contract_ref": {
      "const": "providers:infrastructure_source_intelligence_alpha:v1"
    },
    "page_id": { "$ref": "#/$defs/opaque_ref" },
    "captured_at": { "type": "string", "format": "date-time" },
    "contract_refs": { "$ref": "#/$defs/contract_refs" },
    "connectors": {
      "type": "array",
      "items": { "$ref": "#/$defs/connector_record" },
      "minItems": 1
    },
    "resources": {
      "type": "array",
      "items": { "$ref": "#/$defs/resource_record" },
      "minItems": 1
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "#/$defs/relationship_record" },
      "minItems": 1
    },
    "consumer_projections": {
      "type": "array",
      "items": { "$ref": "#/$defs/consumer_projection" },
      "minItems": 1
    },
    "promotion_gate": { "$ref": "#/$defs/promotion_gate" },
    "support_summary": { "$ref": "#/$defs/reviewable_text" }
  },
  "$defs": {
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque ref safe for logs, support bundles, and review packets. Raw URLs, hostnames, tokens, raw manifests, raw logs, and provider payloads are forbidden."
    },
    "reviewable_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "$ref": "#/$defs/opaque_ref" },
        "scenario": { "$ref": "#/$defs/reviewable_text" },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "connector_kind": {
      "type": "string",
      "enum": [
        "terraform_workspace",
        "kubernetes_cluster",
        "container_runtime",
        "ci_provider",
        "policy_engine"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "terraform_hcl",
        "kubernetes_manifest",
        "container_descriptor",
        "ci_environment_descriptor",
        "policy_access_config"
      ]
    },
    "truth_layer": {
      "type": "string",
      "enum": [
        "authored",
        "rendered",
        "planned",
        "observed",
        "provider_overlay",
        "cached"
      ]
    },
    "read_mode": {
      "type": "string",
      "enum": [
        "read_only_source_intelligence",
        "read_only_provider_overlay",
        "imported_snapshot_only"
      ]
    },
    "control_plane_boundary": {
      "type": "string",
      "enum": [
        "read_only_no_mutation_authority",
        "compare_only_preview",
        "external_handoff_required",
        "in_product_mutation_claimed"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "fresh",
        "stale_within_window",
        "expired_beyond_window",
        "never_observed",
        "revoked_or_disconnected"
      ]
    },
    "relationship_kind": {
      "type": "string",
      "enum": [
        "module_to_module",
        "variable_output",
        "resource_to_provider",
        "plan_to_resource",
        "source_to_rendered_object",
        "object_to_live_resource",
        "object_to_log_or_event_stream",
        "service_to_port",
        "run_to_artifact",
        "policy_to_target_resource",
        "policy_to_enforcement_result",
        "resource_to_runbook"
      ]
    },
    "confidence_class": {
      "type": "string",
      "enum": ["verified", "direct", "transitive", "inferred", "unknown"]
    },
    "partiality_class": {
      "type": "string",
      "enum": [
        "complete",
        "partial_index",
        "partial_retrieval",
        "permission_limited",
        "unavailable"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": ["search", "review", "support", "ai_context"]
    },
    "promotion_state": {
      "type": "string",
      "enum": [
        "promotion_ready",
        "blocked_truth_drift",
        "blocked_validation_defects"
      ]
    },
    "freshness_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["freshness_class", "freshness_floor_ref"],
      "properties": {
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "observed_at": { "type": "string", "format": "date-time" },
        "freshness_floor_ref": { "$ref": "#/$defs/opaque_ref" },
        "stale_after": { "type": "string", "minLength": 1 },
        "degraded_reason": { "$ref": "#/$defs/reviewable_text" },
        "import_session_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "target_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_ref",
        "account_or_project_ref",
        "environment_ref",
        "connector_class_label"
      ],
      "properties": {
        "provider_ref": { "$ref": "#/$defs/opaque_ref" },
        "account_or_project_ref": { "$ref": "#/$defs/opaque_ref" },
        "environment_ref": { "$ref": "#/$defs/opaque_ref" },
        "cluster_ref": { "$ref": "#/$defs/opaque_ref" },
        "namespace_ref": { "$ref": "#/$defs/opaque_ref" },
        "region_ref": { "$ref": "#/$defs/opaque_ref" },
        "connector_class_label": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "resource_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity_class", "resource_kind", "resource_name_ref"],
      "properties": {
        "identity_class": { "$ref": "#/$defs/opaque_ref" },
        "resource_kind": { "$ref": "#/$defs/opaque_ref" },
        "resource_name_ref": { "$ref": "#/$defs/opaque_ref" },
        "namespace_or_project_ref": { "$ref": "#/$defs/opaque_ref" },
        "address_or_selector_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "connected_provider_registry_schema_ref",
        "provider_object_schema_ref",
        "target_context_schema_ref",
        "search_result_identity_schema_ref",
        "review_workspace_schema_ref",
        "support_bundle_schema_ref",
        "content_integrity_schema_ref",
        "ai_context_schema_ref"
      ],
      "properties": {
        "connected_provider_registry_schema_ref": { "$ref": "#/$defs/opaque_ref" },
        "provider_object_schema_ref": { "$ref": "#/$defs/opaque_ref" },
        "target_context_schema_ref": { "$ref": "#/$defs/opaque_ref" },
        "search_result_identity_schema_ref": { "$ref": "#/$defs/opaque_ref" },
        "review_workspace_schema_ref": { "$ref": "#/$defs/opaque_ref" },
        "support_bundle_schema_ref": { "$ref": "#/$defs/opaque_ref" },
        "content_integrity_schema_ref": { "$ref": "#/$defs/opaque_ref" },
        "ai_context_schema_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "connector_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "connector_id",
        "connector_kind",
        "connector_label",
        "provider_descriptor_ref",
        "target_context",
        "source_class",
        "freshness",
        "read_mode",
        "control_plane_boundary",
        "read_only_source_intelligence",
        "mutation_authority_excluded",
        "hidden_ai_writes_allowed",
        "hidden_provider_writes_allowed",
        "support_summary"
      ],
      "properties": {
        "record_kind": { "const": "infrastructure_intelligence_connector_record" },
        "schema_version": { "const": 1 },
        "shared_contract_ref": { "const": "providers:infrastructure_source_intelligence_alpha:v1" },
        "connector_id": { "$ref": "#/$defs/opaque_ref" },
        "connector_kind": { "$ref": "#/$defs/connector_kind" },
        "connector_label": { "$ref": "#/$defs/reviewable_text" },
        "provider_descriptor_ref": { "$ref": "#/$defs/opaque_ref" },
        "target_context": { "$ref": "#/$defs/target_context" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "freshness": { "$ref": "#/$defs/freshness_truth" },
        "read_mode": { "$ref": "#/$defs/read_mode" },
        "control_plane_boundary": { "$ref": "#/$defs/control_plane_boundary" },
        "read_only_source_intelligence": { "const": true },
        "mutation_authority_excluded": { "const": true },
        "hidden_ai_writes_allowed": { "const": false },
        "hidden_provider_writes_allowed": { "const": false },
        "support_summary": { "$ref": "#/$defs/reviewable_text" }
      }
    },
    "resource_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "resource_id",
        "connector_ref",
        "display_label",
        "source_artifact_ref",
        "resource_identity",
        "source_class",
        "truth_layer",
        "freshness",
        "partiality",
        "provider_overlay_replaces_repo_truth",
        "active_control_plane_mutation_authority",
        "provenance_refs",
        "support_summary"
      ],
      "properties": {
        "record_kind": { "const": "infrastructure_intelligence_resource_record" },
        "schema_version": { "const": 1 },
        "shared_contract_ref": { "const": "providers:infrastructure_source_intelligence_alpha:v1" },
        "resource_id": { "$ref": "#/$defs/opaque_ref" },
        "connector_ref": { "$ref": "#/$defs/opaque_ref" },
        "display_label": { "$ref": "#/$defs/reviewable_text" },
        "source_artifact_ref": { "$ref": "#/$defs/opaque_ref" },
        "resource_identity": { "$ref": "#/$defs/resource_identity" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "truth_layer": { "$ref": "#/$defs/truth_layer" },
        "freshness": { "$ref": "#/$defs/freshness_truth" },
        "partiality": { "$ref": "#/$defs/partiality_class" },
        "partiality_reason": { "$ref": "#/$defs/reviewable_text" },
        "provider_overlay_replaces_repo_truth": { "const": false },
        "active_control_plane_mutation_authority": { "const": false },
        "provenance_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "minItems": 1
        },
        "support_summary": { "$ref": "#/$defs/reviewable_text" }
      }
    },
    "relationship_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "relationship_id",
        "from_resource_ref",
        "to_resource_ref",
        "relationship_kind",
        "truth_layer",
        "relationship_source",
        "freshness",
        "confidence_class",
        "partiality",
        "provenance_refs",
        "support_summary"
      ],
      "properties": {
        "record_kind": { "const": "infrastructure_intelligence_relationship_record" },
        "schema_version": { "const": 1 },
        "shared_contract_ref": { "const": "providers:infrastructure_source_intelligence_alpha:v1" },
        "relationship_id": { "$ref": "#/$defs/opaque_ref" },
        "from_resource_ref": { "$ref": "#/$defs/opaque_ref" },
        "to_resource_ref": { "$ref": "#/$defs/opaque_ref" },
        "relationship_kind": { "$ref": "#/$defs/relationship_kind" },
        "truth_layer": { "$ref": "#/$defs/truth_layer" },
        "relationship_source": { "$ref": "#/$defs/source_class" },
        "freshness": { "$ref": "#/$defs/freshness_truth" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "partiality": { "$ref": "#/$defs/partiality_class" },
        "partiality_reason": { "$ref": "#/$defs/reviewable_text" },
        "provenance_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "minItems": 1
        },
        "support_summary": { "$ref": "#/$defs/reviewable_text" }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "projection_id",
        "surface",
        "source_packet_ref",
        "relationship_refs",
        "resource_refs",
        "freshness",
        "uses_same_relationship_packet",
        "parallel_truth_store_created",
        "partiality",
        "support_summary"
      ],
      "properties": {
        "record_kind": { "const": "infrastructure_intelligence_consumer_projection_record" },
        "schema_version": { "const": 1 },
        "shared_contract_ref": { "const": "providers:infrastructure_source_intelligence_alpha:v1" },
        "projection_id": { "$ref": "#/$defs/opaque_ref" },
        "surface": { "$ref": "#/$defs/consumer_surface" },
        "source_packet_ref": { "$ref": "#/$defs/opaque_ref" },
        "relationship_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "minItems": 1
        },
        "resource_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "minItems": 1
        },
        "freshness": { "$ref": "#/$defs/freshness_truth" },
        "uses_same_relationship_packet": { "const": true },
        "parallel_truth_store_created": { "const": false },
        "partiality": { "$ref": "#/$defs/partiality_class" },
        "partiality_reason": { "$ref": "#/$defs/reviewable_text" },
        "support_summary": { "$ref": "#/$defs/reviewable_text" }
      }
    },
    "promotion_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "docs_truth_ref",
        "support_export_ref",
        "ui_truth_ref",
        "operator_truth_alignment",
        "promotion_state",
        "gate_summary"
      ],
      "properties": {
        "docs_truth_ref": { "$ref": "#/$defs/opaque_ref" },
        "support_export_ref": { "$ref": "#/$defs/opaque_ref" },
        "ui_truth_ref": { "$ref": "#/$defs/opaque_ref" },
        "operator_truth_alignment": { "type": "boolean" },
        "promotion_state": { "$ref": "#/$defs/promotion_state" },
        "gate_summary": { "$ref": "#/$defs/reviewable_text" }
      }
    }
  }
}
