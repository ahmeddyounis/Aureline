{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/providers/provider_object.schema.json",
  "title": "Aureline provider-object model alpha",
  "description": "Boundary schema for the provider_object_model_alpha_page_record consumed by the aureline-provider crate. The page publishes typed local object models for code-host pull requests and branches, issue/work-item rows, and CI check, pipeline, log, artifact, and annotation rows. Every row names its source class, freshness truth, current publish state, user-facing mode (local_draft, publish_now, open_in_provider, publish_later, inspect_only), and the typed degraded action it still offers. Continuity observations record per-row offline, stale, expired, revoked, disagreement, or never-observed states with the retained capability the local model preserves. Raw provider URLs, raw provider payloads, raw tokens, callback bodies, and artifact bodies never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "contract_refs",
    "rows",
    "support_export_summary"
  ],
  "properties": {
    "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
    "record_kind": { "const": "provider_object_model_alpha_page_record" },
    "schema_version": { "$ref": "#/$defs/schema_version" },
    "shared_contract_ref": {
      "type": "string",
      "const": "providers:provider_object_model_alpha:v1"
    },
    "page_id": { "$ref": "#/$defs/opaque_id" },
    "contract_refs": { "$ref": "#/$defs/contract_refs" },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/provider_object_row_record" },
      "minItems": 1
    },
    "continuity_observations": {
      "type": "array",
      "items": { "$ref": "#/$defs/provider_object_continuity_observation_record" }
    },
    "support_export_summary": { "$ref": "#/$defs/reviewable_sentence" }
  },
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque ref safe for logs, support bundles, and audit packets. Raw provider URLs and raw tokens are forbidden."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 640
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 }
      }
    },
    "provider_family": {
      "type": "string",
      "enum": ["code_host", "issue_tracker", "ci_checks"]
    },
    "object_kind": {
      "type": "string",
      "enum": [
        "pull_request",
        "branch",
        "issue_or_work_item",
        "check_run",
        "pipeline_run",
        "pipeline_log",
        "pipeline_artifact",
        "pipeline_annotation"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "live_provider",
        "cached_provider_overlay",
        "imported_snapshot",
        "mirrored_or_self_hosted",
        "local_draft_only",
        "offline_unverified_capture"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "fresh",
        "stale_within_window",
        "expired_beyond_window",
        "never_observed",
        "revoked_or_disconnected"
      ]
    },
    "publish_state_class": {
      "type": "string",
      "enum": [
        "local_draft_only",
        "publish_now_pending_review",
        "publish_now_published_observed",
        "open_in_provider_pending",
        "publish_later_queued",
        "publish_later_drained",
        "published_observed_authoritative",
        "inspect_only_imported",
        "offline_unverified",
        "revoked_at_provider",
        "disagrees_with_local"
      ]
    },
    "mode_class": {
      "type": "string",
      "enum": [
        "local_draft_mode",
        "publish_now_mode",
        "open_in_provider_mode",
        "publish_later_mode",
        "inspect_only_mode"
      ]
    },
    "degraded_action_class": {
      "type": "string",
      "enum": [
        "none_required",
        "continue_local_authoring",
        "queue_publish_later",
        "open_in_provider_browser_handoff",
        "export_evidence_packet",
        "hold_for_freshness_repair",
        "hold_for_reauth",
        "hold_for_rescope"
      ]
    },
    "continuity_observation_class": {
      "type": "string",
      "enum": [
        "provider_offline",
        "provider_stale_within_window",
        "provider_expired_beyond_window",
        "provider_revoked_or_disconnected",
        "provider_disagrees_with_local",
        "provider_never_observed"
      ]
    },
    "retained_capability_class": {
      "type": "string",
      "enum": [
        "local_draft_authoring_retained",
        "publish_later_queuing_retained",
        "inspect_only_retained",
        "browser_handoff_offered",
        "no_capability_retained"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "connected_provider_registry_schema_ref",
        "publish_later_queue_alpha_schema_ref",
        "publish_later_record_schema_ref",
        "browser_handoff_packet_schema_ref",
        "approval_ticket_alpha_schema_ref",
        "change_object_alpha_schema_ref"
      ],
      "properties": {
        "connected_provider_registry_schema_ref": { "$ref": "#/$defs/opaque_id" },
        "publish_later_queue_alpha_schema_ref": { "$ref": "#/$defs/opaque_id" },
        "publish_later_record_schema_ref": { "$ref": "#/$defs/opaque_id" },
        "browser_handoff_packet_schema_ref": { "$ref": "#/$defs/opaque_id" },
        "approval_ticket_alpha_schema_ref": { "$ref": "#/$defs/opaque_id" },
        "change_object_alpha_schema_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "object_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_class", "canonical_host_ref", "tenant_or_org_scope_ref"],
      "properties": {
        "source_class": { "$ref": "#/$defs/source_class" },
        "canonical_host_ref": { "$ref": "#/$defs/opaque_id" },
        "tenant_or_org_scope_ref": { "$ref": "#/$defs/opaque_id" },
        "environment_ref": { "$ref": "#/$defs/opaque_id" },
        "import_session_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "freshness_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["freshness_class", "freshness_floor_ref"],
      "properties": {
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "observed_at": { "type": "string", "format": "date-time" },
        "freshness_floor_ref": { "$ref": "#/$defs/opaque_id" },
        "stale_after": { "type": "string" },
        "degraded_reason": { "$ref": "#/$defs/reviewable_sentence" },
        "import_session_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "route_origin_label": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_choice",
        "target_class",
        "route_label",
        "transport_label",
        "target_identity_ref"
      ],
      "properties": {
        "route_choice": { "type": "string", "minLength": 1 },
        "target_class": { "type": "string", "minLength": 1 },
        "route_label": { "$ref": "#/$defs/reviewable_sentence" },
        "transport_label": { "$ref": "#/$defs/reviewable_sentence" },
        "target_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "tunnel_session_ref": { "$ref": "#/$defs/opaque_id" },
        "exposure_posture": { "type": "string", "minLength": 1 }
      }
    },
    "target_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_ref_class", "target_ref", "target_label"],
      "properties": {
        "target_ref_class": { "$ref": "#/$defs/opaque_id" },
        "target_ref": { "$ref": "#/$defs/opaque_id" },
        "target_label": { "$ref": "#/$defs/reviewable_sentence" },
        "route_origin": { "$ref": "#/$defs/route_origin_label" }
      }
    },
    "provider_object_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "object_row_id",
        "display_label",
        "provider_descriptor_ref",
        "provider_family",
        "object_kind",
        "target_ref",
        "source",
        "freshness",
        "publish_state",
        "mode",
        "degraded_action",
        "audit_event_refs",
        "redaction_class",
        "raw_payload_refs_present",
        "local_editing_preserved",
        "support_export_summary",
        "observed_at"
      ],
      "properties": {
        "record_kind": { "const": "provider_object_model_alpha_row_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": {
          "type": "string",
          "const": "providers:provider_object_model_alpha:v1"
        },
        "object_row_id": { "$ref": "#/$defs/opaque_id" },
        "display_label": { "$ref": "#/$defs/reviewable_sentence" },
        "provider_descriptor_ref": { "$ref": "#/$defs/opaque_id" },
        "provider_family": { "$ref": "#/$defs/provider_family" },
        "object_kind": { "$ref": "#/$defs/object_kind" },
        "target_ref": { "$ref": "#/$defs/target_ref" },
        "source": { "$ref": "#/$defs/object_source" },
        "freshness": { "$ref": "#/$defs/freshness_truth" },
        "publish_state": { "$ref": "#/$defs/publish_state_class" },
        "mode": { "$ref": "#/$defs/mode_class" },
        "degraded_action": { "$ref": "#/$defs/degraded_action_class" },
        "local_draft_ref": { "$ref": "#/$defs/opaque_id" },
        "publish_later_queue_item_ref": { "$ref": "#/$defs/opaque_id" },
        "approval_ticket_ref": { "$ref": "#/$defs/opaque_id" },
        "browser_handoff_packet_ref": { "$ref": "#/$defs/opaque_id" },
        "imported_snapshot_ref": { "$ref": "#/$defs/opaque_id" },
        "parent_object_row_ref": { "$ref": "#/$defs/opaque_id" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "raw_payload_refs_present": { "type": "boolean", "const": false },
        "local_editing_preserved": { "type": "boolean", "const": true },
        "support_export_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "observed_at": { "type": "string", "format": "date-time" }
      }
    },
    "provider_object_continuity_observation_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "observation_id",
        "object_row_ref",
        "observation_class",
        "retained_capability_class",
        "degraded_action",
        "rationale_summary",
        "observed_at",
        "silent_mutation_authority_widened",
        "local_editing_preserved"
      ],
      "properties": {
        "record_kind": {
          "const": "provider_object_model_alpha_continuity_observation_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": {
          "type": "string",
          "const": "providers:provider_object_model_alpha:v1"
        },
        "observation_id": { "$ref": "#/$defs/opaque_id" },
        "object_row_ref": { "$ref": "#/$defs/opaque_id" },
        "observation_class": { "$ref": "#/$defs/continuity_observation_class" },
        "retained_capability_class": { "$ref": "#/$defs/retained_capability_class" },
        "degraded_action": { "$ref": "#/$defs/degraded_action_class" },
        "rationale_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "observed_at": { "type": "string", "format": "date-time" },
        "silent_mutation_authority_widened": { "type": "boolean", "const": false },
        "local_editing_preserved": { "type": "boolean" }
      }
    }
  }
}
