{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/providers/comment_sync_state.schema.json",
  "title": "Aureline provider comment sync state beta entry point",
  "description": "Provider-facing schema for durable comment-sync state records bound to the same work-item object model used by status-transition and offline-handoff records. Provider-owned comments, local draft comments, offline capture packets, queued publishes, and failed or conflicted publishes stay on separate enum lanes. Raw comment text and raw provider URLs are forbidden.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "comment_sync_id",
    "work_item_detail_record_id_ref",
    "comment_origin_class",
    "comment_lifecycle_class",
    "comment_sync_state_class",
    "comment_publish_posture_class",
    "comment_conflict_class",
    "acting_as",
    "redaction_class",
    "raw_comment_text_present",
    "raw_provider_url_present",
    "captured_at",
    "support_export_summary"
  ],
  "properties": {
    "record_kind": { "const": "comment_sync_state_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "comment_sync_id": { "$ref": "#/$defs/opaque_id" },
    "work_item_detail_record_id_ref": { "$ref": "#/$defs/opaque_id" },
    "provider_comment_record_id_ref": { "$ref": "#/$defs/opaque_id" },
    "local_draft_comment_record_id_ref": { "$ref": "#/$defs/opaque_id" },
    "offline_handoff_packet_record_id_ref": { "$ref": "#/$defs/opaque_id" },
    "linked_publish_later_queue_item_record_id_ref": { "$ref": "#/$defs/opaque_id" },
    "linked_browser_handoff_packet_ref": { "$ref": "#/$defs/opaque_id" },
    "comment_origin_class": { "$ref": "#/$defs/comment_origin_class" },
    "comment_lifecycle_class": { "$ref": "#/$defs/comment_lifecycle_class" },
    "comment_sync_state_class": { "$ref": "#/$defs/comment_sync_state_class" },
    "comment_publish_posture_class": { "$ref": "#/$defs/comment_publish_posture_class" },
    "comment_conflict_class": { "$ref": "#/$defs/comment_conflict_class" },
    "acting_as": { "$ref": "#/$defs/provider_actor_class" },
    "typed_retry_route_class": { "$ref": "#/$defs/comment_retry_route_class" },
    "origin_disclosure": { "type": "object" },
    "policy_context": { "type": "object" },
    "redaction_class": { "$ref": "#/$defs/redaction_class" },
    "raw_comment_text_present": { "type": "boolean", "const": false },
    "raw_provider_url_present": { "type": "boolean", "const": false },
    "captured_at": { "type": "string", "minLength": 1 },
    "support_export_summary": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque ref safe for logs, manifests, support packets, and fixtures. Raw comment text, provider URLs, and tokens are forbidden."
    },
    "comment_origin_class": {
      "type": "string",
      "enum": [
        "provider_authoritative_comment",
        "local_draft_comment",
        "offline_capture_packet_comment",
        "imported_snapshot_comment",
        "ai_proposed_draft_comment"
      ]
    },
    "comment_lifecycle_class": {
      "type": "string",
      "enum": [
        "provider_observed_active",
        "provider_observed_edited",
        "provider_observed_deleted",
        "local_draft_create_never_published",
        "local_draft_edit_on_provider_comment",
        "local_draft_delete_on_provider_comment"
      ]
    },
    "comment_sync_state_class": {
      "type": "string",
      "enum": [
        "in_sync_provider_observed",
        "pending_publish_local_draft",
        "queued_publish_deferred",
        "pending_drain_offline_captured",
        "pending_provider_callback_after_publish",
        "publish_failed_typed_retry",
        "conflict_detected_awaiting_resolution",
        "stale_provider_unreachable"
      ]
    },
    "comment_publish_posture_class": {
      "type": "string",
      "enum": [
        "provider_published_observed",
        "local_draft_never_published",
        "queued_for_publish_later",
        "offline_captured_not_submitted",
        "publish_failed_awaiting_retry",
        "imported_evidence_only",
        "inspect_only_read_only"
      ]
    },
    "comment_conflict_class": {
      "type": "string",
      "enum": [
        "no_conflict",
        "conflict_provider_edited_after_draft",
        "conflict_provider_deleted_after_draft",
        "conflict_duplicate_publish_rejected",
        "conflict_policy_blocked_after_draft"
      ]
    },
    "comment_retry_route_class": {
      "type": "string",
      "enum": [
        "auto_retry_on_connectivity_restored",
        "auto_retry_on_provider_health_recovered",
        "auto_retry_on_account_reselected",
        "auto_retry_on_freshness_refresh",
        "auto_retry_on_conflict_resolved",
        "manual_retry_user_must_confirm_only",
        "no_retry_imported_evidence_only"
      ]
    },
    "provider_actor_class": {
      "type": "string",
      "enum": [
        "human_account",
        "installation_or_app_grant",
        "delegated_user_token",
        "project_scoped_grant",
        "policy_injected_service_identity",
        "unknown_actor_class"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    }
  }
}
