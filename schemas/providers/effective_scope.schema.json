{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/providers/effective_scope.schema.json",
  "title": "Aureline provider account-scope beta page (connected account, installation grant, delegated credential, effective-scope resolution, scope drift)",
  "description": "Page-level beta schema for the providers_account_scope_beta_page_record. The page separates connected-account, installation-grant, and delegated-credential identity rows; binds each provider-linked row to one acting-identity class and a typed effective-scope resolution; and projects scope-drift events that force reapproval or downgrade instead of silently keeping mutation authority. The schema-of-record lives at /crates/aureline-provider/src/account_scope/mod.rs. The broader cross-tool boundary vocabulary lives in /schemas/providers/effective_scope_resolution.schema.json; this file is the per-page beta projection consumed by admin, support, shell, and reviewer surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "source_matrix_ref",
    "connected_account_rows",
    "installation_grant_rows",
    "delegated_credential_rows",
    "resolution_rows",
    "scope_drift_events",
    "defects",
    "summary"
  ],
  "properties": {
    "record_kind": {
      "const": "providers_account_scope_beta_page_record"
    },
    "schema_version": { "$ref": "#/$defs/schema_version" },
    "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
    "source_matrix_ref": { "$ref": "#/$defs/non_empty_string" },
    "connected_account_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/connected_account_row" }
    },
    "installation_grant_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/installation_grant_row" }
    },
    "delegated_credential_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/delegated_credential_row" }
    },
    "resolution_rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/resolution_row" }
    },
    "scope_drift_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/scope_drift_event" }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/defect" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "providers:account_scope_beta:v1"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "profile_token": {
      "type": "string",
      "enum": ["connected", "mirror_only", "offline", "enterprise_managed"]
    },
    "acting_identity_class_token": {
      "type": "string",
      "enum": [
        "connected_account",
        "installation_grant",
        "delegated_credential"
      ]
    },
    "auth_source_token": {
      "type": "string",
      "enum": [
        "human_session",
        "installation_grant",
        "delegated_credential",
        "project_scoped_grant",
        "policy_injected_service"
      ]
    },
    "account_lifecycle_state_token": {
      "type": "string",
      "enum": [
        "active",
        "reauth_required",
        "revoked",
        "suspended",
        "unreachable"
      ]
    },
    "installation_grant_lifecycle_state_token": {
      "type": "string",
      "enum": [
        "installed",
        "uninstalled",
        "suspended",
        "scope_narrowed",
        "secret_expired"
      ]
    },
    "delegated_credential_lifecycle_state_token": {
      "type": "string",
      "enum": [
        "active",
        "revoked",
        "expired",
        "scope_narrowed",
        "delegator_lost_grant"
      ]
    },
    "decision_token": {
      "type": "string",
      "enum": ["allowed", "denied", "browser_only", "local_draft_only"]
    },
    "resolution_reason_token": {
      "type": "string",
      "enum": [
        "allowed",
        "allowed_with_downgrade",
        "allowed_with_browser_handoff",
        "allowed_with_deferred_publish",
        "denied_scope_missing",
        "denied_policy_bundle",
        "denied_workspace_trust",
        "denied_actor_class_forbidden",
        "denied_freshness_floor",
        "denied_revoked",
        "denied_suspended",
        "denied_approval_ticket_missing",
        "denied_step_up_required",
        "denied_unknown_actor_class"
      ]
    },
    "requested_action_token": {
      "type": "string",
      "enum": [
        "read_only_inspection",
        "human_authored_comment",
        "review_decision_publish",
        "issue_or_work_item_mutation",
        "ci_run_or_check_mutation",
        "release_publish",
        "credential_projection"
      ]
    },
    "reapproval_route_token": {
      "type": "string",
      "enum": [
        "none_required",
        "system_browser_reauth",
        "step_up_authenticator",
        "account_reselection",
        "installation_grant_reconsent",
        "delegated_credential_reissue",
        "browser_handoff",
        "publish_later_deferred",
        "admin_review_or_trust_grant"
      ]
    },
    "scope_drift_trigger_token": {
      "type": "string",
      "enum": [
        "grant_revoked",
        "grant_suspended",
        "scope_narrowed",
        "delegated_credential_expired",
        "installation_secret_expired",
        "actor_class_changed",
        "host_mismatch_detected",
        "tenant_or_org_membership_changed",
        "policy_epoch_rolled",
        "trust_state_downgraded",
        "freshness_floor_drifted"
      ]
    },
    "authority_downgrade_token": {
      "type": "string",
      "enum": [
        "no_downgrade_required",
        "force_inspect_only",
        "force_local_draft_only",
        "force_browser_handoff_only",
        "force_step_up_authenticator",
        "force_account_reselection",
        "force_admin_review",
        "force_disconnect_until_repair"
      ]
    },
    "provider_host_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonical_host_ref", "tenant_or_org_scope_ref", "host_label"],
      "properties": {
        "canonical_host_ref": { "$ref": "#/$defs/non_empty_string" },
        "tenant_or_org_scope_ref": { "$ref": "#/$defs/non_empty_string" },
        "host_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "connected_account_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_ref", "subject_label", "capability_hash_ref"],
