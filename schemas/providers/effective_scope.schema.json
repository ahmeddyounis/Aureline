        "provider_linked_row_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "connected_account_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "identity_row_id",
        "display_label",
        "profile",
        "profile_token",
        "acting_identity_class",
        "acting_identity_class_token",
        "subject",
        "provider_host",
        "auth_source",
        "auth_source_token",
        "lifecycle_state",
        "lifecycle_state_token",
        "lifecycle_note",
        "observed_at",
        "raw_token_material_present",
        "public_endpoint_fallback_offered",
        "local_editing_preserved"
      ],
      "properties": {
        "record_kind": {
          "const": "providers_account_scope_beta_connected_account_row_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "identity_row_id": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "profile": { "$ref": "#/$defs/profile_token" },
        "profile_token": { "$ref": "#/$defs/profile_token" },
        "acting_identity_class": { "const": "connected_account" },
        "acting_identity_class_token": { "const": "connected_account" },
        "subject": { "$ref": "#/$defs/connected_account_subject" },
        "provider_host": { "$ref": "#/$defs/provider_host_binding" },
        "auth_source": { "$ref": "#/$defs/auth_source_token" },
        "auth_source_token": { "$ref": "#/$defs/auth_source_token" },
        "lifecycle_state": { "$ref": "#/$defs/account_lifecycle_state_token" },
        "lifecycle_state_token": { "$ref": "#/$defs/account_lifecycle_state_token" },
        "lifecycle_note": { "type": "string" },
        "observed_at": { "$ref": "#/$defs/monotonic_timestamp" },
