{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/providers/provider_browser_handoff_alpha.schema.json",
  "title": "Aureline provider browser-handoff alpha: typed packets, import sessions, reconnect flows, and continuity observations on claimed provider rows",
  "description": "Provider-side boundary schema for the alpha browser-handoff record family that keeps external handoff and re-entry trustworthy by preserving origin, object identity, and intended follow-up action across browser transitions and provider reconnects. Composes with — and never forks — the canonical provider-object alpha (/schemas/providers/provider_object.schema.json), the integration browser-handoff packet (/schemas/providers/browser_handoff_packet.schema.json), the publish-later queue alpha (/schemas/providers/publish_later_queue_alpha.schema.json), the approval-ticket alpha (/schemas/security/approval_ticket_alpha.schema.json), and the connected-provider registry alpha (/schemas/providers/connected_provider_registry.schema.json). Records carry opaque refs and structured fields only; raw URLs, raw tokens, raw callback bodies, and raw provider payloads never cross this boundary. Adding a new origin/destination/follow-up/state/outcome class is additive-minor and requires a schema-version bump; repurposing an existing value is breaking and requires a new contract row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/provider_browser_handoff_alpha_page_record" },
    { "$ref": "#/$defs/provider_browser_handoff_alpha_packet_record" },
    { "$ref": "#/$defs/provider_browser_handoff_alpha_import_session_record" },
    { "$ref": "#/$defs/provider_browser_handoff_alpha_reconnect_flow_record" },
    { "$ref": "#/$defs/provider_browser_handoff_alpha_continuity_observation_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this alpha export. Current value is 1. Bumped only on breaking payload changes; additive-optional fields do not bump this version."
    },

    "shared_contract_ref": {
      "type": "string",
      "const": "providers:provider_browser_handoff_alpha:v1",
      "description": "Stable shared contract id consumed by every record in this family."
    },

    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests and support bundles."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },

    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Short human-readable sentence safe to show on desktop, CLI, notifications, docs/help, support exports, and audit rollups. Raw URLs, raw tokens, raw callback bodies, and raw provider payloads never appear here."
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ],
      "description": "Declared redaction class reused from ADR-0007 / ADR-0010 redaction posture."
    },

    "provider_family": {
      "type": "string",
      "enum": ["code_host", "issue_tracker", "ci_checks"],
      "description": "Provider family reused verbatim from the connected-provider registry alpha."
    },

    "freshness_class": {
      "type": "string",
      "enum": [
        "fresh",
        "stale_within_window",
        "expired_beyond_window",
        "never_observed",
        "revoked_or_disconnected"
      ],
      "description": "Freshness class reused verbatim from the connected-provider registry alpha."
    },

    "freshness_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["freshness_class", "freshness_floor_ref"],
      "properties": {
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "observed_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "freshness_floor_ref": { "$ref": "#/$defs/non_empty_string" },
        "stale_after": { "type": "string" },
        "degraded_reason": { "type": "string" },
        "import_session_ref": { "type": "string" }
      },
      "description": "Freshness truth observed for an import session. Mirrors the connected-provider registry alpha freshness shape."
    },

    "origin_class": {
      "type": "string",
      "enum": [
        "workspace_start_center",
        "workspace_review_lane",
        "workspace_runtime_lane",
        "workspace_git_lane",
        "workspace_provider_lane",
        "workspace_support_lane",
        "headless_cli_surface"
      ],
      "description": "Workspace lane that minted the handoff packet. Names origin truth so support exports and audit rollups read the same answer."
    },

    "destination_class": {
      "type": "string",
      "enum": [
        "code_host_web",
        "issue_tracker_web",
        "ci_provider_web",
        "identity_provider_web",
        "managed_admin_web",
        "docs_or_portal_web"
      ],
      "description": "Destination class for the packet. Mirrors the integration browser-handoff packet vocabulary, narrowed to the shapes the alpha lane admits."
    },

    "follow_up_action_class": {
      "type": "string",
      "enum": [
        "return_to_local_draft_authoring",
        "return_to_publish_later_queue_item",
        "return_to_inspect_only_view",
        "return_to_review_anchor",
        "return_to_run_or_task_anchor",
        "return_to_change_lineage_view",
        "return_to_authority_repair",
        "return_to_truthful_placeholder"
      ],
      "description": "Intended follow-up action the user is asked to take when they return to product scope. A packet without a typed follow-up is refused at mint."
    },

    "packet_state_class": {
      "type": "string",
      "enum": [
        "minted_awaiting_confirmation",
        "user_confirmed_pending_launch",
        "launched_awaiting_return",
        "returned_authoritative_local_object",
        "returned_truthful_placeholder",
        "returned_provider_observed_authoritative",
        "returned_user_cancelled",
        "returned_callback_invalid",
        "returned_authority_revoked",
        "expired_unused"
      ],
      "description": "Packet-state vocabulary. Silent transition between states is forbidden."
    },

    "import_session_state_class": {
      "type": "string",
      "enum": [
        "pending_first_observation",
        "observed_fresh",
        "stale_within_window",
        "expired_beyond_window",
        "revoked_or_disconnected",
        "replaced_by_newer_session",
        "abandoned_by_user"
      ],
      "description": "Lifecycle state for an import session. Reopened provider flows replay the same session id so continuity is preserved across reconnect attempts."
    },

    "reconnect_outcome_class": {
      "type": "string",
      "enum": [
        "restored_authoritative_local_object",
        "restored_truthful_placeholder",
        "deferred_to_publish_later_queue",
        "browser_handoff_offered_again",
        "denied_unknown_actor",
        "denied_policy_or_trust_mismatch",
        "pending_reauth",
        "pending_rescope",
        "pending_reapproval"
      ],
      "description": "Typed outcome for a provider reconnect flow. A reconnect never silently drops; every outcome names where the user lands."
    },

    "placeholder_class": {
      "type": "string",
      "enum": [
        "local_object_evicted_beyond_retention",
        "superseded_by_newer_import_session",
        "revoked_and_local_body_wiped",
        "inspect_only_target_without_draft",
        "locked_by_trust_posture_change"
      ],
      "description": "Typed placeholder kind. A reconnect or returned packet must name exactly why the authoritative local object could not be restored."
    },

    "continuity_observation_class": {
      "type": "string",
      "enum": [
        "provider_offline",
        "provider_stale_within_window",
        "provider_expired_beyond_window",
        "provider_revoked_or_disconnected",
        "provider_disagrees_with_local",
        "provider_never_observed"
      ],
      "description": "Continuity observation class reused verbatim from the provider-object alpha so support exports read one vocabulary."
    },

    "retained_capability_class": {
      "type": "string",
      "enum": [
        "local_draft_authoring_retained",
        "publish_later_queuing_retained",
        "inspect_only_retained",
        "browser_handoff_offered",
        "no_capability_retained"
      ],
      "description": "Retained capability class reused verbatim from the provider-object alpha."
    },

    "degraded_action_class": {
      "type": "string",
      "enum": [
        "none_required",
        "continue_local_authoring",
        "queue_publish_later",
        "open_in_provider_browser_handoff",
        "export_evidence_packet",
        "hold_for_freshness_repair",
        "hold_for_reauth",
        "hold_for_rescope"
      ],
      "description": "Typed degraded-action class reused verbatim from the provider-object alpha."
    },

    "origin_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin_class",
        "host_identity_ref",
        "workspace_id_ref",
        "execution_context_id_ref"
      ],
      "properties": {
        "origin_class": { "$ref": "#/$defs/origin_class" },
        "host_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "workspace_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "execution_context_id_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "description": "Origin truth for one packet. Names the workspace lane that minted the packet and the host/workspace/execution-context lineage support can reconstruct from."
    },

    "destination_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "destination_class",
        "canonical_host_ref",
        "tenant_or_org_scope_ref",
        "provider_family"
      ],
      "properties": {
        "destination_class": { "$ref": "#/$defs/destination_class" },
        "canonical_host_ref": { "$ref": "#/$defs/non_empty_string" },
        "tenant_or_org_scope_ref": { "$ref": "#/$defs/non_empty_string" },
        "environment_ref": { "type": "string" },
        "provider_family": { "$ref": "#/$defs/provider_family" }
      },
      "description": "Destination truth for one packet. Raw URLs and raw query strings are forbidden — destinations are named through opaque host/tenant refs."
    },

    "contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_object_model_alpha_schema_ref",
        "browser_handoff_packet_schema_ref",
        "publish_later_queue_alpha_schema_ref",
        "approval_ticket_alpha_schema_ref",
        "connected_provider_registry_schema_ref"
      ],
      "properties": {
        "provider_object_model_alpha_schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "browser_handoff_packet_schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "publish_later_queue_alpha_schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "approval_ticket_alpha_schema_ref": { "$ref": "#/$defs/non_empty_string" },
        "connected_provider_registry_schema_ref": { "$ref": "#/$defs/non_empty_string" }
      },
      "description": "Upstream schemas this alpha page composes with. Every ref must be non-empty."
    },

    "provider_browser_handoff_alpha_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "packet_id",
        "display_label",
        "origin",
        "destination",
        "provider_object_row_ref",
        "provider_side_object_id",
        "intended_follow_up_action",
        "follow_up_summary",
        "packet_state",
        "audit_event_refs",
        "redaction_class",
        "raw_url_present",
        "raw_token_material_present",
        "raw_provider_payload_present",
        "silent_authority_widening_taken",
        "support_export_summary",
        "minted_at",
        "replay_expires_at"
      ],
      "properties": {
        "record_kind": { "const": "provider_browser_handoff_alpha_packet_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "display_label": { "$ref": "#/$defs/reviewable_sentence" },
        "origin": { "$ref": "#/$defs/origin_disclosure" },
        "destination": { "$ref": "#/$defs/destination_disclosure" },
        "provider_object_row_ref": { "$ref": "#/$defs/non_empty_string" },
        "provider_side_object_id": { "$ref": "#/$defs/non_empty_string" },
        "intended_follow_up_action": { "$ref": "#/$defs/follow_up_action_class" },
        "follow_up_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "packet_state": { "$ref": "#/$defs/packet_state_class" },
        "integration_packet_ref": { "type": "string" },
        "publish_later_queue_item_ref": { "type": "string" },
        "approval_ticket_ref": { "type": "string" },
        "import_session_ref": { "type": "string" },
        "return_summary": { "type": "string" },
        "placeholder_kind": { "$ref": "#/$defs/placeholder_class" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "raw_url_present": { "const": false },
        "raw_token_material_present": { "const": false },
        "raw_provider_payload_present": { "const": false },
        "silent_authority_widening_taken": { "const": false },
        "support_export_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "replay_expires_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Packets in a returned_truthful_placeholder state must cite a placeholder_kind.",
          "if": {
            "properties": {
              "packet_state": { "const": "returned_truthful_placeholder" }
            },
            "required": ["packet_state"]
          },
          "then": {
            "required": ["placeholder_kind"]
          }
        },
        {
          "description": "return_to_publish_later_queue_item follow-ups must cite a publish_later_queue_item_ref.",
          "if": {
            "properties": {
              "intended_follow_up_action": { "const": "return_to_publish_later_queue_item" }
            },
            "required": ["intended_follow_up_action"]
          },
          "then": {
            "properties": {
              "publish_later_queue_item_ref": { "$ref": "#/$defs/non_empty_string" }
            },
            "required": ["publish_later_queue_item_ref"]
          }
        },
        {
          "description": "return_to_authority_repair follow-ups must route to identity_provider_web or managed_admin_web.",
          "if": {
            "properties": {
              "intended_follow_up_action": { "const": "return_to_authority_repair" }
            },
            "required": ["intended_follow_up_action"]
          },
          "then": {
            "properties": {
              "destination": {
                "properties": {
                  "destination_class": {
                    "enum": ["identity_provider_web", "managed_admin_web"]
                  }
                }
              }
            }
          }
        }
      ],
      "description": "Typed browser-handoff packet. Names origin lane, destination class, provider-object row id, provider-side object id, and intended follow-up action so the packet never collapses into a generic 'Open in browser' affordance."
    },

    "provider_browser_handoff_alpha_import_session_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "import_session_id",
        "display_label",
        "provider_object_row_ref",
        "provider_family",
        "session_state",
        "freshness",
        "audit_event_refs",
        "redaction_class",
        "raw_provider_payload_present",
        "local_editing_preserved",
        "support_export_summary",
        "opened_at",
        "last_observed_at"
      ],
      "properties": {
        "record_kind": { "const": "provider_browser_handoff_alpha_import_session_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "import_session_id": { "$ref": "#/$defs/opaque_id" },
        "display_label": { "$ref": "#/$defs/reviewable_sentence" },
        "provider_object_row_ref": { "$ref": "#/$defs/non_empty_string" },
        "provider_family": { "$ref": "#/$defs/provider_family" },
        "session_state": { "$ref": "#/$defs/import_session_state_class" },
        "freshness": { "$ref": "#/$defs/freshness_truth" },
        "superseded_session_ref": { "type": "string" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "raw_provider_payload_present": { "const": false },
        "local_editing_preserved": { "const": true },
        "support_export_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "opened_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "last_observed_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "replaced_by_newer_session sessions must cite a superseded_session_ref.",
          "if": {
            "properties": {
              "session_state": { "const": "replaced_by_newer_session" }
            },
            "required": ["session_state"]
          },
          "then": {
            "properties": {
              "superseded_session_ref": { "$ref": "#/$defs/non_empty_string" }
            },
            "required": ["superseded_session_ref"]
          }
        }
      ],
      "description": "Import session record. Replays the same opaque session id across reconnect attempts so continuity is preserved without raw provider payload."
    },

    "provider_browser_handoff_alpha_reconnect_flow_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "reconnect_flow_id",
        "display_label",
        "import_session_ref",
        "bound_object_row_ref",
        "outcome",
        "outcome_summary",
        "audit_event_refs",
        "redaction_class",
        "local_editing_preserved",
        "silent_authority_widening_taken",
        "observed_at"
      ],
      "properties": {
        "record_kind": { "const": "provider_browser_handoff_alpha_reconnect_flow_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "reconnect_flow_id": { "$ref": "#/$defs/opaque_id" },
        "display_label": { "$ref": "#/$defs/reviewable_sentence" },
        "originating_packet_ref": { "type": "string" },
        "import_session_ref": { "$ref": "#/$defs/non_empty_string" },
        "bound_object_row_ref": { "$ref": "#/$defs/non_empty_string" },
        "outcome": { "$ref": "#/$defs/reconnect_outcome_class" },
        "restored_object_row_ref": { "type": "string" },
        "placeholder_kind": { "$ref": "#/$defs/placeholder_class" },
        "publish_later_queue_item_ref": { "type": "string" },
        "follow_up_packet_ref": { "type": "string" },
        "outcome_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "audit_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "local_editing_preserved": { "const": true },
        "silent_authority_widening_taken": { "const": false },
        "observed_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "restored_authoritative_local_object outcomes must cite a restored_object_row_ref.",
          "if": {
            "properties": {
              "outcome": { "const": "restored_authoritative_local_object" }
            },
            "required": ["outcome"]
          },
          "then": {
            "properties": {
              "restored_object_row_ref": { "$ref": "#/$defs/non_empty_string" }
            },
            "required": ["restored_object_row_ref"]
          }
        },
        {
          "description": "restored_truthful_placeholder outcomes must cite a placeholder_kind.",
          "if": {
            "properties": {
              "outcome": { "const": "restored_truthful_placeholder" }
            },
            "required": ["outcome"]
          },
          "then": {
            "required": ["placeholder_kind"]
          }
        },
        {
          "description": "deferred_to_publish_later_queue outcomes must cite a publish_later_queue_item_ref.",
          "if": {
            "properties": {
              "outcome": { "const": "deferred_to_publish_later_queue" }
            },
            "required": ["outcome"]
          },
          "then": {
            "properties": {
              "publish_later_queue_item_ref": { "$ref": "#/$defs/non_empty_string" }
            },
            "required": ["publish_later_queue_item_ref"]
          }
        },
        {
          "description": "browser_handoff_offered_again outcomes must cite a follow_up_packet_ref.",
          "if": {
            "properties": {
              "outcome": { "const": "browser_handoff_offered_again" }
            },
            "required": ["outcome"]
          },
          "then": {
            "properties": {
              "follow_up_packet_ref": { "$ref": "#/$defs/non_empty_string" }
            },
            "required": ["follow_up_packet_ref"]
          }
        }
      ],
      "description": "Provider reconnect flow. Names the typed outcome and (when applicable) the restored authoritative local object or truthful placeholder so re-entry into product scope is never silent."
    },

    "provider_browser_handoff_alpha_continuity_observation_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "observation_id",
        "observation_class",
        "retained_capability_class",
        "degraded_action",
        "rationale_summary",
        "observed_at",
        "silent_mutation_authority_widened",
        "local_editing_preserved"
      ],
      "properties": {
        "record_kind": {
          "const": "provider_browser_handoff_alpha_continuity_observation_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "observation_id": { "$ref": "#/$defs/opaque_id" },
        "bound_packet_ref": { "type": "string" },
        "bound_import_session_ref": { "type": "string" },
        "bound_reconnect_flow_ref": { "type": "string" },
        "observation_class": { "$ref": "#/$defs/continuity_observation_class" },
        "retained_capability_class": { "$ref": "#/$defs/retained_capability_class" },
        "degraded_action": { "$ref": "#/$defs/degraded_action_class" },
        "rationale_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "observed_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "silent_mutation_authority_widened": { "const": false },
        "local_editing_preserved": { "type": "boolean" }
      },
      "description": "Continuity observation that names the typed observation class, the retained capability, and the typed degraded action. Reuses the provider-object alpha vocabulary so support exports read one truth."
    },

    "provider_browser_handoff_alpha_page_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "page_id",
        "contract_refs",
        "packets",
        "import_sessions",
        "reconnect_flows",
        "support_export_summary"
      ],
      "properties": {
        "__fixture__": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "scenario"],
          "properties": {
            "name": { "$ref": "#/$defs/non_empty_string" },
            "scenario": { "$ref": "#/$defs/reviewable_sentence" }
          }
        },
        "record_kind": { "const": "provider_browser_handoff_alpha_page_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "page_id": { "$ref": "#/$defs/opaque_id" },
