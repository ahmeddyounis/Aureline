{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/providers/provider_account_mapping_drill_case.schema.json",
  "title": "Aureline provider account-scope and target-mapping continuity drill case",
  "description": "One deterministic drill case in the provider-account/target-mapping continuity corpus. Each case extends a seeded mapping-review row (see /schemas/providers/provider_target_mapping.schema.json) into a failure or recovery scenario for a marketed beta provider lane: board/project remap, stale token, installation-grant withdrawal, policy-locked mapping, offline capture, browser-blocked handoff, publish-later replay, or queued-draft export/import. The case pins the stable provider/account/mapping identity triple that MUST survive support export, activity-center reopen, and restart/restore, the degraded session/mapping/posture state, and the fail-closed expectations. The lane fails when a queued draft silently vanishes, a narrowed session still appears writable, or a mapping changes without visible review. Raw access tokens, raw delegated-token bodies, raw provider payloads, and raw provider URLs are forbidden.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "case_name",
    "drill_class",
    "provider_lane",
    "profile",
    "seed_row_ref",
    "generated_at",
    "identity",
    "drill_input",
    "continuity",
    "expected"
  ],
  "properties": {
    "record_kind": { "const": "providers_account_mapping_drill_case" },
    "schema_version": { "$ref": "#/$defs/schema_version" },
    "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
    "case_name": { "$ref": "#/$defs/non_empty_string" },
    "drill_class": { "$ref": "#/$defs/drill_class" },
    "provider_lane": { "$ref": "#/$defs/lane_class" },
    "profile": { "$ref": "#/$defs/profile_class" },
    "seed_row_ref": { "$ref": "#/$defs/opaque_ref" },
    "generated_at": { "$ref": "#/$defs/non_empty_string" },
    "summary_label": { "$ref": "#/$defs/non_empty_string" },
    "identity": { "$ref": "#/$defs/identity" },
    "drill_input": { "$ref": "#/$defs/drill_input" },
    "continuity": { "$ref": "#/$defs/continuity" },
    "expected": { "$ref": "#/$defs/expected" }
  },
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": { "const": "providers:account_mapping_drill_corpus:v1" },
    "non_empty_string": { "type": "string", "minLength": 1 },
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque ref safe for logs, manifests, support packets, and fixtures. Raw provider URLs and tokens are forbidden."
    },
    "drill_class": {
      "type": "string",
      "enum": [
        "board_project_remap",
        "stale_token",
        "installation_grant_withdrawal",
        "policy_locked_mapping",
        "offline_capture",
        "browser_blocked_handoff",
        "publish_later_replay",
        "queued_draft_export_import"
      ]
    },
    "profile_class": {
      "type": "string",
      "enum": ["connected", "mirror_only", "offline", "enterprise_managed"]
    },
    "lane_class": {
      "type": "string",
      "enum": [
        "issue_or_work_item",
        "review_decision",
        "incident_handoff",
        "publish_later"
      ]
    },
    "acting_identity_class": {
      "type": "string",
      "enum": ["connected_account", "installation_grant", "delegated_credential"]
    },
    "auth_source_class": {
      "type": "string",
      "enum": [
        "human_session",
        "installation_grant",
        "delegated_credential",
        "project_scoped_grant",
        "policy_injected_service"
      ]
    },
    "session_state_class": {
      "type": "string",
      "enum": [
        "live",
        "limited_scope",
        "stale_credential",
        "read_only",
        "offline_capture",
        "publish_later_only"
      ]
    },
    "resolution_state_class": {
      "type": "string",
      "enum": [
        "resolved_single_target",
        "policy_locked_target",
        "ambiguous_needs_selection",
        "unsupported_remap",
        "stale_needs_refresh",
        "invalidated",
        "no_mapping_configured"
      ]
    },
    "publish_posture_class": {
      "type": "string",
      "enum": [
        "local_draft",
        "queued_publish_later",
        "live_provider_mutation",
        "read_only_inspection"
      ]
    },
    "next_action_class": {
      "type": "string",
      "enum": [
        "none_proceed",
        "select_target",
        "refresh_mapping",
        "reconnect_session",
        "reapprove_scope",
        "route_browser_handoff",
        "queue_publish_later",
        "contact_admin",
        "retry_export"
      ]
    },
    "invalidation_trigger_class": {
      "type": "string",
      "enum": [
        "target_archived",
        "target_deleted",
        "target_moved_or_renamed",
        "policy_remap_locked",
        "scope_narrowed_below_target",
        "session_went_offline",
        "credential_went_stale",
        "remap_unsupported_by_provider",
        "board_schema_changed"
      ]
    },
    "handoff_outcome_class": {
      "type": "string",
      "enum": [
        "handoff_blocked_user_must_retry",
        "handoff_blocked_fallback_offered",
        "handoff_returned_exact_object",
        "handoff_returned_truthful_placeholder"
      ]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "description": "The stable provider/account/mapping identity triple that must survive every continuity surface.",
      "required": [
        "provider_id",
        "account_id",
        "mapping_id",
        "account_label",
        "acting_identity_class",
        "auth_source"
      ],
      "properties": {
        "provider_id": { "$ref": "#/$defs/opaque_ref" },
        "account_id": { "$ref": "#/$defs/opaque_ref" },
        "mapping_id": { "$ref": "#/$defs/opaque_ref" },
        "account_label": { "$ref": "#/$defs/non_empty_string" },
        "acting_identity_class": { "$ref": "#/$defs/acting_identity_class" },
        "auth_source": { "$ref": "#/$defs/auth_source_class" }
      }
    },
    "queued_draft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queue_item_ref",
        "draft_kind",
        "retained",
        "retry_export_available"
      ],
      "properties": {
        "queue_item_ref": { "$ref": "#/$defs/opaque_ref" },
        "draft_kind": { "$ref": "#/$defs/non_empty_string" },
        "retained": { "type": "boolean", "const": true },
        "retry_export_available": { "type": "boolean", "const": true },
        "export_round_trip_id": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "mapping_change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "previous_target_ref",
        "next_target_ref",
        "invalidation_trigger",
        "requires_visible_review",
        "review_surfaced"
      ],
      "properties": {
        "previous_target_ref": { "$ref": "#/$defs/opaque_ref" },
        "next_target_ref": { "$ref": "#/$defs/opaque_ref" },
        "invalidation_trigger": { "$ref": "#/$defs/invalidation_trigger_class" },
        "requires_visible_review": { "type": "boolean", "const": true },
        "review_surfaced": { "type": "boolean", "const": true }
      }
    },
    "browser_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocked", "outcome_class", "fallback_offered"],
      "properties": {
        "blocked": { "type": "boolean" },
        "outcome_class": { "$ref": "#/$defs/handoff_outcome_class" },
        "fallback_offered": { "type": "boolean" },
        "fallback_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "drill_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_state",
        "resolution_state",
        "publish_posture",
        "next_action",
        "effective_write_scope_held",
        "raw_token_material_present"
      ],
      "properties": {
        "session_state": { "$ref": "#/$defs/session_state_class" },
        "resolution_state": { "$ref": "#/$defs/resolution_state_class" },
        "publish_posture": { "$ref": "#/$defs/publish_posture_class" },
        "next_action": { "$ref": "#/$defs/next_action_class" },
        "next_action_label": { "$ref": "#/$defs/non_empty_string" },
        "effective_write_scope_held": { "type": "boolean" },
        "queued_draft": { "$ref": "#/$defs/queued_draft" },
        "mapping_change": { "$ref": "#/$defs/mapping_change" },
        "browser_handoff": { "$ref": "#/$defs/browser_handoff" },
        "raw_token_material_present": { "type": "boolean", "const": false }
      }
    },
    "continuity_surface": {
      "type": "object",
      "additionalProperties": false,
      "description": "An echo of the identity triple through one durable surface; the checker proves it matches identity exactly and carries no raw credentials.",
      "required": [
        "provider_id",
        "account_id",
        "mapping_id",
        "identity_preserved",
        "raw_credentials_present"
      ],
      "properties": {
        "provider_id": { "$ref": "#/$defs/opaque_ref" },
        "account_id": { "$ref": "#/$defs/opaque_ref" },
        "mapping_id": { "$ref": "#/$defs/opaque_ref" },
        "identity_preserved": { "type": "boolean", "const": true },
        "raw_credentials_present": { "type": "boolean", "const": false }
      }
    },
    "continuity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_export",
        "activity_center_reopen",
        "restart_restore"
      ],
      "properties": {
        "support_export": { "$ref": "#/$defs/continuity_surface" },
        "activity_center_reopen": { "$ref": "#/$defs/continuity_surface" },
        "restart_restore": { "$ref": "#/$defs/continuity_surface" }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fail_closed",
        "narrowed_session_appears_writable",
        "queued_draft_silently_vanished",
        "mapping_changed_without_visible_review",
        "local_draft_preserved",
        "queued_transitions_preserved",
        "evidence_preserved",
        "retry_export_available",
        "identity_survives_support_export",
        "identity_survives_activity_center_reopen",
        "identity_survives_restart_restore",
        "raw_credentials_leaked"
      ],
      "properties": {
        "fail_closed": { "type": "boolean" },
        "narrowed_session_appears_writable": { "type": "boolean", "const": false },
        "queued_draft_silently_vanished": { "type": "boolean", "const": false },
        "mapping_changed_without_visible_review": {
          "type": "boolean",
          "const": false
        },
        "local_draft_preserved": { "type": "boolean", "const": true },
        "queued_transitions_preserved": { "type": "boolean", "const": true },
        "evidence_preserved": { "type": "boolean", "const": true },
        "retry_export_available": { "type": "boolean", "const": true },
        "identity_survives_support_export": { "type": "boolean", "const": true },
        "identity_survives_activity_center_reopen": {
          "type": "boolean",
          "const": true
        },
        "identity_survives_restart_restore": { "type": "boolean", "const": true },
        "raw_credentials_leaked": { "type": "boolean", "const": false }
      }
    }
  }
}
