{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/providers/work_item_detail.schema.json",
  "title": "Aureline provider work-item detail beta entry point",
  "description": "Provider-facing schema entry point for work-item detail records and provider work-item transition corpus fixtures. The canonical work-item detail record vocabulary lives in schemas/work_items/work_item_detail.schema.json; the aureline-provider crate consumes that vocabulary through typed beta records that keep provider-authoritative, cached/stale, read-only, policy-blocked, local-draft, queued, and offline-captured states visibly distinct.",
  "oneOf": [
    { "$ref": "../work_items/work_item_detail.schema.json" },
    { "$ref": "#/$defs/provider_work_item_transition_corpus_matrix" }
  ],
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque ref safe for logs, manifests, support packets, and fixtures. Raw provider URLs, raw provider payloads, and token material are forbidden."
    },
    "row_posture_class": {
      "type": "string",
      "enum": [
        "provider_authoritative",
        "cached_stale",
        "read_only",
        "policy_blocked",
        "local_draft",
        "queued",
        "offline_captured"
      ]
    },
    "workflow_corpus_class": {
      "type": "string",
      "enum": [
        "stale_target_id",
        "revoked_credentials",
        "conflicting_updates",
        "read_only_session",
        "offline_capture",
        "publish_later_replay"
      ]
    },
    "provider_work_item_transition_corpus_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "corpus_class",
        "expected_visible_posture",
        "detail_ref"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "corpus_class": { "$ref": "#/$defs/workflow_corpus_class" },
        "expected_visible_posture": { "$ref": "#/$defs/row_posture_class" },
        "detail_ref": { "$ref": "#/$defs/opaque_id" },
        "transition_ref": { "$ref": "#/$defs/opaque_id" },
        "offline_handoff_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "provider_work_item_transition_corpus_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_kind", "schema_version", "source_command", "cases"],
      "properties": {
        "record_kind": { "const": "provider_work_item_transition_corpus_matrix" },
        "schema_version": { "type": "integer", "const": 1 },
        "source_command": { "type": "string", "minLength": 1 },
        "cases": {
          "type": "array",
          "items": { "$ref": "#/$defs/provider_work_item_transition_corpus_case" },
          "minItems": 6
        }
      }
    }
  }
}

