{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/providers/provider_callback_deny_event.schema.json",
  "title": "Aureline provider callback deny event",
  "description": "Boundary schema for provider_callback_deny_event_record. A deny event preserves callback, webhook, or browser-return policy rejection evidence without mutating user-visible provider state. It is exportable for support and audit while excluding raw callback bodies, raw provider payloads, raw URLs, and tokens.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "deny_event_id",
    "denied_event_ref",
    "delivery_identity",
    "reason",
    "policy_source_ref",
    "route_class",
    "actor_or_install_ref",
    "remediation_hint",
    "occurred_at",
    "no_user_visible_mutation",
    "audit_event_refs",
    "support_export_summary",
    "redaction_class"
  ],
  "properties": {
    "record_kind": { "const": "provider_callback_deny_event_record" },
    "schema_version": { "const": 1 },
    "shared_contract_ref": { "const": "providers:provider_event_reconciliation:v1" },
    "deny_event_id": { "$ref": "#/$defs/opaque_id" },
    "denied_event_ref": { "$ref": "#/$defs/opaque_id" },
    "delivery_identity": { "$ref": "#/$defs/delivery_identity" },
    "reason": {
      "type": "string",
      "enum": [
        "origin_proof_invalid",
        "host_mismatch",
        "route_class_denied",
        "policy_denied",
        "tenant_or_target_mismatch",
        "actor_scope_revoked",
        "freshness_floor_denied"
      ]
    },
    "policy_source_ref": { "$ref": "#/$defs/opaque_id" },
    "route_class": {
      "type": "string",
      "enum": [
        "browser_return",
        "provider_webhook",
        "machine_to_machine_callback",
        "customer_mirror_ingress",
        "denied_route"
      ]
    },
    "actor_or_install_ref": { "$ref": "#/$defs/opaque_id" },
    "remediation_hint": { "$ref": "#/$defs/reviewable_sentence" },
    "occurred_at": { "$ref": "#/$defs/timestamp" },
    "no_user_visible_mutation": { "const": true },
    "audit_event_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/opaque_id" }
    },
    "support_export_summary": { "$ref": "#/$defs/reviewable_sentence" },
    "redaction_class": { "$ref": "#/$defs/redaction_class" }
  },
  "$defs": {
    "opaque_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "reviewable_sentence": { "type": "string", "minLength": 1 },
    "delivery_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "external_delivery_id",
        "scoped_object_ref",
        "provider_host_ref",
        "tenant_or_org_scope_ref"
      ],
      "properties": {
        "external_delivery_id": { "$ref": "#/$defs/opaque_id" },
        "scoped_object_ref": { "$ref": "#/$defs/opaque_id" },
        "provider_host_ref": { "$ref": "#/$defs/opaque_id" },
        "tenant_or_org_scope_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    }
  }
}
