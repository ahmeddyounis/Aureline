{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/performance/regression_baseline.schema.json",
  "title": "Aureline performance regression-baseline contract",
  "description": "Boundary schema for one governed performance regression baseline and its comparison records. Baselines pin workload, corpus, exact build, hardware, environment, runtime, toolchain, capture backend, recording mode, redaction mode, variance, confidence, threshold, export, and artifact-mismatch state so unlike captures cannot be interpreted as blocking regressions.",
  "$ref": "#/$defs/performance_regression_baseline_record",
  "$defs": {
    "regression_baseline_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "performance_regression_baseline_record"
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1
    },
    "nullable_opaque_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_ref" }
      ]
    },
    "baseline_state_class": {
      "type": "string",
      "enum": ["candidate", "active", "superseded", "quarantined", "expired"]
    },
    "capture_class": {
      "type": "string",
      "enum": [
        "cpu_profile",
        "memory_sample",
        "render_timeline",
        "trace_span_set",
        "io_capture",
        "replay_capture",
        "regression_baseline"
      ]
    },
    "build_mode_class": {
      "type": "string",
      "enum": ["debug", "release", "instrumented", "asan", "tsan", "profiled", "unknown"]
    },
    "execution_location_class": {
      "type": "string",
      "enum": ["local_desktop", "remote_workspace", "managed_workspace", "ci_runner", "imported_only"]
    },
    "recording_mode_state": {
      "type": "string",
      "enum": [
        "not_recording",
        "live_recording",
        "recorded",
        "imported_recording",
        "recording_unavailable",
        "expired",
        "artifact_mismatch"
      ]
    },
    "start_condition_class": {
      "type": "string",
      "enum": ["cold", "warm", "already_loaded", "fixture_replay", "imported_only"]
    },
    "metric_unit_class": {
      "type": "string",
      "enum": ["milliseconds", "bytes", "count", "ratio", "boolean", "watts", "joules", "spans"]
    },
    "aggregation_class": {
      "type": "string",
      "enum": ["p50", "p95", "p99", "mean", "max", "sum", "boolean_all_pass", "structural_digest"]
    },
    "confidence_class": {
      "type": "string",
      "enum": ["reference_grade", "directional", "trend_only", "not_comparable", "unknown"]
    },
    "comparison_policy_class": {
      "type": "string",
      "enum": ["exact_like_for_like", "same_family_advisory", "exploratory_only"]
    },
    "comparison_effect_class": {
      "type": "string",
      "enum": ["block_comparison", "advisory_only", "quarantine", "reset_baseline", "no_effect"]
    },
    "comparison_axis_class": {
      "type": "string",
      "enum": [
        "workload_id",
        "corpus_ref",
        "corpus_revision",
        "execution_location",
        "runtime_ref",
        "toolchain_ref",
        "capture_backend_family",
        "build_mode",
        "exact_build_lineage",
        "hardware_profile",
        "power_posture",
        "thermal_posture",
        "environment_fingerprint",
        "recording_mode",
        "redaction_profile"
      ]
    },
    "comparability_class": {
      "type": "string",
      "enum": ["comparable", "advisory_only", "exploratory_only", "not_comparable", "quarantined"]
    },
    "threshold_state_class": {
      "type": "string",
      "enum": ["within_threshold", "warn_threshold_exceeded", "fail_threshold_exceeded", "waived", "not_comparable", "threshold_not_set"]
    },
    "verdict_class": {
      "type": "string",
      "enum": ["pass", "warn", "fail", "waived", "not_comparable"]
    },
    "expiry_status_class": {
      "type": "string",
      "enum": ["active", "expiring", "expired", "pinned", "held", "artifact_mismatch", "source_unavailable"]
    },
    "artifact_mismatch_status_class": {
      "type": "string",
      "enum": ["none", "source_capture_missing", "digest_mismatch", "schema_mismatch", "symbol_or_build_mismatch", "environment_mismatch", "expired_reference"]
    },
    "export_posture_class": {
      "type": "string",
      "enum": ["summary_only", "manifest_with_digests", "local_only_raw", "upload_safe_after_redaction", "admin_policy_required", "blocked_sensitive", "not_applicable"]
    },
    "redaction_status_class": {
      "type": "string",
      "enum": ["not_required", "pending_review", "redacted", "omitted_sensitive_fields", "blocked_sensitive", "policy_denied"]
    },
    "exact_build_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exact_build_identity_ref", "build_id", "source_revision_ref", "build_mode", "symbol_manifest_ref", "source_map_manifest_ref"],
      "properties": {
        "exact_build_identity_ref": { "$ref": "#/$defs/opaque_ref" },
        "build_id": { "$ref": "#/$defs/opaque_ref" },
        "source_revision_ref": { "$ref": "#/$defs/opaque_ref" },
        "build_mode": { "$ref": "#/$defs/build_mode_class" },
        "symbol_manifest_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "source_map_manifest_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "target_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution_context_id", "target_ref", "workspace_ref", "runtime_ref", "toolchain_ref", "execution_location_class"],
      "properties": {
        "execution_context_id": { "$ref": "#/$defs/opaque_ref" },
        "target_ref": { "$ref": "#/$defs/opaque_ref" },
        "workspace_ref": { "$ref": "#/$defs/opaque_ref" },
        "runtime_ref": { "$ref": "#/$defs/opaque_ref" },
        "toolchain_ref": { "$ref": "#/$defs/opaque_ref" },
        "execution_location_class": { "$ref": "#/$defs/execution_location_class" }
      }
    },
    "environment_fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment_fingerprint_id", "hardware_profile_ref", "power_posture_ref", "thermal_posture_ref", "environment_digest_ref"],
      "properties": {
        "environment_fingerprint_id": { "$ref": "#/$defs/opaque_ref" },
        "hardware_profile_ref": { "$ref": "#/$defs/opaque_ref" },
        "power_posture_ref": { "$ref": "#/$defs/opaque_ref" },
        "thermal_posture_ref": { "$ref": "#/$defs/opaque_ref" },
        "environment_digest_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "workload_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workload_id", "corpus_ref", "corpus_revision", "archetype_ref", "input_digest_ref", "execution_profile_class", "start_condition_class"],
      "properties": {
        "workload_id": { "$ref": "#/$defs/opaque_ref" },
        "corpus_ref": { "$ref": "#/$defs/opaque_ref" },
        "corpus_revision": { "type": "integer", "minimum": 1 },
        "archetype_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "input_digest_ref": { "$ref": "#/$defs/opaque_ref" },
        "execution_profile_class": { "$ref": "#/$defs/execution_location_class" },
        "start_condition_class": { "$ref": "#/$defs/start_condition_class" }
      }
    },
    "baseline_key": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workload_id",
        "corpus_ref",
        "corpus_revision",
        "execution_location_class",
        "runtime_ref",
        "toolchain_ref",
        "capture_backend_family_ref",
        "build_mode",
        "hardware_profile_ref",
        "power_posture_ref",
        "thermal_posture_ref",
        "environment_fingerprint_id",
        "recording_mode_state",
        "redaction_profile_ref"
      ],
      "properties": {
        "workload_id": { "$ref": "#/$defs/opaque_ref" },
        "corpus_ref": { "$ref": "#/$defs/opaque_ref" },
        "corpus_revision": { "type": "integer", "minimum": 1 },
        "execution_location_class": { "$ref": "#/$defs/execution_location_class" },
        "runtime_ref": { "$ref": "#/$defs/opaque_ref" },
        "toolchain_ref": { "$ref": "#/$defs/opaque_ref" },
        "capture_backend_family_ref": { "$ref": "#/$defs/opaque_ref" },
        "build_mode": { "$ref": "#/$defs/build_mode_class" },
        "hardware_profile_ref": { "$ref": "#/$defs/opaque_ref" },
        "power_posture_ref": { "$ref": "#/$defs/opaque_ref" },
        "thermal_posture_ref": { "$ref": "#/$defs/opaque_ref" },
        "environment_fingerprint_id": { "$ref": "#/$defs/opaque_ref" },
        "recording_mode_state": { "$ref": "#/$defs/recording_mode_state" },
        "redaction_profile_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "metric_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric_id", "unit_class", "aggregation_class", "baseline_value", "threshold_ref", "captured_from_capture_session_ref"],
      "properties": {
        "metric_id": { "$ref": "#/$defs/opaque_ref" },
        "unit_class": { "$ref": "#/$defs/metric_unit_class" },
        "aggregation_class": { "$ref": "#/$defs/aggregation_class" },
        "baseline_value": { "type": "number" },
        "threshold_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "captured_from_capture_session_ref": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "sample_statistics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_count", "variance_class_ref", "confidence_class", "variance_note_ref", "coefficient_of_variation", "confidence_interval_ref"],
      "properties": {
        "sample_count": { "type": "integer", "minimum": 1 },
        "variance_class_ref": { "$ref": "#/$defs/opaque_ref" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "variance_note_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "coefficient_of_variation": {
          "oneOf": [
            { "type": "null" },
            { "type": "number", "minimum": 0 }
          ]
        },
        "confidence_interval_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "comparison_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["comparison_policy_class", "required_match_axes", "mismatch_default_effect", "allowed_nonblocking_labels"],
      "properties": {
        "comparison_policy_class": { "$ref": "#/$defs/comparison_policy_class" },
        "required_match_axes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/comparison_axis_class" },
          "uniqueItems": true
        },
        "mismatch_default_effect": { "$ref": "#/$defs/comparison_effect_class" },
        "allowed_nonblocking_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/comparability_class" },
          "uniqueItems": true
        }
      }
    },
    "change_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["change_axis_class", "previous_ref", "observed_ref", "effect_class", "decision_ref", "note_ref"],
      "properties": {
        "change_axis_class": { "$ref": "#/$defs/comparison_axis_class" },
        "previous_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "observed_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "effect_class": { "$ref": "#/$defs/comparison_effect_class" },
        "decision_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "note_ref": { "$ref": "#/$defs/nullable_opaque_ref" }
      }
    },
    "delta_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric_id", "baseline_value", "candidate_value", "absolute_delta", "relative_delta_ratio", "verdict_class"],
      "properties": {
        "metric_id": { "$ref": "#/$defs/opaque_ref" },
        "baseline_value": { "type": "number" },
        "candidate_value": { "type": "number" },
        "absolute_delta": { "type": "number" },
        "relative_delta_ratio": {
          "oneOf": [
            { "type": "null" },
            { "type": "number" }
          ]
        },
        "verdict_class": { "$ref": "#/$defs/verdict_class" }
      }
    },
    "regression_evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evaluation_id",
        "candidate_capture_session_ref",
        "baseline_capture_session_ref",
        "compared_at",
        "comparability_class",
        "confidence_class",
        "variance_note_ref",
        "threshold_state_class",
        "delta_records",
        "mismatch_reason_refs",
        "review_packet_refs",
        "support_bundle_refs"
      ],
      "properties": {
        "evaluation_id": { "$ref": "#/$defs/opaque_ref" },
        "candidate_capture_session_ref": { "$ref": "#/$defs/opaque_ref" },
        "baseline_capture_session_ref": { "$ref": "#/$defs/opaque_ref" },
        "compared_at": { "type": "string", "format": "date-time" },
        "comparability_class": { "$ref": "#/$defs/comparability_class" },
        "confidence_class": { "$ref": "#/$defs/confidence_class" },
        "variance_note_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "threshold_state_class": { "$ref": "#/$defs/threshold_state_class" },
        "delta_records": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/delta_record" }
        },
        "mismatch_reason_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "review_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        },
        "support_bundle_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        }
      }
    },
    "artifact_integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expiry_status", "artifact_mismatch_status", "mismatch_reason_refs"],
      "properties": {
        "expiry_status": { "$ref": "#/$defs/expiry_status_class" },
        "artifact_mismatch_status": { "$ref": "#/$defs/artifact_mismatch_status_class" },
        "mismatch_reason_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        }
      }
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_class_ref", "retained_until", "expiry_status"],
      "properties": {
        "record_class_ref": { "$ref": "#/$defs/opaque_ref" },
        "retained_until": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "format": "date-time" }
          ]
        },
        "expiry_status": { "$ref": "#/$defs/expiry_status_class" }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["redaction_profile_ref", "redaction_status", "omitted_sensitive_fields"],
      "properties": {
        "redaction_profile_ref": { "$ref": "#/$defs/opaque_ref" },
        "redaction_status": { "$ref": "#/$defs/redaction_status_class" },
        "omitted_sensitive_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        }
      }
    },
    "export_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary_export_posture", "raw_export_posture", "export_manifest_refs"],
      "properties": {
        "summary_export_posture": { "$ref": "#/$defs/export_posture_class" },
        "raw_export_posture": { "$ref": "#/$defs/export_posture_class" },
        "export_manifest_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" },
          "uniqueItems": true
        }
      }
    },
    "performance_regression_baseline_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "regression_baseline_schema_version",
        "record_kind",
        "baseline_id",
        "baseline_state_class",
        "baseline_capture_class",
        "source_capture_session_ref",
        "exact_build_identity",
        "target_context",
        "environment_fingerprint",
        "workload_context",
        "baseline_key",
        "metric_set",
        "sample_statistics",
        "comparison_policy",
        "change_records",
        "artifact_integrity",
        "retention",
        "redaction",
        "export_policy",
        "regression_evaluations"
      ],
      "properties": {
        "regression_baseline_schema_version": { "$ref": "#/$defs/regression_baseline_schema_version" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "baseline_id": { "$ref": "#/$defs/opaque_ref" },
        "baseline_state_class": { "$ref": "#/$defs/baseline_state_class" },
        "baseline_capture_class": { "$ref": "#/$defs/capture_class" },
        "source_capture_session_ref": { "$ref": "#/$defs/opaque_ref" },
        "exact_build_identity": { "$ref": "#/$defs/exact_build_identity" },
        "target_context": { "$ref": "#/$defs/target_context" },
        "environment_fingerprint": { "$ref": "#/$defs/environment_fingerprint" },
        "workload_context": { "$ref": "#/$defs/workload_context" },
        "baseline_key": { "$ref": "#/$defs/baseline_key" },
        "metric_set": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/metric_record" }
        },
        "sample_statistics": { "$ref": "#/$defs/sample_statistics" },
        "comparison_policy": { "$ref": "#/$defs/comparison_policy" },
        "change_records": {
          "type": "array",
          "items": { "$ref": "#/$defs/change_record" }
        },
        "artifact_integrity": { "$ref": "#/$defs/artifact_integrity" },
        "retention": { "$ref": "#/$defs/retention" },
        "redaction": { "$ref": "#/$defs/redaction" },
        "export_policy": { "$ref": "#/$defs/export_policy" },
        "regression_evaluations": {
          "type": "array",
          "items": { "$ref": "#/$defs/regression_evaluation" }
        }
      }
    }
  }
}
