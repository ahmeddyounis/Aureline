{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/execution-auth/ship-capability-envelope-packets-with-actor-target-allowed-roots-or-sinks-or-endpoints-secret-handle-refs-policy-epoch-e.schema.json",
  "title": "M5 Capability-Envelope Packets",
  "description": "Export-safe packet of capability envelopes issued against the frozen M5 runtime-authority matrix. Each envelope binds one issued execution to its actor, target identity, allowed roots/sinks/endpoints, handle-only secret references, governing policy epoch, expiry, and audit lineage. Metadata-only: carries no raw secret material, credential bodies, or live ticket signatures.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "packet_label",
    "envelopes",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "ship_m5_capability_envelope_packets" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "packet_label": { "type": "string", "minLength": 1 },
    "envelopes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/envelope" }
    },
    "trust_review": { "$ref": "#/$defs/trustReview" },
    "consumer_projection": { "$ref": "#/$defs/consumerProjection" },
    "proof_freshness": { "$ref": "#/$defs/proofFreshness" },
    "source_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "executingSurface": {
      "type": "string",
      "enum": [
        "request_api_send",
        "database_action",
        "notebook_kernel",
        "scaffold_hook",
        "preview_server",
        "ai_tool",
        "recipe",
        "browser_routed_action",
        "incident_flow",
        "remote_mutation"
      ]
    },
    "actorClass": {
      "type": "string",
      "enum": [
        "human_operator",
        "system_automation",
        "ai_tool",
        "recipe",
        "extension",
        "browser_route",
        "remote_helper"
      ]
    },
    "targetClass": {
      "type": "string",
      "enum": [
        "local_workspace",
        "local_process",
        "network_endpoint",
        "database",
        "remote_host",
        "browser_context"
      ]
    },
    "scopeKind": {
      "type": "string",
      "enum": ["filesystem_root", "data_sink", "network_endpoint"]
    },
    "scopeAccessMode": {
      "type": "string",
      "enum": ["read_only", "append_only", "read_write", "send_only", "navigate"]
    },
    "capabilityClass": {
      "type": "string",
      "enum": [
        "read_workspace",
        "write_workspace",
        "network_egress",
        "process_spawn",
        "secret_handle_projection",
        "database_read",
        "database_write",
        "remote_mutation",
        "browser_navigation"
      ]
    },
    "secretScope": {
      "type": "string",
      "enum": ["no_secret_access", "handle_only_delegated", "scoped_brokered_secret"]
    },
    "sandboxProfile": {
      "type": "string",
      "enum": [
        "inert_no_execution",
        "in_process_trusted_local",
        "brokered_network_only",
        "subprocess_isolated_local",
        "container_isolated_local",
        "isolated_remote_runtime"
      ]
    },
    "approvalTicketPosture": {
      "type": "string",
      "enum": [
        "ticket_required_per_action",
        "ticket_required_per_session",
        "ticket_required_per_scope",
        "standing_policy_ticket",
        "no_ticket_required_read_only",
        "blocked_no_self_issue"
      ]
    },
    "issuerClass": {
      "type": "string",
      "enum": [
        "policy_authority",
        "approval_broker",
        "standing_policy_epoch",
        "remote_broker_runtime"
      ]
    },
    "degradedFallback": {
      "type": "string",
      "enum": [
        "narrow_to_read_only",
        "narrow_to_sanitized_preview",
        "require_fresh_ticket",
        "offline_local_core_only",
        "fail_closed_block"
      ]
    },
    "downgradeTrigger": {
      "type": "string",
      "enum": [
        "approval_ticket_expired",
        "approval_ticket_replayed",
        "sandbox_profile_unavailable",
        "policy_epoch_superseded",
        "secret_broker_unavailable",
        "enforcement_backend_missing",
        "target_identity_unverified",
        "scope_expansion_unqualified",
        "ambient_privilege_detected",
        "upstream_dependency_narrowed"
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_class", "actor_ref", "on_behalf_of"],
      "properties": {
        "actor_class": { "$ref": "#/$defs/actorClass" },
        "actor_ref": { "type": "string", "minLength": 1 },
        "on_behalf_of": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_class", "target_identity", "off_device", "identity_verified"],
      "properties": {
        "target_class": { "$ref": "#/$defs/targetClass" },
        "target_identity": { "type": "string", "minLength": 1 },
        "off_device": { "type": "boolean" },
        "identity_verified": { "type": "boolean" }
      }
    },
    "allowedScopeEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "label", "access"],
      "properties": {
        "kind": { "$ref": "#/$defs/scopeKind" },
        "label": { "type": "string", "minLength": 1 },
        "access": { "$ref": "#/$defs/scopeAccessMode" }
      }
    },
    "secretHandleRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["handle_ref", "scope", "broker_contract_ref"],
      "properties": {
        "handle_ref": { "type": "string", "minLength": 1 },
        "scope": { "$ref": "#/$defs/secretScope" },
        "broker_contract_ref": { "type": "string", "minLength": 1 }
      }
    },
    "policyEpoch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["epoch_id", "epoch_sequence", "superseded"],
      "properties": {
        "epoch_id": { "type": "string", "minLength": 1 },
        "epoch_sequence": { "type": "integer", "minimum": 0 },
        "superseded": { "type": "boolean" }
      }
    },
    "expiry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issued_at", "expires_at", "ttl_seconds", "single_use"],
      "properties": {
        "issued_at": { "type": "string", "minLength": 1 },
        "expires_at": { "type": "string", "minLength": 1 },
        "ttl_seconds": { "type": "integer", "minimum": 1 },
        "single_use": { "type": "boolean" }
      }
    },
    "auditLineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issuer_class",
        "issuer_ref",
        "approval_ticket_ref",
        "approval_posture",
        "decision_chain",
        "self_issued_by_executor"
      ],
      "properties": {
        "issuer_class": { "$ref": "#/$defs/issuerClass" },
        "issuer_ref": { "type": "string", "minLength": 1 },
        "approval_ticket_ref": { "type": "string" },
        "approval_posture": { "$ref": "#/$defs/approvalTicketPosture" },
        "decision_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "self_issued_by_executor": { "type": "boolean", "const": false }
      }
    },
    "envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "envelope_id",
        "surface",
        "actor",
        "target",
        "allowed_scope",
        "granted_capability_classes",
        "secret_handle_refs",
        "secret_scope",
        "sandbox_profile",
        "policy_epoch",
        "expiry",
        "audit_lineage",
        "degraded_fallback",
        "applied_downgrade_triggers",
        "narrowed_from_default",
        "redaction_class_token"
      ],
      "properties": {
        "envelope_id": { "type": "string", "minLength": 1 },
        "surface": { "$ref": "#/$defs/executingSurface" },
        "actor": { "$ref": "#/$defs/actor" },
        "target": { "$ref": "#/$defs/target" },
        "allowed_scope": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/allowedScopeEntry" }
        },
        "granted_capability_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/capabilityClass" }
        },
        "secret_handle_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/secretHandleRef" }
        },
        "secret_scope": { "$ref": "#/$defs/secretScope" },
        "sandbox_profile": { "$ref": "#/$defs/sandboxProfile" },
        "policy_epoch": { "$ref": "#/$defs/policyEpoch" },
        "expiry": { "$ref": "#/$defs/expiry" },
        "audit_lineage": { "$ref": "#/$defs/auditLineage" },
        "degraded_fallback": { "$ref": "#/$defs/degradedFallback" },
        "applied_downgrade_triggers": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgradeTrigger" }
        },
        "narrowed_from_default": { "type": "boolean" },
        "redaction_class_token": { "type": "string", "minLength": 1 }
      }
    },
    "trustReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_ambient_machine_privilege",
        "no_self_issued_authority_by_helpers",
        "actor_and_target_identity_inspectable",
        "allowed_scope_inspectable",
        "secret_refs_handle_only_no_raw_material",
        "policy_epoch_and_expiry_inspectable",
        "audit_lineage_inspectable",
        "off_device_preserves_envelope_semantics",
        "fail_closed_when_enforcement_unavailable",
        "no_raw_secret_material_in_exports"
      ],
      "properties": {
        "no_ambient_machine_privilege": { "type": "boolean" },
        "no_self_issued_authority_by_helpers": { "type": "boolean" },
        "actor_and_target_identity_inspectable": { "type": "boolean" },
        "allowed_scope_inspectable": { "type": "boolean" },
        "secret_refs_handle_only_no_raw_material": { "type": "boolean" },
        "policy_epoch_and_expiry_inspectable": { "type": "boolean" },
        "audit_lineage_inspectable": { "type": "boolean" },
        "off_device_preserves_envelope_semantics": { "type": "boolean" },
        "fail_closed_when_enforcement_unavailable": { "type": "boolean" },
        "no_raw_secret_material_in_exports": { "type": "boolean" }
      }
    },
    "consumerProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "desktop_shows_envelope",
        "command_and_policy_reference_same_envelopes",
        "cli_headless_shows_envelope",
        "support_export_shows_envelope",
        "diagnostics_shows_envelope",
        "help_about_shows_envelope_summary",
        "release_evidence_consumes_envelopes",
        "remote_and_browser_preserve_envelope_semantics"
      ],
      "properties": {
        "desktop_shows_envelope": { "type": "boolean" },
        "command_and_policy_reference_same_envelopes": { "type": "boolean" },
        "cli_headless_shows_envelope": { "type": "boolean" },
        "support_export_shows_envelope": { "type": "boolean" },
        "diagnostics_shows_envelope": { "type": "boolean" },
        "help_about_shows_envelope_summary": { "type": "boolean" },
        "release_evidence_consumes_envelopes": { "type": "boolean" },
        "remote_and_browser_preserve_envelope_semantics": { "type": "boolean" }
      }
    },
    "proofFreshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_freshness_slo_hours", "last_proof_refresh", "auto_narrow_on_stale"],
      "properties": {
        "proof_freshness_slo_hours": { "type": "integer", "minimum": 1 },
        "last_proof_refresh": { "type": "string", "minLength": 1 },
        "auto_narrow_on_stale": { "type": "boolean" }
      }
    }
  }
}
