{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/execution-auth/add-issue-use-revoke-audit-ledgers-invalidation-on-target-or-trust-or-policy-or-sandbox-drift-and-support-export-safe-au.schema.json",
  "title": "M5 Issue-Use-Revoke Authority-Lifecycle Ledger",
  "description": "Export-safe issue-use-revoke audit ledger that threads each M5 authority grant through its whole lifecycle: when it was issued, each time it was used and with what outcome, whether it was revoked, and whether it was invalidated because the target identity, trust anchor, policy epoch, network posture, or sandbox profile drifted. Each entry joins the command, session, approval-ticket, capability-envelope, and originating-flow lineage an incident or support reviewer needs after the fact. Invalidation names the drifted dimension, downgrade trigger, narrowed fallback, and a concrete recovery action instead of a generic permission error. Metadata-only: carries no raw secret material, credential bodies, or live ticket signatures.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "packet_label",
    "entries",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "add_m5_issue_use_revoke_authority_lifecycle_ledger"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "packet_label": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entry" }
    },
    "trust_review": { "$ref": "#/$defs/trustReview" },
    "consumer_projection": { "$ref": "#/$defs/consumerProjection" },
    "proof_freshness": { "$ref": "#/$defs/proofFreshness" },
    "source_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "executingSurface": {
      "type": "string",
      "enum": [
        "request_api_send",
        "database_action",
        "notebook_kernel",
        "scaffold_hook",
        "preview_server",
        "ai_tool",
        "recipe",
        "browser_routed_action",
        "incident_flow",
        "remote_mutation"
      ]
    },
    "sandboxProfile": {
      "type": "string",
      "enum": [
        "inert_no_execution",
        "in_process_trusted_local",
        "brokered_network_only",
        "subprocess_isolated_local",
        "container_isolated_local",
        "isolated_remote_runtime"
      ]
    },
    "secretScope": {
      "type": "string",
      "enum": ["no_secret_access", "handle_only_delegated", "scoped_brokered_secret"]
    },
    "actorClass": {
      "type": "string",
      "enum": [
        "human_operator",
        "system_automation",
        "ai_tool",
        "recipe",
        "extension",
        "browser_route",
        "remote_helper"
      ]
    },
    "issuerClass": {
      "type": "string",
      "enum": [
        "policy_authority",
        "approval_broker",
        "standing_policy_epoch",
        "remote_broker_runtime"
      ]
    },
    "actionClass": {
      "type": "string",
      "enum": [
        "workspace_mutation",
        "process_execution",
        "network_send",
        "database_write",
        "remote_mutation",
        "browser_routed_action",
        "secret_projection"
      ]
    },
    "originFlow": {
      "type": "string",
      "enum": ["execution", "repair", "ai_assisted", "provider_linked", "remote"]
    },
    "driftDimension": {
      "type": "string",
      "enum": [
        "target_identity_drift",
        "trust_anchor_drift",
        "policy_epoch_drift",
        "network_posture_drift",
        "sandbox_profile_drift"
      ]
    },
    "lifecycleState": {
      "type": "string",
      "enum": ["issued", "active", "revoked", "invalidated", "expired"]
    },
    "useOutcome": {
      "type": "string",
      "enum": [
        "allowed_executed",
        "narrowed_executed",
        "denied_invalidated",
        "denied_revoked",
        "denied_expired"
      ]
    },
    "degradedFallback": {
      "type": "string",
      "enum": [
        "narrow_to_read_only",
        "narrow_to_sanitized_preview",
        "require_fresh_ticket",
        "offline_local_core_only",
        "fail_closed_block"
      ]
    },
    "downgradeTrigger": {
      "type": "string",
      "enum": [
        "approval_ticket_expired",
        "approval_ticket_replayed",
        "sandbox_profile_unavailable",
        "policy_epoch_superseded",
        "secret_broker_unavailable",
        "enforcement_backend_missing",
        "target_identity_unverified",
        "scope_expansion_unqualified",
        "ambient_privilege_detected",
        "upstream_dependency_narrowed"
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_class", "actor_ref", "on_behalf_of"],
      "properties": {
        "actor_class": { "$ref": "#/$defs/actorClass" },
        "actor_ref": { "type": "string", "minLength": 1 },
        "on_behalf_of": {
          "oneOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_identity", "off_device", "identity_verified"],
      "properties": {
        "target_identity": { "type": "string", "minLength": 1 },
        "off_device": { "type": "boolean" },
        "identity_verified": { "type": "boolean" }
      }
    },
    "policyEpoch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["epoch_id", "epoch_sequence", "superseded"],
      "properties": {
        "epoch_id": { "type": "string", "minLength": 1 },
        "epoch_sequence": { "type": "integer", "minimum": 0 },
        "superseded": { "type": "boolean" }
      }
    },
    "linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin_flow",
        "command_ref",
        "session_ref",
        "approval_ticket_ref",
        "capability_envelope_ref",
        "capability_envelope_hash"
      ],
      "properties": {
        "origin_flow": { "$ref": "#/$defs/originFlow" },
        "command_ref": {
          "oneOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "session_ref": { "type": "string", "minLength": 1 },
        "approval_ticket_ref": { "type": "string", "minLength": 1 },
        "capability_envelope_ref": { "type": "string", "minLength": 1 },
        "capability_envelope_hash": { "type": "string", "minLength": 1 }
      }
    },
    "issueEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issued_at",
        "issuer_class",
        "issuer_ref",
        "policy_epoch",
        "sandbox_profile",
        "secret_scope",
        "expires_at",
        "ttl_seconds",
        "decision_chain",
        "self_issued_by_executor"
      ],
      "properties": {
        "issued_at": { "type": "string", "minLength": 1 },
        "issuer_class": { "$ref": "#/$defs/issuerClass" },
        "issuer_ref": { "type": "string", "minLength": 1 },
        "policy_epoch": { "$ref": "#/$defs/policyEpoch" },
        "sandbox_profile": { "$ref": "#/$defs/sandboxProfile" },
        "secret_scope": { "$ref": "#/$defs/secretScope" },
        "expires_at": { "type": "string", "minLength": 1 },
        "ttl_seconds": { "type": "integer", "minimum": 1 },
        "decision_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "self_issued_by_executor": { "const": false }
      }
    },
    "useEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["used_at", "sequence", "outcome", "narrowed_to", "note"],
      "properties": {
        "used_at": { "type": "string", "minLength": 1 },
        "sequence": { "type": "integer", "minimum": 1 },
        "outcome": { "$ref": "#/$defs/useOutcome" },
        "narrowed_to": {
          "oneOf": [{ "$ref": "#/$defs/degradedFallback" }, { "type": "null" }]
        },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "invalidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detected_at",
        "drift_dimension",
        "trigger",
        "narrowed_to",
        "explanation",
        "recovery_action"
      ],
      "properties": {
        "detected_at": { "type": "string", "minLength": 1 },
        "drift_dimension": { "$ref": "#/$defs/driftDimension" },
        "trigger": { "$ref": "#/$defs/downgradeTrigger" },
        "narrowed_to": { "$ref": "#/$defs/degradedFallback" },
        "explanation": { "type": "string", "minLength": 1 },
        "recovery_action": { "type": "string", "minLength": 1 }
      }
    },
    "revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revoked_at", "revoked_by", "narrowed_to", "reason"],
      "properties": {
        "revoked_at": { "type": "string", "minLength": 1 },
        "revoked_by": { "type": "string", "minLength": 1 },
        "narrowed_to": { "$ref": "#/$defs/degradedFallback" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "surface",
        "action_class",
        "actor",
        "target",
        "linkage",
        "issue",
        "uses",
        "invalidation",
        "revocation",
        "lifecycle_state",
        "applied_downgrade_triggers",
        "redaction_class_token"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "surface": { "$ref": "#/$defs/executingSurface" },
        "action_class": { "$ref": "#/$defs/actionClass" },
        "actor": { "$ref": "#/$defs/actor" },
        "target": { "$ref": "#/$defs/target" },
        "linkage": { "$ref": "#/$defs/linkage" },
        "issue": { "$ref": "#/$defs/issueEvent" },
        "uses": {
          "type": "array",
          "items": { "$ref": "#/$defs/useEvent" }
        },
        "invalidation": {
          "oneOf": [{ "$ref": "#/$defs/invalidation" }, { "type": "null" }]
        },
        "revocation": {
          "oneOf": [{ "$ref": "#/$defs/revocation" }, { "type": "null" }]
        },
        "lifecycle_state": { "$ref": "#/$defs/lifecycleState" },
        "applied_downgrade_triggers": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgradeTrigger" }
        },
        "redaction_class_token": { "type": "string", "minLength": 1 }
      }
    },
    "trustReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_ambient_machine_privilege",
        "no_self_issued_authority_by_helpers",
        "every_grant_joins_full_lineage",
        "invalidation_names_drift_dimension",
        "invalidation_carries_recovery",
        "lifecycle_state_coherent_with_events",
        "use_outcomes_consistent_with_state",
        "secret_refs_handle_only_no_raw_material",
        "fail_closed_when_enforcement_unavailable",
        "no_raw_secret_material_in_exports"
      ],
      "properties": {
        "no_ambient_machine_privilege": { "type": "boolean" },
        "no_self_issued_authority_by_helpers": { "type": "boolean" },
        "every_grant_joins_full_lineage": { "type": "boolean" },
        "invalidation_names_drift_dimension": { "type": "boolean" },
        "invalidation_carries_recovery": { "type": "boolean" },
        "lifecycle_state_coherent_with_events": { "type": "boolean" },
        "use_outcomes_consistent_with_state": { "type": "boolean" },
        "secret_refs_handle_only_no_raw_material": { "type": "boolean" },
        "fail_closed_when_enforcement_unavailable": { "type": "boolean" },
        "no_raw_secret_material_in_exports": { "type": "boolean" }
      }
    },
    "consumerProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "desktop_shows_lifecycle_and_invalidation",
        "command_and_policy_reference_same_entries",
        "cli_headless_reads_ledger_offline",
        "support_export_shows_full_ledger",
        "diagnostics_shows_full_ledger",
        "incident_review_consumes_ledger",
        "release_evidence_consumes_ledger",
        "remote_and_browser_preserve_ledger_semantics"
      ],
      "properties": {
        "desktop_shows_lifecycle_and_invalidation": { "type": "boolean" },
        "command_and_policy_reference_same_entries": { "type": "boolean" },
        "cli_headless_reads_ledger_offline": { "type": "boolean" },
        "support_export_shows_full_ledger": { "type": "boolean" },
        "diagnostics_shows_full_ledger": { "type": "boolean" },
        "incident_review_consumes_ledger": { "type": "boolean" },
        "release_evidence_consumes_ledger": { "type": "boolean" },
        "remote_and_browser_preserve_ledger_semantics": { "type": "boolean" }
      }
    },
    "proofFreshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_freshness_slo_hours", "last_proof_refresh", "auto_narrow_on_stale"],
      "properties": {
        "proof_freshness_slo_hours": { "type": "integer", "minimum": 1 },
        "last_proof_refresh": { "type": "string", "minLength": 1 },
        "auto_narrow_on_stale": { "type": "boolean" }
      }
    }
  }
}
