{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/execution-auth/ship-child-envelope-derivation-nested-launch-narrowing-handle-only-secret-projection-and-no-ambient-privilege-enforcemen.schema.json",
  "title": "M5 Child-Envelope Derivations",
  "description": "Export-safe packet of child-envelope derivations for nested M5 launches across the notebook, scaffold, request, database, AI, and debug lanes. Each derivation binds a parent-authority snapshot to a derived child envelope and proves the child only narrows the parent: capability classes are a subset, allowed roots/sinks/endpoints are contained at an equal-or-narrower access mode, the sandbox profile is equal-or-stricter, the secret scope is equal-or-narrower, the expiry is no later, and the policy epoch matches. A child never inherits the raw OS environment and never fans out full parent authority; secret projection is handle-only; an unsupported enforcement backend narrows to a stricter profile or becomes visibly unsupported and fails closed. Metadata-only: carries no raw secret material, credential bodies, or live ticket signatures.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "packet_label",
    "derivations",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "ship_m5_child_envelope_derivation" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "packet_label": { "type": "string", "minLength": 1 },
    "derivations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/derivation" }
    },
    "trust_review": { "$ref": "#/$defs/trustReview" },
    "consumer_projection": { "$ref": "#/$defs/consumerProjection" },
    "proof_freshness": { "$ref": "#/$defs/proofFreshness" },
    "source_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "nestedLaunchLane": {
      "type": "string",
      "enum": ["notebook", "scaffold", "request", "database", "ai", "debug"]
    },
    "capabilityClass": {
      "type": "string",
      "enum": [
        "read_workspace",
        "write_workspace",
        "network_egress",
        "process_spawn",
        "secret_handle_projection",
        "database_read",
        "database_write",
        "remote_mutation",
        "browser_navigation"
      ]
    },
    "sandboxProfile": {
      "type": "string",
      "enum": [
        "inert_no_execution",
        "in_process_trusted_local",
        "brokered_network_only",
        "subprocess_isolated_local",
        "container_isolated_local",
        "isolated_remote_runtime"
      ]
    },
    "secretScope": {
      "type": "string",
      "enum": ["no_secret_access", "handle_only_delegated", "scoped_brokered_secret"]
    },
    "actorClass": {
      "type": "string",
      "enum": [
        "human_operator",
        "system_automation",
        "ai_tool",
        "recipe",
        "extension",
        "browser_route",
        "remote_helper"
      ]
    },
    "issuerClass": {
      "type": "string",
      "enum": [
        "policy_authority",
        "approval_broker",
        "standing_policy_epoch",
        "remote_broker_runtime"
      ]
    },
    "allowedScopeKind": {
      "type": "string",
      "enum": ["filesystem_root", "data_sink", "network_endpoint"]
    },
    "scopeAccessMode": {
      "type": "string",
      "enum": ["read_only", "append_only", "read_write", "send_only", "navigate"]
    },
    "ambientEnvironmentPosture": {
      "type": "string",
      "enum": [
        "no_environment_inherited",
        "allowlisted_handles_only",
        "brokered_environment_refs",
        "raw_os_environment_inherited"
      ]
    },
    "enforcementBackendStatus": {
      "type": "string",
      "enum": [
        "enforced",
        "narrowed_to_stricter_profile",
        "unsupported_visibly_degraded",
        "silently_permissive_unsupported"
      ]
    },
    "narrowingDimension": {
      "type": "string",
      "enum": [
        "capability_dropped",
        "scope_narrowed",
        "sandbox_tightened",
        "secret_scope_narrowed",
        "expiry_shortened",
        "environment_stripped"
      ]
    },
    "downgradeTrigger": {
      "type": "string",
      "enum": [
        "approval_ticket_expired",
        "approval_ticket_replayed",
        "sandbox_profile_unavailable",
        "policy_epoch_superseded",
        "secret_broker_unavailable",
        "enforcement_backend_missing",
        "target_identity_unverified",
        "scope_expansion_unqualified",
        "ambient_privilege_detected",
        "upstream_dependency_narrowed"
      ]
    },
    "degradedFallback": {
      "type": "string",
      "enum": [
        "narrow_to_read_only",
        "narrow_to_sanitized_preview",
        "require_fresh_ticket",
        "offline_local_core_only",
        "fail_closed_block"
      ]
    },
    "policyEpoch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["epoch_id", "epoch_sequence", "superseded"],
      "properties": {
        "epoch_id": { "type": "string", "minLength": 1 },
        "epoch_sequence": { "type": "integer", "minimum": 0 },
        "superseded": { "type": "boolean" }
      }
    },
    "allowedScopeEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "label", "access"],
      "properties": {
        "kind": { "$ref": "#/$defs/allowedScopeKind" },
        "label": { "type": "string", "minLength": 1 },
        "access": { "$ref": "#/$defs/scopeAccessMode" }
      }
    },
    "secretHandleRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["handle_ref", "scope", "broker_contract_ref"],
      "properties": {
        "handle_ref": { "type": "string", "minLength": 1 },
        "scope": { "$ref": "#/$defs/secretScope" },
        "broker_contract_ref": { "type": "string", "minLength": 1 }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_class", "actor_ref", "on_behalf_of"],
      "properties": {
        "actor_class": { "$ref": "#/$defs/actorClass" },
        "actor_ref": { "type": "string", "minLength": 1 },
        "on_behalf_of": { "type": ["string", "null"] }
      }
    },
    "parentSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parent_envelope_ref",
        "granted_capability_classes",
        "allowed_scope",
        "sandbox_profile",
        "secret_scope",
        "policy_epoch",
        "expires_at"
      ],
      "properties": {
        "parent_envelope_ref": { "type": "string", "minLength": 1 },
        "granted_capability_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/capabilityClass" }
        },
        "allowed_scope": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/allowedScopeEntry" }
        },
        "sandbox_profile": { "$ref": "#/$defs/sandboxProfile" },
        "secret_scope": { "$ref": "#/$defs/secretScope" },
        "policy_epoch": { "$ref": "#/$defs/policyEpoch" },
        "expires_at": { "type": "string", "minLength": 1 }
      }
    },
    "childEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "envelope_id",
        "target_identity",
        "off_device",
        "identity_verified",
        "granted_capability_classes",
        "allowed_scope",
        "secret_handle_refs",
        "secret_scope",
        "sandbox_profile",
        "policy_epoch",
        "issued_at",
        "expires_at",
        "ttl_seconds",
        "single_use"
      ],
      "properties": {
        "envelope_id": { "type": "string", "minLength": 1 },
        "target_identity": { "type": "string", "minLength": 1 },
        "off_device": { "type": "boolean" },
        "identity_verified": { "type": "boolean" },
        "granted_capability_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/capabilityClass" }
        },
        "allowed_scope": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/allowedScopeEntry" }
        },
        "secret_handle_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/secretHandleRef" }
        },
        "secret_scope": { "$ref": "#/$defs/secretScope" },
        "sandbox_profile": { "$ref": "#/$defs/sandboxProfile" },
        "policy_epoch": { "$ref": "#/$defs/policyEpoch" },
        "issued_at": { "type": "string", "minLength": 1 },
        "expires_at": { "type": "string", "minLength": 1 },
        "ttl_seconds": { "type": "integer", "minimum": 1 },
        "single_use": { "type": "boolean" }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issuer_class",
        "issuer_ref",
        "parent_envelope_ref",
        "approval_ticket_ref",
        "decision_chain",
        "self_issued_by_executor"
      ],
      "properties": {
        "issuer_class": { "$ref": "#/$defs/issuerClass" },
        "issuer_ref": { "type": "string", "minLength": 1 },
        "parent_envelope_ref": { "type": "string", "minLength": 1 },
        "approval_ticket_ref": { "type": "string" },
        "decision_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "self_issued_by_executor": { "type": "boolean", "const": false }
      }
    },
    "derivation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "derivation_id",
        "lane",
        "actor",
        "parent",
        "child",
        "ambient_environment_posture",
        "inherits_full_parent_authority",
        "enforcement_backend",
        "enforcement_status",
        "audit_lineage",
        "degraded_fallback",
        "applied_downgrade_triggers",
        "applied_narrowings",
        "narrowed_below_baseline",
        "redaction_class_token"
      ],
      "properties": {
        "derivation_id": { "type": "string", "minLength": 1 },
        "lane": { "$ref": "#/$defs/nestedLaunchLane" },
        "actor": { "$ref": "#/$defs/actor" },
        "parent": { "$ref": "#/$defs/parentSnapshot" },
        "child": { "$ref": "#/$defs/childEnvelope" },
        "ambient_environment_posture": {
          "allOf": [
            { "$ref": "#/$defs/ambientEnvironmentPosture" },
            { "not": { "const": "raw_os_environment_inherited" } }
          ]
        },
        "inherits_full_parent_authority": { "type": "boolean", "const": false },
        "enforcement_backend": { "type": "string", "minLength": 1 },
        "enforcement_status": {
          "allOf": [
            { "$ref": "#/$defs/enforcementBackendStatus" },
            { "not": { "const": "silently_permissive_unsupported" } }
          ]
        },
        "audit_lineage": { "$ref": "#/$defs/lineage" },
        "degraded_fallback": { "$ref": "#/$defs/degradedFallback" },
        "applied_downgrade_triggers": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgradeTrigger" }
        },
        "applied_narrowings": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowingDimension" }
        },
        "narrowed_below_baseline": { "type": "boolean" },
        "redaction_class_token": { "type": "string", "minLength": 1 }
      }
    },
    "trustReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_ambient_machine_privilege",
        "no_raw_os_environment_inheritance",
        "child_envelopes_only_narrow_parent",
        "no_full_parent_authority_fan_out",
        "secret_projection_handle_only_no_raw_material",
        "no_self_issued_authority_by_helpers",
        "unsupported_backend_fails_closed_or_visible",
        "parent_and_child_identity_inspectable",
        "policy_epoch_and_expiry_inspectable",
        "audit_lineage_inspectable",
        "no_raw_secret_material_in_exports"
      ],
      "properties": {
        "no_ambient_machine_privilege": { "type": "boolean", "const": true },
        "no_raw_os_environment_inheritance": { "type": "boolean", "const": true },
        "child_envelopes_only_narrow_parent": { "type": "boolean", "const": true },
        "no_full_parent_authority_fan_out": { "type": "boolean", "const": true },
        "secret_projection_handle_only_no_raw_material": { "type": "boolean", "const": true },
        "no_self_issued_authority_by_helpers": { "type": "boolean", "const": true },
        "unsupported_backend_fails_closed_or_visible": { "type": "boolean", "const": true },
        "parent_and_child_identity_inspectable": { "type": "boolean", "const": true },
        "policy_epoch_and_expiry_inspectable": { "type": "boolean", "const": true },
        "audit_lineage_inspectable": { "type": "boolean", "const": true },
        "no_raw_secret_material_in_exports": { "type": "boolean", "const": true }
      }
    },
    "consumerProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "desktop_shows_derivation",
        "command_and_policy_reference_same_derivations",
        "cli_headless_shows_derivation",
        "support_export_shows_derivation",
        "diagnostics_shows_derivation",
        "help_about_shows_derivation_summary",
        "release_evidence_consumes_derivations",
        "remote_and_browser_preserve_derivation_semantics"
      ],
      "properties": {
        "desktop_shows_derivation": { "type": "boolean", "const": true },
        "command_and_policy_reference_same_derivations": { "type": "boolean", "const": true },
        "cli_headless_shows_derivation": { "type": "boolean", "const": true },
        "support_export_shows_derivation": { "type": "boolean", "const": true },
        "diagnostics_shows_derivation": { "type": "boolean", "const": true },
        "help_about_shows_derivation_summary": { "type": "boolean", "const": true },
        "release_evidence_consumes_derivations": { "type": "boolean", "const": true },
        "remote_and_browser_preserve_derivation_semantics": { "type": "boolean", "const": true }
      }
    },
    "proofFreshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_freshness_slo_hours", "last_proof_refresh", "auto_narrow_on_stale"],
      "properties": {
        "proof_freshness_slo_hours": { "type": "integer", "minimum": 1 },
        "last_proof_refresh": { "type": "string", "minLength": 1 },
        "auto_narrow_on_stale": { "type": "boolean" }
      }
    }
  }
}
