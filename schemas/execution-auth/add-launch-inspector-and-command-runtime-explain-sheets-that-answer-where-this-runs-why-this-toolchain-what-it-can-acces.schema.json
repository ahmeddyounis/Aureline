{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/execution-auth/add-launch-inspector-and-command-runtime-explain-sheets-that-answer-where-this-runs-why-this-toolchain-what-it-can-acces.schema.json",
  "title": "M5 Launch-Inspector Explain Sheets",
  "description": "Export-safe packet of launch-inspector explain sheets, one per launch route, that answer where a launch runs, why this toolchain, what it can access, and who approved it. Projects the frozen runtime-authority matrix, execution-surface resolution, and capability-envelope truths for desktop, CLI/headless, AI, recipe, extension, remote, and companion routes. Metadata-only: carries no raw secret material, credential bodies, or live ticket signatures. Missing, stale, or unsupported launches degrade to explicit partial or unsupported labels that still carry all four answers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "packet_label",
    "sheets",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": { "const": "add_m5_launch_inspector_explain_sheets" },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "packet_label": { "type": "string", "minLength": 1 },
    "sheets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sheet" }
    },
    "trust_review": { "$ref": "#/$defs/trustReview" },
    "consumer_projection": { "$ref": "#/$defs/consumerProjection" },
    "proof_freshness": { "$ref": "#/$defs/proofFreshness" },
    "source_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "launchRoute": {
      "type": "string",
      "enum": ["desktop", "cli", "ai", "recipe", "extension", "remote", "companion"]
    },
    "executingSurface": {
      "type": "string",
      "enum": [
        "request_api_send",
        "database_action",
        "notebook_kernel",
        "scaffold_hook",
        "preview_server",
        "ai_tool",
        "recipe",
        "browser_routed_action",
        "incident_flow",
        "remote_mutation"
      ]
    },
    "sandboxProfile": {
      "type": "string",
      "enum": [
        "inert_no_execution",
        "in_process_trusted_local",
        "brokered_network_only",
        "subprocess_isolated_local",
        "container_isolated_local",
        "isolated_remote_runtime"
      ]
    },
    "executionBackend": {
      "type": "string",
      "enum": ["in_process", "brokered_network", "local_isolated", "remote_isolated", "inert"]
    },
    "executionPlatform": {
      "type": "string",
      "enum": [
        "linux_desktop",
        "macos_desktop",
        "windows_desktop",
        "managed_remote_runtime",
        "headless_ci"
      ]
    },
    "profileResolutionStatus": {
      "type": "string",
      "enum": [
        "supported",
        "narrowed_to_stricter_profile",
        "unsupported_fail_closed",
        "disabled_with_reason"
      ]
    },
    "capabilityClass": {
      "type": "string",
      "enum": [
        "read_workspace",
        "write_workspace",
        "network_egress",
        "process_spawn",
        "secret_handle_projection",
        "database_read",
        "database_write",
        "remote_mutation",
        "browser_navigation"
      ]
    },
    "secretScope": {
      "type": "string",
      "enum": ["no_secret_access", "handle_only_delegated", "scoped_brokered_secret"]
    },
    "approvalPosture": {
      "type": "string",
      "enum": [
        "ticket_required_per_action",
        "ticket_required_per_session",
        "ticket_required_per_scope",
        "standing_policy_ticket",
        "no_ticket_required_read_only",
        "blocked_no_self_issue"
      ]
    },
    "toolchainSelectionReason": {
      "type": "string",
      "enum": [
        "project_pinned_toolchain",
        "policy_mandated_runtime",
        "platform_default_runtime",
        "narrowed_fallback_runtime",
        "remote_brokered_runtime"
      ]
    },
    "explainStatus": {
      "type": "string",
      "enum": ["complete", "partial_degraded", "unsupported_on_platform"]
    },
    "degradationReason": {
      "type": "string",
      "enum": [
        "stale_proof_packet",
        "missing_explainability_packet",
        "unsupported_profile_on_platform",
        "approval_ticket_expired",
        "enforcement_backend_missing",
        "policy_epoch_superseded",
        "target_identity_unverified"
      ]
    },
    "degradedFallback": {
      "type": "string",
      "enum": [
        "narrow_to_read_only",
        "narrow_to_sanitized_preview",
        "require_fresh_ticket",
        "offline_local_core_only",
        "fail_closed_block"
      ]
    },
    "unsupportedProfileBehavior": {
      "type": "string",
      "enum": [
        "fail_closed_unsupported",
        "narrow_to_stricter_profile",
        "disable_surface_with_reason",
        "fully_supported_all_platforms"
      ]
    },
    "downgradeTrigger": {
      "type": "string",
      "enum": [
        "approval_ticket_expired",
        "approval_ticket_replayed",
        "sandbox_profile_unavailable",
        "policy_epoch_superseded",
        "secret_broker_unavailable",
        "enforcement_backend_missing",
        "target_identity_unverified",
        "scope_expansion_unqualified",
        "ambient_privilege_detected",
        "upstream_dependency_narrowed"
      ]
    },
    "whereItRuns": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executing_surface",
        "sandbox_profile",
        "execution_backend",
        "platform",
        "profile_resolution_status",
        "off_device",
        "target_identity",
        "target_identity_verified",
        "isolation_label"
      ],
      "properties": {
        "executing_surface": { "$ref": "#/$defs/executingSurface" },
        "sandbox_profile": { "$ref": "#/$defs/sandboxProfile" },
        "execution_backend": { "$ref": "#/$defs/executionBackend" },
        "platform": { "$ref": "#/$defs/executionPlatform" },
        "profile_resolution_status": { "$ref": "#/$defs/profileResolutionStatus" },
        "off_device": { "type": "boolean" },
        "target_identity": { "type": "string", "minLength": 1 },
        "target_identity_verified": { "type": "boolean" },
        "isolation_label": { "type": "string", "minLength": 1 }
      }
    },
    "whyThisToolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["toolchain_label", "backend_class", "selection_reason", "resolved_from_ref"],
      "properties": {
        "toolchain_label": { "type": "string", "minLength": 1 },
        "backend_class": { "$ref": "#/$defs/executionBackend" },
        "selection_reason": { "$ref": "#/$defs/toolchainSelectionReason" },
        "resolved_from_ref": { "type": "string", "minLength": 1 }
      }
    },
    "whatItCanAccess": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "granted_capability_classes",
        "allowed_scope_labels",
        "secret_scope",
        "capability_envelope_ref"
      ],
      "properties": {
        "granted_capability_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/capabilityClass" }
        },
        "allowed_scope_labels": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "secret_scope": { "$ref": "#/$defs/secretScope" },
        "capability_envelope_ref": { "type": "string", "minLength": 1 }
      }
    },
    "whoApprovedIt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_posture",
        "approval_ticket_ref",
        "issuer_label",
        "policy_epoch_label",
        "decision_chain",
        "self_issued_by_executor"
      ],
      "properties": {
        "approval_posture": { "$ref": "#/$defs/approvalPosture" },
        "approval_ticket_ref": { "type": "string" },
        "issuer_label": { "type": "string", "minLength": 1 },
        "policy_epoch_label": { "type": "string", "minLength": 1 },
        "decision_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "self_issued_by_executor": { "type": "boolean" }
      }
    },
    "degradation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "narrowed_to", "explanation"],
      "properties": {
        "reason": { "$ref": "#/$defs/degradationReason" },
        "narrowed_to": { "$ref": "#/$defs/degradedFallback" },
        "explanation": { "type": "string", "minLength": 1 }
      }
    },
    "sheet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sheet_id",
        "route",
        "status",
        "where_it_runs",
        "why_this_toolchain",
        "what_it_can_access",
        "who_approved_it",
        "degradation",
        "applied_downgrade_triggers",
        "unsupported_profile_behavior",
        "redaction_class_token"
      ],
      "properties": {
        "sheet_id": { "type": "string", "minLength": 1 },
        "route": { "$ref": "#/$defs/launchRoute" },
        "status": { "$ref": "#/$defs/explainStatus" },
        "where_it_runs": { "$ref": "#/$defs/whereItRuns" },
        "why_this_toolchain": { "$ref": "#/$defs/whyThisToolchain" },
        "what_it_can_access": { "$ref": "#/$defs/whatItCanAccess" },
        "who_approved_it": { "$ref": "#/$defs/whoApprovedIt" },
        "degradation": {
          "oneOf": [{ "$ref": "#/$defs/degradation" }, { "type": "null" }]
        },
        "applied_downgrade_triggers": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgradeTrigger" }
        },
        "unsupported_profile_behavior": {
          "oneOf": [{ "$ref": "#/$defs/unsupportedProfileBehavior" }, { "type": "null" }]
        },
        "redaction_class_token": { "type": "string", "minLength": 1 }
      }
    },
    "trustReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_ambient_machine_privilege",
        "no_self_issued_authority_by_helpers",
        "all_four_answers_present_even_when_degraded",
        "degraded_state_reasons_explicit",
        "access_never_widens_matrix",
        "secret_refs_handle_only_no_raw_material",
        "off_device_preserves_sheet_semantics",
        "fail_closed_when_enforcement_unavailable",
        "no_raw_secret_material_in_exports"
      ],
      "properties": {
        "no_ambient_machine_privilege": { "type": "boolean" },
        "no_self_issued_authority_by_helpers": { "type": "boolean" },
        "all_four_answers_present_even_when_degraded": { "type": "boolean" },
        "degraded_state_reasons_explicit": { "type": "boolean" },
        "access_never_widens_matrix": { "type": "boolean" },
        "secret_refs_handle_only_no_raw_material": { "type": "boolean" },
        "off_device_preserves_sheet_semantics": { "type": "boolean" },
        "fail_closed_when_enforcement_unavailable": { "type": "boolean" },
        "no_raw_secret_material_in_exports": { "type": "boolean" }
      }
    },
    "consumerProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "desktop_shows_explain_sheet",
        "command_and_policy_reference_same_sheets",
        "cli_headless_shows_explain_sheet",
        "support_export_shows_explain_sheet",
        "diagnostics_shows_explain_sheet",
        "help_about_shows_explain_summary",
        "release_evidence_consumes_sheets",
        "all_routes_project_same_facts"
      ],
      "properties": {
        "desktop_shows_explain_sheet": { "type": "boolean" },
        "command_and_policy_reference_same_sheets": { "type": "boolean" },
        "cli_headless_shows_explain_sheet": { "type": "boolean" },
        "support_export_shows_explain_sheet": { "type": "boolean" },
        "diagnostics_shows_explain_sheet": { "type": "boolean" },
        "help_about_shows_explain_summary": { "type": "boolean" },
        "release_evidence_consumes_sheets": { "type": "boolean" },
        "all_routes_project_same_facts": { "type": "boolean" }
      }
    },
    "proofFreshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_freshness_slo_hours", "last_proof_refresh", "auto_narrow_on_stale"],
      "properties": {
        "proof_freshness_slo_hours": { "type": "integer", "minimum": 1 },
        "last_proof_refresh": { "type": "string", "minLength": 1 },
        "auto_narrow_on_stale": { "type": "boolean" }
      }
    }
  }
}
