{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/execution-auth/certify-runtime-authority-approval-ticket-integrity-execution-isolation-and-capability-envelope-parity-on-all-claimed-m5.schema.json",
  "title": "M5 Runtime-Authority Parity Certification",
  "description": "Export-safe certification that joins the per-dimension proofs (execution-isolation sandbox profile, approval-ticket integrity, capability-envelope parity, and runtime-authority lineage) for every claimed M5 executing surface into one inspectable verdict. Each surface keeps its frozen-matrix qualification only when every dimension carries current proof; a missing or stale proof auto-narrows the surface and an unsupported enforcement backend fails it closed, so a claim can never silently widen past its evidence. Metadata-only: carries no raw secret material, credential bodies, or live ticket signatures.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "packet_label",
    "entries",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "certify_m5_runtime_authority_approval_ticket_execution_isolation_capability_envelope_parity"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "packet_label": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entry" }
    },
    "trust_review": { "$ref": "#/$defs/trustReview" },
    "consumer_projection": { "$ref": "#/$defs/consumerProjection" },
    "proof_freshness": { "$ref": "#/$defs/proofFreshness" },
    "source_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "executingSurface": {
      "type": "string",
      "enum": [
        "request_api_send",
        "database_action",
        "notebook_kernel",
        "scaffold_hook",
        "preview_server",
        "ai_tool",
        "recipe",
        "browser_routed_action",
        "incident_flow",
        "remote_mutation"
      ]
    },
    "qualification": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "experimental", "unavailable", "held"]
    },
    "sandboxProfile": {
      "type": "string",
      "enum": [
        "inert_no_execution",
        "in_process_trusted_local",
        "brokered_network_only",
        "subprocess_isolated_local",
        "container_isolated_local",
        "isolated_remote_runtime"
      ]
    },
    "approvalTicketPosture": {
      "type": "string",
      "enum": [
        "ticket_required_per_action",
        "ticket_required_per_session",
        "ticket_required_per_scope",
        "standing_policy_ticket",
        "no_ticket_required_read_only",
        "blocked_no_self_issue"
      ]
    },
    "secretScope": {
      "type": "string",
      "enum": [
        "no_secret_access",
        "handle_only_delegated",
        "scoped_brokered_secret"
      ]
    },
    "dimension": {
      "type": "string",
      "enum": [
        "execution_isolation",
        "approval_ticket_integrity",
        "capability_envelope_parity",
        "runtime_authority_lineage"
      ]
    },
    "proofStatus": {
      "type": "string",
      "enum": ["current", "stale", "missing", "unsupported_backend"]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "certified",
        "narrowed_stale_proof",
        "narrowed_missing_proof",
        "failed_closed_unsupported_backend"
      ]
    },
    "degradedFallback": {
      "type": "string",
      "enum": [
        "narrow_to_read_only",
        "narrow_to_sanitized_preview",
        "require_fresh_ticket",
        "offline_local_core_only",
        "fail_closed_block"
      ]
    },
    "downgradeTrigger": {
      "type": "string",
      "enum": [
        "approval_ticket_expired",
        "approval_ticket_replayed",
        "sandbox_profile_unavailable",
        "policy_epoch_superseded",
        "secret_broker_unavailable",
        "enforcement_backend_missing",
        "target_identity_unverified",
        "scope_expansion_unqualified",
        "ambient_privilege_detected",
        "upstream_dependency_narrowed"
      ]
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension",
        "status",
        "proof_source_ref",
        "proof_schema_ref",
        "proof_packet_id",
        "proof_observed_at",
        "note"
      ],
      "properties": {
        "dimension": { "$ref": "#/$defs/dimension" },
        "status": { "$ref": "#/$defs/proofStatus" },
        "proof_source_ref": { "type": "string", "minLength": 1 },
        "proof_schema_ref": { "type": "string", "minLength": 1 },
        "proof_packet_id": { "type": "string", "minLength": 1 },
        "proof_observed_at": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "claimed_qualification",
        "default_sandbox_profile",
        "approval_ticket_posture",
        "secret_scope",
        "is_untrusted_helper",
        "proofs",
        "verdict",
        "effective_qualification",
        "narrowed_to",
        "downgrade_trigger",
        "recovery_action",
        "redaction_class_token"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/executingSurface" },
        "claimed_qualification": { "$ref": "#/$defs/qualification" },
        "default_sandbox_profile": { "$ref": "#/$defs/sandboxProfile" },
        "approval_ticket_posture": { "$ref": "#/$defs/approvalTicketPosture" },
        "secret_scope": { "$ref": "#/$defs/secretScope" },
        "is_untrusted_helper": { "type": "boolean" },
        "proofs": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "$ref": "#/$defs/proof" }
        },
        "verdict": { "$ref": "#/$defs/verdict" },
        "effective_qualification": { "$ref": "#/$defs/qualification" },
        "narrowed_to": {
          "oneOf": [{ "$ref": "#/$defs/degradedFallback" }, { "type": "null" }]
        },
        "downgrade_trigger": {
          "oneOf": [{ "$ref": "#/$defs/downgradeTrigger" }, { "type": "null" }]
        },
        "recovery_action": { "type": "string", "minLength": 1 },
        "redaction_class_token": { "type": "string", "minLength": 1 }
      }
    },
    "trustReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_ambient_machine_privilege",
        "no_self_issued_authority_by_helpers",
        "every_surface_certified_across_all_dimensions",
        "auto_narrows_on_missing_or_stale_proof",
        "fail_closes_on_unsupported_backend",
        "never_silently_widens_a_claim",
        "secret_refs_handle_only_no_raw_material",
        "certification_offline_verifiable",
        "no_raw_secret_material_in_exports"
      ],
      "properties": {
        "no_ambient_machine_privilege": { "type": "boolean" },
        "no_self_issued_authority_by_helpers": { "type": "boolean" },
        "every_surface_certified_across_all_dimensions": { "type": "boolean" },
        "auto_narrows_on_missing_or_stale_proof": { "type": "boolean" },
        "fail_closes_on_unsupported_backend": { "type": "boolean" },
        "never_silently_widens_a_claim": { "type": "boolean" },
        "secret_refs_handle_only_no_raw_material": { "type": "boolean" },
        "certification_offline_verifiable": { "type": "boolean" },
        "no_raw_secret_material_in_exports": { "type": "boolean" }
      }
    },
    "consumerProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "desktop_shows_certification_and_narrowing",
        "command_and_policy_reference_same_certification",
        "cli_headless_reads_certification_offline",
        "help_about_ingests_certification_status",
        "diagnostics_consumes_certification",
        "release_evidence_gates_on_certification",
        "support_export_shows_full_certification",
        "remote_and_browser_preserve_certification_semantics"
      ],
      "properties": {
        "desktop_shows_certification_and_narrowing": { "type": "boolean" },
        "command_and_policy_reference_same_certification": { "type": "boolean" },
        "cli_headless_reads_certification_offline": { "type": "boolean" },
        "help_about_ingests_certification_status": { "type": "boolean" },
        "diagnostics_consumes_certification": { "type": "boolean" },
        "release_evidence_gates_on_certification": { "type": "boolean" },
        "support_export_shows_full_certification": { "type": "boolean" },
        "remote_and_browser_preserve_certification_semantics": { "type": "boolean" }
      }
    },
    "proofFreshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_freshness_slo_hours",
        "last_proof_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "proof_freshness_slo_hours": { "type": "integer", "minimum": 1 },
        "last_proof_refresh": { "type": "string", "minLength": 1 },
        "auto_narrow_on_stale": { "type": "boolean" }
      }
    }
  }
}
