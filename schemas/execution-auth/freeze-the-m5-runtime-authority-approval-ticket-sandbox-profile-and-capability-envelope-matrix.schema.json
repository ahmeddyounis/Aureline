{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/execution-auth/freeze-the-m5-runtime-authority-approval-ticket-sandbox-profile-and-capability-envelope-matrix.schema.json",
  "title": "M5 Runtime-Authority, Approval-Ticket, Sandbox-Profile, and Capability-Envelope Matrix",
  "description": "Export-safe frozen matrix binding every claimed M5 executing surface to its qualification class, default sandbox profile, required approval-ticket posture, allowed capability classes, secret scope, degraded fallback, unsupported-profile behavior, ticket expiry, downgrade triggers, source contracts, and consumer-surface parity. Metadata-only: carries no raw secret material, credential bodies, or live ticket signatures.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "matrix_label",
    "surface_rows",
    "trust_review",
    "consumer_projection",
    "proof_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "freeze_m5_runtime_authority_approval_ticket_sandbox_profile_and_capability_envelope_matrix"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "matrix_label": { "type": "string", "minLength": 1 },
    "surface_rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surfaceRow" }
    },
    "trust_review": { "$ref": "#/$defs/trustReview" },
    "consumer_projection": { "$ref": "#/$defs/consumerProjection" },
    "proof_freshness": { "$ref": "#/$defs/proofFreshness" },
    "source_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_token": { "type": "string", "minLength": 1 },
    "minted_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "executingSurface": {
      "type": "string",
      "enum": [
        "request_api_send",
        "database_action",
        "notebook_kernel",
        "scaffold_hook",
        "preview_server",
        "ai_tool",
        "recipe",
        "browser_routed_action",
        "incident_flow",
        "remote_mutation"
      ]
    },
    "qualificationClass": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "experimental", "unavailable", "held"]
    },
    "sandboxProfile": {
      "type": "string",
      "enum": [
        "inert_no_execution",
        "in_process_trusted_local",
        "brokered_network_only",
        "subprocess_isolated_local",
        "container_isolated_local",
        "isolated_remote_runtime"
      ]
    },
    "approvalTicketPosture": {
      "type": "string",
      "enum": [
        "ticket_required_per_action",
        "ticket_required_per_session",
        "ticket_required_per_scope",
        "standing_policy_ticket",
        "no_ticket_required_read_only",
        "blocked_no_self_issue"
      ]
    },
    "capabilityClass": {
      "type": "string",
      "enum": [
        "read_workspace",
        "write_workspace",
        "network_egress",
        "process_spawn",
        "secret_handle_projection",
        "database_read",
        "database_write",
        "remote_mutation",
        "browser_navigation"
      ]
    },
    "secretScope": {
      "type": "string",
      "enum": ["no_secret_access", "handle_only_delegated", "scoped_brokered_secret"]
    },
    "degradedFallback": {
      "type": "string",
      "enum": [
        "narrow_to_read_only",
        "narrow_to_sanitized_preview",
        "require_fresh_ticket",
        "offline_local_core_only",
        "fail_closed_block"
      ]
    },
    "unsupportedProfileBehavior": {
      "type": "string",
      "enum": [
        "fail_closed_unsupported",
        "narrow_to_stricter_profile",
        "disable_surface_with_reason",
        "fully_supported_all_platforms"
      ]
    },
    "downgradeTrigger": {
      "type": "string",
      "enum": [
        "approval_ticket_expired",
        "approval_ticket_replayed",
        "sandbox_profile_unavailable",
        "policy_epoch_superseded",
        "secret_broker_unavailable",
        "enforcement_backend_missing",
        "target_identity_unverified",
        "scope_expansion_unqualified",
        "ambient_privilege_detected",
        "upstream_dependency_narrowed"
      ]
    },
    "consumerSurface": {
      "type": "string",
      "enum": [
        "desktop_shell",
        "command_palette",
        "policy_inspector",
        "cli_headless",
        "support_export",
        "diagnostics",
        "help_about",
        "release_evidence"
      ]
    },
    "surfaceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "qualification",
        "scope_summary",
        "default_sandbox_profile",
        "approval_ticket_posture",
        "allowed_capability_classes",
        "secret_scope",
        "degraded_fallback",
        "unsupported_profile_behavior",
        "ticket_expiry_seconds",
        "required_evidence_packet_refs",
        "downgrade_triggers",
        "source_contract_refs",
        "consumer_surfaces"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/executingSurface" },
        "qualification": { "$ref": "#/$defs/qualificationClass" },
        "scope_summary": { "type": "string", "minLength": 1 },
        "default_sandbox_profile": { "$ref": "#/$defs/sandboxProfile" },
        "approval_ticket_posture": { "$ref": "#/$defs/approvalTicketPosture" },
        "allowed_capability_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/capabilityClass" }
        },
        "secret_scope": { "$ref": "#/$defs/secretScope" },
        "degraded_fallback": { "$ref": "#/$defs/degradedFallback" },
        "unsupported_profile_behavior": { "$ref": "#/$defs/unsupportedProfileBehavior" },
        "ticket_expiry_seconds": { "type": "integer", "minimum": 0 },
        "required_evidence_packet_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "downgrade_triggers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downgradeTrigger" }
        },
        "source_contract_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/consumerSurface" }
        }
      }
    },
    "trustReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_ambient_machine_privilege",
        "no_self_issued_authority_by_helpers",
        "target_identity_inspectable_and_export_safe",
        "sandbox_profile_inspectable",
        "secret_scope_handle_only_no_raw_material",
        "policy_epoch_and_expiry_inspectable",
        "degraded_fallback_inspectable",
        "fail_closed_when_enforcement_unavailable",
        "missing_enforcement_backend_auto_narrows",
        "no_raw_secret_material_in_exports"
      ],
      "properties": {
        "no_ambient_machine_privilege": { "type": "boolean" },
        "no_self_issued_authority_by_helpers": { "type": "boolean" },
        "target_identity_inspectable_and_export_safe": { "type": "boolean" },
        "sandbox_profile_inspectable": { "type": "boolean" },
        "secret_scope_handle_only_no_raw_material": { "type": "boolean" },
        "policy_epoch_and_expiry_inspectable": { "type": "boolean" },
        "degraded_fallback_inspectable": { "type": "boolean" },
        "fail_closed_when_enforcement_unavailable": { "type": "boolean" },
        "missing_enforcement_backend_auto_narrows": { "type": "boolean" },
        "no_raw_secret_material_in_exports": { "type": "boolean" }
      }
    },
    "consumerProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "desktop_shows_authority_envelope",
        "command_and_policy_reference_same_matrix",
        "cli_headless_shows_authority_envelope",
        "support_export_shows_authority_envelope",
        "diagnostics_shows_authority_envelope",
        "help_about_shows_qualification",
        "release_evidence_consumes_matrix",
        "preview_labs_label_for_unqualified_surfaces"
      ],
      "properties": {
        "desktop_shows_authority_envelope": { "type": "boolean" },
        "command_and_policy_reference_same_matrix": { "type": "boolean" },
        "cli_headless_shows_authority_envelope": { "type": "boolean" },
        "support_export_shows_authority_envelope": { "type": "boolean" },
        "diagnostics_shows_authority_envelope": { "type": "boolean" },
        "help_about_shows_qualification": { "type": "boolean" },
        "release_evidence_consumes_matrix": { "type": "boolean" },
        "preview_labs_label_for_unqualified_surfaces": { "type": "boolean" }
      }
    },
    "proofFreshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_freshness_slo_hours", "last_proof_refresh", "auto_narrow_on_stale"],
      "properties": {
        "proof_freshness_slo_hours": { "type": "integer", "minimum": 1 },
        "last_proof_refresh": { "type": "string", "minLength": 1 },
        "auto_narrow_on_stale": { "type": "boolean" }
      }
    }
  }
}
