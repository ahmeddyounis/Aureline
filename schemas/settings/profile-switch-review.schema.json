{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/settings/profile-switch-review.schema.json",
  "title": "Aureline profile-switch review and temporary-profile lifecycle certification",
  "description": "Boundary schema for the profile-switch review, temporary-profile lifecycle, portable profile artifact boundary, non-widening import/sync conflict review, rollback checkpoint, and local-authoritative fallback record consumed by settings, shell, sync, help, support export, and file portability surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "summary",
    "profile_cards",
    "switch_review",
    "temporary_profile",
    "artifact_boundaries",
    "import_conflicts",
    "apply_audit",
    "sync_fallbacks",
    "surface_truth",
    "pillars",
    "stable_qualification"
  ],
  "properties": {
    "record_kind": { "const": "profile_switch_review_lifecycle_certification_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": { "type": "string", "const": "settings:profile_switch_review_lifecycle:v1" },
    "record_id": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "profile_cards": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/profile_card_row" }
    },
    "switch_review": { "$ref": "#/$defs/profile_switch_review_sheet" },
    "temporary_profile": { "$ref": "#/$defs/temporary_profile_lifecycle" },
    "artifact_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/profile_artifact_boundary_row" }
    },
    "import_conflicts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/import_conflict_review_row" }
    },
    "apply_audit": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/apply_audit_row" }
    },
    "sync_fallbacks": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/sync_fallback_row" }
    },
    "surface_truth": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/surface_truth_row" }
    },
    "pillars": { "$ref": "#/$defs/pillars" },
    "stable_qualification": { "$ref": "#/$defs/stable_qualification" }
  },
  "$defs": {
    "canonical_ref": {
      "type": "string",
      "pattern": "^aureline://[^/]+/.+"
    },
    "profile_source_class": {
      "type": "string",
      "enum": [
        "durable_user_profile",
        "imported_profile",
        "synced_profile",
        "temporary_profile",
        "troubleshooting_profile",
        "policy_shaped_profile"
      ]
    },
    "profile_scope_class": {
      "type": "string",
      "enum": [
        "visual_appearance",
        "keybindings",
        "snippets",
        "extension_selection",
        "layout",
        "tasks_and_launch",
        "ai_and_network_defaults"
      ]
    },
    "profile_durability_class": {
      "type": "string",
      "enum": ["durable", "session_only", "discarded_on_exit", "inspect_only"]
    },
    "apply_timing_class": {
      "type": "string",
      "enum": ["immediate", "restart_required"]
    },
    "temporary_profile_action_class": {
      "type": "string",
      "enum": ["discard", "promote", "compare_to_durable_profile"]
    },
    "artifact_exclusion_class": {
      "type": "string",
      "enum": [
        "secret_material",
        "keychain_material",
        "machine_unique_trust_anchors",
        "delegated_credentials",
        "admin_policy_bundles",
        "workspace_trust_approvals",
        "machine_local_bindings"
      ]
    },
    "conflict_source_class": {
      "type": "string",
      "enum": ["imported_profile", "synced_profile", "local_durable_profile"]
    },
    "local_authoritative_reason": {
      "type": "string",
      "enum": [
        "stale_remote",
        "sync_unavailable",
        "undecryptable_payload",
        "policy_denied"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "desktop_profile_surface",
        "shell_rollback_surface",
        "sync_conflict_review",
        "help_docs",
        "support_export"
      ]
    },
    "stable_claim_class": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "not_claimed"]
    },
    "narrowing_reason": {
      "type": "string",
      "enum": [
        "switch_review_incomplete",
        "temporary_lifecycle_ambiguous",
        "artifact_boundary_violated",
        "hidden_authority_widening",
        "rollback_checkpoint_missing",
        "local_authoritative_fallback_hidden",
        "surface_truth_drift"
      ]
    },
    "profile_card_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_ref",
        "name",
        "purpose",
        "source_class",
        "durability_class",
        "included_scopes",
        "exportable_without_secrets",
        "visible_state_badge"
      ],
      "properties": {
        "profile_ref": { "$ref": "#/$defs/canonical_ref" },
        "name": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "source_class": { "$ref": "#/$defs/profile_source_class" },
        "durability_class": { "$ref": "#/$defs/profile_durability_class" },
        "included_scopes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/profile_scope_class" }
        },
        "exportable_without_secrets": { "type": "boolean" },
        "visible_state_badge": { "type": "boolean" }
      }
    },
    "profile_switch_delta_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "delta_id",
        "field_path",
        "scope_class",
        "before_value_preview",
        "after_value_preview",
        "apply_timing",
        "restart_posture",
        "narrows_behavior",
        "would_widen_authority",
        "widening_refused_or_reviewed"
      ],
      "properties": {
        "delta_id": { "type": "string", "minLength": 1 },
        "field_path": { "type": "string", "minLength": 1 },
        "scope_class": { "$ref": "#/$defs/profile_scope_class" },
        "before_value_preview": { "type": "string", "minLength": 1 },
        "after_value_preview": { "type": "string", "minLength": 1 },
        "apply_timing": { "$ref": "#/$defs/apply_timing_class" },
        "restart_posture": { "type": "string", "minLength": 1 },
        "narrows_behavior": { "type": "boolean" },
        "would_widen_authority": { "type": "boolean" },
        "widening_refused_or_reviewed": { "type": "boolean" }
      }
    },
    "excluded_machine_state_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exclusion_id", "state_class", "reason", "separate_addendum_required"],
      "properties": {
        "exclusion_id": { "type": "string", "minLength": 1 },
        "state_class": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "separate_addendum_required": { "type": "boolean" }
      }
    },
    "narrowing_effect_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effect_id", "affected_area", "explanation", "narrows_only"],
      "properties": {
        "effect_id": { "type": "string", "minLength": 1 },
        "affected_area": { "type": "string", "minLength": 1 },
        "explanation": { "type": "string", "minLength": 1 },
        "narrows_only": { "type": "boolean" }
      }
    },
    "profile_switch_review_sheet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_profile_ref",
        "to_profile_ref",
        "immediate_changes",
        "restart_required_changes",
        "excluded_machine_state",
        "narrowing_effects",
        "durable_state_changes_materially",
        "creates_rollback_checkpoint",
        "rollback_checkpoint_ref",
        "change_summary_ref",
        "rollback_banner_ref"
      ],
      "properties": {
        "from_profile_ref": { "$ref": "#/$defs/canonical_ref" },
        "to_profile_ref": { "$ref": "#/$defs/canonical_ref" },
        "immediate_changes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/profile_switch_delta_row" }
        },
        "restart_required_changes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/profile_switch_delta_row" }
        },
        "excluded_machine_state": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/excluded_machine_state_row" }
        },
        "narrowing_effects": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/narrowing_effect_row" }
        },
        "durable_state_changes_materially": { "type": "boolean" },
        "creates_rollback_checkpoint": { "type": "boolean" },
        "rollback_checkpoint_ref": {
          "anyOf": [{ "$ref": "#/$defs/canonical_ref" }, { "type": "null" }]
        },
        "change_summary_ref": { "$ref": "#/$defs/canonical_ref" },
        "rollback_banner_ref": { "$ref": "#/$defs/canonical_ref" }
      }
    },
    "temporary_profile_action_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_class",
        "target_ref",
        "keyboard_reachable",
        "persistence_effect_visible"
      ],
      "properties": {
        "action_class": { "$ref": "#/$defs/temporary_profile_action_class" },
        "target_ref": { "$ref": "#/$defs/canonical_ref" },
        "keyboard_reachable": { "type": "boolean" },
        "persistence_effect_visible": { "type": "boolean" }
      }
    },
    "temporary_profile_lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_ref",
        "source_class",
        "durability_class",
        "badge_label",
        "lifetime_or_expiry",
        "restricted_persistence_rules",
        "actions",
        "state_boundary_visible"
      ],
      "properties": {
        "profile_ref": { "$ref": "#/$defs/canonical_ref" },
        "source_class": { "$ref": "#/$defs/profile_source_class" },
        "durability_class": { "$ref": "#/$defs/profile_durability_class" },
        "badge_label": { "type": "string", "minLength": 1 },
        "lifetime_or_expiry": { "type": "string", "minLength": 1 },
        "restricted_persistence_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "actions": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/temporary_profile_action_row" }
        },
        "state_boundary_visible": { "type": "boolean" }
      }
    },
    "profile_artifact_boundary_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_ref",
        "artifact_shape",
        "schema_version",
        "text_based",
        "diffable",
        "exportable_without_forbidden_material",
        "excluded_classes"
      ],
      "properties": {
        "artifact_ref": { "$ref": "#/$defs/canonical_ref" },
        "artifact_shape": { "type": "string", "minLength": 1 },
        "schema_version": { "type": "string", "minLength": 1 },
        "text_based": { "type": "boolean" },
        "diffable": { "type": "boolean" },
        "exportable_without_forbidden_material": { "type": "boolean" },
        "excluded_classes": {
          "type": "array",
          "minItems": 7,
          "items": { "$ref": "#/$defs/artifact_exclusion_class" }
        }
      }
    },
    "import_conflict_review_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conflict_id",
        "source_class",
        "field_path",
        "local_value_preview",
        "incoming_value_preview",
        "effective_value_preview",
        "field_aware",
        "scope_aware",
        "would_widen_authority",
        "widening_refused",
        "local_authoritative_reason",
        "offered_choices"
      ],
      "properties": {
        "conflict_id": { "type": "string", "minLength": 1 },
        "source_class": { "$ref": "#/$defs/conflict_source_class" },
        "field_path": { "type": "string", "minLength": 1 },
        "local_value_preview": { "type": "string", "minLength": 1 },
        "incoming_value_preview": { "type": "string", "minLength": 1 },
        "effective_value_preview": { "type": "string", "minLength": 1 },
        "field_aware": { "type": "boolean" },
        "scope_aware": { "type": "boolean" },
        "would_widen_authority": { "type": "boolean" },
        "widening_refused": { "type": "boolean" },
        "local_authoritative_reason": {
          "anyOf": [{ "$ref": "#/$defs/local_authoritative_reason" }, { "type": "null" }]
        },
        "offered_choices": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "apply_audit_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "apply_id",
        "apply_source",
        "durable_state_changed",
        "change_summary_ref",
        "rollback_checkpoint_ref",
        "rollback_inspectable"
      ],
      "properties": {
        "apply_id": { "type": "string", "minLength": 1 },
        "apply_source": { "type": "string", "minLength": 1 },
        "durable_state_changed": { "type": "boolean" },
        "change_summary_ref": { "$ref": "#/$defs/canonical_ref" },
        "rollback_checkpoint_ref": {
          "anyOf": [{ "$ref": "#/$defs/canonical_ref" }, { "type": "null" }]
        },
        "rollback_inspectable": { "type": "boolean" }
      }
    },
    "sync_fallback_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "local_durable_state_authoritative",
        "file_based_portability_visible",
        "no_hidden_cloud_authority_claim"
      ],
      "properties": {
        "reason": { "$ref": "#/$defs/local_authoritative_reason" },
        "local_durable_state_authoritative": { "type": "boolean" },
        "file_based_portability_visible": { "type": "boolean" },
        "no_hidden_cloud_authority_claim": { "type": "boolean" }
      }
    },
    "surface_truth_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "record_ref",
        "consumes_shared_contract",
        "shows_profile_state",
        "shows_restart_delta_truth",
        "shows_rollback_checkpoint",
        "shows_local_authoritative_fallback"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "record_ref": { "$ref": "#/$defs/canonical_ref" },
        "consumes_shared_contract": { "type": "boolean" },
        "shows_profile_state": { "type": "boolean" },
        "shows_restart_delta_truth": { "type": "boolean" },
        "shows_rollback_checkpoint": { "type": "boolean" },
        "shows_local_authoritative_fallback": { "type": "boolean" }
      }
    },
    "pillars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "switch_review_complete",
        "temporary_lifecycle_complete",
        "artifact_boundary_held",
        "import_conflicts_non_widening",
        "rollback_checkpoints_created",
        "local_authoritative_fallback_visible",
        "surfaces_share_truth"
      ],
      "properties": {
        "switch_review_complete": { "type": "boolean" },
        "temporary_lifecycle_complete": { "type": "boolean" },
        "artifact_boundary_held": { "type": "boolean" },
        "import_conflicts_non_widening": { "type": "boolean" },
        "rollback_checkpoints_created": { "type": "boolean" },
        "local_authoritative_fallback_visible": { "type": "boolean" },
        "surfaces_share_truth": { "type": "boolean" }
      }
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_class", "qualifies_stable", "narrowing_reasons"],
      "properties": {
        "claim_class": { "$ref": "#/$defs/stable_claim_class" },
        "qualifies_stable": { "type": "boolean" },
        "narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        }
      }
    }
  }
}
