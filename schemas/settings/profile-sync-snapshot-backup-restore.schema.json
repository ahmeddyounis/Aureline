{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/settings/profile-sync-snapshot-backup-restore.schema.json",
  "title": "Aureline profile sync, snapshot, backup, restore, and offboarding certification",
  "description": "Boundary schema for the governed profile portability record. The record names the snapshot class, schema/product version, platform traits, included and excluded state classes, integrity hash, source provenance, merge rule, restore preview, rollback checkpoint, cross-platform sidecar, secret-boundary audit, retention posture, offboarding package, and local-authoritative fallback before profile sync, restore, export, or offboarding mutates current local state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "summary",
    "snapshots",
    "merge_rules",
    "restore_previews",
    "secret_boundary_audit",
    "surface_truth",
    "offboarding_retention",
    "conflict_coverage",
    "merge_rule_coverage",
    "pillars",
    "stable_qualification"
  ],
  "properties": {
    "record_kind": { "const": "profile_sync_restore_certification_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": { "type": "string", "const": "settings:profile_sync_snapshot_backup_restore:v1" },
    "record_id": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "snapshots": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/snapshot_manifest_row" }
    },
    "merge_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/merge_rule_row" }
    },
    "restore_previews": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/restore_preview_row" }
    },
    "secret_boundary_audit": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/secret_boundary_audit_row" }
    },
    "surface_truth": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/surface_truth_row" }
    },
    "offboarding_retention": { "$ref": "#/$defs/offboarding_retention_summary" },
    "conflict_coverage": {
      "type": "array",
      "items": { "$ref": "#/$defs/conflict_class" }
    },
    "merge_rule_coverage": {
      "type": "array",
      "items": { "$ref": "#/$defs/merge_rule_class" }
    },
    "pillars": { "$ref": "#/$defs/pillars" },
    "stable_qualification": { "$ref": "#/$defs/stable_qualification" }
  },
  "$defs": {
    "canonical_ref": {
      "type": "string",
      "pattern": "^aureline://[^/]+/.+"
    },
    "snapshot_class": {
      "type": "string",
      "enum": [
        "local_rollback_checkpoint",
        "portable_profile_export",
        "managed_sync_snapshot",
        "support_recovery_manifest"
      ]
    },
    "state_class": {
      "type": "string",
      "enum": [
        "scalar_settings",
        "keybindings",
        "snippets",
        "themes_and_ui_presets",
        "tasks",
        "launch_configs",
        "workset_definitions",
        "extension_inventory_refs",
        "reference_only_secret_metadata",
        "dirty_buffer_journals",
        "session_restore_state",
        "caches",
        "indexes",
        "secret_material"
      ]
    },
    "merge_subject_class": {
      "type": "string",
      "enum": ["scalar_setting", "additive_asset", "structured_definition"]
    },
    "merge_rule_class": {
      "type": "string",
      "enum": [
        "fieldwise_merge",
        "additive_merge",
        "explicit_conflict_review",
        "local_precedence"
      ]
    },
    "conflict_class": {
      "type": "string",
      "enum": [
        "exact_match",
        "fieldwise_merge",
        "additive_merge",
        "explicit_conflict_review",
        "stale_remote_local_precedence"
      ]
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "desktop_settings",
        "cli_inspect",
        "support_export",
        "help_docs",
        "admin_offboarding"
      ]
    },
    "snapshot_manifest_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_class",
        "snapshot_ref",
        "snapshot_schema_version",
        "aureline_version",
        "platform_traits",
        "included_state_classes",
        "excluded_state_classes",
        "integrity_hash",
        "source_provenance",
        "local_only"
      ],
      "properties": {
        "snapshot_class": { "$ref": "#/$defs/snapshot_class" },
        "snapshot_ref": { "$ref": "#/$defs/canonical_ref" },
        "snapshot_schema_version": { "type": "string", "minLength": 1 },
        "aureline_version": { "type": "string", "minLength": 1 },
        "platform_traits": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "included_state_classes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/state_class" } },
        "excluded_state_classes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/state_class" } },
        "integrity_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "source_provenance": { "type": "string", "minLength": 1 },
        "local_only": { "type": "boolean" },
        "waiver_ref": { "type": "string" }
      }
    },
    "merge_rule_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_id",
        "subject_class",
        "conflict_class",
        "merge_rule",
        "source_provenance",
        "stale_remote",
        "local_explicit_edit_wins",
        "change_set_ref",
        "rollback_checkpoint_ref",
        "overwrites_local_state",
        "explicit_review_required",
        "previewable_before_apply"
      ],
      "properties": {
        "subject_id": { "type": "string", "minLength": 1 },
        "subject_class": { "$ref": "#/$defs/merge_subject_class" },
        "conflict_class": { "$ref": "#/$defs/conflict_class" },
        "merge_rule": { "$ref": "#/$defs/merge_rule_class" },
        "source_provenance": { "type": "string", "minLength": 1 },
        "stale_remote": { "type": "boolean" },
        "local_explicit_edit_wins": { "type": "boolean" },
        "change_set_ref": { "$ref": "#/$defs/canonical_ref" },
        "rollback_checkpoint_ref": { "type": "string" },
        "overwrites_local_state": { "type": "boolean" },
        "explicit_review_required": { "type": "boolean" },
        "previewable_before_apply": { "type": "boolean" }
      }
    },
    "restore_preview_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_id",
        "source_ref",
        "snapshot_class",
        "structured_change_set_ref",
        "rollback_checkpoint_ref",
        "cross_platform_unmappable_sidecar_ref",
        "preserves_unmappable_sidecar",
        "retained_vs_overwritten_explicit",
        "previewable_before_apply",
        "overwrites_local_state"
      ],
      "properties": {
        "preview_id": { "type": "string", "minLength": 1 },
        "source_ref": { "$ref": "#/$defs/canonical_ref" },
        "snapshot_class": { "$ref": "#/$defs/snapshot_class" },
        "structured_change_set_ref": { "$ref": "#/$defs/canonical_ref" },
        "rollback_checkpoint_ref": { "type": "string" },
        "cross_platform_unmappable_sidecar_ref": { "$ref": "#/$defs/canonical_ref" },
        "preserves_unmappable_sidecar": { "type": "boolean" },
        "retained_vs_overwritten_explicit": { "type": "boolean" },
        "previewable_before_apply": { "type": "boolean" },
        "overwrites_local_state": { "type": "boolean" }
      }
    },
    "secret_boundary_audit_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_class",
        "lane",
        "raw_material_excluded",
        "reference_only_metadata_allowed",
        "evidence_ref"
      ],
      "properties": {
        "state_class": { "$ref": "#/$defs/state_class" },
        "lane": { "$ref": "#/$defs/snapshot_class" },
        "raw_material_excluded": { "type": "boolean" },
        "reference_only_metadata_allowed": { "type": "boolean" },
        "evidence_ref": { "$ref": "#/$defs/canonical_ref" }
      }
    },
    "surface_truth_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "consumes_shared_record",
        "shows_source",
        "shows_snapshot_class",
        "shows_state_classes",
        "shows_conflict_class",
        "shows_rollback_checkpoint",
        "shows_local_authoritative_fallback"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "consumes_shared_record": { "type": "boolean" },
        "shows_source": { "type": "boolean" },
        "shows_snapshot_class": { "type": "boolean" },
        "shows_state_classes": { "type": "boolean" },
        "shows_conflict_class": { "type": "boolean" },
        "shows_rollback_checkpoint": { "type": "boolean" },
        "shows_local_authoritative_fallback": { "type": "boolean" }
      }
    },
    "offboarding_retention_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_checkpoint_retention_days",
        "retention_inspectable",
        "final_export_package_ref",
        "latest_successful_sync_manifest_ref",
        "profile_export_pointers",
        "extension_inventory_ref",
        "remaining_retention_timeline_ref",
        "explainable_without_internal_logs",
        "local_launch_edit_authority_retained",
        "managed_sync_required_for_local_work"
      ],
      "properties": {
        "local_checkpoint_retention_days": { "type": "integer", "minimum": 1, "maximum": 90 },
        "retention_inspectable": { "type": "boolean" },
        "final_export_package_ref": { "$ref": "#/$defs/canonical_ref" },
        "latest_successful_sync_manifest_ref": { "$ref": "#/$defs/canonical_ref" },
        "profile_export_pointers": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/canonical_ref" } },
        "extension_inventory_ref": { "$ref": "#/$defs/canonical_ref" },
        "remaining_retention_timeline_ref": { "$ref": "#/$defs/canonical_ref" },
        "explainable_without_internal_logs": { "type": "boolean" },
        "local_launch_edit_authority_retained": { "type": "boolean" },
        "managed_sync_required_for_local_work": { "type": "boolean" }
      }
    },
    "pillars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_classes_complete",
        "merge_rules_enforced",
        "secret_boundary_held",
        "restore_preview_checkpointed",
        "cross_platform_sidecar_preserved",
        "retention_offboarding_truth",
        "surface_truth_complete",
        "local_authority_retained"
      ],
      "properties": {
        "snapshot_classes_complete": { "type": "boolean" },
        "merge_rules_enforced": { "type": "boolean" },
        "secret_boundary_held": { "type": "boolean" },
        "restore_preview_checkpointed": { "type": "boolean" },
        "cross_platform_sidecar_preserved": { "type": "boolean" },
        "retention_offboarding_truth": { "type": "boolean" },
        "surface_truth_complete": { "type": "boolean" },
        "local_authority_retained": { "type": "boolean" }
      }
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_class", "qualifies_stable", "narrowing_reasons"],
      "properties": {
        "claim_class": { "type": "string", "enum": ["stable", "beta", "preview", "not_claimed"] },
        "qualifies_stable": { "type": "boolean" },
        "narrowing_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "snapshot_classes_incomplete",
              "merge_rules_unenforced",
              "secret_boundary_failed",
              "restore_preview_missing",
              "cross_platform_sidecar_missing",
              "retention_offboarding_incomplete",
              "surface_truth_incomplete",
              "local_authority_lost"
            ]
          }
        }
      }
    }
  }
}
