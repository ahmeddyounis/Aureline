{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/settings/keybindings.schema.json",
  "title": "Aureline keybinding settings inspection record",
  "description": "Settings/detail projection for source-attributed keybinding truth. The resolver owns key sequence resolution; this schema owns the row shape settings, help, migration, and support surfaces render after resolution.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "row_id",
    "command_id",
    "command_title",
    "current_sequence",
    "source_chain",
    "preview_class",
    "approval_posture_class",
    "authority_class"
  ],
  "additionalProperties": false,
  "properties": {
    "record_kind": { "const": "keybinding_setting_inspection_record" },
    "schema_version": { "const": 1 },
    "row_id": { "$ref": "#/$defs/non_empty_string" },
    "command_id": {
      "type": "string",
      "pattern": "^cmd:[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"
    },
    "command_title": { "$ref": "#/$defs/non_empty_string" },
    "current_sequence": { "$ref": "#/$defs/non_empty_string" },
    "source_chain": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source_record" }
    },
    "preview_class": { "$ref": "#/$defs/non_empty_string" },
    "approval_posture_class": { "$ref": "#/$defs/non_empty_string" },
    "authority_class": { "$ref": "#/$defs/non_empty_string" },
    "resolver_packet_ref": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "conflict": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/conflict_record" }
      ]
    },
    "narrowing": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/narrowing_record" }
      ]
    },
    "retained_report_ref": {
      "type": ["string", "null"],
      "minLength": 1
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "source_layer": {
      "type": "string",
      "enum": [
        "platform_reserved",
        "emergency_security_hard_block",
        "admin_policy_lock",
        "temporary_mode_overlay",
        "user_profile_binding",
        "workspace_recommendation",
        "extension_binding",
        "core_default",
        "not_bound"
      ]
    },
    "source_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_layer",
        "source_ref",
        "source_label",
        "winner",
        "outcome_reason_code"
      ],
      "properties": {
        "source_layer": { "$ref": "#/$defs/source_layer" },
        "source_ref": { "$ref": "#/$defs/non_empty_string" },
        "source_label": { "$ref": "#/$defs/non_empty_string" },
        "winner": { "type": "boolean" },
        "outcome_reason_code": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "narrowing_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "narrowing_class",
        "owner_ref",
        "explanation"
      ],
      "properties": {
        "narrowing_class": { "$ref": "#/$defs/non_empty_string" },
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "explanation": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "conflict_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conflict_review_ref",
        "literal_sequence",
        "winning_command_id",
        "losing_command_ids",
        "migration_report_ref"
      ],
      "properties": {
        "conflict_review_ref": { "$ref": "#/$defs/non_empty_string" },
        "literal_sequence": { "$ref": "#/$defs/non_empty_string" },
        "winning_command_id": {
          "type": ["string", "null"],
          "pattern": "^cmd:[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"
        },
        "losing_command_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^cmd:[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"
          }
        },
        "migration_report_ref": {
          "type": ["string", "null"],
          "minLength": 1
        }
      }
    }
  }
}
