{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/files/watch_fidelity_state.schema.json",
  "title": "Aureline watch-fidelity state record",
  "description": "Boundary schema for watch_fidelity_state_record instances frozen in docs/files/save_fallback_and_watch_fidelity_contract.md. The record names how trustworthy 'I would notice if this file changed outside Aureline' is right now on the active root, which downstream product truths may lag because of the current fidelity state, and which watcher source produced the state. Raw paths, raw URIs, raw provider URLs, and raw credentials never cross this boundary; the record carries opaque refs and closed vocabularies. Adding a new state, watcher source, lag entry, or reduced-fidelity reason is additive-minor; repurposing one is breaking.",
  "type": "object",
  "$ref": "#/$defs/watch_fidelity_state_record",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "nullable_string": {
      "oneOf": [
        { "$ref": "#/$defs/non_empty_string" },
        { "type": "null" }
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_timestamp": {
      "oneOf": [
        { "$ref": "#/$defs/timestamp" },
        { "type": "null" }
      ]
    },
    "record_kind": {
      "type": "string",
      "const": "watch_fidelity_state_record"
    },
    "watch_fidelity_state": {
      "type": "string",
      "enum": [
        "live_watch",
        "reduced_fidelity_watch",
        "polling_fallback",
        "manual_refresh_only"
      ]
    },
    "watcher_source": {
      "type": "string",
      "enum": [
        "os_native_inotify",
        "os_native_kqueue",
        "os_native_fsevents",
        "os_native_readdirectorychangesw",
        "polling_scanner_local",
        "remote_agent_event_stream",
        "remote_agent_polling_proxy",
        "provider_change_feed",
        "provider_polling_proxy",
        "archive_static_snapshot",
        "none_user_disabled",
        "none_entitlement_missing",
        "none_root_disconnected",
        "unknown"
      ]
    },
    "lagging_downstream_truth": {
      "type": "string",
      "enum": [
        "file_tree_row_freshness",
        "quick_open_results",
        "search_index_freshness",
        "external_change_detection",
        "dirty_buffer_external_diff",
        "autosave_correctness_floor",
        "formatter_or_refactor_apply_basis",
        "language_server_disk_view",
        "task_runner_input_freshness",
        "git_status_view",
        "provider_revision_view",
        "cross_root_alias_resolution",
        "metadata_attribute_freshness"
      ]
    },
    "reduced_fidelity_reason": {
      "type": "string",
      "enum": [
        "event_coalescing_active",
        "subtree_coverage_dropped",
        "attribute_only_events",
        "rename_pairing_missing",
        "backend_degraded_at_least_once_window",
        "provider_change_feed_throttled",
        "remote_agent_partial_event_stream"
      ]
    },
    "root_class": {
      "type": "string",
      "enum": [
        "local_posix_like",
        "local_windows_like",
        "remote_agent_mount",
        "container_mount",
        "cloud_backed_sync_root",
        "virtual_generated_document",
        "archive_like_view",
        "unknown"
      ]
    },
    "support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_family", "redaction_policy"],
      "properties": {
        "packet_family": {
          "type": "string",
          "const": "files.watch_fidelity_state"
        },
        "redaction_policy": { "$ref": "#/$defs/non_empty_string" },
        "parity_signature": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "watch_fidelity_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "record_id",
        "observed_at",
        "state",
        "watcher_source",
        "reduced_fidelity_reason",
        "polling_interval_seconds",
        "lagging_downstream_truths",
        "root_class",
        "presentation_path_ref",
        "canonical_object_ref",
        "last_proven_consistent_at",
        "support_export"
      ],
      "properties": {
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "record_id": { "$ref": "#/$defs/non_empty_string" },
        "observed_at": { "$ref": "#/$defs/timestamp" },
        "state": { "$ref": "#/$defs/watch_fidelity_state" },
        "watcher_source": { "$ref": "#/$defs/watcher_source" },
        "reduced_fidelity_reason": {
          "oneOf": [
            { "$ref": "#/$defs/reduced_fidelity_reason" },
            { "type": "null" }
          ]
        },
        "polling_interval_seconds": {
          "oneOf": [
            { "type": "number", "exclusiveMinimum": 0 },
            { "type": "null" }
          ]
        },
        "lagging_downstream_truths": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/lagging_downstream_truth" }
        },
        "root_class": { "$ref": "#/$defs/root_class" },
        "presentation_path_ref": { "$ref": "#/$defs/non_empty_string" },
        "canonical_object_ref": { "$ref": "#/$defs/non_empty_string" },
        "last_proven_consistent_at": { "$ref": "#/$defs/nullable_timestamp" },
        "support_export": { "$ref": "#/$defs/support_export" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "state": { "const": "live_watch" } },
            "required": ["state"]
          },
          "then": {
            "properties": {
              "lagging_downstream_truths": { "maxItems": 0 },
              "reduced_fidelity_reason": { "const": null },
              "polling_interval_seconds": { "const": null }
            }
          }
        },
        {
          "if": {
            "properties": { "state": { "const": "reduced_fidelity_watch" } },
            "required": ["state"]
          },
          "then": {
            "properties": {
              "lagging_downstream_truths": { "minItems": 1 },
              "reduced_fidelity_reason": { "$ref": "#/$defs/reduced_fidelity_reason" },
              "polling_interval_seconds": { "const": null }
            },
            "required": ["reduced_fidelity_reason"]
          }
        },
        {
          "if": {
            "properties": { "state": { "const": "polling_fallback" } },
            "required": ["state"]
          },
          "then": {
            "properties": {
              "lagging_downstream_truths": {
                "type": "array",
                "minItems": 2,
                "allOf": [
                  { "contains": { "const": "external_change_detection" } },
                  { "contains": { "const": "autosave_correctness_floor" } }
                ]
              },
              "reduced_fidelity_reason": { "const": null },
              "polling_interval_seconds": { "type": "number", "exclusiveMinimum": 0 }
            },
            "required": ["polling_interval_seconds"]
          }
        },
        {
          "if": {
            "properties": { "state": { "const": "manual_refresh_only" } },
            "required": ["state"]
          },
          "then": {
            "properties": {
              "lagging_downstream_truths": { "minItems": 1 },
              "reduced_fidelity_reason": { "const": null },
              "polling_interval_seconds": { "const": null }
            }
          }
        }
      ]
    }
  }
}
