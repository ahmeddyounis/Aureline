{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/git/sequence_edit_session.schema.json",
  "title": "Aureline sequence-edit session beta record (history-rewrite lane)",
  "description": "Boundary schema for the durable sequence-edit session record family pinned in docs/source_control/m3/history_rewrite_beta.md. One sequence-edit session row owns an interactive rebase todo, a cherry-pick list, or a patch sequence: it pins the raw todo text and the structured step rows to one underlying object so desktop, CLI/headless, and support/export views cannot drift. The row also records the recovery posture and the ref-update proposal that gates every ref-moving step. Raw absolute paths, raw branch names, raw remote URLs, raw author identity strings, raw commit message bodies, raw patch bodies, and raw reflog bodies MUST NOT appear here.",
  "type": "object",
  "$ref": "#/$defs/history_rewrite_sequence_edit_session_record",
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "opaque_id": { "type": "string", "minLength": 1 },
    "non_empty_string": { "type": "string", "minLength": 1 },
    "monotonic_timestamp": { "type": "string", "format": "date-time" },
    "operation_kind": {
      "type": "string",
      "enum": [
        "rebase",
        "interactive_rebase",
        "cherry_pick",
        "revert",
        "reset",
        "patch_apply",
        "stash_apply",
        "stash_pop",
        "stash_drop",
        "branch_from_stash",
        "merge",
        "amend"
      ]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "draft_unsaved",
        "saved_ready_to_run",
        "running",
        "paused_for_conflict",
        "paused_for_user_edit",
        "completed_admitted",
        "aborted_rolled_back",
        "failed_no_changes_made"
      ]
    },
    "sequence_verb": {
      "type": "string",
      "enum": [
        "pick",
        "reword",
        "edit",
        "squash",
        "fixup",
        "drop",
        "exec",
        "label",
        "reset",
        "merge",
        "break_point",
        "skip"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "desktop_history_panel",
        "desktop_conflict_resolver",
        "desktop_sequence_editor",
        "desktop_stash_browser",
        "activity_center",
        "cli_headless_entry",
        "support_export",
        "audit_lane",
        "review_panel"
      ]
    },
    "recovery_posture_class": {
      "type": "string",
      "enum": [
        "recovery_checkpoint_captured",
        "reflog_only_disclosure_acknowledged",
        "no_recovery_available_blocks_apply",
        "external_handoff_pending"
      ]
    },
    "next_safe_path_class": {
      "type": "string",
      "enum": [
        "open_alternate_worktree",
        "create_temporary_branch",
        "export_history_plan",
        "review_only_mode",
        "request_approval",
        "abort_operation",
        "restore_checkpoint",
        "switch_to_reflog_disclosure",
        "no_safe_path_blocked_requires_human"
      ]
    },
    "audit_event_id": {
      "type": "string",
      "enum": [
        "session_admitted",
        "session_resumed_after_restart",
        "conflict_continue_requested",
        "conflict_skip_requested",
        "conflict_abort_requested",
        "sequence_edit_saved",
        "sequence_edit_step_started",
        "sequence_edit_step_completed",
        "stash_captured",
        "stash_applied",
        "stash_dropped",
        "stash_promoted_to_branch",
        "recovery_checkpoint_captured",
        "recovery_checkpoint_restored",
        "ref_update_proposal_drafted",
        "ref_update_proposal_blocked",
        "ref_update_proposal_applied",
        "next_safe_path_offered",
        "next_safe_path_accepted"
      ]
    },
    "ref_id": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_id", "ref_class", "display_label"],
      "properties": {
        "ref_id": { "$ref": "#/$defs/opaque_id" },
        "ref_class": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "worktree_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace_ref", "worktree_ref", "worktree_label", "is_linked_worktree"],
      "properties": {
        "workspace_ref": { "$ref": "#/$defs/opaque_id" },
        "worktree_ref": { "$ref": "#/$defs/opaque_id" },
        "worktree_label": { "$ref": "#/$defs/non_empty_string" },
        "is_linked_worktree": { "type": "boolean" }
      }
    },
    "recovery_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "posture_class",
        "checkpoint_captured",
        "reflog_only_disclosure_acknowledged",
        "disclosure_label"
      ],
      "properties": {
        "posture_class": { "$ref": "#/$defs/recovery_posture_class" },
        "recovery_checkpoint_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_id" }]
        },
        "checkpoint_captured": { "type": "boolean" },
        "reflog_only_disclosure_acknowledged": { "type": "boolean" },
        "disclosure_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_packet_refs",
        "redaction_class",
        "raw_path_export_allowed",
        "raw_branch_name_export_allowed",
        "raw_patch_body_export_allowed",
        "raw_reflog_body_export_allowed",
        "raw_stash_body_export_allowed"
      ],
      "properties": {
        "export_packet_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "redaction_class": { "$ref": "#/$defs/non_empty_string" },
        "raw_path_export_allowed": { "const": false },
        "raw_branch_name_export_allowed": { "const": false },
        "raw_patch_body_export_allowed": { "const": false },
        "raw_reflog_body_export_allowed": { "const": false },
        "raw_stash_body_export_allowed": { "const": false }
      }
    },
    "audit_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "session_ref", "summary_label", "occurred_at"],
      "properties": {
        "event_id": { "$ref": "#/$defs/audit_event_id" },
        "session_ref": { "$ref": "#/$defs/opaque_id" },
        "summary_label": { "$ref": "#/$defs/non_empty_string" },
        "occurred_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "next_safe_path_class": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/next_safe_path_class" }]
        },
        "recovery_checkpoint_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_id" }]
        }
      }
    },
    "sequence_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordinal",
        "verb",
        "target_ref",
        "display_label",
        "current_step",
        "completed"
      ],
      "properties": {
        "ordinal": { "type": "integer", "minimum": 0 },
        "verb": { "$ref": "#/$defs/sequence_verb" },
        "target_ref": { "$ref": "#/$defs/ref_id" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "current_step": { "type": "boolean" },
        "completed": { "type": "boolean" },
        "conflict_session_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_id" }]
        }
      }
    },
    "history_rewrite_sequence_edit_session_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "sequence_edit_session_id",
        "operation_kind",
        "lifecycle_state",
        "display_label",
        "summary",
        "worktree_context",
        "onto_ref",
        "head_ref",
        "steps",
        "raw_todo_text_ref",
        "recovery_posture",
        "ref_update_proposal_ref",
        "consumer_surfaces",
        "support_export",
        "audit_events",
        "minted_at",
        "updated_at"
      ],
      "properties": {
        "record_kind": { "const": "history_rewrite_sequence_edit_session_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "sequence_edit_session_id": { "$ref": "#/$defs/opaque_id" },
        "operation_kind": { "$ref": "#/$defs/operation_kind" },
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "summary": { "$ref": "#/$defs/non_empty_string" },
        "worktree_context": { "$ref": "#/$defs/worktree_context" },
        "onto_ref": { "$ref": "#/$defs/ref_id" },
        "head_ref": { "$ref": "#/$defs/ref_id" },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sequence_step" }
        },
        "raw_todo_text_ref": { "$ref": "#/$defs/opaque_id" },
        "active_conflict_session_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_id" }]
        },
        "recovery_posture": { "$ref": "#/$defs/recovery_posture" },
        "ref_update_proposal_ref": { "$ref": "#/$defs/opaque_id" },
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/consumer_surface" },
          "allOf": [
            { "contains": { "const": "support_export" } },
            { "contains": { "const": "audit_lane" } }
          ]
        },
        "support_export": { "$ref": "#/$defs/support_export" },
        "audit_events": {
          "type": "array",
          "items": { "$ref": "#/$defs/audit_event" }
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "updated_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Running and completed lifecycle states require recovery checkpoint or reflog-only disclosure.",
          "if": {
            "properties": {
              "lifecycle_state": { "enum": ["running", "completed_admitted"] }
            },
            "required": ["lifecycle_state"]
          },
          "then": {
            "properties": {
              "recovery_posture": {
                "properties": {
                  "posture_class": {
                    "enum": [
                      "recovery_checkpoint_captured",
                      "reflog_only_disclosure_acknowledged"
                    ]
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
