{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/notebook/materialize_the_canonical_ipynb_document_model_stable_cell_ids_attachments_and_no_kernel_editability.schema.json",
  "title": "Aureline canonical .ipynb document model, stable cell IDs, attachments, and no-kernel editability",
  "description": "Boundary schema for the notebook canonical document model. Every record that crosses the document-model boundary (document, cell, attachment, local-state overlay, document-model packet) projects through this schema. Raw notebook JSON bodies, raw cell source bytes, raw attachment bytes, and raw URLs MUST NOT appear in any record; records carry refs only. Additive-optional fields do not bump the schema_version; repurposing an existing member is breaking.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/notebook_document_record" },
    { "$ref": "#/$defs/notebook_cell_record" },
    { "$ref": "#/$defs/notebook_attachment_record" },
    { "$ref": "#/$defs/notebook_local_state_overlay_record" },
    { "$ref": "#/$defs/notebook_document_model_packet_record" }
  ],
  "$defs": {
    "notebook_document_model_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the notebook document model. Current value is 1. Bumped only on breaking payload changes; additive-optional fields do not bump this version."
    },

    "record_kind": {
      "type": "string",
      "enum": [
        "notebook_document",
        "notebook_cell",
        "notebook_attachment",
        "notebook_local_state_overlay",
        "notebook_document_model_packet"
      ],
      "description": "Discriminator for the concrete payload shape. Every record carries exactly one kind."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests / journal entries / support bundles."
    },

    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque ref to another record (VFS path-identity, cell source body, trust-decision packet, cell id, output id, attachment id, etc.). Consumers resolve refs through the owning registry."
    },

    "opaque_ref_nullable": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_ref" },
        { "type": "null" }
      ],
      "description": "Nullable opaque ref."
    },

    "notebook_cell_type": {
      "type": "string",
      "enum": ["code", "markdown", "raw"],
      "description": "Frozen cell-type vocabulary. Mirrors the official Jupyter nbformat vocabulary."
    },

    "notebook_canonical_preservation_class": {
      "type": "string",
      "enum": [
        "canonical_ipynb_preserved",
        "export_only_no_round_trip",
        "no_paired_text_representation"
      ],
      "description": "Frozen canonical-preservation class. The on-disk .ipynb is always canonical; paired text exports are derived."
    },

    "notebook_cell_id_stability_class": {
      "type": "string",
      "enum": [
        "stable_cell_id_required",
        "stable_cell_id_minted_on_first_save",
        "cell_id_stability_not_available_raw_json_fallback_only"
      ],
      "description": "Frozen cell-id stability class. Stable cell ids are the merge gate; non-availability forces raw-JSON fallback with a visible chip."
    },

    "notebook_metadata_survival_class": {
      "type": "string",
      "enum": [
        "survival_required_jupyter_and_aureline_namespaces",
        "survival_required_vendor_namespaces",
        "survival_recommended_unknown_vendor_namespaces"
      ],
      "description": "Frozen metadata-survival class. Jupyter/kernelspec/language_info/aureline namespaces MUST survive; vendor namespaces MUST survive and filtering requires an explicit preset; unknown vendor namespaces SHOULD survive."
    },

    "notebook_no_kernel_editability_class": {
      "type": "string",
      "enum": [
        "editable_searchable_reviewable",
        "editable_readonly_kernel_required_for_execution",
        "editable_with_degraded_preview"
      ],
      "description": "Frozen no-kernel editability class. The notebook must always remain editable, searchable, and reviewable; this class says how degraded the preview is when no kernel is available."
    },

    "notebook_attachment_preview_class": {
      "type": "string",
      "enum": [
        "inline_preview",
        "thumbnail_preview",
        "icon_preview",
        "no_preview"
      ],
      "description": "Frozen attachment-preview class. Names how an attachment is previewed in the chrome row without exposing raw bytes."
    },

    "notebook_paired_text_export_posture_class": {
      "type": "string",
      "enum": [
        "paired_text_export_not_applicable",
        "paired_text_export_derived_notebook_to_script",
        "paired_text_export_derived_notebook_to_markdown"
      ],
      "description": "Frozen paired-text export posture class vocabulary. Paired text exports are always derived from the canonical .ipynb; promoting a paired text form to canonical is non-conforming."
    },

    "notebook_document_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "notebook_document_model_schema_version",
        "document_id",
        "document_path_token_ref",
        "document_uri",
        "nbformat_major",
        "nbformat_minor",
        "canonical_preservation_class",
        "cell_id_stability_class",
        "metadata_survival_class",
        "no_kernel_editability_class",
        "document_trust_state_ref",
        "workspace_trust_state_ref",
        "paired_text_export_posture_class",
        "cells",
        "local_state_overlay",
        "cell_order_digest",
        "summary"
      ],
      "properties": {
        "record_kind": { "const": "notebook_document" },
        "notebook_document_model_schema_version": { "$ref": "#/$defs/notebook_document_model_schema_version" },
        "document_id": { "$ref": "#/$defs/opaque_id" },
        "document_path_token_ref": { "$ref": "#/$defs/opaque_ref" },
        "document_uri": { "type": "string", "minLength": 1 },
        "nbformat_major": { "type": "integer", "minimum": 0 },
        "nbformat_minor": { "type": "integer", "minimum": 0 },
        "canonical_preservation_class": { "$ref": "#/$defs/notebook_canonical_preservation_class" },
        "cell_id_stability_class": { "$ref": "#/$defs/notebook_cell_id_stability_class" },
        "metadata_survival_class": { "$ref": "#/$defs/notebook_metadata_survival_class" },
        "no_kernel_editability_class": { "$ref": "#/$defs/notebook_no_kernel_editability_class" },
        "document_trust_state_ref": { "$ref": "#/$defs/opaque_ref" },
        "workspace_trust_state_ref": { "$ref": "#/$defs/opaque_ref" },
        "paired_text_export_posture_class": { "$ref": "#/$defs/notebook_paired_text_export_posture_class" },
        "paired_text_export_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "cells": {
          "type": "array",
          "items": { "$ref": "#/$defs/notebook_cell_record" },
          "minItems": 1
        },
        "local_state_overlay": { "$ref": "#/$defs/notebook_local_state_overlay_record" },
        "cell_order_digest": { "type": "string", "minLength": 1 },
        "metadata_namespace_inventory": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "summary": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "description": "paired-text export refs are non-null only when the paired-text posture is a derived class.",
          "if": {
            "properties": {
              "paired_text_export_posture_class": {
                "enum": [
                  "paired_text_export_derived_notebook_to_script",
                  "paired_text_export_derived_notebook_to_markdown"
                ]
              }
            },
            "required": ["paired_text_export_posture_class"]
          },
          "then": {
            "required": ["paired_text_export_ref"],
            "properties": {
              "paired_text_export_ref": { "$ref": "#/$defs/opaque_ref" }
            }
          }
        },
        {
          "description": "paired_text_export_not_applicable MUST NOT carry a paired-text export ref.",
          "if": {
            "properties": {
              "paired_text_export_posture_class": { "const": "paired_text_export_not_applicable" }
            },
            "required": ["paired_text_export_posture_class"]
          },
          "then": {
            "properties": {
              "paired_text_export_ref": { "type": "null" }
            }
          }
        }
      ]
    },

    "notebook_cell_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "notebook_document_model_schema_version",
        "cell_id",
        "document_id_ref",
        "cell_type",
        "cell_source_ref",
        "cell_metadata_survival_class",
        "summary"
      ],
      "properties": {
        "record_kind": { "const": "notebook_cell" },
        "notebook_document_model_schema_version": { "$ref": "#/$defs/notebook_document_model_schema_version" },
        "cell_id": { "$ref": "#/$defs/opaque_id" },
        "document_id_ref": { "$ref": "#/$defs/opaque_ref" },
        "cell_type": { "$ref": "#/$defs/notebook_cell_type" },
        "cell_source_ref": { "$ref": "#/$defs/opaque_ref" },
        "cell_metadata_survival_class": { "$ref": "#/$defs/notebook_metadata_survival_class" },
        "attachment_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "unknown_vendor_namespaces_present": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "last_cell_execution_id_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "output_lineage_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "collapsed": { "type": "boolean" },
        "summary": { "type": "string", "minLength": 1 }
      }
    },

    "notebook_attachment_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "notebook_document_model_schema_version",
        "attachment_id",
        "owner_cell_ref",
        "mime_class",
        "digest",
        "size_bytes",
        "preview_class",
        "summary"
      ],
      "properties": {
        "record_kind": { "const": "notebook_attachment" },
        "notebook_document_model_schema_version": { "$ref": "#/$defs/notebook_document_model_schema_version" },
        "attachment_id": { "$ref": "#/$defs/opaque_id" },
        "owner_cell_ref": { "$ref": "#/$defs/opaque_ref" },
        "mime_class": { "type": "string", "minLength": 1 },
        "digest": { "type": "string", "minLength": 1 },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "preview_class": { "$ref": "#/$defs/notebook_attachment_preview_class" },
        "summary": { "type": "string", "minLength": 1 }
      }
    },

    "notebook_local_state_overlay_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "notebook_document_model_schema_version",
        "overlay_id",
        "document_id_ref",
        "summary"
      ],
      "properties": {
        "record_kind": { "const": "notebook_local_state_overlay" },
        "notebook_document_model_schema_version": { "$ref": "#/$defs/notebook_document_model_schema_version" },
        "overlay_id": { "$ref": "#/$defs/opaque_id" },
        "document_id_ref": { "$ref": "#/$defs/opaque_ref" },
        "selected_cell_id_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "output_collapsed_cell_id_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "source_folded_cell_id_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "scroll_anchor_cell_id_ref": { "$ref": "#/$defs/opaque_ref_nullable" },
        "pinned_viewer_cell_id_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_ref" }
        },
        "summary": { "type": "string", "minLength": 1 }
      }
    },

    "notebook_document_model_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "packet_id",
        "as_of",
        "cell_types",
        "canonical_preservation_classes",
        "cell_id_stability_classes",
        "metadata_survival_classes",
        "no_kernel_editability_classes",
        "attachment_preview_classes",
        "example_documents",
        "example_cells",
        "example_attachments",
        "example_overlays",
        "summary"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/notebook_document_model_schema_version" },
        "record_kind": { "const": "notebook_document_model_packet" },
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "as_of": { "type": "string", "format": "date-time" },
        "cell_types": {
          "type": "array",
          "items": { "$ref": "#/$defs/notebook_cell_type" },
          "minItems": 3,
          "maxItems": 3
        },
        "canonical_preservation_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/notebook_canonical_preservation_class" },
          "minItems": 3,
          "maxItems": 3
        },
        "cell_id_stability_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/notebook_cell_id_stability_class" },
          "minItems": 3,
          "maxItems": 3
        },
        "metadata_survival_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/notebook_metadata_survival_class" },
          "minItems": 3,
          "maxItems": 3
        },
        "no_kernel_editability_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/notebook_no_kernel_editability_class" },
          "minItems": 3,
          "maxItems": 3
        },
        "attachment_preview_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/notebook_attachment_preview_class" },
          "minItems": 4,
          "maxItems": 4
        },
        "example_documents": {
          "type": "array",
          "items": { "$ref": "#/$defs/notebook_document_record" }
        },
        "example_cells": {
          "type": "array",
          "items": { "$ref": "#/$defs/notebook_cell_record" }
        },
        "example_attachments": {
          "type": "array",
          "items": { "$ref": "#/$defs/notebook_attachment_record" }
        },
        "example_overlays": {
          "type": "array",
          "items": { "$ref": "#/$defs/notebook_local_state_overlay_record" }
        },
        "summary": { "type": "string", "minLength": 1 }
      }
    }
  }
}
