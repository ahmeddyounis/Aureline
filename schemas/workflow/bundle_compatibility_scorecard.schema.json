{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workflow/bundle_compatibility_scorecard.schema.json",
  "title": "Aureline workflow-bundle compatibility scorecard packet",
  "description": "Boundary schema for workflow-bundle compatibility scorecards consumed by Start Center, migration handoff, docs/help, and support-export surfaces. The packet binds a workflow bundle to explicit status vocabulary, compatible Aureline range, archetype rows, review and drift packet refs, support-safe export refs, and template/scaffold refs resolved through template or generated-lineage contracts. Raw paths, raw source payloads, raw user content, raw secrets, and raw signing material never cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/workflow_bundle_scorecard_packet_record" },
    { "$ref": "#/$defs/workflow_bundle_scorecard_row_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "bundle_class": {
      "type": "string",
      "enum": [
        "launch_bundle",
        "imported_user_bundle",
        "org_approved_bundle",
        "design_partner_bundle",
        "local_draft_bundle"
      ]
    },
    "bundle_source_class": {
      "type": "string",
      "enum": [
        "certified",
        "managed_approved",
        "community",
        "imported",
        "local_draft"
      ]
    },
    "bundle_status_class": {
      "type": "string",
      "enum": [
        "certified_current",
        "certified_retest_pending",
        "managed_approved_current",
        "community_reviewed",
        "community_unreviewed",
        "imported_pending_review",
        "local_draft",
        "deprecated_or_archived",
        "retest_needed",
        "status_unknown"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "officially_supported",
        "community_supported",
        "experimental",
        "legacy_deprecated",
        "unsupported",
        "support_unknown"
      ]
    },
    "mirror_or_offline_packaging_posture": {
      "type": "string",
      "enum": [
        "live_origin_only",
        "live_or_mirror",
        "mirror_only",
        "signed_offline_bundle",
        "offline_no_bundle",
        "packaging_posture_unknown"
      ]
    },
    "compatibility_status_class": {
      "type": "string",
      "enum": [
        "certified",
        "managed_approved",
        "community",
        "imported",
        "local_draft",
        "partial",
        "retest_pending",
        "blocked",
        "status_unknown"
      ],
      "description": "Closed scorecard status projected by badges, docs/help, migration handoff, and support export. Surfaces may narrow these for display but may not invent synonyms."
    },
    "display_status_label": {
      "type": "string",
      "enum": [
        "Certified",
        "Managed approved",
        "Community",
        "Imported",
        "Local draft",
        "Partial",
        "Retest pending",
        "Blocked",
        "Status unknown"
      ]
    },
    "surface_consumer": {
      "type": "string",
      "enum": [
        "start_center_bundle_detail",
        "onboarding_recommendation",
        "migration_handoff",
        "docs_help_badge",
        "support_export",
        "cli_headless_summary"
      ]
    },
    "bundle_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_id",
        "bundle_revision",
        "bundle_class",
        "bundle_source_class",
        "bundle_status_class"
      ],
      "properties": {
        "bundle_id": { "$ref": "#/$defs/opaque_id" },
        "bundle_revision": {
          "type": "integer",
          "minimum": 1
        },
        "bundle_class": { "$ref": "#/$defs/bundle_class" },
        "bundle_source_class": { "$ref": "#/$defs/bundle_source_class" },
        "bundle_status_class": { "$ref": "#/$defs/bundle_status_class" },
        "manifest_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "status_vocabulary_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status_class", "display_status_label"],
      "properties": {
        "status_class": { "$ref": "#/$defs/compatibility_status_class" },
        "display_status_label": { "$ref": "#/$defs/display_status_label" }
      }
    },
    "archetype_scorecard_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "archetype_row_ref",
        "support_class",
        "certification_state",
        "reference_workspace_refs"
      ],
      "properties": {
        "archetype_row_ref": { "$ref": "#/$defs/opaque_id" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "certification_state": { "$ref": "#/$defs/non_empty_string" },
        "reference_workspace_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "compatibility_evidence_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "review_scorecard_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "install_preview_ref",
        "update_preview_ref",
        "remove_review_ref",
        "rollback_checkpoint_policy",
        "drift_packet_ref"
      ],
      "properties": {
        "install_preview_ref": { "$ref": "#/$defs/opaque_id" },
        "update_preview_ref": { "$ref": "#/$defs/opaque_id" },
        "remove_review_ref": { "$ref": "#/$defs/opaque_id" },
        "rollback_checkpoint_policy": {
          "type": "string",
          "enum": ["create_before_apply_update_remove_or_rebase"]
        },
        "drift_packet_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "template_scaffold_scorecard_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_ref",
        "template_manifest_ref",
        "generated_lineage_contract_ref",
        "mirrorable",
        "opaque_generation_behavior_allowed"
      ],
      "properties": {
        "template_ref": { "$ref": "#/$defs/opaque_id" },
        "template_manifest_ref": { "$ref": "#/$defs/opaque_id" },
        "generated_lineage_contract_ref": { "$ref": "#/$defs/opaque_id" },
        "mirrorable": { "type": "boolean", "const": true },
        "opaque_generation_behavior_allowed": { "type": "boolean", "const": false }
      }
    },
    "support_export_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_packet_refs",
        "export_redaction_class",
        "raw_content_export_allowed",
        "support_safe_summary_ref"
      ],
      "properties": {
        "export_packet_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "export_redaction_class": { "$ref": "#/$defs/redaction_class" },
        "raw_content_export_allowed": { "type": "boolean", "const": false },
        "support_safe_summary_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "surface_projection_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_consumers",
        "start_center_detail_ref",
        "docs_help_badge_ref",
        "migration_handoff_ref",
        "support_export_ref"
      ],
      "properties": {
        "surface_consumers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_consumer" },
          "uniqueItems": true
        },
        "start_center_detail_ref": { "$ref": "#/$defs/opaque_id" },
        "docs_help_badge_ref": { "$ref": "#/$defs/opaque_id" },
        "migration_handoff_ref": { "$ref": "#/$defs/opaque_id" },
        "support_export_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "workflow_bundle_scorecard_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "bundle_scorecard_schema_version",
        "scorecard_row_id",
        "minted_at",
        "bundle",
        "compatibility_status_class",
        "display_status_label",
        "scorecard_state_summary_ref",
        "compatible_aureline_range",
        "archetype_bindings",
        "evidence_refs",
        "review_refs",
        "template_scaffold_refs",
        "mirror_or_offline_packaging_posture",
        "support_export",
        "surface_projection",
        "redaction_class"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "workflow_bundle_scorecard_row_record"
        },
        "bundle_scorecard_schema_version": { "$ref": "#/$defs/schema_version" },
        "scorecard_row_id": { "$ref": "#/$defs/opaque_id" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "bundle": { "$ref": "#/$defs/bundle_identity" },
        "compatibility_status_class": { "$ref": "#/$defs/compatibility_status_class" },
        "display_status_label": { "$ref": "#/$defs/display_status_label" },
        "scorecard_state_summary_ref": { "$ref": "#/$defs/opaque_id" },
        "compatible_aureline_range": { "$ref": "#/$defs/non_empty_string" },
        "archetype_bindings": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/archetype_scorecard_binding" }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "review_refs": { "$ref": "#/$defs/review_scorecard_refs" },
        "template_scaffold_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/template_scaffold_scorecard_ref" }
        },
        "mirror_or_offline_packaging_posture": {
          "$ref": "#/$defs/mirror_or_offline_packaging_posture"
        },
        "support_export": { "$ref": "#/$defs/support_export_binding" },
        "surface_projection": { "$ref": "#/$defs/surface_projection_binding" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    },
    "workflow_bundle_scorecard_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "bundle_scorecard_schema_version",
        "scorecard_packet_id",
        "minted_at",
        "status_vocabulary",
        "surface_consumers",
        "rows",
        "redaction_class"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "record_kind": {
          "type": "string",
          "const": "workflow_bundle_scorecard_packet_record"
        },
        "bundle_scorecard_schema_version": { "$ref": "#/$defs/schema_version" },
        "scorecard_packet_id": { "$ref": "#/$defs/opaque_id" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "status_vocabulary": {
          "type": "array",
          "minItems": 9,
          "items": { "$ref": "#/$defs/status_vocabulary_entry" }
        },
        "surface_consumers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_consumer" },
          "uniqueItems": true
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/workflow_bundle_scorecard_row_record" }
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    }
  }
}
