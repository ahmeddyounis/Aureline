{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workflow/bundle_claim_threshold.schema.json",
  "title": "Aureline workflow-bundle stable-claim threshold verdict",
  "description": "Boundary schema for one bundle_claim_threshold_record frozen in docs/workflow/bundle_class_matrix.md. The record is a computed, exportable verdict that answers: may this bundle row imply launch-wedge coverage, benchmark-backed compatibility, or managed support readiness on Start Center, diagnostics, support export, and claim/badge surfaces? The record is derived from workflow-bundle manifest identity (bundle_class, source/status class, signer source/continuity/signature class, support class, packaging posture), evidence-link presence, and badge-freshness evaluation. It is intentionally separate from the bundle manifest: manifests declare identity and evidence links; this record declares the implication ceiling and the typed reasons when a stable claim is blocked or narrowed. Raw marketing copy, raw bundle bodies, raw signing material, raw URLs, raw local paths, and secret-bearing evidence never cross this boundary; the record carries stable ids, typed vocabulary, timestamps, and opaque refs only. Adding a new stable_claim_kind, gate_verdict, or gate_reason is additive-minor and bumps bundle_claim_threshold_schema_version; repurposing an existing reason or widening a gate is breaking and requires a governance decision row.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "bundle_id",
    "bundle_revision",
    "bundle_class",
    "bundle_source_class",
    "bundle_status_class",
    "bundle_signer_source_class",
    "signer_continuity_class",
    "signature_class",
    "support_class",
    "mirror_or_offline_packaging_posture",
    "policy_notice_ref",
    "evidence_badge_ids",
    "evaluated_at",
    "stable_claim_thresholds"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for this boundary."
    },
    "record_kind": {
      "type": "string",
      "const": "bundle_claim_threshold_record",
      "description": "Discriminator for the claim-threshold record."
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable workflow bundle id (opaque)."
    },
    "bundle_revision": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonic revision number for the bundle manifest."
    },
    "bundle_class": {
      "type": "string",
      "enum": [
        "launch_bundle",
        "imported_user_bundle",
        "org_approved_bundle",
        "design_partner_bundle",
        "local_draft_bundle"
      ]
    },
    "bundle_source_class": {
      "type": "string",
      "enum": [
        "certified",
        "managed_approved",
        "community",
        "imported",
        "local_draft"
      ]
    },
    "bundle_status_class": {
      "type": "string",
      "enum": [
        "certified_current",
        "certified_retest_pending",
        "managed_approved_current",
        "community_reviewed",
        "community_unreviewed",
        "imported_pending_review",
        "local_draft",
        "deprecated_or_archived",
        "retest_needed",
        "status_unknown"
      ]
    },
    "bundle_signer_source_class": {
      "type": "string",
      "enum": [
        "core_signing_root",
        "core_signing_root_via_mirror",
        "org_policy_signing_root",
        "org_mirror_signing_root",
        "community_channel_signature",
        "signed_offline_bundle_root",
        "repo_local_workspace_trust",
        "local_user_trust_only",
        "unsigned_user_review_required",
        "trust_source_unknown_review_required"
      ]
    },
    "signer_continuity_class": {
      "type": "string",
      "enum": [
        "continuous_with_previous_acquisition",
        "first_acquisition_no_prior_signer",
        "signer_changed_review_required",
        "signer_unknown_user_review_required",
        "signer_continuity_not_applicable"
      ]
    },
    "signature_class": {
      "type": "string",
      "enum": [
        "unsigned",
        "author_signature",
        "author_and_organization_signature",
        "organization_signature_only",
        "managed_only_channel_signature",
        "quarantined_no_signature"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "officially_supported",
        "community_supported",
        "experimental",
        "legacy_deprecated",
        "unsupported",
        "support_unknown"
      ]
    },
    "mirror_or_offline_packaging_posture": {
      "type": "string",
      "enum": [
        "live_origin_only",
        "live_or_mirror",
        "mirror_only",
        "signed_offline_bundle",
        "offline_no_bundle",
        "packaging_posture_unknown"
      ]
    },
    "policy_notice_ref": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ],
      "description": "Optional policy/availability narrowing notice ref carried by the bundle projection (see template contract policy notice vocabulary)."
    },
    "evidence_badge_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "badge.certified",
          "badge.managed_approved",
          "badge.community",
          "badge.imported",
          "badge.local_draft",
          "badge.retest_pending",
          "badge.deprecated",
          "badge.status_unknown",
          "badge.signed_offline_bundle",
          "badge.mirror_only",
          "badge.live_or_mirror",
          "badge.live_origin_only",
          "badge.offline_no_bundle"
        ]
      },
      "uniqueItems": true
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when the stable-claim thresholds were evaluated."
    },
    "stable_claim_thresholds": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stable_claim_threshold_entry" }
    }
  },
  "$defs": {
    "stable_claim_kind": {
      "type": "string",
      "enum": [
        "launch_wedge_coverage",
        "benchmark_backed_compatibility",
        "managed_support_readiness"
      ]
    },
    "gate_verdict": {
      "type": "string",
      "enum": ["allowed", "allowed_with_narrowing", "blocked"]
    },
    "gate_reason": {
      "type": "string",
      "enum": [
        "bundle_class_not_eligible",
        "source_not_certified",
        "status_not_current",
        "signer_boundary_not_eligible",
        "signer_continuity_or_signature_review_required",
        "evidence_missing_required_link",
        "evidence_stale_or_unknown",
        "missing_cutline_or_scoreboard_coverage",
        "support_class_not_official",
        "identity_or_entitlement_dependency_not_disclosed"
      ]
    },
    "stable_claim_threshold_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_claim_kind",
        "gate_verdict",
        "gate_reasons",
        "notes"
      ],
      "properties": {
        "stable_claim_kind": { "$ref": "#/$defs/stable_claim_kind" },
        "gate_verdict": { "$ref": "#/$defs/gate_verdict" },
        "gate_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/gate_reason" },
          "uniqueItems": true,
          "description": "Typed reasons that explain the verdict. Empty array is allowed only when gate_verdict is allowed."
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "description": "Short reviewer-facing note already scrubbed by the producer."
        }
      },
      "allOf": [
        {
          "description": "An allowed verdict must not carry blocking reasons.",
          "if": {
            "properties": { "gate_verdict": { "const": "allowed" } },
            "required": ["gate_verdict"]
          },
          "then": {
            "properties": {
              "gate_reasons": { "maxItems": 0 }
            }
          }
        },
        {
          "description": "A blocked verdict must cite at least one reason.",
          "if": {
            "properties": { "gate_verdict": { "const": "blocked" } },
            "required": ["gate_verdict"]
          },
          "then": {
            "properties": {
              "gate_reasons": { "minItems": 1 }
            }
          }
        }
      ]
    }
  }
}

