{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workflow/bundle_drift_packet.schema.json",
  "title": "Aureline workflow-bundle drift packet",
  "description": "Boundary schema for a support-safe packet that groups workflow-bundle drift rows, remove-bundle review refs, and visible resolve actions for Start Center, migration handoff, docs/help, support export, and CLI/headless consumers. The packet summarizes row refs already governed by schemas/workflow/bundle_drift_row.schema.json and preserves local overrides, missing artifact truth, bundle version drift, rollback refs, and template/scaffold mirrorability without embedding raw user files or opaque generation behavior.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "bundle_drift_packet_schema_version",
    "drift_packet_id",
    "minted_at",
    "scorecard_packet_ref",
    "drift_rows",
    "remove_reviews",
    "support_export",
    "policy_context",
    "redaction_class"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "record_kind": {
      "type": "string",
      "const": "workflow_bundle_drift_packet_record"
    },
    "bundle_drift_packet_schema_version": {
      "type": "integer",
      "const": 1
    },
    "drift_packet_id": { "$ref": "#/$defs/opaque_id" },
    "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
    "scorecard_packet_ref": { "$ref": "#/$defs/opaque_id" },
    "drift_rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/drift_row_summary" }
    },
    "remove_reviews": {
      "type": "array",
      "items": { "$ref": "#/$defs/remove_review_summary" }
    },
    "support_export": { "$ref": "#/$defs/support_export_binding" },
    "policy_context": { "$ref": "#/$defs/policy_context" },
    "redaction_class": { "$ref": "#/$defs/redaction_class" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "bundle_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bundle_id", "bundle_revision"],
      "properties": {
        "bundle_id": { "$ref": "#/$defs/opaque_id" },
        "bundle_revision": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "drift_state_class": {
      "type": "string",
      "enum": [
        "bundle_version_drift",
        "missing_artifact",
        "local_override",
        "unmanaged_addition",
        "mirror_mismatch",
        "evidence_stale",
        "signer_continuity_break",
        "policy_pinned_revision_lag",
        "drift_state_unknown"
      ]
    },
    "drift_axis": {
      "type": "string",
      "enum": [
        "extension_set",
        "profile_preset",
        "surface_preset",
        "task_recipe",
        "launch_recipe",
        "debug_recipe",
        "template_or_scaffold_ref",
        "docs_pack",
        "tour_pack",
        "glossary_pack",
        "migration_mapping",
        "certification_target",
        "evidence_link",
        "settings_or_token",
        "trust_or_permission",
        "compatibility_or_runtime",
        "side_effect"
      ]
    },
    "drift_subject_kind": {
      "type": "string",
      "enum": [
        "bundle_component_record",
        "settings_or_token_path",
        "trust_or_permission_state",
        "compatibility_state",
        "side_effect_envelope_entry",
        "bundle_revision_pin",
        "evidence_link_record"
      ]
    },
    "asset_ownership_class": {
      "type": "string",
      "enum": [
        "bundle_owned",
        "user_owned",
        "shared_user_overlay_on_bundle",
        "mixed_unknown_provenance"
      ]
    },
    "claim_narrowing_class": {
      "type": "string",
      "enum": [
        "no_narrowing_informational",
        "narrows_support_class_one_rung",
        "narrows_certification_target_pending_retest",
        "breaks_certification_target_recall",
        "narrows_to_imported_pending_review",
        "pending_review_narrowing_unknown"
      ]
    },
    "visible_lifecycle_action": {
      "type": "string",
      "enum": [
        "apply",
        "compare",
        "keep_local",
        "adopt_bundle",
        "remove_bundle",
        "rebase_to_bundle",
        "ignore_this_drift"
      ]
    },
    "safe_to_remove_class": {
      "type": "string",
      "enum": [
        "safe_to_remove_no_user_data",
        "safe_to_remove_user_overlay_preserved",
        "review_required_user_data_co_resident",
        "not_safe_to_remove_user_owned",
        "not_safe_to_remove_policy_locked"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "$ref": "#/$defs/opaque_id" },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted"]
        },
        "execution_context_id": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "drift_row_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle",
        "drift_row_ref",
        "row_schema_ref",
        "drift_state_class",
        "drift_axis",
        "drift_subject_kind",
        "asset_ownership_class",
        "claim_narrowing_class",
        "visible_actions",
        "preserves_local_artifacts",
        "support_export_ref"
      ],
      "properties": {
        "bundle": { "$ref": "#/$defs/bundle_identity" },
        "drift_row_ref": { "$ref": "#/$defs/opaque_id" },
        "row_schema_ref": { "$ref": "#/$defs/opaque_id" },
        "drift_state_class": { "$ref": "#/$defs/drift_state_class" },
        "drift_axis": { "$ref": "#/$defs/drift_axis" },
        "drift_subject_kind": { "$ref": "#/$defs/drift_subject_kind" },
        "asset_ownership_class": { "$ref": "#/$defs/asset_ownership_class" },
        "claim_narrowing_class": { "$ref": "#/$defs/claim_narrowing_class" },
        "visible_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/visible_lifecycle_action" },
          "uniqueItems": true
        },
        "destination_preview_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "preserves_local_artifacts": { "type": "boolean", "const": true },
        "support_export_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "remove_review_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle",
        "remove_bundle_review_ref",
        "rollback_checkpoint_linkage_ref",
        "removable_asset_refs",
        "retained_local_override_refs",
        "safe_to_remove_classes",
        "raw_user_content_exported",
        "support_export_ref"
      ],
      "properties": {
        "bundle": { "$ref": "#/$defs/bundle_identity" },
        "remove_bundle_review_ref": { "$ref": "#/$defs/opaque_id" },
        "rollback_checkpoint_linkage_ref": { "$ref": "#/$defs/opaque_id" },
        "removable_asset_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "retained_local_override_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "safe_to_remove_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/safe_to_remove_class" },
          "uniqueItems": true
        },
        "raw_user_content_exported": { "type": "boolean", "const": false },
        "support_export_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "support_export_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_packet_refs",
        "raw_content_export_allowed",
        "redaction_class"
      ],
      "properties": {
        "export_packet_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "raw_content_export_allowed": { "type": "boolean", "const": false },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    }
  }
}
