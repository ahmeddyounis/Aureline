{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/workflow/bundle_certification_sheet.schema.json",
  "title": "Aureline workflow-bundle certification sheet artifact",
  "description": "Boundary schema for one bundle_certification_sheet_record as frozen in docs/workflow/bundle_lifecycle_visibility_contract.md. The certification sheet is the reviewer-facing artifact that substantiates strong workflow-bundle claims by binding bundle identity, certification target(s), evidence age, platform/toolchain matrix, benchmark pack references, owner attribution, support class, and lifecycle/retest/successor posture into one exportable record. It is consumed by Start Center and bundle detail surfaces (via certification_sheet_refs), support export packets, claim-publication tooling, and offline review flows. Raw proof payloads, raw logs, raw command lines, raw absolute paths, raw repository URLs, raw secrets, and raw user content never cross this boundary; the record carries stable ids, typed vocabulary, timestamps, and opaque refs only. Adding a new enum value or an optional property is additive-minor and bumps bundle_certification_sheet_schema_version; repurposing an existing value is breaking and requires a governance decision row.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_certification_sheet_schema_version",
    "record_kind",
    "certification_sheet_id",
    "bundle_id",
    "bundle_revision",
    "bundle_class",
    "bundle_source_class",
    "bundle_status_class",
    "support_class",
    "owner_dri",
    "certification_targets",
    "evidence_age_class",
    "retest_needed_posture",
    "lifecycle_state_class",
    "successor_recommendation",
    "platform_toolchain_matrix",
    "evidence_link_refs",
    "issued_at"
  ],
  "properties": {
    "bundle_certification_sheet_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this boundary. Bumped on additive-minor changes."
    },
    "record_kind": {
      "type": "string",
      "const": "bundle_certification_sheet_record",
      "description": "Discriminator for the certification-sheet record."
    },
    "certification_sheet_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque id for the sheet artifact. Typically matches the evidence_ref used by evidence_link_kind=certification_sheet and the manifest's certification_sheet_refs[]."
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable workflow bundle id (opaque)."
    },
    "bundle_revision": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonic revision number for the bundle manifest."
    },
    "bundle_class": { "$ref": "#/$defs/bundle_class" },
    "bundle_source_class": { "$ref": "#/$defs/bundle_source_class" },
    "bundle_status_class": { "$ref": "#/$defs/bundle_status_class" },
    "support_class": { "$ref": "#/$defs/support_class" },
    "owner_dri": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Owner DRI for the certified target or bundle row. Resolved by downstream tooling through artifacts/governance/ownership_matrix.yaml."
    },
    "certification_targets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/certification_target" },
      "description": "What the certification asserts: at least one archetype ref and/or reference workspace id."
    },
    "evidence_age_class": { "$ref": "#/$defs/evidence_age_class" },
    "retest_needed_posture": { "$ref": "#/$defs/retest_needed_posture" },
    "lifecycle_state_class": { "$ref": "#/$defs/lifecycle_state_class" },
    "successor_recommendation": { "$ref": "#/$defs/successor_recommendation" },
    "benchmark_pack_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_id" },
      "uniqueItems": true,
      "description": "Optional benchmark pack refs that the certification cites (performance, latency, throughput)."
    },
    "platform_toolchain_matrix": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/platform_toolchain_entry" },
      "description": "Supported platform/toolchain envelope substantiated by the evidence links."
    },
    "evidence_link_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence_link_ref" },
      "description": "Opaque refs binding the certification sheet to underlying evidence packets (scoreboard, benchmark, compatibility report, docs version match, known limits)."
    },
    "issued_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when the sheet was minted."
    },
    "notes": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "description": "Reviewer-facing notes already scrubbed by the producer. Raw URLs, paths, secrets, and proof payloads never appear."
    }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "bundle_class": {
      "type": "string",
      "enum": [
        "launch_bundle",
        "imported_user_bundle",
        "org_approved_bundle",
        "design_partner_bundle",
        "local_draft_bundle"
      ]
    },
    "bundle_source_class": {
      "type": "string",
      "enum": [
        "certified",
        "managed_approved",
        "community",
        "imported",
        "local_draft"
      ]
    },
    "bundle_status_class": {
      "type": "string",
      "enum": [
        "certified_current",
        "certified_retest_pending",
        "managed_approved_current",
        "community_reviewed",
        "community_unreviewed",
        "imported_pending_review",
        "local_draft",
        "deprecated_or_archived",
        "retest_needed",
        "status_unknown"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "officially_supported",
        "community_supported",
        "experimental",
        "legacy_deprecated",
        "unsupported",
        "support_unknown"
      ]
    },
    "lifecycle_state_class": {
      "type": "string",
      "enum": [
        "active_supported",
        "soft_deprecated_with_successor",
        "hard_deprecated_remove_recommended",
        "retest_needed",
        "evidence_aged",
        "removed_unavailable",
        "rollback_recommended",
        "lifecycle_unknown"
      ]
    },
    "evidence_age_class": {
      "type": "string",
      "enum": [
        "fresh_current",
        "aging_within_window",
        "stale_past_window",
        "age_unknown"
      ]
    },
    "retest_needed_posture": {
      "type": "string",
      "enum": [
        "not_required",
        "retest_recommended",
        "retest_required",
        "retest_blocked"
      ]
    },
    "successor_recommendation_class": {
      "type": "string",
      "enum": [
        "no_successor",
        "successor_recommended_same_class",
        "successor_recommended_different_class",
        "successor_recommended_first_party_native",
        "successor_unknown"
      ]
    },
    "successor_recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["successor_recommendation_class", "successor_summary_ref"],
      "properties": {
        "successor_recommendation_class": { "$ref": "#/$defs/successor_recommendation_class" },
        "successor_bundle_id": { "$ref": "#/$defs/nullable_opaque_id" },
        "successor_bundle_revision": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 1 }
          ]
        },
        "successor_summary_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "decision_row_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      },
      "allOf": [
        {
          "description": "A no_successor or successor_unknown recommendation must not cite a successor identity.",
          "if": {
            "properties": {
              "successor_recommendation_class": {
                "enum": ["no_successor", "successor_unknown"]
              }
            },
            "required": ["successor_recommendation_class"]
          },
          "then": {
            "properties": {
              "successor_bundle_id": { "type": "null" },
              "successor_bundle_revision": { "type": "null" },
              "decision_row_ref": { "type": "null" }
            }
          }
        },
        {
          "description": "Successor-recommended classes cite a stable successor id and revision.",
          "if": {
            "properties": {
              "successor_recommendation_class": {
                "enum": [
                  "successor_recommended_same_class",
                  "successor_recommended_different_class",
                  "successor_recommended_first_party_native"
                ]
              }
            },
            "required": ["successor_recommendation_class"]
          },
          "then": {
            "required": ["successor_bundle_id", "successor_bundle_revision"],
            "properties": {
              "successor_bundle_id": { "$ref": "#/$defs/opaque_id" },
              "successor_bundle_revision": { "type": "integer", "minimum": 1 }
            }
          }
        },
        {
          "description": "First-party-native successors and cross-class successors cite a decision row.",
          "if": {
            "properties": {
              "successor_recommendation_class": {
                "enum": [
                  "successor_recommended_different_class",
                  "successor_recommended_first_party_native"
                ]
              }
            },
            "required": ["successor_recommendation_class"]
          },
          "then": {
            "required": ["decision_row_ref"],
            "properties": {
              "decision_row_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        }
      ]
    },
    "certification_target_kind": {
      "type": "string",
      "enum": ["archetype_ref", "reference_workspace_id"]
    },
    "certification_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["certification_target_kind"],
      "properties": {
        "certification_target_kind": { "$ref": "#/$defs/certification_target_kind" },
        "archetype_row_id": { "$ref": "#/$defs/nullable_opaque_id" },
        "archetype_revision": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 1 }
          ]
        },
        "reference_workspace_id": { "$ref": "#/$defs/nullable_opaque_id" },
        "summary_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      },
      "allOf": [
        {
          "description": "An archetype_ref target must carry archetype_row_id and archetype_revision.",
          "if": {
            "properties": { "certification_target_kind": { "const": "archetype_ref" } },
            "required": ["certification_target_kind"]
          },
          "then": {
            "required": ["archetype_row_id", "archetype_revision"],
            "properties": {
              "archetype_row_id": { "$ref": "#/$defs/opaque_id" },
              "archetype_revision": { "type": "integer", "minimum": 1 }
            }
          }
        },
        {
          "description": "A reference_workspace_id target must carry reference_workspace_id.",
          "if": {
            "properties": { "certification_target_kind": { "const": "reference_workspace_id" } },
            "required": ["certification_target_kind"]
          },
          "then": {
            "required": ["reference_workspace_id"],
            "properties": {
              "reference_workspace_id": { "$ref": "#/$defs/opaque_id" }
            }
          }
        }
      ]
    },
    "os_family_class": {
      "type": "string",
      "enum": ["macos", "windows", "linux", "platform_native_any", "unknown_offline"]
    },
    "architecture_class": {
      "type": "string",
      "enum": ["x86_64", "aarch64", "universal_binary", "platform_native_any"]
    },
    "mode_class": {
      "type": "string",
      "enum": ["local_desktop", "remote_agent", "mixed_or_unknown"]
    },
    "platform_toolchain_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os_family_class", "architecture_class", "mode_class", "toolchain_label"],
      "properties": {
        "os_family_class": { "$ref": "#/$defs/os_family_class" },
        "architecture_class": { "$ref": "#/$defs/architecture_class" },
        "mode_class": { "$ref": "#/$defs/mode_class" },
        "toolchain_label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Short label for the toolchain tuple asserted by the certification (for example, 'Rust stable + cargo', 'Node 22 + pnpm')."
        },
        "toolchain_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    },
    "evidence_link_kind": {
      "type": "string",
      "enum": [
        "certification_sheet",
        "compatibility_report",
        "benchmark_packet",
        "migration_note",
        "docs_version_match",
        "support_export_reference",
        "known_limit_note",
        "scoreboard_packet",
        "claim_manifest_row",
        "decision_row_ref"
      ]
    },
    "evidence_link_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_link_kind", "evidence_ref"],
      "properties": {
        "evidence_link_kind": { "$ref": "#/$defs/evidence_link_kind" },
        "evidence_ref": { "$ref": "#/$defs/opaque_id" },
        "evidence_summary_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "captured_at": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "format": "date-time" }
          ]
        },
        "stale_after": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Optional ISO-8601 duration indicating how long the referenced evidence is considered fresh (cadence/window)."
        }
      }
    }
  }
}
