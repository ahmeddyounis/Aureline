{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/infra/relation-graph-incident-support-parity.schema.json",
  "title": "Infrastructure relation-graph incident/support parity packet",
  "description": "Schema for the canonical M5 infrastructure parity packet that preserves exact relation-graph selections for incident packets, support exports, and proof corpora. The packet embeds the checked source-intelligence object packet, reopen-safe graph selections, stale-live overlay posture, connector-skew and locality mismatch labels, control-plane handoff lineage, and required wrong-target / stale-live / permission / skew drills. Raw provider payloads, raw credentials, browser cookies, and hidden mutation instructions are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "captured_at",
    "source_intelligence_packet_ref",
    "overlay_continuity_packet_ref",
    "source_object_packet",
    "relation_graph_selections",
    "handoff_lineage",
    "consumer_bindings",
    "drill_records",
    "support_summary"
  ],
  "properties": {
    "record_kind": {
      "const": "infra_relation_graph_incident_support_parity_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_intelligence_packet_ref": {
      "const": "infra_source_intelligence_object_packet"
    },
    "overlay_continuity_packet_ref": {
      "const": "infra_provider_overlay_and_vendor_console_handoff_continuity_packet"
    },
    "source_object_packet": {
      "$ref": "source-intelligence-object-packet.schema.json"
    },
    "relation_graph_selections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/relation_graph_selection"
      }
    },
    "handoff_lineage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/handoff_lineage"
      }
    },
    "consumer_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/consumer_binding"
      }
    },
    "drill_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/drill_record"
      }
    },
    "support_summary": {
      "$ref": "#/$defs/reviewable_sentence"
    }
  },
  "$defs": {
    "non_empty": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    },
    "family": {
      "type": "string",
      "enum": [
        "terraform_hcl",
        "kubernetes_helm",
        "devcontainer",
        "ci_environment",
        "policy_manifest"
      ]
    },
    "truth_layer": {
      "type": "string",
      "enum": [
        "authored_desired",
        "rendered_expanded",
        "planned_validated",
        "observed_live",
        "provider_overlay"
      ]
    },
    "freshness_label": {
      "type": "string",
      "enum": [
        "live",
        "current_snapshot",
        "cached_within_floor",
        "stale",
        "partial",
        "offline",
        "permission_limited",
        "unavailable"
      ]
    },
    "action_posture": {
      "type": "string",
      "enum": [
        "inspect_only",
        "dry_run_only",
        "step_up_required",
        "write_approved",
        "blocked",
        "not_claimed",
        "handoff_only"
      ]
    },
    "surface": {
      "type": "string",
      "enum": [
        "incident_packet",
        "support_export",
        "proof_corpus"
      ]
    },
    "stale_live_overlay_state": {
      "type": "string",
      "enum": [
        "live_current",
        "live_with_stale_overlay",
        "permission_limited_overlay",
        "overlay_unavailable"
      ]
    },
    "connector_skew_state": {
      "type": "string",
      "enum": [
        "matched",
        "retry_required",
        "unsupported_skew"
      ]
    },
    "execution_plane": {
      "type": "string",
      "enum": [
        "local",
        "remote",
        "managed"
      ]
    },
    "locality_mismatch_state": {
      "type": "string",
      "enum": [
        "matched",
        "local_vs_remote",
        "remote_vs_managed",
        "local_vs_managed"
      ]
    },
    "handoff_reason": {
      "type": "string",
      "enum": [
        "provider_overlay_inspection",
        "mutation_requires_vendor_console",
        "permission_scope_gap",
        "incident_runbook_continuation",
        "preview_or_route_continuation",
        "source_or_ownership_trace"
      ]
    },
    "return_surface": {
      "type": "string",
      "enum": [
        "code_breadcrumb",
        "incident_workspace",
        "preview_route",
        "route_explorer",
        "infrastructure_panel"
      ]
    },
    "drill_class": {
      "type": "string",
      "enum": [
        "wrong_target",
        "stale_live_overlay",
        "missing_permission",
        "connector_skew",
        "locality_mismatch"
      ]
    },
    "drill_resolution": {
      "type": "string",
      "enum": [
        "blocked",
        "downgraded",
        "reopenable"
      ]
    },
    "handoff_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lineage_id",
        "context_ref",
        "handoff_ref",
        "stable_target_ref",
        "handoff_reason",
        "return_surface",
        "return_anchor_ref",
        "control_plane_boundary_visible",
        "support_summary"
      ],
      "properties": {
        "lineage_id": {
          "$ref": "#/$defs/non_empty"
        },
        "context_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "handoff_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "stable_target_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "handoff_reason": {
          "$ref": "#/$defs/handoff_reason"
        },
        "return_surface": {
          "$ref": "#/$defs/return_surface"
        },
        "return_anchor_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "control_plane_boundary_visible": {
          "type": "boolean",
          "const": true
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "relation_graph_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selection_id",
        "family",
        "context_ref",
        "primary_object_ref",
        "root_object_refs",
        "relation_refs",
        "visible_truth_layers",
        "freshness_labels",
        "authority_postures",
        "stale_live_overlay_state",
        "connector_skew_state",
        "execution_plane",
        "locality_mismatch_state",
        "handoff_lineage_refs",
        "relation_set_signature",
        "support_summary"
      ],
      "properties": {
        "selection_id": {
          "$ref": "#/$defs/non_empty"
        },
        "family": {
          "$ref": "#/$defs/family"
        },
        "context_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "primary_object_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "root_object_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "relation_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "visible_truth_layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/truth_layer"
          }
        },
        "freshness_labels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/freshness_label"
          }
        },
        "authority_postures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/action_posture"
          }
        },
        "stale_live_overlay_state": {
          "$ref": "#/$defs/stale_live_overlay_state"
        },
        "connector_skew_state": {
          "$ref": "#/$defs/connector_skew_state"
        },
        "execution_plane": {
          "$ref": "#/$defs/execution_plane"
        },
        "locality_mismatch_state": {
          "$ref": "#/$defs/locality_mismatch_state"
        },
        "handoff_lineage_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "relation_set_signature": {
          "$ref": "#/$defs/non_empty"
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "consumer_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "surface",
        "selection_ref",
        "reopen_context_ref",
        "reopen_command_id_ref",
        "exact_reopen_only",
        "preserves_target_identity",
        "preserves_relation_set",
        "preserves_truth_layers",
        "preserves_stale_live_overlay_state",
        "preserves_connector_skew_state",
        "preserves_locality_mismatch_state",
        "preserves_handoff_lineage",
        "preserves_permission_limited_state",
        "uses_shared_packet",
        "export_safe_only",
        "support_summary"
      ],
      "properties": {
        "binding_id": {
          "$ref": "#/$defs/non_empty"
        },
        "surface": {
          "$ref": "#/$defs/surface"
        },
        "selection_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "reopen_context_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "reopen_command_id_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "exact_reopen_only": {
          "type": "boolean",
          "const": true
        },
        "preserves_target_identity": {
          "type": "boolean",
          "const": true
        },
        "preserves_relation_set": {
          "type": "boolean",
          "const": true
        },
        "preserves_truth_layers": {
          "type": "boolean",
          "const": true
        },
        "preserves_stale_live_overlay_state": {
          "type": "boolean",
          "const": true
        },
        "preserves_connector_skew_state": {
          "type": "boolean",
          "const": true
        },
        "preserves_locality_mismatch_state": {
          "type": "boolean",
          "const": true
        },
        "preserves_handoff_lineage": {
          "type": "boolean",
          "const": true
        },
        "preserves_permission_limited_state": {
          "type": "boolean"
        },
        "uses_shared_packet": {
          "type": "boolean",
          "const": true
        },
        "export_safe_only": {
          "type": "boolean",
          "const": true
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "drill_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drill_id",
        "family",
        "drill_class",
        "selection_ref",
        "context_ref",
        "connector_skew_state",
        "locality_mismatch_state",
        "stale_live_overlay_state",
        "visible_freshness_labels",
        "resolution",
        "proof_packet_included",
        "support_summary"
      ],
      "properties": {
        "drill_id": {
          "$ref": "#/$defs/non_empty"
        },
        "family": {
          "$ref": "#/$defs/family"
        },
        "drill_class": {
          "$ref": "#/$defs/drill_class"
        },
        "selection_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "context_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "connector_skew_state": {
          "$ref": "#/$defs/connector_skew_state"
        },
        "locality_mismatch_state": {
          "$ref": "#/$defs/locality_mismatch_state"
        },
        "stale_live_overlay_state": {
          "$ref": "#/$defs/stale_live_overlay_state"
        },
        "visible_freshness_labels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/freshness_label"
          }
        },
        "resolution": {
          "$ref": "#/$defs/drill_resolution"
        },
        "proof_packet_included": {
          "type": "boolean",
          "const": true
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    }
  }
}
