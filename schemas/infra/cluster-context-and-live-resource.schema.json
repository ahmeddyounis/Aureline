{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/infra/cluster-context-and-live-resource.schema.json",
  "title": "Infrastructure cluster-context and live-resource qualification packet",
  "description": "Schema for packets that keep Terraform, Kubernetes, and incident-adjacent surfaces explicit about target context, truth mode, and console handoff. Packets carry a shared environment context, per-surface context strips, separate desired/rendered/plan/live/provider-overlay truth-mode views, mutating-action gates, and provider-console handoff truth. Raw credentials, raw kubeconfig bodies, raw provider responses, private endpoint URLs, and browser cookies are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "captured_at",
    "environment_context",
    "surface_projections",
    "action_gates",
    "console_handoffs",
    "support_summary"
  ],
  "properties": {
    "record_kind": { "const": "infra_cluster_context_and_live_resource_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty" },
    "captured_at": { "type": "string", "format": "date-time" },
    "environment_context": { "$ref": "#/$defs/environment_context" },
    "surface_projections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surface_projection" }
    },
    "action_gates": {
      "type": "array",
      "items": { "$ref": "#/$defs/action_gate" }
    },
    "console_handoffs": {
      "type": "array",
      "items": { "$ref": "#/$defs/console_handoff_truth" }
    },
    "support_summary": { "$ref": "#/$defs/reviewable_sentence" }
  },
  "$defs": {
    "non_empty": { "type": "string", "minLength": 1 },
    "nullable_non_empty": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/non_empty" }
      ]
    },
    "reviewable_sentence": { "type": "string", "minLength": 1, "maxLength": 600 },
    "connector_class": {
      "type": "string",
      "enum": [
        "static-file-only",
        "cli-mediated",
        "agent-mediated-live",
        "provider-console-overlay"
      ]
    },
    "freshness_label": {
      "type": "string",
      "enum": [
        "live",
        "current_snapshot",
        "cached_within_floor",
        "stale",
        "partial",
        "offline",
        "permission_limited",
        "unavailable"
      ]
    },
    "action_kind": {
      "type": "string",
      "enum": [
        "inspect",
        "dry_run",
        "mutate",
        "port_forward",
        "shell_attach",
        "exec",
        "container_exec",
        "browser_console_launch"
      ]
    },
    "ops_tool_kind": {
      "type": "string",
      "enum": ["terraform", "kubernetes", "incident_adjacent"]
    },
    "ops_surface": {
      "type": "string",
      "enum": [
        "terraform_plan_review",
        "kubernetes_resource_view",
        "cluster_live_resource",
        "incident_runbook_step",
        "ai_action_sheet",
        "cli",
        "browser_console_handoff",
        "support_runbook_export"
      ]
    },
    "truth_mode": {
      "type": "string",
      "enum": ["desired", "rendered", "plan", "live", "provider_overlay"]
    },
    "environment_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_id",
        "provider",
        "account_subscription_project",
        "cluster",
        "namespace",
        "region_zone",
        "tenant",
        "workspace_root",
        "branch_worktree_or_commit",
        "execution_context_profile",
        "toolchain_cli_identity",
        "credential_handle_class",
        "issuance_source",
        "expiry",
        "write_scope",
        "observed_at",
        "completeness",
        "ambient_context_prohibited",
        "high_risk"
      ],
      "properties": {
        "context_id": { "$ref": "#/$defs/non_empty" },
        "provider": { "$ref": "#/$defs/non_empty" },
        "account_subscription_project": { "$ref": "#/$defs/non_empty" },
        "cluster": { "$ref": "#/$defs/nullable_non_empty" },
        "namespace": { "$ref": "#/$defs/nullable_non_empty" },
        "region_zone": { "$ref": "#/$defs/nullable_non_empty" },
        "tenant": { "$ref": "#/$defs/nullable_non_empty" },
        "workspace_root": { "$ref": "#/$defs/non_empty" },
        "branch_worktree_or_commit": { "$ref": "#/$defs/non_empty" },
        "execution_context_profile": { "$ref": "#/$defs/non_empty" },
        "toolchain_cli_identity": { "$ref": "#/$defs/non_empty" },
        "credential_handle_class": { "$ref": "#/$defs/non_empty" },
        "issuance_source": { "$ref": "#/$defs/non_empty" },
        "expiry": { "$ref": "#/$defs/nullable_non_empty" },
        "write_scope": { "$ref": "#/$defs/non_empty" },
        "observed_at": { "type": "string", "format": "date-time" },
        "completeness": { "type": "string", "enum": ["complete", "partial_acknowledged", "incomplete"] },
        "ambient_context_prohibited": { "type": "boolean", "const": true },
        "high_risk": { "type": "boolean" }
      }
    },
    "context_strip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strip_id",
        "context_ref",
        "provider",
        "account_subscription",
        "project",
        "cluster",
        "namespace",
        "region",
        "tenant",
        "execution_origin",
        "credential_class"
      ],
      "properties": {
        "strip_id": { "$ref": "#/$defs/non_empty" },
        "context_ref": { "$ref": "#/$defs/non_empty" },
        "provider": { "$ref": "#/$defs/non_empty" },
        "account_subscription": { "$ref": "#/$defs/non_empty" },
        "project": { "$ref": "#/$defs/nullable_non_empty" },
        "cluster": { "$ref": "#/$defs/nullable_non_empty" },
        "namespace": { "$ref": "#/$defs/nullable_non_empty" },
        "region": { "$ref": "#/$defs/nullable_non_empty" },
        "tenant": { "$ref": "#/$defs/nullable_non_empty" },
        "execution_origin": { "$ref": "#/$defs/non_empty" },
        "credential_class": { "$ref": "#/$defs/non_empty" }
      }
    },
    "truth_mode_view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truth_mode",
        "source_label",
        "source_ref",
        "freshness",
        "observed_at",
        "blended_with_other_modes",
        "mutation_capable"
      ],
      "properties": {
        "truth_mode": { "$ref": "#/$defs/truth_mode" },
        "source_label": { "$ref": "#/$defs/non_empty" },
        "source_ref": { "$ref": "#/$defs/non_empty" },
        "freshness": { "$ref": "#/$defs/freshness_label" },
        "observed_at": { "$ref": "#/$defs/nullable_non_empty" },
        "blended_with_other_modes": { "type": "boolean" },
        "mutation_capable": { "type": "boolean" }
      }
    },
    "surface_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "tool_kind",
        "context_strip",
        "truth_mode_views",
        "preserves_truth_vocabulary",
        "uses_shared_packet"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/ops_surface" },
        "tool_kind": { "$ref": "#/$defs/ops_tool_kind" },
        "context_strip": { "$ref": "#/$defs/context_strip" },
        "truth_mode_views": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/truth_mode_view" }
        },
        "preserves_truth_vocabulary": { "type": "boolean" },
        "uses_shared_packet": { "type": "boolean" }
      }
    },
    "action_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "surface",
        "tool_kind",
        "action_kind",
        "context_ref",
        "requires_reviewed_preview",
        "preview_ref",
        "target_preview_ref",
        "source_of_truth_posture",
        "handoff_ref",
        "approved"
      ],
      "properties": {
        "gate_id": { "$ref": "#/$defs/non_empty" },
        "surface": { "$ref": "#/$defs/ops_surface" },
        "tool_kind": { "$ref": "#/$defs/ops_tool_kind" },
        "action_kind": { "$ref": "#/$defs/action_kind" },
        "context_ref": { "$ref": "#/$defs/non_empty" },
        "requires_reviewed_preview": { "type": "boolean" },
        "preview_ref": { "$ref": "#/$defs/nullable_non_empty" },
        "target_preview_ref": { "$ref": "#/$defs/nullable_non_empty" },
        "source_of_truth_posture": { "$ref": "#/$defs/non_empty" },
        "handoff_ref": { "$ref": "#/$defs/nullable_non_empty" },
        "approved": { "type": "boolean" }
      }
    },
    "console_handoff_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "tool_kind", "aureline_is_authoritative", "handoff"],
      "properties": {
        "surface": { "$ref": "#/$defs/ops_surface" },
        "tool_kind": { "$ref": "#/$defs/ops_tool_kind" },
        "aureline_is_authoritative": { "type": "boolean" },
        "handoff": { "$ref": "#/$defs/control_plane_handoff" }
      }
    },
    "control_plane_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff_id",
        "destination",
        "target_context_ref",
        "connector_class",
        "explicit_handoff_destination",
        "not_substitute_truth",
        "return_or_revocation_path",
        "audit_ref"
      ],
      "properties": {
        "handoff_id": { "$ref": "#/$defs/non_empty" },
        "destination": { "$ref": "#/$defs/non_empty" },
        "target_context_ref": { "$ref": "#/$defs/non_empty" },
        "connector_class": { "$ref": "#/$defs/connector_class" },
        "explicit_handoff_destination": { "type": "boolean", "const": true },
        "not_substitute_truth": { "type": "boolean", "const": true },
        "return_or_revocation_path": { "$ref": "#/$defs/non_empty" },
        "audit_ref": { "$ref": "#/$defs/non_empty" }
      }
    }
  }
}
