{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/infra/source-intelligence-and-resource-relationships.schema.json",
  "title": "Infrastructure source-intelligence and resource-relationship matrix packet",
  "description": "Schema for the canonical M5 matrix that freezes Terraform/HCL, Kubernetes/Helm, devcontainer, CI/environment, and policy-manifest truth layers, relation-edge classes, target-context requirements, live-access prerequisites, console-handoff posture, export fidelity, and explicit file-only or inspect-only or handoff-only downgrade behavior. Raw provider payloads, raw credentials, raw kubeconfig bodies, browser cookies, and hidden mutation authority are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "captured_at",
    "matrix_rows",
    "support_summary"
  ],
  "properties": {
    "record_kind": {
      "const": "infra_source_intelligence_and_resource_relationship_matrix_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "matrix_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/family_row"
      }
    },
    "support_summary": {
      "$ref": "#/$defs/reviewable_sentence"
    }
  },
  "$defs": {
    "non_empty": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    },
    "family": {
      "type": "string",
      "enum": [
        "terraform_hcl",
        "kubernetes_helm",
        "devcontainer",
        "ci_environment",
        "policy_manifest"
      ]
    },
    "truth_layer": {
      "type": "string",
      "enum": [
        "authored_desired",
        "rendered_expanded",
        "planned_validated",
        "observed_live",
        "provider_overlay"
      ]
    },
    "relation_edge_class": {
      "type": "string",
      "enum": [
        "source_of_render",
        "plan_for",
        "live_counterpart_of",
        "applied_by",
        "owned_by",
        "impacts",
        "runbook_reference",
        "review_anchor",
        "provider_overlay_of"
      ]
    },
    "target_context_field": {
      "type": "string",
      "enum": [
        "provider",
        "account_subscription_project",
        "environment_selector",
        "namespace_or_scope",
        "region_zone",
        "tenant",
        "workspace_revision",
        "execution_origin",
        "execution_context_profile",
        "tool_identity",
        "credential_class",
        "freshness_timestamp"
      ]
    },
    "target_context_requirement_class": {
      "type": "string",
      "enum": [
        "repo_scoped",
        "render_scoped",
        "planned_target_resolved",
        "live_target_resolved",
        "overlay_target_resolved"
      ]
    },
    "live_access_prerequisite": {
      "type": "string",
      "enum": [
        "no_live_access_required",
        "render_tool_resolved",
        "plan_or_validator_resolved",
        "scoped_read_only_live_access",
        "provider_overlay_session"
      ]
    },
    "console_handoff_posture": {
      "type": "string",
      "enum": [
        "no_console_handoff",
        "explicit_optional_boundary",
        "explicit_mutation_boundary",
        "overlay_only_boundary"
      ]
    },
    "export_fidelity": {
      "type": "string",
      "enum": [
        "source_only_metadata",
        "derived_relationship_metadata",
        "target_scoped_snapshot",
        "handoff_reference_only"
      ]
    },
    "qualification_posture": {
      "type": "string",
      "enum": [
        "file_only",
        "inspect_only",
        "handoff_only"
      ]
    },
    "target_context_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_class",
        "required_fields",
        "stable_across_surfaces",
        "ambient_context_forbidden"
      ],
      "properties": {
        "requirement_class": {
          "$ref": "#/$defs/target_context_requirement_class"
        },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/target_context_field"
          }
        },
        "stable_across_surfaces": {
          "type": "boolean"
        },
        "ambient_context_forbidden": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "truth_layer_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truth_layer",
        "target_context_requirement",
        "live_access_prerequisite",
        "console_handoff_posture",
        "export_fidelity",
        "file_intelligence_posture",
        "summary"
      ],
      "properties": {
        "truth_layer": {
          "$ref": "#/$defs/truth_layer"
        },
        "target_context_requirement": {
          "$ref": "#/$defs/target_context_requirement"
        },
        "live_access_prerequisite": {
          "$ref": "#/$defs/live_access_prerequisite"
        },
        "console_handoff_posture": {
          "$ref": "#/$defs/console_handoff_posture"
        },
        "export_fidelity": {
          "$ref": "#/$defs/export_fidelity"
        },
        "file_intelligence_posture": {
          "$ref": "#/$defs/qualification_posture"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "relation_edge_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_class",
        "source_truth_layers",
        "target_truth_layers",
        "summary"
      ],
      "properties": {
        "edge_class": {
          "$ref": "#/$defs/relation_edge_class"
        },
        "source_truth_layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/truth_layer"
          }
        },
        "target_truth_layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/truth_layer"
          }
        },
        "summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "downgrade_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "posture",
        "preserved_truth_layers",
        "preserved_relation_edges",
        "export_fidelity",
        "summary"
      ],
      "properties": {
        "posture": {
          "$ref": "#/$defs/qualification_posture"
        },
        "preserved_truth_layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/truth_layer"
          }
        },
        "preserved_relation_edges": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/relation_edge_class"
          }
        },
        "export_fidelity": {
          "$ref": "#/$defs/export_fidelity"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "family_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "claimed_artifact_families",
        "truth_layer_bindings",
        "relation_edges",
        "downgrade_profiles",
        "support_summary"
      ],
      "properties": {
        "family": {
          "$ref": "#/$defs/family"
        },
        "claimed_artifact_families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "truth_layer_bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/truth_layer_binding"
          }
        },
        "relation_edges": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/relation_edge_binding"
          }
        },
        "downgrade_profiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/downgrade_profile"
          }
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    }
  }
}
