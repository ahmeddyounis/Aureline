{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/infra/infrastructure-surface-qualification.schema.json",
  "title": "Infrastructure surface qualification packet",
  "description": "Schema for the canonical infrastructure qualification packet that binds claimed source-intelligence, live-counterpart, plan-viewer, live-resource-context, provider-overlay, incident/support parity, and public evidence-index surface families to exact proof classes, auto-narrowing posture, and shared docs/help/support/public-truth consumer bindings. Raw provider payloads, raw credentials, browser cookies, raw kubeconfig bodies, private endpoint URLs, and hidden mutation authority are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "certification_label",
    "surface_rows",
    "evidence_index",
    "consumer_bindings",
    "source_contract_refs",
    "minted_at",
    "support_summary"
  ],
  "properties": {
    "record_kind": {
      "const": "infrastructure_surface_qualification"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty"
    },
    "certification_label": {
      "$ref": "#/$defs/non_empty"
    },
    "surface_rows": {
      "type": "array",
      "minItems": 7,
      "items": {
        "$ref": "#/$defs/surface_row"
      }
    },
    "evidence_index": {
      "type": "array",
      "minItems": 7,
      "items": {
        "$ref": "#/$defs/evidence_index_entry"
      }
    },
    "consumer_bindings": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/consumer_binding"
      }
    },
    "source_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty"
      }
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    },
    "support_summary": {
      "$ref": "#/$defs/reviewable_sentence"
    }
  },
  "$defs": {
    "non_empty": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    },
    "surface": {
      "type": "string",
      "enum": [
        "source_intelligence",
        "live_counterpart_graph",
        "plan_and_validation",
        "live_resource_context",
        "provider_overlay_handoff",
        "incident_support_parity",
        "public_evidence_index"
      ]
    },
    "qualification_posture": {
      "type": "string",
      "enum": [
        "stable_qualified",
        "file_only",
        "inspect_only",
        "handoff_only",
        "downgraded"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "certified",
        "narrowed",
        "blocked"
      ]
    },
    "evidence_currency": {
      "type": "string",
      "enum": [
        "current",
        "stale"
      ]
    },
    "proof_class": {
      "type": "string",
      "enum": [
        "relationship_graph",
        "target_context",
        "live_counterpart",
        "plan_validation",
        "handoff_boundary",
        "wrong_target_drill",
        "stale_live_overlay_drill",
        "export_parity"
      ]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "missing_relationship_proof",
        "missing_target_context_proof",
        "missing_live_counterpart_proof",
        "missing_plan_validation_proof",
        "missing_handoff_boundary_proof",
        "missing_wrong_target_drill",
        "missing_stale_live_overlay_drill",
        "missing_export_parity_proof",
        "evidence_stale"
      ]
    },
    "consumer": {
      "type": "string",
      "enum": [
        "docs_help",
        "help_about",
        "support_playbook",
        "public_truth"
      ]
    },
    "surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "claimed_posture",
        "displayed_posture",
        "verdict",
        "evidence_currency",
        "packet_refs",
        "required_proofs",
        "satisfied_proofs",
        "narrow_reasons",
        "scope_summary"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/surface"
        },
        "claimed_posture": {
          "$ref": "#/$defs/qualification_posture"
        },
        "displayed_posture": {
          "$ref": "#/$defs/qualification_posture"
        },
        "verdict": {
          "$ref": "#/$defs/verdict"
        },
        "evidence_currency": {
          "$ref": "#/$defs/evidence_currency"
        },
        "packet_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "required_proofs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/proof_class"
          }
        },
        "satisfied_proofs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/proof_class"
          }
        },
        "narrow_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/narrow_reason"
          }
        },
        "scope_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "evidence_index_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "surface",
        "schema_ref",
        "doc_ref",
        "artifact_ref",
        "drill_refs",
        "support_summary"
      ],
      "properties": {
        "entry_id": {
          "$ref": "#/$defs/non_empty"
        },
        "surface": {
          "$ref": "#/$defs/surface"
        },
        "schema_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "doc_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "artifact_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "drill_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "consumer_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer",
        "consumer_ref",
        "surface_refs",
        "uses_shared_index",
        "shows_displayed_posture",
        "shows_narrow_reasons",
        "shows_handoff_boundary",
        "support_summary"
      ],
      "properties": {
        "consumer": {
          "$ref": "#/$defs/consumer"
        },
        "consumer_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "surface_refs": {
          "type": "array",
          "minItems": 7,
          "items": {
            "$ref": "#/$defs/surface"
          }
        },
        "uses_shared_index": {
          "type": "boolean"
        },
        "shows_displayed_posture": {
          "type": "boolean"
        },
        "shows_narrow_reasons": {
          "type": "boolean"
        },
        "shows_handoff_boundary": {
          "type": "boolean"
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    }
  }
}
