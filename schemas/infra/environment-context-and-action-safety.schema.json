{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/infra/environment-context-and-action-safety.schema.json",
  "title": "Infrastructure environment-context and action-safety qualification packet",
  "description": "Schema for packets that qualify infrastructure, cluster, incident-ops, and control-plane handoff surfaces. Packets carry explicit environment context, connector-class policy, resource state truth, target-context chips, boundary action reviews, and provider-console handoff truth. Raw credentials, raw kubeconfig bodies, raw provider responses, private endpoint URLs, and browser cookies are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "captured_at",
    "environment_context",
    "connector_policies",
    "resource_links",
    "surface_bindings",
    "action_reviews",
    "control_plane_handoffs",
    "support_summary"
  ],
  "properties": {
    "record_kind": { "const": "infra_target_context_control_plane_boundary_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty" },
    "captured_at": { "type": "string", "format": "date-time" },
    "environment_context": { "$ref": "#/$defs/environment_context" },
    "connector_policies": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/connector_policy" }
    },
    "resource_links": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/resource_link" }
    },
    "surface_bindings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surface_binding" }
    },
    "action_reviews": {
      "type": "array",
      "items": { "$ref": "#/$defs/action_review" }
    },
    "control_plane_handoffs": {
      "type": "array",
      "items": { "$ref": "#/$defs/control_plane_handoff" }
    },
    "support_summary": { "$ref": "#/$defs/reviewable_sentence" }
  },
  "$defs": {
    "non_empty": { "type": "string", "minLength": 1 },
    "nullable_non_empty": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/non_empty" }
      ]
    },
    "reviewable_sentence": { "type": "string", "minLength": 1, "maxLength": 600 },
    "connector_class": {
      "type": "string",
      "enum": [
        "static-file-only",
        "cli-mediated",
        "agent-mediated-live",
        "provider-console-overlay"
      ]
    },
    "truth_class": {
      "type": "string",
      "enum": [
        "desired",
        "rendered",
        "planned",
        "observed",
        "cached",
        "permission_limited",
        "unavailable",
        "provider_overlay"
      ]
    },
    "state_class": {
      "type": "string",
      "enum": [
        "desired",
        "rendered",
        "planned",
        "observed",
        "cached",
        "permission_limited",
        "unavailable"
      ]
    },
    "freshness_label": {
      "type": "string",
      "enum": [
        "live",
        "current_snapshot",
        "cached_within_floor",
        "stale",
        "partial",
        "offline",
        "permission_limited",
        "unavailable"
      ]
    },
    "action_posture": {
      "type": "string",
      "enum": [
        "inspect_only",
        "dry_run_only",
        "step_up_required",
        "write_approved",
        "blocked",
        "not_claimed",
        "handoff_only"
      ]
    },
    "action_kind": {
      "type": "string",
      "enum": [
        "inspect",
        "dry_run",
        "mutate",
        "port_forward",
        "shell_attach",
        "exec",
        "container_exec",
        "browser_console_launch"
      ]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "terminal",
        "logs",
        "resource_graph",
        "incident_workspace",
        "ai_action_sheet",
        "cli_json",
        "browser_console_handoff",
        "support_export"
      ]
    },
    "qualification_posture": {
      "type": "string",
      "enum": [
        "stable_qualified",
        "file_only",
        "inspect_only",
        "handoff_only",
        "downgraded"
      ]
    },
    "handoff_reason": {
      "type": "string",
      "enum": [
        "provider_overlay_inspection",
        "mutation_requires_vendor_console",
        "permission_scope_gap",
        "incident_runbook_continuation",
        "preview_or_route_continuation",
        "source_or_ownership_trace"
      ]
    },
    "handoff_destination_class": {
      "type": "string",
      "enum": [
        "vendor_console",
        "provider_owned_page",
        "managed_control_plane",
        "provider_runbook_page"
      ]
    },
    "return_surface": {
      "type": "string",
      "enum": [
        "code_breadcrumb",
        "incident_workspace",
        "preview_route",
        "route_explorer",
        "infrastructure_panel"
      ]
    },
    "environment_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_id",
        "provider",
        "account_subscription_project",
        "cluster",
        "namespace",
        "region_zone",
        "tenant",
        "workspace_root",
        "branch_worktree_or_commit",
        "execution_context_profile",
        "toolchain_cli_identity",
        "credential_handle_class",
        "issuance_source",
        "expiry",
        "write_scope",
        "observed_at",
        "completeness",
        "ambient_context_prohibited",
        "high_risk"
      ],
      "properties": {
        "context_id": { "$ref": "#/$defs/non_empty" },
        "provider": { "$ref": "#/$defs/non_empty" },
        "account_subscription_project": { "$ref": "#/$defs/non_empty" },
        "cluster": { "$ref": "#/$defs/nullable_non_empty" },
        "namespace": { "$ref": "#/$defs/nullable_non_empty" },
        "region_zone": { "$ref": "#/$defs/nullable_non_empty" },
        "tenant": { "$ref": "#/$defs/nullable_non_empty" },
        "workspace_root": { "$ref": "#/$defs/non_empty" },
        "branch_worktree_or_commit": { "$ref": "#/$defs/non_empty" },
        "execution_context_profile": { "$ref": "#/$defs/non_empty" },
        "toolchain_cli_identity": { "$ref": "#/$defs/non_empty" },
        "credential_handle_class": { "$ref": "#/$defs/non_empty" },
        "issuance_source": { "$ref": "#/$defs/non_empty" },
        "expiry": { "$ref": "#/$defs/nullable_non_empty" },
        "write_scope": { "$ref": "#/$defs/non_empty" },
        "observed_at": { "type": "string", "format": "date-time" },
        "completeness": { "type": "string", "enum": ["complete", "partial_acknowledged", "incomplete"] },
        "ambient_context_prohibited": { "type": "boolean", "const": true },
        "high_risk": { "type": "boolean" }
      }
    },
    "connector_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["connector_class", "allowed_actions", "freshness_labels", "required_step_up_posture", "summary"],
      "properties": {
        "connector_class": { "$ref": "#/$defs/connector_class" },
        "allowed_actions": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/action_posture" },
          "propertyNames": { "$ref": "#/$defs/action_kind" }
        },
        "freshness_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/freshness_label" }
        },
        "required_step_up_posture": { "$ref": "#/$defs/action_posture" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "resource_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "link_id",
        "resource_label",
        "truth_class",
        "state_class",
        "relationship_edge",
        "desired_ref",
        "rendered_ref",
        "planned_ref",
        "observed_ref",
        "provider_overlay_ref",
        "freshness",
        "mutation_downgraded"
      ],
      "properties": {
        "link_id": { "$ref": "#/$defs/non_empty" },
        "resource_label": { "$ref": "#/$defs/non_empty" },
        "truth_class": { "$ref": "#/$defs/truth_class" },
        "state_class": { "$ref": "#/$defs/state_class" },
        "relationship_edge": { "$ref": "#/$defs/non_empty" },
        "desired_ref": { "$ref": "#/$defs/nullable_non_empty" },
        "rendered_ref": { "$ref": "#/$defs/nullable_non_empty" },
        "planned_ref": { "$ref": "#/$defs/nullable_non_empty" },
        "observed_ref": { "$ref": "#/$defs/nullable_non_empty" },
        "provider_overlay_ref": { "$ref": "#/$defs/nullable_non_empty" },
        "freshness": { "$ref": "#/$defs/freshness_label" },
        "mutation_downgraded": { "type": "boolean" }
      }
    },
    "target_chip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_ref",
        "provider",
        "account_subscription_project",
        "cluster",
        "namespace",
        "region_zone",
        "execution_origin",
        "mismatch_state",
        "dry_run_available",
        "rollback_checkpoint_posture"
      ],
      "properties": {
        "context_ref": { "$ref": "#/$defs/non_empty" },
        "provider": { "$ref": "#/$defs/non_empty" },
        "account_subscription_project": { "$ref": "#/$defs/non_empty" },
        "cluster": { "$ref": "#/$defs/nullable_non_empty" },
        "namespace": { "$ref": "#/$defs/nullable_non_empty" },
        "region_zone": { "$ref": "#/$defs/nullable_non_empty" },
        "execution_origin": { "$ref": "#/$defs/non_empty" },
        "mismatch_state": { "$ref": "#/$defs/non_empty" },
        "dry_run_available": { "type": "boolean" },
        "rollback_checkpoint_posture": { "$ref": "#/$defs/non_empty" }
      }
    },
    "surface_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "qualification_posture",
        "target_chip",
        "truth_classes",
        "state_classes",
        "resource_link_refs",
        "uses_shared_packet"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/surface_kind" },
        "qualification_posture": { "$ref": "#/$defs/qualification_posture" },
        "target_chip": { "$ref": "#/$defs/target_chip" },
        "truth_classes": { "type": "array", "items": { "$ref": "#/$defs/truth_class" } },
        "state_classes": { "type": "array", "items": { "$ref": "#/$defs/state_class" } },
        "resource_link_refs": { "type": "array", "items": { "$ref": "#/$defs/non_empty" } },
        "uses_shared_packet": { "type": "boolean" }
      }
    },
    "action_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_id",
        "action_kind",
        "target_context_ref",
        "connector_class",
        "action_posture",
        "duration",
        "credential_scope",
        "revocation_path",
        "preview_envelope",
        "approval_lineage_ref"
      ],
      "properties": {
        "review_id": { "$ref": "#/$defs/non_empty" },
        "action_kind": { "$ref": "#/$defs/action_kind" },
        "target_context_ref": { "$ref": "#/$defs/non_empty" },
        "connector_class": { "$ref": "#/$defs/connector_class" },
        "action_posture": { "$ref": "#/$defs/action_posture" },
        "duration": { "$ref": "#/$defs/nullable_non_empty" },
        "credential_scope": { "$ref": "#/$defs/nullable_non_empty" },
        "revocation_path": { "$ref": "#/$defs/nullable_non_empty" },
        "preview_envelope": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["envelope_ref", "preview_hash", "dry_run_result_ref", "rollback_checkpoint_ref"],
              "properties": {
                "envelope_ref": { "$ref": "#/$defs/non_empty" },
                "preview_hash": { "$ref": "#/$defs/non_empty" },
                "dry_run_result_ref": { "$ref": "#/$defs/nullable_non_empty" },
                "rollback_checkpoint_ref": { "$ref": "#/$defs/nullable_non_empty" }
              }
            }
          ]
        },
        "approval_lineage_ref": { "$ref": "#/$defs/nullable_non_empty" }
      }
    },
    "handoff_target_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_label",
        "provider",
        "account_subscription_project",
        "cluster",
        "namespace_or_scope",
        "region_zone",
        "tenant",
        "stable_target_ref",
        "provider_handle_ref"
      ],
      "properties": {
        "target_label": { "$ref": "#/$defs/non_empty" },
        "provider": { "$ref": "#/$defs/non_empty" },
        "account_subscription_project": { "$ref": "#/$defs/non_empty" },
        "cluster": { "$ref": "#/$defs/nullable_non_empty" },
        "namespace_or_scope": { "$ref": "#/$defs/nullable_non_empty" },
        "region_zone": { "$ref": "#/$defs/nullable_non_empty" },
        "tenant": { "$ref": "#/$defs/nullable_non_empty" },
        "stable_target_ref": { "$ref": "#/$defs/non_empty" },
        "provider_handle_ref": { "$ref": "#/$defs/nullable_non_empty" }
      }
    },
    "handoff_authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "boundary_label",
        "aureline_posture",
        "destination_authority_label",
        "control_plane_boundary_disclosed",
        "vendor_owned_authority",
        "overlay_cannot_become_canonical_truth"
      ],
      "properties": {
        "boundary_label": { "$ref": "#/$defs/non_empty" },
        "aureline_posture": { "$ref": "#/$defs/action_posture" },
        "destination_authority_label": { "$ref": "#/$defs/non_empty" },
        "control_plane_boundary_disclosed": { "type": "boolean" },
        "vendor_owned_authority": { "type": "boolean" },
        "overlay_cannot_become_canonical_truth": { "type": "boolean" }
      }
    },
    "handoff_return_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "anchor_id",
        "surface",
        "context_ref",
        "primary_object_ref",
        "route_or_view_ref",
        "restore_action_label",
        "generic_shell_reopen_forbidden"
      ],
      "properties": {
        "anchor_id": { "$ref": "#/$defs/non_empty" },
        "surface": { "$ref": "#/$defs/return_surface" },
        "context_ref": { "$ref": "#/$defs/non_empty" },
        "primary_object_ref": { "$ref": "#/$defs/non_empty" },
        "route_or_view_ref": { "$ref": "#/$defs/non_empty" },
        "restore_action_label": { "$ref": "#/$defs/non_empty" },
        "generic_shell_reopen_forbidden": { "type": "boolean" }
      }
    },
    "handoff_breadcrumb": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "breadcrumb_id",
        "position",
        "label",
        "surface",
        "context_ref",
        "object_ref"
      ],
      "properties": {
        "breadcrumb_id": { "$ref": "#/$defs/non_empty" },
        "position": { "type": "integer", "minimum": 1 },
        "label": { "$ref": "#/$defs/non_empty" },
        "surface": { "$ref": "#/$defs/return_surface" },
        "context_ref": { "$ref": "#/$defs/non_empty" },
        "object_ref": { "$ref": "#/$defs/non_empty" }
      }
    },
    "control_plane_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff_id",
        "destination",
        "handoff_reason",
        "destination_class",
        "target_context_ref",
        "connector_class",
        "target_identity",
        "authority_boundary",
        "explicit_handoff_destination",
        "not_substitute_truth",
        "return_or_revocation_path",
        "return_anchor",
        "breadcrumbs",
        "audit_ref"
      ],
      "properties": {
        "handoff_id": { "$ref": "#/$defs/non_empty" },
        "destination": { "$ref": "#/$defs/non_empty" },
        "handoff_reason": { "$ref": "#/$defs/handoff_reason" },
        "destination_class": { "$ref": "#/$defs/handoff_destination_class" },
        "target_context_ref": { "$ref": "#/$defs/non_empty" },
        "connector_class": { "$ref": "#/$defs/connector_class" },
        "target_identity": { "$ref": "#/$defs/handoff_target_identity" },
        "authority_boundary": { "$ref": "#/$defs/handoff_authority_boundary" },
        "explicit_handoff_destination": { "type": "boolean", "const": true },
        "not_substitute_truth": { "type": "boolean", "const": true },
        "return_or_revocation_path": { "$ref": "#/$defs/non_empty" },
        "return_anchor": { "$ref": "#/$defs/handoff_return_anchor" },
        "breadcrumbs": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/handoff_breadcrumb" }
        },
        "audit_ref": { "$ref": "#/$defs/non_empty" }
      }
    }
  }
}
