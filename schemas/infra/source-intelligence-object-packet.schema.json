{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/infra/source-intelligence-object-packet.schema.json",
  "title": "Infrastructure source-intelligence object packet",
  "description": "Schema for the canonical M5 infrastructure object packet that instantiates the shared Terraform/HCL, Kubernetes/Helm, devcontainer, CI/environment, and policy-manifest vocabulary as stable authored, rendered, planned, observed, and provider-overlay objects plus stable relation edges and shared graph/review/docs/incident projections. Raw provider payloads, raw credentials, raw kubeconfig bodies, and hidden mutation authority are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "captured_at",
    "matrix_packet_ref",
    "environment_contexts",
    "object_records",
    "relation_records",
    "consumer_projections",
    "support_summary"
  ],
  "properties": {
    "record_kind": {
      "const": "infra_source_intelligence_object_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "matrix_packet_ref": {
      "const": "infra_source_intelligence_and_resource_relationship_matrix_packet"
    },
    "environment_contexts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/environment_context"
      }
    },
    "object_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/object_record"
      }
    },
    "relation_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/relation_record"
      }
    },
    "consumer_projections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/consumer_projection"
      }
    },
    "support_summary": {
      "$ref": "#/$defs/reviewable_sentence"
    }
  },
  "$defs": {
    "non_empty": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    },
    "family": {
      "type": "string",
      "enum": [
        "terraform_hcl",
        "kubernetes_helm",
        "devcontainer",
        "ci_environment",
        "policy_manifest"
      ]
    },
    "truth_layer": {
      "type": "string",
      "enum": [
        "authored_desired",
        "rendered_expanded",
        "planned_validated",
        "observed_live",
        "provider_overlay"
      ]
    },
    "relation_edge_class": {
      "type": "string",
      "enum": [
        "source_of_render",
        "plan_for",
        "live_counterpart_of",
        "applied_by",
        "owned_by",
        "impacts",
        "runbook_reference",
        "review_anchor",
        "provider_overlay_of"
      ]
    },
    "freshness_label": {
      "type": "string",
      "enum": [
        "live",
        "current_snapshot",
        "cached_within_floor",
        "stale",
        "partial",
        "offline",
        "permission_limited",
        "unavailable"
      ]
    },
    "action_posture": {
      "type": "string",
      "enum": [
        "inspect_only",
        "dry_run_only",
        "handoff_only"
      ]
    },
    "console_handoff_posture": {
      "type": "string",
      "enum": [
        "no_console_handoff",
        "explicit_optional_boundary",
        "explicit_mutation_boundary",
        "overlay_only_boundary"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "graph",
        "review",
        "docs",
        "incident"
      ]
    },
    "environment_completeness": {
      "type": "string",
      "enum": [
        "complete",
        "partial_acknowledged",
        "incomplete"
      ]
    },
    "environment_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_id",
        "provider",
        "account_subscription_project",
        "workspace_root",
        "branch_worktree_or_commit",
        "execution_context_profile",
        "toolchain_cli_identity",
        "credential_handle_class",
        "issuance_source",
        "write_scope",
        "observed_at",
        "completeness",
        "ambient_context_prohibited",
        "high_risk"
      ],
      "properties": {
        "context_id": {
          "$ref": "#/$defs/non_empty"
        },
        "provider": {
          "$ref": "#/$defs/non_empty"
        },
        "account_subscription_project": {
          "$ref": "#/$defs/non_empty"
        },
        "cluster": {
          "type": [
            "string",
            "null"
          ]
        },
        "namespace": {
          "type": [
            "string",
            "null"
          ]
        },
        "region_zone": {
          "type": [
            "string",
            "null"
          ]
        },
        "tenant": {
          "type": [
            "string",
            "null"
          ]
        },
        "workspace_root": {
          "$ref": "#/$defs/non_empty"
        },
        "branch_worktree_or_commit": {
          "$ref": "#/$defs/non_empty"
        },
        "execution_context_profile": {
          "$ref": "#/$defs/non_empty"
        },
        "toolchain_cli_identity": {
          "$ref": "#/$defs/non_empty"
        },
        "credential_handle_class": {
          "$ref": "#/$defs/non_empty"
        },
        "issuance_source": {
          "$ref": "#/$defs/non_empty"
        },
        "expiry": {
          "type": [
            "string",
            "null"
          ]
        },
        "write_scope": {
          "$ref": "#/$defs/non_empty"
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "completeness": {
          "$ref": "#/$defs/environment_completeness"
        },
        "ambient_context_prohibited": {
          "type": "boolean",
          "const": true
        },
        "high_risk": {
          "type": "boolean"
        }
      }
    },
    "object_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity_class",
        "stable_locator",
        "selector_refs",
        "owner_refs"
      ],
      "properties": {
        "identity_class": {
          "$ref": "#/$defs/non_empty"
        },
        "stable_locator": {
          "$ref": "#/$defs/non_empty"
        },
        "namespace_or_scope": {
          "type": [
            "string",
            "null"
          ]
        },
        "selector_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "owner_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "source_path_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "provider_handle_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "object_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authored_object_refs",
        "source_input_refs",
        "known_path_back_to_source_refs",
        "parameter_or_environment_refs"
      ],
      "properties": {
        "authored_object_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "source_input_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "known_path_back_to_source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "tool_identity": {
          "type": [
            "string",
            "null"
          ]
        },
        "tool_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "parameter_or_environment_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        }
      }
    },
    "object_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "family",
        "truth_layer",
        "display_label",
        "context_ref",
        "identity",
        "freshness",
        "authority_posture",
        "provider_owned",
        "lineage",
        "provenance_refs",
        "support_summary"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/non_empty"
        },
        "family": {
          "$ref": "#/$defs/family"
        },
        "truth_layer": {
          "$ref": "#/$defs/truth_layer"
        },
        "display_label": {
          "$ref": "#/$defs/non_empty"
        },
        "context_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "identity": {
          "$ref": "#/$defs/object_identity"
        },
        "freshness": {
          "$ref": "#/$defs/freshness_label"
        },
        "observed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "authority_posture": {
          "$ref": "#/$defs/action_posture"
        },
        "provider_owned": {
          "type": "boolean"
        },
        "lineage": {
          "$ref": "#/$defs/object_lineage"
        },
        "provenance_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "relation_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation_id",
        "family",
        "edge_class",
        "from_object_ref",
        "to_object_ref",
        "freshness",
        "authority_posture",
        "console_handoff_posture",
        "selector_refs",
        "owner_refs",
        "provenance_refs",
        "support_summary"
      ],
      "properties": {
        "relation_id": {
          "$ref": "#/$defs/non_empty"
        },
        "family": {
          "$ref": "#/$defs/family"
        },
        "edge_class": {
          "$ref": "#/$defs/relation_edge_class"
        },
        "from_object_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "to_object_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "freshness": {
          "$ref": "#/$defs/freshness_label"
        },
        "authority_posture": {
          "$ref": "#/$defs/action_posture"
        },
        "console_handoff_posture": {
          "$ref": "#/$defs/console_handoff_posture"
        },
        "selector_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "owner_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "provenance_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projection_id",
        "surface",
        "source_packet_ref",
        "object_refs",
        "relation_refs",
        "uses_shared_packet",
        "hidden_side_cache_created",
        "support_summary"
      ],
      "properties": {
        "projection_id": {
          "$ref": "#/$defs/non_empty"
        },
        "surface": {
          "$ref": "#/$defs/consumer_surface"
        },
        "source_packet_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "object_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "relation_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "uses_shared_packet": {
          "type": "boolean",
          "const": true
        },
        "hidden_side_cache_created": {
          "type": "boolean",
          "const": false
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    }
  }
}
