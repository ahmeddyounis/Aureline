{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/infra/plan-and-validation-viewers.schema.json",
  "title": "Infrastructure plan and validation viewer packet",
  "description": "Schema for the canonical M5 infrastructure plan, diff, dry-run, admission, and policy-check viewers. Packets preserve planned/validated truth labeling, target context, timestamp, tool identity/version, explicit review-before-apply gates, and export-safe review/incident/support joins without hidden live authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "captured_at",
    "source_intelligence_packet_ref",
    "boundary_packet_ref",
    "environment_contexts",
    "viewer_records",
    "follow_up_gates",
    "consumer_joins",
    "support_summary"
  ],
  "properties": {
    "record_kind": {
      "const": "infra_plan_and_validation_viewer_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_intelligence_packet_ref": {
      "const": "infra_source_intelligence_object_packet"
    },
    "boundary_packet_ref": {
      "const": "infra_target_context_control_plane_boundary_packet"
    },
    "environment_contexts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/environment_context"
      }
    },
    "viewer_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/viewer_record"
      }
    },
    "follow_up_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/follow_up_gate"
      }
    },
    "consumer_joins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/consumer_join"
      }
    },
    "support_summary": {
      "$ref": "#/$defs/reviewable_sentence"
    }
  },
  "$defs": {
    "non_empty": {
      "type": "string",
      "minLength": 1
    },
    "nullable_non_empty": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/non_empty"
        }
      ]
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    },
    "family": {
      "type": "string",
      "enum": [
        "terraform_hcl",
        "kubernetes_helm",
        "devcontainer",
        "ci_environment",
        "policy_manifest"
      ]
    },
    "truth_layer": {
      "type": "string",
      "enum": [
        "planned_validated"
      ]
    },
    "viewer_kind": {
      "type": "string",
      "enum": [
        "plan",
        "diff",
        "dry_run",
        "admission",
        "policy_check"
      ]
    },
    "viewer_result": {
      "type": "string",
      "enum": [
        "ready_for_review",
        "validation_passed",
        "changes_detected",
        "blocked"
      ]
    },
    "target_context_field": {
      "type": "string",
      "enum": [
        "provider",
        "account_subscription_project",
        "environment_selector",
        "namespace_or_scope",
        "region_zone",
        "tenant",
        "workspace_revision",
        "execution_origin",
        "execution_context_profile",
        "tool_identity",
        "credential_class",
        "freshness_timestamp"
      ]
    },
    "action_posture": {
      "type": "string",
      "enum": [
        "inspect_only",
        "dry_run_only",
        "handoff_only"
      ]
    },
    "action_kind": {
      "type": "string",
      "enum": [
        "mutate",
        "browser_console_launch"
      ]
    },
    "authority_source_class": {
      "type": "string",
      "enum": [
        "reviewed_preview_step_up",
        "explicit_provider_handoff"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "review",
        "incident",
        "support_export"
      ]
    },
    "environment_completeness": {
      "type": "string",
      "enum": [
        "complete",
        "partial_acknowledged",
        "incomplete"
      ]
    },
    "environment_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_id",
        "provider",
        "account_subscription_project",
        "cluster",
        "namespace",
        "region_zone",
        "tenant",
        "workspace_root",
        "branch_worktree_or_commit",
        "execution_context_profile",
        "toolchain_cli_identity",
        "credential_handle_class",
        "issuance_source",
        "expiry",
        "write_scope",
        "observed_at",
        "completeness",
        "ambient_context_prohibited",
        "high_risk"
      ],
      "properties": {
        "context_id": {
          "$ref": "#/$defs/non_empty"
        },
        "provider": {
          "$ref": "#/$defs/non_empty"
        },
        "account_subscription_project": {
          "$ref": "#/$defs/non_empty"
        },
        "cluster": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "namespace": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "region_zone": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "tenant": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "workspace_root": {
          "$ref": "#/$defs/non_empty"
        },
        "branch_worktree_or_commit": {
          "$ref": "#/$defs/non_empty"
        },
        "execution_context_profile": {
          "$ref": "#/$defs/non_empty"
        },
        "toolchain_cli_identity": {
          "$ref": "#/$defs/non_empty"
        },
        "credential_handle_class": {
          "$ref": "#/$defs/non_empty"
        },
        "issuance_source": {
          "$ref": "#/$defs/non_empty"
        },
        "expiry": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "write_scope": {
          "$ref": "#/$defs/non_empty"
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "completeness": {
          "$ref": "#/$defs/environment_completeness"
        },
        "ambient_context_prohibited": {
          "type": "boolean",
          "const": true
        },
        "high_risk": {
          "type": "boolean"
        }
      }
    },
    "tool_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_name",
        "tool_version",
        "invocation_identity"
      ],
      "properties": {
        "tool_name": {
          "$ref": "#/$defs/non_empty"
        },
        "tool_version": {
          "$ref": "#/$defs/non_empty"
        },
        "invocation_identity": {
          "$ref": "#/$defs/non_empty"
        }
      }
    },
    "viewer_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "viewer_id",
        "viewer_kind",
        "family",
        "truth_layer",
        "result",
        "context_ref",
        "visible_target_fields",
        "tool_identity",
        "captured_at",
        "input_ref",
        "target_ref",
        "can_lead_to_mutate",
        "review_before_apply_required",
        "authority_posture",
        "source_is_static_repo_material",
        "inherits_live_authority_from_viewer",
        "handoff_ref",
        "support_summary"
      ],
      "properties": {
        "viewer_id": {
          "$ref": "#/$defs/non_empty"
        },
        "viewer_kind": {
          "$ref": "#/$defs/viewer_kind"
        },
        "family": {
          "$ref": "#/$defs/family"
        },
        "truth_layer": {
          "$ref": "#/$defs/truth_layer"
        },
        "result": {
          "$ref": "#/$defs/viewer_result"
        },
        "context_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "visible_target_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/target_context_field"
          }
        },
        "tool_identity": {
          "$ref": "#/$defs/tool_identity"
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "input_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "target_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "can_lead_to_mutate": {
          "type": "boolean"
        },
        "review_before_apply_required": {
          "type": "boolean"
        },
        "authority_posture": {
          "$ref": "#/$defs/action_posture"
        },
        "source_is_static_repo_material": {
          "type": "boolean"
        },
        "inherits_live_authority_from_viewer": {
          "type": "boolean"
        },
        "handoff_ref": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "follow_up_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "viewer_ref",
        "action_kind",
        "context_ref",
        "approval_required",
        "preview_reviewed",
        "authority_source_class",
        "authority_source_ref",
        "handoff_ref",
        "approved",
        "support_summary"
      ],
      "properties": {
        "gate_id": {
          "$ref": "#/$defs/non_empty"
        },
        "viewer_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "action_kind": {
          "$ref": "#/$defs/action_kind"
        },
        "context_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "approval_required": {
          "type": "boolean"
        },
        "preview_reviewed": {
          "type": "boolean"
        },
        "authority_source_class": {
          "$ref": "#/$defs/authority_source_class"
        },
        "authority_source_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "handoff_ref": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "approved": {
          "type": "boolean"
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "consumer_join": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "join_id",
        "surface",
        "source_packet_ref",
        "viewer_refs",
        "gate_refs",
        "uses_shared_packet",
        "preserves_tool_identity",
        "preserves_target_context",
        "preserves_timestamp",
        "preserves_handoff_and_repair_attribution",
        "export_safe_only",
        "hidden_live_authority_created",
        "support_summary"
      ],
      "properties": {
        "join_id": {
          "$ref": "#/$defs/non_empty"
        },
        "surface": {
          "$ref": "#/$defs/consumer_surface"
        },
        "source_packet_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "viewer_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "gate_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "uses_shared_packet": {
          "type": "boolean"
        },
        "preserves_tool_identity": {
          "type": "boolean"
        },
        "preserves_target_context": {
          "type": "boolean"
        },
        "preserves_timestamp": {
          "type": "boolean"
        },
        "preserves_handoff_and_repair_attribution": {
          "type": "boolean"
        },
        "export_safe_only": {
          "type": "boolean"
        },
        "hidden_live_authority_created": {
          "type": "boolean"
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    }
  }
}
