{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/infra/provider-overlay-and-vendor-console-handoff-continuity.schema.json",
  "title": "Infrastructure provider-overlay and vendor-console handoff continuity packet",
  "description": "Schema for the canonical M5 infrastructure packet that keeps provider overlays explicit, binds them to attributable vendor-console handoffs, and preserves return-safe breadcrumbs across code, incident, preview, route, and infrastructure surfaces. Raw provider payloads, raw credentials, browser cookies, and generic shell fallbacks are excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "captured_at",
    "source_intelligence_packet_ref",
    "boundary_packet_ref",
    "environment_contexts",
    "overlay_rows",
    "handoff_rows",
    "surface_bindings",
    "support_summary"
  ],
  "properties": {
    "record_kind": {
      "const": "infra_provider_overlay_and_vendor_console_handoff_continuity_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_intelligence_packet_ref": {
      "const": "infra_source_intelligence_object_packet"
    },
    "boundary_packet_ref": {
      "const": "infra_target_context_control_plane_boundary_packet"
    },
    "environment_contexts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/environment_context"
      }
    },
    "overlay_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/overlay_row"
      }
    },
    "handoff_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/control_plane_handoff"
      }
    },
    "surface_bindings": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/surface_binding"
      }
    },
    "support_summary": {
      "$ref": "#/$defs/reviewable_sentence"
    }
  },
  "$defs": {
    "non_empty": {
      "type": "string",
      "minLength": 1
    },
    "nullable_non_empty": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/non_empty"
        }
      ]
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    },
    "family": {
      "type": "string",
      "enum": [
        "terraform_hcl",
        "kubernetes_helm",
        "devcontainer",
        "ci_environment",
        "policy_manifest"
      ]
    },
    "truth_layer": {
      "type": "string",
      "enum": [
        "authored_desired",
        "rendered_expanded",
        "planned_validated",
        "observed_live",
        "provider_overlay"
      ]
    },
    "freshness_label": {
      "type": "string",
      "enum": [
        "live",
        "current_snapshot",
        "cached_within_floor",
        "stale",
        "partial",
        "offline",
        "permission_limited",
        "unavailable"
      ]
    },
    "action_posture": {
      "type": "string",
      "enum": [
        "inspect_only",
        "dry_run_only",
        "step_up_required",
        "write_approved",
        "blocked",
        "not_claimed",
        "handoff_only"
      ]
    },
    "connector_class": {
      "type": "string",
      "enum": [
        "static-file-only",
        "cli-mediated",
        "agent-mediated-live",
        "provider-console-overlay"
      ]
    },
    "overlay_surface": {
      "type": "string",
      "enum": [
        "code_breadcrumb",
        "incident_workspace",
        "preview_route",
        "route_explorer",
        "infrastructure_panel"
      ]
    },
    "handoff_reason": {
      "type": "string",
      "enum": [
        "provider_overlay_inspection",
        "mutation_requires_vendor_console",
        "permission_scope_gap",
        "incident_runbook_continuation",
        "preview_or_route_continuation",
        "source_or_ownership_trace"
      ]
    },
    "handoff_destination_class": {
      "type": "string",
      "enum": [
        "vendor_console",
        "provider_owned_page",
        "managed_control_plane",
        "provider_runbook_page"
      ]
    },
    "environment_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_id",
        "provider",
        "account_subscription_project",
        "cluster",
        "namespace",
        "region_zone",
        "tenant",
        "workspace_root",
        "branch_worktree_or_commit",
        "execution_context_profile",
        "toolchain_cli_identity",
        "credential_handle_class",
        "issuance_source",
        "expiry",
        "write_scope",
        "observed_at",
        "completeness",
        "ambient_context_prohibited",
        "high_risk"
      ],
      "properties": {
        "context_id": {
          "$ref": "#/$defs/non_empty"
        },
        "provider": {
          "$ref": "#/$defs/non_empty"
        },
        "account_subscription_project": {
          "$ref": "#/$defs/non_empty"
        },
        "cluster": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "namespace": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "region_zone": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "tenant": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "workspace_root": {
          "$ref": "#/$defs/non_empty"
        },
        "branch_worktree_or_commit": {
          "$ref": "#/$defs/non_empty"
        },
        "execution_context_profile": {
          "$ref": "#/$defs/non_empty"
        },
        "toolchain_cli_identity": {
          "$ref": "#/$defs/non_empty"
        },
        "credential_handle_class": {
          "$ref": "#/$defs/non_empty"
        },
        "issuance_source": {
          "$ref": "#/$defs/non_empty"
        },
        "expiry": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "write_scope": {
          "$ref": "#/$defs/non_empty"
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "completeness": {
          "type": "string",
          "enum": [
            "complete",
            "partial_acknowledged",
            "incomplete"
          ]
        },
        "ambient_context_prohibited": {
          "type": "boolean",
          "const": true
        },
        "high_risk": {
          "type": "boolean"
        }
      }
    },
    "handoff_target_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_label",
        "provider",
        "account_subscription_project",
        "cluster",
        "namespace_or_scope",
        "region_zone",
        "tenant",
        "stable_target_ref",
        "provider_handle_ref"
      ],
      "properties": {
        "target_label": {
          "$ref": "#/$defs/non_empty"
        },
        "provider": {
          "$ref": "#/$defs/non_empty"
        },
        "account_subscription_project": {
          "$ref": "#/$defs/non_empty"
        },
        "cluster": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "namespace_or_scope": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "region_zone": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "tenant": {
          "$ref": "#/$defs/nullable_non_empty"
        },
        "stable_target_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "provider_handle_ref": {
          "$ref": "#/$defs/nullable_non_empty"
        }
      }
    },
    "handoff_authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "boundary_label",
        "aureline_posture",
        "destination_authority_label",
        "control_plane_boundary_disclosed",
        "vendor_owned_authority",
        "overlay_cannot_become_canonical_truth"
      ],
      "properties": {
        "boundary_label": {
          "$ref": "#/$defs/non_empty"
        },
        "aureline_posture": {
          "$ref": "#/$defs/action_posture"
        },
        "destination_authority_label": {
          "$ref": "#/$defs/non_empty"
        },
        "control_plane_boundary_disclosed": {
          "type": "boolean"
        },
        "vendor_owned_authority": {
          "type": "boolean"
        },
        "overlay_cannot_become_canonical_truth": {
          "type": "boolean"
        }
      }
    },
    "handoff_return_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "anchor_id",
        "surface",
        "context_ref",
        "primary_object_ref",
        "route_or_view_ref",
        "restore_action_label",
        "generic_shell_reopen_forbidden"
      ],
      "properties": {
        "anchor_id": {
          "$ref": "#/$defs/non_empty"
        },
        "surface": {
          "$ref": "#/$defs/overlay_surface"
        },
        "context_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "primary_object_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "route_or_view_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "restore_action_label": {
          "$ref": "#/$defs/non_empty"
        },
        "generic_shell_reopen_forbidden": {
          "type": "boolean"
        }
      }
    },
    "handoff_breadcrumb": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "breadcrumb_id",
        "position",
        "label",
        "surface",
        "context_ref",
        "object_ref"
      ],
      "properties": {
        "breadcrumb_id": {
          "$ref": "#/$defs/non_empty"
        },
        "position": {
          "type": "integer",
          "minimum": 1
        },
        "label": {
          "$ref": "#/$defs/non_empty"
        },
        "surface": {
          "$ref": "#/$defs/overlay_surface"
        },
        "context_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "object_ref": {
          "$ref": "#/$defs/non_empty"
        }
      }
    },
    "control_plane_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff_id",
        "destination",
        "handoff_reason",
        "destination_class",
        "target_context_ref",
        "connector_class",
        "target_identity",
        "authority_boundary",
        "explicit_handoff_destination",
        "not_substitute_truth",
        "return_or_revocation_path",
        "return_anchor",
        "breadcrumbs",
        "audit_ref"
      ],
      "properties": {
        "handoff_id": {
          "$ref": "#/$defs/non_empty"
        },
        "destination": {
          "$ref": "#/$defs/non_empty"
        },
        "handoff_reason": {
          "$ref": "#/$defs/handoff_reason"
        },
        "destination_class": {
          "$ref": "#/$defs/handoff_destination_class"
        },
        "target_context_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "connector_class": {
          "$ref": "#/$defs/connector_class"
        },
        "target_identity": {
          "$ref": "#/$defs/handoff_target_identity"
        },
        "authority_boundary": {
          "$ref": "#/$defs/handoff_authority_boundary"
        },
        "explicit_handoff_destination": {
          "type": "boolean",
          "const": true
        },
        "not_substitute_truth": {
          "type": "boolean",
          "const": true
        },
        "return_or_revocation_path": {
          "$ref": "#/$defs/non_empty"
        },
        "return_anchor": {
          "$ref": "#/$defs/handoff_return_anchor"
        },
        "breadcrumbs": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/handoff_breadcrumb"
          }
        },
        "audit_ref": {
          "$ref": "#/$defs/non_empty"
        }
      }
    },
    "overlay_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overlay_row_id",
        "family",
        "overlay_object_ref",
        "canonical_object_ref",
        "overlay_relation_ref",
        "canonical_truth_layer",
        "context_ref",
        "handoff_reason",
        "freshness",
        "source_label",
        "declares_provider_owned_truth",
        "canonical_truth_visible",
        "handoff_ref",
        "visible_surfaces",
        "support_summary"
      ],
      "properties": {
        "overlay_row_id": {
          "$ref": "#/$defs/non_empty"
        },
        "family": {
          "$ref": "#/$defs/family"
        },
        "overlay_object_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "canonical_object_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "overlay_relation_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "canonical_truth_layer": {
          "$ref": "#/$defs/truth_layer"
        },
        "context_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "handoff_reason": {
          "$ref": "#/$defs/handoff_reason"
        },
        "freshness": {
          "$ref": "#/$defs/freshness_label"
        },
        "source_label": {
          "$ref": "#/$defs/non_empty"
        },
        "declares_provider_owned_truth": {
          "type": "boolean"
        },
        "canonical_truth_visible": {
          "type": "boolean"
        },
        "handoff_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "visible_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/overlay_surface"
          }
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "surface_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "context_ref",
        "overlay_row_refs",
        "handoff_refs",
        "shows_provider_overlay_badge",
        "shows_canonical_truth_reference",
        "shows_control_plane_boundary",
        "shows_handoff_reason",
        "shows_return_anchor",
        "shows_breadcrumbs",
        "preserves_target_identity",
        "return_rehydrates_same_context",
        "uses_shared_packet",
        "support_summary"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/overlay_surface"
        },
        "context_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "overlay_row_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "handoff_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "shows_provider_overlay_badge": {
          "type": "boolean"
        },
        "shows_canonical_truth_reference": {
          "type": "boolean"
        },
        "shows_control_plane_boundary": {
          "type": "boolean"
        },
        "shows_handoff_reason": {
          "type": "boolean"
        },
        "shows_return_anchor": {
          "type": "boolean"
        },
        "shows_breadcrumbs": {
          "type": "boolean"
        },
        "preserves_target_identity": {
          "type": "boolean"
        },
        "return_rehydrates_same_context": {
          "type": "boolean"
        },
        "uses_shared_packet": {
          "type": "boolean"
        },
        "support_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    }
  }
}
