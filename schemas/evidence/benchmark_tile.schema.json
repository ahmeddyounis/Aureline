{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/evidence/benchmark_tile.schema.json",
  "title": "Aureline public-proof and benchmark evidence tile",
  "description": "Boundary schema for reusable public-proof tiles: benchmark evidence cards, compatibility rows, importer diff rows, migration handoff tiles, community issue handoff tiles, and known-limits references. Each record pins workflow-bundle id, exact-build identity, archetype row, scope, freshness, docs/help version match, caveats, source packet/row refs, and open-packet/open-issue actions so exported packets, release notes, docs/public proof, and in-product migration/help surfaces downgrade stale, partial, unsupported, or community-owned evidence explicitly instead of hiding it.",
  "$ref": "#/$defs/public_proof_tile_record",
  "$defs": {
    "benchmark_tile_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the public-proof tile boundary."
    },
    "record_kind": {
      "type": "string",
      "const": "public_proof_tile_record"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe for manifests, support exports, public-proof packets, and fixtures. Raw URLs, raw paths, credentials, private repository names, raw logs, and raw trace bodies never appear here."
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Short export-safe label. Keep raw secrets, raw local paths, raw unrestricted provider URLs, account identifiers, hostnames, and private repository names outside this field."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "iso_duration": {
      "type": "string",
      "pattern": "^P(?:\\d+Y)?(?:\\d+M)?(?:\\d+W)?(?:\\d+D)?(?:T(?:\\d+H)?(?:\\d+M)?(?:\\d+S)?)?$"
    },
    "opaque_id_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_id" },
      "uniqueItems": true
    },
    "non_empty_opaque_id_array": {
      "allOf": [
        { "$ref": "#/$defs/opaque_id_array" },
        { "minItems": 1 }
      ]
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "$ref": "#/$defs/reviewable_label" },
        "scenario": { "$ref": "#/$defs/reviewable_label" },
        "contract_sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_label" },
          "uniqueItems": true
        },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "component_kind": {
      "type": "string",
      "enum": [
        "benchmark_evidence_card",
        "compatibility_row",
        "importer_diff_row",
        "migration_handoff_tile",
        "community_issue_handoff_tile",
        "known_limits_reference"
      ]
    },
    "surface_context": {
      "type": "string",
      "enum": [
        "exported_packet",
        "release_notes",
        "docs_public_proof",
        "in_product_migration",
        "in_product_help",
        "support_handoff",
        "cli_json"
      ]
    },
    "release_channel_class": {
      "type": "string",
      "enum": [
        "dev_local",
        "nightly",
        "preview",
        "beta",
        "stable",
        "lts",
        "hotfix"
      ]
    },
    "deployment_profile": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "certified",
        "supported",
        "community",
        "experimental",
        "not_supported"
      ]
    },
    "headline_state": {
      "type": "string",
      "enum": [
        "passing",
        "warning",
        "partial",
        "retest_pending",
        "evidence_stale",
        "blocked",
        "unsupported",
        "community_follow_up",
        "unknown"
      ]
    },
    "result_posture": {
      "type": "string",
      "enum": [
        "claim_bearing",
        "claim_bearing_with_caveat",
        "narrowed_claim",
        "methodology_only",
        "support_only",
        "not_claim_bearing",
        "blocked"
      ]
    },
    "downgrade_reason_class": {
      "type": "string",
      "enum": [
        "required_evidence_missing",
        "required_evidence_stale",
        "required_evidence_narrower_than_claim",
        "docs_version_match_unmet",
        "docs_freshness_floor_unmet",
        "unresolved_migration_gap",
        "incomplete_import_mapping",
        "unsupported_workflow_gap",
        "community_owned_follow_up",
        "known_limit_note_missing",
        "support_export_cannot_redact_persona_workspace",
        "proof_class_not_currently_verifiable",
        "not_applicable"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "live_exact",
        "fresh_enough",
        "snapshot_exact_fresh",
        "recently_stale",
        "materially_stale",
        "stale",
        "partial",
        "approximate_derived",
        "unknown"
      ]
    },
    "docs_version_match_state": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build",
        "not_applicable"
      ]
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "benchmark_row",
        "compatibility_row",
        "importer_outcome_row",
        "migration_session",
        "workflow_bundle",
        "known_limit_note",
        "community_issue",
        "mixed_public_proof"
      ]
    },
    "scope_relationship_class": {
      "type": "string",
      "enum": [
        "same_scope",
        "captured_narrower_than_current",
        "captured_wider_than_current",
        "changed_scope",
        "unknown_scope_relationship"
      ]
    },
    "caveat_class": {
      "type": "string",
      "enum": [
        "scope_caveat",
        "platform_narrowed",
        "workflow_narrowed",
        "corpus_narrowed",
        "docs_drift",
        "support_export_narrowed",
        "migration_path_limited",
        "unsupported_workflow_gap",
        "community_owned_follow_up",
        "known_limit",
        "none"
      ]
    },
    "interop_result_state": {
      "type": "string",
      "enum": [
        "imported",
        "mapped",
        "skipped",
        "manual_review",
        "bridge_required",
        "unsupported"
      ]
    },
    "mapping_basis": {
      "type": "string",
      "enum": [
        "exact_identity",
        "semantic_equivalent",
        "capability_based",
        "bridge_adapter",
        "name_heuristic",
        "user_override",
        "not_applicable"
      ]
    },
    "benchmark_class": {
      "type": "string",
      "enum": [
        "startup",
        "first_useful_edit",
        "quick_open",
        "search",
        "typing_latency",
        "task_run",
        "debug_attach",
        "migration_fidelity",
        "extension_bridge",
        "public_head_to_head",
        "other"
      ]
    },
    "threshold_state": {
      "type": "string",
      "enum": [
        "passing",
        "warning",
        "blocked",
        "waived",
        "expired_waiver",
        "evidence_stale",
        "not_applicable"
      ]
    },
    "baseline_comparability": {
      "type": "string",
      "enum": [
        "comparable",
        "same_host_only",
        "not_yet_comparable",
        "incomparable",
        "scope_changed",
        "unknown",
        "not_applicable"
      ]
    },
    "destination_visibility": {
      "type": "string",
      "enum": [
        "public",
        "private_to_maintainers",
        "organization_scoped",
        "local_export_only",
        "not_applicable"
      ]
    },
    "ownership_class": {
      "type": "string",
      "enum": [
        "first_party_owned",
        "shared_with_partner",
        "community_owned",
        "local_user_owned",
        "unknown"
      ]
    },
    "action_destination": {
      "type": "string",
      "enum": [
        "public_proof_packet",
        "benchmark_report",
        "compatibility_report",
        "migration_outcome_packet",
        "known_limit_note",
        "support_packet",
        "public_issue_tracker",
        "private_security_channel",
        "private_partner_channel",
        "community_forum",
        "local_export",
        "disabled"
      ]
    },
    "action_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_ref", "label", "destination", "enabled"],
      "properties": {
        "action_ref": { "$ref": "#/$defs/opaque_id" },
        "label": { "$ref": "#/$defs/reviewable_label" },
        "destination": { "$ref": "#/$defs/action_destination" },
        "enabled": { "type": "boolean" },
        "disabled_reason": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_label" }
          ]
        },
        "packet_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "issue_template_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "bundle_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bundle_id", "bundle_revision"],
      "properties": {
        "bundle_id": { "$ref": "#/$defs/opaque_id" },
        "bundle_revision": { "type": "integer", "minimum": 1 }
      }
    },
    "archetype_row_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["archetype_row_id", "archetype_revision"],
      "properties": {
        "archetype_row_id": { "$ref": "#/$defs/opaque_id" },
        "archetype_revision": { "type": "integer", "minimum": 1 }
      }
    },
    "exact_build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exact_build_identity_ref",
        "release_channel_class",
        "workspace_version"
      ],
      "properties": {
        "exact_build_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "release_channel_class": { "$ref": "#/$defs/release_channel_class" },
        "workspace_version": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_id",
        "scope_label",
        "scope_class",
        "captured_scope_ref",
        "current_scope_ref",
        "scope_relationship_class",
        "deployment_profiles",
        "visible_scope_note"
      ],
      "properties": {
        "scope_id": { "$ref": "#/$defs/opaque_id" },
        "scope_label": { "$ref": "#/$defs/reviewable_label" },
        "scope_class": { "$ref": "#/$defs/scope_class" },
        "captured_scope_ref": { "$ref": "#/$defs/opaque_id" },
        "current_scope_ref": { "$ref": "#/$defs/opaque_id" },
        "scope_relationship_class": { "$ref": "#/$defs/scope_relationship_class" },
        "deployment_profiles": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile" },
          "uniqueItems": true
        },
        "visible_scope_note": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "source_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_proof_packet_refs",
        "benchmark_row_refs",
        "compatibility_row_refs",
        "importer_outcome_packet_refs",
        "importer_outcome_row_refs",
        "migration_session_refs",
        "known_limit_refs",
        "claim_row_refs",
        "support_packet_refs",
        "supporting_artifact_refs"
      ],
      "properties": {
        "public_proof_packet_refs": { "$ref": "#/$defs/opaque_id_array" },
        "benchmark_row_refs": { "$ref": "#/$defs/opaque_id_array" },
        "compatibility_row_refs": { "$ref": "#/$defs/opaque_id_array" },
        "importer_outcome_packet_refs": { "$ref": "#/$defs/opaque_id_array" },
        "importer_outcome_row_refs": { "$ref": "#/$defs/opaque_id_array" },
        "migration_session_refs": { "$ref": "#/$defs/opaque_id_array" },
        "known_limit_refs": { "$ref": "#/$defs/opaque_id_array" },
        "claim_row_refs": { "$ref": "#/$defs/opaque_id_array" },
        "support_packet_refs": { "$ref": "#/$defs/opaque_id_array" },
        "supporting_artifact_refs": { "$ref": "#/$defs/non_empty_opaque_id_array" }
      },
      "anyOf": [
        { "properties": { "public_proof_packet_refs": { "minItems": 1 } } },
        { "properties": { "benchmark_row_refs": { "minItems": 1 } } },
        { "properties": { "compatibility_row_refs": { "minItems": 1 } } },
        { "properties": { "importer_outcome_packet_refs": { "minItems": 1 } } },
        { "properties": { "importer_outcome_row_refs": { "minItems": 1 } } },
        { "properties": { "migration_session_refs": { "minItems": 1 } } },
        { "properties": { "known_limit_refs": { "minItems": 1 } } }
      ]
    },
    "evidence_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headline_state",
        "support_class",
        "result_posture",
        "green_rendering_allowed",
        "state_label",
        "downgrade_reasons"
      ],
      "properties": {
        "headline_state": { "$ref": "#/$defs/headline_state" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "result_posture": { "$ref": "#/$defs/result_posture" },
        "green_rendering_allowed": { "type": "boolean" },
        "state_label": { "$ref": "#/$defs/reviewable_label" },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason_class" },
          "uniqueItems": true
        }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness_class",
        "captured_at",
        "evaluated_at",
        "stale_after",
        "expires_on",
        "freshness_label",
        "rerun_trigger_refs"
      ],
      "properties": {
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "captured_at": { "$ref": "#/$defs/timestamp" },
        "evaluated_at": { "$ref": "#/$defs/timestamp" },
        "stale_after": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/iso_duration" }
          ]
        },
        "expires_on": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/timestamp" }
          ]
        },
        "freshness_label": { "$ref": "#/$defs/reviewable_label" },
        "rerun_trigger_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },
    "docs_version_match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "pack_revision_ref", "repair_hook_ref"],
      "properties": {
        "state": { "$ref": "#/$defs/docs_version_match_state" },
        "pack_revision_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "repair_hook_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "caveat_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "caveat_id",
        "caveat_class",
        "summary",
        "known_limit_ref",
        "affects_claim"
      ],
      "properties": {
        "caveat_id": { "$ref": "#/$defs/opaque_id" },
        "caveat_class": { "$ref": "#/$defs/caveat_class" },
        "summary": { "$ref": "#/$defs/reviewable_label" },
        "known_limit_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "affects_claim": { "type": "boolean" }
      }
    },
    "caveats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "visible",
        "items",
        "machine_export_includes_caveats"
      ],
      "properties": {
        "visible": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/caveat_record" }
        },
        "machine_export_includes_caveats": { "type": "boolean", "const": true }
      }
    },
    "surface_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_contexts",
        "exported_packet_projection",
        "release_notes_projection",
        "docs_public_proof_projection",
        "in_product_projection"
      ],
      "properties": {
        "surface_contexts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_context" },
          "uniqueItems": true
        },
        "exported_packet_projection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "included",
            "preserves_full_tile_payload",
            "preserves_truth_basis",
            "redaction_class"
          ],
          "properties": {
            "included": { "type": "boolean" },
            "preserves_full_tile_payload": { "type": "boolean" },
            "preserves_truth_basis": { "type": "boolean", "const": true },
            "redaction_class": {
              "type": "string",
              "enum": [
                "public_packet_safe",
                "support_packet_redacted",
                "metadata_only_default",
                "internal_only_redacted"
              ]
            }
          }
        },
        "release_notes_projection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["state_visible", "downgrade_visible", "caveats_visible"],
          "properties": {
            "state_visible": { "type": "boolean", "const": true },
            "downgrade_visible": { "type": "boolean" },
            "caveats_visible": { "type": "boolean" }
          }
        },
        "docs_public_proof_projection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["packet_refs_visible", "freshness_visible", "docs_match_visible"],
          "properties": {
            "packet_refs_visible": { "type": "boolean", "const": true },
            "freshness_visible": { "type": "boolean", "const": true },
            "docs_match_visible": { "type": "boolean", "const": true }
          }
        },
        "in_product_projection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "surface_label",
            "keeps_partial_and_unsupported_rows_visible",
            "opens_stable_detail_route"
          ],
          "properties": {
            "surface_label": { "$ref": "#/$defs/reviewable_label" },
            "keeps_partial_and_unsupported_rows_visible": { "type": "boolean" },
            "opens_stable_detail_route": { "type": "boolean", "const": true }
          }
        }
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["open_packet_action", "open_issue_action"],
      "properties": {
        "open_packet_action": { "$ref": "#/$defs/action_record" },
        "open_issue_action": { "$ref": "#/$defs/action_record" }
      }
    },
    "benchmark_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "benchmark_class",
        "result_value_label",
        "threshold_state",
        "baseline_comparability",
        "measurement_ref"
      ],
      "properties": {
        "benchmark_class": { "$ref": "#/$defs/benchmark_class" },
        "result_value_label": { "$ref": "#/$defs/reviewable_label" },
        "threshold_state": { "$ref": "#/$defs/threshold_state" },
        "baseline_comparability": { "$ref": "#/$defs/baseline_comparability" },
        "measurement_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "compatibility_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compatibility_state",
        "qualification_evidence_status",
        "report_ref"
      ],
      "properties": {
        "compatibility_state": {
          "type": "string",
          "enum": ["supported", "best_effort", "untested", "degraded", "unsupported"]
        },
        "qualification_evidence_status": {
          "type": "string",
          "enum": ["current", "stale", "missing", "partial", "not_applicable"]
        },
        "report_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "importer_diff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "source_object_ref",
        "target_object_ref",
        "source_value_ref",
        "target_value_ref",
        "outcome_state",
        "mapping_basis",
        "mapping_note"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "enum": [
            "settings",
            "shortcuts",
            "themes_and_visuals",
            "snippets_and_templates",
            "tasks_and_run_configs",
            "launch_debug",
            "extensions_and_providers",
            "workspace_metadata",
            "profiles_and_layout",
            "docs_and_tours",
            "bridge_metadata",
            "other"
          ]
        },
        "source_object_ref": { "$ref": "#/$defs/opaque_id" },
        "target_object_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "source_value_ref": { "$ref": "#/$defs/opaque_id" },
        "target_value_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "outcome_state": { "$ref": "#/$defs/interop_result_state" },
        "mapping_basis": { "$ref": "#/$defs/mapping_basis" },
        "mapping_note": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "migration_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "migration_session_ref",
        "outcome_packet_ref",
        "restore_or_rollback_ref",
        "handoff_state",
        "recommended_next_ref"
      ],
      "properties": {
        "migration_session_ref": { "$ref": "#/$defs/opaque_id" },
        "outcome_packet_ref": { "$ref": "#/$defs/opaque_id" },
        "restore_or_rollback_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "handoff_state": {
          "type": "string",
          "enum": [
            "supported",
            "partial",
            "blocked",
            "unsupported",
            "community_follow_up"
          ]
        },
        "recommended_next_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "community_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ownership_class",
        "destination_visibility",
        "privacy_class",
        "packet_preview_ref",
        "redaction_review_required"
      ],
      "properties": {
        "ownership_class": { "$ref": "#/$defs/ownership_class" },
        "destination_visibility": { "$ref": "#/$defs/destination_visibility" },
        "privacy_class": {
          "type": "string",
          "enum": ["public", "private_with_public_advisory", "private_partner_only", "local_only"]
        },
        "packet_preview_ref": { "$ref": "#/$defs/opaque_id" },
        "redaction_review_required": { "type": "boolean" }
      }
    },
    "known_limits_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "known_limit_note_refs",
        "limitation_class",
        "severity_class",
        "publication_destination_refs"
      ],
      "properties": {
        "known_limit_note_refs": { "$ref": "#/$defs/non_empty_opaque_id_array" },
        "limitation_class": {
          "type": "string",
          "enum": [
            "scope_caveat_noted",
            "platform_narrowed",
            "workflow_narrowed",
            "persona_narrowed",
            "corpus_narrowed",
            "competitor_parity_narrowed",
            "docs_drift_active",
            "support_export_narrowed",
            "migration_path_limited"
          ]
        },
        "severity_class": {
          "type": "string",
          "enum": ["minor", "moderate", "major", "blocking"]
        },
        "publication_destination_refs": { "$ref": "#/$defs/non_empty_opaque_id_array" }
      }
    },
    "public_proof_tile_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "benchmark_tile_schema_version",
        "record_kind",
        "tile_id",
        "component_kind",
        "title",
        "bundle_ref",
        "exact_build",
        "archetype_row_ref",
        "scope",
        "source_bindings",
        "evidence_state",
        "freshness",
        "docs_version_match",
        "caveats",
        "surface_projection",
        "actions"
      ],
      "properties": {
        "$schema": {
          "type": "string",
          "const": "https://aureline.dev/schemas/evidence/benchmark_tile.schema.json"
        },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "benchmark_tile_schema_version": { "$ref": "#/$defs/benchmark_tile_schema_version" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "tile_id": { "$ref": "#/$defs/opaque_id" },
        "component_kind": { "$ref": "#/$defs/component_kind" },
        "title": { "$ref": "#/$defs/reviewable_label" },
        "bundle_ref": { "$ref": "#/$defs/bundle_ref" },
        "exact_build": { "$ref": "#/$defs/exact_build" },
        "archetype_row_ref": { "$ref": "#/$defs/archetype_row_ref" },
        "scope": { "$ref": "#/$defs/scope" },
        "source_bindings": { "$ref": "#/$defs/source_bindings" },
        "evidence_state": { "$ref": "#/$defs/evidence_state" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "docs_version_match": { "$ref": "#/$defs/docs_version_match" },
        "caveats": { "$ref": "#/$defs/caveats" },
        "surface_projection": { "$ref": "#/$defs/surface_projection" },
        "actions": { "$ref": "#/$defs/actions" },
        "benchmark_evidence": { "$ref": "#/$defs/benchmark_evidence" },
        "compatibility_row": { "$ref": "#/$defs/compatibility_row" },
        "importer_diff": { "$ref": "#/$defs/importer_diff" },
        "migration_handoff": { "$ref": "#/$defs/migration_handoff" },
        "community_handoff": { "$ref": "#/$defs/community_handoff" },
        "known_limits_reference": { "$ref": "#/$defs/known_limits_reference" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "component_kind": { "const": "benchmark_evidence_card" } },
            "required": ["component_kind"]
          },
          "then": { "required": ["benchmark_evidence"] }
        },
        {
          "if": {
            "properties": { "component_kind": { "const": "compatibility_row" } },
            "required": ["component_kind"]
          },
          "then": { "required": ["compatibility_row"] }
        },
        {
          "if": {
            "properties": { "component_kind": { "const": "importer_diff_row" } },
            "required": ["component_kind"]
          },
          "then": { "required": ["importer_diff"] }
        },
        {
          "if": {
            "properties": { "component_kind": { "const": "migration_handoff_tile" } },
            "required": ["component_kind"]
          },
          "then": { "required": ["migration_handoff"] }
        },
        {
          "if": {
            "properties": { "component_kind": { "const": "community_issue_handoff_tile" } },
            "required": ["component_kind"]
          },
          "then": { "required": ["community_handoff"] }
        },
        {
          "if": {
            "properties": { "component_kind": { "const": "known_limits_reference" } },
            "required": ["component_kind"]
          },
          "then": { "required": ["known_limits_reference"] }
        },
        {
          "description": "Stale or unknown freshness cannot render green and must carry at least one downgrade reason.",
          "if": {
            "properties": {
              "freshness": {
                "type": "object",
                "properties": {
                  "freshness_class": {
                    "enum": [
                      "recently_stale",
                      "materially_stale",
                      "stale",
                      "unknown"
                    ]
                  }
                },
                "required": ["freshness_class"]
              }
            },
            "required": ["freshness"]
          },
          "then": {
            "properties": {
              "evidence_state": {
                "type": "object",
                "properties": {
                  "green_rendering_allowed": { "const": false },
                  "downgrade_reasons": { "minItems": 1 }
                },
                "required": ["green_rendering_allowed", "downgrade_reasons"]
              }
            }
          }
        },
        {
          "description": "Docs/help mismatch cannot render green and must carry a downgrade reason.",
          "if": {
            "properties": {
              "docs_version_match": {
                "type": "object",
                "properties": {
                  "state": {
                    "enum": [
                      "incompatible_drift_detected",
                      "pre_release_unverified",
                      "unknown_target_build"
                    ]
                  }
                },
                "required": ["state"]
              }
            },
            "required": ["docs_version_match"]
          },
          "then": {
            "properties": {
              "evidence_state": {
                "type": "object",
                "properties": {
                  "green_rendering_allowed": { "const": false },
                  "downgrade_reasons": { "minItems": 1 }
                }
              }
            }
          }
        },
        {
          "description": "Importer rows that need review, bridge work, or unsupported handling must downgrade.",
          "if": {
            "properties": {
              "component_kind": { "const": "importer_diff_row" },
              "importer_diff": {
                "type": "object",
                "properties": {
                  "outcome_state": {
                    "enum": ["manual_review", "bridge_required", "unsupported"]
                  }
                },
                "required": ["outcome_state"]
              }
            },
            "required": ["component_kind", "importer_diff"]
          },
          "then": {
            "properties": {
              "evidence_state": {
                "type": "object",
                "properties": {
                  "green_rendering_allowed": { "const": false },
                  "downgrade_reasons": { "minItems": 1 }
                }
              },
              "surface_projection": {
                "type": "object",
                "properties": {
                  "in_product_projection": {
                    "type": "object",
                    "properties": {
                      "keeps_partial_and_unsupported_rows_visible": { "const": true }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "description": "Community issue handoff tiles must expose community ownership and an enabled issue route.",
          "if": {
            "properties": {
              "component_kind": { "const": "community_issue_handoff_tile" }
            },
            "required": ["component_kind"]
          },
          "then": {
            "properties": {
              "community_handoff": {
                "type": "object",
                "properties": {
                  "ownership_class": { "const": "community_owned" }
                },
                "required": ["ownership_class"]
              },
              "actions": {
                "type": "object",
                "properties": {
                  "open_issue_action": {
                    "type": "object",
                    "properties": {
                      "enabled": { "const": true }
                    },
                    "required": ["enabled"]
                  }
                }
              }
            }
          }
        },
        {
          "description": "Unsupported workflow handoffs must cite at least one caveat or known-limit ref and stay non-green.",
          "if": {
            "properties": {
              "migration_handoff": {
                "type": "object",
                "properties": {
                  "handoff_state": { "const": "unsupported" }
                },
                "required": ["handoff_state"]
              }
            },
            "required": ["migration_handoff"]
          },
          "then": {
            "properties": {
              "evidence_state": {
                "type": "object",
                "properties": {
                  "green_rendering_allowed": { "const": false },
                  "downgrade_reasons": { "minItems": 1 }
                }
              },
              "caveats": {
                "type": "object",
                "properties": {
                  "items": { "minItems": 1 }
                }
              }
            }
          }
        }
      ]
    }
  }
}
