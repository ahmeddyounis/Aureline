{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/debug/symbolication_contract.schema.json",
  "title": "Aureline symbolication contract packet",
  "description": "Boundary schema for the M5 symbolication contract packet. The packet binds exact-build symbol or source-map manifests, mirror-policy rows, symbolication source usage, local or mirrored symbolication reports, and cross-surface fidelity labels shared by debug, profiler, preview, browser-runtime, and support/export surfaces. Raw symbol bytes, raw dump bytes, raw source files, raw stack frames, raw memory, and raw URLs never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "doc_ref",
    "schema_ref",
    "artifact_doc_ref",
    "source_spec_refs",
    "manifests",
    "mirror_policies",
    "source_usages",
    "reports",
    "surfaces",
    "summary"
  ],
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "symbolication_contract_packet"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "doc_ref": {
      "type": "string",
      "const": "docs/debug/symbolication.md"
    },
    "schema_ref": {
      "type": "string",
      "const": "schemas/debug/symbolication_contract.schema.json"
    },
    "artifact_doc_ref": {
      "type": "string",
      "const": "artifacts/debug/symbolication_contract.md"
    },
    "source_spec_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "manifests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/symbol_manifest_row"
      }
    },
    "mirror_policies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mirror_policy_row"
      }
    },
    "source_usages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_usage_row"
      }
    },
    "reports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/report_row"
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/surface_row"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary_row"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "debug_format": {
      "type": "string",
      "enum": [
        "pdb",
        "dsym",
        "dwarf",
        "javascript_source_map",
        "typescript_source_map",
        "css_source_map"
      ]
    },
    "retention_posture": {
      "type": "string",
      "enum": [
        "local_bounded",
        "release_retained_reference",
        "mirror_retained_reference",
        "imported_ephemeral"
      ]
    },
    "source_identity": {
      "type": "string",
      "enum": [
        "local_workspace_or_cache",
        "local_trusted_store",
        "mirrored_enterprise_store",
        "mirrored_managed_store",
        "imported_attachment"
      ]
    },
    "resolution_source_class": {
      "type": "string",
      "enum": [
        "workspace_output",
        "local_resolver_cache",
        "local_trusted_store",
        "mirrored_store",
        "user_attached_import"
      ]
    },
    "build_match_state": {
      "type": "string",
      "enum": [
        "exact_build_verified",
        "approximate_candidate_only",
        "mismatched_candidate_rejected",
        "no_candidate_available"
      ]
    },
    "fidelity_label": {
      "type": "string",
      "enum": [
        "exact",
        "approximate",
        "symbol_only",
        "unresolved"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_and_hashes_only",
        "support_bundle_scoped",
        "operator_only_restricted"
      ]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "debug_frame_stack",
        "crash_dump_card",
        "profiler_hotspot_workspace",
        "profiler_trace_viewer",
        "preview_runtime_frame",
        "browser_runtime_stack",
        "support_export_packet",
        "incident_crash_card"
      ]
    },
    "symbol_manifest_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_id",
        "debug_artifact_ref",
        "exact_build_identity_ref",
        "build_id",
        "target_triple",
        "debug_format",
        "artifact_digest",
        "retention_posture",
        "source_identity",
        "source_ref",
        "mirrored_source_visible",
        "notes"
      ],
      "properties": {
        "manifest_id": { "$ref": "#/$defs/non_empty_string" },
        "debug_artifact_ref": { "$ref": "#/$defs/non_empty_string" },
        "exact_build_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "build_id": { "$ref": "#/$defs/non_empty_string" },
        "target_triple": { "$ref": "#/$defs/non_empty_string" },
        "debug_format": { "$ref": "#/$defs/debug_format" },
        "artifact_digest": { "$ref": "#/$defs/non_empty_string" },
        "retention_posture": { "$ref": "#/$defs/retention_posture" },
        "source_identity": { "$ref": "#/$defs/source_identity" },
        "source_ref": { "$ref": "#/$defs/non_empty_string" },
        "mirror_policy_ref": {
          "type": ["string", "null"]
        },
        "mirrored_source_visible": { "type": "boolean" },
        "module_identity_ref": {
          "type": ["string", "null"]
        },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "mirror_policy_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "source_identity",
        "mirror_source_ref",
        "signer_identity_ref",
        "access_policy_ref",
        "retention_posture",
        "requires_local_miss_before_lookup",
        "mirror_usage_disclosed",
        "notes"
      ],
      "properties": {
        "policy_id": { "$ref": "#/$defs/non_empty_string" },
        "source_identity": { "$ref": "#/$defs/source_identity" },
        "mirror_source_ref": { "$ref": "#/$defs/non_empty_string" },
        "signer_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "access_policy_ref": { "$ref": "#/$defs/non_empty_string" },
        "retention_posture": { "$ref": "#/$defs/retention_posture" },
        "requires_local_miss_before_lookup": { "type": "boolean" },
        "mirror_usage_disclosed": { "type": "boolean" },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "source_usage_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_usage_id",
        "manifest_id",
        "resolution_source_class",
        "source_ref",
        "source_identity",
        "build_match_state",
        "selected_for_symbolication",
        "mirror_usage_visible",
        "notes"
      ],
      "properties": {
        "source_usage_id": { "$ref": "#/$defs/non_empty_string" },
        "manifest_id": { "$ref": "#/$defs/non_empty_string" },
        "resolution_source_class": { "$ref": "#/$defs/resolution_source_class" },
        "source_ref": { "$ref": "#/$defs/non_empty_string" },
        "source_identity": { "$ref": "#/$defs/source_identity" },
        "build_match_state": { "$ref": "#/$defs/build_match_state" },
        "selected_for_symbolication": { "type": "boolean" },
        "mirror_usage_visible": { "type": "boolean" },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "report_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_id",
        "context_ref",
        "primary_exact_build_identity_ref",
        "symbol_source_usage_refs",
        "fidelity_label",
        "build_match_state",
        "exact_frame_count",
        "approximate_frame_count",
        "symbol_only_frame_count",
        "unresolved_frame_count",
        "redaction_class",
        "mirror_usage_visible",
        "local_first_semantics_preserved",
        "notes"
      ],
      "properties": {
        "report_id": { "$ref": "#/$defs/non_empty_string" },
        "context_ref": { "$ref": "#/$defs/non_empty_string" },
        "primary_exact_build_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "symbol_source_usage_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "fidelity_label": { "$ref": "#/$defs/fidelity_label" },
        "build_match_state": { "$ref": "#/$defs/build_match_state" },
        "exact_frame_count": { "type": "integer", "minimum": 0 },
        "approximate_frame_count": { "type": "integer", "minimum": 0 },
        "symbol_only_frame_count": { "type": "integer", "minimum": 0 },
        "unresolved_frame_count": { "type": "integer", "minimum": 0 },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "mirror_usage_visible": { "type": "boolean" },
        "local_first_semantics_preserved": { "type": "boolean" },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "surface_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "surface_kind",
        "context_ref",
        "report_ref",
        "fidelity_label",
        "build_match_state",
        "unresolved_frame_count",
        "shows_fidelity_label",
        "shows_symbol_sources_used",
        "shows_build_mismatch_before_navigation",
        "shows_mirror_visibility",
        "shows_redaction_class",
        "notes"
      ],
      "properties": {
        "surface_id": { "$ref": "#/$defs/non_empty_string" },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "context_ref": { "$ref": "#/$defs/non_empty_string" },
        "report_ref": { "$ref": "#/$defs/non_empty_string" },
        "fidelity_label": { "$ref": "#/$defs/fidelity_label" },
        "build_match_state": { "$ref": "#/$defs/build_match_state" },
        "unresolved_frame_count": { "type": "integer", "minimum": 0 },
        "shows_fidelity_label": { "type": "boolean" },
        "shows_symbol_sources_used": { "type": "boolean" },
        "shows_build_mismatch_before_navigation": { "type": "boolean" },
        "shows_mirror_visibility": { "type": "boolean" },
        "shows_redaction_class": { "type": "boolean" },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_count",
        "report_count",
        "surface_count",
        "exact_report_count",
        "approximate_report_count",
        "symbol_only_report_count",
        "unresolved_report_count"
      ],
      "properties": {
        "manifest_count": { "type": "integer", "minimum": 0 },
        "report_count": { "type": "integer", "minimum": 0 },
        "surface_count": { "type": "integer", "minimum": 0 },
        "exact_report_count": { "type": "integer", "minimum": 0 },
        "approximate_report_count": { "type": "integer", "minimum": 0 },
        "symbol_only_report_count": { "type": "integer", "minimum": 0 },
        "unresolved_report_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
