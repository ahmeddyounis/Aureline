{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/install/m5-install-diagnostics.schema.json",
  "title": "Aureline M5 install-and-update diagnostics packet",
  "description": "Schema for the m5_install_update_diagnostics packet. The packet exposes one inspectable diagnostics row per M5-added artifact family (desktop-app, companion, marketplace-helper, local-model-runtime, portable-export) recording, for each, its install mode (system, user, portable, managed, marketplace), channel-and-ring, updater owner, classified artifact/mutable-state/policy roots, last verification state (signed-verified, platform-trusted, self-signed, unverified) and freshness (current, aging, stale, never-verified), and rollback target (available, available-bounded, expired, missing). Every machine-protected or secret-bearing root must be redacted, so stores are classified without dumping secrets, token values, or machine-unique protected material. A non-inheriting diagnostics gate derives the support label that may be published: an unverified binary, a stale verification, a missing rollback target, or a governance lane that was itself narrowed cannot publish a verified label, and the published support never exceeds the governance lane the artifact is pinned to via governs_lane/governs_assurance (validated against the m5_install_and_portability_governance_matrix packet). Troubleshooting drills replay the root-mismatch, stale-verification, missing-rollback-target, and wrong-root-support incidents and prove the object detects each. Every required consumer surface (desktop, CLI, About, support export) binds to the packet and narrows with it; the recorded published support, narrow reasons, and recovery path must equal the recomputed gate decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "diagnostics_identity_scheme",
    "governance_packet_id_ref",
    "artifact_families",
    "install_modes",
    "channels",
    "updater_owners",
    "root_roles",
    "root_sensitivities",
    "verification_states",
    "verification_freshness_states",
    "rollback_target_states",
    "assurance_labels",
    "narrow_reasons",
    "recovery_paths",
    "incidents",
    "consumers",
    "artifacts",
    "drills",
    "consumer_bindings",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_install_update_diagnostics" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "diagnostics_identity_scheme": { "$ref": "#/$defs/non_empty_string" },
    "governance_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
    "artifact_families": { "type": "array", "items": { "$ref": "#/$defs/artifact_family" } },
    "install_modes": { "type": "array", "items": { "$ref": "#/$defs/install_mode" } },
    "channels": { "type": "array", "items": { "$ref": "#/$defs/channel" } },
    "updater_owners": { "type": "array", "items": { "$ref": "#/$defs/updater_owner" } },
    "root_roles": { "type": "array", "items": { "$ref": "#/$defs/root_role" } },
    "root_sensitivities": { "type": "array", "items": { "$ref": "#/$defs/root_sensitivity" } },
    "verification_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/verification_state" }
    },
    "verification_freshness_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/verification_freshness" }
    },
    "rollback_target_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/rollback_target" }
    },
    "assurance_labels": { "type": "array", "items": { "$ref": "#/$defs/assurance" } },
    "narrow_reasons": { "type": "array", "items": { "$ref": "#/$defs/narrow_reason" } },
    "recovery_paths": { "type": "array", "items": { "$ref": "#/$defs/recovery_path" } },
    "incidents": { "type": "array", "items": { "$ref": "#/$defs/incident" } },
    "consumers": { "type": "array", "items": { "$ref": "#/$defs/consumer" } },
    "artifacts": { "type": "array", "items": { "$ref": "#/$defs/artifact_row" } },
    "drills": { "type": "array", "items": { "$ref": "#/$defs/drill" } },
    "consumer_bindings": { "type": "array", "items": { "$ref": "#/$defs/consumer_binding" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "artifact_family": {
      "enum": [
        "desktop_app",
        "companion",
        "marketplace_helper",
        "local_model_runtime",
        "portable_export"
      ]
    },
    "install_mode": {
      "enum": ["system", "user", "portable", "managed", "marketplace"]
    },
    "channel": {
      "enum": [
        "stable_broad",
        "stable_pinned",
        "preview_early_access",
        "preview_canary",
        "nightly_canary",
        "managed_pinned"
      ]
    },
    "updater_owner": {
      "enum": [
        "first_party_auto",
        "managed_fleet",
        "marketplace_host",
        "os_package_manager",
        "manual_user",
        "none"
      ]
    },
    "root_role": {
      "enum": [
        "artifact_binary",
        "resource_bundle",
        "mutable_state",
        "cache",
        "log",
        "credential_store",
        "policy_store",
        "machine_identity"
      ]
    },
    "root_sensitivity": {
      "enum": ["public_path", "user_scoped", "machine_protected", "secret_bearing"]
    },
    "verification_state": {
      "enum": ["signed_verified", "platform_trusted", "self_signed", "unverified"]
    },
    "verification_freshness": {
      "enum": ["current", "aging", "stale", "never_verified"]
    },
    "rollback_target": {
      "enum": ["available", "available_bounded", "expired", "missing"]
    },
    "assurance": {
      "enum": ["verified", "bounded", "retest_pending", "withheld"]
    },
    "narrow_reason": {
      "enum": [
        "unverified_artifact",
        "stale_verification",
        "rollback_unavailable",
        "governance_narrowed"
      ]
    },
    "recovery_path": {
      "enum": [
        "reverify_artifact",
        "refresh_verification",
        "restore_rollback_target",
        "follow_governance_recovery",
        "withhold_claim",
        "none"
      ]
    },
    "incident": {
      "enum": ["root_mismatch", "stale_verification", "missing_rollback_target", "wrong_root_support"]
    },
    "consumer": {
      "enum": ["desktop", "cli", "about", "support_export"]
    },
    "root": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "location_label", "sensitivity", "redacted", "writable"],
      "properties": {
        "role": { "$ref": "#/$defs/root_role" },
        "location_label": { "$ref": "#/$defs/non_empty_string" },
        "sensitivity": { "$ref": "#/$defs/root_sensitivity" },
        "redacted": { "type": "boolean" },
        "writable": { "type": "boolean" }
      }
    },
    "artifact_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_family",
        "display_name",
        "install_mode",
        "channel",
        "updater_owner",
        "owner",
        "artifact_roots",
        "mutable_state_roots",
        "policy_roots",
        "verification_state",
        "verification_freshness",
        "verification_evidence_ref",
        "rollback_target",
        "rollback_target_ref",
        "governs_lane",
        "governs_assurance",
        "declared_support",
        "published_support",
        "narrow_reasons",
        "recovery_path",
        "supported_scopes",
        "caveats",
        "stale_or_missing_fields",
        "diagnostics_ref",
        "note"
      ],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/non_empty_string" },
        "artifact_family": { "$ref": "#/$defs/artifact_family" },
        "display_name": { "$ref": "#/$defs/non_empty_string" },
        "install_mode": { "$ref": "#/$defs/install_mode" },
        "channel": { "$ref": "#/$defs/channel" },
        "updater_owner": { "$ref": "#/$defs/updater_owner" },
        "owner": { "$ref": "#/$defs/non_empty_string" },
        "artifact_roots": { "type": "array", "items": { "$ref": "#/$defs/root" } },
        "mutable_state_roots": { "type": "array", "items": { "$ref": "#/$defs/root" } },
        "policy_roots": { "type": "array", "items": { "$ref": "#/$defs/root" } },
        "verification_state": { "$ref": "#/$defs/verification_state" },
        "verification_freshness": { "$ref": "#/$defs/verification_freshness" },
        "verification_evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "rollback_target": { "$ref": "#/$defs/rollback_target" },
        "rollback_target_ref": { "$ref": "#/$defs/non_empty_string" },
        "governs_lane": {
          "enum": [
            "desktop_stable",
            "desktop_preview",
            "portable_install",
            "managed_fleet",
            "marketplace_companion",
            "cli_headless",
            "sync_device"
          ]
        },
        "governs_assurance": { "$ref": "#/$defs/assurance" },
        "declared_support": { "$ref": "#/$defs/assurance" },
        "published_support": { "$ref": "#/$defs/assurance" },
        "narrow_reasons": { "type": "array", "items": { "$ref": "#/$defs/narrow_reason" } },
        "recovery_path": { "$ref": "#/$defs/recovery_path" },
        "supported_scopes": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "caveats": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "stale_or_missing_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "diagnostics_ref": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "drill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drill_id",
        "incident",
        "artifact_id",
        "scenario",
        "expected_signal",
        "observed_signal",
        "detected",
        "remediation",
        "resolves_to"
      ],
      "properties": {
        "drill_id": { "$ref": "#/$defs/non_empty_string" },
        "incident": { "$ref": "#/$defs/incident" },
        "artifact_id": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/non_empty_string" },
        "expected_signal": { "$ref": "#/$defs/non_empty_string" },
        "observed_signal": { "$ref": "#/$defs/non_empty_string" },
        "detected": { "type": "boolean" },
        "remediation": { "$ref": "#/$defs/recovery_path" },
        "resolves_to": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "consumer_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer",
        "binding_ref",
        "diagnostics_packet_id_ref",
        "ingests_diagnostics",
        "preserves_published_support",
        "preserves_recovery_paths",
        "narrows_on_downgrade",
        "raw_private_material_excluded"
      ],
      "properties": {
        "consumer": { "$ref": "#/$defs/consumer" },
        "binding_ref": { "$ref": "#/$defs/non_empty_string" },
        "diagnostics_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "ingests_diagnostics": { "type": "boolean" },
        "preserves_published_support": { "type": "boolean" },
        "preserves_recovery_paths": { "type": "boolean" },
        "narrows_on_downgrade": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_artifacts",
        "family_count",
        "verified_artifacts",
        "bounded_artifacts",
        "retest_pending_artifacts",
        "withheld_artifacts",
        "downgraded_artifacts",
        "unverified_artifacts",
        "stale_verification_artifacts",
        "rollback_unavailable_artifacts",
        "governance_narrowed_artifacts",
        "total_roots",
        "redacted_roots",
        "drill_count",
        "detected_drill_count"
      ],
      "properties": {
        "total_artifacts": { "type": "integer", "minimum": 0 },
        "family_count": { "type": "integer", "minimum": 0 },
        "verified_artifacts": { "type": "integer", "minimum": 0 },
        "bounded_artifacts": { "type": "integer", "minimum": 0 },
        "retest_pending_artifacts": { "type": "integer", "minimum": 0 },
        "withheld_artifacts": { "type": "integer", "minimum": 0 },
        "downgraded_artifacts": { "type": "integer", "minimum": 0 },
        "unverified_artifacts": { "type": "integer", "minimum": 0 },
        "stale_verification_artifacts": { "type": "integer", "minimum": 0 },
        "rollback_unavailable_artifacts": { "type": "integer", "minimum": 0 },
        "governance_narrowed_artifacts": { "type": "integer", "minimum": 0 },
        "total_roots": { "type": "integer", "minimum": 0 },
        "redacted_roots": { "type": "integer", "minimum": 0 },
        "drill_count": { "type": "integer", "minimum": 0 },
        "detected_drill_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
