{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/install/install_topology_truth.schema.json",
  "title": "Aureline install-topology truth-surface seed envelope",
  "description": "Boundary schema for artifacts/install/state_root_matrix.yaml. The envelope pins the canonical row vocabulary at install_topology_truth_row.schema.json, the reviewer-facing landing page at docs/install/m1_install_topology_truth.md, the silent-deployment design packet at design/m1/silent_deployment_baseline.md, the upstream install-profile and state-root sources, the validation-lane registry ref, the closed install-mode coverage list, the closed M1 truth-surface coverage list, the named-runtime-consumer set the seed asserts is live, and the named failure-drill ids the per-row drills must draw from. Rows conform to the row schema; the envelope cannot relax that contract.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "status",
    "matrix_id",
    "owner_dri",
    "overview_page",
    "silent_deployment_design_packet_ref",
    "install_profile_card_source",
    "state_root_map_source",
    "row_schema_ref",
    "build_identity_ref",
    "validation_lane_ref",
    "install_mode_class_vocabulary",
    "channel_class_vocabulary",
    "updater_owner_class_vocabulary",
    "binary_root_class_vocabulary",
    "side_by_side_relation_class_vocabulary",
    "file_association_ownership_class_vocabulary",
    "protocol_handler_ownership_class_vocabulary",
    "revert_path_class_vocabulary",
    "silent_deployment_baseline_class_vocabulary",
    "m1_truth_surface_class_vocabulary",
    "failure_drill_id_vocabulary",
    "named_runtime_consumers",
    "required_install_mode_coverage",
    "required_m1_truth_surface_coverage",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": ["seeded", "stabilising", "stable"]
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "matrix_id": {
      "type": "string",
      "const": "m1_install_topology_truth_seed"
    },
    "owner_dri": {
      "type": "string",
      "pattern": "^@[a-zA-Z0-9_-]+$"
    },
    "overview_page": {
      "type": "string",
      "const": "docs/install/m1_install_topology_truth.md"
    },
    "silent_deployment_design_packet_ref": {
      "type": "string",
      "const": "design/m1/silent_deployment_baseline.md"
    },
    "install_profile_card_source": {
      "type": "string",
      "minLength": 1,
      "description": "Upstream canonical install-profile card source the seed projects against."
    },
    "state_root_map_source": {
      "type": "string",
      "minLength": 1,
      "description": "Upstream canonical state-root map source the seed projects against."
    },
    "silent_deployment_seed_source": {
      "type": "string",
      "minLength": 1,
      "description": "Optional reference to the upstream silent-deployment return-code seed."
    },
    "row_schema_ref": {
      "type": "string",
      "const": "schemas/install/install_topology_truth_row.schema.json"
    },
    "build_identity_ref": {
      "type": "string",
      "minLength": 1
    },
    "validation_lane_ref": {
      "type": "string",
      "minLength": 1
    },
    "install_mode_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": { "type": "string", "minLength": 1 },
      "description": "Closed install-mode vocabulary the seed asserts. MUST agree with the row schema's install_mode_class $defs enum."
    },
    "channel_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": { "type": "string", "minLength": 1 }
    },
    "updater_owner_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "items": { "type": "string", "minLength": 1 }
    },
    "binary_root_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "items": { "type": "string", "minLength": 1 }
    },
    "side_by_side_relation_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "items": { "type": "string", "minLength": 1 }
    },
    "file_association_ownership_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 2,
      "items": { "type": "string", "minLength": 1 }
    },
    "protocol_handler_ownership_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 2,
      "items": { "type": "string", "minLength": 1 }
    },
    "revert_path_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "items": { "type": "string", "minLength": 1 }
    },
    "silent_deployment_baseline_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "items": { "type": "string", "minLength": 1 },
      "description": "Closed silent-deployment baseline vocabulary. M1 baseline forbids 'managed_silent_full'; the absence of that token is intentional and the runner asserts it stays out."
    },
    "m1_truth_surface_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": { "type": "string", "minLength": 1 }
    },
    "failure_drill_id_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "description": "Closed vocabulary of named failure drills the per-row failure_drill blocks must draw from."
    },
    "named_runtime_consumers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "consumer_id",
          "consumer_class",
          "consumer_ref",
          "consumed_fields"
        ],
        "properties": {
          "consumer_id": { "type": "string", "minLength": 1 },
          "consumer_class": {
            "type": "string",
            "enum": [
              "review_docs_landing_page",
              "design_packet",
              "ci_schema_validator",
              "support_or_release_surface",
              "docs_or_help_surface"
            ]
          },
          "consumer_ref": { "type": "string", "minLength": 1 },
          "consumed_fields": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "notes": { "type": "string" }
        }
      },
      "description": "Named live consumers that read the truth seed. The lane resolves consumer_ref on disk and asserts consumed_fields is non-empty."
    },
    "required_install_mode_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "per_user_installed",
          "per_machine_installed",
          "portable",
          "offline_bundle",
          "managed_deployed",
          "side_by_side_preview"
        ]
      },
      "description": "Install-mode classes that MUST appear at least once across the entries."
    },
    "required_m1_truth_surface_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "help_about",
          "diagnostics",
          "support_export",
          "release_evidence",
          "cli_help"
        ]
      },
      "description": "M1 truth-surface families that MUST appear at least once across the entries."
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "install_topology_truth_row.schema.json"
      }
    }
  }
}
