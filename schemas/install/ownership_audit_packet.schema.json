{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/install/ownership_audit_packet.schema.json",
  "title": "Install ownership audit packet",
  "description": "Desktop-entry ownership audit projecting which channel/build owns each OS handoff surface (file association, protocol handler, default-browser callback, deep-link intent, recent item) across side-by-side channels and portable installs. The packet references an install topology alpha packet and proves that deep links route through the same trust, preview, and scope checks as in-product invocation.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "packet_id",
    "topology_packet_ref",
    "rows"
  ],
  "additionalProperties": false,
  "properties": {
    "record_kind": {
      "const": "install_ownership_audit_packet"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "shared_contract_ref": {
      "const": "install:ownership_audit:v1"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "topology_packet_ref": {
      "type": "string",
      "minLength": 1
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ownership_audit_row" }
    }
  },
  "$defs": {
    "platform_class": {
      "enum": [
        "windows",
        "macos",
        "linux",
        "air_gap_bundle_target"
      ]
    },
    "channel_class": {
      "enum": [
        "stable",
        "preview",
        "beta",
        "lts",
        "portable_stable",
        "portable_preview"
      ]
    },
    "install_mode_class": {
      "enum": [
        "per_user_installed",
        "per_machine_installed",
        "portable",
        "offline_bundle",
        "managed_deployed",
        "side_by_side_preview"
      ]
    },
    "channel_layout_class": {
      "enum": [
        "stable_only",
        "stable_and_preview_side_by_side",
        "stable_and_portable_beside",
        "stable_and_managed_beside",
        "portable_only",
        "air_gapped_bundle_only",
        "three_channel_mixed"
      ]
    },
    "handoff_surface_class": {
      "enum": [
        "file_association",
        "protocol_handler",
        "default_browser_callback",
        "deep_link_intent",
        "recent_item_registration",
        "default_open_behavior"
      ]
    },
    "owner_verdict_class": {
      "enum": [
        "selected_owner",
        "candidate_only",
        "not_registered",
        "admin_policy_owned",
        "managed_fleet_owned",
        "displaced_owner"
      ]
    },
    "portable_ownership_claim": {
      "enum": [
        "never_claims_host_global_ownership",
        "not_applicable"
      ]
    },
    "managed_ownership_claim": {
      "enum": [
        "admin_policy_owns_handler",
        "managed_ring_owns_handler",
        "user_visible_not_overrideable",
        "not_applicable"
      ]
    },
    "side_by_side_disclosure_class": {
      "enum": [
        "per_channel_suffixed_scheme",
        "user_or_admin_selected_default_never_last_writer_wins",
        "channel_owner_summary_in_review",
        "handler_owner_change_preview_before_commit",
        "portable_does_not_steal_installed_ownership",
        "managed_owner_shown_not_overrideable",
        "not_applicable"
      ]
    },
    "deep_link_route_check_class": {
      "enum": [
        "origin_trust",
        "reviewed_sheet_preview",
        "target_scope",
        "single_use_replay",
        "handler_ownership_verification"
      ]
    },
    "ownership_audit_row": {
      "type": "object",
      "required": [
        "audit_row_id",
        "topology_row_ref",
        "platform_class",
        "channel_layout",
        "owning_install_mode_class",
        "owning_channel_class",
        "handoff_surface_class",
        "owner_verdict",
        "candidate_owner_channels",
        "coexisting_channels",
        "portable_claim",
        "managed_claim",
        "side_by_side_disclosure",
        "silent_steal_blocked",
        "deep_link_route_checks",
        "in_product_invocation_uses_same_checks",
        "rationale"
      ],
      "additionalProperties": false,
      "properties": {
        "audit_row_id": { "type": "string", "minLength": 1 },
        "topology_row_ref": { "type": "string", "minLength": 1 },
        "platform_class": { "$ref": "#/$defs/platform_class" },
        "channel_layout": { "$ref": "#/$defs/channel_layout_class" },
        "owning_install_mode_class": { "$ref": "#/$defs/install_mode_class" },
        "owning_channel_class": { "$ref": "#/$defs/channel_class" },
        "handoff_surface_class": { "$ref": "#/$defs/handoff_surface_class" },
        "owner_verdict": { "$ref": "#/$defs/owner_verdict_class" },
        "selected_owner_channel": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/channel_class" }
          ]
        },
        "candidate_owner_channels": {
          "type": "array",
          "items": { "$ref": "#/$defs/channel_class" }
        },
        "coexisting_channels": {
          "type": "array",
          "items": { "$ref": "#/$defs/channel_class" }
        },
        "portable_claim": { "$ref": "#/$defs/portable_ownership_claim" },
        "managed_claim": { "$ref": "#/$defs/managed_ownership_claim" },
        "side_by_side_disclosure": {
          "type": "array",
          "items": { "$ref": "#/$defs/side_by_side_disclosure_class" }
        },
        "silent_steal_blocked": { "type": "boolean" },
        "deep_link_route_checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/deep_link_route_check_class" }
        },
        "in_product_invocation_uses_same_checks": { "type": "boolean" },
        "displaced_owner_diagnostic_ref": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    }
  }
}
