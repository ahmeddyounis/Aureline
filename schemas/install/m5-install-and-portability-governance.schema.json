{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/install/m5-install-and-portability-governance.schema.json",
  "title": "Aureline M5 install-topology, configuration-portability, sync-device, and auth-recovery governance matrix",
  "description": "Schema for the m5_install_and_portability_governance_matrix packet. The packet aggregates the stable-line install, settings, sync, and identity lanes into one qualification report, freezing one governance row per claimed M5 install/config/auth lane (desktop-stable, desktop-preview, portable-install, managed-fleet, marketplace-companion, cli-headless, sync-device). Each row is pinned to one distinct install mode (system, user, portable, managed, marketplace) and to the canonical install-truth packet it draws evidence from, and records the owner, channel-and-ring topology, state-root class, portable/export class, effective-setting scope, whether the binary is verified (signed-verified, platform-trusted, self-signed, unverified), whether the install topology is supported (supported, side-by-side-bounded, experimental, unsupported), whether portable/export state is fresh (current, aging, stale, missing), whether the device participates in sync (active, degraded, offline, blocked), what account-recovery posture it can reach (passkey-verified, system-browser-fallback, local-only-continuity, recovery-blocked), and whether its local durable state remains authoritative (authoritative, local-only-fallback, policy-restricted); it surfaces stable install-root and state-root identity namespaces, supported scope or slice labels, caveats, stale or narrowing fields, the source packet, a machine-readable governance receipt, and release-evidence, help/About, support-export, and diagnostics refs so those surfaces ingest the same packet rather than parallel spreadsheets. A non-inheriting governance gate derives the assurance label that may be published: an unverified binary, an unsupported install topology, a stale portable-state package, a blocked sync apply, a missing passkey, or a policy-limited recovery cannot publish a verified label, and the admission outcome records whether the gate admitted the lane at full trust, admitted it bounded, admitted it pending retest, or refused it. A desktop, marketplace, companion, managed, preview, portable, or sync lane never silently widens install or auth language, one row is required per claimed lane so no lane inherits a verified label, every required consumer surface (release center, Help/About, support export, diagnostics, CLI, admin docs) binds to the packet and narrows with it, and the recorded published label, admission outcome, and downgrade reasons must equal the recomputed gate decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "install_identity_scheme",
    "lanes",
    "install_modes",
    "channel_rings",
    "state_root_classes",
    "portable_export_classes",
    "effective_setting_scopes",
    "assurance_labels",
    "install_verification_states",
    "install_topology_support_states",
    "portable_state_freshness_states",
    "sync_device_states",
    "auth_recovery_postures",
    "local_continuity_states",
    "downgrade_paths",
    "downgrade_reasons",
    "admission_outcomes",
    "consumer_surfaces",
    "lane_rows",
    "consumer_bindings",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_install_and_portability_governance_matrix" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "install_identity_scheme": { "$ref": "#/$defs/non_empty_string" },
    "lanes": { "type": "array", "items": { "$ref": "#/$defs/lane" } },
    "install_modes": { "type": "array", "items": { "$ref": "#/$defs/install_mode" } },
    "channel_rings": { "type": "array", "items": { "$ref": "#/$defs/channel_ring" } },
    "state_root_classes": { "type": "array", "items": { "$ref": "#/$defs/state_root_class" } },
    "portable_export_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/portable_export_class" }
    },
    "effective_setting_scopes": {
      "type": "array",
      "items": { "$ref": "#/$defs/effective_setting_scope" }
    },
    "assurance_labels": { "type": "array", "items": { "$ref": "#/$defs/assurance" } },
    "install_verification_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/install_verification" }
    },
    "install_topology_support_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/install_topology_support" }
    },
    "portable_state_freshness_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/portable_state_freshness" }
    },
    "sync_device_states": { "type": "array", "items": { "$ref": "#/$defs/sync_device_state" } },
    "auth_recovery_postures": {
      "type": "array",
      "items": { "$ref": "#/$defs/auth_recovery_posture" }
    },
    "local_continuity_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/local_continuity" }
    },
    "downgrade_paths": { "type": "array", "items": { "$ref": "#/$defs/downgrade_path" } },
    "downgrade_reasons": { "type": "array", "items": { "$ref": "#/$defs/downgrade_reason" } },
    "admission_outcomes": { "type": "array", "items": { "$ref": "#/$defs/admission_outcome" } },
    "consumer_surfaces": { "type": "array", "items": { "$ref": "#/$defs/consumer_surface" } },
    "lane_rows": { "type": "array", "items": { "$ref": "#/$defs/lane_row" } },
    "consumer_bindings": { "type": "array", "items": { "$ref": "#/$defs/consumer_binding" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "lane": {
      "enum": [
        "desktop_stable",
        "desktop_preview",
        "portable_install",
        "managed_fleet",
        "marketplace_companion",
        "cli_headless",
        "sync_device"
      ]
    },
    "install_mode": {
      "enum": ["system", "user", "portable", "managed", "marketplace"]
    },
    "channel_ring": {
      "enum": [
        "stable_broad",
        "stable_pinned",
        "preview_early_access",
        "preview_canary",
        "nightly_canary",
        "managed_pinned"
      ]
    },
    "state_root_class": {
      "enum": [
        "isolated_per_install",
        "shared_user_scope",
        "portable_root",
        "managed_root",
        "ephemeral_sandbox"
      ]
    },
    "portable_export_class": {
      "enum": [
        "native_state",
        "portable_package",
        "export_archive",
        "imported_package",
        "not_portable"
      ]
    },
    "effective_setting_scope": {
      "enum": [
        "default_baseline",
        "user_scoped",
        "workspace_scoped",
        "managed_enforced",
        "synced_overlay"
      ]
    },
    "assurance": {
      "enum": ["verified", "bounded", "retest_pending", "withheld"]
    },
    "install_verification": {
      "enum": ["signed_verified", "platform_trusted", "self_signed", "unverified"]
    },
    "install_topology_support": {
      "enum": ["supported", "side_by_side_bounded", "experimental", "unsupported"]
    },
    "portable_state_freshness": {
      "enum": ["current", "aging", "stale", "missing"]
    },
    "sync_device_state": {
      "enum": ["active", "degraded", "offline", "blocked"]
    },
    "auth_recovery_posture": {
      "enum": [
        "passkey_verified",
        "system_browser_fallback",
        "local_only_continuity",
        "recovery_blocked"
      ]
    },
    "local_continuity": {
      "enum": ["authoritative", "local_only_fallback", "policy_restricted"]
    },
    "downgrade_path": {
      "enum": [
        "verify_install_signature",
        "switch_supported_topology",
        "refresh_portable_state",
        "restore_sync_apply",
        "enroll_passkey",
        "request_recovery_policy",
        "withhold_claim",
        "none"
      ]
    },
    "downgrade_reason": {
      "enum": [
        "unverified_install",
        "unsupported_install_topology",
        "stale_portable_state",
        "blocked_sync_apply",
        "missing_passkey",
        "policy_limited_recovery"
      ]
    },
    "admission_outcome": {
      "enum": ["admit_full", "admit_bounded", "admit_retest", "refuse"]
    },
    "consumer_surface": {
      "enum": [
        "release_center",
        "help_about",
        "support_export",
        "diagnostics",
        "cli",
        "admin_docs"
      ]
    },
    "lane_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_id",
        "lane",
        "install_mode",
        "channel_ring",
        "state_root_class",
        "portable_export_class",
        "effective_setting_scope",
        "owner",
        "install_verification",
        "install_topology_support",
        "portable_state_freshness",
        "sync_device_state",
        "auth_recovery_posture",
        "local_continuity",
        "install_root_namespace",
        "state_root_namespace",
        "declared_assurance",
        "published_assurance",
        "admission_outcome",
        "downgrade_reasons",
        "downgrade_path",
        "supported_scopes",
        "caveats",
        "stale_or_missing_fields",
        "packet_ref",
        "conformance_ref",
        "evidence_ref",
        "governance_receipt_ref",
        "release_evidence_ref",
        "help_about_ref",
        "support_export_ref",
        "diagnostics_ref",
        "note"
      ],
      "properties": {
        "lane_id": { "$ref": "#/$defs/non_empty_string" },
        "lane": { "$ref": "#/$defs/lane" },
        "install_mode": { "$ref": "#/$defs/install_mode" },
        "channel_ring": { "$ref": "#/$defs/channel_ring" },
        "state_root_class": { "$ref": "#/$defs/state_root_class" },
        "portable_export_class": { "$ref": "#/$defs/portable_export_class" },
        "effective_setting_scope": { "$ref": "#/$defs/effective_setting_scope" },
        "owner": { "$ref": "#/$defs/non_empty_string" },
        "install_verification": { "$ref": "#/$defs/install_verification" },
        "install_topology_support": { "$ref": "#/$defs/install_topology_support" },
        "portable_state_freshness": { "$ref": "#/$defs/portable_state_freshness" },
        "sync_device_state": { "$ref": "#/$defs/sync_device_state" },
        "auth_recovery_posture": { "$ref": "#/$defs/auth_recovery_posture" },
        "local_continuity": { "$ref": "#/$defs/local_continuity" },
        "install_root_namespace": { "$ref": "#/$defs/non_empty_string" },
        "state_root_namespace": { "$ref": "#/$defs/non_empty_string" },
        "declared_assurance": { "$ref": "#/$defs/assurance" },
        "published_assurance": { "$ref": "#/$defs/assurance" },
        "admission_outcome": { "$ref": "#/$defs/admission_outcome" },
        "downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason" }
        },
        "downgrade_path": { "$ref": "#/$defs/downgrade_path" },
        "supported_scopes": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "caveats": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "stale_or_missing_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "conformance_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "governance_receipt_ref": { "$ref": "#/$defs/non_empty_string" },
        "release_evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "help_about_ref": { "$ref": "#/$defs/non_empty_string" },
        "support_export_ref": { "$ref": "#/$defs/non_empty_string" },
        "diagnostics_ref": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "consumer_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer_surface",
        "binding_ref",
        "governance_packet_id_ref",
        "ingests_governance_matrix",
        "preserves_published_labels",
        "preserves_downgrade_paths",
        "narrows_on_downgrade",
        "raw_private_material_excluded"
      ],
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/consumer_surface" },
        "binding_ref": { "$ref": "#/$defs/non_empty_string" },
        "governance_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "ingests_governance_matrix": { "type": "boolean" },
        "preserves_published_labels": { "type": "boolean" },
        "preserves_downgrade_paths": { "type": "boolean" },
        "narrows_on_downgrade": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_lanes",
        "lane_count",
        "verified_lanes",
        "bounded_lanes",
        "retest_pending_lanes",
        "withheld_lanes",
        "admit_full_decisions",
        "admit_bounded_decisions",
        "admit_retest_decisions",
        "refuse_decisions",
        "downgraded_lanes",
        "trust_sensitive_lanes",
        "unverified_install_lanes",
        "unsupported_topology_lanes",
        "stale_portable_lanes",
        "blocked_sync_lanes",
        "degraded_recovery_lanes",
        "lanes_with_downgrade_reasons",
        "local_only_fallback_lanes",
        "policy_restricted_lanes"
      ],
      "properties": {
        "total_lanes": { "type": "integer", "minimum": 0 },
        "lane_count": { "type": "integer", "minimum": 0 },
        "verified_lanes": { "type": "integer", "minimum": 0 },
        "bounded_lanes": { "type": "integer", "minimum": 0 },
        "retest_pending_lanes": { "type": "integer", "minimum": 0 },
        "withheld_lanes": { "type": "integer", "minimum": 0 },
        "admit_full_decisions": { "type": "integer", "minimum": 0 },
        "admit_bounded_decisions": { "type": "integer", "minimum": 0 },
        "admit_retest_decisions": { "type": "integer", "minimum": 0 },
        "refuse_decisions": { "type": "integer", "minimum": 0 },
        "downgraded_lanes": { "type": "integer", "minimum": 0 },
        "trust_sensitive_lanes": { "type": "integer", "minimum": 0 },
        "unverified_install_lanes": { "type": "integer", "minimum": 0 },
        "unsupported_topology_lanes": { "type": "integer", "minimum": 0 },
        "stale_portable_lanes": { "type": "integer", "minimum": 0 },
        "blocked_sync_lanes": { "type": "integer", "minimum": 0 },
        "degraded_recovery_lanes": { "type": "integer", "minimum": 0 },
        "lanes_with_downgrade_reasons": { "type": "integer", "minimum": 0 },
        "local_only_fallback_lanes": { "type": "integer", "minimum": 0 },
        "policy_restricted_lanes": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
