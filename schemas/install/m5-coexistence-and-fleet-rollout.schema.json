{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/install/m5-coexistence-and-fleet-rollout.schema.json",
  "title": "Aureline M5 coexistence-and-fleet-rollout packet",
  "description": "Schema for the m5_coexistence_and_fleet_rollout packet. The packet records one coexistence lane per M5 side-by-side install family (stable-broad, preview-side-by-side, portable, managed, mirror-offline), exposing for each its state-root separation (isolated, bounded-namespaced, import-linked, colliding), first-run import choice, update-marker ownership (exclusive-owned, scoped-shared, contested-last-writer), and per-surface handler precedence for file associations, deep links, and protocol handlers (sole-owner, precedence-declared, user-arbitrated, last-writer-wins). A non-inheriting coexistence gate derives the support label that may be published: an unverified binary, a shared or colliding state root, a contested update marker, a last-writer-wins handler, or a governance lane that was itself narrowed cannot publish a verified label, and the published support never exceeds the governance lane the family is pinned to via governs_lane/governs_assurance (validated against the m5_install_and_portability_governance_matrix packet). Canary, pilot, broad, and LTS rollout rings each publish posture, rollback, and evidence-freshness; mirror and air-gap imports record detached-signature verification, freshness, and review state. Drills replay the wrong-target-launch, handler-takeover, stale-mirror, and managed-package-drift incidents and prove the object detects each. Every required consumer surface (release center, About, support export, diagnostics, CLI, admin docs) binds to the packet and narrows with it; the recorded published support, narrow reasons, and recovery path must equal the recomputed gate decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "coexistence_identity_scheme",
    "governance_packet_id_ref",
    "families",
    "install_modes",
    "channels",
    "state_root_separations",
    "import_choices",
    "update_marker_ownerships",
    "handler_surfaces",
    "handler_precedence_classes",
    "install_verification_states",
    "rollout_rings",
    "ring_postures",
    "rollback_states",
    "evidence_freshness_states",
    "mirror_sources",
    "mirror_signature_verifications",
    "mirror_review_states",
    "assurance_labels",
    "narrow_reasons",
    "recovery_paths",
    "incidents",
    "consumers",
    "lanes",
    "rings",
    "mirror_imports",
    "drills",
    "consumer_bindings",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "const": "m5_coexistence_and_fleet_rollout" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "coexistence_identity_scheme": { "$ref": "#/$defs/non_empty_string" },
    "governance_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
    "families": { "type": "array", "items": { "$ref": "#/$defs/family" } },
    "install_modes": { "type": "array", "items": { "$ref": "#/$defs/install_mode" } },
    "channels": { "type": "array", "items": { "$ref": "#/$defs/channel" } },
    "state_root_separations": {
      "type": "array",
      "items": { "$ref": "#/$defs/state_root_separation" }
    },
    "import_choices": { "type": "array", "items": { "$ref": "#/$defs/import_choice" } },
    "update_marker_ownerships": {
      "type": "array",
      "items": { "$ref": "#/$defs/update_marker_ownership" }
    },
    "handler_surfaces": { "type": "array", "items": { "$ref": "#/$defs/handler_surface" } },
    "handler_precedence_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/handler_precedence_class" }
    },
    "install_verification_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/install_verification" }
    },
    "rollout_rings": { "type": "array", "items": { "$ref": "#/$defs/ring" } },
    "ring_postures": { "type": "array", "items": { "$ref": "#/$defs/ring_posture" } },
    "rollback_states": { "type": "array", "items": { "$ref": "#/$defs/rollback_state" } },
    "evidence_freshness_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_freshness" }
    },
    "mirror_sources": { "type": "array", "items": { "$ref": "#/$defs/mirror_source" } },
    "mirror_signature_verifications": {
      "type": "array",
      "items": { "$ref": "#/$defs/mirror_signature_verification" }
    },
    "mirror_review_states": { "type": "array", "items": { "$ref": "#/$defs/mirror_review_state" } },
    "assurance_labels": { "type": "array", "items": { "$ref": "#/$defs/assurance" } },
    "narrow_reasons": { "type": "array", "items": { "$ref": "#/$defs/narrow_reason" } },
    "recovery_paths": { "type": "array", "items": { "$ref": "#/$defs/recovery_path" } },
    "incidents": { "type": "array", "items": { "$ref": "#/$defs/incident" } },
    "consumers": { "type": "array", "items": { "$ref": "#/$defs/consumer" } },
    "lanes": { "type": "array", "items": { "$ref": "#/$defs/lane" } },
    "rings": { "type": "array", "items": { "$ref": "#/$defs/ring_row" } },
    "mirror_imports": { "type": "array", "items": { "$ref": "#/$defs/mirror_import" } },
    "drills": { "type": "array", "items": { "$ref": "#/$defs/drill" } },
    "consumer_bindings": { "type": "array", "items": { "$ref": "#/$defs/consumer_binding" } },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "family": {
      "enum": ["stable_broad", "preview_side_by_side", "portable", "managed", "mirror_offline"]
    },
    "install_mode": { "enum": ["system", "user", "portable", "managed", "marketplace"] },
    "channel": {
      "enum": [
        "stable_broad",
        "stable_pinned",
        "preview_early_access",
        "preview_canary",
        "nightly_canary",
        "managed_pinned"
      ]
    },
    "state_root_separation": {
      "enum": ["isolated", "bounded_namespaced", "import_linked", "colliding"]
    },
    "import_choice": {
      "enum": ["fresh_state", "copy_from_sibling", "decline_import", "mirror_import", "link_shared"]
    },
    "update_marker_ownership": {
      "enum": ["exclusive_owned", "scoped_shared", "contested_last_writer"]
    },
    "handler_surface": { "enum": ["file_association", "deep_link", "protocol_handler"] },
    "handler_precedence_class": {
      "enum": ["sole_owner", "precedence_declared", "user_arbitrated", "last_writer_wins"]
    },
    "install_verification": {
      "enum": ["signed_verified", "platform_trusted", "self_signed", "unverified"]
    },
    "ring": { "enum": ["canary", "pilot", "broad", "lts"] },
    "ring_posture": { "enum": ["promoted", "soaking", "held", "rolled_back"] },
    "rollback_state": { "enum": ["available", "available_bounded", "expired", "missing"] },
    "evidence_freshness": { "enum": ["current", "aging", "stale", "missing"] },
    "mirror_source": { "enum": ["managed_mirror", "air_gap_media"] },
    "mirror_signature_verification": {
      "enum": ["detached_signature_verified", "checksum_only", "unverified"]
    },
    "mirror_review_state": { "enum": ["reviewed", "pending_review", "rejected"] },
    "assurance": { "enum": ["verified", "bounded", "retest_pending", "withheld"] },
    "narrow_reason": {
      "enum": [
        "unverified_install",
        "shared_state_root",
        "contested_update_marker",
        "contested_handler",
        "governance_narrowed"
      ]
    },
    "recovery_path": {
      "enum": [
        "reverify_install",
        "isolate_state_root",
        "claim_update_marker",
        "declare_handler_precedence",
        "follow_governance_recovery",
        "withhold_claim",
        "none"
      ]
    },
    "incident": {
      "enum": ["wrong_target_launch", "handler_takeover", "stale_mirror", "managed_package_drift"]
    },
    "consumer": {
      "enum": ["release_center", "about", "support_export", "diagnostics", "cli", "admin_docs"]
    },
    "governs_lane": {
      "enum": [
        "desktop_stable",
        "desktop_preview",
        "portable_install",
        "managed_fleet",
        "marketplace_companion",
        "cli_headless",
        "sync_device"
      ]
    },
    "handler_precedence_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "registered_owner", "precedence", "precedence_rule"],
      "properties": {
        "surface": { "$ref": "#/$defs/handler_surface" },
        "registered_owner": { "$ref": "#/$defs/non_empty_string" },
        "precedence": { "$ref": "#/$defs/handler_precedence_class" },
        "precedence_rule": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_id",
        "family",
        "display_name",
        "install_mode",
        "channel",
        "state_root_separation",
        "state_root_label",
        "import_choice",
        "update_marker_ownership",
        "handler_precedence",
        "install_verification",
        "owner",
        "governs_lane",
        "governs_assurance",
        "declared_support",
        "published_support",
        "narrow_reasons",
        "recovery_path",
        "supported_scopes",
        "caveats",
        "stale_or_missing_fields",
        "coexistence_ref",
        "note"
      ],
      "properties": {
        "lane_id": { "$ref": "#/$defs/non_empty_string" },
        "family": { "$ref": "#/$defs/family" },
        "display_name": { "$ref": "#/$defs/non_empty_string" },
        "install_mode": { "$ref": "#/$defs/install_mode" },
        "channel": { "$ref": "#/$defs/channel" },
        "state_root_separation": { "$ref": "#/$defs/state_root_separation" },
        "state_root_label": { "$ref": "#/$defs/non_empty_string" },
        "import_choice": { "$ref": "#/$defs/import_choice" },
        "update_marker_ownership": { "$ref": "#/$defs/update_marker_ownership" },
        "handler_precedence": {
          "type": "array",
          "items": { "$ref": "#/$defs/handler_precedence_row" }
        },
        "install_verification": { "$ref": "#/$defs/install_verification" },
        "owner": { "$ref": "#/$defs/non_empty_string" },
        "governs_lane": { "$ref": "#/$defs/governs_lane" },
        "governs_assurance": { "$ref": "#/$defs/assurance" },
        "declared_support": { "$ref": "#/$defs/assurance" },
        "published_support": { "$ref": "#/$defs/assurance" },
        "narrow_reasons": { "type": "array", "items": { "$ref": "#/$defs/narrow_reason" } },
        "recovery_path": { "$ref": "#/$defs/recovery_path" },
        "supported_scopes": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "caveats": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "stale_or_missing_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "coexistence_ref": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "ring_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ring_id",
        "ring",
        "lane_ref",
        "posture",
        "rollback_state",
        "evidence_freshness",
        "evidence_ref",
        "declared_support",
        "published_support",
        "caveats",
        "stale_or_missing_fields",
        "note"
      ],
      "properties": {
        "ring_id": { "$ref": "#/$defs/non_empty_string" },
        "ring": { "$ref": "#/$defs/ring" },
        "lane_ref": { "$ref": "#/$defs/family" },
        "posture": { "$ref": "#/$defs/ring_posture" },
        "rollback_state": { "$ref": "#/$defs/rollback_state" },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness" },
        "evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "declared_support": { "$ref": "#/$defs/assurance" },
        "published_support": { "$ref": "#/$defs/assurance" },
        "caveats": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "stale_or_missing_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "mirror_import": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "import_id",
        "source",
        "target_family",
        "signature_verification",
        "signature_ref",
        "freshness",
        "review_state",
        "declared_support",
        "published_support",
        "caveats",
        "stale_or_missing_fields",
        "note"
      ],
      "properties": {
        "import_id": { "$ref": "#/$defs/non_empty_string" },
        "source": { "$ref": "#/$defs/mirror_source" },
        "target_family": { "$ref": "#/$defs/family" },
        "signature_verification": { "$ref": "#/$defs/mirror_signature_verification" },
        "signature_ref": { "$ref": "#/$defs/non_empty_string" },
        "freshness": { "$ref": "#/$defs/evidence_freshness" },
        "review_state": { "$ref": "#/$defs/mirror_review_state" },
        "declared_support": { "$ref": "#/$defs/assurance" },
        "published_support": { "$ref": "#/$defs/assurance" },
        "caveats": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "stale_or_missing_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "drill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drill_id",
        "incident",
        "target_ref",
        "scenario",
        "expected_signal",
        "observed_signal",
        "detected",
        "resolves_to"
      ],
      "properties": {
        "drill_id": { "$ref": "#/$defs/non_empty_string" },
        "incident": { "$ref": "#/$defs/incident" },
        "target_ref": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/non_empty_string" },
        "expected_signal": { "$ref": "#/$defs/non_empty_string" },
        "observed_signal": { "$ref": "#/$defs/non_empty_string" },
        "detected": { "type": "boolean" },
        "resolves_to": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "consumer_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer",
        "binding_ref",
        "rollout_packet_id_ref",
        "ingests_packet",
        "preserves_published_support",
        "preserves_recovery_paths",
        "narrows_on_downgrade",
        "raw_private_material_excluded"
      ],
      "properties": {
        "consumer": { "$ref": "#/$defs/consumer" },
        "binding_ref": { "$ref": "#/$defs/non_empty_string" },
        "rollout_packet_id_ref": { "$ref": "#/$defs/non_empty_string" },
        "ingests_packet": { "type": "boolean" },
        "preserves_published_support": { "type": "boolean" },
        "preserves_recovery_paths": { "type": "boolean" },
        "narrows_on_downgrade": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_lanes",
        "family_count",
        "verified_lanes",
        "bounded_lanes",
        "retest_pending_lanes",
        "withheld_lanes",
        "downgraded_lanes",
        "shared_state_root_lanes",
        "contested_marker_lanes",
        "contested_handler_lanes",
        "governance_narrowed_lanes",
        "total_handler_rows",
        "total_rings",
        "verified_rings",
        "downgraded_rings",
        "total_mirror_imports",
        "detached_signature_verified_imports",
        "drill_count",
        "detected_drill_count"
      ],
      "properties": {
        "total_lanes": { "type": "integer", "minimum": 0 },
        "family_count": { "type": "integer", "minimum": 0 },
        "verified_lanes": { "type": "integer", "minimum": 0 },
        "bounded_lanes": { "type": "integer", "minimum": 0 },
        "retest_pending_lanes": { "type": "integer", "minimum": 0 },
        "withheld_lanes": { "type": "integer", "minimum": 0 },
        "downgraded_lanes": { "type": "integer", "minimum": 0 },
        "shared_state_root_lanes": { "type": "integer", "minimum": 0 },
        "contested_marker_lanes": { "type": "integer", "minimum": 0 },
        "contested_handler_lanes": { "type": "integer", "minimum": 0 },
        "governance_narrowed_lanes": { "type": "integer", "minimum": 0 },
        "total_handler_rows": { "type": "integer", "minimum": 0 },
        "total_rings": { "type": "integer", "minimum": 0 },
        "verified_rings": { "type": "integer", "minimum": 0 },
        "downgraded_rings": { "type": "integer", "minimum": 0 },
        "total_mirror_imports": { "type": "integer", "minimum": 0 },
        "detached_signature_verified_imports": { "type": "integer", "minimum": 0 },
        "drill_count": { "type": "integer", "minimum": 0 },
        "detected_drill_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
