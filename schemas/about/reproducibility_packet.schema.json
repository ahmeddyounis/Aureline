{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/about/reproducibility_packet.schema.json",
  "title": "Aureline reproducibility packet record",
  "description": "Boundary schema for one reproducibility_packet_record frozen in docs/about/about_provenance_and_boundary_contract.md. The packet is the redaction-safe export bundle that links one about_card_record to its exact-build identity, symbol or SBOM availability, provenance bundle refs, public-vs-private issue-routing guidance, and an export-safe summary. Reproducibility packets are the only export form for About / provenance state that crosses the customer, auditor, regulator, partner, community-reviewer, support, or release-evidence boundary. Raw signatures, raw attestations, raw key material, raw SBOM bodies, raw notice text, raw URLs, raw issue-template bodies, raw advisory payloads, raw private mirror endpoints, raw policy bodies, raw tenant identifiers, raw user identifiers, and raw paths never cross this boundary. Adding a new packet_class, packet_state, symbol_class, included_field_class, excluded_field_class, recipient_class, delivery_channel_class, redaction_class, redacted_field_class, route_class, or limitation field is additive-minor and bumps reproducibility_packet_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "$ref": "#/$defs/reproducibility_packet_record",
  "$defs": {
    "reproducibility_packet_schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/non_empty_string" }
      ]
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_ref" },
      "uniqueItems": true
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Short reviewable sentence. Raw secrets, raw license bodies, raw notices, raw URLs, raw advisory payloads, raw issue-template bodies, raw signatures, raw key material, and raw artifact bytes MUST NOT appear."
    },
    "utc_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_utc_datetime": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/utc_datetime" }
      ]
    },
    "packet_id": {
      "type": "string",
      "pattern": "^reproducibility_packet:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "packet_class": {
      "type": "string",
      "enum": [
        "open_local_export",
        "managed_export",
        "mirrored_offline_export",
        "regulated_review_export",
        "community_review_export",
        "release_evidence_export"
      ]
    },
    "packet_state": {
      "type": "string",
      "enum": ["draft", "in_review", "frozen", "superseded", "withdrawn"]
    },
    "product_name_class": {
      "type": "string",
      "enum": ["aureline"]
    },
    "channel_class": {
      "type": "string",
      "enum": [
        "dev_local",
        "nightly",
        "preview",
        "beta",
        "stable",
        "lts",
        "hotfix"
      ]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "about_card_ref",
        "exact_build_identity_ref",
        "running_build_identity_ref",
        "product_name_class",
        "channel_class",
        "build_id",
        "subject_disclosure"
      ],
      "properties": {
        "about_card_ref": { "$ref": "#/$defs/opaque_ref" },
        "exact_build_identity_ref": { "$ref": "#/$defs/opaque_ref" },
        "running_build_identity_ref": { "$ref": "#/$defs/opaque_ref" },
        "product_name_class": { "$ref": "#/$defs/product_name_class" },
        "channel_class": { "$ref": "#/$defs/channel_class" },
        "build_id": { "$ref": "#/$defs/non_empty_string" },
        "subject_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "symbol_class": {
      "type": "string",
      "enum": [
        "source_bundle_attached",
        "symbol_archive_attached",
        "partial_symbols",
        "symbols_omitted_with_reason",
        "not_applicable"
      ]
    },
    "symbol_availability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol_class",
        "symbol_refs",
        "omission_reason",
        "symbol_disclosure"
      ],
      "properties": {
        "symbol_class": { "$ref": "#/$defs/symbol_class" },
        "symbol_refs": { "$ref": "#/$defs/ref_array" },
        "omission_reason": { "$ref": "#/$defs/nullable_string" },
        "symbol_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "sbom_state": {
      "type": "string",
      "enum": [
        "sbom_attached_verified",
        "sbom_attached_unverified",
        "sbom_missing",
        "sbom_stale",
        "sbom_policy_blocked",
        "not_applicable"
      ]
    },
    "sbom_format": {
      "type": "string",
      "enum": [
        "spdx_json",
        "spdx_tag_value",
        "spdx_rdf",
        "cyclonedx_json",
        "cyclonedx_xml"
      ]
    },
    "sbom_availability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sbom_state",
        "sbom_formats",
        "sbom_refs",
        "sbom_disclosure"
      ],
      "properties": {
        "sbom_state": { "$ref": "#/$defs/sbom_state" },
        "sbom_formats": {
          "type": "array",
          "items": { "$ref": "#/$defs/sbom_format" },
          "uniqueItems": true
        },
        "sbom_refs": { "$ref": "#/$defs/ref_array" },
        "sbom_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "provenance_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provenance_badge_refs",
        "signed_attestation_refs",
        "signature_evidence_refs",
        "post_install_disclosure_ref",
        "mirror_or_offline_receipt_refs",
        "advisory_history_refs",
        "release_evidence_refs",
        "bundle_disclosure"
      ],
      "properties": {
        "provenance_badge_refs": { "$ref": "#/$defs/ref_array" },
        "signed_attestation_refs": { "$ref": "#/$defs/ref_array" },
        "signature_evidence_refs": { "$ref": "#/$defs/ref_array" },
        "post_install_disclosure_ref": { "$ref": "#/$defs/opaque_ref" },
        "mirror_or_offline_receipt_refs": { "$ref": "#/$defs/ref_array" },
        "advisory_history_refs": { "$ref": "#/$defs/ref_array" },
        "release_evidence_refs": { "$ref": "#/$defs/ref_array" },
        "bundle_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "route_class": {
      "type": "string",
      "enum": [
        "public_issue_tracker",
        "public_rfc_forum",
        "private_security_channel",
        "private_partner_channel",
        "private_support_channel",
        "benchmark_council_queue",
        "governance_packet_queue"
      ]
    },
    "public_summary_expectation_class": {
      "type": "string",
      "enum": ["required", "recommended", "none", "forbidden"]
    },
    "public_route_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["route_class", "destination_descriptor_ref", "disclosure"],
      "properties": {
        "route_class": {
          "type": "string",
          "enum": ["public_issue_tracker", "public_rfc_forum"]
        },
        "destination_descriptor_ref": { "$ref": "#/$defs/opaque_ref" },
        "disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "private_route_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_class",
        "destination_descriptor_ref",
        "why_private_disclosure",
        "disclosure"
      ],
      "properties": {
        "route_class": {
          "type": "string",
          "enum": [
            "private_security_channel",
            "private_partner_channel",
            "private_support_channel",
            "benchmark_council_queue",
            "governance_packet_queue"
          ]
        },
        "destination_descriptor_ref": { "$ref": "#/$defs/opaque_ref" },
        "why_private_disclosure": { "$ref": "#/$defs/reviewable_sentence" },
        "disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "public_private_routing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_routes",
        "private_routes",
        "default_route_for_packet_class",
        "public_summary_expectation_class",
        "routing_disclosure"
      ],
      "properties": {
        "public_routes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/public_route_row" }
        },
        "private_routes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/private_route_row" }
        },
        "default_route_for_packet_class": { "$ref": "#/$defs/route_class" },
        "public_summary_expectation_class": { "$ref": "#/$defs/public_summary_expectation_class" },
        "routing_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "included_field_class": {
      "type": "string",
      "enum": [
        "build_identity",
        "exact_build_identity_ref",
        "channel_class",
        "tree_state_class",
        "signing_class",
        "signature_state",
        "attestation_state",
        "checksum_state",
        "revocation_state",
        "sbom_state",
        "sbom_formats",
        "sbom_refs",
        "symbol_refs",
        "openness_boundary_rows",
        "active_openness_claim",
        "active_narrowing_reasons",
        "post_install_disclosure_ref",
        "provenance_badge_refs",
        "advisory_history_refs",
        "mirror_or_offline_receipt_refs",
        "community_handoff_routes",
        "release_evidence_refs",
        "limitations"
      ]
    },
    "excluded_field_class": {
      "type": "string",
      "enum": [
        "raw_signature_bytes",
        "raw_attestation_bytes",
        "raw_sbom_body",
        "raw_notice_text",
        "raw_license_body",
        "raw_advisory_payload",
        "raw_issue_template_body",
        "raw_url_strings",
        "raw_private_mirror_endpoint",
        "raw_policy_body",
        "raw_tenant_identifier",
        "raw_user_identifier",
        "raw_path",
        "internal_only_diagnostics_detail"
      ]
    },
    "export_safe_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "openness_summary_sentence",
        "boundary_summary_sentence",
        "reproducibility_summary_sentence",
        "included_field_classes",
        "excluded_field_classes"
      ],
      "properties": {
        "openness_summary_sentence": { "$ref": "#/$defs/reviewable_sentence" },
        "boundary_summary_sentence": { "$ref": "#/$defs/reviewable_sentence" },
        "reproducibility_summary_sentence": { "$ref": "#/$defs/reviewable_sentence" },
        "included_field_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/included_field_class" },
          "uniqueItems": true
        },
        "excluded_field_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/excluded_field_class" },
          "uniqueItems": true
        }
      }
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "public_proof_safe",
        "support_redacted",
        "regulated_review_restricted",
        "internal_only"
      ]
    },
    "redacted_field_class": {
      "type": "string",
      "enum": [
        "raw_signature_bytes",
        "raw_attestation_bytes",
        "raw_sbom_body",
        "raw_notice_text",
        "raw_license_body",
        "raw_advisory_payload",
        "raw_issue_template_body",
        "raw_url_strings",
        "raw_private_mirror_endpoint",
        "raw_policy_body",
        "raw_tenant_identifier",
        "raw_user_identifier",
        "raw_path",
        "internal_only_diagnostics_detail"
      ]
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redaction_class",
        "redaction_rules_ref",
        "redacted_field_classes",
        "redaction_disclosure"
      ],
      "properties": {
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "redaction_rules_ref": { "$ref": "#/$defs/opaque_ref" },
        "redacted_field_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/redacted_field_class" },
          "uniqueItems": true
        },
        "redaction_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "recipient_class": {
      "type": "string",
      "enum": [
        "customer_evaluator",
        "regulator",
        "auditor",
        "community_reviewer",
        "partner",
        "support_engineer",
        "release_evidence_archive",
        "internal_archive"
      ]
    },
    "delivery_channel_class": {
      "type": "string",
      "enum": [
        "in_product_export",
        "support_bundle_attachment",
        "release_evidence_publication",
        "regulated_review_handoff",
        "community_review_publication",
        "partner_contractual_channel",
        "offline_media_handoff"
      ]
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recipient_class",
        "recipient_label",
        "delivery_channel_class",
        "signed_at",
        "signing_evidence_ref",
        "handoff_disclosure"
      ],
      "properties": {
        "recipient_class": { "$ref": "#/$defs/recipient_class" },
        "recipient_label": { "$ref": "#/$defs/non_empty_string" },
        "delivery_channel_class": { "$ref": "#/$defs/delivery_channel_class" },
        "signed_at": { "$ref": "#/$defs/nullable_utc_datetime" },
        "signing_evidence_ref": { "$ref": "#/$defs/nullable_string" },
        "handoff_disclosure": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["captured_at", "stale_after", "freshness_state", "next_review_target"],
      "properties": {
        "captured_at": { "$ref": "#/$defs/utc_datetime" },
        "stale_after": { "$ref": "#/$defs/nullable_string" },
        "freshness_state": {
          "type": "string",
          "enum": [
            "current",
            "warm_cached",
            "known_issues",
            "retest_pending",
            "stale",
            "community_reported",
            "unknown"
          ]
        },
        "next_review_target": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exact_build_identity_refs",
        "post_install_disclosure_refs",
        "provenance_badge_refs",
        "advisory_record_refs",
        "release_evidence_refs",
        "support_bundle_refs",
        "diagnostics_export_refs",
        "destination_descriptor_refs"
      ],
      "properties": {
        "exact_build_identity_refs": { "$ref": "#/$defs/ref_array" },
        "post_install_disclosure_refs": { "$ref": "#/$defs/ref_array" },
        "provenance_badge_refs": { "$ref": "#/$defs/ref_array" },
        "advisory_record_refs": { "$ref": "#/$defs/ref_array" },
        "release_evidence_refs": { "$ref": "#/$defs/ref_array" },
        "support_bundle_refs": { "$ref": "#/$defs/ref_array" },
        "diagnostics_export_refs": { "$ref": "#/$defs/ref_array" },
        "destination_descriptor_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "reproducibility_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reproducibility_packet_schema_version",
        "record_kind",
        "packet_id",
        "packet_class",
        "packet_state",
        "emitted_at",
        "frozen_at",
        "subject",
        "symbol_availability",
        "sbom_availability",
        "provenance_bundle",
        "public_private_routing",
        "export_safe_summary",
        "redaction",
        "handoff",
        "freshness",
        "linkage",
        "limitations",
        "owner",
        "evidence_owner",
        "notes"
      ],
      "properties": {
        "__fixture__": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional worked-fixture prelude. Runtime producers omit this field."
        },
        "reproducibility_packet_schema_version": { "$ref": "#/$defs/reproducibility_packet_schema_version" },
        "record_kind": {
          "type": "string",
          "const": "reproducibility_packet_record"
        },
        "packet_id": { "$ref": "#/$defs/packet_id" },
        "packet_class": { "$ref": "#/$defs/packet_class" },
        "packet_state": { "$ref": "#/$defs/packet_state" },
        "emitted_at": { "$ref": "#/$defs/utc_datetime" },
        "frozen_at": { "$ref": "#/$defs/nullable_utc_datetime" },
        "subject": { "$ref": "#/$defs/subject" },
        "symbol_availability": { "$ref": "#/$defs/symbol_availability" },
        "sbom_availability": { "$ref": "#/$defs/sbom_availability" },
        "provenance_bundle": { "$ref": "#/$defs/provenance_bundle" },
        "public_private_routing": { "$ref": "#/$defs/public_private_routing" },
        "export_safe_summary": { "$ref": "#/$defs/export_safe_summary" },
        "redaction": { "$ref": "#/$defs/redaction" },
        "handoff": { "$ref": "#/$defs/handoff" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "linkage": { "$ref": "#/$defs/linkage" },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewable_sentence" }
        },
        "owner": { "$ref": "#/$defs/non_empty_string" },
        "evidence_owner": { "$ref": "#/$defs/non_empty_string" },
        "notes": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "description": "Frozen, superseded, and withdrawn packets MUST set frozen_at.",
          "if": {
            "properties": {
              "packet_state": { "enum": ["frozen", "superseded", "withdrawn"] }
            },
            "required": ["packet_state"]
          },
          "then": {
            "properties": {
              "frozen_at": { "$ref": "#/$defs/utc_datetime" }
            }
          }
        },
        {
          "description": "External-class packets cannot ship internal_only redaction.",
          "if": {
            "properties": {
              "packet_class": {
                "enum": [
                  "community_review_export",
                  "regulated_review_export",
                  "release_evidence_export",
                  "managed_export"
                ]
              }
            },
            "required": ["packet_class"]
          },
          "then": {
            "properties": {
              "redaction": {
                "properties": {
                  "redaction_class": {
                    "enum": [
                      "metadata_safe_default",
                      "public_proof_safe",
                      "support_redacted",
                      "regulated_review_restricted"
                    ]
                  }
                },
                "required": ["redaction_class"]
              }
            }
          }
        },
        {
          "description": "Mirrored-offline packets MUST include at least one mirror or offline receipt ref so an offline reviewer can replay the import.",
          "if": {
            "properties": {
              "packet_class": { "const": "mirrored_offline_export" }
            },
            "required": ["packet_class"]
          },
          "then": {
            "properties": {
              "provenance_bundle": {
                "properties": {
                  "mirror_or_offline_receipt_refs": { "minItems": 1 }
                },
                "required": ["mirror_or_offline_receipt_refs"]
              }
            }
          }
        },
        {
          "description": "Symbol class symbols_omitted_with_reason MUST carry an omission_reason.",
          "if": {
            "properties": {
              "symbol_availability": {
                "properties": {
                  "symbol_class": { "const": "symbols_omitted_with_reason" }
                },
                "required": ["symbol_class"]
              }
            },
            "required": ["symbol_availability"]
          },
          "then": {
            "properties": {
              "symbol_availability": {
                "properties": {
                  "omission_reason": { "$ref": "#/$defs/non_empty_string" }
                },
                "required": ["omission_reason"]
              }
            }
          }
        },
        {
          "description": "Community-review and regulated-review packets MUST include a public summary expectation that is not 'forbidden' so reviewers know whether a public summary will follow.",
          "if": {
            "properties": {
              "packet_class": {
                "enum": ["community_review_export", "regulated_review_export"]
              }
            },
            "required": ["packet_class"]
          },
          "then": {
            "properties": {
              "public_private_routing": {
                "properties": {
                  "public_summary_expectation_class": {
                    "enum": ["required", "recommended", "none"]
                  }
                },
                "required": ["public_summary_expectation_class"]
              }
            }
          }
        }
      ]
    }
  }
}
