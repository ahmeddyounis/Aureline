{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/identity/admin_audit_packet.schema.json",
  "title": "Aureline admin-audit and export-packet boundary schema",
  "description": "Boundary schema for one admin_audit_packet_record frozen in docs/identity/offline_entitlement_and_policy_seed.md. The admin-audit packet is the typed, export-safe object the admin audit stream, admin export surfaces, support exporter, boundary-manifest tooling, and release evidence read for identity-mode transitions, policy-bundle changes, entitlement lifecycle transitions, seat or device actions, revocation events, and tenant / org switches. One packet carries the event class, typed decision reason, tenant scope, policy epoch, entitlement epoch, actor and target refs, signer identity, distribution posture across live / mirror / file-import / offline paths, and the local-versus-vendor-console explainability envelope so an enterprise claim is reconstructable from the packet without needing a hosted admin console as the only source of truth. Raw session tokens, raw OIDC id tokens, raw SCIM payloads, raw directory attribute values, raw policy rule bodies, raw audit trail bodies from upstream, and raw IP / device fingerprints never cross this boundary; the packet carries opaque refs, typed vocabulary, and reviewable-sentence summaries only. Live OIDC, SCIM, and provider implementations are out of scope at this revision. Adding a new audit_event_class, decision_reason_class, device_action_class, revocation_event_class, entitlement_lifecycle_transition_class, org_switch_class, actor_class, target_kind, distribution_source_class, distribution_freshness_class, or local_vs_vendor_console_explainability_class value is additive-minor and requires an admin_audit_packet_schema_version bump; repurposing an existing value is breaking and requires a new decision row co-signed by security_trust_review, product_scope_review, and compatibility_ecosystem_review.",
  "$ref": "#/$defs/admin_audit_packet_record",
  "$defs": {
    "admin_audit_packet_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this admin-audit packet export. Current value is 1."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in admin exports, support bundles, and boundary-manifest surfaces. Raw session tokens, raw SCIM payloads, raw OIDC id tokens, raw directory attribute values, and raw IP / device fingerprints never appear here."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },

    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "description": "Short reviewable sentence safe for admin consoles, support packets, and release evidence. Raw claim payloads, raw directory attribute values, and raw rule text MUST NOT appear."
    },

    "export_safe_label": {
      "type": "string",
      "minLength": 1,
      "description": "Short export-safe label. Raw URLs, raw tenant names, raw user emails, raw device serial numbers, and raw policy rule text MUST NOT appear."
    },

    "identity_mode": {
      "type": "string",
      "enum": [
        "account_free_local",
        "self_hosted_org",
        "managed_workspace"
      ]
    },

    "deployment_profile_class": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "managed_cloud",
        "air_gapped"
      ]
    },

    "workspace_trust_state": {
      "type": "string",
      "enum": [ "trusted", "restricted" ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "identity_mode", "policy_epoch", "trust_state" ],
      "properties": {
        "identity_mode": { "$ref": "#/$defs/identity_mode" },
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": { "$ref": "#/$defs/workspace_trust_state" },
        "execution_context_id": { "type": "string", "minLength": 1 }
      }
    },

    "audit_event_class": {
      "type": "string",
      "enum": [
        "policy_bundle_change",
        "entitlement_lifecycle_transition",
        "seat_action",
        "device_action",
        "revocation_event",
        "org_switch",
        "identity_mode_transition",
        "admin_console_explainability_assertion"
      ],
      "description": "Closed audit-event vocabulary for the identity lane. Extending this enum is additive-minor."
    },

    "decision_reason_class": {
      "type": "string",
      "enum": [
        "policy_authoring_update",
        "policy_rollback_to_last_known_good",
        "signer_rotation_completed",
        "signer_compromise_response",
        "mirror_integrity_failure_response",
        "tenant_wind_down",
        "tenant_restructure",
        "seat_assigned_by_admin",
        "seat_reassigned_by_admin",
        "seat_revoked_by_admin",
        "seat_paused_by_admin",
        "seat_restored_after_revocation",
        "device_registered_by_user",
        "device_paused_by_admin",
        "device_revoked_by_admin",
        "device_forgotten_by_user",
        "plan_change_by_admin",
        "plan_change_by_billing",
        "quota_reset_on_window_roll",
        "quota_grant_by_admin",
        "quota_revoke_by_admin",
        "entitlement_refresh_completed",
        "entitlement_refresh_declined_stale_snapshot",
        "entitlement_revoked",
        "policy_bundle_revoked",
        "org_switch_user_initiated",
        "org_switch_admin_initiated",
        "org_switch_degraded_into_local",
        "identity_mode_downgrade_managed_to_self_hosted",
        "identity_mode_downgrade_self_hosted_to_account_free",
        "identity_mode_upgrade_account_free_to_self_hosted",
        "identity_mode_upgrade_self_hosted_to_managed",
        "explainability_assertion_recorded",
        "explainability_gap_acknowledged_by_waiver"
      ],
      "description": "Closed decision-reason vocabulary. Every packet carries exactly one decision reason. The vocabulary is intentionally granular so release evidence, admin exports, and support packets can cite a typed reason rather than a free-text field."
    },

    "actor_class": {
      "type": "string",
      "enum": [
        "anonymous_local_user",
        "authenticated_end_user",
        "authenticated_local_admin",
        "authenticated_org_admin",
        "service_account_automation",
        "vendor_managed_automation",
        "signed_policy_bundle_source",
        "signed_entitlement_source",
        "system_scheduled_task"
      ],
      "description": "Closed actor-class vocabulary re-exported from ADR-0001 actor classes plus system / signed-bundle actors. Raw session / subject identities never appear; the actor_ref is an opaque id."
    },

    "target_kind_class": {
      "type": "string",
      "enum": [
        "policy_bundle",
        "entitlement_snapshot",
        "seat_binding",
        "device_record",
        "tenant_or_org",
        "workspace",
        "install_profile_card",
        "credential_store_lock_state",
        "account_boundary",
        "capability_scope"
      ],
      "description": "Closed target-kind vocabulary. Names what the audit event is about."
    },

    "target_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "target_kind", "target_id", "target_label" ],
      "properties": {
        "target_kind": { "$ref": "#/$defs/target_kind_class" },
        "target_id": { "$ref": "#/$defs/opaque_id" },
        "target_label": {
          "$ref": "#/$defs/export_safe_label",
          "description": "Short export-safe label. Raw tenant names, raw user emails, and raw device serial numbers MUST NOT appear."
        },
        "target_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "actor_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "actor_class", "actor_id", "actor_label" ],
      "properties": {
        "actor_class": { "$ref": "#/$defs/actor_class" },
        "actor_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Opaque ref to the actor. Null only for anonymous_local_user."
        },
        "actor_label": {
          "$ref": "#/$defs/export_safe_label",
          "description": "Short export-safe label. Raw emails, raw subject ids, raw directory attribute values, and raw session ids MUST NOT appear."
        },
        "actor_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "tenant_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_or_org_ref",
        "tenant_or_org_label",
        "deployment_profile_scope",
        "install_profile_card_refs",
        "scope_note"
      ],
      "properties": {
        "tenant_or_org_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Opaque ref to the tenant or org. Null for account_free_local identity-mode events."
        },
        "tenant_or_org_label": {
          "$ref": "#/$defs/export_safe_label"
        },
        "deployment_profile_scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/deployment_profile_class" }
        },
        "install_profile_card_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "scope_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "signer_authority_class": {
      "type": "string",
      "enum": [
        "customer_operated_trust_root",
        "vendor_operated_trust_root",
        "cross_signed_transition_root",
        "managed_admin_delegated_signer",
        "build_preload_signer",
        "not_applicable_local_derived"
      ]
    },

    "signer_continuity_state_class": {
      "type": "string",
      "enum": [
        "same_signer_chain",
        "rotated_with_continuity_statement",
        "cross_signed_transition",
        "continuity_review_required",
        "continuity_broken",
        "unknown_offline",
        "not_applicable_local_derived"
      ]
    },

    "signer_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signer_authority_class",
        "signer_authority_ref",
        "continuity_state",
        "previous_signer_refs",
        "continuity_statement_ref",
        "last_verified_at",
        "signing_scope_note"
      ],
      "properties": {
        "signer_authority_class": { "$ref": "#/$defs/signer_authority_class" },
        "signer_authority_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "continuity_state": { "$ref": "#/$defs/signer_continuity_state_class" },
        "previous_signer_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "continuity_statement_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "last_verified_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/monotonic_timestamp" }
          ]
        },
        "signing_scope_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "distribution_source_class": {
      "type": "string",
      "enum": [
        "authoritative_origin",
        "customer_managed_mirror",
        "approved_private_mirror",
        "manual_file_import",
        "offline_transfer_snapshot",
        "local_cache_projection",
        "runtime_preload"
      ]
    },

    "distribution_path_class": {
      "type": "string",
      "enum": [
        "managed_push",
        "managed_pull",
        "mirror_sync",
        "file_import",
        "offline_transfer",
        "local_cache_projection",
        "runtime_preload"
      ]
    },

    "distribution_freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "mirrored_current",
        "mirrored_stale_within_grace",
        "mirrored_stale_past_grace",
        "manual_snapshot_current",
        "manual_snapshot_stale",
        "offline_snapshot_unexpired",
        "offline_snapshot_expired",
        "unknown"
      ]
    },

    "distribution_status_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "distribution_id",
        "source_class",
        "path_class",
        "freshness_class",
        "observed_at",
        "receipt_ref",
        "note"
      ],
      "properties": {
        "distribution_id": { "$ref": "#/$defs/opaque_id" },
        "source_class": { "$ref": "#/$defs/distribution_source_class" },
        "path_class": { "$ref": "#/$defs/distribution_path_class" },
        "freshness_class": { "$ref": "#/$defs/distribution_freshness_class" },
        "observed_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "receipt_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "policy_bundle_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_bundle_ref",
        "bundle_version",
        "policy_epoch",
        "link_note"
      ],
      "properties": {
        "policy_bundle_ref": { "$ref": "#/$defs/opaque_id" },
        "bundle_version": { "type": "string", "minLength": 1 },
        "policy_epoch": { "type": "string", "minLength": 1 },
        "link_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "entitlement_snapshot_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entitlement_snapshot_ref",
        "entitlement_epoch",
        "link_note"
      ],
      "properties": {
        "entitlement_snapshot_ref": { "$ref": "#/$defs/opaque_id" },
        "entitlement_epoch": { "type": "string", "minLength": 1 },
        "link_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "before_after_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "before_state_label",
        "after_state_label",
        "transition_note"
      ],
      "properties": {
        "before_state_label": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/export_safe_label" }
          ],
          "description": "Export-safe label naming the state before the transition. Null when there was no prior state (first-time registration)."
        },
        "after_state_label": { "$ref": "#/$defs/export_safe_label" },
        "transition_note": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "description": "Before / after state envelope for transition-class events. Raw before / after rule bodies, raw directory attribute diffs, and raw session payload diffs MUST NOT appear; only the reviewable labels and note."
    },

    "local_vs_vendor_console_explainability_class": {
      "type": "string",
      "enum": [
        "locally_explainable_from_packet",
        "locally_explainable_with_signed_evidence",
        "vendor_console_required_for_full_detail",
        "vendor_console_only_acknowledged_gap"
      ],
      "description": "Closed local-versus-vendor-console vocabulary. Every packet records which class it belongs to so release evidence, support exports, admin desktops, and boundary-manifest tooling can reconstruct the decision without calling a hosted admin console."
    },

    "explainability_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "explainability_class",
        "locally_inspectable_fields",
        "vendor_console_only_fields",
        "acknowledged_gap_waiver_refs",
        "explainability_note"
      ],
      "properties": {
        "explainability_class": { "$ref": "#/$defs/local_vs_vendor_console_explainability_class" },
        "locally_inspectable_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_sentence" }
        },
        "vendor_console_only_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewable_sentence" }
        },
        "acknowledged_gap_waiver_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "explainability_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },

    "history_links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supersedes_packet_refs",
        "superseded_by_packet_ref",
        "related_packet_refs",
        "support_packet_refs",
        "release_evidence_packet_refs",
        "mutation_journal_refs"
      ],
      "properties": {
        "supersedes_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "superseded_by_packet_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "related_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "support_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "release_evidence_packet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "mutation_journal_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      }
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "name", "scenario" ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "instance_schema_hint": {
      "type": "string",
      "format": "uri-reference"
    },

    "admin_audit_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "admin_audit_packet_schema_version",
        "packet_id",
        "audit_event_class",
        "decision_reason_class",
        "decision_reason_note",
        "tenant_scope",
        "actor_ref",
        "target_refs",
        "before_after_state",
        "policy_epoch",
        "entitlement_epoch",
        "policy_bundle_links",
        "entitlement_snapshot_links",
        "signer_identity",
        "distribution_statuses",
        "explainability_envelope",
        "history_links",
        "policy_context",
        "redaction_class",
        "event_at",
        "minted_at"
      ],
      "properties": {
        "$schema": { "$ref": "#/$defs/instance_schema_hint" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "admin_audit_packet_record" },
        "admin_audit_packet_schema_version": { "$ref": "#/$defs/admin_audit_packet_schema_version" },
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "audit_event_class": { "$ref": "#/$defs/audit_event_class" },
        "decision_reason_class": { "$ref": "#/$defs/decision_reason_class" },
        "decision_reason_note": {
          "$ref": "#/$defs/reviewable_sentence",
          "description": "One-sentence reviewable description of the decision. The field is mandatory on every packet so release evidence and admin exports do not fork on free-text prose."
        },
        "tenant_scope": { "$ref": "#/$defs/tenant_scope" },
        "actor_ref": { "$ref": "#/$defs/actor_ref" },
        "target_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/target_ref" }
        },
        "before_after_state": { "$ref": "#/$defs/before_after_state" },
        "policy_epoch": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Opaque policy epoch at which the event was recorded. Null only for identity_mode_transition events that leave the managed posture and land on account_free_local, where no policy epoch applies."
        },
        "entitlement_epoch": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Opaque entitlement epoch at which the event was recorded. Null only when the event is not bound to an entitlement (for example policy_bundle_change before an entitlement snapshot exists)."
        },
        "policy_bundle_links": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_bundle_link" }
        },
        "entitlement_snapshot_links": {
          "type": "array",
          "items": { "$ref": "#/$defs/entitlement_snapshot_link" }
        },
        "signer_identity": { "$ref": "#/$defs/signer_identity" },
        "distribution_statuses": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/distribution_status_record" }
        },
        "explainability_envelope": { "$ref": "#/$defs/explainability_envelope" },
        "history_links": { "$ref": "#/$defs/history_links" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "event_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "notes": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "description": "policy_bundle_change events MUST link at least one policy bundle.",
          "if": {
            "properties": {
              "audit_event_class": { "const": "policy_bundle_change" }
            },
            "required": [ "audit_event_class" ]
          },
          "then": {
            "properties": {
              "policy_bundle_links": { "minItems": 1 },
              "target_refs": {
                "contains": {
                  "properties": {
                    "target_kind": { "const": "policy_bundle" }
                  },
                  "required": [ "target_kind" ]
                }
              }
            }
          }
        },
        {
          "description": "entitlement_lifecycle_transition events MUST link at least one entitlement snapshot.",
          "if": {
            "properties": {
              "audit_event_class": { "const": "entitlement_lifecycle_transition" }
            },
            "required": [ "audit_event_class" ]
          },
          "then": {
            "properties": {
              "entitlement_snapshot_links": { "minItems": 1 },
              "target_refs": {
                "contains": {
                  "properties": {
                    "target_kind": { "const": "entitlement_snapshot" }
                  },
                  "required": [ "target_kind" ]
                }
              }
            }
          }
        },
        {
          "description": "revocation_event packets MUST name either a policy_bundle or entitlement_snapshot target and supply distribution freshness proof.",
          "if": {
            "properties": {
              "audit_event_class": { "const": "revocation_event" }
            },
            "required": [ "audit_event_class" ]
          },
          "then": {
            "properties": {
              "target_refs": {
                "contains": {
                  "properties": {
                    "target_kind": {
                      "enum": [ "policy_bundle", "entitlement_snapshot" ]
                    }
                  },
                  "required": [ "target_kind" ]
                }
              }
            }
          }
        },
        {
          "description": "device_action and seat_action packets MUST name a device_record or seat_binding target.",
          "if": {
            "properties": {
              "audit_event_class": {
                "enum": [ "device_action", "seat_action" ]
              }
            },
            "required": [ "audit_event_class" ]
          },
          "then": {
            "properties": {
              "target_refs": {
                "contains": {
                  "properties": {
                    "target_kind": {
                      "enum": [ "device_record", "seat_binding" ]
                    }
                  },
                  "required": [ "target_kind" ]
                }
              }
            }
          }
        },
        {
          "description": "org_switch and identity_mode_transition packets MUST name a tenant_or_org or account_boundary target.",
          "if": {
            "properties": {
              "audit_event_class": {
                "enum": [ "org_switch", "identity_mode_transition" ]
              }
            },
            "required": [ "audit_event_class" ]
          },
          "then": {
            "properties": {
              "target_refs": {
                "contains": {
                  "properties": {
                    "target_kind": {
                      "enum": [ "tenant_or_org", "account_boundary" ]
                    }
                  },
                  "required": [ "target_kind" ]
                }
              }
            }
          }
        },
        {
          "description": "account_free_local packets omit tenant binding.",
          "if": {
            "properties": {
              "policy_context": {
                "properties": { "identity_mode": { "const": "account_free_local" } },
                "required": [ "identity_mode" ]
              }
            },
            "required": [ "policy_context" ]
          },
          "then": {
            "properties": {
              "tenant_scope": {
                "properties": {
                  "tenant_or_org_ref": { "type": "null" }
                }
              }
            }
          }
        },
        {
          "description": "vendor_console_only_acknowledged_gap requires at least one waiver ref.",
          "if": {
            "properties": {
              "explainability_envelope": {
                "properties": {
                  "explainability_class": { "const": "vendor_console_only_acknowledged_gap" }
                },
                "required": [ "explainability_class" ]
              }
            },
            "required": [ "explainability_envelope" ]
          },
          "then": {
            "properties": {
              "explainability_envelope": {
                "properties": {
                  "acknowledged_gap_waiver_refs": { "minItems": 1 }
                }
              }
            }
          }
        },
        {
          "description": "entitlement_refresh_declined_stale_snapshot decisions MUST NOT claim authoritative-live distribution.",
          "if": {
            "properties": {
              "decision_reason_class": { "const": "entitlement_refresh_declined_stale_snapshot" }
            },
            "required": [ "decision_reason_class" ]
          },
          "then": {
            "properties": {
              "distribution_statuses": {
                "items": {
                  "properties": {
                    "freshness_class": {
                      "enum": [
                        "mirrored_stale_within_grace",
                        "mirrored_stale_past_grace",
                        "manual_snapshot_stale",
                        "offline_snapshot_unexpired",
                        "offline_snapshot_expired",
                        "unknown"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      ],
      "description": "Admin-audit packet record. One packet per audit-event row. Carries the typed event class, decision reason, tenant scope, actor and target refs, policy and entitlement epochs, linked policy-bundle and entitlement-snapshot refs, signer identity, distribution status across live / mirror / file-import / offline paths, and the local-versus-vendor-console explainability envelope so a narrowing or widening decision can be reconstructed from the packet without a hosted console as the only source of truth."
    }
  }
}
