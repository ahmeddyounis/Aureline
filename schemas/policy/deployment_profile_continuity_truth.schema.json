{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/policy/deployment_profile_continuity_truth.schema.json",
  "title": "Aureline deployment profile continuity truth packet",
  "description": "Canonical schema for the policy_deployment_profile_continuity_page_record consumed by About, Help, diagnostics, service-health, admin, and support-export surfaces when they need one shared fact source for deployment summary cards, residual dependency disclosure, mirror freshness, and local-safe fallback truth. The packet is metadata-only: it carries closed-vocabulary profile and continuity tokens, export-safe labels, UTC timestamps, and opaque refs. Raw hostnames, raw tenant identifiers, raw trust material, raw bundle bodies, and secret material never appear.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "page_label",
    "generated_at",
    "summary",
    "defects",
    "input"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "record_kind": {
      "type": "string",
      "const": "policy_deployment_profile_continuity_page_record"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": {
      "type": "string",
      "const": "policy:deployment_profile_continuity_truth:v1"
    },
    "page_id": { "$ref": "#/$defs/opaque_id" },
    "page_label": { "$ref": "#/$defs/label" },
    "generated_at": { "$ref": "#/$defs/timestamp" },
    "summary": { "$ref": "#/$defs/summary" },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/defect" }
    },
    "input": { "$ref": "#/$defs/input" }
  },
  "allOf": [
    {
      "description": "A packet with zero defects must qualify stable.",
      "if": {
        "properties": {
          "summary": {
            "type": "object",
            "properties": { "defect_count": { "const": 0 } },
            "required": ["defect_count"]
          }
        },
        "required": ["summary"]
      },
      "then": {
        "properties": {
          "summary": {
            "type": "object",
            "properties": {
              "overall_qualification_token": { "const": "stable" }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "deployment_profile": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud"
      ]
    },
    "tenant_scope": {
      "type": "string",
      "enum": [
        "single_user_local",
        "customer_tenant",
        "shared_multi_tenant",
        "tenant_boundary_recheck_required",
        "not_applicable"
      ]
    },
    "mirror_state": {
      "type": "string",
      "enum": [
        "online_live_allowed",
        "online_mirror_only",
        "offline_grace_preserved",
        "offline_air_gapped",
        "deny_all_enforced",
        "network_disabled_by_user",
        "network_degraded_heuristic",
        "not_applicable"
      ]
    },
    "plane": {
      "type": "string",
      "enum": ["control_plane", "data_plane"]
    },
    "hosting_posture": {
      "type": "string",
      "enum": [
        "local_only",
        "customer_hosted",
        "vendor_hosted",
        "third_party_hosted",
        "mirror_backed",
        "offline_snapshot"
      ]
    },
    "residual_dependency_class": {
      "type": "string",
      "enum": ["control_plane", "content", "telemetry", "ai"]
    },
    "freshness_state": {
      "type": "string",
      "enum": [
        "current",
        "stale_within_grace",
        "stale_needs_refresh",
        "offline_snapshot",
        "unknown"
      ]
    },
    "signer_continuity": {
      "type": "string",
      "enum": [
        "verified_current",
        "verified_mirror",
        "verified_offline",
        "rotation_review_required",
        "unverified"
      ]
    },
    "local_safe_state": {
      "type": "string",
      "enum": [
        "healthy",
        "control_plane_degraded",
        "reauth_required",
        "offline_local_safe",
        "mirror_stale"
      ]
    },
    "fact_family": {
      "type": "string",
      "enum": [
        "deployment_summary",
        "residual_dependency",
        "mirror_freshness",
        "local_safe_fallback"
      ]
    },
    "delivery_source": {
      "type": "string",
      "enum": [
        "managed_pull",
        "mirror_publication",
        "file_import",
        "mdm_fleet_drop",
        "air_gap_transfer",
        "last_known_good_cache"
      ]
    },
    "qualification": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "missing_profile_coverage",
        "summary_card_truth_missing",
        "residual_dependency_disclosure_missing",
        "sovereign_boundary_overclaimed",
        "local_safe_fallback_truth_missing",
        "mirror_freshness_truth_missing",
        "surface_fact_reuse_missing"
      ]
    },
    "surface_visibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "about",
        "help",
        "diagnostics",
        "service_health",
        "admin",
        "support_export"
      ],
      "properties": {
        "about": { "type": "boolean" },
        "help": { "type": "boolean" },
        "diagnostics": { "type": "boolean" },
        "service_health": { "type": "boolean" },
        "admin": { "type": "boolean" },
        "support_export": { "type": "boolean" }
      }
    },
    "service_fact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service_ref",
        "service_label",
        "plane",
        "plane_token",
        "hosting_posture",
        "hosting_posture_token",
        "status_label",
        "continuity_note"
      ],
      "properties": {
        "service_ref": { "$ref": "#/$defs/opaque_id" },
        "service_label": { "$ref": "#/$defs/label" },
        "plane": { "$ref": "#/$defs/plane" },
        "plane_token": { "$ref": "#/$defs/plane" },
        "hosting_posture": { "$ref": "#/$defs/hosting_posture" },
        "hosting_posture_token": { "$ref": "#/$defs/hosting_posture" },
        "status_label": { "$ref": "#/$defs/label" },
        "continuity_note": { "$ref": "#/$defs/label" }
      }
    },
    "deployment_summary_card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id",
        "profile",
        "profile_token",
        "tenant_scope",
        "tenant_scope_token",
        "tenant_org_label",
        "region_label",
        "key_ownership_label",
        "mirror_offline_state",
        "mirror_offline_state_token",
        "delivery_sources",
        "delivery_source_tokens",
        "control_plane_services",
        "data_plane_services",
        "vendor_dependency_refs",
        "last_control_plane_sync",
        "local_safe_baseline",
        "surface_visibility"
      ],
      "properties": {
        "card_id": { "$ref": "#/$defs/opaque_id" },
        "profile": { "$ref": "#/$defs/deployment_profile" },
        "profile_token": { "$ref": "#/$defs/deployment_profile" },
        "tenant_scope": { "$ref": "#/$defs/tenant_scope" },
        "tenant_scope_token": { "$ref": "#/$defs/tenant_scope" },
        "tenant_org_label": { "$ref": "#/$defs/label" },
        "region_label": { "$ref": "#/$defs/label" },
        "key_ownership_label": { "$ref": "#/$defs/label" },
        "mirror_offline_state": { "$ref": "#/$defs/mirror_state" },
        "mirror_offline_state_token": { "$ref": "#/$defs/mirror_state" },
        "delivery_sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/delivery_source" }
        },
        "delivery_source_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/delivery_source" }
        },
        "control_plane_services": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/service_fact" }
        },
        "data_plane_services": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/service_fact" }
        },
        "vendor_dependency_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "last_control_plane_sync": { "$ref": "#/$defs/timestamp" },
        "local_safe_baseline": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/label" }
        },
        "surface_visibility": { "$ref": "#/$defs/surface_visibility" }
      }
    },
    "residual_dependency_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "profile",
        "profile_token",
        "dependency_ref",
        "feature_label",
        "dependency_class",
        "dependency_class_token",
        "host_posture",
        "host_posture_token",
        "failure_consequence",
        "local_safe_alternative",
        "disable_or_alternative_action",
        "surface_visibility"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/opaque_id" },
        "profile": { "$ref": "#/$defs/deployment_profile" },
        "profile_token": { "$ref": "#/$defs/deployment_profile" },
        "dependency_ref": { "$ref": "#/$defs/opaque_id" },
        "feature_label": { "$ref": "#/$defs/label" },
        "dependency_class": { "$ref": "#/$defs/residual_dependency_class" },
        "dependency_class_token": { "$ref": "#/$defs/residual_dependency_class" },
        "host_posture": { "$ref": "#/$defs/hosting_posture" },
        "host_posture_token": { "$ref": "#/$defs/hosting_posture" },
        "failure_consequence": { "$ref": "#/$defs/label" },
        "local_safe_alternative": { "$ref": "#/$defs/label" },
        "disable_or_alternative_action": { "$ref": "#/$defs/label" },
        "surface_visibility": { "$ref": "#/$defs/surface_visibility" }
      }
    },
    "mirror_freshness_card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id",
        "profile",
        "profile_token",
        "artifact_label",
        "delivery_source",
        "delivery_source_token",
        "source_label",
        "freshness_state",
        "freshness_state_token",
        "signer_continuity",
        "signer_continuity_token",
        "last_verified_at",
        "cached_usable_now",
        "blocked_until_refresh",
        "refresh_action_label",
        "surface_visibility"
      ],
      "properties": {
        "card_id": { "$ref": "#/$defs/opaque_id" },
        "profile": { "$ref": "#/$defs/deployment_profile" },
        "profile_token": { "$ref": "#/$defs/deployment_profile" },
        "artifact_label": { "$ref": "#/$defs/label" },
        "delivery_source": { "$ref": "#/$defs/delivery_source" },
        "delivery_source_token": { "$ref": "#/$defs/delivery_source" },
        "source_label": { "$ref": "#/$defs/label" },
        "freshness_state": { "$ref": "#/$defs/freshness_state" },
        "freshness_state_token": { "$ref": "#/$defs/freshness_state" },
        "signer_continuity": { "$ref": "#/$defs/signer_continuity" },
        "signer_continuity_token": { "$ref": "#/$defs/signer_continuity" },
        "last_verified_at": { "$ref": "#/$defs/timestamp" },
        "cached_usable_now": {
          "type": "array",
          "items": { "$ref": "#/$defs/label" }
        },
        "blocked_until_refresh": {
          "type": "array",
          "items": { "$ref": "#/$defs/label" }
        },
        "refresh_action_label": { "$ref": "#/$defs/label" },
        "surface_visibility": { "$ref": "#/$defs/surface_visibility" }
      }
    },
    "local_safe_fallback_card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id",
        "profile",
        "profile_token",
        "state",
        "state_token",
        "usable_now",
        "cached_or_stale",
        "blocked_until_refresh",
        "next_steps",
        "surface_visibility"
      ],
      "properties": {
        "card_id": { "$ref": "#/$defs/opaque_id" },
        "profile": { "$ref": "#/$defs/deployment_profile" },
        "profile_token": { "$ref": "#/$defs/deployment_profile" },
        "state": { "$ref": "#/$defs/local_safe_state" },
        "state_token": { "$ref": "#/$defs/local_safe_state" },
        "usable_now": {
          "type": "array",
          "items": { "$ref": "#/$defs/label" }
        },
        "cached_or_stale": {
          "type": "array",
          "items": { "$ref": "#/$defs/label" }
        },
        "blocked_until_refresh": {
          "type": "array",
          "items": { "$ref": "#/$defs/label" }
        },
        "next_steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/label" }
        },
        "surface_visibility": { "$ref": "#/$defs/surface_visibility" }
      }
    },
    "surface_reuse_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fact_family",
        "fact_family_token",
        "canonical_source_label",
        "canonical_source_ref",
        "surface_visibility"
      ],
      "properties": {
        "fact_family": { "$ref": "#/$defs/fact_family" },
        "fact_family_token": { "$ref": "#/$defs/fact_family" },
        "canonical_source_label": { "$ref": "#/$defs/label" },
        "canonical_source_ref": { "$ref": "#/$defs/opaque_id" },
        "surface_visibility": { "$ref": "#/$defs/surface_visibility" }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claimed_profiles",
        "current_profile",
        "deployment_summary_cards",
        "residual_dependency_rows",
        "mirror_freshness_cards",
        "local_safe_fallback_cards",
        "surface_reuse_rows"
      ],
      "properties": {
        "claimed_profiles": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile" },
          "uniqueItems": true
        },
        "current_profile": { "$ref": "#/$defs/deployment_profile" },
        "deployment_summary_cards": {
          "type": "array",
          "items": { "$ref": "#/$defs/deployment_summary_card" }
        },
        "residual_dependency_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/residual_dependency_row" }
        },
        "mirror_freshness_cards": {
          "type": "array",
          "items": { "$ref": "#/$defs/mirror_freshness_card" }
        },
        "local_safe_fallback_cards": {
          "type": "array",
          "items": { "$ref": "#/$defs/local_safe_fallback_card" }
        },
        "surface_reuse_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_reuse_row" }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "current_profile_token",
        "overall_qualification_token",
        "claimed_profile_count",
        "deployment_summary_card_count",
        "residual_dependency_row_count",
        "mirror_freshness_card_count",
        "local_safe_fallback_card_count",
        "complete_surface_reuse_row_count",
        "stale_or_offline_profile_count",
        "defect_count"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_deployment_profile_continuity_summary_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "policy:deployment_profile_continuity_truth:v1"
        },
        "current_profile_token": { "$ref": "#/$defs/deployment_profile" },
        "overall_qualification_token": { "$ref": "#/$defs/qualification" },
        "claimed_profile_count": { "type": "integer", "minimum": 1 },
        "deployment_summary_card_count": { "type": "integer", "minimum": 0 },
        "residual_dependency_row_count": { "type": "integer", "minimum": 0 },
        "mirror_freshness_card_count": { "type": "integer", "minimum": 0 },
        "local_safe_fallback_card_count": { "type": "integer", "minimum": 0 },
        "complete_surface_reuse_row_count": { "type": "integer", "minimum": 0 },
        "stale_or_offline_profile_count": { "type": "integer", "minimum": 0 },
        "defect_count": { "type": "integer", "minimum": 0 }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "policy_deployment_profile_continuity_defect_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "policy:deployment_profile_continuity_truth:v1"
        },
        "defect_id": { "$ref": "#/$defs/opaque_id" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason" },
        "source": { "$ref": "#/$defs/opaque_id" },
        "note": { "$ref": "#/$defs/label" }
      }
    }
  }
}
