{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/policy/exception_and_memory_state.schema.json",
  "title": "Aureline policy exception, waiver, and remembered-decision state",
  "description": "Boundary schema for policy exception, waiver, and remembered-decision rows. Exceptions and waivers expose owner, scope, evidence trail, expiry, renewal path, revocation path, status, dashboard bucket, and audit lineage. Remembered decisions are narrowed to actor, object, action family, environment, policy epoch, target version, authority epoch, and time horizon, then carry drift reasons when they expire or require reapproval.",
  "oneOf": [
    { "$ref": "#/$defs/policy_exception_or_waiver_record" },
    { "$ref": "#/$defs/policy_remembered_decision_record" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "non_empty": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "shared_contract_ref": {
      "type": "string",
      "const": "policy:simulation_exception_memory_beta:v1"
    },
    "scope_kind": {
      "type": "string",
      "enum": ["workspace", "root", "workset", "session", "tenant", "fleet"]
    },
    "action_family": {
      "type": "string",
      "enum": [
        "connected_provider_mutation",
        "ai_apply_mutation",
        "settings_write",
        "support_export",
        "records_lifecycle"
      ]
    },
    "exception_kind": {
      "type": "string",
      "enum": [
        "policy_exception",
        "policy_waiver",
        "admin_reconfirmation_defer",
        "remembered_decision_binding"
      ]
    },
    "exception_status": {
      "type": "string",
      "enum": [
        "active",
        "expiring_soon",
        "expired_reapproval_required",
        "superseded",
        "revoked",
        "force_retired_by_policy"
      ]
    },
    "renewal_path": {
      "type": "string",
      "enum": [
        "reprompt_user",
        "require_admin_reconfirmation",
        "require_original_author",
        "no_renewal_allowed"
      ]
    },
    "revocation_path": {
      "type": "string",
      "enum": [
        "owner_admin_review",
        "policy_epoch_change",
        "security_lane",
        "support_escalation"
      ]
    },
    "memory_state": {
      "type": "string",
      "enum": [
        "active",
        "narrowed",
        "expired",
        "requires_reapproval",
        "force_retired_by_policy",
        "superseded"
      ]
    },
    "dashboard_bucket": {
      "type": "string",
      "enum": [
        "healthy",
        "expiring_soon",
        "future_effective_pending",
        "narrowed_carry_forward",
        "expired_reprompt_due",
        "blocked_by_hold",
        "force_retired_by_policy",
        "superseded_pending_cleanup",
        "drift_detected"
      ]
    },
    "drift_reason": {
      "type": "string",
      "enum": [
        "actor_changed",
        "object_changed",
        "action_family_changed",
        "environment_changed",
        "policy_epoch_changed",
        "target_version_changed",
        "authority_drift",
        "expiry_elapsed"
      ]
    },
    "actor_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stable_id", "role"],
      "properties": {
        "stable_id": { "$ref": "#/$defs/non_empty" },
        "role": { "$ref": "#/$defs/non_empty" }
      }
    },
    "subject_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_kind", "subject_id"],
      "properties": {
        "subject_kind": { "$ref": "#/$defs/non_empty" },
        "subject_id": { "$ref": "#/$defs/non_empty" }
      }
    },
    "scope_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_kind", "scope_kind_token", "scope_id"],
      "properties": {
        "scope_kind": { "$ref": "#/$defs/scope_kind" },
        "scope_kind_token": { "$ref": "#/$defs/scope_kind" },
        "scope_id": { "$ref": "#/$defs/non_empty" }
      }
    },
    "time_horizon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["declared_at", "expires_at", "reapproval_prompt_at"],
      "properties": {
        "declared_at": { "$ref": "#/$defs/timestamp" },
        "expires_at": { "$ref": "#/$defs/timestamp" },
        "reapproval_prompt_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "environment_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment_id",
        "workspace_ref",
        "profile_token",
        "trust_state",
        "network_posture"
      ],
      "properties": {
        "environment_id": { "$ref": "#/$defs/non_empty" },
        "workspace_ref": { "$ref": "#/$defs/non_empty" },
        "profile_token": { "$ref": "#/$defs/non_empty" },
        "trust_state": { "$ref": "#/$defs/non_empty" },
        "network_posture": { "$ref": "#/$defs/non_empty" }
      }
    },
    "policy_exception_or_waiver_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "exception_id",
        "exception_kind",
        "exception_kind_token",
        "owner",
        "scope",
        "evidence_trail_refs",
        "time_horizon",
        "renewal_path",
        "renewal_path_token",
        "revocation_path",
        "revocation_path_token",
        "status",
        "status_token",
        "dashboard_bucket",
        "dashboard_bucket_token",
        "audit_lineage_refs",
        "raw_justification_excluded"
      ],
      "properties": {
        "record_kind": { "const": "policy_exception_or_waiver_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "exception_id": { "$ref": "#/$defs/non_empty" },
        "exception_kind": { "$ref": "#/$defs/exception_kind" },
        "exception_kind_token": { "$ref": "#/$defs/exception_kind" },
        "owner": { "$ref": "#/$defs/actor_ref" },
        "scope": { "$ref": "#/$defs/scope_ref" },
        "evidence_trail_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty" }
        },
        "time_horizon": { "$ref": "#/$defs/time_horizon" },
        "renewal_path": { "$ref": "#/$defs/renewal_path" },
        "renewal_path_token": { "$ref": "#/$defs/renewal_path" },
        "revocation_path": { "$ref": "#/$defs/revocation_path" },
        "revocation_path_token": { "$ref": "#/$defs/revocation_path" },
        "status": { "$ref": "#/$defs/exception_status" },
        "status_token": { "$ref": "#/$defs/exception_status" },
        "dashboard_bucket": { "$ref": "#/$defs/dashboard_bucket" },
        "dashboard_bucket_token": { "$ref": "#/$defs/dashboard_bucket" },
        "audit_lineage_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty" }
        },
        "linked_simulation_refs": { "type": "array", "items": { "$ref": "#/$defs/non_empty" } },
        "raw_justification_excluded": { "const": true }
      }
    },
    "policy_remembered_decision_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "remembered_decision_id",
        "bound_actor",
        "object",
        "action_family",
        "action_family_token",
        "environment",
        "policy_epoch",
        "target_version_ref",
        "authority_epoch_ref",
        "time_horizon",
        "memory_state",
        "memory_state_token",
        "invalidation_reasons",
        "invalidation_reason_tokens",
        "dashboard_bucket",
        "dashboard_bucket_token",
        "reapproval_prompt",
        "audit_lineage_refs"
      ],
      "properties": {
        "record_kind": { "const": "policy_remembered_decision_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "remembered_decision_id": { "$ref": "#/$defs/non_empty" },
        "bound_actor": { "$ref": "#/$defs/actor_ref" },
        "object": { "$ref": "#/$defs/subject_ref" },
        "action_family": { "$ref": "#/$defs/action_family" },
        "action_family_token": { "$ref": "#/$defs/action_family" },
        "environment": { "$ref": "#/$defs/environment_binding" },
        "policy_epoch": { "$ref": "#/$defs/non_empty" },
        "target_version_ref": { "$ref": "#/$defs/non_empty" },
        "authority_epoch_ref": { "$ref": "#/$defs/non_empty" },
        "time_horizon": { "$ref": "#/$defs/time_horizon" },
        "memory_state": { "$ref": "#/$defs/memory_state" },
        "memory_state_token": { "$ref": "#/$defs/memory_state" },
        "carry_forward_scope": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/scope_ref" }]
        },
        "invalidation_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/drift_reason" }
        },
        "invalidation_reason_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/drift_reason" }
        },
        "dashboard_bucket": { "$ref": "#/$defs/dashboard_bucket" },
        "dashboard_bucket_token": { "$ref": "#/$defs/dashboard_bucket" },
        "reapproval_prompt": { "$ref": "#/$defs/non_empty" },
        "related_exception_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/non_empty" }]
        },
        "audit_lineage_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "memory_state": {
                "enum": ["expired", "requires_reapproval", "force_retired_by_policy"]
              }
            },
            "required": ["memory_state"]
          },
          "then": {
            "properties": {
              "invalidation_reasons": { "minItems": 1 },
              "invalidation_reason_tokens": { "minItems": 1 }
            }
          }
        }
      ]
    }
  }
}
