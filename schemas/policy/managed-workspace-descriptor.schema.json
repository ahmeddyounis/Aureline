{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aureline.dev/schemas/policy/managed-workspace-descriptor.schema.json",
  "title": "ManagedWorkspaceDescriptor",
  "description": "Managed-workspace descriptor carrying workspace ID/name, org or tenant, region, persistence class, template or snapshot version, quota/billing owner, secret model, expiry policy, and current control-plane versus data-plane state.",
  "type": "object",
  "required": [
    "workspace_id",
    "workspace_name",
    "org_or_tenant",
    "region",
    "persistence_class",
    "persistence_class_token",
    "template_version",
    "quota_billing_owner",
    "secret_model",
    "secret_model_token",
    "expiry_policy",
    "plane_state_token"
  ],
  "properties": {
    "workspace_id": {
      "type": "string",
      "description": "Opaque workspace ID."
    },
    "workspace_name": {
      "type": "string",
      "description": "Human-readable workspace name."
    },
    "org_or_tenant": {
      "type": "string",
      "description": "Org or tenant identifier."
    },
    "region": {
      "type": "string",
      "description": "Region token."
    },
    "persistence_class": {
      "type": "string",
      "enum": [
        "ephemeral",
        "files_and_editor_state",
        "full_workspace_snapshot",
        "customer_managed_volume",
        "policy_retention_with_expiry"
      ],
      "description": "Closed persistence-class vocabulary."
    },
    "persistence_class_token": {
      "type": "string",
      "description": "Stable persistence token."
    },
    "template_version": {
      "type": "string",
      "description": "Template or snapshot version."
    },
    "quota_billing_owner": {
      "type": "string",
      "description": "Quota/billing owner identifier."
    },
    "secret_model": {
      "type": "string",
      "enum": [
        "static_injection",
        "broker_delegated_with_rotation",
        "customer_managed_never_leaves_tenant",
        "ephemeral_per_session"
      ],
      "description": "Closed secret-model vocabulary."
    },
    "secret_model_token": {
      "type": "string",
      "description": "Stable secret-model token."
    },
    "expiry_policy": {
      "type": "string",
      "description": "Expiry policy summary."
    },
    "plane_state_token": {
      "type": "string",
      "description": "Current control-plane versus data-plane state token."
    }
  }
}
