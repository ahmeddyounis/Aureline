{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/policy/usage-export.schema.json",
  "title": "Aureline versioned usage-export packet",
  "description": "Boundary schema for usage-export records that disclose quota family, record class, partiality, retention/audit posture, and tenant-scoped data scope. Every export packet carries a schema-version integer, a closed-vocabulary availability token, a machine-readable partiality marker, and a retention label. Raw quota counters, raw billing records, raw entitlement values, raw seat identifiers, and raw tenant configuration stay outside this boundary.",
  "$ref": "#/$defs/usage_export_packet",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the usage-export packet. Current value is 1. Bumped only on breaking payload changes."
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "policy:open_vs_paid_boundary:v1"
    },
    "non_empty": {
      "type": "string",
      "minLength": 1
    },
    "availability_token": {
      "type": "string",
      "enum": ["full", "partial", "unavailable"],
      "description": "Export availability for the record class."
    },
    "retention_token": {
      "type": "string",
      "enum": [
        "user_owned_immediate",
        "tenant_retained_policy",
        "billing_retained",
        "grace_window_exportable",
        "expired_unavailable"
      ],
      "description": "Retention posture applied to the exported or retained record."
    },
    "offboarding_outcome_token": {
      "type": "string",
      "enum": [
        "local_only",
        "managed_copy",
        "queued",
        "partial",
        "blocked_by_hold",
        "policy_retained",
        "outside_platform_scope",
        "completed"
      ],
      "description": "Offboarding outcome state for a capability or data record."
    },
    "grace_window_state_token": {
      "type": "string",
      "enum": ["active", "expired", "export_only", "degraded"],
      "description": "Grace-window state during offboarding, seat loss, or cancellation."
    },
    "usage_export_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "packet_id",
        "capability_family_token",
        "availability_token",
        "partial",
        "retention_token",
        "quota_family_label",
        "tenant_scoped_data_excluded",
        "export_summary"
      ],
      "properties": {
        "record_kind": { "const": "policy_usage_export_packet_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "packet_id": { "$ref": "#/$defs/non_empty" },
        "capability_family_token": { "$ref": "#/$defs/non_empty" },
        "availability_token": { "$ref": "#/$defs/availability_token" },
        "partial": { "type": "boolean" },
        "retention_token": { "$ref": "#/$defs/retention_token" },
        "quota_family_label": { "$ref": "#/$defs/non_empty" },
        "tenant_scoped_data_excluded": { "type": "boolean" },
        "export_summary": { "$ref": "#/$defs/non_empty" }
      }
    },
    "offboarding_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "packet_id",
        "capability_family_token",
        "local_data_outcome_token",
        "managed_data_outcome_token",
        "exportability_outcome_token",
        "policy_retained_outcome_token",
        "grace_window_state_token",
        "platform_retention_disclosed",
        "offboarding_summary"
      ],
      "properties": {
        "record_kind": { "const": "policy_offboarding_packet_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "packet_id": { "$ref": "#/$defs/non_empty" },
        "capability_family_token": { "$ref": "#/$defs/non_empty" },
        "local_data_outcome_token": { "$ref": "#/$defs/offboarding_outcome_token" },
        "managed_data_outcome_token": { "$ref": "#/$defs/offboarding_outcome_token" },
        "exportability_outcome_token": { "$ref": "#/$defs/offboarding_outcome_token" },
        "policy_retained_outcome_token": { "$ref": "#/$defs/offboarding_outcome_token" },
        "grace_window_state_token": { "$ref": "#/$defs/grace_window_state_token" },
        "platform_retention_disclosed": { "type": "boolean" },
        "offboarding_summary": { "$ref": "#/$defs/non_empty" }
      }
    }
  }
}
