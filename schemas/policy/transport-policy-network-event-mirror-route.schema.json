{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aureline.dev/policy/transport-policy-network-event-mirror-route.schema.json",
  "title": "Transport policy network event mirror route inspector packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "page_label",
    "generated_at",
    "route_source_precedence",
    "policies",
    "network_events",
    "trust_store_layers",
    "summary",
    "defects"
  ],
  "properties": {
    "record_kind": { "const": "policy_transport_policy_inspector_page_record" },
    "schema_version": { "const": 1 },
    "shared_contract_ref": { "const": "policy:transport_policy_network_event_mirror_route:v1" },
    "page_id": { "type": "string", "minLength": 1 },
    "page_label": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "route_source_precedence": {
      "type": "array",
      "prefixItems": [
        { "const": "policy_pinned" },
        { "const": "manual" },
        { "const": "system" },
        { "const": "pac" },
        { "const": "mirror_only" },
        { "const": "offline" }
      ],
      "minItems": 6,
      "maxItems": 6
    },
    "policies": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/transport_policy_record" }
    },
    "network_events": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/network_event_record" }
    },
    "trust_store_layers": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/trust_layer_snapshot" }
    },
    "summary": { "$ref": "#/$defs/summary" },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/defect" }
    }
  },
  "$defs": {
    "endpoint_class": {
      "enum": ["update", "marketplace", "docs", "ai", "provider", "remote", "bootstrap"]
    },
    "route_source": {
      "enum": ["policy_pinned", "manual", "system", "pac", "mirror_only", "offline"]
    },
    "egress_decision": {
      "enum": [
        "allow",
        "allow_mirror",
        "offline_deferred",
        "deny_policy",
        "deny_contract_mismatch",
        "deny_trust",
        "deny_transport",
        "stale_mirror"
      ]
    },
    "plane_status": {
      "enum": [
        "reachable",
        "unreachable_local_continuity",
        "degraded_cached_or_mirrored",
        "policy_blocked"
      ]
    },
    "trust_layer": {
      "enum": [
        "os_roots",
        "custom_ca_bundle",
        "pinned_ssh_host_proof",
        "client_certificate",
        "mirror_trust_root"
      ]
    },
    "proxy_resolution_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "source_token",
        "precedence_rank",
        "selected",
        "resolution_status_token",
        "explanation_label"
      ],
      "properties": {
        "source": { "$ref": "#/$defs/route_source" },
        "source_token": { "$ref": "#/$defs/route_source" },
        "precedence_rank": { "type": "integer", "minimum": 1, "maximum": 6 },
        "selected": { "type": "boolean" },
        "resolution_status_token": { "type": "string", "minLength": 1 },
        "explanation_label": { "type": "string", "minLength": 1 }
      }
    },
    "mirror_route_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mirror_route_ref",
        "state_token",
        "freshness_token",
        "signer_continuity_token",
        "offline_eligible",
        "route_label"
      ],
      "properties": {
        "mirror_route_ref": { "type": "string", "minLength": 1 },
        "state_token": { "type": "string", "minLength": 1 },
        "freshness_token": { "type": "string", "minLength": 1 },
        "signer_continuity_token": { "type": "string", "minLength": 1 },
        "offline_eligible": { "type": "boolean" },
        "route_label": { "type": "string", "minLength": 1 }
      }
    },
    "trust_layer_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer",
        "layer_token",
        "layer_ref",
        "health_token",
        "change_event_ref",
        "repair_action_token",
        "affected_endpoint_refs",
        "raw_trust_material_excluded"
      ],
      "properties": {
        "layer": { "$ref": "#/$defs/trust_layer" },
        "layer_token": { "$ref": "#/$defs/trust_layer" },
        "layer_ref": { "type": "string", "minLength": 1 },
        "health_token": { "type": "string", "minLength": 1 },
        "change_event_ref": { "type": "string", "minLength": 1 },
        "repair_action_token": { "type": "string", "minLength": 1 },
        "affected_endpoint_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/endpoint_class" }
        },
        "raw_trust_material_excluded": { "const": true }
      }
    },
    "transport_policy_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "policy_record_id",
        "endpoint_class",
        "endpoint_class_token",
        "effective_route_source",
        "effective_route_source_token",
        "egress_decision",
        "egress_decision_token",
        "policy_epoch_ref",
        "proxy_resolution_chain",
        "mirror_route_state",
        "trust_store_snapshot",
        "control_plane_status",
        "control_plane_status_token",
        "data_plane_status",
        "data_plane_status_token",
        "cached_offline_posture_token",
        "local_core_continuity_explicit",
        "explanation_label",
        "raw_secret_material_excluded"
      ],
      "properties": {
        "record_kind": { "const": "policy_transport_policy_record" },
        "schema_version": { "const": 1 },
        "shared_contract_ref": { "const": "policy:transport_policy_network_event_mirror_route:v1" },
        "policy_record_id": { "type": "string", "minLength": 1 },
        "endpoint_class": { "$ref": "#/$defs/endpoint_class" },
        "endpoint_class_token": { "$ref": "#/$defs/endpoint_class" },
        "effective_route_source": { "$ref": "#/$defs/route_source" },
        "effective_route_source_token": { "$ref": "#/$defs/route_source" },
        "egress_decision": { "$ref": "#/$defs/egress_decision" },
        "egress_decision_token": { "$ref": "#/$defs/egress_decision" },
        "policy_epoch_ref": { "type": "string", "minLength": 1 },
        "proxy_resolution_chain": {
          "type": "array",
          "minItems": 6,
          "items": { "$ref": "#/$defs/proxy_resolution_step" }
        },
        "mirror_route_state": { "$ref": "#/$defs/mirror_route_state" },
        "trust_store_snapshot": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/trust_layer_snapshot" }
        },
        "control_plane_status": { "$ref": "#/$defs/plane_status" },
        "control_plane_status_token": { "$ref": "#/$defs/plane_status" },
        "data_plane_status": { "$ref": "#/$defs/plane_status" },
        "data_plane_status_token": { "$ref": "#/$defs/plane_status" },
        "cached_offline_posture_token": { "type": "string", "minLength": 1 },
        "local_core_continuity_explicit": { "const": true },
        "explanation_label": { "type": "string", "minLength": 1 },
        "raw_secret_material_excluded": { "const": true }
      }
    },
    "network_event_record": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "record_kind",
        "event_id",
        "endpoint_class",
        "egress_decision_token",
        "handshake_outcome_token",
        "resolved_route_source_token",
        "proxy_resolution_chain",
        "trust_layer_refs",
        "mirror_route_state",
        "control_plane_status_token",
        "data_plane_status_token",
        "recovery_action_hint_token",
        "raw_secret_material_excluded"
      ],
      "properties": {
        "record_kind": { "const": "policy_network_event_record" },
        "event_id": { "type": "string", "minLength": 1 },
        "endpoint_class": { "$ref": "#/$defs/endpoint_class" },
        "egress_decision_token": { "$ref": "#/$defs/egress_decision" },
        "handshake_outcome_token": { "type": "string", "minLength": 1 },
        "resolved_route_source_token": { "$ref": "#/$defs/route_source" },
        "proxy_resolution_chain": {
          "type": "array",
          "minItems": 6,
          "items": { "$ref": "#/$defs/proxy_resolution_step" }
        },
        "trust_layer_refs": { "type": "array", "minItems": 1 },
        "mirror_route_state": { "$ref": "#/$defs/mirror_route_state" },
        "control_plane_status_token": { "$ref": "#/$defs/plane_status" },
        "data_plane_status_token": { "$ref": "#/$defs/plane_status" },
        "recovery_action_hint_token": { "type": "string", "minLength": 1 },
        "raw_secret_material_excluded": { "const": true }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "policy_record_count",
        "network_event_count",
        "stable_proof_index_ref",
        "raw_secret_material_excluded",
        "overall_qualification_token"
      ],
      "properties": {
        "policy_record_count": { "type": "integer", "minimum": 7 },
        "network_event_count": { "type": "integer", "minimum": 7 },
        "stable_proof_index_ref": {
          "const": "artifacts/release/stable_proof_index.json#proof:transport_policy_inspector_truth"
        },
        "raw_secret_material_excluded": { "const": true },
        "overall_qualification_token": { "enum": ["stable", "beta", "preview", "withdrawn"] }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": true,
      "required": ["record_kind", "narrow_reason_token", "source", "note"],
      "properties": {
        "record_kind": { "const": "policy_transport_policy_inspector_defect_record" },
        "narrow_reason_token": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 }
      }
    }
  }
}
