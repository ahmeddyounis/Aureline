{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/policy/policy-simulation-exception-and-expiry.schema.json",
  "title": "Aureline policy simulation, exception preview, approval history, and expiry packet",
  "description": "Stable boundary schema for policy-simulation views, exception/waiver preview sheets, approval-history rows, policy diff impact summaries, expiry banners, and one reviewable cross-surface packet. Payloads expose durable ids, actor/source, scope, created time, expiry or review target, export-safe lineage, degraded-mode consequences, stale/offline notes, and material reapproval triggers without raw policy bodies, raw identities, credentials, or secret material.",
  "oneOf": [
    { "$ref": "#/$defs/page" },
    { "$ref": "#/$defs/review_packet" },
    { "$ref": "#/$defs/support_export" }
  ],
  "$defs": {
    "schema_version": { "type": "integer", "const": 1 },
    "non_empty": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "shared_contract_ref": {
      "type": "string",
      "const": "policy:simulation_exception_expiry_stable:v1"
    },
    "surface_projection": {
      "type": "string",
      "enum": ["desktop", "cli_headless", "admin_support_handoff"]
    },
    "reapproval_trigger": {
      "type": "string",
      "enum": ["target_drift", "policy_drift", "version_drift", "authority_drift"]
    },
    "expiry_subject": {
      "type": "string",
      "enum": ["policy_exception", "policy_waiver", "remembered_decision"]
    },
    "string_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty" }
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty" }
    },
    "simulation_view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "simulation_view_id",
        "source_simulation_id",
        "actor_ref",
        "source_ref",
        "scope_ref",
        "created_at",
        "review_target_at",
        "changed_keys_or_feature_areas",
        "previous_value_ref",
        "simulated_value_ref",
        "user_visible_consequence",
        "affected_surface_refs",
        "degraded_mode_consequences",
        "stale_offline_notes",
        "policy_diff_summary_refs",
        "exception_preview_sheet_refs",
        "approval_history_row_refs",
        "expiry_banner_refs",
        "export_safe_lineage_refs"
      ],
      "properties": {
        "record_kind": { "const": "policy_simulation_view_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "simulation_view_id": { "$ref": "#/$defs/non_empty" },
        "source_simulation_id": { "$ref": "#/$defs/non_empty" },
        "actor_ref": { "$ref": "#/$defs/non_empty" },
        "source_ref": { "$ref": "#/$defs/non_empty" },
        "scope_ref": { "$ref": "#/$defs/non_empty" },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "review_target_at": { "$ref": "#/$defs/timestamp" },
        "changed_keys_or_feature_areas": { "$ref": "#/$defs/non_empty_string_array" },
        "previous_value_ref": { "$ref": "#/$defs/non_empty" },
        "simulated_value_ref": { "$ref": "#/$defs/non_empty" },
        "user_visible_consequence": { "$ref": "#/$defs/non_empty" },
        "affected_surface_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "degraded_mode_consequences": { "$ref": "#/$defs/non_empty_string_array" },
        "stale_offline_notes": { "$ref": "#/$defs/non_empty_string_array" },
        "policy_diff_summary_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "exception_preview_sheet_refs": { "$ref": "#/$defs/string_array" },
        "approval_history_row_refs": { "$ref": "#/$defs/string_array" },
        "expiry_banner_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "export_safe_lineage_refs": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "exception_preview_sheet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "sheet_id",
        "exception_ref",
        "source_ref",
        "scope_ref",
        "created_at",
        "exact_bypass_scope",
        "owner_or_approver_ref",
        "reason",
        "mitigation",
        "evidence_link_refs",
        "expiry_target_at",
        "fallback_behavior_on_lapse",
        "export_safe_lineage_refs",
        "linked_simulation_view_refs"
      ],
      "properties": {
        "record_kind": { "const": "policy_exception_preview_sheet_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "sheet_id": { "$ref": "#/$defs/non_empty" },
        "exception_ref": { "$ref": "#/$defs/non_empty" },
        "source_ref": { "$ref": "#/$defs/non_empty" },
        "scope_ref": { "$ref": "#/$defs/non_empty" },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "exact_bypass_scope": { "$ref": "#/$defs/non_empty" },
        "owner_or_approver_ref": { "$ref": "#/$defs/non_empty" },
        "reason": { "$ref": "#/$defs/non_empty" },
        "mitigation": { "$ref": "#/$defs/non_empty" },
        "evidence_link_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "expiry_target_at": { "$ref": "#/$defs/timestamp" },
        "fallback_behavior_on_lapse": { "$ref": "#/$defs/non_empty" },
        "export_safe_lineage_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "linked_simulation_view_refs": { "$ref": "#/$defs/string_array" }
      }
    },
    "approval_history_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "approval_history_row_id",
        "remembered_decision_ref",
        "source_ref",
        "actor_ref",
        "object_ref",
        "action_family_token",
        "environment_ref",
        "scope_ref",
        "created_at",
        "expires_at",
        "review_target_at",
        "memory_state_token",
        "revoke_action_ref",
        "open_details_action_ref",
        "reapproval_triggers",
        "reapproval_trigger_tokens",
        "invalidation_reason_tokens",
        "bounded_by_expiry",
        "export_safe_lineage_refs"
      ],
      "properties": {
        "record_kind": { "const": "policy_approval_history_row_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "approval_history_row_id": { "$ref": "#/$defs/non_empty" },
        "remembered_decision_ref": { "$ref": "#/$defs/non_empty" },
        "source_ref": { "$ref": "#/$defs/non_empty" },
        "actor_ref": { "$ref": "#/$defs/non_empty" },
        "object_ref": { "$ref": "#/$defs/non_empty" },
        "action_family_token": { "$ref": "#/$defs/non_empty" },
        "environment_ref": { "$ref": "#/$defs/non_empty" },
        "scope_ref": { "$ref": "#/$defs/non_empty" },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "expires_at": { "$ref": "#/$defs/timestamp" },
        "review_target_at": { "$ref": "#/$defs/timestamp" },
        "memory_state_token": { "$ref": "#/$defs/non_empty" },
        "revoke_action_ref": { "$ref": "#/$defs/non_empty" },
        "open_details_action_ref": { "$ref": "#/$defs/non_empty" },
        "reapproval_triggers": {
          "type": "array",
          "minItems": 4,
          "allOf": [
            { "contains": { "const": "target_drift" } },
            { "contains": { "const": "policy_drift" } },
            { "contains": { "const": "version_drift" } },
            { "contains": { "const": "authority_drift" } }
          ],
          "items": { "$ref": "#/$defs/reapproval_trigger" }
        },
        "reapproval_trigger_tokens": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/reapproval_trigger" }
        },
        "invalidation_reason_tokens": { "$ref": "#/$defs/string_array" },
        "bounded_by_expiry": { "const": true },
        "export_safe_lineage_refs": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "policy_diff_impact_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "diff_summary_id",
        "simulation_ref",
        "actor_ref",
        "source_ref",
        "scope_ref",
        "created_at",
        "review_target_at",
        "changed_key_or_feature_area",
        "previous_value",
        "simulated_value",
        "user_visible_consequence",
        "affected_surface_refs",
        "degraded_mode_consequences",
        "stale_offline_notes",
        "export_safe_lineage_refs"
      ],
      "properties": {
        "record_kind": { "const": "policy_diff_impact_summary_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "diff_summary_id": { "$ref": "#/$defs/non_empty" },
        "simulation_ref": { "$ref": "#/$defs/non_empty" },
        "actor_ref": { "$ref": "#/$defs/non_empty" },
        "source_ref": { "$ref": "#/$defs/non_empty" },
        "scope_ref": { "$ref": "#/$defs/non_empty" },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "review_target_at": { "$ref": "#/$defs/timestamp" },
        "changed_key_or_feature_area": { "$ref": "#/$defs/non_empty" },
        "previous_value": { "$ref": "#/$defs/non_empty" },
        "simulated_value": { "$ref": "#/$defs/non_empty" },
        "user_visible_consequence": { "$ref": "#/$defs/non_empty" },
        "affected_surface_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "degraded_mode_consequences": { "$ref": "#/$defs/non_empty_string_array" },
        "stale_offline_notes": { "$ref": "#/$defs/non_empty_string_array" },
        "export_safe_lineage_refs": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "expiry_banner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "banner_id",
        "subject_class",
        "subject_class_token",
        "subject_ref",
        "actor_or_source_ref",
        "scope_ref",
        "created_at",
        "what_expires",
        "exact_expiry_at",
        "relative_time_label",
        "consequence_on_expiry",
        "renew_or_review_action_ref",
        "export_safe_lineage_refs"
      ],
      "properties": {
        "record_kind": { "const": "policy_expiry_banner_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "banner_id": { "$ref": "#/$defs/non_empty" },
        "subject_class": { "$ref": "#/$defs/expiry_subject" },
        "subject_class_token": { "$ref": "#/$defs/expiry_subject" },
        "subject_ref": { "$ref": "#/$defs/non_empty" },
        "actor_or_source_ref": { "$ref": "#/$defs/non_empty" },
        "scope_ref": { "$ref": "#/$defs/non_empty" },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "what_expires": { "$ref": "#/$defs/non_empty" },
        "exact_expiry_at": { "$ref": "#/$defs/timestamp" },
        "relative_time_label": { "$ref": "#/$defs/non_empty" },
        "consequence_on_expiry": { "$ref": "#/$defs/non_empty" },
        "renew_or_review_action_ref": { "$ref": "#/$defs/non_empty" },
        "export_safe_lineage_refs": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "review_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "review_packet_id",
        "policy_diff_summary_refs",
        "simulation_outcome_refs",
        "approval_or_waiver_owner_refs",
        "expiry_banner_refs",
        "chronology_refs",
        "reapproval_triggers",
        "reapproval_trigger_tokens",
        "surface_projections",
        "surface_projection_tokens"
      ],
      "properties": {
        "record_kind": { "const": "policy_simulation_exception_expiry_review_packet_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "review_packet_id": { "$ref": "#/$defs/non_empty" },
        "policy_diff_summary_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "simulation_outcome_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "approval_or_waiver_owner_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "expiry_banner_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "chronology_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "reapproval_triggers": {
          "type": "array",
          "minItems": 4,
          "allOf": [
            { "contains": { "const": "target_drift" } },
            { "contains": { "const": "policy_drift" } },
            { "contains": { "const": "version_drift" } },
            { "contains": { "const": "authority_drift" } }
          ],
          "items": { "$ref": "#/$defs/reapproval_trigger" }
        },
        "reapproval_trigger_tokens": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/reapproval_trigger" }
        },
        "surface_projections": {
          "type": "array",
          "minItems": 3,
          "allOf": [
            { "contains": { "const": "desktop" } },
            { "contains": { "const": "cli_headless" } },
            { "contains": { "const": "admin_support_handoff" } }
          ],
          "items": { "$ref": "#/$defs/surface_projection" }
        },
        "surface_projection_tokens": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/surface_projection" }
        }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": true,
      "required": ["record_kind", "schema_version", "shared_contract_ref", "defect_kind_token"],
      "properties": {
        "record_kind": { "const": "policy_simulation_exception_expiry_defect_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_kind_token": { "$ref": "#/$defs/non_empty" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["defect_count", "overall_qualification_token"],
      "properties": {
        "defect_count": { "type": "integer", "minimum": 0 },
        "overall_qualification_token": {
          "type": "string",
          "enum": ["stable", "needs_review", "withdrawn"]
        }
      }
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "page_id",
        "page_label",
        "generated_at",
        "source_policy_simulation_page",
        "simulation_views",
        "exception_preview_sheets",
        "approval_history_rows",
        "policy_diff_summaries",
        "expiry_banners",
        "review_packet",
        "defects",
        "summary"
      ],
      "properties": {
        "record_kind": { "const": "policy_simulation_exception_expiry_page_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "page_id": { "$ref": "#/$defs/non_empty" },
        "page_label": { "$ref": "#/$defs/non_empty" },
        "generated_at": { "$ref": "#/$defs/timestamp" },
        "source_policy_simulation_page": { "type": "object" },
        "simulation_views": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/simulation_view" }
        },
        "exception_preview_sheets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/exception_preview_sheet" }
        },
        "approval_history_rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/approval_history_row" }
        },
        "policy_diff_summaries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/policy_diff_impact_summary" }
        },
        "expiry_banners": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/expiry_banner" }
        },
        "review_packet": { "$ref": "#/$defs/review_packet" },
        "defects": {
          "type": "array",
          "items": { "$ref": "#/$defs/defect" }
        },
        "summary": { "$ref": "#/$defs/summary" }
      }
    },
    "support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "export_id",
        "exported_at",
        "page",
        "defect_counts_by_kind",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": { "const": "policy_simulation_exception_expiry_support_export_record" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "export_id": { "$ref": "#/$defs/non_empty" },
        "exported_at": { "$ref": "#/$defs/timestamp" },
        "page": { "$ref": "#/$defs/page" },
        "defect_counts_by_kind": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "raw_private_material_excluded": { "const": true }
      }
    }
  }
}
