{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/design/geometry_token.schema.json",
  "title": "Aureline geometry token ledger and geometry-case records",
  "description": "Boundary schema for the geometry token ledger and geometry-case fixtures frozen in docs/design/geometry_and_hit_target_contract.md. The ledger publishes the canonical spacing/sizing/radius/border/elevation/opacity tokens plus density-derived row/control heights, indent and disclosure metrics, and the minimum interactive hit-target floors. Geometry-case fixtures exercise the cross-surface contract for density, zoom/text-scale behavior, and overflow guardrails without embedding raw design assets or screenshots.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/geometry_token_ledger_record" },
    { "$ref": "#/$defs/geometry_case_record" }
  ],
  "$defs": {
    "geometry_token_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for geometry token ledger and geometry-case records."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log and safe in fixtures. Raw user content is not required to be carried by ids."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },

    "nonempty_string": {
      "type": "string",
      "minLength": 1
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "$ref": "#/$defs/nonempty_string" },
        "scenario": { "$ref": "#/$defs/nonempty_string" },
        "exercised_axes": { "type": "object", "additionalProperties": true },
        "contract_sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonempty_string" }
        }
      }
    },

    "density_class": {
      "$ref": "./token_export_manifest.schema.json#/$defs/density_class"
    },

    "input_mode_class": {
      "type": "string",
      "enum": ["pointer", "keyboard"],
      "description": "Input modality used for a geometry case. Pointer-vs-keyboard affects focus-visible and hover affordances; it must not reduce hit target floors."
    },

    "component_family_class": {
      "type": "string",
      "enum": ["button", "input", "tab", "tree", "table", "dialog", "banner", "status_item"],
      "description": "Closed component-family vocabulary for geometry-case fixtures."
    },

    "spacing_token": {
      "type": "string",
      "enum": [
        "space.0",
        "space.0_5",
        "space.1",
        "space.2",
        "space.3",
        "space.4",
        "space.5",
        "space.6",
        "space.8",
        "space.10",
        "space.12",
        "space.16"
      ],
      "description": "Frozen spacing tokens (`space.*`)."
    },

    "sizing_token": {
      "type": "string",
      "enum": [
        "size.icon.xs",
        "size.icon.sm",
        "size.icon.md",
        "size.icon.lg",
        "size.hit.min",
        "size.control.sm",
        "size.control.md",
        "size.control.lg",
        "size.control.compact",
        "size.control.standard",
        "size.control.comfortable",
        "size.row.compact",
        "size.row.standard",
        "size.row.comfortable",
        "size.statusbar",
        "size.tab",
        "size.sidebar.row",
        "size.indent.step",
        "size.disclosure.glyph"
      ],
      "description": "Frozen sizing tokens (`size.*`) including density-derived row/control heights and shared tree/disclosure metrics."
    },

    "radius_token": {
      "type": "string",
      "enum": ["radius.none", "radius.sm", "radius.md", "radius.lg", "radius.xl"],
      "description": "Frozen radius tokens (`radius.*`)."
    },

    "border_stroke_token": {
      "type": "string",
      "enum": ["stroke.border.default", "stroke.border.strong", "stroke.focus.ring"],
      "description": "Frozen border/stroke tokens."
    },

    "elevation_token": {
      "type": "string",
      "enum": ["elevation.0", "elevation.1", "elevation.2", "elevation.3"],
      "description": "Frozen elevation tokens (`elevation.*`)."
    },

    "opacity_token": {
      "type": "string",
      "enum": [
        "opacity.full",
        "opacity.subtle",
        "opacity.disabled",
        "opacity.scrim.weak",
        "opacity.scrim.strong"
      ],
      "description": "Frozen opacity tokens (`opacity.*`)."
    },

    "density_token": {
      "type": "string",
      "enum": ["density.compact", "density.standard", "density.comfortable"],
      "description": "Frozen density tokens (`density.*`)."
    },

    "px_value": {
      "type": "integer",
      "minimum": 0,
      "description": "A non-negative measurement in logical pixels."
    },

    "alpha_value": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Opacity alpha value in the inclusive range [0, 1]."
    },

    "spacing_token_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token_name", "px"],
      "properties": {
        "token_name": { "$ref": "#/$defs/spacing_token" },
        "px": { "$ref": "#/$defs/px_value" },
        "use_hint": { "$ref": "#/$defs/nonempty_string" },
        "source_of_truth_ref": { "$ref": "#/$defs/nonempty_string" }
      }
    },

    "sizing_token_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token_name", "px"],
      "properties": {
        "token_name": { "$ref": "#/$defs/sizing_token" },
        "px": { "$ref": "#/$defs/px_value" },
        "use_hint": { "$ref": "#/$defs/nonempty_string" },
        "source_of_truth_ref": { "$ref": "#/$defs/nonempty_string" }
      }
    },

    "radius_token_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token_name", "px"],
      "properties": {
        "token_name": { "$ref": "#/$defs/radius_token" },
        "px": { "$ref": "#/$defs/px_value" },
        "use_hint": { "$ref": "#/$defs/nonempty_string" },
        "source_of_truth_ref": { "$ref": "#/$defs/nonempty_string" }
      }
    },

    "border_stroke_token_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token_name", "px"],
      "properties": {
        "token_name": { "$ref": "#/$defs/border_stroke_token" },
        "px": { "$ref": "#/$defs/px_value" },
        "use_hint": { "$ref": "#/$defs/nonempty_string" },
        "source_of_truth_ref": { "$ref": "#/$defs/nonempty_string" }
      }
    },

    "elevation_token_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token_name", "treatment"],
      "properties": {
        "token_name": { "$ref": "#/$defs/elevation_token" },
        "treatment": { "$ref": "#/$defs/nonempty_string" },
        "source_of_truth_ref": { "$ref": "#/$defs/nonempty_string" }
      }
    },

    "opacity_token_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token_name", "alpha"],
      "properties": {
        "token_name": { "$ref": "#/$defs/opacity_token" },
        "alpha": { "$ref": "#/$defs/alpha_value" },
        "use_hint": { "$ref": "#/$defs/nonempty_string" },
        "source_of_truth_ref": { "$ref": "#/$defs/nonempty_string" }
      }
    },

    "density_token_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token_name", "density_class"],
      "properties": {
        "token_name": { "$ref": "#/$defs/density_token" },
        "density_class": { "$ref": "#/$defs/density_class" },
        "source_of_truth_ref": { "$ref": "#/$defs/nonempty_string" }
      }
    },

    "hit_target_class": {
      "type": "string",
      "enum": [
        "interactive_min",
        "icon_only_control",
        "row_action",
        "disclosure_affordance",
        "resize_handle",
        "splitter_hit_target"
      ],
      "description": "Closed hit-target floor vocabulary."
    },

    "hit_target_floor_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hit_target_class", "minimum_px"],
      "properties": {
        "hit_target_class": { "$ref": "#/$defs/hit_target_class" },
        "minimum_px": { "$ref": "#/$defs/px_value" },
        "recommended_default_min_px": { "$ref": "#/$defs/px_value" },
        "recommended_default_max_px": { "$ref": "#/$defs/px_value" },
        "recommended_maximum_px": { "$ref": "#/$defs/px_value" },
        "token_ref": { "$ref": "#/$defs/nonempty_string" },
        "notes": { "$ref": "#/$defs/nonempty_string" },
        "source_of_truth_ref": { "$ref": "#/$defs/nonempty_string" }
      }
    },

    "component_family_binding_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component_family_class", "required_token_refs"],
      "properties": {
        "component_family_class": { "$ref": "#/$defs/component_family_class" },
        "required_token_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonempty_string" },
          "uniqueItems": true,
          "description": "Token refs (e.g. space.*, size.*, radius.*, stroke.*, opacity.*) every instance of this family is expected to consume."
        },
        "notes": { "$ref": "#/$defs/nonempty_string" }
      }
    },

    "geometry_token_ledger_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "geometry_token_schema_version",
        "ledger_id",
        "source_of_truth_refs",
        "minted_at",
        "spacing_tokens",
        "sizing_tokens",
        "radius_tokens",
        "border_stroke_tokens",
        "elevation_tokens",
        "opacity_tokens",
        "density_tokens",
        "hit_target_floors",
        "component_family_bindings"
      ],
      "properties": {
        "record_kind": { "const": "geometry_token_ledger_record" },
        "geometry_token_schema_version": { "$ref": "#/$defs/geometry_token_schema_version" },
        "ledger_id": { "$ref": "#/$defs/opaque_id" },
        "source_of_truth_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonempty_string" }
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "spacing_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/spacing_token_row" }
        },
        "sizing_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sizing_token_row" }
        },
        "radius_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/radius_token_row" }
        },
        "border_stroke_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/border_stroke_token_row" }
        },
        "elevation_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/elevation_token_row" }
        },
        "opacity_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opacity_token_row" }
        },
        "density_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/density_token_row" }
        },
        "hit_target_floors": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/hit_target_floor_row" }
        },
        "component_family_bindings": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/component_family_binding_row" }
        }
      }
    },

    "token_value_expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token_ref"],
      "properties": {
        "token_ref": { "$ref": "#/$defs/nonempty_string" },
        "expected_px": { "$ref": "#/$defs/px_value" },
        "expected_alpha": { "$ref": "#/$defs/alpha_value" },
        "notes": { "$ref": "#/$defs/nonempty_string" }
      },
      "description": "Expected resolved value for a referenced token. Exactly one of expected_px or expected_alpha must be present per token_ref."
    },

    "overflow_guardrail_class": {
      "type": "string",
      "enum": [
        "collapse_secondary_before_truncate_primary",
        "move_optional_actions_to_overflow_before_shrinking_hit_targets",
        "preserve_disclosure_hit_target_under_cramped_width",
        "preserve_focus_ring_clearance_under_zoom"
      ],
      "description": "Closed overflow/safety guardrail vocabulary for geometry cases."
    },

    "geometry_case_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "geometry_token_schema_version",
        "case_id",
        "component_family_class",
        "density_class",
        "input_mode_class",
        "effective_zoom_percent",
        "effective_text_scale_percent",
        "token_expectations",
        "overflow_guardrails",
        "minted_at"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "geometry_case_record" },
        "geometry_token_schema_version": { "$ref": "#/$defs/geometry_token_schema_version" },
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "component_family_class": { "$ref": "#/$defs/component_family_class" },
        "density_class": { "$ref": "#/$defs/density_class" },
        "input_mode_class": { "$ref": "#/$defs/input_mode_class" },
        "effective_zoom_percent": { "type": "integer", "minimum": 25, "maximum": 400 },
        "effective_text_scale_percent": { "type": "integer", "minimum": 75, "maximum": 250 },
        "token_expectations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/token_value_expectation" }
        },
        "overflow_guardrails": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/overflow_guardrail_class" },
          "uniqueItems": true
        },
        "notes": { "$ref": "#/$defs/nonempty_string" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    }
  }
}
