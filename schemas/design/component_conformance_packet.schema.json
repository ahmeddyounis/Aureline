{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/design/component_conformance_packet.schema.json",
  "title": "Aureline component conformance packet",
  "description": "Boundary schema for component conformance packets. A conformance packet ties a reusable component to its component contract packet, state taxonomy coverage, micro-metric ledger ids, token inheritance contract, screenshot baselines, keyboard journey refs, accessibility evidence refs, and explicit extension/embedded inheritance exceptions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "component_conformance_schema_version",
    "packet_id",
    "component_id",
    "component_title",
    "component_family_class",
    "launch_priority_class",
    "component_contract_ref",
    "conformance_posture_class",
    "state_taxonomy",
    "metric_requirements",
    "token_inheritance",
    "appearance_evidence",
    "keyboard_evidence",
    "accessibility_evidence",
    "extension_embedded_exceptions",
    "minted_at"
  ],
  "properties": {
    "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
    "record_kind": { "type": "string", "const": "component_conformance_packet_record" },
    "component_conformance_schema_version": { "type": "integer", "const": 1 },
    "packet_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^component_conformance_packet:[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "component_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^component\\.[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "component_title": { "$ref": "#/$defs/nonempty_string" },
    "component_family_class": { "$ref": "#/$defs/component_family_class" },
    "launch_priority_class": { "$ref": "#/$defs/launch_priority_class" },
    "component_contract_ref": { "$ref": "#/$defs/nonempty_string" },
    "conformance_posture_class": { "$ref": "#/$defs/conformance_posture_class" },
    "state_taxonomy": { "$ref": "#/$defs/state_taxonomy_block" },
    "metric_requirements": { "$ref": "#/$defs/metric_requirements_block" },
    "token_inheritance": { "$ref": "#/$defs/token_inheritance_block" },
    "appearance_evidence": { "$ref": "#/$defs/appearance_evidence_block" },
    "keyboard_evidence": { "$ref": "#/$defs/keyboard_evidence_block" },
    "accessibility_evidence": { "$ref": "#/$defs/accessibility_evidence_block" },
    "extension_embedded_exceptions": {
      "type": "array",
      "items": { "$ref": "#/$defs/inheritance_exception_record" }
    },
    "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
  },
  "$defs": {
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },
    "nonempty_string": { "type": "string", "minLength": 1 },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "$ref": "#/$defs/nonempty_string" },
        "scenario": { "$ref": "#/$defs/nonempty_string" },
        "exercised_axes": { "type": "object", "additionalProperties": true },
        "contract_sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonempty_string" }
        }
      }
    },
    "component_family_class": {
      "type": "string",
      "enum": [
        "button",
        "text_input",
        "choice_control",
        "tabs",
        "tree",
        "list_row",
        "table",
        "dialog_or_sheet",
        "banner",
        "toast",
        "status_item",
        "settings_row",
        "permission_sheet",
        "badge_or_pill"
      ]
    },
    "launch_priority_class": {
      "type": "string",
      "enum": ["launch_critical", "supporting", "optional"]
    },
    "conformance_posture_class": {
      "type": "string",
      "enum": ["fully_conformant", "conformant_with_disclosed_gaps"]
    },
    "taxonomy_state_class": {
      "type": "string",
      "enum": [
        "default",
        "hover",
        "focus_visible",
        "pressed_active",
        "selected",
        "current",
        "disabled",
        "read_only",
        "loading",
        "pending",
        "warning_error",
        "locked",
        "degraded"
      ]
    },
    "state_taxonomy_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taxonomy_ref", "required_taxonomy_state_classes", "additional_state_notes"],
      "properties": {
        "taxonomy_ref": { "$ref": "#/$defs/nonempty_string" },
        "required_taxonomy_state_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/taxonomy_state_class" },
          "uniqueItems": true
        },
        "additional_state_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonempty_string" }
        }
      }
    },
    "metric_requirements_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ledger_ref", "metric_ids", "component_metric_case_refs"],
      "properties": {
        "ledger_ref": { "$ref": "#/$defs/nonempty_string" },
        "metric_ids": {
          "type": "array",
          "items": { "$ref": "./component_metrics.schema.json#/$defs/metric_id" },
          "uniqueItems": true
        },
        "component_metric_case_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonempty_string" },
          "uniqueItems": true
        }
      }
    },
    "token_inheritance_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "token_vocabulary_ref",
        "theme_inheritance_contract_ref",
        "token_conformance_contract_ref",
        "token_drift_rules_ref",
        "token_drift_check_refs"
      ],
      "properties": {
        "token_vocabulary_ref": { "$ref": "#/$defs/nonempty_string" },
        "theme_inheritance_contract_ref": { "$ref": "#/$defs/nonempty_string" },
        "token_conformance_contract_ref": { "$ref": "#/$defs/nonempty_string" },
        "token_drift_rules_ref": { "$ref": "#/$defs/nonempty_string" },
        "token_drift_check_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonempty_string" },
          "uniqueItems": true
        }
      }
    },
    "appearance_evidence_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["screenshot_baseline_refs", "appearance_notes"],
      "properties": {
        "screenshot_baseline_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonempty_string" },
          "uniqueItems": true
        },
        "appearance_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonempty_string" }
        }
      }
    },
    "keyboard_evidence_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyboard_journey_refs"],
      "properties": {
        "keyboard_journey_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonempty_string" },
          "uniqueItems": true
        }
      }
    },
    "accessibility_evidence_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assistive_technology_refs", "accessible_name_notes"],
      "properties": {
        "assistive_technology_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonempty_string" },
          "uniqueItems": true
        },
        "accessible_name_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonempty_string" }
        }
      }
    },
    "surface_owner_role_class": {
      "type": "string",
      "enum": ["extension_contributed_surface", "embedded_surface_contributed"]
    },
    "allowed_inheritance_gap_class": {
      "type": "string",
      "enum": [
        "extension_inherits_first_party_palette",
        "extension_partial_high_contrast_inheritance",
        "embedded_surface_inherits_outer_chrome",
        "embedded_surface_inert_placeholder_for_unmapped_role",
        "docs_help_service_health_inherits_shell_palette",
        "notification_surface_inherits_durable_attention_palette"
      ]
    },
    "inheritance_exception_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exception_id",
        "surface_owner_role_class",
        "allowed_inheritance_gap_class",
        "rationale",
        "disclosure_requirement",
        "evidence_refs"
      ],
      "properties": {
        "exception_id": { "$ref": "#/$defs/nonempty_string" },
        "surface_owner_role_class": { "$ref": "#/$defs/surface_owner_role_class" },
        "allowed_inheritance_gap_class": { "$ref": "#/$defs/allowed_inheritance_gap_class" },
        "rationale": { "$ref": "#/$defs/nonempty_string" },
        "disclosure_requirement": { "$ref": "#/$defs/nonempty_string" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonempty_string" }
        }
      }
    }
  }
}

