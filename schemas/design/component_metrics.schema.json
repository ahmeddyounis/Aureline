{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/design/component_metrics.schema.json",
  "title": "Aureline component metrics ledger and component-metric case records",
  "description": "Boundary schema for the component metrics ledger and component-metric case fixtures frozen in docs/design/component_metrics_contract.md. The ledger publishes mechanically reviewable micro-metrics (row heights, control heights, icon sizes, indent steps, disclosure glyph sizes, hit-target floors, splitter hit areas, focus-ring gutters, and status bar spacing budgets) so density modes and compact-shell layouts remain consistent without reading CSS or widget code. Component-metric cases bind those metrics to screenshot baselines, accessibility review hooks, and component packet refs so geometry drift becomes testable early.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/component_metrics_ledger_record" },
    { "$ref": "#/$defs/component_metric_case_record" }
  ],
  "$defs": {
    "component_metrics_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for component metrics ledger and component-metric case records."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },
    "nonempty_string": {
      "type": "string",
      "minLength": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$",
      "description": "Opaque, stable id safe for fixtures and logs."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "$ref": "#/$defs/nonempty_string" },
        "scenario": { "$ref": "#/$defs/nonempty_string" },
        "exercised_axes": { "type": "object", "additionalProperties": true },
        "contract_sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonempty_string" }
        }
      }
    },
    "density_class": {
      "$ref": "./token_export_manifest.schema.json#/$defs/density_class"
    },
    "input_mode_class": {
      "type": "string",
      "enum": ["pointer", "keyboard"],
      "description": "Input modality used for a component-metric case."
    },
    "component_surface_class": {
      "type": "string",
      "enum": [
        "button",
        "icon_button",
        "input",
        "tab",
        "tree_row",
        "list_row",
        "grid_row",
        "dialog_action_row",
        "splitter",
        "status_item"
      ],
      "description": "Closed component-surface vocabulary for component-metric ledgers and cases."
    },
    "metric_axis_class": {
      "type": "string",
      "enum": [
        "row_height",
        "control_height",
        "hit_target",
        "splitter_hit_area",
        "icon_size",
        "indent_step",
        "disclosure_glyph_size",
        "focus_ring_stroke",
        "focus_ring_gutter",
        "statusbar_height",
        "inset_x",
        "inter_item_gap_x"
      ],
      "description": "Closed metric-axis vocabulary for component metrics."
    },
    "px_value": {
      "type": "integer",
      "minimum": 0,
      "description": "A non-negative measurement in logical pixels."
    },
    "metric_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^metric\\.[a-z0-9]+(?:[_.:-][a-z0-9]+)*$",
      "description": "Stable metric id. Metric ids are not user-facing strings."
    },
    "metric_row_fixed_px": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "measurement_kind",
        "metric_axis_class",
        "component_surface_class",
        "density_class",
        "px"
      ],
      "properties": {
        "metric_id": { "$ref": "#/$defs/metric_id" },
        "measurement_kind": { "type": "string", "const": "fixed_px" },
        "metric_axis_class": { "$ref": "#/$defs/metric_axis_class" },
        "component_surface_class": {
          "oneOf": [
            { "$ref": "#/$defs/component_surface_class" },
            { "type": "null" }
          ]
        },
        "density_class": {
          "oneOf": [
            { "$ref": "#/$defs/density_class" },
            { "type": "null" }
          ]
        },
        "px": { "$ref": "#/$defs/px_value" },
        "token_ref": { "$ref": "#/$defs/nonempty_string" },
        "notes": { "$ref": "#/$defs/nonempty_string" },
        "source_of_truth_ref": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "metric_row_range_px": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "measurement_kind",
        "metric_axis_class",
        "component_surface_class",
        "density_class",
        "minimum_px"
      ],
      "properties": {
        "metric_id": { "$ref": "#/$defs/metric_id" },
        "measurement_kind": { "type": "string", "const": "range_px" },
        "metric_axis_class": { "$ref": "#/$defs/metric_axis_class" },
        "component_surface_class": {
          "oneOf": [
            { "$ref": "#/$defs/component_surface_class" },
            { "type": "null" }
          ]
        },
        "density_class": {
          "oneOf": [
            { "$ref": "#/$defs/density_class" },
            { "type": "null" }
          ]
        },
        "minimum_px": { "$ref": "#/$defs/px_value" },
        "recommended_default_min_px": { "$ref": "#/$defs/px_value" },
        "recommended_default_max_px": { "$ref": "#/$defs/px_value" },
        "recommended_maximum_px": { "$ref": "#/$defs/px_value" },
        "token_ref": { "$ref": "#/$defs/nonempty_string" },
        "notes": { "$ref": "#/$defs/nonempty_string" },
        "source_of_truth_ref": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "metric_row": {
      "oneOf": [
        { "$ref": "#/$defs/metric_row_fixed_px" },
        { "$ref": "#/$defs/metric_row_range_px" }
      ]
    },
    "metric_expectation_fixed_px": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric_id", "expected_px"],
      "properties": {
        "metric_id": { "$ref": "#/$defs/metric_id" },
        "expected_px": { "$ref": "#/$defs/px_value" },
        "notes": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "metric_expectation_range_px": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric_id", "expected_minimum_px"],
      "properties": {
        "metric_id": { "$ref": "#/$defs/metric_id" },
        "expected_minimum_px": { "$ref": "#/$defs/px_value" },
        "expected_recommended_default_min_px": { "$ref": "#/$defs/px_value" },
        "expected_recommended_default_max_px": { "$ref": "#/$defs/px_value" },
        "expected_recommended_maximum_px": { "$ref": "#/$defs/px_value" },
        "notes": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "metric_expectation": {
      "oneOf": [
        { "$ref": "#/$defs/metric_expectation_fixed_px" },
        { "$ref": "#/$defs/metric_expectation_range_px" }
      ]
    },
    "component_metrics_ledger_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "component_metrics_schema_version",
        "ledger_id",
        "source_of_truth_refs",
        "metric_rows",
        "minted_at"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "component_metrics_ledger_record" },
        "component_metrics_schema_version": { "$ref": "#/$defs/component_metrics_schema_version" },
        "ledger_id": { "$ref": "#/$defs/opaque_id" },
        "source_of_truth_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/nonempty_string" }
        },
        "metric_rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/metric_row" }
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    },
    "component_metric_case_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "component_metrics_schema_version",
        "case_id",
        "component_surface_class",
        "density_class",
        "input_mode_class",
        "effective_zoom_percent",
        "effective_text_scale_percent",
        "metric_expectations",
        "screenshot_baseline_refs",
        "accessibility_review_refs",
        "minted_at"
      ],
      "properties": {
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "type": "string", "const": "component_metric_case_record" },
        "component_metrics_schema_version": { "$ref": "#/$defs/component_metrics_schema_version" },
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "component_surface_class": { "$ref": "#/$defs/component_surface_class" },
        "density_class": { "$ref": "#/$defs/density_class" },
        "input_mode_class": { "$ref": "#/$defs/input_mode_class" },
        "effective_zoom_percent": {
          "type": "integer",
          "minimum": 25,
          "maximum": 800
        },
        "effective_text_scale_percent": {
          "type": "integer",
          "minimum": 25,
          "maximum": 400
        },
        "metric_expectations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/metric_expectation" }
        },
        "screenshot_baseline_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/nonempty_string" }
        },
        "accessibility_review_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/nonempty_string" }
        },
        "component_packet_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/nonempty_string" }
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    }
  }
}

