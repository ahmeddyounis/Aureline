{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/design/contrast_thresholds.schema.json",
  "title": "Aureline contrast threshold ledger and contrast review fixtures",
  "description": "Boundary schema for the contrast threshold ledger published in artifacts/design/contrast_threshold_rows.yaml and the worked fixtures under fixtures/design/contrast_review_cases. The ledger freezes named contrast targets for text, UI boundaries, focus indicators, badges/banners, diff cues, chart marks, and overlay chrome across dark/light parity and first-party high-contrast themes. Fixtures provide mechanically reviewable substitution examples for high-contrast, low-color/reduced-chroma, print/export, and screenshot/publication contexts without relying on hue alone.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/contrast_threshold_ledger_record" },
    { "$ref": "#/$defs/contrast_review_case_record" }
  ],
  "$defs": {
    "contrast_threshold_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for contrast threshold and fixture records."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "contrast_threshold_ledger_record",
        "contrast_review_case_record"
      ]
    },
    "nonempty_string": {
      "type": "string",
      "minLength": 1
    },
    "safe_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2400,
      "description": "Bounded prose safe for docs and fixtures. Raw paths, raw URLs, raw terminal output, secrets, and private identifiers must not appear."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "theme_class": {
      "type": "string",
      "enum": [
        "dark_reference",
        "light_parity",
        "high_contrast_dark",
        "high_contrast_light"
      ],
      "description": "Theme class vocabulary re-exported from the design-token vocabulary without modification."
    },
    "element_class": {
      "type": "string",
      "enum": [
        "text_primary",
        "text_secondary",
        "code_text_primary",
        "code_token_accent",
        "chart_mark",
        "diff_region_boundary",
        "diff_marker_or_glyph",
        "badge_text",
        "badge_boundary",
        "banner_text",
        "banner_boundary",
        "focus_indicator",
        "overlay_text",
        "overlay_boundary"
      ]
    },
    "measurement_kind": {
      "type": "string",
      "enum": [
        "text",
        "non_text_graphic",
        "ui_boundary",
        "focus_indicator"
      ]
    },
    "contrast_ratio": {
      "type": "number",
      "minimum": 1,
      "maximum": 21,
      "description": "Contrast ratio (L1+0.05)/(L2+0.05), per WCAG relative luminance."
    },
    "target_by_theme_class": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dark_reference",
        "light_parity",
        "high_contrast_dark",
        "high_contrast_light"
      ],
      "properties": {
        "dark_reference": { "$ref": "#/$defs/contrast_ratio" },
        "light_parity": { "$ref": "#/$defs/contrast_ratio" },
        "high_contrast_dark": { "$ref": "#/$defs/contrast_ratio" },
        "high_contrast_light": { "$ref": "#/$defs/contrast_ratio" }
      }
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonempty_string" },
      "uniqueItems": true
    },
    "nonempty_ref_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonempty_string" },
      "uniqueItems": true
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "$ref": "#/$defs/nonempty_string" },
        "scenario": { "$ref": "#/$defs/safe_summary" },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonempty_string" },
          "uniqueItems": true
        }
      }
    },
    "contrast_threshold_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "threshold_id",
        "element_class",
        "measurement_kind",
        "target_by_theme_class"
      ],
      "properties": {
        "threshold_id": { "$ref": "#/$defs/nonempty_string" },
        "element_class": { "$ref": "#/$defs/element_class" },
        "measurement_kind": { "$ref": "#/$defs/measurement_kind" },
        "target_by_theme_class": { "$ref": "#/$defs/target_by_theme_class" },
        "source_of_truth_refs": { "$ref": "#/$defs/ref_array" },
        "notes": { "$ref": "#/$defs/safe_summary" }
      }
    },
    "contrast_threshold_ledger_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "contrast_threshold_schema_version",
        "ledger_id",
        "source_of_truth_refs",
        "threshold_rows",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "type": "string", "const": "contrast_threshold_ledger_record" },
        "contrast_threshold_schema_version": { "$ref": "#/$defs/contrast_threshold_schema_version" },
        "ledger_id": { "$ref": "#/$defs/nonempty_string" },
        "source_of_truth_refs": { "$ref": "#/$defs/nonempty_ref_array" },
        "threshold_rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/contrast_threshold_row_record" }
        },
        "minted_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "substitution_context_class": {
      "type": "string",
      "enum": [
        "interactive_standard",
        "high_contrast",
        "forced_colors",
        "low_color",
        "reduced_chroma",
        "print_export",
        "screenshot_publication"
      ]
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "diff_surface",
        "evidence_chart",
        "trust_warning",
        "notification_surface",
        "badge",
        "banner",
        "focus_indicator",
        "overlay",
        "other"
      ]
    },
    "non_color_cue": {
      "type": "string",
      "enum": [
        "text_label",
        "icon_glyph",
        "shape",
        "border",
        "pattern",
        "plus_minus_marker",
        "line_style",
        "marker_shape",
        "underline_style",
        "keyboard_detail_route"
      ]
    },
    "threshold_assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "threshold_id_ref",
        "theme_class"
      ],
      "properties": {
        "threshold_id_ref": { "$ref": "#/$defs/nonempty_string" },
        "theme_class": { "$ref": "#/$defs/theme_class" },
        "element_description": { "$ref": "#/$defs/safe_summary" },
        "notes": { "$ref": "#/$defs/safe_summary" }
      }
    },
    "substitution_example": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_family",
        "context_class",
        "summary",
        "required_non_color_cues"
      ],
      "properties": {
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "context_class": { "$ref": "#/$defs/substitution_context_class" },
        "summary": { "$ref": "#/$defs/safe_summary" },
        "required_non_color_cues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_color_cue" },
          "uniqueItems": true
        },
        "notes": { "$ref": "#/$defs/safe_summary" }
      }
    },
    "severity_signal_class": {
      "type": "string",
      "enum": [
        "error",
        "warning",
        "destructive_action",
        "degraded_mode",
        "support_state_cue"
      ]
    },
    "severity_independence_assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_class",
        "required_channels"
      ],
      "properties": {
        "signal_class": { "$ref": "#/$defs/severity_signal_class" },
        "required_channels": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/non_color_cue" },
          "uniqueItems": true
        },
        "notes": { "$ref": "#/$defs/safe_summary" }
      }
    },
    "contrast_review_case_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "contrast_threshold_schema_version",
        "case_id",
        "scenario",
        "surfaces_under_review",
        "threshold_assertions",
        "substitution_examples",
        "severity_independence_assertions",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "type": "string", "const": "contrast_review_case_record" },
        "contrast_threshold_schema_version": { "$ref": "#/$defs/contrast_threshold_schema_version" },
        "case_id": { "$ref": "#/$defs/nonempty_string" },
        "case_revision_ref": { "$ref": "#/$defs/nonempty_string" },
        "scenario": { "$ref": "#/$defs/safe_summary" },
        "surfaces_under_review": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_family" },
          "uniqueItems": true
        },
        "threshold_assertions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/threshold_assertion" }
        },
        "substitution_examples": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/substitution_example" }
        },
        "severity_independence_assertions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/severity_independence_assertion" }
        },
        "source_of_truth_refs": { "$ref": "#/$defs/ref_array" },
        "minted_at": { "$ref": "#/$defs/timestamp" }
      }
    }
  }
}

