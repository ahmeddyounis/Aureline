{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/design/theme_import_mapping_report.schema.json",
  "title": "Aureline theme import-mapping audited report and audit-event records",
  "description": "Boundary schema for the theme_import_mapping_report_record and theme_import_mapping_audit_event_record frozen in docs/design/theme_support_and_inheritance_contract.md. Every imported translated theme emits one audited report pinning source tool/ecosystem/version, the source theme identifier, target theme classes, per-slot mapping rows (translated, unsupported, unresolved, blocked, deprecated-replacement, substituted-fallback), syntax-token coverage, fallback token classes, the protected-cue honesty check matrix, the appearance checkpoint, and the rollback path. The audited record is the design-side twin of the user-facing theme_import_report_record owned by schemas/ux/theme_import_report.schema.json; this record cites the user-facing record by id and pins its rows against the canonical token-export manifest. Theme classes, token-family classes, semantic-status, trust-visual-state, and redaction-class vocabularies are re-exported by reference from schemas/design/token_export_manifest.schema.json and schemas/governance/capability_lifecycle.schema.json without modification. Raw source theme files, raw token values, raw rendered screenshots, raw URLs, raw absolute paths, and raw user content never cross this boundary; this schema carries opaque ids, typed vocabulary, small counts, and short privacy-safe labels only.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/theme_import_mapping_report_record" },
    { "$ref": "#/$defs/theme_import_mapping_audit_event_record" }
  ],
  "$defs": {
    "theme_import_mapping_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for theme import-mapping audited reports. Vocabulary additions are additive-minor and require a version bump."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1
    },

    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },

    "short_note_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "theme_class": {
      "type": "string",
      "enum": [
        "dark_reference",
        "light_parity",
        "high_contrast_dark",
        "high_contrast_light"
      ],
      "description": "Re-exported from schemas/design/token_export_manifest.schema.json without modification."
    },

    "token_family_class": {
      "type": "string",
      "enum": [
        "color_brand",
        "color_functional_accent",
        "color_neutral",
        "color_state",
        "color_semantic_theme",
        "color_syntax",
        "color_diff",
        "color_chart",
        "typography_role",
        "typography_scale",
        "text_rule",
        "spacing",
        "sizing",
        "radius",
        "border_stroke",
        "elevation",
        "opacity_scrim",
        "layer_portal_order",
        "motion_duration",
        "motion_easing",
        "motion_restriction",
        "density",
        "icon_treatment",
        "semantic_status",
        "trust_visual_state"
      ],
      "description": "Re-exported from schemas/design/token_export_manifest.schema.json without modification."
    },

    "semantic_status_class": {
      "type": "string",
      "enum": ["success", "warning", "danger", "info", "insight"]
    },

    "trust_visual_state_class": {
      "type": "string",
      "enum": [
        "trusted_full",
        "restricted_workspace",
        "remote_target_active",
        "collaboration_active",
        "ai_draft_pending",
        "ai_applied",
        "index_warming",
        "debugging_active",
        "quiet_hours_active",
        "policy_locked"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted"]
        },
        "execution_context_id": { "type": "string", "minLength": 1 }
      }
    },

    "source_ecosystem_class": {
      "type": "string",
      "enum": [
        "vscode",
        "jetbrains",
        "vim",
        "emacs",
        "zed",
        "sublime",
        "textmate",
        "unknown"
      ]
    },

    "source_tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ecosystem",
        "source_tool_name",
        "source_tool_version",
        "source_theme_identifier"
      ],
      "properties": {
        "source_ecosystem": { "$ref": "#/$defs/source_ecosystem_class" },
        "source_tool_name": { "$ref": "#/$defs/short_label_text" },
        "source_tool_version": { "$ref": "#/$defs/short_label_text" },
        "source_theme_identifier": { "$ref": "#/$defs/opaque_id" },
        "source_schema_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },

    "slot_class": {
      "type": "string",
      "enum": [
        "semantic_theme_token",
        "component_token",
        "syntax_token",
        "diff_token",
        "terminal_token",
        "icon_slot",
        "motion_preset",
        "density_token",
        "unknown_source_slot"
      ]
    },

    "mapping_state_class": {
      "type": "string",
      "enum": [
        "translated",
        "substituted_fallback",
        "unsupported",
        "unresolved",
        "blocked_honesty",
        "deprecated_replacement"
      ]
    },

    "fallback_token_class": {
      "type": "string",
      "enum": [
        "semantic_neutral",
        "semantic_warning",
        "semantic_danger",
        "trust_visual_state",
        "syntax_default",
        "syntax_comment",
        "diff_default",
        "focus_ring_default",
        "density_default",
        "motion_reduced_default",
        "no_fallback_blocked"
      ]
    },

    "parity_claim_state_class": {
      "type": "string",
      "enum": [
        "not_claimed",
        "claimed_with_report",
        "partial_claim_with_gaps",
        "denied_unresolved_or_blocked"
      ]
    },

    "import_outcome_class": {
      "type": "string",
      "enum": [
        "preview_ready",
        "applied",
        "applied_with_warnings",
        "blocked",
        "rolled_back",
        "cancelled",
        "policy_denied",
        "review_required"
      ]
    },

    "rollback_path_class": {
      "type": "string",
      "enum": [
        "restore_appearance_checkpoint",
        "discard_preview",
        "reopen_import_review",
        "manual_repair_required",
        "rollback_unavailable_denied"
      ]
    },

    "protected_cue_class": {
      "type": "string",
      "enum": ["trust", "policy_lock", "severity", "source_integrity"]
    },

    "non_color_cue": {
      "type": "string",
      "enum": [
        "shape",
        "border",
        "icon",
        "text",
        "label_chip",
        "position",
        "pattern",
        "accessible_name"
      ]
    },

    "check_result_state": {
      "type": "string",
      "enum": ["passed", "warning", "failed_blocked"]
    },

    "audit_event_id": {
      "type": "string",
      "enum": [
        "theme_import_mapping_report_emitted",
        "theme_import_mapping_report_refused",
        "theme_import_mapping_report_downgraded",
        "theme_import_mapping_report_rolled_back"
      ]
    },

    "denial_reason": {
      "type": "string",
      "enum": [
        "unknown_token_dropped",
        "unresolved_mapping_hidden",
        "rollback_path_missing",
        "appearance_checkpoint_missing",
        "protected_cue_color_only",
        "color_alone_conveyed_required_meaning",
        "syntax_coverage_unreported",
        "mapping_summary_count_mismatch",
        "design_token_schema_version_lagging",
        "token_export_manifest_unresolved",
        "theme_package_manifest_unresolved",
        "shadow_registry_detected"
      ]
    },

    "mapping_slot_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_slot_ref",
        "target_token_ref",
        "slot_class",
        "mapping_state",
        "fallback_token_class",
        "visible_in_report"
      ],
      "properties": {
        "source_slot_ref": { "$ref": "#/$defs/opaque_id" },
        "target_token_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "token_family_class": { "$ref": "#/$defs/token_family_class" },
        "slot_class": { "$ref": "#/$defs/slot_class" },
        "mapping_state": { "$ref": "#/$defs/mapping_state_class" },
        "fallback_token_class": { "$ref": "#/$defs/fallback_token_class" },
        "deprecated_replacement_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "notes": { "$ref": "#/$defs/short_note_text" },
        "visible_in_report": {
          "type": "boolean",
          "const": true,
          "description": "Frozen at true: every mapping row MUST be visible in the audited report. Surfaces that hide rows behind a generic 'fallback applied' message are non-conforming."
        }
      }
    },

    "mapping_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_source_slot_count",
        "translated_slot_count",
        "unsupported_slot_count",
        "unresolved_mapping_count",
        "substituted_with_fallback_count",
        "blocked_honesty_count",
        "deprecated_replacement_count"
      ],
      "properties": {
        "total_source_slot_count": { "type": "integer", "minimum": 0 },
        "translated_slot_count": { "type": "integer", "minimum": 0 },
        "unsupported_slot_count": { "type": "integer", "minimum": 0 },
        "unresolved_mapping_count": { "type": "integer", "minimum": 0 },
        "substituted_with_fallback_count": { "type": "integer", "minimum": 0 },
        "blocked_honesty_count": { "type": "integer", "minimum": 0 },
        "deprecated_replacement_count": { "type": "integer", "minimum": 0 }
      },
      "description": "Aggregate mapping counts. The seven counts MUST sum to total_source_slot_count: translated + unsupported + unresolved + substituted_with_fallback + blocked_honesty + deprecated_replacement = total_source_slot_count."
    },

    "syntax_token_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_source_scope_count",
        "translated_scope_count",
        "substituted_scope_count",
        "unresolved_scope_count",
        "blocked_scope_count",
        "coverage_percent",
        "unsupported_scope_refs"
      ],
      "properties": {
        "total_source_scope_count": { "type": "integer", "minimum": 0 },
        "translated_scope_count": { "type": "integer", "minimum": 0 },
        "substituted_scope_count": { "type": "integer", "minimum": 0 },
        "unresolved_scope_count": { "type": "integer", "minimum": 0 },
        "blocked_scope_count": { "type": "integer", "minimum": 0 },
        "coverage_percent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "unsupported_scope_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },

    "rollback_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rollback_path_class",
        "checkpoint_ref",
        "rollback_ref",
        "user_visible_action_id"
      ],
      "properties": {
        "rollback_path_class": { "$ref": "#/$defs/rollback_path_class" },
        "checkpoint_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "rollback_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "user_visible_action_id": { "$ref": "#/$defs/opaque_id" },
        "notes": { "$ref": "#/$defs/short_note_text" }
      }
    },

    "protected_cue_honesty_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protected_cue_class",
        "non_color_cues",
        "color_alone_prohibited",
        "preserved_in_high_contrast",
        "preserved_in_forced_colors",
        "result_state"
      ],
      "properties": {
        "protected_cue_class": { "$ref": "#/$defs/protected_cue_class" },
        "trust_visual_state_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/trust_visual_state_class" }
          ]
        },
        "semantic_status_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/semantic_status_class" }
          ]
        },
        "non_color_cues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_color_cue" },
          "uniqueItems": true
        },
        "color_alone_prohibited": {
          "type": "boolean",
          "const": true
        },
        "preserved_in_high_contrast": {
          "type": "boolean",
          "const": true
        },
        "preserved_in_forced_colors": {
          "type": "boolean",
          "const": true
        },
        "result_state": { "$ref": "#/$defs/check_result_state" },
        "denial_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/denial_reason" },
          "uniqueItems": true
        },
        "notes": { "$ref": "#/$defs/short_note_text" }
      }
    },

    "theme_import_mapping_report_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "theme_import_mapping_schema_version",
        "report_id",
        "import_session_ref",
        "source_tool",
        "source_artifact_ref",
        "target_theme_package_ref",
        "target_theme_classes",
        "token_export_manifest_ref",
        "translated_slots",
        "unsupported_slots",
        "unresolved_slots",
        "blocked_slots",
        "syntax_token_coverage",
        "mapping_summary",
        "fallback_token_classes",
        "protected_cue_honesty_checks",
        "appearance_checkpoint_ref",
        "rollback_path",
        "parity_claim_state",
        "import_outcome",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "theme_import_mapping_report_record" },
        "theme_import_mapping_schema_version": { "$ref": "#/$defs/theme_import_mapping_schema_version" },
        "report_id": { "$ref": "#/$defs/opaque_id" },
        "import_session_ref": { "$ref": "#/$defs/opaque_id" },
        "source_tool": { "$ref": "#/$defs/source_tool" },
        "source_artifact_ref": { "$ref": "#/$defs/opaque_id" },
        "target_theme_package_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "target_theme_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/theme_class" },
          "uniqueItems": true
        },
        "token_export_manifest_ref": { "$ref": "#/$defs/opaque_id" },
        "translated_slots": {
          "type": "array",
          "items": { "$ref": "#/$defs/mapping_slot_row" }
        },
        "unsupported_slots": {
          "type": "array",
          "items": { "$ref": "#/$defs/mapping_slot_row" }
        },
        "unresolved_slots": {
          "type": "array",
          "items": { "$ref": "#/$defs/mapping_slot_row" }
        },
        "blocked_slots": {
          "type": "array",
          "items": { "$ref": "#/$defs/mapping_slot_row" }
        },
        "syntax_token_coverage": { "$ref": "#/$defs/syntax_token_coverage" },
        "mapping_summary": { "$ref": "#/$defs/mapping_summary" },
        "fallback_token_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/fallback_token_class" },
          "uniqueItems": true
        },
        "protected_cue_honesty_checks": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/protected_cue_honesty_check" }
        },
        "appearance_checkpoint_ref": { "$ref": "#/$defs/opaque_id" },
        "rollback_path": { "$ref": "#/$defs/rollback_path" },
        "parity_claim_state": { "$ref": "#/$defs/parity_claim_state_class" },
        "import_outcome": { "$ref": "#/$defs/import_outcome_class" },
        "linked_ux_import_report_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Opaque ref to the user-facing theme_import_report_record owned by schemas/ux/theme_import_report.schema.json. The audited row pins the user-facing record by id; it never re-mints the user-facing prose."
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Protected-cue honesty checks MUST cover trust.",
          "properties": {
            "protected_cue_honesty_checks": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": { "protected_cue_class": { "const": "trust" } },
                "required": ["protected_cue_class"]
              }
            }
          }
        },
        {
          "description": "Protected-cue honesty checks MUST cover policy_lock.",
          "properties": {
            "protected_cue_honesty_checks": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": { "protected_cue_class": { "const": "policy_lock" } },
                "required": ["protected_cue_class"]
              }
            }
          }
        },
        {
          "description": "Protected-cue honesty checks MUST cover severity.",
          "properties": {
            "protected_cue_honesty_checks": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": { "protected_cue_class": { "const": "severity" } },
                "required": ["protected_cue_class"]
              }
            }
          }
        },
        {
          "description": "Protected-cue honesty checks MUST cover source_integrity.",
          "properties": {
            "protected_cue_honesty_checks": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": { "protected_cue_class": { "const": "source_integrity" } },
                "required": ["protected_cue_class"]
              }
            }
          }
        },
        {
          "description": "claimed_with_report parity requires zero unresolved and zero blocked counts.",
          "if": {
            "properties": { "parity_claim_state": { "const": "claimed_with_report" } },
            "required": ["parity_claim_state"]
          },
          "then": {
            "properties": {
              "mapping_summary": {
                "type": "object",
                "properties": {
                  "unresolved_mapping_count": { "const": 0 },
                  "blocked_honesty_count": { "const": 0 }
                }
              }
            }
          }
        },
        {
          "description": "denied_unresolved_or_blocked parity requires at least one unresolved or blocked row.",
          "if": {
            "properties": {
              "parity_claim_state": { "const": "denied_unresolved_or_blocked" }
            },
            "required": ["parity_claim_state"]
          },
          "then": {
            "properties": {
              "mapping_summary": {
                "anyOf": [
                  {
                    "properties": {
                      "unresolved_mapping_count": { "minimum": 1 }
                    }
                  },
                  {
                    "properties": {
                      "blocked_honesty_count": { "minimum": 1 }
                    }
                  }
                ]
              }
            }
          }
        }
      ],
      "description": "One audited theme import-mapping report. See docs/design/theme_support_and_inheritance_contract.md §3."
    },

    "theme_import_mapping_audit_event_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "theme_import_mapping_schema_version",
        "event_id",
        "audit_event_id",
        "subject_ref",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "theme_import_mapping_audit_event_record" },
        "theme_import_mapping_schema_version": { "$ref": "#/$defs/theme_import_mapping_schema_version" },
        "event_id": { "$ref": "#/$defs/opaque_id" },
        "audit_event_id": { "$ref": "#/$defs/audit_event_id" },
        "denial_reason": { "$ref": "#/$defs/denial_reason" },
        "subject_ref": { "$ref": "#/$defs/opaque_id" },
        "prior_parity_claim_state": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/parity_claim_state_class" }
          ]
        },
        "resulting_parity_claim_state": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/parity_claim_state_class" }
          ]
        },
        "notes": { "$ref": "#/$defs/short_note_text" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Refused events MUST cite a denial_reason.",
          "if": {
            "properties": {
              "audit_event_id": { "const": "theme_import_mapping_report_refused" }
            },
            "required": ["audit_event_id"]
          },
          "then": {
            "required": ["denial_reason"]
          }
        }
      ],
      "description": "One event per import-mapping report emission, refusal, downgrade, or rollback on the theme-import-mapping audit stream."
    }
  }
}
