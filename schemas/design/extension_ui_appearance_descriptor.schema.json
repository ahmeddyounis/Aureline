{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/design/extension_ui_appearance_descriptor.schema.json",
  "title": "Aureline extension/embedded UI appearance descriptor and audit-event records",
  "description": "Boundary schema for the extension_ui_appearance_descriptor_record and extension_ui_appearance_audit_event_record frozen in docs/design/theme_support_and_inheritance_contract.md. Every extension or embedded surface (extension-hosted, embedded webview, service dashboard, marketplace/account, docs/help embedded, native extension panel, terminal decoration) emits one audited descriptor declaring inherits/partial/does_not_inherit for theme/focus/contrast/density/reduced-motion, the per-mode theme/contrast support row references, the protected-cue preservation matrix, the embedded-boundary-card ref, the theme-package linkage, the appearance-session ref, and the canonical token-export linkage. The descriptor is the design-side audited twin of the user-facing extension_surface_appearance_record owned by schemas/ux/appearance_checkpoint.schema.json; this record cites that record by id and pins its inheritance and support rows against the canonical token-export manifest. Theme classes, density classes, accessibility postures, semantic-status, trust-visual-state, and redaction-class vocabularies are re-exported by reference from schemas/design/token_export_manifest.schema.json and schemas/governance/capability_lifecycle.schema.json without modification. Raw token values, raw asset bytes, raw rendered screenshots, raw URLs, raw absolute paths, and raw user content never cross this boundary; this schema carries opaque ids, typed vocabulary, small counts, and short privacy-safe labels only.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/extension_ui_appearance_descriptor_record" },
    { "$ref": "#/$defs/extension_ui_appearance_audit_event_record" }
  ],
  "$defs": {
    "extension_ui_appearance_schema_version": {
      "type": "integer",
      "const": 1
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1
    },

    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },

    "short_note_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "theme_class": {
      "type": "string",
      "enum": [
        "dark_reference",
        "light_parity",
        "high_contrast_dark",
        "high_contrast_light"
      ]
    },

    "contrast_mode": {
      "type": "string",
      "enum": [
        "contrast_standard",
        "contrast_high",
        "contrast_forced_colors"
      ]
    },

    "density_class": {
      "type": "string",
      "enum": ["compact", "standard", "comfortable"]
    },

    "accessibility_posture_class": {
      "type": "string",
      "enum": [
        "motion_standard",
        "motion_reduced",
        "motion_low_motion",
        "motion_power_saver",
        "motion_critical_hot_path"
      ]
    },

    "trust_visual_state_class": {
      "type": "string",
      "enum": [
        "trusted_full",
        "restricted_workspace",
        "remote_target_active",
        "collaboration_active",
        "ai_draft_pending",
        "ai_applied",
        "index_warming",
        "debugging_active",
        "quiet_hours_active",
        "policy_locked"
      ]
    },

    "semantic_status_class": {
      "type": "string",
      "enum": ["success", "warning", "danger", "info", "insight"]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted"]
        },
        "execution_context_id": { "type": "string", "minLength": 1 }
      }
    },

    "surface_family_class": {
      "type": "string",
      "enum": [
        "extension_hosted_surface",
        "embedded_webview_surface",
        "service_dashboard_surface",
        "docs_help_embedded_surface",
        "native_extension_panel",
        "terminal_decoration_surface",
        "marketplace_account_surface"
      ]
    },

    "inheritance_axis_class": {
      "type": "string",
      "enum": ["theme", "focus", "contrast", "density", "reduced_motion"]
    },

    "inheritance_state_class": {
      "type": "string",
      "enum": ["inherits", "partial", "does_not_inherit"]
    },

    "parity_claim_state_class": {
      "type": "string",
      "enum": [
        "no_parity_claim",
        "claims_host_parity",
        "partial_claim_with_gaps",
        "denied_claim"
      ]
    },

    "support_state_class": {
      "type": "string",
      "enum": [
        "supported",
        "partial",
        "unsupported",
        "not_claimed",
        "denied"
      ]
    },

    "protected_cue_class": {
      "type": "string",
      "enum": ["trust", "policy_lock", "severity", "source_integrity"]
    },

    "non_color_cue": {
      "type": "string",
      "enum": [
        "shape",
        "border",
        "icon",
        "text",
        "label_chip",
        "position",
        "pattern",
        "accessible_name"
      ]
    },

    "check_result_state": {
      "type": "string",
      "enum": ["passed", "warning", "failed_blocked"]
    },

    "audit_event_id": {
      "type": "string",
      "enum": [
        "extension_ui_appearance_descriptor_emitted",
        "extension_ui_appearance_descriptor_refused",
        "extension_ui_appearance_descriptor_gap_disclosed",
        "extension_ui_appearance_descriptor_downgraded"
      ]
    },

    "denial_reason": {
      "type": "string",
      "enum": [
        "embedded_boundary_card_missing",
        "extension_inheritance_gap_hidden",
        "color_alone_conveyed_required_meaning",
        "protected_cue_color_only",
        "density_changed_information_architecture",
        "reduced_motion_stripped_state_conveyance",
        "evidence_ref_missing",
        "design_token_schema_version_lagging",
        "token_export_manifest_unresolved",
        "theme_package_manifest_unresolved",
        "shadow_registry_detected"
      ]
    },

    "inheritance_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "axis",
        "inheritance_state",
        "claim_source_ref",
        "known_gap_count",
        "gap_refs",
        "user_visible_disclosure_required"
      ],
      "properties": {
        "axis": { "$ref": "#/$defs/inheritance_axis_class" },
        "inheritance_state": { "$ref": "#/$defs/inheritance_state_class" },
        "claim_source_ref": { "$ref": "#/$defs/opaque_id" },
        "known_gap_count": {
          "type": "integer",
          "minimum": 0
        },
        "gap_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "user_visible_disclosure_required": {
          "type": "boolean",
          "description": "MUST be true whenever inheritance_state ∈ {partial, does_not_inherit}; MAY be true for inherits rows when the surface wants to expose proof."
        },
        "notes": { "$ref": "#/$defs/short_note_text" }
      },
      "allOf": [
        {
          "description": "partial / does_not_inherit rows require known_gap_count ≥ 1 and user_visible_disclosure_required = true.",
          "if": {
            "properties": {
              "inheritance_state": {
                "enum": ["partial", "does_not_inherit"]
              }
            },
            "required": ["inheritance_state"]
          },
          "then": {
            "properties": {
              "known_gap_count": { "minimum": 1 },
              "user_visible_disclosure_required": { "const": true }
            }
          }
        }
      ]
    },

    "theme_contrast_support_row_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "theme_class",
        "contrast_mode",
        "support_state",
        "claim_ref"
      ],
      "properties": {
        "theme_class": { "$ref": "#/$defs/theme_class" },
        "contrast_mode": { "$ref": "#/$defs/contrast_mode" },
        "support_state": { "$ref": "#/$defs/support_state_class" },
        "claim_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque ref to a theme_support_row_claim_record. The descriptor cites the audited claim by id; it never re-mints the support matrix locally."
        },
        "evidence_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "gap_summary": { "$ref": "#/$defs/short_note_text" }
      }
    },

    "protected_cue_preservation_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protected_cue_class",
        "non_color_cues",
        "color_alone_prohibited",
        "preserved_in_high_contrast",
        "preserved_in_forced_colors",
        "validation_state"
      ],
      "properties": {
        "protected_cue_class": { "$ref": "#/$defs/protected_cue_class" },
        "trust_visual_state_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/trust_visual_state_class" }
          ]
        },
        "semantic_status_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/semantic_status_class" }
          ]
        },
        "non_color_cues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_color_cue" },
          "uniqueItems": true
        },
        "color_alone_prohibited": {
          "type": "boolean",
          "const": true
        },
        "preserved_in_high_contrast": {
          "type": "boolean",
          "const": true
        },
        "preserved_in_forced_colors": {
          "type": "boolean",
          "const": true
        },
        "validation_state": { "$ref": "#/$defs/check_result_state" },
        "notes": { "$ref": "#/$defs/short_note_text" }
      }
    },

    "extension_ui_appearance_descriptor_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "extension_ui_appearance_schema_version",
        "descriptor_id",
        "extension_package_ref",
        "surface_ref",
        "surface_family",
        "owner_label",
        "parity_claim_state",
        "inheritance_rows",
        "theme_contrast_support_rows",
        "protected_cue_preservation",
        "token_export_manifest_ref",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "extension_ui_appearance_descriptor_record" },
        "extension_ui_appearance_schema_version": { "$ref": "#/$defs/extension_ui_appearance_schema_version" },
        "descriptor_id": { "$ref": "#/$defs/opaque_id" },
        "extension_package_ref": { "$ref": "#/$defs/opaque_id" },
        "surface_ref": { "$ref": "#/$defs/opaque_id" },
        "surface_family": { "$ref": "#/$defs/surface_family_class" },
        "owner_label": { "$ref": "#/$defs/short_label_text" },
        "parity_claim_state": { "$ref": "#/$defs/parity_claim_state_class" },
        "inheritance_rows": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/inheritance_row" }
        },
        "theme_contrast_support_rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/theme_contrast_support_row_ref" }
        },
        "protected_cue_preservation": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/protected_cue_preservation_row" }
        },
        "token_export_manifest_ref": { "$ref": "#/$defs/opaque_id" },
        "linked_theme_package_manifest_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "linked_ux_extension_appearance_record_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "embedded_boundary_card_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "appearance_session_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "compatibility_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/short_note_text" },
          "uniqueItems": true
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Inheritance rows MUST cover theme.",
          "properties": {
            "inheritance_rows": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": { "axis": { "const": "theme" } },
                "required": ["axis"]
              }
            }
          }
        },
        {
          "description": "Inheritance rows MUST cover focus.",
          "properties": {
            "inheritance_rows": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": { "axis": { "const": "focus" } },
                "required": ["axis"]
              }
            }
          }
        },
        {
          "description": "Inheritance rows MUST cover contrast.",
          "properties": {
            "inheritance_rows": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": { "axis": { "const": "contrast" } },
                "required": ["axis"]
              }
            }
          }
        },
        {
          "description": "Inheritance rows MUST cover density.",
          "properties": {
            "inheritance_rows": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": { "axis": { "const": "density" } },
                "required": ["axis"]
              }
            }
          }
        },
        {
          "description": "Inheritance rows MUST cover reduced_motion.",
          "properties": {
            "inheritance_rows": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": { "axis": { "const": "reduced_motion" } },
                "required": ["axis"]
              }
            }
          }
        },
        {
          "description": "Protected-cue preservation MUST cover trust.",
          "properties": {
            "protected_cue_preservation": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": { "protected_cue_class": { "const": "trust" } },
                "required": ["protected_cue_class"]
              }
            }
          }
        },
        {
          "description": "Protected-cue preservation MUST cover policy_lock.",
          "properties": {
            "protected_cue_preservation": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": { "protected_cue_class": { "const": "policy_lock" } },
                "required": ["protected_cue_class"]
              }
            }
          }
        },
        {
          "description": "Protected-cue preservation MUST cover severity.",
          "properties": {
            "protected_cue_preservation": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": { "protected_cue_class": { "const": "severity" } },
                "required": ["protected_cue_class"]
              }
            }
          }
        },
        {
          "description": "Protected-cue preservation MUST cover source_integrity.",
          "properties": {
            "protected_cue_preservation": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": { "protected_cue_class": { "const": "source_integrity" } },
                "required": ["protected_cue_class"]
              }
            }
          }
        },
        {
          "description": "Webview-backed surfaces require a non-null embedded_boundary_card_ref.",
          "if": {
            "properties": {
              "surface_family": {
                "enum": [
                  "embedded_webview_surface",
                  "service_dashboard_surface",
                  "docs_help_embedded_surface",
                  "marketplace_account_surface"
                ]
              }
            },
            "required": ["surface_family"]
          },
          "then": {
            "required": ["embedded_boundary_card_ref"],
            "properties": {
              "embedded_boundary_card_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        },
        {
          "description": "claims_host_parity descriptors require every inheritance row to be inherits.",
          "if": {
            "properties": { "parity_claim_state": { "const": "claims_host_parity" } },
            "required": ["parity_claim_state"]
          },
          "then": {
            "properties": {
              "inheritance_rows": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "inheritance_state": { "const": "inherits" }
                  },
                  "required": ["inheritance_state"]
                }
              }
            }
          }
        }
      ],
      "description": "One audited extension/embedded UI appearance descriptor. See docs/design/theme_support_and_inheritance_contract.md §4."
    },

    "extension_ui_appearance_audit_event_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "extension_ui_appearance_schema_version",
        "event_id",
        "audit_event_id",
        "subject_ref",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "extension_ui_appearance_audit_event_record" },
        "extension_ui_appearance_schema_version": { "$ref": "#/$defs/extension_ui_appearance_schema_version" },
        "event_id": { "$ref": "#/$defs/opaque_id" },
        "audit_event_id": { "$ref": "#/$defs/audit_event_id" },
        "denial_reason": { "$ref": "#/$defs/denial_reason" },
        "subject_ref": { "$ref": "#/$defs/opaque_id" },
        "prior_parity_claim_state": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/parity_claim_state_class" }
          ]
        },
        "resulting_parity_claim_state": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/parity_claim_state_class" }
          ]
        },
        "notes": { "$ref": "#/$defs/short_note_text" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Refused events MUST cite a denial_reason.",
          "if": {
            "properties": {
              "audit_event_id": { "const": "extension_ui_appearance_descriptor_refused" }
            },
            "required": ["audit_event_id"]
          },
          "then": {
            "required": ["denial_reason"]
          }
        }
      ],
      "description": "One event per descriptor emission, refusal, gap disclosure, or downgrade on the extension-ui-appearance audit stream."
    }
  }
}
