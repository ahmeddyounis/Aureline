{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/design/density_case.schema.json",
  "title": "Aureline density case fixture",
  "description": "Boundary schema for density-case fixtures under fixtures/design/density_cases. These cases bind the frozen density vocabulary (compact/standard/comfortable) to the geometry token ledger (size.*, space.*) and document which first-party shell surfaces are expected to honor the density-derived measurements.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "density_case_schema_version",
    "case_id",
    "density_class",
    "surface_claims",
    "token_expectations",
    "minted_at"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "additionalProperties": true,
      "description": "Fixture metadata for humans; ignored by validators beyond being well-formed JSON."
    },
    "record_kind": {
      "type": "string",
      "const": "density_case_record"
    },
    "density_case_schema_version": {
      "type": "integer",
      "const": 1
    },
    "case_id": {
      "type": "string",
      "pattern": "^density_case:[a-z0-9_\\-]+(:[a-z0-9_\\-]+)*:[0-9]{2}$"
    },
    "density_class": {
      "$ref": "./token_export_manifest.schema.json#/$defs/density_class"
    },
    "surface_claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "shell_zones",
          "start_center",
          "command_palette",
          "embedded_docs_help_boundary"
        ]
      }
    },
    "token_expectations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/token_expectation"
      }
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "token_ref": {
      "oneOf": [
        { "$ref": "./geometry_token.schema.json#/$defs/spacing_token" },
        { "$ref": "./geometry_token.schema.json#/$defs/sizing_token" }
      ]
    },
    "token_expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token_ref", "expected_px"],
      "properties": {
        "token_ref": { "$ref": "#/$defs/token_ref" },
        "expected_px": { "type": "integer", "minimum": 0 },
        "notes": { "type": "string", "minLength": 1 }
      }
    }
  }
}

