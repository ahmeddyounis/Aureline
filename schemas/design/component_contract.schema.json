{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/design/component_contract.schema.json",
  "title": "Aureline component contract packet",
  "description": "Boundary schema for the reusable component-contract packet frozen in docs/ux/component_contract_template.md. Every launch-critical or extension-parity-sensitive component publishes one packet naming anatomy, state-machine, content rules, keyboard model, accessibility behavior, token bindings, theme/icon/motion hooks, localization behavior, substitution visibility, extension guidance, and typed evidence hooks. Raw screenshots, raw palette values, and local implementation-only aliases never cross this boundary; the packet carries stable ids, refs, and typed rules only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "component_contract_schema_version",
    "record_kind",
    "component_id",
    "component_title",
    "summary",
    "component_family_class",
    "stability_label",
    "source_anchor_refs",
    "theme_package_hooks",
    "anatomy",
    "state_machine",
    "content_contract",
    "interaction_contract",
    "accessibility_contract",
    "token_binding_rules",
    "visual_asset_hooks",
    "localization_contract",
    "extension_guidance",
    "substitution_and_deprecation",
    "evidence_hooks"
  ],
  "properties": {
    "component_contract_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for the component-contract packet. Current value is 1."
    },
    "record_kind": {
      "type": "string",
      "const": "component_contract_record",
      "description": "Discriminator for this packet family."
    },
    "component_id": {
      "$ref": "#/$defs/stable_id",
      "description": "Stable component identifier. Engineering, design, QA, docs, and extension guidance cite this id verbatim."
    },
    "component_title": {
      "$ref": "#/$defs/nonempty_string",
      "description": "Human-readable component title."
    },
    "summary": {
      "$ref": "#/$defs/nonempty_string",
      "description": "One or two sentence summary of what the component conveys."
    },
    "component_family_class": {
      "$ref": "#/$defs/component_family_class"
    },
    "stability_label": {
      "$ref": "#/$defs/stability_label"
    },
    "source_anchor_refs": {
      "$ref": "#/$defs/nonempty_ref_array",
      "description": "Normative source anchors governing this component contract."
    },
    "theme_package_hooks": {
      "$ref": "#/$defs/theme_package_hooks"
    },
    "anatomy": {
      "$ref": "#/$defs/anatomy_block"
    },
    "state_machine": {
      "$ref": "#/$defs/state_machine_block"
    },
    "content_contract": {
      "$ref": "#/$defs/content_contract_block"
    },
    "interaction_contract": {
      "$ref": "#/$defs/interaction_contract_block"
    },
    "accessibility_contract": {
      "$ref": "#/$defs/accessibility_contract_block"
    },
    "token_binding_rules": {
      "$ref": "#/$defs/token_binding_rules_block"
    },
    "visual_asset_hooks": {
      "$ref": "#/$defs/visual_asset_hooks_block"
    },
    "localization_contract": {
      "$ref": "#/$defs/localization_contract_block"
    },
    "extension_guidance": {
      "$ref": "#/$defs/extension_guidance_block"
    },
    "substitution_and_deprecation": {
      "$ref": "#/$defs/substitution_and_deprecation_block"
    },
    "evidence_hooks": {
      "$ref": "#/$defs/evidence_hooks_block"
    }
  },
  "$defs": {
    "stable_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*$",
      "description": "Stable dot-delimited identifier."
    },
    "slot_id": {
      "$ref": "#/$defs/stable_id"
    },
    "state_ref": {
      "$ref": "#/$defs/stable_id"
    },
    "ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable ref, repo-relative path, or anchor ref."
    },
    "nonempty_string": {
      "type": "string",
      "minLength": 1
    },
    "nonempty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonempty_string" }
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/ref" },
      "uniqueItems": true
    },
    "nonempty_ref_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ref" },
      "uniqueItems": true
    },
    "component_family_class": {
      "type": "string",
      "enum": [
        "result_row",
        "permission_prompt",
        "job_row",
        "banner",
        "dialog_or_sheet",
        "list_row",
        "status_item",
        "other"
      ],
      "description": "High-level component family. The family clarifies the intended review and reuse context; it does not replace the stable component_id."
    },
    "stability_label": {
      "type": "string",
      "enum": ["seed", "draft", "experimental", "beta", "stable"],
      "description": "Lifecycle label for the contract itself."
    },
    "slot_role_class": {
      "type": "string",
      "enum": [
        "surface",
        "icon",
        "illustration",
        "primary_label",
        "secondary_label",
        "status_text",
        "reason_text",
        "status_badge",
        "action",
        "help_link",
        "progress_indicator",
        "metadata"
      ],
      "description": "Role the slot plays in the component anatomy."
    },
    "content_kind_class": {
      "type": "string",
      "enum": [
        "primary_label",
        "supporting_text",
        "status_text",
        "reason_text",
        "raw_identifier",
        "shortcut_hint",
        "action_label",
        "progress_summary",
        "timestamp",
        "badge_label",
        "help_link"
      ],
      "description": "Content kind carried by a slot."
    },
    "overflow_behavior_class": {
      "type": "string",
      "enum": [
        "truncate_tail",
        "wrap",
        "multi_line_expand",
        "preserve_raw",
        "overflow_menu",
        "hide_when_unavailable"
      ],
      "description": "Overflow behavior for a content slot."
    },
    "raw_identifier_display_mode": {
      "type": "string",
      "enum": ["not_applicable", "strict_raw", "localized_wrapper_only"],
      "description": "How the slot treats raw identifiers that must remain exact."
    },
    "theme_class": {
      "$ref": "./token_export_manifest.schema.json#/$defs/theme_class"
    },
    "component_state_class": {
      "$ref": "./token_export_manifest.schema.json#/$defs/component_state_class"
    },
    "accessibility_posture_class": {
      "$ref": "./token_export_manifest.schema.json#/$defs/accessibility_posture_class"
    },
    "density_class": {
      "$ref": "./token_export_manifest.schema.json#/$defs/density_class"
    },
    "icon_treatment_class": {
      "$ref": "./token_export_manifest.schema.json#/$defs/icon_treatment_class"
    },
    "semantic_status_class": {
      "$ref": "./token_export_manifest.schema.json#/$defs/semantic_status_class"
    },
    "trust_visual_state_class": {
      "$ref": "./token_export_manifest.schema.json#/$defs/trust_visual_state_class"
    },
    "theme_package_hook_class": {
      "type": "string",
      "enum": [
        "theme_support_row",
        "theme_package_manifest",
        "appearance_session_contract",
        "token_overlay_contract"
      ],
      "description": "Typed theme-package or appearance hook the component depends on."
    },
    "theme_package_hook_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hook_class", "ref", "required", "notes"],
      "properties": {
        "hook_class": { "$ref": "#/$defs/theme_package_hook_class" },
        "ref": { "$ref": "#/$defs/ref" },
        "required": {
          "type": "boolean",
          "description": "Whether the component cannot truthfully claim the contract without this hook."
        },
        "notes": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "theme_package_hooks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_theme_support_row_ref",
        "supported_theme_classes",
        "hook_records"
      ],
      "properties": {
        "default_theme_support_row_ref": {
          "$ref": "#/$defs/ref",
          "description": "Default theme-support row or equivalent appearance anchor."
        },
        "supported_theme_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/theme_class" },
          "uniqueItems": true
        },
        "hook_records": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/theme_package_hook_record" }
        }
      }
    },
    "slot_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "role_class",
        "required",
        "focusable",
        "localized",
        "description"
      ],
      "properties": {
        "slot_id": { "$ref": "#/$defs/slot_id" },
        "role_class": { "$ref": "#/$defs/slot_role_class" },
        "required": {
          "type": "boolean",
          "description": "Whether the slot must render whenever the component renders."
        },
        "focusable": {
          "type": "boolean",
          "description": "Whether the slot itself can own focus."
        },
        "localized": {
          "type": "boolean",
          "description": "Whether the slot normally participates in translation."
        },
        "description": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "anatomy_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slots", "focus_order", "responsive_reflow_notes"],
      "properties": {
        "slots": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/slot_record" }
        },
        "focus_order": {
          "type": "array",
          "items": { "$ref": "#/$defs/slot_id" },
          "uniqueItems": true,
          "description": "Stable focus order through the component's owned slots."
        },
        "responsive_reflow_notes": {
          "$ref": "#/$defs/nonempty_string_array",
          "description": "How the component reflows when space tightens."
        }
      }
    },
    "state_node_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_ref",
        "display_label",
        "component_state_classes",
        "user_visible_summary",
        "blocks_primary_action",
        "requires_persistent_disclosure"
      ],
      "properties": {
        "state_ref": { "$ref": "#/$defs/state_ref" },
        "display_label": { "$ref": "#/$defs/nonempty_string" },
        "component_state_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/component_state_class" },
          "uniqueItems": true
        },
        "user_visible_summary": {
          "$ref": "#/$defs/nonempty_string",
          "description": "What the user should understand when the component enters this state."
        },
        "blocks_primary_action": {
          "type": "boolean",
          "description": "Whether the component's primary action is unavailable in this state."
        },
        "requires_persistent_disclosure": {
          "type": "boolean",
          "description": "Whether the state must remain visible without hover or tooltip-only disclosure."
        }
      }
    },
    "transition_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_state_ref",
        "event_ref",
        "to_state_ref",
        "user_visible_effect",
        "recovery_action_ref"
      ],
      "properties": {
        "from_state_ref": { "$ref": "#/$defs/state_ref" },
        "event_ref": { "$ref": "#/$defs/nonempty_string" },
        "to_state_ref": { "$ref": "#/$defs/state_ref" },
        "user_visible_effect": { "$ref": "#/$defs/nonempty_string" },
        "recovery_action_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/nonempty_string" }],
          "description": "Named recovery action or null when not applicable."
        }
      }
    },
    "non_color_cue_class": {
      "type": "string",
      "enum": [
        "label_text",
        "icon",
        "border",
        "shape",
        "pattern",
        "position",
        "progress_indicator"
      ],
      "description": "Non-color cue the component uses to preserve meaning."
    },
    "composite_state_rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "when_all_of_component_state_classes",
        "presentation_priority",
        "required_disclosure_slot_ids",
        "non_color_cues"
      ],
      "properties": {
        "when_all_of_component_state_classes": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/component_state_class" },
          "uniqueItems": true
        },
        "presentation_priority": {
          "type": "integer",
          "minimum": 1,
          "description": "Higher number means this composite rule wins over lower-priority overlaps."
        },
        "required_disclosure_slot_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/slot_id" },
          "uniqueItems": true
        },
        "non_color_cues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_color_cue_class" },
          "uniqueItems": true
        }
      }
    },
    "state_machine_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_state_ref",
        "state_nodes",
        "transitions",
        "composite_state_rules"
      ],
      "properties": {
        "default_state_ref": { "$ref": "#/$defs/state_ref" },
        "state_nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/state_node_record" }
        },
        "transitions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/transition_record" }
        },
        "composite_state_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/composite_state_rule_record" }
        }
      }
    },
    "slot_content_rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "content_kind_class",
        "max_lines",
        "overflow_behavior_class",
        "plain_language_required",
        "raw_identifier_display_mode",
        "notes"
      ],
      "properties": {
        "slot_id": { "$ref": "#/$defs/slot_id" },
        "content_kind_class": { "$ref": "#/$defs/content_kind_class" },
        "max_lines": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum intended line count before the overflow rule applies."
        },
        "overflow_behavior_class": {
          "$ref": "#/$defs/overflow_behavior_class"
        },
        "plain_language_required": {
          "type": "boolean",
          "description": "Whether the slot requires plain-language explanatory copy."
        },
        "raw_identifier_display_mode": {
          "$ref": "#/$defs/raw_identifier_display_mode"
        },
        "notes": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "content_contract_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_content_rules",
        "blocked_and_degraded_copy_rule",
        "empty_or_missing_data_rule"
      ],
      "properties": {
        "slot_content_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/slot_content_rule_record" }
        },
        "blocked_and_degraded_copy_rule": {
          "$ref": "#/$defs/nonempty_string"
        },
        "empty_or_missing_data_rule": {
          "$ref": "#/$defs/nonempty_string"
        }
      }
    },
    "key_binding_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "effect", "when"],
      "properties": {
        "key": { "$ref": "#/$defs/nonempty_string" },
        "effect": { "$ref": "#/$defs/nonempty_string" },
        "when": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "interaction_contract_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "keyboard_model_ref",
        "entry_command_refs",
        "primary_navigation_keys",
        "activation_keys",
        "dismissal_keys",
        "focus_return_rule",
        "pointer_behavior_note"
      ],
      "properties": {
        "keyboard_model_ref": { "$ref": "#/$defs/nonempty_string" },
        "entry_command_refs": {
          "$ref": "#/$defs/nonempty_ref_array",
          "description": "Commands or routes that enter the component."
        },
        "primary_navigation_keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/key_binding_record" }
        },
        "activation_keys": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/key_binding_record" }
        },
        "dismissal_keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/key_binding_record" }
        },
        "focus_return_rule": { "$ref": "#/$defs/nonempty_string" },
        "pointer_behavior_note": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "announcement_channel_class": {
      "type": "string",
      "enum": [
        "focus_name",
        "status_region",
        "assertive_live_region",
        "polite_live_region",
        "description_change"
      ],
      "description": "Announcement channel used for the accessibility rule."
    },
    "announcement_rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger_ref", "announcement_channel_class", "message_rule"],
      "properties": {
        "trigger_ref": { "$ref": "#/$defs/nonempty_string" },
        "announcement_channel_class": {
          "$ref": "#/$defs/announcement_channel_class"
        },
        "message_rule": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "accessibility_contract_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role_description",
        "accessible_name_rule",
        "accessible_description_rule",
        "announcement_rules",
        "high_contrast_behavior",
        "forced_colors_behavior",
        "blocked_and_degraded_behavior"
      ],
      "properties": {
        "role_description": { "$ref": "#/$defs/nonempty_string" },
        "accessible_name_rule": { "$ref": "#/$defs/nonempty_string" },
        "accessible_description_rule": { "$ref": "#/$defs/nonempty_string" },
        "announcement_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/announcement_rule_record" }
        },
        "high_contrast_behavior": { "$ref": "#/$defs/nonempty_string" },
        "forced_colors_behavior": { "$ref": "#/$defs/nonempty_string" },
        "blocked_and_degraded_behavior": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "semantic_token_binding_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "token_role_refs",
        "when_component_state_classes",
        "notes"
      ],
      "properties": {
        "slot_id": { "$ref": "#/$defs/slot_id" },
        "token_role_refs": {
          "$ref": "#/$defs/nonempty_ref_array",
          "description": "Semantic token role ids or equivalent token refs consumed by this slot."
        },
        "when_component_state_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/component_state_class" },
          "uniqueItems": true
        },
        "notes": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "density_variant_binding_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "density_class",
        "slot_ids",
        "measurement_token_refs",
        "layout_effect"
      ],
      "properties": {
        "density_class": { "$ref": "#/$defs/density_class" },
        "slot_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/slot_id" },
          "uniqueItems": true
        },
        "measurement_token_refs": {
          "$ref": "#/$defs/nonempty_ref_array",
          "description": "Spacing, size, or density token refs consumed by this density variant."
        },
        "layout_effect": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "motion_binding_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "motion_preset_ref",
        "slot_ids",
        "default_duration_token_refs",
        "default_easing_token_refs",
        "reduced_motion_posture_refs",
        "reduced_motion_behavior"
      ],
      "properties": {
        "motion_preset_ref": { "$ref": "#/$defs/ref" },
        "slot_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/slot_id" },
          "uniqueItems": true
        },
        "default_duration_token_refs": {
          "$ref": "#/$defs/nonempty_ref_array"
        },
        "default_easing_token_refs": {
          "$ref": "#/$defs/nonempty_ref_array"
        },
        "reduced_motion_posture_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/accessibility_posture_class" },
          "uniqueItems": true
        },
        "reduced_motion_behavior": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "state_visualization_binding_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_ref",
        "semantic_status_class",
        "trust_visual_state_class",
        "required_disclosure_slot_ids",
        "non_color_cues",
        "notes"
      ],
      "properties": {
        "state_ref": { "$ref": "#/$defs/state_ref" },
        "semantic_status_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/semantic_status_class" }
          ]
        },
        "trust_visual_state_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/trust_visual_state_class" }
          ]
        },
        "required_disclosure_slot_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/slot_id" },
          "uniqueItems": true
        },
        "non_color_cues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_color_cue_class" },
          "uniqueItems": true
        },
        "notes": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "token_binding_rules_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "design_token_manifest_ref",
        "semantic_token_bindings",
        "density_variant_bindings",
        "motion_bindings",
        "state_visualization_bindings"
      ],
      "properties": {
        "design_token_manifest_ref": {
          "$ref": "#/$defs/ref",
          "description": "Canonical design-token or vocabulary manifest this component consumes."
        },
        "semantic_token_bindings": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/semantic_token_binding_record" }
        },
        "density_variant_bindings": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/density_variant_binding_record" }
        },
        "motion_bindings": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/motion_binding_record" }
        },
        "state_visualization_bindings": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/state_visualization_binding_record" }
        }
      }
    },
    "asset_kind_class": {
      "type": "string",
      "enum": ["icon", "illustration", "none"],
      "description": "Whether the slot consumes an icon, an illustration, or no visual asset."
    },
    "rtl_behavior_class": {
      "type": "string",
      "enum": ["mirror_directional", "literal_no_mirror", "not_applicable"],
      "description": "Directionality rule for the visual asset."
    },
    "asset_slot_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "asset_kind_class",
        "asset_ref",
        "icon_treatment_class",
        "rtl_behavior_class",
        "notes"
      ],
      "properties": {
        "slot_id": { "$ref": "#/$defs/slot_id" },
        "asset_kind_class": { "$ref": "#/$defs/asset_kind_class" },
        "asset_ref": { "$ref": "#/$defs/ref" },
        "icon_treatment_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/icon_treatment_class" }
          ]
        },
        "rtl_behavior_class": { "$ref": "#/$defs/rtl_behavior_class" },
        "notes": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "visual_asset_hooks_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset_slots"],
      "properties": {
        "asset_slots": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/asset_slot_record" }
        }
      }
    },
    "localization_contract_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "translation_required_slot_ids",
        "raw_identifier_slot_ids",
        "text_expansion_strategy",
        "bidi_behavior",
        "formatting_behavior",
        "source_language_fallback_behavior",
        "notes"
      ],
      "properties": {
        "translation_required_slot_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/slot_id" },
          "uniqueItems": true,
          "description": "Slots expected to localize."
        },
        "raw_identifier_slot_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/slot_id" },
          "uniqueItems": true,
          "description": "Slots that preserve raw identifiers or raw capability names."
        },
        "text_expansion_strategy": { "$ref": "#/$defs/nonempty_string" },
        "bidi_behavior": { "$ref": "#/$defs/nonempty_string" },
        "formatting_behavior": { "$ref": "#/$defs/nonempty_string" },
        "source_language_fallback_behavior": {
          "$ref": "#/$defs/nonempty_string"
        },
        "notes": { "$ref": "#/$defs/nonempty_string" }
      }
    },
    "parity_posture_class": {
      "type": "string",
      "enum": [
        "must_match",
        "may_narrow_with_disclosure",
        "handoff_only",
        "not_applicable"
      ],
      "description": "How extension surfaces relate to the canonical component."
    },
    "required_inheritance_axis": {
      "type": "string",
      "enum": [
        "semantic_tokens",
        "density",
        "contrast",
        "focus",
        "reduced_motion",
        "state_machine",
        "keyboard_model",
        "command_routing",
        "provenance_badging"
      ],
      "description": "Axis an extension surface must inherit when it claims parity."
    },
    "extension_guidance_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parity_posture_class",
        "required_inheritance_axes",
        "allowed_extension_variations",
        "required_gap_disclosure"
      ],
      "properties": {
        "parity_posture_class": { "$ref": "#/$defs/parity_posture_class" },
        "required_inheritance_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/required_inheritance_axis" },
          "uniqueItems": true
        },
        "allowed_extension_variations": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonempty_string" }
        },
        "required_gap_disclosure": {
          "$ref": "#/$defs/nonempty_string"
        }
      }
    },
    "substitution_and_deprecation_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deprecated_refs",
        "replacement_refs",
        "visibility_required",
        "visibility_surface_refs",
        "unsupported_package_behavior"
      ],
      "properties": {
        "deprecated_refs": { "$ref": "#/$defs/ref_array" },
        "replacement_refs": { "$ref": "#/$defs/ref_array" },
        "visibility_required": {
          "type": "boolean",
          "description": "Whether substitutions or deprecations must stay visible to the user or reviewer."
        },
        "visibility_surface_refs": {
          "$ref": "#/$defs/ref_array",
          "description": "Surfaces where the substitution or deprecation remains visible."
        },
        "unsupported_package_behavior": {
          "$ref": "#/$defs/nonempty_string"
        }
      }
    },
    "evidence_hooks_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "keyboard_journey_refs",
        "assistive_technology_refs",
        "token_drift_check_refs",
        "screenshot_baseline_refs",
        "localization_or_pseudoloc_refs",
        "state_machine_validation_refs"
      ],
      "properties": {
        "keyboard_journey_refs": { "$ref": "#/$defs/nonempty_ref_array" },
        "assistive_technology_refs": { "$ref": "#/$defs/nonempty_ref_array" },
        "token_drift_check_refs": { "$ref": "#/$defs/nonempty_ref_array" },
        "screenshot_baseline_refs": { "$ref": "#/$defs/nonempty_ref_array" },
        "localization_or_pseudoloc_refs": { "$ref": "#/$defs/ref_array" },
        "state_machine_validation_refs": { "$ref": "#/$defs/nonempty_ref_array" }
      }
    }
  }
}
