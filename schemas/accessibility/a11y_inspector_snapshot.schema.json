{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/accessibility/a11y_inspector_snapshot.schema.json",
  "title": "Aureline accessibility-tree inspector snapshot contract",
  "description": "Boundary schema for a11y_inspector_snapshot_record instances frozen in docs/accessibility/accessibility_tree_contract.md. The snapshot gives support, quality engineering, and developers one export-safe capture of active accessibility-tree state, focus chain, selection state, virtualized row indices, live-region posture, announcement contract version, support-class downgrade language, and redaction decisions. Raw source text, raw paths, raw URLs, terminal bytes, prompts, credentials, and unredacted user identifiers never cross this boundary; snapshots carry opaque refs, bounded labels, counts, message IDs, state classes, and schema refs only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "a11y_inspector_snapshot_schema_version",
    "accessibility_tree_contract_id",
    "accessibility_tree_contract_revision",
    "snapshot_id",
    "captured_at",
    "capture_reason",
    "build_context",
    "capture_scope",
    "tree_summary",
    "active_tree_nodes",
    "focus_chain",
    "selection_state",
    "row_index_state",
    "announcement_state",
    "downgrade_state",
    "export_redaction"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "record_kind": {
      "const": "a11y_inspector_snapshot_record"
    },
    "a11y_inspector_snapshot_schema_version": {
      "type": "integer",
      "const": 1
    },
    "accessibility_tree_contract_id": {
      "type": "string",
      "const": "aureline.accessibility.tree_node_taxonomy"
    },
    "accessibility_tree_contract_revision": {
      "type": "integer",
      "const": 1
    },
    "snapshot_id": { "$ref": "#/$defs/opaque_id" },
    "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
    "capture_reason": { "$ref": "#/$defs/capture_reason" },
    "build_context": { "$ref": "#/$defs/build_context" },
    "capture_scope": { "$ref": "#/$defs/capture_scope" },
    "tree_summary": { "$ref": "#/$defs/tree_summary" },
    "active_tree_nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node_projection" }
    },
    "focus_chain": {
      "type": "array",
      "items": { "$ref": "#/$defs/focus_step" }
    },
    "selection_state": { "$ref": "#/$defs/selection_state" },
    "row_index_state": {
      "type": "array",
      "items": { "$ref": "#/$defs/row_index_state" }
    },
    "announcement_state": { "$ref": "#/$defs/announcement_state" },
    "downgrade_state": { "$ref": "#/$defs/downgrade_state" },
    "export_redaction": { "$ref": "#/$defs/export_redaction" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 220,
      "description": "Opaque stable id safe for fixtures, logs, support bundles, and release evidence."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_id" },
        { "type": "null" }
      ]
    },
    "bounded_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "description": "Privacy-safe bounded label."
    },
    "bounded_note": {
      "type": "string",
      "minLength": 1,
      "maxLength": 800,
      "description": "Privacy-safe narrative note."
    },
    "message_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
    },
    "nullable_message_id": {
      "oneOf": [
        { "$ref": "#/$defs/message_id" },
        { "type": "null" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "capture_reason": {
      "type": "string",
      "enum": [
        "developer_inspector",
        "qe_regression",
        "support_bundle",
        "repro_bundle",
        "project_doctor",
        "user_report"
      ]
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "shell_zone",
        "editor_content",
        "editor_gutter",
        "diagnostics",
        "inline_widget",
        "list",
        "tree",
        "table_grid",
        "log_terminal",
        "notebook",
        "status_notification",
        "diff_review",
        "data_surface",
        "graph_canvas_equivalent",
        "support_export"
      ]
    },
    "node_kind": {
      "type": "string",
      "enum": [
        "application_root",
        "window_root",
        "shell_zone",
        "landmark_region",
        "toolbar",
        "tablist",
        "tab",
        "splitter",
        "button",
        "link",
        "menu_item",
        "searchbox",
        "text_input",
        "editor_document",
        "editor_line",
        "editor_text_run",
        "editor_caret",
        "editor_selection_range",
        "editor_gutter_lane",
        "editor_gutter_marker",
        "diagnostic_marker",
        "diagnostic_row",
        "inline_widget",
        "list_container",
        "list_row",
        "tree_container",
        "tree_row",
        "table_grid",
        "row",
        "column_header",
        "row_header",
        "cell",
        "log_region",
        "log_entry",
        "terminal_region",
        "command_boundary",
        "notebook",
        "notebook_cell",
        "notebook_input",
        "notebook_output",
        "output_summary",
        "status_bar",
        "status_item",
        "notification",
        "banner",
        "live_region",
        "review_hunk",
        "placeholder",
        "support_downgrade_notice",
        "unknown_degraded_summary"
      ]
    },
    "generic_role": {
      "type": "string",
      "enum": [
        "application",
        "window",
        "group",
        "landmark",
        "toolbar",
        "tablist",
        "tab",
        "button",
        "link",
        "menuitem",
        "searchbox",
        "textbox",
        "document",
        "code",
        "line",
        "text",
        "list",
        "listitem",
        "tree",
        "treeitem",
        "table",
        "grid",
        "row",
        "rowheader",
        "columnheader",
        "cell",
        "gridcell",
        "log",
        "status",
        "alert",
        "progressbar",
        "separator",
        "checkbox",
        "switch",
        "combobox",
        "dialog",
        "note",
        "none"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "certified",
        "supported",
        "community",
        "experimental",
        "unsupported"
      ]
    },
    "support_state": {
      "type": "string",
      "enum": [
        "full_accessible",
        "degraded_accessible",
        "summary_only",
        "inspect_only",
        "unsupported_blocked",
        "not_applicable"
      ]
    },
    "degradation_reason_class": {
      "type": "string",
      "enum": [
        "none",
        "platform_bridge_unavailable",
        "missing_role",
        "missing_name",
        "missing_state",
        "missing_relationship",
        "virtualization_truth_unavailable",
        "live_region_unavailable",
        "platform_api_gap",
        "extension_boundary",
        "resource_protect_core",
        "policy_or_trust_restriction",
        "unsupported_surface",
        "not_applicable"
      ]
    },
    "index_truth_class": {
      "type": "string",
      "enum": [
        "exact",
        "estimated",
        "stale",
        "degraded",
        "unknown",
        "not_applicable"
      ]
    },
    "integer_count": {
      "type": "integer",
      "minimum": 0
    },
    "positive_integer": {
      "type": "integer",
      "minimum": 1
    },
    "nullable_positive_integer": {
      "oneOf": [
        { "$ref": "#/$defs/positive_integer" },
        { "type": "null" }
      ]
    },
    "bridge_kind": {
      "type": "string",
      "enum": [
        "uia",
        "nsaccessibility",
        "at_spi",
        "bridge_unavailable",
        "not_applicable"
      ]
    },
    "build_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exact_build_identity_ref",
        "channel_context",
        "platform_profile_ref",
        "os_accessibility_bridge",
        "assistive_technology_ref",
        "locale",
        "text_direction",
        "theme_state",
        "effective_zoom_percent",
        "reduced_motion"
      ],
      "properties": {
        "exact_build_identity_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "channel_context": {
          "type": "string",
          "enum": [
            "local_dev",
            "nightly",
            "preview",
            "beta",
            "stable",
            "not_applicable"
          ]
        },
        "platform_profile_ref": { "$ref": "#/$defs/opaque_id" },
        "os_accessibility_bridge": { "$ref": "#/$defs/bridge_kind" },
        "assistive_technology_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "locale": {
          "type": "string",
          "minLength": 2,
          "maxLength": 35
        },
        "text_direction": {
          "type": "string",
          "enum": [
            "ltr",
            "rtl",
            "mixed",
            "unknown"
          ]
        },
        "theme_state": {
          "type": "string",
          "enum": [
            "light",
            "dark",
            "high_contrast",
            "unknown"
          ]
        },
        "effective_zoom_percent": {
          "type": "integer",
          "minimum": 50,
          "maximum": 400
        },
        "reduced_motion": { "type": "boolean" }
      }
    },
    "capture_moment": {
      "type": "string",
      "enum": [
        "initial_shell_render",
        "focus_changed",
        "selection_changed",
        "virtualized_window_changed",
        "live_region_event",
        "degraded_state_changed",
        "support_export",
        "post_action_summary"
      ]
    },
    "capture_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_ref",
        "workspace_ref",
        "focused_surface_family",
        "capture_moment",
        "source_fixture_refs"
      ],
      "properties": {
        "window_ref": { "$ref": "#/$defs/opaque_id" },
        "workspace_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "focused_surface_family": { "$ref": "#/$defs/surface_family" },
        "capture_moment": { "$ref": "#/$defs/capture_moment" },
        "source_fixture_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },
    "count_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "count"
      ],
      "properties": {
        "key": { "$ref": "#/$defs/opaque_id" },
        "count": { "$ref": "#/$defs/integer_count" }
      }
    },
    "tree_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root_node_ref",
        "tree_epoch_ref",
        "node_count",
        "mounted_node_count",
        "virtualized_represented_count",
        "omitted_node_count",
        "role_group_counts",
        "support_class_counts"
      ],
      "properties": {
        "root_node_ref": { "$ref": "#/$defs/opaque_id" },
        "tree_epoch_ref": { "$ref": "#/$defs/opaque_id" },
        "node_count": { "$ref": "#/$defs/integer_count" },
        "mounted_node_count": { "$ref": "#/$defs/integer_count" },
        "virtualized_represented_count": { "$ref": "#/$defs/integer_count" },
        "omitted_node_count": { "$ref": "#/$defs/integer_count" },
        "role_group_counts": {
          "type": "array",
          "items": { "$ref": "#/$defs/count_row" }
        },
        "support_class_counts": {
          "type": "array",
          "items": { "$ref": "#/$defs/count_row" }
        }
      }
    },
    "node_position_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "position_in_set",
        "set_size",
        "row_index",
        "row_count",
        "column_index",
        "column_count",
        "index_truth_class"
      ],
      "properties": {
        "position_in_set": { "$ref": "#/$defs/nullable_positive_integer" },
        "set_size": { "$ref": "#/$defs/nullable_positive_integer" },
        "row_index": { "$ref": "#/$defs/nullable_positive_integer" },
        "row_count": { "$ref": "#/$defs/nullable_positive_integer" },
        "column_index": { "$ref": "#/$defs/nullable_positive_integer" },
        "column_count": { "$ref": "#/$defs/nullable_positive_integer" },
        "index_truth_class": { "$ref": "#/$defs/index_truth_class" }
      }
    },
    "node_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_ref",
        "parent_node_ref",
        "surface_family",
        "node_kind",
        "generic_role",
        "accessible_name",
        "state_tokens",
        "position",
        "support_class",
        "support_state",
        "degradation_reason_classes"
      ],
      "properties": {
        "node_ref": { "$ref": "#/$defs/opaque_id" },
        "parent_node_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "node_kind": { "$ref": "#/$defs/node_kind" },
        "generic_role": { "$ref": "#/$defs/generic_role" },
        "accessible_name": { "$ref": "#/$defs/bounded_label" },
        "state_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "position": { "$ref": "#/$defs/node_position_projection" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "support_state": { "$ref": "#/$defs/support_state" },
        "degradation_reason_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/degradation_reason_class" },
          "uniqueItems": true
        }
      }
    },
    "focus_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "order",
        "node_ref",
        "surface_family",
        "focus_state",
        "focus_visible",
        "focus_return_target_ref",
        "command_route_ref"
      ],
      "properties": {
        "order": { "$ref": "#/$defs/positive_integer" },
        "node_ref": { "$ref": "#/$defs/opaque_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "focus_state": {
          "type": "string",
          "enum": [
            "primary_focus_owner",
            "active_descendant",
            "focusable_region",
            "return_target",
            "not_currently_focused"
          ]
        },
        "focus_visible": { "type": "boolean" },
        "focus_return_target_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "command_route_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "selection_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selection_model",
        "selected_node_refs",
        "anchor_node_ref",
        "active_node_ref",
        "visible_selected_count",
        "hidden_selected_count",
        "total_selected_count",
        "selection_scope_label",
        "selection_truth_class"
      ],
      "properties": {
        "selection_model": {
          "type": "string",
          "enum": [
            "none",
            "single",
            "multi",
            "range",
            "editor_text",
            "table_cells",
            "notebook_cells"
          ]
        },
        "selected_node_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "anchor_node_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "active_node_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "visible_selected_count": { "$ref": "#/$defs/integer_count" },
        "hidden_selected_count": { "$ref": "#/$defs/integer_count" },
        "total_selected_count": { "$ref": "#/$defs/integer_count" },
        "selection_scope_label": { "$ref": "#/$defs/bounded_label" },
        "selection_truth_class": { "$ref": "#/$defs/index_truth_class" }
      }
    },
    "row_index_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "container_node_ref",
        "total_row_count",
        "visible_start_index",
        "visible_end_index",
        "row_index_truth_class",
        "sort_or_filter_label",
        "hidden_row_count",
        "unmounted_selected_count"
      ],
      "properties": {
        "container_node_ref": { "$ref": "#/$defs/opaque_id" },
        "total_row_count": { "$ref": "#/$defs/nullable_positive_integer" },
        "visible_start_index": { "$ref": "#/$defs/nullable_positive_integer" },
        "visible_end_index": { "$ref": "#/$defs/nullable_positive_integer" },
        "row_index_truth_class": { "$ref": "#/$defs/index_truth_class" },
        "sort_or_filter_label": { "$ref": "#/$defs/bounded_label" },
        "hidden_row_count": { "$ref": "#/$defs/integer_count" },
        "unmounted_selected_count": { "$ref": "#/$defs/integer_count" }
      }
    },
    "announcement_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "announcement_contract_id",
        "announcement_contract_revision",
        "announcement_event_schema_version",
        "live_region_node_refs",
        "last_event_refs",
        "coalescing_state",
        "suppressed_event_count"
      ],
      "properties": {
        "announcement_contract_id": {
          "type": "string",
          "const": "aureline.accessibility.screen_reader_live_region"
        },
        "announcement_contract_revision": {
          "type": "integer",
          "const": 1
        },
        "announcement_event_schema_version": {
          "type": "integer",
          "const": 1
        },
        "live_region_node_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "last_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "coalescing_state": {
          "type": "string",
          "enum": [
            "none",
            "dedupe_active",
            "burst_coalesced",
            "focused_surface_only",
            "unknown"
          ]
        },
        "suppressed_event_count": { "$ref": "#/$defs/integer_count" }
      }
    },
    "downgrade_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall_support_class",
        "overall_support_state",
        "support_class_language",
        "degraded_surface_refs",
        "degradation_reason_classes",
        "user_visible_notice_node_ref",
        "recovery_action_refs"
      ],
      "properties": {
        "overall_support_class": { "$ref": "#/$defs/support_class" },
        "overall_support_state": { "$ref": "#/$defs/support_state" },
        "support_class_language": { "$ref": "#/$defs/bounded_label" },
        "degraded_surface_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "degradation_reason_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/degradation_reason_class" },
          "uniqueItems": true
        },
        "user_visible_notice_node_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "recovery_action_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },
    "export_redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_private_material_excluded",
        "redaction_class",
        "redacted_field_refs",
        "allowed_export_fields",
        "schema_refs",
        "support_note"
      ],
      "properties": {
        "raw_private_material_excluded": {
          "type": "boolean",
          "const": true
        },
        "redaction_class": {
          "type": "string",
          "enum": [
            "public_safe",
            "operator_only_restricted",
            "metadata_only",
            "support_packet_redacted",
            "policy_forbidden"
          ]
        },
        "redacted_field_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "allowed_export_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "schema_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "support_note": { "$ref": "#/$defs/bounded_note" }
      }
    }
  }
}
