{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/accessibility/operational_surface_state.schema.json",
  "title": "Aureline operational-surface accessibility-parity contract",
  "description": "Boundary schema for operational_surface_parity_row_record, operational_surface_action_record, operational_surface_state_record, operational_surface_case_record, and operational_surface_export_projection_record instances frozen in docs/accessibility/operational_surface_parity_contract.md. The schema gives risky VCS and repair surfaces (worktree manager, stash shelf, sequence editor, recovery pane, conflict resolution view, force-push or publish review sheet, patch apply or revert review sheet) one export-safe vocabulary for closed action and state classes, screen-reader announcement reuse, accessibility-tree reuse, focus-and-keyboard reuse, zoom resilience, plain-language label requirements, and support packet repro fields. The records reuse the announcement_event, focus_owner, and tree_node contracts rather than minting a second accessibility language. Raw absolute paths, raw branch/commit URLs, raw author identity strings, raw commit message bodies, raw patch bodies, raw run-log bodies, raw terminal bytes, raw prompts, raw provider payloads, credential material, and unredacted user identifiers MUST NOT appear on any record emitted against this schema; records carry opaque refs, typed vocabulary, bounded labels, message ids, parity classes, and recovery refs only. Adding a new operational_surface_family, action_class, state_class, parity_dimension, blocker_class, recovery_object_class, or denial_reason is additive-minor and bumps operational_surface_state_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/operational_surface_parity_row_record" },
    { "$ref": "#/$defs/operational_surface_action_record" },
    { "$ref": "#/$defs/operational_surface_state_record" },
    { "$ref": "#/$defs/operational_surface_case_record" },
    { "$ref": "#/$defs/operational_surface_export_projection_record" }
  ],
  "$defs": {
    "operational_surface_state_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this operational-surface parity vocabulary."
    },
    "operational_surface_parity_contract_id": {
      "type": "string",
      "const": "aureline.accessibility.operational_surface_parity"
    },
    "operational_surface_parity_contract_revision": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "operational_surface_parity_row_record",
        "operational_surface_action_record",
        "operational_surface_state_record",
        "operational_surface_case_record",
        "operational_surface_export_projection_record"
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Opaque stable id safe for fixtures, logs, support bundles, and release evidence."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_id" },
        { "type": "null" }
      ]
    },
    "bounded_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "description": "Privacy-safe label. Raw paths, URLs, command bodies, terminal bytes, prompts, credentials, and user identifiers must not appear."
    },
    "bounded_note": {
      "type": "string",
      "minLength": 1,
      "maxLength": 700,
      "description": "Privacy-safe explanation for support packets or fixture narratives."
    },
    "message_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "Stable localized-message key. Logic must not depend on localized prose."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "operational_surface_family": {
      "type": "string",
      "enum": [
        "worktree_manager",
        "stash_shelf",
        "sequence_editor",
        "recovery_pane",
        "conflict_resolution_view",
        "force_push_or_publish_review_sheet",
        "patch_apply_or_revert_review_sheet"
      ],
      "description": "Closed family of risky operational surfaces covered by this parity contract."
    },
    "operation_kind_class": {
      "type": "string",
      "enum": [
        "worktree_switch",
        "worktree_remove_or_repair",
        "stash_apply",
        "stash_pop",
        "stash_drop",
        "stash_create",
        "interactive_rebase",
        "cherry_pick_sequence",
        "revert_sequence",
        "patch_series_restack",
        "merge_replay",
        "conflict_resolution",
        "corruption_recovery_restore",
        "checkpoint_restore",
        "force_push_or_publish",
        "patch_apply",
        "patch_revert"
      ]
    },
    "action_class": {
      "type": "string",
      "enum": [
        "continue",
        "abort",
        "skip",
        "restore_checkpoint",
        "review_conflict",
        "open_details",
        "open_output",
        "preview_consequence",
        "open_diff",
        "open_recovery_pane",
        "create_checkpoint",
        "switch_target",
        "retry"
      ],
      "description": "Closed action vocabulary mirrored to plain-language labels in the contract document. Each value has its own command route, keyboard route, audit event, and message id."
    },
    "action_label": {
      "type": "string",
      "enum": [
        "Continue",
        "Abort",
        "Skip",
        "Restore checkpoint",
        "Review conflict",
        "Open details",
        "Open output",
        "Preview consequence",
        "Open diff",
        "Open recovery pane",
        "Create checkpoint",
        "Switch target",
        "Retry"
      ],
      "description": "Plain-language verb-first labels that remain distinct on every risky operational surface."
    },
    "state_class": {
      "type": "string",
      "enum": [
        "idle_inspect_only",
        "dirty_pending_review",
        "in_progress",
        "paused_pending_conflict",
        "paused_pending_protected_path",
        "paused_pending_signoff",
        "paused_pending_base_or_head_identity_changed",
        "blocking_destructive_preview",
        "checkpoint_created",
        "checkpoint_expired",
        "approval_invalidated",
        "recovery_available",
        "recovery_in_progress",
        "completed",
        "aborted_rolled_back"
      ],
      "description": "Closed user-facing state vocabulary. Values reuse history-edit and recovery semantics so live-region announcements and accessibility-tree state labels stay aligned."
    },
    "state_label": {
      "type": "string",
      "enum": [
        "Idle",
        "Dirty",
        "In progress",
        "Conflict",
        "Protected path blocker",
        "Missing signoff",
        "Base or head identity changed",
        "Destructive preview",
        "Checkpoint created",
        "Checkpoint expired",
        "Approval invalidated",
        "Recovery available",
        "Recovery in progress",
        "Completed",
        "Aborted"
      ],
      "description": "Plain-language state labels paired one-to-one with state_class values."
    },
    "blocker_class": {
      "type": "string",
      "enum": [
        "no_blocker",
        "unresolved_conflict",
        "protected_path_blocker",
        "missing_signoff",
        "base_or_head_identity_changed",
        "policy_blocked",
        "recovery_object_missing",
        "checkpoint_expired",
        "trust_revoked"
      ]
    },
    "recovery_object_class": {
      "type": "string",
      "enum": [
        "no_recovery_required",
        "checkpoint",
        "backup_ref",
        "reflog_anchor",
        "export_patch",
        "safe_worktree",
        "snapshot"
      ],
      "description": "Mirrors recovery_object_record_id_ref shapes from schemas/vcs/recovery_object.schema.json so risky surfaces can name the exact recovery object before mutation."
    },
    "parity_dimension": {
      "type": "string",
      "enum": [
        "screen_reader_announcement",
        "accessibility_tree_role_name_state",
        "full_keyboard_traversal",
        "focus_order_and_return",
        "zoom_50_to_400_percent",
        "larger_text_and_line_height",
        "plain_language_action_labels",
        "plain_language_state_labels",
        "non_color_state_cue",
        "live_region_dedupe_and_coalesce",
        "durable_fallback_row",
        "no_drag_only_dependency",
        "support_export_repro"
      ],
      "description": "Closed parity dimensions that every operational surface row must report against."
    },
    "parity_state": {
      "type": "string",
      "enum": [
        "passed",
        "degraded",
        "partial",
        "blocked",
        "failed",
        "pending_evidence",
        "unclaimed"
      ],
      "description": "Coverage state per parity dimension. partial maps to degraded when composing with older result-state vocabularies that do not carry partial."
    },
    "support_class": {
      "type": "string",
      "enum": [
        "claimed",
        "claimed_narrow",
        "best_effort",
        "unclaimed"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "public_safe",
        "operator_only_restricted",
        "metadata_only",
        "support_packet_redacted",
        "policy_forbidden"
      ]
    },
    "denial_reason": {
      "type": "string",
      "enum": [
        "operational_surface_family_unresolved",
        "action_class_label_mismatch",
        "state_class_label_mismatch",
        "missing_recovery_object_ref",
        "missing_announcement_event_ref",
        "missing_accessibility_tree_node_ref",
        "missing_focus_owner_snapshot_ref",
        "missing_keyboard_route_for_action",
        "drag_only_dependency_in_critical_path",
        "color_only_state_cue_only",
        "live_region_spam_or_contradictory_output",
        "ambiguous_button_copy_for_continue_abort_skip_restore",
        "support_packet_redaction_violation",
        "schema_version_lagging"
      ]
    },
    "parity_dimension_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension",
        "parity_state",
        "evidence_ref"
      ],
      "properties": {
        "dimension": { "$ref": "#/$defs/parity_dimension" },
        "parity_state": { "$ref": "#/$defs/parity_state" },
        "evidence_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "notes": {
          "oneOf": [
            { "$ref": "#/$defs/bounded_note" },
            { "type": "null" }
          ]
        }
      }
    },
    "keyboard_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_ref",
        "route_label",
        "shortcut_label_present",
        "non_hover_help_surface_ref"
      ],
      "properties": {
        "command_ref": { "$ref": "#/$defs/opaque_id" },
        "route_label": { "$ref": "#/$defs/bounded_label" },
        "shortcut_label_present": { "type": "boolean" },
        "non_hover_help_surface_ref": { "$ref": "#/$defs/opaque_id" },
        "shortcut_label": {
          "oneOf": [
            { "$ref": "#/$defs/bounded_label" },
            { "type": "null" }
          ]
        }
      }
    },
    "operational_surface_action_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "operational_surface_state_schema_version",
        "operational_surface_parity_contract_id",
        "operational_surface_parity_contract_revision",
        "action_id",
        "operational_surface_family",
        "action_class",
        "action_label",
        "message_id",
        "keyboard_route",
        "drag_only_critical_path_denied",
        "color_only_cue_denied",
        "announcement_event_type_ref",
        "tree_node_ref"
      ],
      "properties": {
        "record_kind": { "const": "operational_surface_action_record" },
        "operational_surface_state_schema_version": { "$ref": "#/$defs/operational_surface_state_schema_version" },
        "operational_surface_parity_contract_id": { "$ref": "#/$defs/operational_surface_parity_contract_id" },
        "operational_surface_parity_contract_revision": { "$ref": "#/$defs/operational_surface_parity_contract_revision" },
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "operational_surface_family": { "$ref": "#/$defs/operational_surface_family" },
        "action_class": { "$ref": "#/$defs/action_class" },
        "action_label": { "$ref": "#/$defs/action_label" },
        "message_id": { "$ref": "#/$defs/message_id" },
        "keyboard_route": { "$ref": "#/$defs/keyboard_route" },
        "drag_only_critical_path_denied": { "type": "boolean", "const": true },
        "color_only_cue_denied": { "type": "boolean", "const": true },
        "announcement_event_type_ref": { "$ref": "#/$defs/opaque_id" },
        "tree_node_ref": { "$ref": "#/$defs/opaque_id" },
        "audit_event_id_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "preview_required_before_commit": { "type": "boolean" },
        "notes": {
          "oneOf": [
            { "$ref": "#/$defs/bounded_note" },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "action_class": { "const": "continue" } } },
          "then": { "properties": { "action_label": { "const": "Continue" } } }
        },
        {
          "if": { "properties": { "action_class": { "const": "abort" } } },
          "then": { "properties": { "action_label": { "const": "Abort" } } }
        },
        {
          "if": { "properties": { "action_class": { "const": "skip" } } },
          "then": { "properties": { "action_label": { "const": "Skip" } } }
        },
        {
          "if": { "properties": { "action_class": { "const": "restore_checkpoint" } } },
          "then": { "properties": { "action_label": { "const": "Restore checkpoint" } } }
        },
        {
          "if": { "properties": { "action_class": { "const": "review_conflict" } } },
          "then": { "properties": { "action_label": { "const": "Review conflict" } } }
        },
        {
          "if": { "properties": { "action_class": { "const": "open_details" } } },
          "then": { "properties": { "action_label": { "const": "Open details" } } }
        },
        {
          "if": { "properties": { "action_class": { "const": "open_output" } } },
          "then": { "properties": { "action_label": { "const": "Open output" } } }
        },
        {
          "if": { "properties": { "action_class": { "const": "preview_consequence" } } },
          "then": { "properties": { "action_label": { "const": "Preview consequence" } } }
        },
        {
          "if": { "properties": { "action_class": { "const": "open_diff" } } },
          "then": { "properties": { "action_label": { "const": "Open diff" } } }
        },
        {
          "if": { "properties": { "action_class": { "const": "open_recovery_pane" } } },
          "then": { "properties": { "action_label": { "const": "Open recovery pane" } } }
        },
        {
          "if": { "properties": { "action_class": { "const": "create_checkpoint" } } },
          "then": { "properties": { "action_label": { "const": "Create checkpoint" } } }
        },
        {
          "if": { "properties": { "action_class": { "const": "switch_target" } } },
          "then": { "properties": { "action_label": { "const": "Switch target" } } }
        },
        {
          "if": { "properties": { "action_class": { "const": "retry" } } },
          "then": { "properties": { "action_label": { "const": "Retry" } } }
        }
      ]
    },
    "operational_surface_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "operational_surface_state_schema_version",
        "operational_surface_parity_contract_id",
        "operational_surface_parity_contract_revision",
        "state_id",
        "operational_surface_family",
        "operation_kind_class",
        "state_class",
        "state_label",
        "blocker_class",
        "recovery_object_class",
        "recovery_object_record_ref",
        "available_actions",
        "announcement_event_id_ref",
        "tree_node_ref",
        "focus_owner_snapshot_ref",
        "non_color_state_cue_present",
        "captured_at"
      ],
      "properties": {
        "record_kind": { "const": "operational_surface_state_record" },
        "operational_surface_state_schema_version": { "$ref": "#/$defs/operational_surface_state_schema_version" },
        "operational_surface_parity_contract_id": { "$ref": "#/$defs/operational_surface_parity_contract_id" },
        "operational_surface_parity_contract_revision": { "$ref": "#/$defs/operational_surface_parity_contract_revision" },
        "state_id": { "$ref": "#/$defs/opaque_id" },
        "operational_surface_family": { "$ref": "#/$defs/operational_surface_family" },
        "operation_kind_class": { "$ref": "#/$defs/operation_kind_class" },
        "state_class": { "$ref": "#/$defs/state_class" },
        "state_label": { "$ref": "#/$defs/state_label" },
        "blocker_class": { "$ref": "#/$defs/blocker_class" },
        "blocker_label": {
          "oneOf": [
            { "$ref": "#/$defs/bounded_label" },
            { "type": "null" }
          ]
        },
        "recovery_object_class": { "$ref": "#/$defs/recovery_object_class" },
        "recovery_object_record_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "available_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/action_class" }
        },
        "announcement_event_id_ref": { "$ref": "#/$defs/opaque_id" },
        "tree_node_ref": { "$ref": "#/$defs/opaque_id" },
        "focus_owner_snapshot_ref": { "$ref": "#/$defs/opaque_id" },
        "durable_fallback_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "non_color_state_cue_present": { "type": "boolean", "const": true },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "notes": {
          "oneOf": [
            { "$ref": "#/$defs/bounded_note" },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "state_class": { "const": "idle_inspect_only" } } },
          "then": { "properties": { "state_label": { "const": "Idle" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "dirty_pending_review" } } },
          "then": { "properties": { "state_label": { "const": "Dirty" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "in_progress" } } },
          "then": { "properties": { "state_label": { "const": "In progress" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "paused_pending_conflict" } } },
          "then": { "properties": { "state_label": { "const": "Conflict" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "paused_pending_protected_path" } } },
          "then": { "properties": { "state_label": { "const": "Protected path blocker" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "paused_pending_signoff" } } },
          "then": { "properties": { "state_label": { "const": "Missing signoff" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "paused_pending_base_or_head_identity_changed" } } },
          "then": { "properties": { "state_label": { "const": "Base or head identity changed" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "blocking_destructive_preview" } } },
          "then": { "properties": { "state_label": { "const": "Destructive preview" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "checkpoint_created" } } },
          "then": { "properties": { "state_label": { "const": "Checkpoint created" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "checkpoint_expired" } } },
          "then": { "properties": { "state_label": { "const": "Checkpoint expired" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "approval_invalidated" } } },
          "then": { "properties": { "state_label": { "const": "Approval invalidated" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "recovery_available" } } },
          "then": { "properties": { "state_label": { "const": "Recovery available" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "recovery_in_progress" } } },
          "then": { "properties": { "state_label": { "const": "Recovery in progress" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "completed" } } },
          "then": { "properties": { "state_label": { "const": "Completed" } } }
        },
        {
          "if": { "properties": { "state_class": { "const": "aborted_rolled_back" } } },
          "then": { "properties": { "state_label": { "const": "Aborted" } } }
        }
      ]
    },
    "support_export_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "include_in_accessibility_packet",
        "include_in_repro_bundle",
        "operational_surface_parity_contract_id",
        "operational_surface_parity_contract_revision",
        "schema_ref",
        "announcement_contract_id_ref",
        "tree_node_contract_id_ref",
        "focus_zoom_pointer_contract_id_ref",
        "task_corpus_ref",
        "checklist_refs",
        "redaction_class",
        "raw_private_material_excluded"
      ],
      "properties": {
        "include_in_accessibility_packet": { "type": "boolean" },
        "include_in_repro_bundle": { "type": "boolean" },
        "operational_surface_parity_contract_id": { "$ref": "#/$defs/operational_surface_parity_contract_id" },
        "operational_surface_parity_contract_revision": { "$ref": "#/$defs/operational_surface_parity_contract_revision" },
        "schema_ref": {
          "type": "string",
          "const": "schemas/accessibility/operational_surface_state.schema.json"
        },
        "announcement_contract_id_ref": {
          "type": "string",
          "const": "aureline.accessibility.screen_reader_live_region"
        },
        "tree_node_contract_id_ref": {
          "type": "string",
          "const": "aureline.accessibility.tree_node_taxonomy"
        },
        "focus_zoom_pointer_contract_id_ref": {
          "type": "string",
          "const": "aureline.accessibility.focus_zoom_pointer_independence"
        },
        "task_corpus_ref": { "$ref": "#/$defs/opaque_id" },
        "checklist_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "export_field_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      }
    },
    "operational_surface_parity_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "operational_surface_state_schema_version",
        "operational_surface_parity_contract_id",
        "operational_surface_parity_contract_revision",
        "row_id",
        "operational_surface_family",
        "support_class",
        "platform_review_row_ref",
        "assistive_tech_coverage_row_ref",
        "accessibility_tree_coverage_row_ref",
        "required_actions",
        "required_states",
        "parity_dimension_checks",
        "support_export"
      ],
      "properties": {
        "record_kind": { "const": "operational_surface_parity_row_record" },
        "operational_surface_state_schema_version": { "$ref": "#/$defs/operational_surface_state_schema_version" },
