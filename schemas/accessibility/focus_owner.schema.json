{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/accessibility/focus_owner.schema.json",
  "title": "Aureline focus-owner, zoom, and pointer-independence boundary",
  "description": "Boundary schema for focus_owner_snapshot_record, focus_target_record, and focus_disclosure_record instances frozen in docs/accessibility/focus_zoom_and_pointer_independence_contract.md. The schema gives shell, editor, dense collection, overlay, review, docs/help, terminal, notebook, graph, collaboration, trust, remote, and support/export surfaces one export-safe vocabulary for window-local focus ownership, visible focus indicators, focus return, high-zoom and larger-text posture, cursor ergonomics, and pointer-independence disclosure. Raw source text, raw paths, raw URLs, terminal bytes, prompts, credentials, and unredacted user identifiers never cross this boundary; records carry opaque refs, bounded labels, typed state, command refs, and fixture refs only. Adding a new target role, surface family, window role, disclosure class, zoom simplification class, pointer action class, or denial reason is additive-minor and requires a focus_owner_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/focus_owner_snapshot_record" },
    { "$ref": "#/$defs/focus_target_record" },
    { "$ref": "#/$defs/focus_disclosure_record" }
  ],
  "$defs": {
    "focus_owner_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this focus/zoom/pointer-independence vocabulary."
    },
    "focus_zoom_pointer_contract_id": {
      "type": "string",
      "const": "aureline.accessibility.focus_zoom_pointer_independence"
    },
    "focus_zoom_pointer_contract_revision": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "focus_owner_snapshot_record",
        "focus_target_record",
        "focus_disclosure_record"
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "description": "Opaque stable id safe for fixtures, logs, support bundles, and release evidence."
    },
    "bounded_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "description": "Privacy-safe label. Raw paths, URLs, command bodies, terminal bytes, prompts, credentials, and user identifiers must not appear."
    },
    "bounded_note": {
      "type": "string",
      "minLength": 1,
      "maxLength": 520,
      "description": "Privacy-safe explanation for support packets or fixture narratives."
    },
    "message_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "Stable localized-message key. Logic must not depend on localized prose."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_ref": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_id" },
        { "type": "null" }
      ]
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "shell_workspace_launcher",
        "palette_search",
        "editor_group",
        "terminal_output",
        "docs_reader",
        "diff_review",
        "dense_collection_batch_review",
        "sign_in_and_trust_prompt",
        "task_and_debug",
        "notebook_output",
        "graph_or_timeline",
        "presentation_overlay",
        "collaboration_session",
        "remote_attach",
        "settings",
        "support_export"
      ]
    },
    "window_role": {
      "type": "string",
      "enum": [
        "primary_workspace_window",
        "secondary_workspace_window",
        "detached_auxiliary_window",
        "modal_owner_window",
        "presentation_window",
        "companion_projection_window"
      ]
    },
    "target_role": {
      "type": "string",
      "enum": [
        "editor_insertion_point",
        "editor_group",
        "terminal_prompt",
        "palette_input",
        "list_row",
        "tree_row",
        "table_cell",
        "grid_cell",
        "button",
        "menu_item",
        "splitter",
        "dialog_control",
        "sheet_control",
        "popover_control",
        "review_hunk",
        "batch_review_owner",
        "notebook_cell",
        "graph_node_summary",
        "timeline_range_summary",
        "status_item",
        "placeholder_reentry",
        "region_landmark"
      ]
    },
    "target_visibility": {
      "type": "string",
      "enum": [
        "visible",
        "visible_after_recenter",
        "visible_placeholder",
        "visible_in_overflow_or_sheet",
        "not_focusable_hidden_denied",
        "not_focusable_destroyed_denied"
      ]
    },
    "focus_indicator_shape": {
      "type": "string",
      "enum": [
        "outside_ring",
        "inside_outline",
        "caret",
        "active_region_boundary",
        "row_outline",
        "cell_outline",
        "placeholder_boundary"
      ]
    },
    "non_color_cue": {
      "type": "string",
      "enum": [
        "outline",
        "border",
        "inset_stroke",
        "caret_geometry",
        "shape",
        "label",
        "active_region_boundary"
      ]
    },
    "focus_indicator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "visible",
        "minimum_thickness_px",
        "contrast_ratio",
        "shape",
        "non_color_cues"
      ],
      "properties": {
        "visible": { "type": "boolean", "const": true },
        "minimum_thickness_px": {
          "type": "number",
          "minimum": 2,
          "description": "Effective rendered focus-indicator thickness in CSS or device-independent pixels."
        },
        "contrast_ratio": {
          "type": "number",
          "minimum": 3,
          "description": "Minimum adjacent contrast ratio for the rendered indicator."
        },
        "shape": { "$ref": "#/$defs/focus_indicator_shape" },
        "non_color_cues": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/non_color_cue" }
        }
      }
    },
    "focus_return_state": {
      "type": "string",
      "enum": [
        "returned_exact",
        "returned_nearest_safe_ancestor",
        "returned_current_batch_or_detail_owner",
        "returned_placeholder_announced",
        "focus_loss_denied",
        "focus_not_applicable_non_interactive"
      ]
    },
    "return_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin_target_ref",
        "expected_return_state",
        "fallback_target_ref",
        "announcement_required",
        "message_id"
      ],
      "properties": {
        "origin_target_ref": { "$ref": "#/$defs/nullable_ref" },
        "expected_return_state": { "$ref": "#/$defs/focus_return_state" },
        "fallback_target_ref": { "$ref": "#/$defs/nullable_ref" },
        "announcement_required": { "type": "boolean" },
        "message_id": {
          "oneOf": [
            { "$ref": "#/$defs/message_id" },
            { "type": "null" }
          ]
        }
      }
    },
    "overlay_kind": {
      "type": "string",
      "enum": [
        "none",
        "menu",
        "popover",
        "completion_list",
        "peek_panel",
        "command_palette",
        "sheet",
        "dialog",
        "wizard",
        "guided_step",
        "presentation_spotlight"
      ]
    },
    "overlay_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overlay_ref",
        "overlay_kind",
        "modal",
        "owns_focus",
        "invoker_target_ref"
      ],
      "properties": {
        "overlay_ref": { "$ref": "#/$defs/opaque_id" },
        "overlay_kind": { "$ref": "#/$defs/overlay_kind" },
        "modal": { "type": "boolean" },
        "owns_focus": { "type": "boolean" },
        "invoker_target_ref": { "$ref": "#/$defs/nullable_ref" }
      }
    },
    "zoom_scale_class": {
      "type": "string",
      "enum": [
        "zoom_50",
        "zoom_100",
        "zoom_150",
        "zoom_200",
        "zoom_300",
        "zoom_400",
        "platform_scale_mixed",
        "larger_text",
        "presentation_zoom"
      ]
    },
    "line_height_mode": {
      "type": "string",
      "enum": [
        "default_editor_1_55_to_1_65",
        "comfortable_editor",
        "user_custom",
        "ui_minimum_1_35_or_above"
      ]
    },
    "cursor_control_state": {
      "type": "string",
      "enum": [
        "default",
        "thick_cursor_enabled",
        "blink_disabled",
        "animation_reduced",
        "high_contrast_caret"
      ]
    },
    "zoom_simplification_class": {
      "type": "string",
      "enum": [
        "none",
        "minimap_simplified",
        "overview_simplified",
        "dense_chrome_compacted",
        "secondary_panel_to_sheet",
        "low_frequency_actions_to_overflow",
        "canvas_to_list_or_table"
      ]
    },
    "zoom_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effective_zoom_percent",
        "text_scale_percent",
        "platform_scale_percent",
        "zoom_scale_classes",
        "line_height_mode",
        "cursor_control_states",
        "reflow_before_clipping",
        "editor_group_visible",
        "critical_side_surface_visible",
        "simplification_classes"
      ],
      "properties": {
        "effective_zoom_percent": { "type": "integer", "minimum": 50, "maximum": 400 },
        "text_scale_percent": { "type": "integer", "minimum": 50, "maximum": 400 },
        "platform_scale_percent": { "type": "integer", "minimum": 50, "maximum": 400 },
        "zoom_scale_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/zoom_scale_class" }
        },
        "line_height_mode": { "$ref": "#/$defs/line_height_mode" },
        "cursor_control_states": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/cursor_control_state" }
        },
        "reflow_before_clipping": { "type": "boolean", "const": true },
        "editor_group_visible": { "type": "boolean" },
        "critical_side_surface_visible": { "type": "boolean" },
        "simplification_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/zoom_simplification_class" }
        }
      }
    },
    "pointer_action_class": {
      "type": "string",
      "enum": [
        "reorder",
        "selection",
        "range_selection",
        "pane_resize",
        "review_action",
        "drag_drop_import",
        "canvas_navigation",
        "timeline_range",
        "visual_resize_or_position"
      ]
    },
    "pointer_equivalence_state": {
      "type": "string",
      "enum": [
        "keyboard_equivalent_verified",
        "command_route_verified",
        "assistive_route_verified",
        "degraded_with_disclosure",
        "pointer_only_debt",
        "not_applicable"
      ]
    },
    "keyboard_equivalent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_class",
        "equivalence_state",
        "command_ref",
        "route_label",
        "pointer_only_dependency_denied"
      ],
      "properties": {
        "action_class": { "$ref": "#/$defs/pointer_action_class" },
        "equivalence_state": { "$ref": "#/$defs/pointer_equivalence_state" },
        "command_ref": { "$ref": "#/$defs/nullable_ref" },
        "route_label": { "$ref": "#/$defs/bounded_label" },
        "pointer_only_dependency_denied": { "type": "boolean" }
      }
    },
    "pointer_independence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_critical_drag_only_dependency",
        "keyboard_equivalents"
      ],
      "properties": {
        "no_critical_drag_only_dependency": { "type": "boolean", "const": true },
        "keyboard_equivalents": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/keyboard_equivalent" }
        }
      }
    },
    "disclosure_class": {
      "type": "string",
      "enum": [
        "control_moved_to_overflow",
        "control_reduced_to_icon_with_label",
        "control_hidden_until_region_focus",
        "control_unavailable_at_current_scale",
        "minimap_simplified",
        "overview_simplified",
        "dense_chrome_compacted",
        "platform_scaling_limited"
      ]
    },
    "disclosure_reason_class": {
      "type": "string",
      "enum": [
        "high_zoom",
        "larger_text",
        "increased_line_height",
        "high_contrast",
        "platform_scaling",
        "narrow_width",
        "reduced_motion",
        "input_modality",
        "surface_not_claimed"
      ]
    },
    "focus_disclosure_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "focus_owner_schema_version",
        "focus_zoom_pointer_contract_id",
        "focus_zoom_pointer_contract_revision",
        "disclosure_id",
        "surface_family",
        "disclosure_class",
        "reason_class",
        "affected_control_ref",
        "message_id",
        "replacement_path_label",
        "keyboard_route_ref",
        "can_continue_without_pointer"
      ],
      "properties": {
        "record_kind": { "const": "focus_disclosure_record" },
        "focus_owner_schema_version": { "$ref": "#/$defs/focus_owner_schema_version" },
        "focus_zoom_pointer_contract_id": { "$ref": "#/$defs/focus_zoom_pointer_contract_id" },
        "focus_zoom_pointer_contract_revision": { "$ref": "#/$defs/focus_zoom_pointer_contract_revision" },
        "disclosure_id": { "$ref": "#/$defs/opaque_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "disclosure_class": { "$ref": "#/$defs/disclosure_class" },
        "reason_class": { "$ref": "#/$defs/disclosure_reason_class" },
        "affected_control_ref": { "$ref": "#/$defs/opaque_id" },
        "message_id": { "$ref": "#/$defs/message_id" },
        "replacement_path_label": { "$ref": "#/$defs/bounded_label" },
        "keyboard_route_ref": { "$ref": "#/$defs/nullable_ref" },
        "can_continue_without_pointer": { "type": "boolean", "const": true }
      }
    },
    "focus_target_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "focus_owner_schema_version",
        "focus_zoom_pointer_contract_id",
        "focus_zoom_pointer_contract_revision",
        "target_ref",
        "window_ref",
        "surface_family",
        "target_role",
        "target_visibility",
        "focus_indicator",
        "keyboard_route_ref",
        "destroyed_or_hidden_focus_denied"
      ],
      "properties": {
        "record_kind": { "const": "focus_target_record" },
        "focus_owner_schema_version": { "$ref": "#/$defs/focus_owner_schema_version" },
        "focus_zoom_pointer_contract_id": { "$ref": "#/$defs/focus_zoom_pointer_contract_id" },
        "focus_zoom_pointer_contract_revision": { "$ref": "#/$defs/focus_zoom_pointer_contract_revision" },
        "target_ref": { "$ref": "#/$defs/opaque_id" },
        "window_ref": { "$ref": "#/$defs/opaque_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "target_role": { "$ref": "#/$defs/target_role" },
        "target_visibility": { "$ref": "#/$defs/target_visibility" },
        "focus_indicator": { "$ref": "#/$defs/focus_indicator" },
        "keyboard_route_ref": { "$ref": "#/$defs/nullable_ref" },
        "destroyed_or_hidden_focus_denied": { "type": "boolean", "const": true }
      }
    },
    "invariant_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exactly_one_primary_focus_owner",
        "primary_owner_visible",
        "hidden_or_destroyed_targets_denied",
        "focus_indicator_meets_minimum",
        "return_path_preserved_or_disclosed",
        "reflow_before_clipping",
        "no_critical_drag_only_dependency",
        "disclosure_for_reduced_unavailable_controls"
      ],
      "properties": {
        "exactly_one_primary_focus_owner": { "type": "boolean", "const": true },
        "primary_owner_visible": { "type": "boolean", "const": true },
        "hidden_or_destroyed_targets_denied": { "type": "boolean", "const": true },
        "focus_indicator_meets_minimum": { "type": "boolean", "const": true },
        "return_path_preserved_or_disclosed": { "type": "boolean", "const": true },
        "reflow_before_clipping": { "type": "boolean", "const": true },
        "no_critical_drag_only_dependency": { "type": "boolean", "const": true },
        "disclosure_for_reduced_unavailable_controls": { "type": "boolean", "const": true }
      }
    },
    "focus_owner_snapshot_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "focus_owner_schema_version",
        "focus_zoom_pointer_contract_id",
        "focus_zoom_pointer_contract_revision",
        "snapshot_id",
        "captured_at",
        "window_ref",
        "window_role",
        "surface_family",
        "primary_focus_owner",
        "return_path",
        "overlay_stack",
        "focus_disclosures",
        "zoom_context",
        "pointer_independence",
        "invariant_checks"
      ],
      "properties": {
        "record_kind": { "const": "focus_owner_snapshot_record" },
        "focus_owner_schema_version": { "$ref": "#/$defs/focus_owner_schema_version" },
        "focus_zoom_pointer_contract_id": { "$ref": "#/$defs/focus_zoom_pointer_contract_id" },
        "focus_zoom_pointer_contract_revision": { "$ref": "#/$defs/focus_zoom_pointer_contract_revision" },
        "snapshot_id": { "$ref": "#/$defs/opaque_id" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "window_ref": { "$ref": "#/$defs/opaque_id" },
        "window_role": { "$ref": "#/$defs/window_role" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "primary_focus_owner": { "$ref": "#/$defs/focus_target_record" },
        "return_path": { "$ref": "#/$defs/return_path" },
        "overlay_stack": {
          "type": "array",
          "items": { "$ref": "#/$defs/overlay_entry" }
        },
        "focus_disclosures": {
          "type": "array",
          "items": { "$ref": "#/$defs/focus_disclosure_record" }
        },
        "zoom_context": { "$ref": "#/$defs/zoom_context" },
        "pointer_independence": { "$ref": "#/$defs/pointer_independence" },
        "invariant_checks": { "$ref": "#/$defs/invariant_checks" },
        "notes": {
          "oneOf": [
            { "$ref": "#/$defs/bounded_note" },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
