{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/accessibility/announcement_event.schema.json",
  "title": "Aureline screen-reader announcement, live-region, and assistive-tech parity event contract",
  "description": "Boundary schema for announcement_event_record, announcement_case_record, and announcement_export_projection_record instances frozen in docs/accessibility/screen_reader_and_live_region_contract.md. The schema gives shell, editor, diagnostics, debug, task, trust, remote attach, collaboration, AI patch, VCS, recovery, support/export, and accessibility review surfaces one vocabulary for screen-reader event types, live-region urgency, dedupe/coalescing, stable phrasing, silence reasons, assistive-tech parity rows, and export-safe repro fields. Raw source text, raw paths, raw URLs, raw terminal bytes, raw prompts, raw provider payloads, credential material, and unredacted user identifiers never cross this boundary; records carry opaque refs, bounded labels, typed state, message IDs, placeholder keys, and row refs only. Adding a new announcement_event_type, surface_family, source_subsystem, live_region_channel, silence_reason, coalescing_strategy, or parity_support_state is additive-minor and requires an announcement_event_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/announcement_event_record" },
    { "$ref": "#/$defs/announcement_case_record" },
    { "$ref": "#/$defs/announcement_export_projection_record" }
  ],
  "$defs": {
    "announcement_event_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this announcement contract."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "announcement_event_record",
        "announcement_case_record",
        "announcement_export_projection_record"
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for logs, support bundles, fixtures, and evidence packets."
    },
    "message_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "Stable localized-message key. Logic must not depend on localized prose."
    },
    "short_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 140,
      "description": "Privacy-safe bounded label. Raw paths, URLs, command bodies, terminal bytes, prompts, credentials, and user identifiers must not appear."
    },
    "long_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 420,
      "description": "Privacy-safe explanation for support packets or fixture narratives."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_timestamp": {
      "oneOf": [
        { "$ref": "#/$defs/monotonic_timestamp" },
        { "type": "null" }
      ]
    },
    "announcement_contract_id": {
      "type": "string",
      "const": "aureline.accessibility.screen_reader_live_region"
    },
    "announcement_contract_revision": {
      "type": "integer",
      "const": 1
    },
    "announcement_event_type": {
      "type": "string",
      "enum": [
        "diagnostic_entered_active_line",
        "diagnostic_left_active_line",
        "breakpoint_added",
        "breakpoint_removed",
        "breakpoint_verified",
        "breakpoint_unverified",
        "task_started",
        "task_completed",
        "task_failed",
        "task_blocked",
        "trust_entered_restricted_mode",
        "trust_granted",
        "trust_revoked",
        "remote_attach_connecting",
        "remote_attach_connected",
        "remote_attach_degraded",
        "remote_attach_disconnected",
        "collaboration_control_requested",
        "collaboration_control_granted",
        "collaboration_control_revoked",
        "collaboration_control_handoff_failed",
        "ai_patch_ready",
        "ai_patch_apply_succeeded",
        "ai_patch_revert_succeeded",
        "ai_patch_apply_failed",
        "vcs_worktree_state_changed",
        "vcs_stash_state_changed",
        "vcs_sequence_state_changed",
        "recovery_state_changed",
        "conflict_state_changed"
      ],
      "description": "Closed critical announcement vocabulary. Surfaces must not mint ad hoc string-only synonyms."
    },
    "announcement_event_class": {
      "type": "string",
      "enum": [
        "diagnostic_navigation",
        "breakpoint_change",
        "task_lifecycle",
        "trust_mode_change",
        "remote_attach_state",
        "collaboration_control",
        "ai_patch_review",
        "apply_or_revert_result",
        "vcs_or_recovery_state"
      ]
    },
    "source_subsystem": {
      "type": "string",
      "enum": [
        "shell",
        "editor",
        "language_diagnostics",
        "debug_session",
        "task_runner",
        "terminal",
        "workspace_trust",
        "policy_resolver",
        "remote_agent",
        "collaboration",
        "ai_apply",
        "review_and_diff",
        "source_control",
        "recovery",
        "activity_center",
        "support_export"
      ]
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "editor",
        "editor_gutter",
        "problems_list",
        "debug_breakpoints",
        "task_row",
        "task_output",
        "terminal_output",
        "trust_prompt",
        "remote_attach_card",
        "collaboration_session",
        "ai_patch_review",
        "activity_center",
        "status_bar",
        "diff_review",
        "worktree_manager",
        "stash_shelf",
        "sequence_editor",
        "recovery_pane",
        "conflict_resolution_view",
        "support_export"
      ]
    },
    "urgency_class": {
      "type": "string",
      "enum": [
        "ambient",
        "status",
        "progress",
        "completion",
        "blocking",
        "safety_critical"
      ]
    },
    "live_region_channel": {
      "type": "string",
      "enum": [
        "polite",
        "assertive",
        "silent"
      ]
    },
    "delivery_timing": {
      "type": "string",
      "enum": [
        "immediate",
        "coalesced",
        "on_focus",
        "durable_surface_only",
        "not_delivered_silent"
      ]
    },
    "silence_reason": {
      "type": "string",
      "enum": [
        "focused_surface_already_conveys_state",
        "visible_state_already_announced_or_focused",
        "meaning_unchanged_refresh",
        "superseded_by_coalesced_terminal_state",
        "structured_output_channel_active",
        "not_silent"
      ]
    },
    "coalescing_strategy": {
      "type": "string",
      "enum": [
        "none",
        "dedupe_same_meaning",
        "last_meaning_wins_with_count",
        "start_and_terminal_only",
        "focused_surface_only"
      ]
    },
    "parity_support_state": {
      "type": "string",
      "enum": [
        "pending_evidence",
        "passed",
        "degraded",
        "partial",
        "blocked",
        "failed",
        "unclaimed"
      ],
      "description": "Coverage state used by the announcement parity artifact. partial maps to degraded when composing with older result-state vocabularies that do not carry a partial value."
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "public_safe",
        "operator_only_restricted",
        "metadata_only",
        "support_packet_redacted",
        "policy_forbidden"
      ]
    },
    "action_label": {
      "type": "string",
      "enum": [
        "Continue",
        "Abort",
        "Skip",
        "Restore checkpoint",
        "Review conflict",
        "Open output",
        "Review patch",
        "Open details",
        "Retry",
        "Undo",
        "No action"
      ],
      "description": "Plain-language next action labels that remain distinct for risky operational surfaces."
    },
    "placeholder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value_class"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "value_class": {
          "type": "string",
          "enum": [
            "bounded_label",
            "count",
            "state_class",
            "severity",
            "action_label",
            "role_label",
            "scope_label"
          ]
        },
        "example_value": { "$ref": "#/$defs/short_label" }
      }
    },
    "announcement_phrasing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message_id",
        "locale",
        "template",
        "placeholders",
        "spoken_example",
        "stable_nouns"
      ],
      "properties": {
        "message_id": { "$ref": "#/$defs/message_id" },
        "locale": {
          "type": "string",
          "minLength": 2
        },
        "template": { "$ref": "#/$defs/long_label" },
        "placeholders": {
          "type": "array",
          "items": { "$ref": "#/$defs/placeholder" },
          "uniqueItems": true
        },
        "spoken_example": { "$ref": "#/$defs/long_label" },
        "stable_nouns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/short_label" },
          "uniqueItems": true
        },
        "plain_language_next_action": { "$ref": "#/$defs/action_label" }
      }
    },
    "live_region_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel",
        "urgency_class",
        "delivery_timing",
        "interrupts_current_speech",
        "coalescing_strategy",
        "coalesce_window_ms",
        "max_announcements_per_burst",
        "silence_reason"
      ],
      "properties": {
        "channel": { "$ref": "#/$defs/live_region_channel" },
        "urgency_class": { "$ref": "#/$defs/urgency_class" },
        "delivery_timing": { "$ref": "#/$defs/delivery_timing" },
        "interrupts_current_speech": { "type": "boolean" },
        "coalescing_strategy": { "$ref": "#/$defs/coalescing_strategy" },
        "coalesce_window_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "max_announcements_per_burst": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "silence_reason": { "$ref": "#/$defs/silence_reason" },
        "dedupe_key": { "$ref": "#/$defs/opaque_id" },
        "meaning_hash_ref": { "$ref": "#/$defs/opaque_id" },
        "supersedes_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },
    "source_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_subsystem",
        "surface_family",
        "canonical_event_id",
        "target_ref",
        "target_label"
      ],
      "properties": {
        "source_subsystem": { "$ref": "#/$defs/source_subsystem" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "canonical_event_id": { "$ref": "#/$defs/opaque_id" },
        "target_ref": { "$ref": "#/$defs/opaque_id" },
        "target_label": { "$ref": "#/$defs/short_label" },
        "scope_label": { "$ref": "#/$defs/short_label" },
        "actor_role_label": { "$ref": "#/$defs/short_label" },
        "durable_fallback_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "state_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_label",
        "state_changed",
        "visible_state_already_covers_change",
        "available_next_actions"
      ],
      "properties": {
        "state_label": { "$ref": "#/$defs/short_label" },
        "severity_label": { "$ref": "#/$defs/short_label" },
        "state_changed": { "type": "boolean" },
        "visible_state_already_covers_change": { "type": "boolean" },
        "available_next_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/action_label" },
          "uniqueItems": true
        },
        "blocked_reason_label": { "$ref": "#/$defs/short_label" },
        "count_label": { "$ref": "#/$defs/short_label" }
      }
    },
    "assistive_tech_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assistive_tech_coverage_row_ref",
        "platform_review_row_ref",
        "assistive_technology_row_ref",
        "parity_support_state",
        "keyboard_traversal_required",
        "zoom_resilience_required"
      ],
      "properties": {
        "assistive_tech_coverage_row_ref": { "$ref": "#/$defs/opaque_id" },
        "platform_review_row_ref": { "$ref": "#/$defs/opaque_id" },
        "assistive_technology_row_ref": { "$ref": "#/$defs/opaque_id" },
        "parity_support_state": { "$ref": "#/$defs/parity_support_state" },
        "keyboard_traversal_required": { "type": "boolean", "const": true },
        "zoom_resilience_required": { "type": "boolean", "const": true },
        "plain_language_action_labels_required": { "type": "boolean", "const": true }
      }
    },
    "support_export_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "include_in_accessibility_packet",
        "include_in_repro_bundle",
        "announcement_contract_id",
        "announcement_contract_revision",
        "schema_ref",
        "task_corpus_ref",
        "checklist_refs",
        "redaction_class",
        "raw_private_material_excluded"
      ],
      "properties": {
        "include_in_accessibility_packet": { "type": "boolean" },
        "include_in_repro_bundle": { "type": "boolean" },
        "announcement_contract_id": { "$ref": "#/$defs/announcement_contract_id" },
        "announcement_contract_revision": { "$ref": "#/$defs/announcement_contract_revision" },
        "schema_ref": {
          "type": "string",
          "const": "schemas/accessibility/announcement_event.schema.json"
        },
        "task_corpus_ref": { "$ref": "#/$defs/opaque_id" },
        "checklist_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "export_field_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },
    "announcement_event_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "announcement_event_schema_version",
        "announcement_event_id",
        "announcement_contract_id",
        "announcement_contract_revision",
        "announcement_event_type",
        "announcement_event_class",
        "source_context",
        "state_context",
        "phrasing",
        "live_region_policy",
        "assistive_tech_context",
        "support_export",
        "minted_at"
      ],
      "properties": {
        "record_kind": { "const": "announcement_event_record" },
        "announcement_event_schema_version": { "$ref": "#/$defs/announcement_event_schema_version" },
        "announcement_event_id": { "$ref": "#/$defs/opaque_id" },
        "announcement_contract_id": { "$ref": "#/$defs/announcement_contract_id" },
        "announcement_contract_revision": { "$ref": "#/$defs/announcement_contract_revision" },
        "announcement_event_type": { "$ref": "#/$defs/announcement_event_type" },
        "announcement_event_class": { "$ref": "#/$defs/announcement_event_class" },
        "source_context": { "$ref": "#/$defs/source_context" },
        "state_context": { "$ref": "#/$defs/state_context" },
        "phrasing": { "$ref": "#/$defs/announcement_phrasing" },
        "live_region_policy": { "$ref": "#/$defs/live_region_policy" },
        "assistive_tech_context": { "$ref": "#/$defs/assistive_tech_context" },
        "support_export": { "$ref": "#/$defs/support_export_context" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "expires_at": { "$ref": "#/$defs/nullable_timestamp" }
      }
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name",
        "scenario",
        "contract_sections"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/short_label" },
        "scenario": { "$ref": "#/$defs/long_label" },
        "contract_sections": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/short_label" },
          "uniqueItems": true
        }
      }
    },
    "expected_delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "delivered_event_refs",
        "suppressed_event_refs",
        "assertive_event_refs",
        "polite_event_refs",
        "spam_forbidden",
        "contradictory_output_forbidden"
      ],
      "properties": {
        "delivered_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "suppressed_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "assertive_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "polite_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "final_spoken_order": {
          "type": "array",
          "items": { "$ref": "#/$defs/short_label" }
        },
        "spam_forbidden": { "type": "boolean", "const": true },
        "contradictory_output_forbidden": { "type": "boolean", "const": true }
      }
    },
    "announcement_case_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "announcement_event_schema_version",
        "case_id",
        "title",
        "scenario",
        "contract_refs",
        "events",
        "expected_delivery"
      ],
      "properties": {
        "record_kind": { "const": "announcement_case_record" },
        "announcement_event_schema_version": { "$ref": "#/$defs/announcement_event_schema_version" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "title": { "$ref": "#/$defs/short_label" },
        "scenario": { "$ref": "#/$defs/long_label" },
        "contract_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/announcement_event_record" }
        },
        "expected_delivery": { "$ref": "#/$defs/expected_delivery" }
      }
    },
    "announcement_export_projection_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "announcement_event_schema_version",
        "projection_id",
        "source_announcement_event_ref",
        "support_export",
        "assistive_tech_context"
      ],
      "properties": {
        "record_kind": { "const": "announcement_export_projection_record" },
        "announcement_event_schema_version": { "$ref": "#/$defs/announcement_event_schema_version" },
        "projection_id": { "$ref": "#/$defs/opaque_id" },
        "source_announcement_event_ref": { "$ref": "#/$defs/opaque_id" },
        "support_export": { "$ref": "#/$defs/support_export_context" },
        "assistive_tech_context": { "$ref": "#/$defs/assistive_tech_context" },
        "notes": { "$ref": "#/$defs/long_label" }
      }
    }
  }
}
