{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/accessibility/tree_node.schema.json",
  "title": "Aureline accessibility-tree node taxonomy and mapping contract",
  "description": "Boundary schema for accessibility_tree_node_record and accessibility_tree_case_record instances frozen in docs/accessibility/accessibility_tree_contract.md. The schema gives custom-rendered shell, editor, gutter, diagnostics, inline-widget, list, tree, table, log, terminal, notebook, status, notification, diff, and support/export surfaces one export-safe vocabulary for role/name/state mapping, position truth, relationships, virtualization, support-class downgrades, and privacy posture. Raw source text, raw paths, raw URLs, terminal bytes, prompts, credentials, and unredacted user identifiers never cross this boundary; records carry opaque refs, bounded labels, state classes, counts, message IDs, and redaction decisions only. Adding a new surface_family, node_kind, generic_role, state label class, relationship field, virtualization state, degradation reason, or support state is additive-minor and requires a tree_node_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/accessibility_tree_node_record" },
    { "$ref": "#/$defs/accessibility_tree_case_record" }
  ],
  "$defs": {
    "tree_node_schema_version": {
      "type": "integer",
      "const": 1
    },
    "accessibility_tree_contract_id": {
      "type": "string",
      "const": "aureline.accessibility.tree_node_taxonomy"
    },
    "accessibility_tree_contract_revision": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "accessibility_tree_node_record",
        "accessibility_tree_case_record"
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Opaque stable id safe for fixtures, logs, support bundles, and release evidence."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_id" },
        { "type": "null" }
      ]
    },
    "bounded_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "description": "Privacy-safe label. Raw paths, URLs, command bodies, terminal bytes, prompts, credentials, and user identifiers must not appear."
    },
    "bounded_note": {
      "type": "string",
      "minLength": 1,
      "maxLength": 700,
      "description": "Privacy-safe explanation for support packets or fixture narratives."
    },
    "message_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "Stable localized-message key. Logic must not depend on localized prose."
    },
    "nullable_message_id": {
      "oneOf": [
        { "$ref": "#/$defs/message_id" },
        { "type": "null" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "shell_zone",
        "editor_content",
        "editor_gutter",
        "diagnostics",
        "inline_widget",
        "list",
        "tree",
        "table_grid",
        "log_terminal",
        "notebook",
        "status_notification",
        "diff_review",
        "data_surface",
        "graph_canvas_equivalent",
        "support_export"
      ]
    },
    "node_kind": {
      "type": "string",
      "enum": [
        "application_root",
        "window_root",
        "shell_zone",
        "landmark_region",
        "toolbar",
        "tablist",
        "tab",
        "splitter",
        "button",
        "link",
        "menu_item",
        "searchbox",
        "text_input",
        "editor_document",
        "editor_line",
        "editor_text_run",
        "editor_caret",
        "editor_selection_range",
        "editor_gutter_lane",
        "editor_gutter_marker",
        "diagnostic_marker",
        "diagnostic_row",
        "inline_widget",
        "list_container",
        "list_row",
        "tree_container",
        "tree_row",
        "table_grid",
        "row",
        "column_header",
        "row_header",
        "cell",
        "log_region",
        "log_entry",
        "terminal_region",
        "command_boundary",
        "notebook",
        "notebook_cell",
        "notebook_input",
        "notebook_output",
        "output_summary",
        "status_bar",
        "status_item",
        "notification",
        "banner",
        "live_region",
        "review_hunk",
        "placeholder",
        "support_downgrade_notice",
        "unknown_degraded_summary"
      ]
    },
    "generic_role": {
      "type": "string",
      "enum": [
        "application",
        "window",
        "group",
        "landmark",
        "toolbar",
        "tablist",
        "tab",
        "button",
        "link",
        "menuitem",
        "searchbox",
        "textbox",
        "document",
        "code",
        "line",
        "text",
        "list",
        "listitem",
        "tree",
        "treeitem",
        "table",
        "grid",
        "row",
        "rowheader",
        "columnheader",
        "cell",
        "gridcell",
        "log",
        "status",
        "alert",
        "progressbar",
        "separator",
        "checkbox",
        "switch",
        "combobox",
        "dialog",
        "note",
        "none"
      ]
    },
    "role_source": {
      "type": "string",
      "enum": [
        "explicit_surface_contract",
        "command_descriptor",
        "document_model",
        "collection_model",
        "diagnostics_model",
        "renderer_semantic_hook",
        "generated_summary",
        "fallback_summary",
        "platform_adapter",
        "unsupported_placeholder"
      ]
    },
    "role_confidence": {
      "type": "string",
      "enum": [
        "exact",
        "degraded",
        "summary_only",
        "unavailable"
      ]
    },
    "native_role_hints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uia",
        "nsaccessibility",
        "at_spi"
      ],
      "properties": {
        "uia": { "$ref": "#/$defs/nullable_opaque_id" },
        "nsaccessibility": { "$ref": "#/$defs/nullable_opaque_id" },
        "at_spi": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "role_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generic_role",
        "role_source",
        "role_confidence",
        "native_role_hints"
      ],
      "properties": {
        "generic_role": { "$ref": "#/$defs/generic_role" },
        "role_source": { "$ref": "#/$defs/role_source" },
        "role_confidence": { "$ref": "#/$defs/role_confidence" },
        "native_role_hints": { "$ref": "#/$defs/native_role_hints" }
      }
    },
    "name_source": {
      "type": "string",
      "enum": [
        "visible_label",
        "command_descriptor",
        "document_title",
        "file_or_symbol_label",
        "row_identity",
        "column_header",
        "diagnostic_message_id",
        "status_message_id",
        "announcement_message_id",
        "aria_label_equivalent",
        "generated_summary",
        "degraded_support_label"
      ]
    },
    "placeholder": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value_class"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "value_class": {
          "type": "string",
          "enum": [
            "bounded_label",
            "count",
            "state_label",
            "support_class",
            "action_label",
            "severity_label"
          ]
        }
      }
    },
    "accessible_name": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "name_source",
        "message_id",
        "placeholder_names",
        "description",
        "description_message_id"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/bounded_label" },
        "name_source": { "$ref": "#/$defs/name_source" },
        "message_id": { "$ref": "#/$defs/nullable_message_id" },
        "placeholder_names": {
          "type": "array",
          "items": { "$ref": "#/$defs/placeholder" },
          "uniqueItems": true
        },
        "description": {
          "oneOf": [
            { "$ref": "#/$defs/bounded_note" },
            { "type": "null" }
          ]
        },
        "description_message_id": { "$ref": "#/$defs/nullable_message_id" }
      }
    },
    "checked_state": {
      "type": "string",
      "enum": [
        "true",
        "false",
        "mixed",
        "not_applicable"
      ]
    },
    "current_state": {
      "type": "string",
      "enum": [
        "none",
        "page",
        "step",
        "location",
        "line",
        "row",
        "cell",
        "item",
        "tab"
      ]
    },
    "severity_class": {
      "type": "string",
      "enum": [
        "none",
        "info",
        "warning",
        "error",
        "blocking",
        "security",
        "unsupported"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "fresh",
        "warming",
        "cached",
        "stale",
        "degraded",
        "unavailable",
        "not_applicable"
      ]
    },
    "state_label": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_class",
        "label",
        "message_id"
      ],
      "properties": {
        "state_class": {
          "type": "string",
          "enum": [
            "severity",
            "freshness",
            "support",
            "disabled_reason",
            "read_only_reason",
            "selection_scope",
            "virtualization",
            "trust_or_policy",
            "live_region",
            "not_applicable"
          ]
        },
        "label": { "$ref": "#/$defs/bounded_label" },
        "message_id": { "$ref": "#/$defs/nullable_message_id" }
      }
    },
    "states": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focused",
        "focusable",
        "selected",
        "current",
        "disabled",
        "read_only",
        "expanded",
        "checked",
        "busy",
        "invalid",
        "required",
        "modal",
        "visible",
        "offscreen",
        "virtualized",
        "stale",
        "degraded",
        "severity",
        "freshness",
        "state_labels"
      ],
      "properties": {
        "focused": { "type": "boolean" },
        "focusable": { "type": "boolean" },
        "selected": { "type": "boolean" },
        "current": { "$ref": "#/$defs/current_state" },
        "disabled": { "type": "boolean" },
        "read_only": { "type": "boolean" },
        "expanded": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "checked": { "$ref": "#/$defs/checked_state" },
        "busy": { "type": "boolean" },
        "invalid": { "type": "boolean" },
        "required": { "type": "boolean" },
        "modal": { "type": "boolean" },
        "visible": { "type": "boolean" },
        "offscreen": { "type": "boolean" },
        "virtualized": { "type": "boolean" },
        "stale": { "type": "boolean" },
        "degraded": { "type": "boolean" },
        "severity": { "$ref": "#/$defs/severity_class" },
        "freshness": { "$ref": "#/$defs/freshness_class" },
        "state_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/state_label" },
          "uniqueItems": true
        }
      }
    },
    "nullable_integer": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "positive_nullable_integer": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "null" }
      ]
    },
    "index_truth_class": {
      "type": "string",
      "enum": [
        "exact",
        "estimated",
        "stale",
        "degraded",
        "unknown",
        "not_applicable"
      ]
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "position_in_set",
        "set_size",
        "row_index",
        "row_count",
        "column_index",
        "column_count",
        "level",
        "index_truth_class"
      ],
      "properties": {
        "position_in_set": { "$ref": "#/$defs/positive_nullable_integer" },
        "set_size": { "$ref": "#/$defs/positive_nullable_integer" },
        "row_index": { "$ref": "#/$defs/positive_nullable_integer" },
        "row_count": { "$ref": "#/$defs/positive_nullable_integer" },
        "column_index": { "$ref": "#/$defs/positive_nullable_integer" },
        "column_count": { "$ref": "#/$defs/positive_nullable_integer" },
        "level": { "$ref": "#/$defs/positive_nullable_integer" },
        "index_truth_class": { "$ref": "#/$defs/index_truth_class" }
      }
    },
    "relationships": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parent_node_ref",
        "child_node_refs",
        "labelled_by_refs",
        "described_by_refs",
        "controls_refs",
        "owns_refs",
        "active_descendant_ref",
        "details_refs",
        "error_message_refs",
        "flow_to_refs",
        "source_anchor_refs",
        "related_node_refs"
      ],
      "properties": {
        "parent_node_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "child_node_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "labelled_by_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "described_by_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "controls_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "owns_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "active_descendant_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "details_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "error_message_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "flow_to_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "source_anchor_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "related_node_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },
    "virtualization_state": {
      "type": "string",
      "enum": [
        "not_virtualized",
        "mounted_visible",
        "mounted_offscreen",
        "virtual_placeholder",
        "unmounted_represented",
        "summary_for_unmounted"
      ]
    },
    "virtualized_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "visible_start_index",
        "visible_end_index",
        "total_count",
        "index_truth_class"
      ],
      "properties": {
        "visible_start_index": { "$ref": "#/$defs/positive_nullable_integer" },
        "visible_end_index": { "$ref": "#/$defs/positive_nullable_integer" },
        "total_count": { "$ref": "#/$defs/positive_nullable_integer" },
        "index_truth_class": { "$ref": "#/$defs/index_truth_class" }
      }
    },
    "virtualization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "virtualization_state",
        "stable_item_ref",
        "mounted_node_ref",
        "visible_window",
        "recycle_safe",
        "hidden_selected_count"
      ],
      "properties": {
        "virtualization_state": { "$ref": "#/$defs/virtualization_state" },
        "stable_item_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "mounted_node_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "visible_window": { "$ref": "#/$defs/virtualized_window" },
        "recycle_safe": { "type": "boolean" },
        "hidden_selected_count": { "$ref": "#/$defs/nullable_integer" }
      }
    },
    "support_class": {
      "type": "string",
      "enum": [
        "certified",
        "supported",
        "community",
        "experimental",
        "unsupported"
      ]
    },
    "support_state": {
      "type": "string",
      "enum": [
        "full_accessible",
        "degraded_accessible",
        "summary_only",
        "inspect_only",
        "unsupported_blocked",
        "not_applicable"
      ]
    },
    "degradation_reason_class": {
      "type": "string",
      "enum": [
        "none",
        "platform_bridge_unavailable",
        "missing_role",
        "missing_name",
        "missing_state",
        "missing_relationship",
        "virtualization_truth_unavailable",
        "live_region_unavailable",
        "platform_api_gap",
        "extension_boundary",
        "resource_protect_core",
        "policy_or_trust_restriction",
        "unsupported_surface",
        "not_applicable"
      ]
    },
    "support_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_class",
        "support_state",
        "degradation_reason_classes",
        "user_visible_notice_required",
        "support_language",
        "recovery_action_label"
      ],
      "properties": {
        "support_class": { "$ref": "#/$defs/support_class" },
        "support_state": { "$ref": "#/$defs/support_state" },
        "degradation_reason_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/degradation_reason_class" },
          "uniqueItems": true
        },
        "user_visible_notice_required": { "type": "boolean" },
        "support_language": { "$ref": "#/$defs/bounded_label" },
        "recovery_action_label": {
          "oneOf": [
            { "$ref": "#/$defs/bounded_label" },
            { "type": "null" }
          ]
        }
      }
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "public_safe",
        "operator_only_restricted",
        "metadata_only",
        "support_packet_redacted",
        "policy_forbidden"
      ]
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redaction_class",
        "raw_private_material_excluded",
        "allowed_export_fields",
        "schema_refs"
      ],
      "properties": {
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "raw_private_material_excluded": {
          "type": "boolean",
          "const": true
        },
        "allowed_export_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "schema_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },
    "accessibility_tree_node_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "tree_node_schema_version",
        "accessibility_tree_contract_id",
        "accessibility_tree_contract_revision",
        "node_id",
        "tree_epoch_ref",
        "surface_family",
        "node_kind",
        "role_mapping",
        "accessible_name",
        "states",
        "position",
        "relationships",
        "virtualization",
        "support_status",
        "privacy",
        "minted_at"
      ],
      "properties": {
        "$schema": {
          "type": "string"
        },
        "record_kind": { "const": "accessibility_tree_node_record" },
        "tree_node_schema_version": { "$ref": "#/$defs/tree_node_schema_version" },
        "accessibility_tree_contract_id": { "$ref": "#/$defs/accessibility_tree_contract_id" },
        "accessibility_tree_contract_revision": { "$ref": "#/$defs/accessibility_tree_contract_revision" },
        "node_id": { "$ref": "#/$defs/opaque_id" },
        "tree_epoch_ref": { "$ref": "#/$defs/opaque_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "node_kind": { "$ref": "#/$defs/node_kind" },
        "role_mapping": { "$ref": "#/$defs/role_mapping" },
        "accessible_name": { "$ref": "#/$defs/accessible_name" },
        "states": { "$ref": "#/$defs/states" },
        "position": { "$ref": "#/$defs/position" },
        "relationships": { "$ref": "#/$defs/relationships" },
        "virtualization": { "$ref": "#/$defs/virtualization" },
        "support_status": { "$ref": "#/$defs/support_status" },
        "privacy": { "$ref": "#/$defs/privacy" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    },
    "selection_assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selection_model",
        "selected_node_refs",
        "anchor_node_ref",
        "active_node_ref",
        "visible_selected_count",
        "hidden_selected_count",
        "selection_truth_class"
      ],
      "properties": {
        "selection_model": {
          "type": "string",
          "enum": [
            "none",
            "single",
            "multi",
            "range",
            "editor_text",
            "table_cells",
            "notebook_cells"
          ]
        },
        "selected_node_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "anchor_node_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "active_node_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "visible_selected_count": { "$ref": "#/$defs/nullable_integer" },
        "hidden_selected_count": { "$ref": "#/$defs/nullable_integer" },
        "selection_truth_class": { "$ref": "#/$defs/index_truth_class" }
      }
    },
    "virtualized_truth_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "container_node_ref",
        "expected_total_count",
        "expected_visible_start_index",
        "expected_visible_end_index",
        "index_truth_class"
      ],
      "properties": {
        "container_node_ref": { "$ref": "#/$defs/opaque_id" },
        "expected_total_count": { "$ref": "#/$defs/positive_nullable_integer" },
        "expected_visible_start_index": { "$ref": "#/$defs/positive_nullable_integer" },
        "expected_visible_end_index": { "$ref": "#/$defs/positive_nullable_integer" },
        "index_truth_class": { "$ref": "#/$defs/index_truth_class" }
      }
    },
    "downgrade_expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_ref",
        "support_class",
        "support_state",
        "degradation_reason_classes",
        "user_visible_notice_required"
      ],
      "properties": {
        "node_ref": { "$ref": "#/$defs/opaque_id" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "support_state": { "$ref": "#/$defs/support_state" },
        "degradation_reason_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/degradation_reason_class" },
          "uniqueItems": true
        },
        "user_visible_notice_required": { "type": "boolean" }
      }
    },
    "case_assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_node_refs",
        "focus_chain_node_refs",
        "selection_state",
        "virtualized_truth_checks",
        "downgrade_expectations",
        "raw_private_material_excluded"
      ],
      "properties": {
        "required_node_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "focus_chain_node_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "selection_state": { "$ref": "#/$defs/selection_assertion" },
        "virtualized_truth_checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/virtualized_truth_check" }
        },
        "downgrade_expectations": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_expectation" }
        },
        "raw_private_material_excluded": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "accessibility_tree_case_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "tree_node_schema_version",
        "accessibility_tree_contract_id",
        "accessibility_tree_contract_revision",
        "case_id",
        "title",
        "scenario",
        "contract_refs",
        "root_node_id",
        "nodes",
        "assertions",
        "minted_at"
      ],
      "properties": {
        "$schema": {
          "type": "string"
        },
        "record_kind": { "const": "accessibility_tree_case_record" },
        "tree_node_schema_version": { "$ref": "#/$defs/tree_node_schema_version" },
        "accessibility_tree_contract_id": { "$ref": "#/$defs/accessibility_tree_contract_id" },
        "accessibility_tree_contract_revision": { "$ref": "#/$defs/accessibility_tree_contract_revision" },
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "title": { "$ref": "#/$defs/bounded_label" },
        "scenario": { "$ref": "#/$defs/bounded_note" },
        "contract_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "root_node_id": { "$ref": "#/$defs/opaque_id" },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/accessibility_tree_node_record" }
        },
        "assertions": { "$ref": "#/$defs/case_assertions" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    }
  }
}
