{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/work_items/object_rows.schema.json",
  "title": "Work-item object rows packet",
  "description": "Boundary schema for shared work-item object rows, provider chips, freshness or local-draft disclosure, and relation strips.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_at",
    "source_page_id_ref",
    "rows",
    "summary_label"
  ],
  "properties": {
    "record_kind": {
      "const": "work_item_object_rows_packet"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "source_page_id_ref": {
      "type": "string",
      "minLength": 1
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/work_item_object_row_record"
      }
    },
    "summary_label": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "work_item_provider_chip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_family",
        "provider_label",
        "project_or_space_ref",
        "provider_host_ref",
        "tenant_or_org_scope_ref",
        "sync_scope_class",
        "inspect_only"
      ],
      "properties": {
        "provider_family": {
          "type": "string",
          "minLength": 1
        },
        "provider_label": {
          "type": "string",
          "minLength": 1
        },
        "project_or_space_ref": {
          "type": "string",
          "minLength": 1
        },
        "provider_host_ref": {
          "type": "string",
          "minLength": 1
        },
        "tenant_or_org_scope_ref": {
          "type": "string",
          "minLength": 1
        },
        "sync_scope_class": {
          "type": "string",
          "enum": [
            "provider_committed",
            "local_draft_only",
            "queued_publish",
            "offline_captured",
            "cached_inspect_only",
            "local_relation_only"
          ]
        },
        "inspect_only": {
          "type": "boolean"
        }
      }
    },
    "work_item_relation_strip_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation_item_id",
        "relation_kind",
        "relation_identity_ref",
        "source_class",
        "freshness_class",
        "summary_label"
      ],
      "properties": {
        "relation_item_id": {
          "type": "string",
          "minLength": 1
        },
        "relation_kind": {
          "type": "string",
          "enum": [
            "branch_or_worktree",
            "review",
            "run",
            "incident",
            "validation_evidence"
          ]
        },
        "relation_identity_ref": {
          "type": "string",
          "minLength": 1
        },
        "source_class": {
          "type": "string",
          "enum": [
            "local_workspace",
            "provider_overlay",
            "imported_snapshot",
            "derived_review_state",
            "incident_workspace"
          ]
        },
        "freshness_class": {
          "type": "string",
          "enum": [
            "live",
            "cached",
            "stale",
            "local_draft",
            "imported_snapshot"
          ]
        },
        "summary_label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "work_item_relation_strip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "items",
        "summary_label"
      ],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/work_item_relation_strip_item"
          }
        },
        "summary_label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "work_item_object_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "row_id",
        "work_item_detail_record_id_ref",
        "provider_chip",
        "object_class",
        "canonical_id",
        "title_label",
        "primary_state_label",
        "freshness_class",
        "freshness_label",
        "row_posture_class",
        "sync_scope_class",
        "local_draft_marker_visible",
        "relation_strip",
        "link_state_class",
        "support_export_summary"
      ],
      "properties": {
        "record_kind": {
          "const": "work_item_object_row_record"
        },
        "schema_version": {
          "const": 1
        },
        "row_id": {
          "type": "string",
          "minLength": 1
        },
        "work_item_detail_record_id_ref": {
          "type": "string",
          "minLength": 1
        },
        "provider_chip": {
          "$ref": "#/$defs/work_item_provider_chip"
        },
        "object_class": {
          "type": "string",
          "minLength": 1
        },
        "canonical_id": {
          "type": "string",
          "minLength": 1
        },
        "title_label": {
          "type": "string",
          "minLength": 1
        },
        "primary_state_label": {
          "type": "string",
          "minLength": 1
        },
        "owner_or_assignee_label": {
          "type": "string",
          "minLength": 1
        },
        "freshness_class": {
          "type": "string",
          "minLength": 1
        },
        "freshness_label": {
          "type": "string",
          "minLength": 1
        },
        "row_posture_class": {
          "type": "string",
          "minLength": 1
        },
        "sync_scope_class": {
          "type": "string",
          "enum": [
            "provider_committed",
            "local_draft_only",
            "queued_publish",
            "offline_captured",
            "cached_inspect_only",
            "local_relation_only"
          ]
        },
        "local_draft_marker_visible": {
          "type": "boolean"
        },
        "relation_strip": {
          "$ref": "#/$defs/work_item_relation_strip"
        },
        "link_state_class": {
          "type": "string",
          "enum": [
            "unlinked",
            "single_relation_linked",
            "multi_relation_linked"
          ]
        },
        "support_export_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
