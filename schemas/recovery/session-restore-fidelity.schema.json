{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/recovery/session-restore-fidelity.schema.json",
  "title": "Aureline session-scoped restore fidelity",
  "description": "Shared restore-fidelity, placeholder-state, no-hidden-rerun, diagnostics, and support-export schema for runtime-backed panes. Restored context, transcripts, checkpoints, and static evidence never imply hidden rerun, silent reattach, or live authority reacquisition.",
  "oneOf": [
    { "$ref": "#/$defs/session_scoped_restore_fidelity_packet" },
    { "$ref": "#/$defs/session_scoped_restore_fidelity_support_export" },
    { "$ref": "#/$defs/placeholder_state_matrix_row" },
    { "$ref": "#/$defs/no_hidden_rerun_drill" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "restore_fidelity_class": {
      "type": "string",
      "enum": [
        "exact_restore",
        "compatible_restore",
        "layout_only",
        "recovered_drafts",
        "evidence_only"
      ],
      "description": "Controlled restore-fidelity classes rendered as Exact restore, Compatible restore, Layout only, Recovered drafts, and Evidence only."
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "terminal_session",
        "task_run",
        "debug_session",
        "notebook_kernel",
        "preview_server",
        "remote_tunnel",
        "diagnostics",
        "support_export"
      ]
    },
    "restore_state": {
      "type": "string",
      "enum": [
        "transcript_restored",
        "session_ended",
        "reconnect_available",
        "rerun_required",
        "context_unavailable",
        "static_evidence_only",
        "live_runtime_survived"
      ],
      "description": "Truthful state rendered for a session-scoped surface. live_runtime_survived is valid only when the same runtime actually survived and was verified."
    },
    "dependency_state": {
      "type": "string",
      "enum": [
        "available",
        "missing",
        "incompatible",
        "quarantined",
        "revoked",
        "offline"
      ]
    },
    "next_action": {
      "type": "string",
      "enum": [
        "none_required",
        "inspect_evidence",
        "reconnect_explicitly",
        "rerun_explicitly",
        "reauthenticate_then_retry",
        "repair_dependency",
        "export_evidence",
        "dismiss_placeholder"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "stable",
        "downgraded_below_stable",
        "preview_only",
        "unsupported"
      ]
    },
    "restore_fidelity_label": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "label"],
      "properties": {
        "class": { "$ref": "#/$defs/restore_fidelity_class" },
        "label": {
          "type": "string",
          "enum": [
            "Exact restore",
            "Compatible restore",
            "Layout only",
            "Recovered drafts",
            "Evidence only"
          ]
        }
      }
    },
    "placeholder_state_matrix_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "surface_class",
        "restore_fidelity_class",
        "restore_state",
        "dependency_state",
        "layout_preserved",
        "stale_evidence_visible",
        "auto_rerun_forbidden",
        "silent_reattach_forbidden",
        "hidden_authority_reacquisition_forbidden",
        "explicit_user_intent_required",
        "next_actions",
        "evidence_refs",
        "visible_summary",
        "support_class"
      ],
      "properties": {
        "record_kind": { "const": "placeholder_state_matrix_row" },
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "restore_fidelity_class": { "$ref": "#/$defs/restore_fidelity_class" },
        "restore_state": { "$ref": "#/$defs/restore_state" },
        "dependency_state": { "$ref": "#/$defs/dependency_state" },
        "layout_preserved": { "type": "boolean", "const": true },
        "stale_evidence_visible": { "type": "boolean", "const": true },
        "auto_rerun_forbidden": { "type": "boolean", "const": true },
        "silent_reattach_forbidden": { "type": "boolean", "const": true },
        "hidden_authority_reacquisition_forbidden": { "type": "boolean", "const": true },
        "explicit_user_intent_required": { "type": "boolean" },
        "target_runtime_ref": { "$ref": "#/$defs/non_empty_string" },
        "next_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/next_action" },
          "uniqueItems": true
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "visible_summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "support_class": { "$ref": "#/$defs/support_class" }
      }
    },
    "no_hidden_rerun_drill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drill_id",
        "surface_class",
        "condition",
        "expected_restore_state",
        "hidden_rerun_attempted",
        "silent_reattach_attempted",
        "authority_reacquired_without_user_intent",
        "target_runtime_named_before_action",
        "evidence_refs"
      ],
      "properties": {
        "drill_id": { "$ref": "#/$defs/non_empty_string" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "condition": { "$ref": "#/$defs/non_empty_string" },
        "expected_restore_state": { "$ref": "#/$defs/restore_state" },
        "hidden_rerun_attempted": { "type": "boolean", "const": false },
        "silent_reattach_attempted": { "type": "boolean", "const": false },
        "authority_reacquired_without_user_intent": { "type": "boolean", "const": false },
        "target_runtime_named_before_action": { "type": "boolean", "const": true },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer_surface",
        "consumer_ref",
        "consumes_schema_ref",
        "consumes_placeholder_state_matrix",
        "consumes_no_hidden_rerun_corpus",
        "support_class"
      ],
      "properties": {
        "consumer_surface": { "$ref": "#/$defs/surface_class" },
        "consumer_ref": { "$ref": "#/$defs/non_empty_string" },
        "consumes_schema_ref": { "type": "boolean", "const": true },
        "consumes_placeholder_state_matrix": { "type": "boolean", "const": true },
        "consumes_no_hidden_rerun_corpus": { "type": "boolean", "const": true },
        "support_class": { "$ref": "#/$defs/support_class" }
      }
    },
    "diagnostics_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "restored_summary",
        "not_restored_summary",
        "topology_adjustment_summary",
        "action_required_summary"
      ],
      "properties": {
        "restored_summary": { "$ref": "#/$defs/non_empty_string" },
        "not_restored_summary": { "$ref": "#/$defs/non_empty_string" },
        "topology_adjustment_summary": { "$ref": "#/$defs/non_empty_string" },
        "action_required_summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "session_scoped_restore_fidelity_support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "schema_ref",
        "placeholder_state_matrix",
        "no_hidden_rerun_drill_refs",
        "diagnostics_summary",
        "raw_private_material_excluded",
        "live_authority_excluded"
      ],
      "properties": {
        "record_kind": { "const": "session_scoped_restore_fidelity_support_export" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "schema_ref": { "const": "schemas/recovery/session-restore-fidelity.schema.json" },
        "placeholder_state_matrix": {
          "type": "array",
          "minItems": 6,
          "items": { "$ref": "#/$defs/placeholder_state_matrix_row" }
        },
        "no_hidden_rerun_drill_refs": {
          "type": "array",
          "minItems": 6,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "diagnostics_summary": { "$ref": "#/$defs/diagnostics_summary" },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "live_authority_excluded": { "type": "boolean", "const": true }
      }
    },
    "session_scoped_restore_fidelity_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "generated_at",
        "schema_ref",
        "doc_ref",
        "artifact_ref",
        "fixture_dir_ref",
        "controlled_restore_fidelity_classes",
        "placeholder_state_matrix",
        "no_hidden_rerun_drills",
        "consumer_projections",
        "diagnostics_summary",
        "support_export"
      ],
      "properties": {
        "record_kind": { "const": "session_scoped_restore_fidelity_packet" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "schema_ref": { "const": "schemas/recovery/session-restore-fidelity.schema.json" },
        "doc_ref": { "const": "docs/reliability/stabilize-session-scoped-restore-fidelity.md" },
        "artifact_ref": { "const": "artifacts/reliability/stabilize-session-scoped-restore-fidelity.md" },
        "fixture_dir_ref": { "const": "fixtures/recovery/stabilize-session-scoped-restore-fidelity" },
        "controlled_restore_fidelity_classes": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/restore_fidelity_label" }
        },
        "placeholder_state_matrix": {
          "type": "array",
          "minItems": 6,
          "items": { "$ref": "#/$defs/placeholder_state_matrix_row" }
        },
        "no_hidden_rerun_drills": {
          "type": "array",
          "minItems": 6,
          "items": { "$ref": "#/$defs/no_hidden_rerun_drill" }
        },
        "consumer_projections": {
          "type": "array",
          "minItems": 8,
          "items": { "$ref": "#/$defs/consumer_projection" }
        },
        "diagnostics_summary": { "$ref": "#/$defs/diagnostics_summary" },
        "support_export": { "$ref": "#/$defs/session_scoped_restore_fidelity_support_export" }
      }
    }
  }
}
