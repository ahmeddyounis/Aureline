        "affected_journal_entry_refs",
        "export_before_reset",
        "tombstone_retained",
        "result_state",
        "support_export",
        "emitted_at"
      ],
      "properties": {
        "record_kind": { "const": "journal_reset_record" },
        "autosave_journal_schema_version": { "$ref": "#/$defs/autosave_journal_schema_version" },
        "fixture_metadata": { "$ref": "#/$defs/fixture_metadata" },
        "reset_record_id": { "$ref": "#/$defs/opaque_id" },
        "workspace_ref": { "$ref": "#/$defs/opaque_id" },
        "reset_scope": {
          "type": "string",
          "enum": [
            "current_journal",
            "selected_entries",
            "workspace_journals",
            "profile_journals",
            "device_journals"
          ]
        },
        "initiated_from": {
          "type": "string",
          "enum": [
            "recovery_screen",
            "support_center",
            "cli",
            "safe_mode",
            "settings_storage_inspector"
          ]
        },
        "separated_from_settings_reset": { "type": "boolean", "const": true },
        "separated_from_cache_clear": { "type": "boolean", "const": true },
        "separated_from_local_history_clear": { "type": "boolean", "const": true },
        "destructive_confirmation": { "$ref": "#/$defs/destructive_confirmation" },
        "affected_journal_entry_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "skipped_journal_entry_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "export_before_reset": { "$ref": "#/$defs/export_before_reset_class" },
        "support_export_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "tombstone_retained": {
          "type": "boolean",
          "description": "True when a reset tombstone remains for support and audit explanation."
        },
        "result_state": {
          "type": "string",
          "enum": [
            "pending_confirmation",
            "reset_completed",
            "reset_partially_completed",
            "reset_blocked_by_policy",
            "reset_cancelled"
          ]
        },
        "support_export": { "$ref": "#/$defs/support_export" },
        "reset_notes": { "$ref": "#/$defs/short_text" },
        "emitted_at": { "$ref": "#/$defs/timestamp" }
      }
    }
  }
}
