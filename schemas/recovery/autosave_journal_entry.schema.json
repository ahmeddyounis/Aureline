        "fixture_metadata": { "$ref": "#/$defs/fixture_metadata" },
        "sentinel_id": { "$ref": "#/$defs/opaque_id" },
        "workspace_ref": { "$ref": "#/$defs/opaque_id" },
        "build_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "restore_graph_ref": {
          "type": ["string", "null"],
          "description": "Opaque restore graph ref when the sentinel is tied to replay."
        },
        "fault_domain_class": { "$ref": "#/$defs/fault_domain_class" },
        "trigger_class": { "$ref": "#/$defs/sentinel_trigger_class" },
        "attempt_counters": { "$ref": "#/$defs/attempt_counters" },
        "threshold_result": { "$ref": "#/$defs/threshold_result_class" },
        "automatic_loop_prevented": {
          "type": "boolean",
          "description": "True when this sentinel blocked another hidden automatic restore or restart attempt."
        },
        "suspect_extension_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "actions_blocked_from_auto_loop": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "automatic_restore_replay",
              "automatic_shell_restart",
              "extension_auto_reactivation",
              "remote_auto_reattach",
              "background_rebuild"
            ]
          },
          "uniqueItems": true
        },
        "recommended_choice_class": { "$ref": "#/$defs/guided_choice_class" },
        "preserved_evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "sentinel_notes": { "$ref": "#/$defs/short_text" },
        "emitted_at": { "$ref": "#/$defs/timestamp" }
      }
