        "object_identity": { "$ref": "#/$defs/object_identity" },
        "base_on_disk_token": { "$ref": "#/$defs/base_on_disk_token" },
        "text_format": { "$ref": "#/$defs/text_format" },
        "actor_surface": { "$ref": "#/$defs/actor_surface" },
        "capture_descriptor": { "$ref": "#/$defs/capture_descriptor" },
        "integrity": { "$ref": "#/$defs/integrity" },
        "replay_posture": { "$ref": "#/$defs/replay_posture" },
        "retention_posture": { "$ref": "#/$defs/retention_posture" },
        "support_export": { "$ref": "#/$defs/support_export" },
        "emitted_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "autosave_journal_group_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "autosave_journal_schema_version",
        "journal_group_id",
        "journal_id",
        "workspace_ref",
        "group_reason",
        "member_entry_refs",
        "group_integrity_state",
        "grouped_replay_posture",
        "recommended_choice_class",
        "member_summaries",
        "retention_posture",
        "support_export",
        "emitted_at"
      ],
      "properties": {
        "record_kind": { "const": "autosave_journal_group_record" },
        "autosave_journal_schema_version": { "$ref": "#/$defs/autosave_journal_schema_version" },
        "fixture_metadata": { "$ref": "#/$defs/fixture_metadata" },
        "journal_group_id": { "$ref": "#/$defs/opaque_id" },
        "journal_id": { "$ref": "#/$defs/opaque_id" },
        "workspace_ref": { "$ref": "#/$defs/opaque_id" },
        "group_reason": { "$ref": "#/$defs/group_reason_class" },
        "member_entry_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "minItems": 1,
          "uniqueItems": true
        },
        "group_integrity_state": { "$ref": "#/$defs/group_integrity_state" },
        "grouped_replay_posture": { "$ref": "#/$defs/grouped_replay_posture" },
        "recommended_choice_class": { "$ref": "#/$defs/guided_choice_class" },
        "base_group_token_ref": {
          "type": ["string", "null"],
          "description": "Opaque ref to a grouped base token or restore graph."
        },
        "member_summaries": {
          "type": "array",
          "items": { "$ref": "#/$defs/member_summary" },
          "minItems": 1
        },
        "retention_posture": { "$ref": "#/$defs/retention_posture" },
        "support_export": { "$ref": "#/$defs/support_export" },
        "emitted_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "crash_sentinel_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "autosave_journal_schema_version",
