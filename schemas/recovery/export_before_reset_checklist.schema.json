{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/recovery/export_before_reset_checklist.schema.json",
  "title": "Aureline export-before-reset checklist",
  "description": "Boundary schema for export-before-reset checklists frozen in docs/reliability/export_before_reset_contract.md. Each checklist describes one drastic destructive recovery action (factory reset, profile reset, workspace reset, layout reset, evidence-index reset, credential-store reset, mirror or offline-bundle reset, sync-replica reset) under one named scenario family (profile corruption, workspace-index corruption, failed update, control-plane outage, device replacement, seat loss, credential-store unreadable, mirror or offline-bundle unavailable). Closed scenario-family vocabulary is re-exported verbatim from schemas/recovery/recovery_scenario_card.schema.json. Closed value-posture vocabulary is re-exported verbatim from schemas/recovery/corruption_rescue_sheet.schema.json. Closed approved-repair vocabulary is re-exported verbatim from schemas/support/scenario_picker.schema.json. Closed probe-family vocabulary is re-exported verbatim from fixtures/support/scenario_matrix.yaml. Closed data-class boundary vocabulary is re-exported verbatim from the shared portability vocabulary. Raw file bodies, raw diff hunks, raw credentials, raw absolute paths, and raw provider payloads never cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/export_before_reset_checklist_record" }
  ],
  "$defs": {
    "export_before_reset_checklist_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for export-before-reset checklist records."
    },
    "record_kind": {
      "type": "string",
      "const": "export_before_reset_checklist_record"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for status surfaces, support bundles, evidence packets, CLI output, and logs. Raw paths, raw URLs, raw credentials, and raw provider payloads never appear here."
    },
    "short_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Short redaction-aware text safe to render in checklists, support exports, evidence packets, and CLI output."
    },
    "monotonic_timestamp": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Producer-local monotonic timestamp string. Opaque to the contract; the surface never re-reads system wall-clock time from this field."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "doc_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "scenario_family_class": {
      "type": "string",
      "enum": [
        "profile_corruption",
        "workspace_index_corruption",
        "failed_update",
        "control_plane_outage",
        "device_replacement",
        "seat_loss",
        "credential_store_unreadable",
        "mirror_or_offline_bundle_unavailable"
      ],
      "description": "Re-exported verbatim from schemas/recovery/recovery_scenario_card.schema.json#recovery_scenario_family_class."
    },
    "reset_kind_class": {
      "type": "string",
      "enum": [
        "factory_reset",
        "profile_reset",
        "workspace_reset",
        "layout_reset",
        "evidence_index_reset",
        "credential_store_reset",
        "mirror_or_offline_bundle_reset",
        "sync_replica_reset"
      ],
      "description": "Closed reset-kind vocabulary. Each checklist resolves to exactly one reset kind; surfaces never collapse factory_reset and profile_reset into one row."
    },
    "deployment_profile_scope_class": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "air_gapped",
        "managed_tenant",
        "cross_plane_failover_pending"
      ]
    },
    "artifact_class": {
      "type": "string",
      "enum": [
        "workspace_state",
        "profile_defaults",
        "layout_topology",
        "evidence_packets",
        "local_history_lane",
        "autosave_journal",
        "credentials",
        "seat_or_license_token",
        "machine_local_assets",
        "caches",
        "install_chain_metadata"
      ],
      "description": "Closed artifact-class vocabulary. Each checklist row resolves to exactly one artifact class."
    },
    "value_posture_class": {
      "type": "string",
      "enum": [
        "user_authored_durable",
        "user_owned_recovery_state",
        "derived_disposable_only",
        "mixed_user_and_derived",
        "policy_bound_evidence",
        "local_forensics_only",
        "install_chain_metadata"
      ],
      "description": "Re-exported verbatim from schemas/recovery/corruption_rescue_sheet.schema.json#artifact_value_posture."
    },
    "external_recoverability_class": {
      "type": "string",
      "enum": [
        "externally_recoverable_authoritative_backup",
        "externally_recoverable_sync_replica",
        "externally_recoverable_managed_admin_seat",
        "externally_recoverable_offline_bundle",
        "locally_recoverable_only_no_external_source",
        "not_recoverable_after_reset"
      ],
      "description": "Closed external-recoverability vocabulary. Every checklist row resolves to exactly one class; surfaces never claim 'maybe recoverable' without a named source."
    },
    "export_action_class": {
      "type": "string",
      "enum": [
        "export_required",
        "export_recommended",
        "export_offered",
        "export_unsupported",
        "export_blocked_by_policy",
        "export_declined_by_user"
      ],
      "description": "Closed export-action vocabulary."
    },
    "verification_result_class": {
      "type": "string",
      "enum": [
        "verified",
        "partial",
        "blocked_by_policy",
        "unsupported_class",
        "user_declined"
      ],
      "description": "Closed verification-result vocabulary. Surfaces that emit complete_with_warnings, best_effort, or try_again are non-conforming."
    },
    "follow_up_guidance_class": {
      "type": "string",
      "enum": [
        "proceed_to_reset_acknowledged",
        "retry_export_after_policy_review",
        "skip_unsupported_class_acknowledged",
        "defer_reset_until_user_returns",
        "escalate_to_admin_seat_recovery",
        "escalate_to_support_with_evidence",
        "abort_reset"
      ],
      "description": "Closed follow-up-guidance vocabulary. Every non-verified row carries exactly one."
    },
    "post_reset_state_class": {
      "type": "string",
      "enum": [
        "will_be_deleted",
        "will_be_retained",
        "externally_recoverable_after_reset",
        "not_exported_unsupported",
        "not_exported_user_declined"
      ],
      "description": "Closed post-reset-state vocabulary. The reset-review language block uses one of these per row to distinguish deleted, retained, externally recoverable, and not-exported state."
    },
    "data_class_boundary_class": {
      "type": "string",
      "enum": [
        "metadata_only",
        "environment_adjacent",
        "code_adjacent",
        "high_risk"
      ]
    },
    "size_precision_class": {
      "type": "string",
      "enum": [
        "exact_preflight",
        "estimated_preflight",
        "bounded_upper",
        "unknown_until_build"
      ],
      "description": "Re-exported from the portable-state manifest size_estimate vocabulary."
    },
    "approved_repair_class": {
      "type": "string",
      "enum": [
        "observe_only_no_repair",
        "disposable_state_rebuild",
        "extension_isolation",
        "extension_rollback_reinstall",
        "execution_context_reresolve",
        "remote_runtime_repair",
        "policy_entitlement_refresh",
        "guided_export_escalation",
        "support_bundle_export",
        "trace_capture"
      ],
      "description": "Re-exported verbatim from schemas/support/scenario_picker.schema.json#approved_repair_class."
    },
    "probe_family_class": {
      "type": "string",
      "enum": [
        "toolchain_probe",
        "trust_state_probe",
        "filesystem_watcher_probe",
        "cache_profile_probe",
        "extension_host_probe",
        "target_and_route_probe",
        "helper_attach_probe",
        "docs_mirror_probe"
      ],
      "description": "Re-exported verbatim from fixtures/support/scenario_matrix.yaml#probe_family_vocabulary."
    },
    "unsupported_reason_class": {
      "type": "string",
      "enum": [
        "transport_does_not_carry_class",
        "class_is_disposable_derived",
        "class_is_authority_owned_remote",
        "class_is_install_chain_metadata",
        "class_is_machine_local_unique"
      ],
      "description": "Closed unsupported-reason vocabulary."
    },
    "size_estimate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bytes_estimate", "precision_class"],
      "properties": {
        "bytes_estimate": {
          "type": "integer",
          "minimum": 0,
          "description": "Producer estimate of the export-artifact size in bytes."
        },
        "precision_class": { "$ref": "#/$defs/size_precision_class" },
        "summary": { "$ref": "#/$defs/short_text" }
      }
    },
    "checklist_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "artifact_class",
        "value_posture",
        "external_recoverability_class",
        "export_action_class",
        "redaction_class",
        "estimated_size",
        "verification_result_class",
        "post_reset_state_class",
        "summary"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/opaque_id" },
        "artifact_class": { "$ref": "#/$defs/artifact_class" },
        "value_posture": { "$ref": "#/$defs/value_posture_class" },
        "external_recoverability_class": { "$ref": "#/$defs/external_recoverability_class" },
        "external_source_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque ref to the authoritative backup, sync replica, managed admin-seat record, or offline bundle that covers the class after reset."
        },
        "export_action_class": { "$ref": "#/$defs/export_action_class" },
        "export_artifact_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque ref to the convenience export produced for this class."
        },
        "redaction_class": { "$ref": "#/$defs/data_class_boundary_class" },
        "estimated_size": { "$ref": "#/$defs/size_estimate" },
        "verification_result_class": { "$ref": "#/$defs/verification_result_class" },
        "follow_up_guidance_class": { "$ref": "#/$defs/follow_up_guidance_class" },
        "post_reset_state_class": { "$ref": "#/$defs/post_reset_state_class" },
        "summary": { "$ref": "#/$defs/short_text" }
      },
      "allOf": [
        {
          "description": "Externally recoverable rows MUST cite an external_source_ref; the four externally_recoverable_* classes are never claimed without a named source.",
          "if": {
            "properties": {
              "external_recoverability_class": {
                "enum": [
                  "externally_recoverable_authoritative_backup",
                  "externally_recoverable_sync_replica",
                  "externally_recoverable_managed_admin_seat",
                  "externally_recoverable_offline_bundle"
                ]
              }
            },
            "required": ["external_recoverability_class"]
          },
          "then": {
            "required": ["external_source_ref"]
          }
        },
        {
          "description": "When the row is not_recoverable_after_reset, post_reset_state_class MUST be will_be_deleted. The user is never told a class is unrecoverable while also claiming it will be retained.",
          "if": {
            "properties": {
              "external_recoverability_class": { "const": "not_recoverable_after_reset" }
            },
            "required": ["external_recoverability_class"]
          },
          "then": {
            "properties": {
              "post_reset_state_class": { "const": "will_be_deleted" }
            },
            "required": ["post_reset_state_class"]
          }
        },
        {
          "description": "Verified rows whose export action is required, recommended, or offered MUST carry an export_artifact_ref so a future support engineer can reconstruct the export.",
          "if": {
            "allOf": [
              {
                "properties": {
                  "verification_result_class": { "const": "verified" }
                },
                "required": ["verification_result_class"]
              },
              {
                "properties": {
                  "export_action_class": {
                    "enum": ["export_required", "export_recommended", "export_offered"]
                  }
                },
                "required": ["export_action_class"]
              }
            ]
          },
          "then": {
            "required": ["export_artifact_ref"]
          }
        },
        {
          "description": "Non-verified rows MUST carry one closed follow-up-guidance class. Free-form 'Try again' prose is non-conforming.",
          "if": {
            "properties": {
              "verification_result_class": {
                "not": { "const": "verified" }
              }
            },
            "required": ["verification_result_class"]
          },
          "then": {
            "required": ["follow_up_guidance_class"]
          }
        },
        {
          "description": "Caches MUST resolve to derived_disposable_only posture; surfaces never claim cache state is durable user-authored bytes.",
          "if": {
            "properties": {
              "artifact_class": { "const": "caches" }
            },
            "required": ["artifact_class"]
          },
          "then": {
            "properties": {
              "value_posture": { "const": "derived_disposable_only" }
            },
            "required": ["value_posture"]
          }
        },
        {
          "description": "export_unsupported rows MUST carry verification_result_class = unsupported_class.",
          "if": {
            "properties": {
              "export_action_class": { "const": "export_unsupported" }
            },
            "required": ["export_action_class"]
          },
          "then": {
            "properties": {
              "verification_result_class": { "const": "unsupported_class" }
            },
            "required": ["verification_result_class"]
          }
        },
        {
          "description": "export_blocked_by_policy rows MUST carry verification_result_class = blocked_by_policy.",
          "if": {
            "properties": {
              "export_action_class": { "const": "export_blocked_by_policy" }
            },
            "required": ["export_action_class"]
          },
          "then": {
            "properties": {
              "verification_result_class": { "const": "blocked_by_policy" }
            },
            "required": ["verification_result_class"]
          }
        },
        {
          "description": "export_declined_by_user rows MUST carry verification_result_class = user_declined.",
          "if": {
            "properties": {
              "export_action_class": { "const": "export_declined_by_user" }
            },
            "required": ["export_action_class"]
          },
          "then": {
            "properties": {
              "verification_result_class": { "const": "user_declined" }
            },
            "required": ["verification_result_class"]
          }
        },
        {
          "description": "Partial verification rows MUST select a follow-up guidance from the partial-allowed set.",
          "if": {
            "properties": {
              "verification_result_class": { "const": "partial" }
            },
            "required": ["verification_result_class"]
          },
          "then": {
            "properties": {
              "follow_up_guidance_class": {
                "enum": [
                  "proceed_to_reset_acknowledged",
                  "defer_reset_until_user_returns",
                  "escalate_to_support_with_evidence",
                  "abort_reset"
                ]
              }
            },
            "required": ["follow_up_guidance_class"]
          }
        },
        {
          "description": "blocked_by_policy rows MUST select a follow-up guidance from the policy-allowed set.",
          "if": {
            "properties": {
              "verification_result_class": { "const": "blocked_by_policy" }
            },
            "required": ["verification_result_class"]
          },
          "then": {
            "properties": {
              "follow_up_guidance_class": {
                "enum": [
                  "retry_export_after_policy_review",
                  "defer_reset_until_user_returns",
                  "escalate_to_admin_seat_recovery",
                  "abort_reset"
                ]
              }
            },
            "required": ["follow_up_guidance_class"]
          }
        },
        {
          "description": "unsupported_class rows MUST select a follow-up guidance from the unsupported-allowed set.",
          "if": {
            "properties": {
              "verification_result_class": { "const": "unsupported_class" }
            },
            "required": ["verification_result_class"]
          },
          "then": {
            "properties": {
              "follow_up_guidance_class": {
                "enum": [
                  "skip_unsupported_class_acknowledged",
                  "escalate_to_support_with_evidence",
                  "abort_reset"
                ]
              }
            },
            "required": ["follow_up_guidance_class"]
          }
        },
        {
          "description": "user_declined rows MUST select a follow-up guidance from the declined-allowed set.",
          "if": {
            "properties": {
              "verification_result_class": { "const": "user_declined" }
            },
            "required": ["verification_result_class"]
          },
          "then": {
            "properties": {
              "follow_up_guidance_class": {
                "enum": [
                  "proceed_to_reset_acknowledged",
                  "defer_reset_until_user_returns",
                  "abort_reset"
                ]
              }
            },
            "required": ["follow_up_guidance_class"]
          }
        }
      ]
    },
    "unsupported_class_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unsupported_class",
        "unsupported_reason_class",
        "redaction_class",
        "summary"
      ],
      "properties": {
        "unsupported_class": { "$ref": "#/$defs/artifact_class" },
        "unsupported_reason_class": { "$ref": "#/$defs/unsupported_reason_class" },
        "redaction_class": { "$ref": "#/$defs/data_class_boundary_class" },
        "summary": { "$ref": "#/$defs/short_text" }
      }
    },
    "policy_exclusion_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "excluded_class",
        "policy_ref",
        "redaction_class",
        "summary"
      ],
      "properties": {
        "excluded_class": { "$ref": "#/$defs/artifact_class" },
        "policy_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Stable ref to the active policy that excluded this class."
        },
        "redaction_class": { "$ref": "#/$defs/data_class_boundary_class" },
        "summary": { "$ref": "#/$defs/short_text" }
      }
    },
    "externally_recoverable_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_class",
        "external_recoverability_class",
        "external_source_ref",
        "summary"
      ],
      "properties": {
        "artifact_class": { "$ref": "#/$defs/artifact_class" },
        "external_recoverability_class": {
          "type": "string",
          "enum": [
            "externally_recoverable_authoritative_backup",
            "externally_recoverable_sync_replica",
            "externally_recoverable_managed_admin_seat",
            "externally_recoverable_offline_bundle"
          ],
          "description": "Only the four externally_recoverable_* values from the parent vocabulary are admitted here."
        },
        "external_source_ref": { "$ref": "#/$defs/opaque_id" },
        "summary": { "$ref": "#/$defs/short_text" }
      }
    },
    "reset_review_language": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "will_be_deleted",
        "will_be_retained",
        "externally_recoverable_after_reset",
        "not_exported"
      ],
      "properties": {
        "summary": { "$ref": "#/$defs/short_text" },
        "will_be_deleted": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact_class" },
          "uniqueItems": true,
          "description": "Artifact classes whose post_reset_state_class is will_be_deleted."
        },
        "will_be_retained": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact_class" },
          "uniqueItems": true,
          "description": "Artifact classes whose post_reset_state_class is will_be_retained."
        },
        "externally_recoverable_after_reset": {
          "type": "array",
          "items": { "$ref": "#/$defs/externally_recoverable_row" },
          "uniqueItems": true
        },
        "not_exported": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "unsupported_classes",
            "policy_excluded_classes",
            "user_declined_classes"
          ],
          "properties": {
            "unsupported_classes": {
              "type": "array",
              "items": { "$ref": "#/$defs/artifact_class" },
              "uniqueItems": true
            },
            "policy_excluded_classes": {
              "type": "array",
              "items": { "$ref": "#/$defs/artifact_class" },
              "uniqueItems": true
            },
            "user_declined_classes": {
              "type": "array",
              "items": { "$ref": "#/$defs/artifact_class" },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "linkage_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recovery_scenario_card",
        "support_bundle",
        "repair_transaction"
      ],
      "properties": {
        "recovery_scenario_card": {
          "type": "object",
          "additionalProperties": false,
          "required": ["card_ref", "summary"],
          "properties": {
            "card_ref": { "$ref": "#/$defs/opaque_id" },
            "matrix_row_ref": { "$ref": "#/$defs/opaque_id" },
            "summary": { "$ref": "#/$defs/short_text" }
          }
        },
        "support_bundle": {
          "type": "object",
          "additionalProperties": false,
          "required": ["redaction_class", "summary"],
          "properties": {
            "support_bundle_ref": { "$ref": "#/$defs/opaque_id" },
            "support_bundle_preview_ref": { "$ref": "#/$defs/opaque_id" },
            "redaction_class": { "$ref": "#/$defs/data_class_boundary_class" },
            "summary": { "$ref": "#/$defs/short_text" }
          }
        },
        "repair_transaction": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repair_transaction_ref", "approved_repair_class", "summary"],
          "properties": {
            "repair_transaction_ref": { "$ref": "#/$defs/opaque_id" },
            "repair_preview_ref": { "$ref": "#/$defs/opaque_id" },
            "approved_repair_class": { "$ref": "#/$defs/approved_repair_class" },
            "summary": { "$ref": "#/$defs/short_text" }
          }
        },
        "restore_destination_review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["summary"],
          "properties": {
            "review_ref": { "$ref": "#/$defs/opaque_id" },
            "summary": { "$ref": "#/$defs/short_text" }
          }
        },
        "continuity_status_card_ref": { "$ref": "#/$defs/opaque_id" },
        "project_doctor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["probe_family_class", "summary"],
          "properties": {
            "probe_family_class": { "$ref": "#/$defs/probe_family_class" },
            "doctor_finding_code_refs": {
              "type": "array",
              "items": { "$ref": "#/$defs/opaque_id" },
              "uniqueItems": true
            },
            "summary": { "$ref": "#/$defs/short_text" }
          }
        },
        "admin_seat_recovery_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "glossary_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "externally_recoverable_definition_const",
        "merely_local_definition_const"
      ],
      "properties": {
        "externally_recoverable_definition_const": {
          "type": "boolean",
          "const": true,
          "description": "Const guarantee that the surface uses the contract's externally_recoverable definition (authoritative backup, sync replica for profile-shaped state, managed admin-seat re-issuance for seat or license tokens, or signed offline bundle for mirror or docs-pack-shaped state) rather than substituting a private prose definition."
        },
        "merely_local_definition_const": {
          "type": "boolean",
          "const": true,
          "description": "Const guarantee that the surface uses the contract's merely_local definition: no external source above exists, the convenience export written by this checklist is the only copy, and an unsupported, blocked, or declined export converts the class to not_recoverable_after_reset."
        }
      }
    },
    "honesty_invariants": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_family_is_closed",
        "reset_kind_is_closed",
        "unsupported_classes_explicit",
        "policy_exclusions_explicit",
        "external_recoverability_per_row",
        "reset_review_language_distinguishes_four_buckets",
        "linkage_is_typed"
      ],
      "properties": {
        "scenario_family_is_closed": {
          "type": "boolean",
          "const": true
        },
        "reset_kind_is_closed": {
          "type": "boolean",
          "const": true
        },
        "unsupported_classes_explicit": {
          "type": "boolean",
          "const": true
        },
        "policy_exclusions_explicit": {
          "type": "boolean",
          "const": true
        },
        "external_recoverability_per_row": {
          "type": "boolean",
          "const": true
        },
        "reset_review_language_distinguishes_four_buckets": {
          "type": "boolean",
          "const": true
        },
        "linkage_is_typed": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "export_before_reset_checklist_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "export_before_reset_checklist_schema_version",
        "checklist_id",
        "generated_at",
        "scenario_family_class",
        "reset_kind_class",
        "title",
        "summary",
        "deployment_profile_scope_class",
        "checklist_rows",
        "unsupported_classes",
        "policy_exclusions",
        "reset_review_language",
        "glossary",
        "linkage",
        "honesty_invariants"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "export_before_reset_checklist_schema_version": { "$ref": "#/$defs/export_before_reset_checklist_schema_version" },
        "checklist_id": { "$ref": "#/$defs/opaque_id" },
        "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "scenario_family_class": { "$ref": "#/$defs/scenario_family_class" },
        "reset_kind_class": { "$ref": "#/$defs/reset_kind_class" },
        "title": { "$ref": "#/$defs/short_text" },
        "summary": { "$ref": "#/$defs/short_text" },
        "deployment_profile_scope_class": { "$ref": "#/$defs/deployment_profile_scope_class" },
        "checklist_rows": {
          "type": "array",
          "minItems": 1,
          "maxItems": 11,
          "items": { "$ref": "#/$defs/checklist_row" },
          "uniqueItems": true,
          "description": "One row per reviewable artifact class. Bounded by the closed artifact-class vocabulary."
        },
        "unsupported_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/unsupported_class_row" },
          "uniqueItems": true,
          "description": "Every artifact class whose export_action_class is export_unsupported. Surfaces that hide an unsupported class behind a generic 'Export complete' summary are non-conforming."
        },
        "policy_exclusions": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_exclusion_row" },
          "uniqueItems": true,
          "description": "Every artifact class whose export_action_class is export_blocked_by_policy."
        },
        "reset_review_language": { "$ref": "#/$defs/reset_review_language" },
        "verification_result_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque ref to the matching export_verification_result_record."
        },
        "glossary": { "$ref": "#/$defs/glossary_block" },
        "linkage": { "$ref": "#/$defs/linkage_block" },
        "honesty_invariants": { "$ref": "#/$defs/honesty_invariants" }
      },
      "allOf": [
        {
          "description": "workspace_index_corruption forbids every reset kind. Surfaces that propose a destructive action for a derived index corruption are non-conforming.",
          "not": {
            "properties": {
              "scenario_family_class": { "const": "workspace_index_corruption" }
            },
            "required": ["scenario_family_class"]
          }
        },
        {
          "description": "control_plane_outage forbids every reset kind while the control-plane is unreachable. The recovery-scenario contract gates destructive actions during outages.",
          "not": {
            "properties": {
              "scenario_family_class": { "const": "control_plane_outage" }
            },
            "required": ["scenario_family_class"]
          }
        },
        {
          "description": "profile_corruption admits profile_reset and factory_reset only.",
          "if": {
            "properties": {
              "scenario_family_class": { "const": "profile_corruption" }
            },
            "required": ["scenario_family_class"]
          },
          "then": {
            "properties": {
              "reset_kind_class": {
                "enum": ["profile_reset", "factory_reset"]
              }
            },
            "required": ["reset_kind_class"]
          }
        },
        {
          "description": "failed_update admits factory_reset only (last-resort path after rollback failed).",
          "if": {
            "properties": {
              "scenario_family_class": { "const": "failed_update" }
            },
            "required": ["scenario_family_class"]
          },
          "then": {
            "properties": {
              "reset_kind_class": { "const": "factory_reset" }
            },
            "required": ["reset_kind_class"]
          }
        },
        {
          "description": "device_replacement admits factory_reset only (on the abandoned device).",
          "if": {
            "properties": {
              "scenario_family_class": { "const": "device_replacement" }
            },
            "required": ["scenario_family_class"]
          },
          "then": {
            "properties": {
              "reset_kind_class": { "const": "factory_reset" }
            },
            "required": ["reset_kind_class"]
          }
        },
        {
          "description": "seat_loss admits factory_reset, profile_reset, and credential_store_reset.",
          "if": {
            "properties": {
              "scenario_family_class": { "const": "seat_loss" }
            },
            "required": ["scenario_family_class"]
          },
          "then": {
            "properties": {
              "reset_kind_class": {
                "enum": ["factory_reset", "profile_reset", "credential_store_reset"]
              }
            },
            "required": ["reset_kind_class"]
          }
        },
        {
          "description": "credential_store_unreadable admits credential_store_reset only.",
          "if": {
            "properties": {
              "scenario_family_class": { "const": "credential_store_unreadable" }
            },
            "required": ["scenario_family_class"]
          },
          "then": {
            "properties": {
              "reset_kind_class": { "const": "credential_store_reset" }
            },
            "required": ["reset_kind_class"]
          }
        },
        {
          "description": "mirror_or_offline_bundle_unavailable admits mirror_or_offline_bundle_reset and sync_replica_reset.",
          "if": {
            "properties": {
              "scenario_family_class": { "const": "mirror_or_offline_bundle_unavailable" }
            },
            "required": ["scenario_family_class"]
          },
          "then": {
            "properties": {
              "reset_kind_class": {
                "enum": ["mirror_or_offline_bundle_reset", "sync_replica_reset"]
              }
            },
            "required": ["reset_kind_class"]
          }
        }
      ]
    }
  }
}
