{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/recovery/local_history_snapshot_class.schema.json",
  "title": "Aureline local-history visible snapshot-class card",
  "description": "Boundary schema for user-facing local-history snapshot-class cards frozen in docs/reliability/local_history_restore_preview_contract.md. The card projects the underlying local_history_entry or local_history_group_record into a reviewable checkpoint row with visible snapshot class, actor/source attribution, checkpoint identity, restore affordances, and export metadata. Raw file bodies, raw diff hunks, raw prompts, raw credentials, raw absolute paths, and raw provider payloads never cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/local_history_snapshot_class_card" },
    { "$ref": "#/$defs/local_history_snapshot_class_card_set" }
  ],
  "$defs": {
    "snapshot_class_card_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for visible snapshot-class card records."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "local_history_snapshot_class_card",
        "local_history_snapshot_class_card_set"
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for timeline rows, restore previews, support bundles, evidence packets, and CLI output. Raw paths, URLs, provider payloads, and credentials never appear here."
    },
    "short_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "description": "Short redaction-aware text safe to render in checkpoint rows, support exports, and evidence packets."
    },
    "stable_token": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[_-][a-z0-9]+)*$"
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "doc_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "description": "Optional fixture prelude. Not read by production consumers."
    },
    "visible_snapshot_class": {
      "type": "string",
      "enum": [
        "autosaved_typing_bucket",
        "save_boundary",
        "pre_destructive_checkpoint",
        "tool_generated_checkpoint",
        "crash_restore_capture"
      ],
      "description": "Closed user-facing snapshot class. Surfaces render this class on local-history checkpoint rows and restore previews instead of deriving private labels from the lower-level storage class."
    },
    "storage_snapshot_class": {
      "type": "string",
      "enum": [
        "edit_save_checkpoint",
        "workspace_mutation_checkpoint",
        "automation_ai_checkpoint",
        "external_state_checkpoint",
        "restore_rollback_checkpoint",
        "capture_omitted_stub",
        "policy_redacted_stub"
      ],
      "description": "Underlying local_history_entry.snapshot_class or local_history_group_record.snapshot_class projected by this card."
    },
    "truth_source_class": {
      "type": "string",
      "enum": [
        "local_history",
        "autosave_journal",
        "git_history",
        "automation_lineage",
        "external_change_record",
        "synced_or_provider_history",
        "review_checkpoint"
      ]
    },
    "actor_class": {
      "type": "string",
      "enum": [
        "user_keystroke",
        "user_command",
        "multi_cursor_command",
        "refactor_engine",
        "formatter",
        "save_participant",
        "ai_apply",
        "code_action",
        "scaffolding",
        "settings_import",
        "workspace_migration",
        "external_reload",
        "decode_recovery",
        "build_runner",
        "codegen_runner",
        "preview_regenerator",
        "review_apply",
        "replay_import",
        "vendor_import",
        "paste_or_drop_import",
        "automation_recipe_runner",
        "external_change_detector",
        "restore_rollback_runner",
        "crash_recovery_journal"
      ],
      "description": "Actor class projected from the mutation journal, external-change detector, crash journal, repair flow, or restore runner."
    },
    "actor_family": {
      "type": "string",
      "enum": [
        "user",
        "automation",
        "ai_or_tool",
        "external_detector",
        "repair",
        "restore_runner",
        "crash_recovery"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "human_local",
        "human_remote_session",
        "machine_local",
        "machine_remote_agent",
        "ai_local_model",
        "ai_hosted_provider",
        "imported_external",
        "replayed_capture",
        "policy_driven",
        "autosave_journal",
        "crash_journal",
        "external_change_observation"
      ],
      "description": "Source class preserved on the card so review, export, and support surfaces can render origin without loading the full mutation-journal body."
    },
    "origin_surface_class": {
      "type": "string",
      "enum": [
        "editor_typing",
        "save_pipeline",
        "formatter",
        "refactor_preview",
        "ai_apply_review",
        "automation_recipe",
        "migration_import",
        "package_or_tool_action",
        "external_change_review",
        "crash_restore_review",
        "repair_preview",
        "restore_preview",
        "generated_artifact_refresh",
        "support_or_evidence_export"
      ]
    },
    "capture_mode": {
      "type": "string",
      "enum": [
        "content_addressed_snapshot",
        "metadata_plus_reference_only",
        "group_manifest_only",
        "external_cause_metadata_only"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_only",
        "environment_adjacent",
        "code_adjacent",
        "high_risk"
      ]
    },
    "retention_class": {
      "type": "string",
      "enum": [
        "retained_by_policy_window",
        "retained_by_explicit_user_pin",
        "retained_by_evidence_reference",
        "retained_by_support_case_reference",
        "retained_by_release_reference",
        "retained_by_review_pack_reference",
        "stub_only_after_expiry",
        "stub_only_after_redaction"
      ]
    },
    "support_bundle_inclusion_state": {
      "type": "string",
      "enum": [
        "excluded_by_default",
        "included_by_entry_ref",
        "review_required_before_export",
        "retained_local_only",
        "exported_in_support_bundle",
        "prohibited"
      ],
      "description": "Support-bundle posture for the checkpoint body or metadata. included_by_entry_ref means the bundle may cite the checkpoint without embedding raw body content."
    },
    "local_export_state": {
      "type": "string",
      "enum": [
        "local_only_not_exported",
        "exported_as_patch",
        "exported_as_evidence",
        "exported_in_support_bundle",
        "managed_copy_reference_only",
        "export_blocked_by_policy"
      ]
    },
    "restore_action_class": {
      "type": "string",
      "enum": [
        "inspect_only",
        "restore_selected_range",
        "restore_selected_hunks",
        "restore_whole_file",
        "restore_grouped_checkpoint",
        "export_as_patch",
        "export_as_evidence"
      ]
    },
    "action_availability_class": {
      "type": "string",
      "enum": [
        "allowed",
        "requires_review",
        "disabled",
        "blocked_by_policy",
        "blocked_by_artifact_class"
      ]
    },
    "disabled_reason_class": {
      "type": ["string", "null"],
      "enum": [
        "not_applicable",
        "body_unavailable",
        "metadata_only_snapshot",
        "identity_drift_requires_review",
        "generated_target_requires_source",
        "managed_mirror_read_only",
        "current_object_missing",
        "group_member_blocked",
        "policy_blocks_body_restore",
        "scope_not_supported",
        null
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_class", "actor_family", "display_label"],
      "properties": {
        "actor_class": { "$ref": "#/$defs/actor_class" },
        "actor_family": { "$ref": "#/$defs/actor_family" },
        "display_label": { "$ref": "#/$defs/short_text" },
        "stable_actor_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_class", "truth_source_class", "origin_surface_class"],
      "properties": {
        "source_class": { "$ref": "#/$defs/source_class" },
        "truth_source_class": { "$ref": "#/$defs/truth_source_class" },
        "origin_surface_class": { "$ref": "#/$defs/origin_surface_class" },
        "mutation_journal_ref": { "$ref": "#/$defs/opaque_id" },
        "mutation_group_ref": { "$ref": "#/$defs/opaque_id" },
        "command_ref": { "$ref": "#/$defs/opaque_id" },
        "external_event_ref": { "$ref": "#/$defs/opaque_id" },
        "crash_or_journal_ref": { "$ref": "#/$defs/opaque_id" },
        "evidence_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "checkpoint_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_ref",
        "logical_document_refs",
        "capture_mode",
        "grouped_checkpoint"
      ],
      "properties": {
        "entry_ref": { "$ref": "#/$defs/opaque_id" },
        "group_ref": { "$ref": "#/$defs/opaque_id" },
        "logical_document_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "branch_context_ref": { "$ref": "#/$defs/opaque_id" },
        "worktree_context_ref": { "$ref": "#/$defs/opaque_id" },
        "capture_mode": { "$ref": "#/$defs/capture_mode" },
        "body_available": { "type": "boolean" },
        "grouped_checkpoint": { "type": "boolean" },
        "member_entry_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "export_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redaction_class",
        "retention_class",
        "support_bundle_inclusion_state",
        "local_export_state",
        "local_only_by_default",
        "ordinary_cache_clear_exclusion"
      ],
      "properties": {
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "retention_class": { "$ref": "#/$defs/retention_class" },
        "support_bundle_inclusion_state": { "$ref": "#/$defs/support_bundle_inclusion_state" },
        "local_export_state": { "$ref": "#/$defs/local_export_state" },
        "local_only_by_default": {
          "type": "boolean",
          "const": true
        },
        "ordinary_cache_clear_exclusion": {
          "type": "boolean",
          "const": true
        },
        "export_artifact_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "export_summary": { "$ref": "#/$defs/short_text" }
      }
    },
    "action_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_class",
        "availability_class",
        "artifact_class_allows",
        "would_create_new_checkpoint"
      ],
      "properties": {
        "action_class": { "$ref": "#/$defs/restore_action_class" },
        "availability_class": { "$ref": "#/$defs/action_availability_class" },
        "artifact_class_allows": { "type": "boolean" },
        "would_create_new_checkpoint": { "type": "boolean" },
        "disabled_reason_class": { "$ref": "#/$defs/disabled_reason_class" },
        "new_checkpoint_preview_ref": { "$ref": "#/$defs/opaque_id" },
        "summary": { "$ref": "#/$defs/short_text" }
      }
    },
    "local_history_snapshot_class_card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "snapshot_class_card_schema_version",
        "card_id",
        "visible_snapshot_class",
        "storage_snapshot_class",
        "timeline_label",
        "actor",
        "source",
        "checkpoint_identity",
        "export_metadata",
        "available_actions"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "local_history_snapshot_class_card" },
        "snapshot_class_card_schema_version": { "$ref": "#/$defs/snapshot_class_card_schema_version" },
        "card_id": { "$ref": "#/$defs/opaque_id" },
        "visible_snapshot_class": { "$ref": "#/$defs/visible_snapshot_class" },
        "storage_snapshot_class": { "$ref": "#/$defs/storage_snapshot_class" },
        "timeline_label": { "$ref": "#/$defs/short_text" },
        "actor": { "$ref": "#/$defs/actor" },
        "source": { "$ref": "#/$defs/source" },
        "checkpoint_identity": { "$ref": "#/$defs/checkpoint_identity" },
        "export_metadata": { "$ref": "#/$defs/export_metadata" },
        "available_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/action_summary" }
        },
        "notes": { "$ref": "#/$defs/short_text" }
      }
    },
    "local_history_snapshot_class_card_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "snapshot_class_card_schema_version",
        "card_set_id",
        "cards"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "local_history_snapshot_class_card_set" },
        "snapshot_class_card_schema_version": { "$ref": "#/$defs/snapshot_class_card_schema_version" },
        "card_set_id": { "$ref": "#/$defs/opaque_id" },
        "cards": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/local_history_snapshot_class_card" }
        }
      }
    }
  }
}
