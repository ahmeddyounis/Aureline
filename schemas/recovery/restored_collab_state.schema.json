{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/recovery/restored_collab_state.schema.json",
  "title": "Aureline restored collaboration state contract",
  "description": "Boundary schema for restored-collab-state records frozen in docs/recovery/collab_restore_and_presentation_contract.md. One record per recovering scope projects the typed restored-collab rows (one per restored kind: follow target, presenter state, presenter handoff history, role badge, shared-cursor visibility, speaker-note locality, presenter grant state, shared-terminal grant state, shared-debugger grant state, shared-notebook-kernel grant state, shared-runbook grant state, shared-review-comment grant state), the typed restoration-posture, the typed live-authority-status, the typed no-auto-resume directives for shared terminal / debugger / notebook / runbook / build-task / review / editor lanes and the presenter grant, the typed shared-control reopen postures, the typed export-lane classification, the typed forbidden-claim list, the packet/export linkage, the accessibility contract, and the const honesty invariants. Closed follow-mode, follow-target-kind, presenter-role, focus-broadcast-posture, presenter-handoff-kind, degraded-follow-posture, control-grant-lane, control-grant-revocation-cause, recovery-level, restore-fidelity, redaction, and export-posture vocabularies are re-exported verbatim from their owning schemas. Raw paths, raw URLs, raw credentials, raw provider payloads, raw terminal scrollback, raw debug payloads, and raw notebook outputs never cross this boundary.",
  "type": "object",
  "$ref": "#/$defs/restored_collab_state_record",
  "$defs": {
    "restored_collab_state_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for restored_collab_state_record. Additive-minor changes (new restored_collab_kind_class, new restoration_posture_class, new live_authority_status_class, new no_auto_resume_class, new required_regrant_action_class, new reopen_as_class, new forbidden_claim_class, new surface_family) bump this const; repurposing an existing value is breaking."
    },
    "record_kind": {
      "type": "string",
      "const": "restored_collab_state_record",
      "description": "Discriminator. Always restored_collab_state_record for records conforming to this schema."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe for status surfaces, support bundles, evidence packets, release-evidence packets, CLI output, and logs. Raw paths, raw URLs, raw credentials, and raw provider payloads never appear here."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "short_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Short redaction-aware text safe to render in shell surfaces, support exports, evidence packets, CLI output, and docs/help previews."
    },
    "monotonic_timestamp": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Producer-local monotonic timestamp string. Opaque to the contract; the surface never re-reads system wall-clock time from this field."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "doc_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "restored_collab_kind_class": {
      "type": "string",
      "enum": [
        "restored_follow_target",
        "restored_presenter_state",
        "restored_presenter_handoff_history",
        "restored_role_badge",
        "restored_shared_cursor_visibility",
        "restored_speaker_note_locality",
        "restored_presenter_grant_state",
        "restored_shared_terminal_control_grant_state",
        "restored_shared_debugger_control_grant_state",
        "restored_shared_notebook_kernel_control_grant_state",
        "restored_shared_runbook_control_grant_state",
        "restored_shared_review_comment_grant_state"
      ],
      "description": "Closed twelve-class restored-collab-kind vocabulary. Every restored row resolves to exactly one."
    },
    "restoration_posture_class": {
      "type": "string",
      "enum": [
        "restored_as_local_context_only",
        "restored_as_placeholder_pending_session_rejoin",
        "degraded_session_expired",
        "degraded_collaborator_missing",
        "degraded_grant_revoked",
        "degraded_authority_unrecoverable_evidence_only",
        "bypassed_no_collab_state_to_restore"
      ],
      "description": "Closed seven-class restoration-posture vocabulary. Every row cites exactly one."
    },
    "live_authority_status_class": {
      "type": "string",
      "enum": [
        "not_live_no_grant",
        "not_live_explicit_regrant_required",
        "not_live_grant_revoked_evidence_only",
        "unrecoverable_collaboration_authority_evidence_only"
      ],
      "description": "Closed four-class live-authority-status vocabulary. This contract mints no live class; every row cites exactly one of these non-live classes."
    },
    "no_auto_resume_class": {
      "type": "string",
      "enum": [
        "shared_terminal_control",
        "shared_debugger_control",
        "shared_notebook_kernel_control",
        "shared_runbook_control",
        "shared_build_task_control",
        "shared_review_admit_control",
        "shared_editor_driver_control",
        "presenter_grant_active_authority"
      ],
      "description": "Closed eight-class no-auto-resume vocabulary. The first seven cover the shared-control lanes; the last covers presenter grant active authority."
    },
    "required_regrant_action_class": {
      "type": "string",
      "enum": [
        "explicit_invite_required",
        "explicit_grant_request_required",
        "admin_signed_admission_required",
        "approval_ticket_required",
        "no_regrant_admitted_evidence_only",
        "policy_blocked_no_regrant"
      ],
      "description": "Closed six-class required-regrant-action vocabulary. Each no-auto-resume directive cites exactly one."
    },
    "reopen_as_class": {
      "type": "string",
      "enum": [
        "reopen_as_context_only",
        "reopen_as_placeholder_with_explicit_regrant",
        "reopen_as_evidence_only",
        "do_not_reopen"
      ],
      "description": "Closed four-class reopen-as vocabulary for shared-control surfaces. No live reopen class exists in this contract."
    },
    "forbidden_claim_class": {
      "type": "string",
      "enum": [
        "claim_live_share_session_intact",
        "claim_presenter_grant_still_active",
        "claim_shared_terminal_control_intact",
        "claim_shared_debugger_control_intact",
        "claim_shared_notebook_kernel_intact",
        "claim_runbook_control_intact",
        "claim_silent_grant_reacquisition",
        "claim_silent_session_rejoin",
        "claim_collaborator_present_when_unresolved"
      ],
      "description": "Closed nine-class forbidden-claim vocabulary. Every record cites at least one; surfaces that bypass by free-text wording are non-conforming."
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "start_center_chooser",
        "restore_panel",
        "shell_chrome_role_badge",
        "diagnostics_collab_panel",
        "support_export_preview",
        "release_evidence_packet",
        "docs_help_example"
      ],
      "description": "Closed surface-family vocabulary. Each record cites exactly one."
    },
    "startup_state_token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^startup_state:[a-z_]+$",
      "description": "A startup_state token from docs/ux/entry_restore_truth_audit.md §6 (e.g. startup_state:reopen_with_pending_restore, startup_state:open_without_restore)."
    },
    "recovery_level_class": {
      "type": "string",
      "enum": [
        "exact_session_restore",
        "context_restore_with_placeholders",
        "dirty_buffer_recovery",
        "checkpoint_rollback",
        "evidence_only_recovery"
      ],
      "description": "Re-exported verbatim from schemas/recovery/recovery_level.schema.json#recovery_level_class. The chooser ref carries the chosen level for this launch; this field is the chosen class quoted for fast cross-surface filtering."
    },
    "follow_mode_class": {
      "type": "string",
      "enum": [
        "cursor_follow_exact",
        "scroll_follow_viewport_only",
        "focus_follow_attention_only",
        "presenter_broadcast_follow",
        "follow_paused_local_view_only",
        "follow_unavailable_live_state_missing"
      ],
      "description": "Re-exported verbatim from schemas/collaboration/follow_and_presenter_state.schema.json#follow_mode_class."
    },
    "follow_target_kind_class": {
      "type": "string",
      "enum": [
        "actor_cursor_target",
        "buffer_selection_target",
        "pane_focus_target",
        "presenter_broadcast_channel",
        "graph_focus_target",
        "review_diff_hunk_target"
      ],
      "description": "Re-exported verbatim from schemas/collaboration/follow_and_presenter_state.schema.json#follow_target_kind_class."
    },
    "presenter_role_class": {
      "type": "string",
      "enum": [
        "presenter",
        "co_presenter",
        "observer",
        "none_pre_session_or_post_handoff"
      ],
      "description": "Re-exported verbatim from schemas/collaboration/follow_and_presenter_state.schema.json#presenter_role_class."
    },
    "focus_broadcast_posture_class": {
      "type": "string",
      "enum": [
        "focus_broadcast_active",
        "focus_broadcast_paused_temporary",
        "focus_broadcast_disabled_local_view_only",
        "focus_broadcast_unavailable_degraded_projection"
      ],
      "description": "Re-exported verbatim from schemas/collaboration/follow_and_presenter_state.schema.json#focus_broadcast_posture_class."
    },
    "presenter_handoff_kind_class": {
      "type": "string",
      "enum": [
        "presenter_assigned_by_owner",
        "presenter_accepted_handoff",
        "presenter_refused_handoff",
        "presenter_step_away_auto_observer",
        "presenter_revoked_by_owner",
        "presenter_revoked_by_policy"
      ],
      "description": "Re-exported verbatim from schemas/collaboration/follow_and_presenter_state.schema.json#presenter_handoff_kind_class."
    },
    "degraded_follow_posture_class": {
      "type": "string",
      "enum": [
        "follow_only_summary_readout_offered",
        "invitation_or_handoff_fallback_offered",
        "transcript_summary_only_live_state_missing",
        "local_view_only_no_follow_admitted"
      ],
      "description": "Re-exported verbatim from schemas/collaboration/follow_and_presenter_state.schema.json#degraded_follow_posture_class."
    },
    "role_badge_class": {
      "type": "string",
      "enum": [
        "presenter",
        "co_presenter",
        "observer",
        "driver",
        "approver"
      ],
      "description": "Re-exported verbatim from the layout-serialization contract role-badge set. Restored badges are visible context only and never confer mutating authority."
    },
    "shared_cursor_visibility_class": {
      "type": "string",
      "enum": [
        "hidden_pending_session_rejoin",
        "local_only_evidence_label",
        "degraded_summary_readout_only",
        "not_applicable_no_prior_share"
      ],
      "description": "Closed shared-cursor visibility vocabulary. Restored shared cursors never imply a live cursor stream."
    },
    "speaker_note_locality_class": {
      "type": "string",
      "enum": [
        "local_to_workspace_no_share",
        "local_to_pane_only_view_only",
        "pending_explicit_share_rebind",
        "evidence_only_unrecoverable"
      ],
      "description": "Closed speaker-note locality vocabulary. Restored speaker notes are never silently shared."
    },
    "presenter_grant_state_class": {
      "type": "string",
      "enum": [
        "no_prior_presenter_grant",
        "prior_presenter_grant_active_at_crash",
        "prior_presenter_grant_expired_before_restart",
        "prior_presenter_grant_revoked_by_owner",
        "prior_presenter_grant_revoked_by_policy",
        "prior_presenter_grant_unrecoverable_evidence_only"
      ],
      "description": "Closed presenter-grant-state vocabulary. Presenter grants do not survive a restart; this row records what was true at the crash boundary."
    },
    "shared_control_lane_class": {
      "type": "string",
      "enum": [
        "shared_terminal_lane",
        "shared_debugger_lane",
        "shared_runbook_lane",
        "shared_notebook_kernel_lane",
        "shared_build_task_lane",
        "shared_editor_buffer_lane",
        "shared_review_comment_lane"
      ],
      "description": "Re-exported verbatim from schemas/collaboration/control_grant.schema.json#control_grant_lane_class."
    },
    "shared_control_grant_state_class": {
      "type": "string",
      "enum": [
        "no_prior_grant",
        "prior_grant_active_at_crash",
        "prior_grant_expired_before_restart",
        "prior_grant_revoked_by_owner",
        "prior_grant_revoked_by_policy",
        "prior_grant_unrecoverable_evidence_only"
      ],
      "description": "Closed shared-control-grant-state vocabulary. Shared-control grants do not survive a restart; the row records what was true at the crash boundary so the no-auto-resume directive can name the regrant action explicitly."
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_only_default",
        "review_required_code_adjacent",
        "regulated_support_only",
        "local_only_private",
        "raw_dump_excluded"
      ],
      "description": "Re-exported verbatim from schemas/ux/restore_fidelity.schema.json#redaction_class."
    },
    "export_posture": {
      "type": "string",
      "enum": [
        "local_first_not_exported",
        "export_review_required",
        "exported_by_reference",
        "export_blocked_by_policy"
      ],
      "description": "Re-exported verbatim from schemas/ux/restore_fidelity.schema.json#export_posture."
    },
    "no_auto_resume_directive": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_auto_resume_class",
        "required_regrant_action_class",
        "summary"
      ],
      "properties": {
        "no_auto_resume_class": { "$ref": "#/$defs/no_auto_resume_class" },
        "required_regrant_action_class": { "$ref": "#/$defs/required_regrant_action_class" },
        "bound_lane_class": { "$ref": "#/$defs/shared_control_lane_class" },
        "prior_grant_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "prior_grant_revocation_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "approval_ticket_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "policy_bundle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "summary": { "$ref": "#/$defs/short_text" }
      },
      "allOf": [
        {
          "description": "approval_ticket_required directives MUST cite the approval_ticket_ref.",
          "if": {
            "properties": {
              "required_regrant_action_class": { "const": "approval_ticket_required" }
            },
            "required": ["required_regrant_action_class"]
          },
          "then": {
            "properties": {
              "approval_ticket_ref": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": ["approval_ticket_ref"]
          }
        },
        {
          "description": "policy_blocked_no_regrant directives MUST cite the policy_bundle_ref.",
          "if": {
            "properties": {
              "required_regrant_action_class": { "const": "policy_blocked_no_regrant" }
            },
            "required": ["required_regrant_action_class"]
          },
          "then": {
            "properties": {
              "policy_bundle_ref": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": ["policy_bundle_ref"]
          }
        },
        {
          "description": "Every shared-control no_auto_resume_class except presenter_grant_active_authority MUST name the bound_lane_class.",
          "if": {
            "properties": {
              "no_auto_resume_class": {
                "enum": [
                  "shared_terminal_control",
                  "shared_debugger_control",
                  "shared_notebook_kernel_control",
                  "shared_runbook_control",
                  "shared_build_task_control",
                  "shared_review_admit_control",
                  "shared_editor_driver_control"
                ]
              }
            },
            "required": ["no_auto_resume_class"]
          },
          "then": {
            "required": ["bound_lane_class"]
          }
        }
      ]
    },
    "shared_control_reopen_directive": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shared_control_lane_class_restored",
        "reopen_as_class",
        "no_auto_resume_class",
        "forbidden_claim_classes",
        "summary"
      ],
      "properties": {
        "shared_control_lane_class_restored": { "$ref": "#/$defs/shared_control_lane_class" },
        "bound_pane_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "reopen_as_class": { "$ref": "#/$defs/reopen_as_class" },
        "no_auto_resume_class": { "$ref": "#/$defs/no_auto_resume_class" },
        "forbidden_claim_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/forbidden_claim_class" },
          "uniqueItems": true
        },
        "placeholder_card_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "summary": { "$ref": "#/$defs/short_text" }
      },
      "allOf": [
        {
          "description": "reopen_as_placeholder_with_explicit_regrant requires a placeholder_card_ref.",
          "if": {
            "properties": {
              "reopen_as_class": { "const": "reopen_as_placeholder_with_explicit_regrant" }
            },
            "required": ["reopen_as_class"]
          },
          "then": {
            "properties": {
              "placeholder_card_ref": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": ["placeholder_card_ref"]
          }
        }
      ]
    },
    "restored_collab_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "collab_kind_class",
        "restoration_posture_class",
        "live_authority_status_class",
        "summary"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/opaque_id" },
        "collab_kind_class": { "$ref": "#/$defs/restored_collab_kind_class" },
        "restoration_posture_class": { "$ref": "#/$defs/restoration_posture_class" },
        "live_authority_status_class": { "$ref": "#/$defs/live_authority_status_class" },
        "follow_mode_class_restored": { "$ref": "#/$defs/follow_mode_class" },
        "follow_target_kind_class_restored": { "$ref": "#/$defs/follow_target_kind_class" },
        "degraded_follow_posture_class_restored": { "$ref": "#/$defs/degraded_follow_posture_class" },
        "presenter_role_class_restored": { "$ref": "#/$defs/presenter_role_class" },
        "focus_broadcast_posture_class_restored": { "$ref": "#/$defs/focus_broadcast_posture_class" },
        "presenter_handoff_kind_class_restored": { "$ref": "#/$defs/presenter_handoff_kind_class" },
        "role_badge_class_restored": { "$ref": "#/$defs/role_badge_class" },
        "shared_cursor_visibility_class": { "$ref": "#/$defs/shared_cursor_visibility_class" },
        "speaker_note_locality_class": { "$ref": "#/$defs/speaker_note_locality_class" },
        "presenter_grant_state_class": { "$ref": "#/$defs/presenter_grant_state_class" },
        "shared_control_lane_class_restored": { "$ref": "#/$defs/shared_control_lane_class" },
        "shared_control_grant_state_class": { "$ref": "#/$defs/shared_control_grant_state_class" },
        "prior_follow_target_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "prior_presenter_state_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "prior_presenter_handoff_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "prior_control_grant_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "prior_control_grant_revocation_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "placeholder_card_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "bound_pane_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "observer_actor_label": { "$ref": "#/$defs/short_text" },
        "target_actor_label": { "$ref": "#/$defs/short_text" },
        "co_presenter_actor_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/short_text" },
          "uniqueItems": true
        },
        "observer_actor_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/short_text" },
          "uniqueItems": true
        },
        "row_forbidden_claim_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/forbidden_claim_class" },
          "uniqueItems": true
        },
        "summary": { "$ref": "#/$defs/short_text" }
      },
      "allOf": [
        {
          "description": "restored_follow_target requires follow_mode_class_restored and follow_target_kind_class_restored; degraded follow rows MUST also carry degraded_follow_posture_class_restored.",
          "if": {
            "properties": {
              "collab_kind_class": { "const": "restored_follow_target" }
            },
            "required": ["collab_kind_class"]
          },
          "then": {
            "required": [
              "follow_mode_class_restored",
              "follow_target_kind_class_restored"
            ]
          }
        },
        {
          "description": "follow_unavailable_live_state_missing requires degraded_follow_posture_class_restored.",
          "if": {
            "properties": {
              "follow_mode_class_restored": { "const": "follow_unavailable_live_state_missing" }
            },
            "required": ["follow_mode_class_restored"]
          },
          "then": {
            "required": ["degraded_follow_posture_class_restored"]
          }
        },
        {
          "description": "restored_presenter_state requires presenter_role_class_restored and focus_broadcast_posture_class_restored.",
          "if": {
            "properties": {
              "collab_kind_class": { "const": "restored_presenter_state" }
            },
            "required": ["collab_kind_class"]
          },
          "then": {
            "required": [
              "presenter_role_class_restored",
              "focus_broadcast_posture_class_restored"
            ]
          }
        },
        {
          "description": "restored_presenter_handoff_history requires presenter_handoff_kind_class_restored and prior_presenter_handoff_ref.",
          "if": {
            "properties": {
              "collab_kind_class": { "const": "restored_presenter_handoff_history" }
            },
            "required": ["collab_kind_class"]
          },
          "then": {
            "required": [
              "presenter_handoff_kind_class_restored",
              "prior_presenter_handoff_ref"
            ]
          }
        },
        {
          "description": "restored_role_badge requires role_badge_class_restored.",
          "if": {
            "properties": {
              "collab_kind_class": { "const": "restored_role_badge" }
            },
            "required": ["collab_kind_class"]
          },
          "then": {
            "required": ["role_badge_class_restored"]
          }
        },
        {
          "description": "restored_shared_cursor_visibility requires shared_cursor_visibility_class.",
          "if": {
            "properties": {
              "collab_kind_class": { "const": "restored_shared_cursor_visibility" }
            },
            "required": ["collab_kind_class"]
          },
          "then": {
            "required": ["shared_cursor_visibility_class"]
          }
        },
        {
          "description": "restored_speaker_note_locality requires speaker_note_locality_class.",
          "if": {
            "properties": {
              "collab_kind_class": { "const": "restored_speaker_note_locality" }
            },
            "required": ["collab_kind_class"]
          },
          "then": {
            "required": ["speaker_note_locality_class"]
          }
        },
        {
          "description": "restored_presenter_grant_state requires presenter_grant_state_class.",
          "if": {
            "properties": {
              "collab_kind_class": { "const": "restored_presenter_grant_state" }
            },
            "required": ["collab_kind_class"]
          },
          "then": {
            "required": ["presenter_grant_state_class"]
          }
        },
        {
          "description": "Every restored_shared_*_control_grant_state row requires shared_control_lane_class_restored and shared_control_grant_state_class.",
          "if": {
            "properties": {
              "collab_kind_class": {
                "enum": [
                  "restored_shared_terminal_control_grant_state",
                  "restored_shared_debugger_control_grant_state",
                  "restored_shared_notebook_kernel_control_grant_state",
                  "restored_shared_runbook_control_grant_state",
                  "restored_shared_review_comment_grant_state"
                ]
              }
            },
            "required": ["collab_kind_class"]
          },
          "then": {
            "required": [
              "shared_control_lane_class_restored",
              "shared_control_grant_state_class"
            ],
            "properties": {
              "live_authority_status_class": {
                "enum": [
                  "not_live_explicit_regrant_required",
                  "not_live_grant_revoked_evidence_only",
                  "unrecoverable_collaboration_authority_evidence_only"
                ]
              }
            }
          }
        },
        {
          "description": "Shared-control grant rows pin their lane class to the matching collab kind.",
          "if": {
            "properties": {
              "collab_kind_class": { "const": "restored_shared_terminal_control_grant_state" }
            },
            "required": ["collab_kind_class"]
          },
          "then": {
            "properties": {
              "shared_control_lane_class_restored": { "const": "shared_terminal_lane" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "collab_kind_class": { "const": "restored_shared_debugger_control_grant_state" }
            },
            "required": ["collab_kind_class"]
          },
          "then": {
            "properties": {
              "shared_control_lane_class_restored": { "const": "shared_debugger_lane" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "collab_kind_class": { "const": "restored_shared_notebook_kernel_control_grant_state" }
            },
            "required": ["collab_kind_class"]
          },
          "then": {
            "properties": {
              "shared_control_lane_class_restored": { "const": "shared_notebook_kernel_lane" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "collab_kind_class": { "const": "restored_shared_runbook_control_grant_state" }
            },
            "required": ["collab_kind_class"]
          },
          "then": {
            "properties": {
              "shared_control_lane_class_restored": { "const": "shared_runbook_lane" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "collab_kind_class": { "const": "restored_shared_review_comment_grant_state" }
            },
            "required": ["collab_kind_class"]
          },
          "then": {
            "properties": {
              "shared_control_lane_class_restored": { "const": "shared_review_comment_lane" }
            }
          }
        },
        {
          "description": "restored_presenter_grant_state pairs with a non-live authority status; live presenter authority never survives a restart.",
          "if": {
            "properties": {
              "collab_kind_class": { "const": "restored_presenter_grant_state" }
            },
            "required": ["collab_kind_class"]
          },
          "then": {
            "properties": {
              "live_authority_status_class": {
                "enum": [
                  "not_live_explicit_regrant_required",
                  "not_live_grant_revoked_evidence_only",
                  "unrecoverable_collaboration_authority_evidence_only",
                  "not_live_no_grant"
                ]
              }
            }
          }
        },
        {
          "description": "restoration_posture_class restored_as_placeholder_pending_session_rejoin requires a non-null placeholder_card_ref.",
          "if": {
            "properties": {
              "restoration_posture_class": { "const": "restored_as_placeholder_pending_session_rejoin" }
            },
            "required": ["restoration_posture_class"]
          },
          "then": {
            "required": ["placeholder_card_ref"],
            "properties": {
              "placeholder_card_ref": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "description": "restoration_posture_class degraded_grant_revoked requires a non-null prior_control_grant_revocation_ref.",
          "if": {
            "properties": {
              "restoration_posture_class": { "const": "degraded_grant_revoked" }
            },
            "required": ["restoration_posture_class"]
          },
          "then": {
            "required": ["prior_control_grant_revocation_ref"],
            "properties": {
              "prior_control_grant_revocation_ref": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "description": "Posture / authority pairing — restored_as_local_context_only pairs with not_live_no_grant or not_live_explicit_regrant_required.",
          "if": {
            "properties": {
              "restoration_posture_class": { "const": "restored_as_local_context_only" }
            },
            "required": ["restoration_posture_class"]
          },
          "then": {
            "properties": {
              "live_authority_status_class": {
                "enum": [
                  "not_live_no_grant",
                  "not_live_explicit_regrant_required"
                ]
              }
            }
          }
        },
        {
          "description": "restored_as_placeholder_pending_session_rejoin pairs with not_live_explicit_regrant_required.",
          "if": {
            "properties": {
              "restoration_posture_class": { "const": "restored_as_placeholder_pending_session_rejoin" }
            },
            "required": ["restoration_posture_class"]
          },
          "then": {
            "properties": {
              "live_authority_status_class": { "const": "not_live_explicit_regrant_required" }
            }
          }
        },
        {
          "description": "degraded_session_expired pairs with not_live_grant_revoked_evidence_only or unrecoverable_collaboration_authority_evidence_only.",
          "if": {
            "properties": {
              "restoration_posture_class": { "const": "degraded_session_expired" }
            },
            "required": ["restoration_posture_class"]
          },
          "then": {
            "properties": {
              "live_authority_status_class": {
                "enum": [
                  "not_live_grant_revoked_evidence_only",
                  "unrecoverable_collaboration_authority_evidence_only"
                ]
              }
            }
          }
        },
        {
          "description": "degraded_collaborator_missing pairs with not_live_no_grant or not_live_explicit_regrant_required.",
          "if": {
            "properties": {
              "restoration_posture_class": { "const": "degraded_collaborator_missing" }
            },
            "required": ["restoration_posture_class"]
          },
          "then": {
            "properties": {
              "live_authority_status_class": {
                "enum": [
                  "not_live_no_grant",
                  "not_live_explicit_regrant_required"
                ]
              }
            }
          }
        },
        {
          "description": "degraded_grant_revoked pairs with not_live_grant_revoked_evidence_only or unrecoverable_collaboration_authority_evidence_only.",
          "if": {
            "properties": {
              "restoration_posture_class": { "const": "degraded_grant_revoked" }
            },
            "required": ["restoration_posture_class"]
          },
          "then": {
            "properties": {
              "live_authority_status_class": {
                "enum": [
                  "not_live_grant_revoked_evidence_only",
                  "unrecoverable_collaboration_authority_evidence_only"
                ]
              }
            }
          }
        },
        {
          "description": "degraded_authority_unrecoverable_evidence_only pairs with unrecoverable_collaboration_authority_evidence_only.",
          "if": {
            "properties": {
              "restoration_posture_class": { "const": "degraded_authority_unrecoverable_evidence_only" }
            },
            "required": ["restoration_posture_class"]
          },
          "then": {
            "properties": {
              "live_authority_status_class": { "const": "unrecoverable_collaboration_authority_evidence_only" }
            }
          }
        },
        {
          "description": "bypassed_no_collab_state_to_restore pairs with not_live_no_grant.",
          "if": {
            "properties": {
              "restoration_posture_class": { "const": "bypassed_no_collab_state_to_restore" }
            },
            "required": ["restoration_posture_class"]
          },
          "then": {
            "properties": {
              "live_authority_status_class": { "const": "not_live_no_grant" }
            }
          }
        }
      ]
    },
    "export_lane_classification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_restored_context_lane_visible",
        "live_shared_state_inferable",
        "requires_explicit_regrant_lane_present",
        "unrecoverable_collaboration_authority_lane_present",
        "evidence_only_lane_present",
        "redaction_class",
        "export_posture",
        "summary"
      ],
      "properties": {
        "local_restored_context_lane_visible": { "type": "boolean" },
        "live_shared_state_inferable": {
          "type": "boolean",
          "const": false,
          "description": "Const false. No row in this contract may imply live shared state. Surfaces that emit true are non-conforming."
        },
        "requires_explicit_regrant_lane_present": { "type": "boolean" },
        "unrecoverable_collaboration_authority_lane_present": { "type": "boolean" },
        "evidence_only_lane_present": { "type": "boolean" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "export_posture": { "$ref": "#/$defs/export_posture" },
        "summary": { "$ref": "#/$defs/short_text" }
      }
    },
    "packet_export_linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "restore_chooser_state_ref",
        "window_topology_snapshot_ref",
        "workspace_authority_checkpoint_ref",
        "recovery_ladder_packet_ref",
        "docs_help_label"
      ],
      "properties": {
        "prior_collaboration_session_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "restore_chooser_state_ref": { "$ref": "#/$defs/opaque_id" },
        "recovery_level_class_ref": { "$ref": "#/$defs/recovery_level_class" },
        "restore_provenance_record_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "window_topology_snapshot_ref": { "$ref": "#/$defs/opaque_id" },
        "workspace_authority_checkpoint_ref": { "$ref": "#/$defs/opaque_id" },
        "hydration_phase_session_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "recovery_ladder_packet_ref": { "$ref": "#/$defs/opaque_id" },
        "support_bundle_candidate_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "release_evidence_packet_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "prior_follow_target_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "prior_presenter_state_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "prior_presenter_handoff_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "prior_control_grant_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "prior_control_grant_revocation_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "approval_ticket_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "policy_bundle_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "docs_help_label": { "$ref": "#/$defs/short_text" }
      }
    },
    "accessibility_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "keyboard_reachable_actions",
        "screen_reader_summary"
      ],
      "properties": {
        "keyboard_reachable_actions": {
          "type": "boolean",
          "const": true,
          "description": "Const guarantee that any restored-collab chip / banner / placeholder card the shell renders is keyboard-reachable; restoration posture is not buried behind hover-only tooltips."
        },
        "focus_target_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "screen_reader_summary": { "$ref": "#/$defs/short_text" }
      }
    },
    "honesty_invariants": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collab_kind_vocabulary_is_closed",
        "live_authority_never_inferred_from_restore",
        "no_auto_resume_for_shared_control",
        "forbidden_claims_typed",
        "linkage_is_typed",
        "presence_does_not_imply_control"
      ],
      "properties": {
        "collab_kind_vocabulary_is_closed": {
          "type": "boolean",
          "const": true,
          "description": "Const guarantee that every restored row resolves to exactly one of the twelve closed kinds."
        },
        "live_authority_never_inferred_from_restore": {
          "type": "boolean",
          "const": true,
          "description": "Const guarantee that every row cites a not_live_* or unrecoverable_* authority status; this contract mints no live class."
        },
        "no_auto_resume_for_shared_control": {
          "type": "boolean",
          "const": true,
          "description": "Const guarantee that every record carrying a restored_shared_*_control_grant_state row also carries a matching no_auto_resume_directive; presenter grant active authority pairs with the presenter_grant_active_authority directive."
        },
        "forbidden_claims_typed": {
          "type": "boolean",
          "const": true,
          "description": "Const guarantee that the record's forbidden_claims[] carries at least one closed-vocabulary entry."
        },
        "linkage_is_typed": {
          "type": "boolean",
          "const": true,
          "description": "Const guarantee that packet/export linkage refs are typed; free-text linkage prose is non-conforming."
        },
        "presence_does_not_imply_control": {
          "type": "boolean",
          "const": true,
          "description": "Const guarantee that a restored presenter or follow row never implies live shared-control authority; shared-control authority is never inferable from presence or presenter state."
        }
      }
    },
    "restored_collab_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "restored_collab_state_schema_version",
        "restored_collab_state_id",
        "emitted_at",
        "surface_family",
        "restored_rows",
        "no_auto_resume_directives",
        "shared_control_reopen_postures",
        "export_lane_classification",
        "forbidden_claims",
        "packet_export_linkage",
        "accessibility_contract",
        "honesty_invariants"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "restored_collab_state_schema_version": { "$ref": "#/$defs/restored_collab_state_schema_version" },
        "restored_collab_state_id": { "$ref": "#/$defs/opaque_id" },
        "emitted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "startup_state_ref": { "$ref": "#/$defs/startup_state_token" },
        "restored_rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/restored_collab_row" },
          "description": "Ordered list of restored-collab rows. At least one row per record; bypass scopes emit a single row with restoration_posture_class bypassed_no_collab_state_to_restore."
        },
        "no_auto_resume_directives": {
          "type": "array",
          "items": { "$ref": "#/$defs/no_auto_resume_directive" },
          "description": "Typed no-auto-resume directives, one per shared-control authority that was visible prior to the crash. Required to be non-empty whenever the record carries a restored_shared_*_control_grant_state row or a restored_presenter_grant_state row whose presenter_grant_state_class is prior_presenter_grant_active_at_crash."
        },
        "shared_control_reopen_postures": {
          "type": "array",
          "items": { "$ref": "#/$defs/shared_control_reopen_directive" },
          "description": "Typed reopen postures for shared-control surfaces. Required to be non-empty whenever the record carries a restored_shared_*_control_grant_state row."
        },
        "export_lane_classification": { "$ref": "#/$defs/export_lane_classification" },
        "forbidden_claims": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/forbidden_claim_class" },
          "uniqueItems": true,
          "description": "Closed-vocabulary list. At least one entry per record."
        },
        "packet_export_linkage": { "$ref": "#/$defs/packet_export_linkage" },
        "accessibility_contract": { "$ref": "#/$defs/accessibility_contract" },
        "honesty_invariants": { "$ref": "#/$defs/honesty_invariants" }
      },
      "allOf": [
        {
          "description": "Records carrying any restored_shared_*_control_grant_state row MUST also carry at least one no_auto_resume_directive AND at least one shared_control_reopen_directive.",
          "if": {
            "properties": {
              "restored_rows": {
                "type": "array",
                "contains": {
                  "properties": {
                    "collab_kind_class": {
                      "enum": [
                        "restored_shared_terminal_control_grant_state",
                        "restored_shared_debugger_control_grant_state",
                        "restored_shared_notebook_kernel_control_grant_state",
                        "restored_shared_runbook_control_grant_state",
                        "restored_shared_review_comment_grant_state"
                      ]
                    }
                  },
                  "required": ["collab_kind_class"]
                }
              }
            },
            "required": ["restored_rows"]
          },
          "then": {
            "properties": {
              "no_auto_resume_directives": {
                "type": "array",
                "minItems": 1
              },
              "shared_control_reopen_postures": {
                "type": "array",
                "minItems": 1
              }
            },
            "required": ["no_auto_resume_directives", "shared_control_reopen_postures"]
          }
        },
        {
          "description": "Records whose presenter grant state row was active at crash MUST carry a presenter_grant_active_authority no-auto-resume directive.",
          "if": {
            "properties": {
              "restored_rows": {
                "type": "array",
                "contains": {
                  "properties": {
                    "collab_kind_class": { "const": "restored_presenter_grant_state" },
                    "presenter_grant_state_class": { "const": "prior_presenter_grant_active_at_crash" }
                  },
                  "required": ["collab_kind_class", "presenter_grant_state_class"]
                }
              }
            },
            "required": ["restored_rows"]
          },
          "then": {
            "properties": {
              "no_auto_resume_directives": {
                "type": "array",
                "contains": {
                  "properties": {
                    "no_auto_resume_class": { "const": "presenter_grant_active_authority" }
                  },
                  "required": ["no_auto_resume_class"]
                }
              }
            },
            "required": ["no_auto_resume_directives"]
          }
        }
      ]
    }
  }
}
