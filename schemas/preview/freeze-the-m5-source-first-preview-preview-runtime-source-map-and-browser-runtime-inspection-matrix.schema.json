{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/preview/freeze-the-m5-source-first-preview-preview-runtime-source-map-and-browser-runtime-inspection-matrix.schema.json",
  "title": "Aureline M5 source-first preview, preview-runtime, source-map, and browser-runtime inspection matrix",
  "description": "Export-safe matrix binding every claimed M5 preview/runtime surface to its preview-session class, source-sync state, target kind, mapping-quality class, browser-runtime attach depth, and round-trip capability. The matrix reuses the frozen preview target-kind and source-mapping-quality vocabularies and adds the matrix-level session, source-sync, attach-depth, and round-trip vocabularies it owns. A claimed row that cannot identify its source-sync state, target kind, or mapping-quality class auto-narrows to an effective qualification strictly below its claim, with a recorded narrowing trigger and a precise degraded label. Source remains canonical and the preview is derivative; runtime-backed inspection never masquerades as saved source state; inspect-only rows never auto-upgrade into write-capable designer flows; and write-capable visual edits preview the real source diff before commit. Raw URLs, hostnames, cookies, raw provider payloads, credentials, and raw runtime handles never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "matrix_label",
    "rows",
    "guardrails",
    "consumer_projection",
    "evidence_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "freeze_the_m5_source_first_preview_runtime_source_map_and_browser_runtime_inspection_matrix"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "matrix_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/preview_inspection_row"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "evidence_freshness": {
      "$ref": "#/$defs/evidence_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "preview_surface": {
      "type": "string",
      "enum": [
        "source_first_framework_preview",
        "visual_surface_mapping",
        "browser_runtime_inspection",
        "device_or_simulator_preview",
        "full_stack_preview_loop",
        "embedded_webview_preview",
        "visual_edit_transform",
        "support_export_projection"
      ]
    },
    "preview_session_class": {
      "type": "string",
      "enum": [
        "source_bound_live_preview",
        "runtime_backed_inspection",
        "snapshot_projection",
        "device_tethered_session",
        "embedded_renderer_session",
        "external_handoff_session"
      ]
    },
    "source_sync_class": {
      "type": "string",
      "enum": [
        "in_sync_from_source",
        "pending_rebuild",
        "drifted_from_source",
        "runtime_only_no_source",
        "unidentified_source_sync"
      ]
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "viewport_preset_only",
        "design_renderer_target",
        "simulator_target",
        "physical_device_target",
        "browser_tab_target",
        "embedded_webview_target",
        "remote_preview_target"
      ]
    },
    "mapping_quality_class": {
      "type": "string",
      "enum": [
        "exact",
        "heuristic",
        "stale",
        "partial",
        "unavailable"
      ]
    },
    "attach_depth_class": {
      "type": "string",
      "enum": [
        "no_attach",
        "dom_only",
        "dom_and_styles",
        "dom_styles_network",
        "dom_styles_network_storage",
        "not_applicable_non_browser"
      ]
    },
    "round_trip_capability_class": {
      "type": "string",
      "enum": [
        "exact_source_round_trip",
        "approximate_source_round_trip",
        "inspect_only_no_write",
        "source_only_fallback",
        "no_round_trip"
      ]
    },
    "qualification_class": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "preview",
        "experimental",
        "held",
        "unavailable"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "unidentified_source_sync",
        "unidentified_target_kind",
        "unidentified_mapping_quality",
        "inspect_only_scope",
        "cross_origin_blocked",
        "runtime_only_no_source",
        "policy_narrowed",
        "upstream_dependency_narrowed"
      ]
    },
    "preview_inspection_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "surface",
        "label_summary",
        "preview_session_class",
        "source_sync_class",
        "attach_depth_class",
        "round_trip_capability",
        "claimed_qualification",
        "effective_qualification",
        "runtime_backed",
        "claims_saved_source",
        "write_capable",
        "previews_source_diff_before_commit",
        "evidence_refs",
        "source_contract_refs"
      ],
      "properties": {
        "row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface": {
          "$ref": "#/$defs/preview_surface"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preview_session_class": {
          "$ref": "#/$defs/preview_session_class"
        },
        "source_sync_class": {
          "$ref": "#/$defs/source_sync_class"
        },
        "target_kind": {
          "$ref": "#/$defs/target_kind"
        },
        "mapping_quality": {
          "$ref": "#/$defs/mapping_quality_class"
        },
        "attach_depth_class": {
          "$ref": "#/$defs/attach_depth_class"
        },
        "round_trip_capability": {
          "$ref": "#/$defs/round_trip_capability_class"
        },
        "claimed_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "effective_qualification": {
          "$ref": "#/$defs/qualification_class"
        },
        "runtime_backed": {
          "type": "boolean"
        },
        "claims_saved_source": {
          "type": "boolean"
        },
        "write_capable": {
          "type": "boolean"
        },
        "previews_source_diff_before_commit": {
          "type": "boolean"
        },
        "narrow_trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "degraded_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_canonical_preview_derivative",
        "runtime_inspection_never_masquerades_as_source",
        "mapping_uncertainty_never_hidden",
        "inspect_only_never_auto_upgraded_to_write",
        "visual_edits_preview_source_diff_before_commit",
        "embedded_boundaries_not_blurred_into_product",
        "rows_auto_narrow_on_unidentified_dimension"
      ],
      "properties": {
        "source_canonical_preview_derivative": {
          "type": "boolean"
        },
        "runtime_inspection_never_masquerades_as_source": {
          "type": "boolean"
        },
        "mapping_uncertainty_never_hidden": {
          "type": "boolean"
        },
        "inspect_only_never_auto_upgraded_to_write": {
          "type": "boolean"
        },
        "visual_edits_preview_source_diff_before_commit": {
          "type": "boolean"
        },
        "embedded_boundaries_not_blurred_into_product": {
          "type": "boolean"
        },
        "rows_auto_narrow_on_unidentified_dimension": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_matrix",
        "docs_help_ingests_matrix",
        "diagnostics_ingests_matrix",
        "extension_provider_conformance_ingests_matrix",
        "release_control_ingests_matrix",
        "narrowed_rows_labeled_below_current"
      ],
      "properties": {
        "product_ingests_matrix": {
          "type": "boolean"
        },
        "docs_help_ingests_matrix": {
          "type": "boolean"
        },
        "diagnostics_ingests_matrix": {
          "type": "boolean"
        },
        "extension_provider_conformance_ingests_matrix": {
          "type": "boolean"
        },
        "release_control_ingests_matrix": {
          "type": "boolean"
        },
        "narrowed_rows_labeled_below_current": {
          "type": "boolean"
        }
      }
    },
    "evidence_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_freshness_slo_hours",
        "last_evidence_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "evidence_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_evidence_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
