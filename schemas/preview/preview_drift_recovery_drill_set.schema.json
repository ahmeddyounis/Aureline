{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/preview/preview_drift_recovery_drill_set.schema.json",
  "title": "Aureline M5 preview drift-recovery drill set",
  "description": "Export-safe set of drift-and-recovery drills for the claimed M5 preview lanes. Each drill captures a before/after truth snapshot across a real preview failure (hot-reload reset, stale source map, lost dev server, device reconnect, expired browser session, replaced runtime, or data-posture flip) and proves the session fails honestly: it never silently swaps the target it was bound to, a stale-source-map drift cannot keep claiming an exact mapping, a lost dev server or expired session can no longer claim a live runtime, a data-posture flip actually changes the governed data chip, and every degraded post-drift state records a downgrade trigger plus a precise non-generic degraded label that survives reopen and export. The drill reuses the frozen source-sync, data-posture, freshness, consumer-surface, target, device-capability, runtime-origin, and source-mapping-quality vocabularies rather than minting synonyms, and adds the transition-level drift-event, recovery-route, and drift-trigger vocabularies. Source remains canonical; the drill is derivative and never a second writable truth model. Raw URLs, hostnames, cookies, raw provider payloads, credentials, and raw runtime handles never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "set_label",
    "drills",
    "guardrails",
    "consumer_projection",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "preview_drift_recovery_drill_set"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "set_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "drills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/drill"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "drift_event_class": {
      "type": "string",
      "enum": [
        "hot_reload_reset",
        "stale_source_map",
        "dev_server_lost",
        "device_reconnect",
        "browser_session_expired",
        "runtime_replaced",
        "data_posture_flip"
      ]
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "framework_pack_preview",
        "preview_route",
        "notebook_adjacent_preview",
        "support_export_projection"
      ]
    },
    "source_sync_class": {
      "type": "string",
      "enum": [
        "in_sync_from_source",
        "pending_rebuild",
        "drifted_from_source",
        "runtime_only_no_source",
        "unidentified_source_sync"
      ]
    },
    "data_posture_class": {
      "type": "string",
      "enum": [
        "live",
        "mock",
        "captured",
        "unidentified"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "fresh",
        "aging",
        "stale",
        "unknown"
      ]
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "viewport_preset_only",
        "design_renderer_target",
        "simulator_target",
        "physical_device_target",
        "browser_tab_target",
        "embedded_webview_target",
        "remote_preview_target"
      ]
    },
    "device_capability_class": {
      "type": "string",
      "enum": [
        "desktop_default",
        "touch",
        "mobile",
        "tablet",
        "wearable",
        "television",
        "high_dpi",
        "low_resource",
        "reduced_capability",
        "not_applicable"
      ]
    },
    "source_mapping_quality_class": {
      "type": "string",
      "enum": [
        "exact",
        "heuristic",
        "stale",
        "partial",
        "unavailable"
      ]
    },
    "runtime_origin_class": {
      "type": "string",
      "enum": [
        "local_dev_server",
        "remote_or_container_runtime",
        "managed_preview_service",
        "embedded_renderer",
        "imported_or_static_evidence"
      ]
    },
    "recovery_route": {
      "type": "string",
      "enum": [
        "reconnect_same_runtime",
        "restart_runtime",
        "rebuild_then_reload",
        "remap_source_then_reload",
        "reattach_device_session",
        "reimport_capture_snapshot",
        "hold_inspect_only_until_remapped",
        "open_canonical_source",
        "export_metadata_only"
      ]
    },
    "drift_recovery_trigger": {
      "type": "string",
      "enum": [
        "reconnect_required",
        "runtime_unavailable",
        "source_map_stale",
        "source_map_unavailable",
        "drifted_from_source",
        "data_posture_reclassified",
        "awaiting_rebuild"
      ]
    },
    "truth_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_sync_class",
        "data_posture",
        "freshness_class",
        "target_kind",
        "device_capability_class",
        "source_mapping_quality",
        "runtime_origin_class",
        "runtime_backed",
        "reconnect_required"
      ],
      "properties": {
        "source_sync_class": {
          "$ref": "#/$defs/source_sync_class"
        },
        "data_posture": {
          "$ref": "#/$defs/data_posture_class"
        },
        "freshness_class": {
          "$ref": "#/$defs/freshness_class"
        },
        "target_kind": {
          "$ref": "#/$defs/target_kind"
        },
        "device_capability_class": {
          "$ref": "#/$defs/device_capability_class"
        },
        "source_mapping_quality": {
          "$ref": "#/$defs/source_mapping_quality_class"
        },
        "runtime_origin_class": {
          "$ref": "#/$defs/runtime_origin_class"
        },
        "runtime_backed": {
          "type": "boolean"
        },
        "reconnect_required": {
          "type": "boolean"
        }
      }
    },
    "drill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drill_id",
        "drift_event_class",
        "consumer_surface",
        "label_summary",
        "observed_at",
        "before",
        "after",
        "recovery_routes",
        "survives_reopen_export",
        "evidence_refs"
      ],
      "properties": {
        "drill_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "drift_event_class": {
          "$ref": "#/$defs/drift_event_class"
        },
        "consumer_surface": {
          "$ref": "#/$defs/consumer_surface"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "before": {
          "$ref": "#/$defs/truth_snapshot"
        },
        "after": {
          "$ref": "#/$defs/truth_snapshot"
        },
        "recovery_routes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/recovery_route"
          }
        },
        "survives_reopen_export": {
          "type": "boolean"
        },
        "downgrade_trigger": {
          "$ref": "#/$defs/drift_recovery_trigger"
        },
        "degraded_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_canonical_no_second_writable_model",
        "drift_never_silently_swaps_target",
        "runtime_state_never_hides_source_mapping_uncertainty",
        "inspect_only_never_auto_upgraded_to_write",
        "embedded_boundaries_not_blurred_into_product",
        "degraded_state_exports_truth_surviving_reopen"
      ],
      "properties": {
        "source_canonical_no_second_writable_model": {
          "type": "boolean"
        },
        "drift_never_silently_swaps_target": {
          "type": "boolean"
        },
        "runtime_state_never_hides_source_mapping_uncertainty": {
          "type": "boolean"
        },
        "inspect_only_never_auto_upgraded_to_write": {
          "type": "boolean"
        },
        "embedded_boundaries_not_blurred_into_product": {
          "type": "boolean"
        },
        "degraded_state_exports_truth_surviving_reopen": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_drills",
        "docs_help_ingests_drills",
        "diagnostics_ingests_drills",
        "support_export_ingests_drills",
        "release_control_ingests_drills",
        "degraded_state_labeled_below_current"
      ],
      "properties": {
        "product_ingests_drills": {
          "type": "boolean"
        },
        "docs_help_ingests_drills": {
          "type": "boolean"
        },
        "diagnostics_ingests_drills": {
          "type": "boolean"
        },
        "support_export_ingests_drills": {
          "type": "boolean"
        },
        "release_control_ingests_drills": {
          "type": "boolean"
        },
        "degraded_state_labeled_below_current": {
          "type": "boolean"
        }
      }
    }
  }
}
