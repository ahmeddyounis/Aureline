{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/preview/inspect_to_source_tree_mapping.schema.json",
  "title": "Aureline M5 inspect-to-source tree mapping",
  "description": "Export-safe packet of inspect-to-source tree-node mapping descriptors binding inspectable component, DOM, and widget-tree surfaces onto one shared mapping vocabulary. Each node carries a mapping-quality label (exact/approximate/generated-only/runtime-only) that is resolved and presented before any jump-to-source or mutation affordance appears, plus the continuity route that stays honest for that quality (exact jump, approximate jump with disclosure, source-only fallback, or runtime-only explanation). A runtime-only node is runtime-backed, carries no canonical source anchor, and never claims to be saved source state; only an exact or approximate (source-backed) node may offer a mutation affordance, and only when it previews the real source diff before commit; a node downgraded through a reconnect, provider loss, or mapping downgrade records a trigger and a precise non-generic degraded label and never silently re-upgrades into a source-backed mapping. Source remains canonical; the mapping packet is derivative and never a second writable truth model. Raw URLs, hostnames, cookies, raw provider payloads, credentials, raw DOM bodies, and raw runtime handles never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "set_label",
    "nodes",
    "guardrails",
    "consumer_projection",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "inspect_to_source_tree_mapping"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "set_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/inspect_node"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "tree_kind": {
      "type": "string",
      "enum": [
        "component",
        "dom_element",
        "widget_tree_node"
      ]
    },
    "mapping_quality": {
      "type": "string",
      "enum": [
        "exact",
        "approximate",
        "generated_only",
        "runtime_only"
      ]
    },
    "continuity_route": {
      "type": "string",
      "enum": [
        "exact_jump",
        "approximate_jump_with_disclosure",
        "source_only_fallback",
        "runtime_only_explanation"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "runtime_reconnect",
        "provider_loss",
        "mapping_downgraded",
        "source_drift",
        "unidentified_mapping_quality",
        "policy_narrowed",
        "upstream_dependency_narrowed"
      ]
    },
    "inspect_node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "tree_kind",
        "label_summary",
        "observed_at",
        "mapping_quality",
        "continuity_route",
        "mapping_label_resolved",
        "source_navigation_offered",
        "mutation_offered",
        "previews_source_diff_before_commit",
        "runtime_backed",
        "claims_saved_source",
        "evidence_refs"
      ],
      "properties": {
        "node_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "tree_kind": {
          "$ref": "#/$defs/tree_kind"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "mapping_quality": {
          "$ref": "#/$defs/mapping_quality"
        },
        "continuity_route": {
          "$ref": "#/$defs/continuity_route"
        },
        "mapping_label_resolved": {
          "type": "boolean"
        },
        "source_navigation_offered": {
          "type": "boolean"
        },
        "mutation_offered": {
          "type": "boolean"
        },
        "previews_source_diff_before_commit": {
          "type": "boolean"
        },
        "runtime_backed": {
          "type": "boolean"
        },
        "claims_saved_source": {
          "type": "boolean"
        },
        "source_anchor_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "downgrade_trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "degraded_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_canonical_no_second_writable_model",
        "runtime_state_never_hides_source_mapping_uncertainty",
        "inspect_only_never_auto_upgraded_to_write",
        "embedded_boundaries_not_blurred_into_product",
        "mapping_label_shown_before_navigation_or_mutation",
        "continuity_preserved_without_silent_source_upgrade"
      ],
      "properties": {
        "source_canonical_no_second_writable_model": {
          "type": "boolean"
        },
        "runtime_state_never_hides_source_mapping_uncertainty": {
          "type": "boolean"
        },
        "inspect_only_never_auto_upgraded_to_write": {
          "type": "boolean"
        },
        "embedded_boundaries_not_blurred_into_product": {
          "type": "boolean"
        },
        "mapping_label_shown_before_navigation_or_mutation": {
          "type": "boolean"
        },
        "continuity_preserved_without_silent_source_upgrade": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_nodes",
        "docs_help_ingests_nodes",
        "diagnostics_ingests_nodes",
        "support_export_ingests_nodes",
        "release_control_ingests_nodes",
        "support_export_reconstructs_mapping_quality"
      ],
      "properties": {
        "product_ingests_nodes": {
          "type": "boolean"
        },
        "docs_help_ingests_nodes": {
          "type": "boolean"
        },
        "diagnostics_ingests_nodes": {
          "type": "boolean"
        },
        "support_export_ingests_nodes": {
          "type": "boolean"
        },
        "release_control_ingests_nodes": {
          "type": "boolean"
        },
        "support_export_reconstructs_mapping_quality": {
          "type": "boolean"
        }
      }
    }
  }
}
