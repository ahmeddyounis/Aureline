{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/preview/preview_session_descriptor_set.schema.json",
  "title": "Aureline M5 preview-session descriptor set",
  "description": "Export-safe set of preview-session descriptors binding the first real M5 framework-pack, preview-route, and notebook-adjacent surfaces onto one shared packet. Each session carries source revision, runtime identity, device/viewport target, data posture (live/mock/captured), freshness, and source-sync state through governed chips, reusing the frozen preview-session and source-sync vocabularies plus the per-view origin, target, and device-capability vocabularies. Switching between live, mock, captured, or stale preview states changes governed chips and exports rather than bespoke copy: a runtime-only view never masquerades as saved source state, a captured snapshot never claims a live runtime or write capability, and a stale or downgraded session always records a downgrade trigger and a precise non-generic degraded label. Source remains canonical; the descriptor is derivative and never a second writable truth model. Raw URLs, hostnames, cookies, raw provider payloads, credentials, and raw runtime handles never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "set_label",
    "sessions",
    "guardrails",
    "consumer_projection",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "preview_session_descriptor_set"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "set_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "sessions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/preview_session_descriptor"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "consumer_surface": {
      "type": "string",
      "enum": [
        "framework_pack_preview",
        "preview_route",
        "notebook_adjacent_preview",
        "support_export_projection"
      ]
    },
    "preview_session_class": {
      "type": "string",
      "enum": [
        "source_bound_live_preview",
        "runtime_backed_inspection",
        "snapshot_projection",
        "device_tethered_session",
        "embedded_renderer_session",
        "external_handoff_session"
      ]
    },
    "source_sync_class": {
      "type": "string",
      "enum": [
        "in_sync_from_source",
        "pending_rebuild",
        "drifted_from_source",
        "runtime_only_no_source",
        "unidentified_source_sync"
      ]
    },
    "data_posture_class": {
      "type": "string",
      "enum": [
        "live",
        "mock",
        "captured",
        "unidentified"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "fresh",
        "aging",
        "stale",
        "unknown"
      ]
    },
    "runtime_origin_class": {
      "type": "string",
      "enum": [
        "local_dev_server",
        "remote_or_container_runtime",
        "managed_preview_service",
        "embedded_renderer",
        "imported_or_static_evidence"
      ]
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "viewport_preset_only",
        "design_renderer_target",
        "simulator_target",
        "physical_device_target",
        "browser_tab_target",
        "embedded_webview_target",
        "remote_preview_target"
      ]
    },
    "device_capability_class": {
      "type": "string",
      "enum": [
        "desktop_default",
        "touch",
        "mobile",
        "tablet",
        "wearable",
        "television",
        "high_dpi",
        "low_resource",
        "reduced_capability",
        "not_applicable"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "stale_freshness",
        "unknown_freshness",
        "drifted_from_source",
        "unidentified_source_sync",
        "unidentified_data_posture",
        "policy_narrowed",
        "upstream_dependency_narrowed"
      ]
    },
    "preview_session_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "consumer_surface",
        "label_summary",
        "observed_at",
        "preview_session_class",
        "source_sync_class",
        "data_posture",
        "freshness_class",
        "runtime_origin_class",
        "target_kind",
        "device_capability_class",
        "freshness_slo_seconds",
        "runtime_backed",
        "claims_saved_source",
        "write_capable",
        "previews_source_diff_before_commit",
        "evidence_refs",
        "source_contract_refs"
      ],
      "properties": {
        "session_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "consumer_surface": {
          "$ref": "#/$defs/consumer_surface"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "preview_session_class": {
          "$ref": "#/$defs/preview_session_class"
        },
        "source_sync_class": {
          "$ref": "#/$defs/source_sync_class"
        },
        "data_posture": {
          "$ref": "#/$defs/data_posture_class"
        },
        "freshness_class": {
          "$ref": "#/$defs/freshness_class"
        },
        "runtime_origin_class": {
          "$ref": "#/$defs/runtime_origin_class"
        },
        "target_kind": {
          "$ref": "#/$defs/target_kind"
        },
        "device_capability_class": {
          "$ref": "#/$defs/device_capability_class"
        },
        "source_revision_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "viewport_pixel_width": {
          "type": "integer",
          "minimum": 1
        },
        "viewport_pixel_height": {
          "type": "integer",
          "minimum": 1
        },
        "freshness_slo_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "runtime_backed": {
          "type": "boolean"
        },
        "claims_saved_source": {
          "type": "boolean"
        },
        "write_capable": {
          "type": "boolean"
        },
        "previews_source_diff_before_commit": {
          "type": "boolean"
        },
        "downgrade_trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "degraded_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "source_contract_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_canonical_no_second_writable_model",
        "runtime_state_never_hides_source_mapping_uncertainty",
        "inspect_only_never_auto_upgraded_to_write",
        "embedded_boundaries_not_blurred_into_product",
        "posture_switch_changes_governed_chips_not_bespoke_copy",
        "stale_or_downgraded_sessions_export_truth"
      ],
      "properties": {
        "source_canonical_no_second_writable_model": {
          "type": "boolean"
        },
        "runtime_state_never_hides_source_mapping_uncertainty": {
          "type": "boolean"
        },
        "inspect_only_never_auto_upgraded_to_write": {
          "type": "boolean"
        },
        "embedded_boundaries_not_blurred_into_product": {
          "type": "boolean"
        },
        "posture_switch_changes_governed_chips_not_bespoke_copy": {
          "type": "boolean"
        },
        "stale_or_downgraded_sessions_export_truth": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_sessions",
        "docs_help_ingests_sessions",
        "diagnostics_ingests_sessions",
        "support_export_ingests_sessions",
        "release_control_ingests_sessions",
        "downgraded_sessions_labeled_below_current"
      ],
      "properties": {
        "product_ingests_sessions": {
          "type": "boolean"
        },
        "docs_help_ingests_sessions": {
          "type": "boolean"
        },
        "diagnostics_ingests_sessions": {
          "type": "boolean"
        },
        "support_export_ingests_sessions": {
          "type": "boolean"
        },
        "release_control_ingests_sessions": {
          "type": "boolean"
        },
        "downgraded_sessions_labeled_below_current": {
          "type": "boolean"
        }
      }
    }
  }
}
