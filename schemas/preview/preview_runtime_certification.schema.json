{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/preview/preview_runtime_certification.schema.json",
  "title": "Aureline M5 source-first preview / browser-runtime release certification",
  "description": "Export-safe release-certification rollup that binds the source-first preview, inspect-to-source fidelity, browser-runtime inspection, round-trip honesty, drift/recovery, and provider-conformance lanes into a single auto-narrowing gate over every claimed M5 framework / preview / browser-runtime row. Each row reuses the frozen preview-surface vocabulary, lists the certification lanes release requires for that surface, and carries one lane proof per lane bound to the canonical upstream lane schema it rolls up. A claimed row whose required lanes are not all currently proven must carry an effective certification strictly below its claim, a recorded narrowing trigger, a precise degraded label, and promotion_blocked = true. Stale source maps, unlabeled runtime targets, weak provider replacement, and hidden inspect-only fallback regressions are recorded as the narrowing trigger and block promotion or visibly narrow the affected claim. A write-capable claim appears only when the round-trip-honesty lane is currently proven and the row is not narrowed. Source remains canonical; the certification packet is derivative and never a second writable truth model. Raw URLs, hostnames, cookies, raw provider payloads, credentials, and raw runtime handles never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "certification_label",
    "rows",
    "guardrails",
    "consumer_projection",
    "evidence_freshness",
    "source_contract_refs",
    "redaction_class_token",
    "minted_at"
  ],
  "properties": {
    "record_kind": {
      "const": "preview_runtime_certification"
    },
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "certification_label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/certification_row"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "consumer_projection": {
      "$ref": "#/$defs/consumer_projection"
    },
    "evidence_freshness": {
      "$ref": "#/$defs/evidence_freshness"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "redaction_class_token": {
      "$ref": "#/$defs/non_empty_string"
    },
    "minted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "surface": {
      "type": "string",
      "enum": [
        "source_first_framework_preview",
        "visual_surface_mapping",
        "browser_runtime_inspection",
        "device_or_simulator_preview",
        "full_stack_preview_loop",
        "embedded_webview_preview",
        "visual_edit_transform",
        "support_export_projection"
      ]
    },
    "certification_lane": {
      "type": "string",
      "enum": [
        "source_first_preview",
        "inspect_to_source_fidelity",
        "browser_runtime_inspection",
        "round_trip_honesty",
        "drift_recovery",
        "provider_conformance"
      ]
    },
    "lane_proof_status": {
      "type": "string",
      "enum": [
        "current",
        "stale",
        "missing",
        "not_applicable"
      ]
    },
    "certification_class": {
      "type": "string",
      "enum": [
        "certified",
        "beta",
        "preview",
        "held",
        "blocked"
      ]
    },
    "downgrade_trigger": {
      "type": "string",
      "enum": [
        "missing_lane_proof",
        "stale_lane_proof",
        "stale_source_map",
        "unlabeled_runtime_target",
        "weak_provider_replacement",
        "hidden_inspect_only_fallback",
        "upstream_lane_narrowed",
        "policy_narrowed"
      ]
    },
    "lane_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane",
        "status",
        "source_lane_ref",
        "evidence_ref"
      ],
      "properties": {
        "lane": {
          "$ref": "#/$defs/certification_lane"
        },
        "status": {
          "$ref": "#/$defs/lane_proof_status"
        },
        "source_lane_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "last_refresh": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "certification_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "surface",
        "claimed_surface_label",
        "required_lanes",
        "lane_proofs",
        "claimed_certification",
        "effective_certification",
        "promotion_blocked",
        "claims_write_capable",
        "label_summary",
        "observed_at",
        "evidence_refs",
        "source_lane_refs"
      ],
      "properties": {
        "row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface": {
          "$ref": "#/$defs/surface"
        },
        "claimed_surface_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "required_lanes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/certification_lane"
          }
        },
        "lane_proofs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/lane_proof"
          }
        },
        "claimed_certification": {
          "$ref": "#/$defs/certification_class"
        },
        "effective_certification": {
          "$ref": "#/$defs/certification_class"
        },
        "promotion_blocked": {
          "type": "boolean"
        },
        "claims_write_capable": {
          "type": "boolean"
        },
        "narrow_trigger": {
          "$ref": "#/$defs/downgrade_trigger"
        },
        "degraded_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "label_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "source_lane_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_canonical_no_second_writable_model",
        "runtime_state_never_hides_source_mapping_uncertainty",
        "inspect_only_never_auto_upgraded_to_write",
        "embedded_boundaries_not_blurred_into_product",
        "claimed_rows_auto_narrow_without_current_proof",
        "regressions_block_promotion_or_narrow",
        "single_certification_result_no_manual_clone"
      ],
      "properties": {
        "source_canonical_no_second_writable_model": {
          "type": "boolean"
        },
        "runtime_state_never_hides_source_mapping_uncertainty": {
          "type": "boolean"
        },
        "inspect_only_never_auto_upgraded_to_write": {
          "type": "boolean"
        },
        "embedded_boundaries_not_blurred_into_product": {
          "type": "boolean"
        },
        "claimed_rows_auto_narrow_without_current_proof": {
          "type": "boolean"
        },
        "regressions_block_promotion_or_narrow": {
          "type": "boolean"
        },
        "single_certification_result_no_manual_clone": {
          "type": "boolean"
        }
      }
    },
    "consumer_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ingests_certification",
        "docs_help_ingests_certification",
        "diagnostics_ingests_certification",
        "provider_conformance_ingests_certification",
        "release_control_ingests_certification",
        "narrowed_or_blocked_rows_labeled_below_current"
      ],
      "properties": {
        "product_ingests_certification": {
          "type": "boolean"
        },
        "docs_help_ingests_certification": {
          "type": "boolean"
        },
        "diagnostics_ingests_certification": {
          "type": "boolean"
        },
        "provider_conformance_ingests_certification": {
          "type": "boolean"
        },
        "release_control_ingests_certification": {
          "type": "boolean"
        },
        "narrowed_or_blocked_rows_labeled_below_current": {
          "type": "boolean"
        }
      }
    },
    "evidence_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_freshness_slo_hours",
        "last_evidence_refresh",
        "auto_narrow_on_stale"
      ],
      "properties": {
        "evidence_freshness_slo_hours": {
          "type": "integer",
          "minimum": 1
        },
        "last_evidence_refresh": {
          "type": "string",
          "format": "date-time"
        },
        "auto_narrow_on_stale": {
          "type": "boolean"
        }
      }
    }
  }
}
