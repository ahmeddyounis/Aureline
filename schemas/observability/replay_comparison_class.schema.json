{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/observability/replay_comparison_class.schema.json",
  "title": "Aureline replay and trace-bundle comparison class",
  "description": "Boundary schema for replay_comparison_class_record. The record freezes whether two replay or trace bundles are exact matches, comparable with named differences, imported external baselines, or not comparable. It carries the required UI label, required export wording, difference axes, denial reasons, import receipt posture, and claim posture so profile/replay comparisons cannot silently become benchmark or release claims.",
  "type": "object",
  "$ref": "#/$defs/replay_comparison_class_record",
  "$defs": {
    "comparison_class_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the replay comparison-class contract."
    },
    "record_kind": {
      "type": "string",
      "const": "replay_comparison_class_record"
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable ref. Raw paths, URLs, commands, payload bytes, source text, provider payloads, and secret material never appear here."
    },
    "nullable_opaque_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_ref" }
      ]
    },
    "utc_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_utc_timestamp": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/utc_timestamp" }
      ]
    },
    "comparison_class": {
      "type": "string",
      "enum": [
        "exact_same_code_data_env_hardware",
        "comparable_with_named_differences",
        "imported_external_baseline",
        "not_comparable"
      ]
    },
    "required_ui_label": {
      "type": "string",
      "enum": [
        "Exact same code, data, environment, and hardware",
        "Comparable with named differences",
        "Imported external baseline",
        "Not comparable"
      ]
    },
    "required_export_wording": {
      "type": "string",
      "enum": [
        "Compared against an exact-match bundle: code, data, environment, hardware, build, runtime, capture backend, redaction, and capture mode match.",
        "Comparable with declared differences; review listed axes before treating deltas as regressions.",
        "Imported baseline; source identity is preserved by receipt and cannot be refreshed from Aureline.",
        "Not comparable; Aureline may show bundles side by side but must not compute or publish regression claims."
      ]
    },
    "claim_posture_class": {
      "type": "string",
      "enum": [
        "blocking_regression_allowed",
        "advisory_delta_only",
        "imported_reference_only",
        "no_claim_allowed"
      ]
    },
    "difference_axis_class": {
      "type": "string",
      "enum": [
        "workload",
        "corpus",
        "code_revision",
        "data_snapshot",
        "build_identity",
        "runtime",
        "toolchain",
        "environment_fingerprint",
        "hardware_profile",
        "power_posture",
        "thermal_posture",
        "execution_location",
        "capture_backend",
        "capture_mode",
        "recording_mode",
        "sampling",
        "truncation",
        "downscope",
        "redaction",
        "symbol_linkage",
        "source_map_linkage",
        "source_availability",
        "extension_set",
        "provider_source"
      ],
      "description": "Closed axis vocabulary used when a comparison remains possible but not exact."
    },
    "denial_reason_class": {
      "type": "string",
      "enum": [
        "missing_or_mismatched_build_identity",
        "workload_or_corpus_mismatch",
        "data_snapshot_mismatch",
        "runtime_or_toolchain_mismatch",
        "environment_or_hardware_mismatch",
        "capture_backend_mismatch",
        "capture_mode_mismatch",
        "recording_mode_mismatch",
        "sampling_or_truncation_incompatible",
        "downscope_incompatible",
        "redaction_incompatible",
        "missing_symbols",
        "missing_source_map",
        "source_unavailable",
        "policy_restricted_source",
        "import_receipt_missing",
        "source_refresh_unavailable",
        "artifact_integrity_failed",
        "comparison_policy_denied"
      ],
      "description": "Closed reason vocabulary for not-comparable or claim-blocked comparisons."
    },
    "import_refresh_posture_class": {
      "type": "string",
      "enum": [
        "not_imported",
        "import_receipt_only",
        "provider_refresh_unavailable",
        "provider_refresh_available_verified",
        "external_source_unavailable"
      ]
    },
    "import_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_system_ref",
        "import_receipt_ref",
        "imported_at",
        "refresh_posture_class"
      ],
      "properties": {
        "source_system_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "import_receipt_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "imported_at": { "$ref": "#/$defs/nullable_utc_timestamp" },
        "refresh_posture_class": { "$ref": "#/$defs/import_refresh_posture_class" }
      }
    },
    "replay_comparison_class_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_class_schema_version",
        "record_kind",
        "comparison_class_id",
        "comparison_class",
        "candidate_bundle_ref",
        "baseline_bundle_ref",
        "required_ui_label",
        "required_export_wording",
        "claim_posture_class",
        "named_difference_axes",
        "comparison_denial_reasons",
        "import_context"
      ],
      "properties": {
        "comparison_class_schema_version": { "$ref": "#/$defs/comparison_class_schema_version" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "comparison_class_id": { "$ref": "#/$defs/opaque_ref" },
        "comparison_class": { "$ref": "#/$defs/comparison_class" },
        "candidate_bundle_ref": { "$ref": "#/$defs/opaque_ref" },
        "baseline_bundle_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "required_ui_label": { "$ref": "#/$defs/required_ui_label" },
        "required_export_wording": { "$ref": "#/$defs/required_export_wording" },
        "claim_posture_class": { "$ref": "#/$defs/claim_posture_class" },
        "named_difference_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/difference_axis_class" },
          "uniqueItems": true
        },
        "comparison_denial_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/denial_reason_class" },
          "uniqueItems": true
        },
        "import_context": { "$ref": "#/$defs/import_context" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "comparison_class": { "const": "exact_same_code_data_env_hardware" }
            },
            "required": ["comparison_class"]
          },
          "then": {
            "properties": {
              "required_ui_label": { "const": "Exact same code, data, environment, and hardware" },
              "required_export_wording": { "const": "Compared against an exact-match bundle: code, data, environment, hardware, build, runtime, capture backend, redaction, and capture mode match." },
              "claim_posture_class": { "const": "blocking_regression_allowed" },
              "named_difference_axes": { "maxItems": 0 },
              "comparison_denial_reasons": { "maxItems": 0 },
              "import_context": {
                "properties": {
                  "source_system_ref": { "type": "null" },
                  "import_receipt_ref": { "type": "null" },
                  "imported_at": { "type": "null" },
                  "refresh_posture_class": { "const": "not_imported" }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison_class": { "const": "comparable_with_named_differences" }
            },
            "required": ["comparison_class"]
          },
          "then": {
            "properties": {
              "required_ui_label": { "const": "Comparable with named differences" },
              "required_export_wording": { "const": "Comparable with declared differences; review listed axes before treating deltas as regressions." },
              "claim_posture_class": { "const": "advisory_delta_only" },
              "named_difference_axes": { "minItems": 1 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison_class": { "const": "imported_external_baseline" }
            },
            "required": ["comparison_class"]
          },
          "then": {
            "properties": {
              "required_ui_label": { "const": "Imported external baseline" },
              "required_export_wording": { "const": "Imported baseline; source identity is preserved by receipt and cannot be refreshed from Aureline." },
              "claim_posture_class": { "const": "imported_reference_only" },
              "named_difference_axes": { "minItems": 1 },
              "import_context": {
                "properties": {
                  "import_receipt_ref": { "$ref": "#/$defs/opaque_ref" },
                  "imported_at": { "$ref": "#/$defs/utc_timestamp" },
                  "refresh_posture_class": {
                    "not": { "const": "not_imported" }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison_class": { "const": "not_comparable" }
            },
            "required": ["comparison_class"]
          },
          "then": {
            "properties": {
              "required_ui_label": { "const": "Not comparable" },
              "required_export_wording": { "const": "Not comparable; Aureline may show bundles side by side but must not compute or publish regression claims." },
              "claim_posture_class": { "const": "no_claim_allowed" },
              "comparison_denial_reasons": { "minItems": 1 }
            }
          }
        }
      ]
    }
  }
}
