{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/observability/signal_class_example.schema.json",
  "title": "Aureline signal-class example record",
  "description": "Boundary schema for worked signal-class example fixtures under fixtures/observability/signal_class_examples/. The examples explain why coarse counters, crash artifacts, and manual support uploads do or do not require explicit preview and redaction, and how each case links to the schema registry and privacy-history vocabulary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "signal_class_example_schema_version",
    "record_kind",
    "example_id",
    "signal_class_id",
    "scenario_title",
    "default_collection_postures",
    "upload_preview_requirement",
    "allowed_payload_notes",
    "forbidden_payload_notes",
    "linkage",
    "decision_note"
  ],
  "properties": {
    "__fixture__": {
      "type": "object",
      "description": "Optional fixture annotation block; never part of the runtime record."
    },
    "signal_class_example_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "signal_class_example_record"
    },
    "example_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable example id safe to attach to docs and review discussions."
    },
    "signal_class_id": {
      "$ref": "./signal_class_matrix.schema.json#/$defs/signal_class_id"
    },
    "scenario_title": {
      "type": "string",
      "minLength": 1
    },
    "default_collection_postures": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "./signal_class_matrix.schema.json#/$defs/collection_posture"
      }
    },
    "upload_preview_requirement": {
      "$ref": "./signal_class_matrix.schema.json#/$defs/upload_preview_requirement"
    },
    "allowed_payload_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_payload_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_registry_entry_refs"],
      "properties": {
        "schema_registry_entry_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "privacy_history_event_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "support_contract_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "record_class_id_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "decision_note": {
      "type": "string",
      "minLength": 1
    }
  }
}

