{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/registry/schema_registry.schema.json",
  "title": "Aureline M1 schema-registry seed envelope",
  "description": "Boundary schema for schemas/registry/schema_registry.yaml. The envelope pins the canonical row vocabulary at schema_registry_row.schema.json, the consent-ledger registry the rows inherit broader posture from, the required family coverage, the row vocabularies (family / lifecycle / consent / posture / endpoint / redaction / consumer classes), and the named external refs the validation lane resolves. Rows themselves conform to schema_registry_row.schema.json; the envelope cannot relax that contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "matrix_id",
    "owner_dri",
    "overview_page",
    "row_schema_ref",
    "consent_ledger_registry_ref",
    "build_identity_ref",
    "validation_lane_ref",
    "family_class_vocabulary",
    "lifecycle_state_class_vocabulary",
    "consent_class_vocabulary",
    "default_posture_class_vocabulary",
    "endpoint_class_vocabulary",
    "redaction_class_vocabulary",
    "registry_consumer_class_vocabulary",
    "required_family_class_coverage",
    "rows"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": ["seeded", "stabilising", "stable"]
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "matrix_id": {
      "type": "string",
      "const": "m1_schema_registry_seed"
    },
    "owner_dri": {
      "type": "string",
      "pattern": "^@[a-zA-Z0-9_-]+$"
    },
    "overview_page": {
      "type": "string",
      "minLength": 1
    },
    "row_schema_ref": {
      "type": "string",
      "const": "schemas/registry/schema_registry_row.schema.json"
    },
    "consent_ledger_registry_ref": {
      "type": "string",
      "const": "artifacts/governance/consent_ledger_seed.yaml"
    },
    "build_identity_ref": {
      "type": "string",
      "minLength": 1
    },
    "validation_lane_ref": {
      "type": "string",
      "minLength": 1
    },
    "family_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": { "type": "string", "minLength": 1 }
    },
    "lifecycle_state_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "consent_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "default_posture_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "endpoint_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "redaction_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "registry_consumer_class_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "failure_drill_id_vocabulary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_family_class_coverage": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "telemetry_payload",
          "diagnostic_payload",
          "support_export_payload",
          "usage_export_payload"
        ]
      },
      "description": "Required family-class coverage for the M1 seed. All four payload families MUST appear with at least one row."
    },
    "rows": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "schema_registry_row.schema.json"
      }
    }
  }
}
