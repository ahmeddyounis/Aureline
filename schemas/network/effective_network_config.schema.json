{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/network/effective_network_config.schema.json",
  "title": "Aureline effective network-trust beta inspection page",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "source_matrix_ref",
    "rows",
    "support_rows",
    "defects",
    "summary"
  ],
  "properties": {
    "record_kind": {
      "const": "network_network_trust_beta_page_record"
    },
    "schema_version": {
      "$ref": "#/$defs/schema_version"
    },
    "shared_contract_ref": {
      "$ref": "#/$defs/shared_contract_ref"
    },
    "source_matrix_ref": {
      "type": "string",
      "minLength": 1
    },
    "rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/row"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "support_rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/support_row"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "defects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/defect"
      },
      "uniqueItems": true
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "network:network_trust_beta:v1"
    },
    "token": {
      "type": "string",
      "minLength": 1
    },
    "facet": {
      "type": "string",
      "enum": [
        "proxy",
        "trust_store",
        "ssh_host_proof",
        "client_certificate"
      ]
    },
    "profile": {
      "type": "string",
      "enum": [
        "connected",
        "mirror_only",
        "offline",
        "enterprise_managed"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "admin_managed_policy",
        "signed_mirror_policy",
        "user_workspace_setting",
        "process_environment",
        "platform_pac_auto_config",
        "platform_system_setting",
        "manual_signed_file_import",
        "air_gapped_signed_transfer",
        "baseline_default"
      ]
    },
    "lock_class": {
      "type": "string",
      "enum": [
        "signed_managed_policy_locked",
        "admin_policy_locked",
        "platform_locked",
        "user_editable",
        "not_applicable"
      ]
    },
    "authority": {
      "type": "string",
      "enum": [
        "effective_value_published",
        "degraded_preview_only",
        "blocked_missing_input",
        "blocked_managed_policy",
        "not_applicable"
      ]
    },
    "consumer_lane": {
      "type": "string",
      "enum": [
        "runtime",
        "extension",
        "ai",
        "provider",
        "update"
      ]
    },
    "defect_kind": {
      "type": "string",
      "enum": [
        "missing_facet_coverage",
        "missing_profile_coverage",
        "facet_token_drift",
        "source_token_drift",
        "lock_token_drift",
        "lock_inconsistent_with_source",
        "unsigned_managed_authority",
        "hidden_public_endpoint_fallback",
        "raw_secret_or_private_material_exposed",
        "missing_consumer_lane_coverage",
        "support_row_vocabulary_drift",
        "empty_effective_value_label"
      ]
    },
    "profile_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "profile_class",
        "profile_token",
        "source_class",
        "source_token",
        "lock_class",
        "lock_token",
        "authority",
        "authority_token",
        "effective_value_label",
        "source_label",
        "lock_reason",
        "managed_attribution_ref",
        "no_public_endpoint_fallback"
      ],
      "properties": {
        "record_kind": {
          "const": "network_network_trust_beta_profile_binding_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "profile_class": {
          "$ref": "#/$defs/profile"
        },
        "profile_token": {
          "$ref": "#/$defs/profile"
        },
        "source_class": {
          "$ref": "#/$defs/source_class"
        },
        "source_token": {
          "$ref": "#/$defs/source_class"
        },
        "lock_class": {
          "$ref": "#/$defs/lock_class"
        },
        "lock_token": {
          "$ref": "#/$defs/lock_class"
        },
        "authority": {
          "$ref": "#/$defs/authority"
        },
        "authority_token": {
          "$ref": "#/$defs/authority"
        },
        "effective_value_label": {
          "type": "string"
        },
        "source_label": {
          "$ref": "#/$defs/token"
        },
        "lock_reason": {
          "$ref": "#/$defs/token"
        },
        "managed_attribution_ref": {
          "type": "string"
        },
        "no_public_endpoint_fallback": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_id",
        "facet",
        "facet_token",
        "source_matrix_ref",
        "profile_bindings",
        "consumer_lanes",
        "consumer_lane_tokens",
        "support_export_summary",
        "no_public_endpoint_fallback",
        "raw_secret_or_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "const": "network_network_trust_beta_row_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "row_id": {
          "$ref": "#/$defs/token"
        },
        "facet": {
          "$ref": "#/$defs/facet"
        },
        "facet_token": {
          "$ref": "#/$defs/facet"
        },
        "source_matrix_ref": {
          "$ref": "#/$defs/token"
        },
        "profile_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/profile_binding"
          },
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true
        },
        "consumer_lanes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/consumer_lane"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "consumer_lane_tokens": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/consumer_lane"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "support_export_summary": {
          "$ref": "#/$defs/token"
        },
        "no_public_endpoint_fallback": {
          "type": "boolean",
          "const": true
        },
        "raw_secret_or_private_material_excluded": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "support_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "row_id",
        "facet_token",
        "source_tokens_by_profile",
        "lock_tokens_by_profile",
        "authority_tokens_by_profile",
        "effective_value_labels_by_profile",
        "consumer_lane_tokens",
        "support_export_summary",
        "no_public_endpoint_fallback",
        "raw_secret_or_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "const": "network_network_trust_beta_support_row_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "row_id": {
          "$ref": "#/$defs/token"
        },
        "facet_token": {
          "$ref": "#/$defs/facet"
        },
        "source_tokens_by_profile": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/source_class"
          }
        },
        "lock_tokens_by_profile": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/lock_class"
          }
        },
        "authority_tokens_by_profile": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/authority"
          }
        },
        "effective_value_labels_by_profile": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "consumer_lane_tokens": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/consumer_lane"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "support_export_summary": {
          "$ref": "#/$defs/token"
        },
        "no_public_endpoint_fallback": {
          "type": "boolean",
          "const": true
        },
        "raw_secret_or_private_material_excluded": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_kind",
        "defect_kind_token",
        "row_id",
        "facet_token",
        "profile_token",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": {
          "const": "network_network_trust_beta_defect_record"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "shared_contract_ref": {
          "$ref": "#/$defs/shared_contract_ref"
        },
        "defect_kind": {
          "$ref": "#/$defs/defect_kind"
        },
        "defect_kind_token": {
          "$ref": "#/$defs/defect_kind"
        },
        "row_id": {
          "$ref": "#/$defs/token"
        },
        "facet_token": {
          "type": "string",
          "minLength": 1
        },
        "profile_token": {
          "type": "string",
          "minLength": 1
        },
        "field": {
          "$ref": "#/$defs/token"
        },
        "note": {
          "$ref": "#/$defs/token"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_record_kind",
        "record_kind",
        "row_count",
        "support_row_count",
        "facets_present",
        "profiles_present",
        "source_tokens_present",
        "lock_tokens_present",
        "consumer_lane_tokens_present",
        "effective_value_published_count",
        "blocked_binding_count",
        "defect_count",
        "defect_counts_by_kind"
      ],
      "properties": {
        "page_record_kind": {
          "const": "network_network_trust_beta_page_record"
        },
        "record_kind": {
          "const": "network_network_trust_beta_summary_record"
        },
        "row_count": {
          "type": "integer",
          "minimum": 0
        },
        "support_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "facets_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/facet"
          },
          "uniqueItems": true
        },
        "profiles_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/profile"
          },
          "uniqueItems": true
        },
        "source_tokens_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_class"
          },
          "uniqueItems": true
        },
        "lock_tokens_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lock_class"
          },
          "uniqueItems": true
        },
        "consumer_lane_tokens_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/consumer_lane"
          },
          "uniqueItems": true
        },
        "effective_value_published_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_binding_count": {
          "type": "integer",
          "minimum": 0
        },
        "defect_count": {
          "type": "integer",
          "minimum": 0
        },
        "defect_counts_by_kind": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
