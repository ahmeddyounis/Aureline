        "deny_reason_detail": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/deny_reason_detail" }
          ]
        },
        "trust_failure_state": { "$ref": "#/$defs/trust_failure_state" },
        "offline_deferred_details": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/offline_deferred_details" }
          ]
        },
        "result_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
