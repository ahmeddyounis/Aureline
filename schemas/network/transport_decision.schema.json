      "properties": {
        "repair_hint_class": { "$ref": "#/$defs/repair_hint_class" },
        "hint_sentence": { "$ref": "#/$defs/reviewable_sentence" },
        "repair_action_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "consumer_surface_class": {
      "type": "string",
      "enum": [
        "summary_strip",
        "endpoint_row",
        "certificate_card",
        "denied_attempt_history",
        "cli_explain",
        "support_export",
        "admin_audit"
      ]
    },
    "projection_field": {
      "type": "string",
      "enum": [
        "decision_id",
        "component_class",
        "permission_class",
        "target_class",
        "origin_scope",
        "egress_class",
        "auth_mode",
        "route_class",
        "proxy_resolution_mode",
        "trust_store_source",
        "ssh_host_key_provenance",
        "client_certificate_state",
        "mirror_public_label",
        "mirror_freshness_class",
        "transport_decision_code",
        "outcome_class",
        "failure_reason",
        "trust_failure_state",
        "no_bypass_status",
        "repair_hints"
      ]
    },
    "projection_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer_surfaces",
        "summary_strip_fields",
        "endpoint_row_fields",
        "certificate_card_fields",
        "denied_attempt_history_fields"
      ],
      "properties": {
        "consumer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/consumer_surface_class" },
          "uniqueItems": true
        },
        "summary_strip_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/projection_field" },
          "uniqueItems": true
        },
        "endpoint_row_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/projection_field" },
          "uniqueItems": true
        },
        "certificate_card_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/projection_field" },
          "uniqueItems": true
        },
        "denied_attempt_history_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/projection_field" },
          "uniqueItems": true
        }
      }
    }
  }
}
