        "client_certificate_fingerprint": { "$ref": "#/$defs/nullable_opaque_fingerprint" },
        "trust_failure_state": { "$ref": "#/$defs/trust_failure_state" },
        "trust_note": { "$ref": "#/$defs/reviewable_sentence" }
