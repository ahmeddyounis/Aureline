        "public_origin_allowed": { "type": "boolean" },
        "mirror_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "deny_reason_detail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deny_reason_class",
