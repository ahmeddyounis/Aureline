      ],
      "properties": {
        "deferred_action_safe": { "type": "boolean" },
        "deferred_queue_ref": { "$ref": "#/$defs/opaque_id" },
        "retry_after_posture_ref": { "$ref": "#/$defs/opaque_id" },
        "retry_condition_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "decision_result": {
      "type": "object",
      "additionalProperties": false,
