{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/network/m5_transport_governance_certification.schema.json",
  "title": "Aureline M5 transport-governance certification packet",
  "description": "Boundary schema for the stable M5TransportGovernanceCertificationPage proof packet. The packet binds the six transport-governance lanes (transport_decision, proxy_resolution, trust_store, host_proof, mirror_offline, denial_vocabulary) into one certification verdict per named deployment profile (local_oss, self_hosted, managed, air_gapped), and auto-narrows any profile whose transport, proxy, trust, host-proof, denial-vocabulary, or mirror/offline proof is missing, stale, or partial. Raw URLs, hostnames, ports, paths, query strings, cookies, headers, bearer or session tokens, private certificate bytes, and SSH private material are excluded; only closed-vocabulary tokens, opaque refs, UTC timestamps, counts, and plain-language summary sentences cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "page_label",
    "generated_at",
    "evidence_index_ref",
    "summary",
    "dimension_bindings",
    "rows",
    "defects",
    "certification_snapshot"
  ],
  "$defs": {
    "profile_token": {
      "type": "string",
      "enum": ["local_oss", "self_hosted", "managed", "air_gapped"]
    },
    "dimension_token": {
      "type": "string",
      "enum": [
        "transport_decision",
        "proxy_resolution",
        "trust_store",
        "host_proof",
        "mirror_offline",
        "denial_vocabulary"
      ]
    },
    "state_token": {
      "type": "string",
      "enum": ["pass", "partial", "stale", "missing", "waived"]
    },
    "freshness_token": {
      "type": "string",
      "enum": ["fresh", "stale_within_window", "expired_beyond_window"]
    },
    "verdict_token": {
      "type": "string",
      "enum": ["certified", "narrowed", "held_back", "withdrawn"]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "raw_material_exposed",
        "shared_governance_bypassed",
        "non_idempotent_replay_queued",
        "silent_public_fallthrough",
        "required_profile_missing",
        "transport_proof_missing",
        "continuity_coverage_missing",
        "denial_vocabulary_missing",
        "transport_proof_stale",
        "transport_proof_partial"
      ]
    },
    "cell": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "profile",
        "profile_token",
        "dimension",
        "dimension_token",
        "state",
        "state_token",
        "freshness",
        "freshness_token",
        "evidence_contract_ref",
        "note"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_m5_transport_governance_certification_cell_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:m5_transport_governance_certification:v1"
        },
        "profile": { "$ref": "#/$defs/profile_token" },
        "profile_token": { "$ref": "#/$defs/profile_token" },
        "dimension": { "$ref": "#/$defs/dimension_token" },
        "dimension_token": { "$ref": "#/$defs/dimension_token" },
        "state": { "$ref": "#/$defs/state_token" },
        "state_token": { "$ref": "#/$defs/state_token" },
        "freshness": { "$ref": "#/$defs/freshness_token" },
        "freshness_token": { "$ref": "#/$defs/freshness_token" },
        "evidence_contract_ref": { "type": "string", "minLength": 1 },
        "note": { "type": "string" }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "dimension",
        "dimension_token",
        "dimension_label",
        "evidence_contract_ref",
        "evidence_doc_ref"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_m5_transport_governance_certification_binding_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:m5_transport_governance_certification:v1"
        },
        "dimension": { "$ref": "#/$defs/dimension_token" },
        "dimension_token": { "$ref": "#/$defs/dimension_token" },
        "dimension_label": { "type": "string", "minLength": 1 },
        "evidence_contract_ref": { "type": "string", "minLength": 1 },
        "evidence_doc_ref": { "type": "string", "minLength": 1 }
      }
    },
    "profile_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "profile",
        "profile_token",
        "profile_label",
        "cells",
        "raw_private_material_excluded",
        "no_bypass",
        "replay_idempotent_only",
        "no_silent_public_fallthrough"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_m5_transport_governance_certification_profile_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:m5_transport_governance_certification:v1"
        },
        "profile": { "$ref": "#/$defs/profile_token" },
        "profile_token": { "$ref": "#/$defs/profile_token" },
        "profile_label": { "type": "string", "minLength": 1 },
        "cells": {
          "type": "array",
          "items": { "$ref": "#/$defs/cell" }
        },
        "raw_private_material_excluded": { "type": "boolean" },
        "no_bypass": { "type": "boolean" },
        "replay_idempotent_only": { "type": "boolean" },
        "no_silent_public_fallthrough": { "type": "boolean" }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "profile_token",
        "profile_label",
        "verdict_token",
        "narrow_reason_token",
        "satisfied_dimension_count",
        "total_dimension_count",
        "cell_states",
        "raw_private_material_excluded",
        "no_bypass",
        "replay_idempotent_only",
        "no_silent_public_fallthrough",
        "plain_language_summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_m5_transport_governance_certification_row_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:m5_transport_governance_certification:v1"
        },
        "profile_token": { "$ref": "#/$defs/profile_token" },
        "profile_label": { "type": "string", "minLength": 1 },
        "verdict_token": { "$ref": "#/$defs/verdict_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "satisfied_dimension_count": { "type": "integer", "minimum": 0 },
        "total_dimension_count": { "type": "integer", "minimum": 0 },
        "cell_states": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/state_token" }
        },
        "raw_private_material_excluded": { "type": "boolean" },
        "no_bypass": { "type": "boolean" },
        "replay_idempotent_only": { "type": "boolean" },
        "no_silent_public_fallthrough": { "type": "boolean" },
        "plain_language_summary": { "type": "string" }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_m5_transport_governance_certification_defect_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:m5_transport_governance_certification:v1"
        },
        "defect_id": { "type": "string", "minLength": 1 },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "type": "string", "minLength": 1 },
        "note": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_count",
        "certified_row_count",
        "narrowed_row_count",
        "held_back_row_count",
        "withdrawn_row_count",
        "cell_count",
        "cell_state_counts",
        "profiles_covered",
        "dimensions_certified",
        "denial_vocabulary",
        "overall_verdict_token"
      ],
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "certified_row_count": { "type": "integer", "minimum": 0 },
        "narrowed_row_count": { "type": "integer", "minimum": 0 },
        "held_back_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "cell_count": { "type": "integer", "minimum": 0 },
        "cell_state_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "profiles_covered": {
          "type": "array",
          "items": { "$ref": "#/$defs/profile_token" }
        },
        "dimensions_certified": {
          "type": "array",
          "items": { "$ref": "#/$defs/dimension_token" }
        },
        "denial_vocabulary": {
          "type": "array",
          "items": { "type": "string" }
        },
        "overall_verdict_token": { "$ref": "#/$defs/verdict_token" }
      }
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "record_kind": {
      "type": "string",
      "const": "remote_m5_transport_governance_certification_page_record"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": {
      "type": "string",
      "const": "remote:m5_transport_governance_certification:v1"
    },
    "page_id": { "type": "string", "minLength": 1 },
    "page_label": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "evidence_index_ref": { "type": "string", "minLength": 1 },
    "summary": { "$ref": "#/$defs/summary" },
    "dimension_bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/binding" }
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/row" }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/defect" }
    },
    "certification_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profiles"],
      "properties": {
        "profiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/profile_snapshot" }
        }
      }
    }
  }
}
