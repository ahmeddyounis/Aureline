{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/network/networked_surface_mirror_offline_continuity.schema.json",
  "title": "Aureline networked-surface mirror/offline continuity packet",
  "description": "Boundary schema for the stable MirrorOfflineContinuityPage proof packet. The packet makes mirror-only, local-file-bundle, public-direct, blocked, and deferred route handling explicit across the claimed M5 artifact families (docs packs, registries, model packs, request workspaces, and companion handoffs). Each record freezes the typed route handling, the stale-mirror warning, the declared public-fallback rule, the mirror/offline behavior, and the local-core workflow that stays usable, so a mirror-only or deny-all profile can never silently fall through to the public internet and local work continues when a network action is denied or deferred. Raw mirror URLs, raw hostnames, raw ports, raw credentials, raw bearer/session tokens, raw cookie jars, raw private certificate bytes, raw SSH private material, and raw mirror bodies are excluded; only closed-vocabulary tokens, opaque handles and refs, plain-language summary sentences, and schema-version integers cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "page_label",
    "generated_at",
    "evidence_index_ref",
    "summary",
    "rows",
    "defects",
    "continuity_snapshot"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "record_kind": {
      "type": "string",
      "const": "remote_networked_surface_mirror_offline_continuity_page_record"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": {
      "type": "string",
      "const": "remote:networked_surface_mirror_offline_continuity:v1"
    },
    "page_id": { "$ref": "#/$defs/opaque_id" },
    "page_label": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
    "evidence_index_ref": { "$ref": "#/$defs/non_empty_string" },
    "summary": { "$ref": "#/$defs/continuity_summary" },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/continuity_row" }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/continuity_defect" }
    },
    "continuity_snapshot": { "$ref": "#/$defs/continuity_snapshot" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "monotonic_timestamp": { "type": "string", "format": "date-time" },
    "reviewable_sentence": { "type": "string", "minLength": 1, "maxLength": 800 },
    "opaque_ref": { "type": "string", "minLength": 1 },
    "artifact_family_token": {
      "type": "string",
      "enum": [
        "docs_pack",
        "registry",
        "model_pack",
        "request_workspace",
        "companion_handoff"
      ]
    },
    "continuity_route_token": {
      "type": "string",
      "enum": [
        "mirror_route",
        "local_file_bundle",
        "public_direct",
        "blocked",
        "deferred"
      ]
    },
    "origin_scope_token": {
      "type": "string",
      "enum": [
        "first_party",
        "third_party",
        "user_configured",
        "managed_tenant",
        "loopback_local"
      ]
    },
    "egress_class_token": {
      "type": "string",
      "enum": [
        "public_internet",
        "managed_endpoint",
        "mirror_only",
        "loopback_only",
        "air_gapped"
      ]
    },
    "mirror_offline_behavior_token": {
      "type": "string",
      "enum": [
        "mirror_first_then_deny",
        "cached_offline",
        "offline_grace",
        "deny_all",
        "local_core_only"
      ]
    },
    "stale_mirror_warning_token": {
      "type": "string",
      "enum": [
        "none",
        "stale_within_grace",
        "stale_beyond_grace",
        "mirror_root_mismatch"
      ]
    },
    "public_fallback_rule_token": {
      "type": "string",
      "enum": [
        "no_public_fallback",
        "explicit_public_direct_allowed",
        "mirror_only_no_fallback",
        "deny_all_no_fallback"
      ]
    },
    "proof_freshness_token": {
      "type": "string",
      "enum": ["fresh", "stale_within_window", "expired_beyond_window"]
    },
    "denial_reason_token": {
      "type": "string",
      "enum": [
        "",
        "policy_blocked",
        "egress_class_forbidden",
        "trust_proof_missing",
        "trust_proof_expired",
        "auth_posture_rejected",
        "proxy_unreachable",
        "mirror_root_mismatch",
        "offline_no_fallback",
        "non_idempotent_replay_rejected"
      ]
    },
    "nullable_denial_reason": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "string",
          "enum": [
            "policy_blocked",
            "egress_class_forbidden",
            "trust_proof_missing",
            "trust_proof_expired",
            "auth_posture_rejected",
            "proxy_unreachable",
            "mirror_root_mismatch",
            "offline_no_fallback",
            "non_idempotent_replay_rejected"
          ]
        }
      ]
    },
    "qualification_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "raw_private_material_exposed",
        "bypassed_shared_governance",
        "silent_public_fallback_resolved",
        "non_idempotent_replay_queued",
        "required_artifact_family_missing",
        "denial_reason_missing",
        "local_core_continuity_not_preserved",
        "trust_proof_missing",
        "proof_stale_beyond_window",
        "fallback_rule_inconsistent",
        "stale_mirror_served_beyond_grace"
      ]
    },
    "continuity_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "record_id",
        "artifact_family",
        "artifact_family_token",
        "artifact_family_label",
        "continuity_route",
        "continuity_route_token",
        "origin_scope",
        "origin_scope_token",
        "egress_class",
        "egress_class_token",
        "mirror_offline_behavior",
        "mirror_offline_behavior_token",
        "stale_mirror_warning",
        "stale_mirror_warning_token",
        "public_fallback_rule",
        "public_fallback_rule_token",
        "local_core_workflow",
        "trust_proof_ref",
        "trust_proof_freshness",
        "trust_proof_freshness_token",
        "denial_reason",
        "denial_reason_token",
        "action_is_idempotent",
        "no_silent_public_fallback",
        "local_core_continuity_preserved",
        "no_bypass",
        "summary",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_mirror_offline_continuity_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_mirror_offline_continuity:v1"
        },
        "record_id": { "$ref": "#/$defs/opaque_id" },
        "artifact_family": { "$ref": "#/$defs/artifact_family_token" },
        "artifact_family_token": { "$ref": "#/$defs/artifact_family_token" },
        "artifact_family_label": { "$ref": "#/$defs/non_empty_string" },
        "continuity_route": { "$ref": "#/$defs/continuity_route_token" },
        "continuity_route_token": { "$ref": "#/$defs/continuity_route_token" },
        "origin_scope": { "$ref": "#/$defs/origin_scope_token" },
        "origin_scope_token": { "$ref": "#/$defs/origin_scope_token" },
        "egress_class": { "$ref": "#/$defs/egress_class_token" },
        "egress_class_token": { "$ref": "#/$defs/egress_class_token" },
        "mirror_offline_behavior": {
          "$ref": "#/$defs/mirror_offline_behavior_token"
        },
        "mirror_offline_behavior_token": {
          "$ref": "#/$defs/mirror_offline_behavior_token"
        },
        "stale_mirror_warning": { "$ref": "#/$defs/stale_mirror_warning_token" },
        "stale_mirror_warning_token": {
          "$ref": "#/$defs/stale_mirror_warning_token"
        },
        "public_fallback_rule": { "$ref": "#/$defs/public_fallback_rule_token" },
        "public_fallback_rule_token": {
          "$ref": "#/$defs/public_fallback_rule_token"
        },
        "local_core_workflow": { "$ref": "#/$defs/reviewable_sentence" },
        "trust_proof_ref": { "$ref": "#/$defs/opaque_ref" },
        "trust_proof_freshness": { "$ref": "#/$defs/proof_freshness_token" },
        "trust_proof_freshness_token": {
          "$ref": "#/$defs/proof_freshness_token"
        },
        "denial_reason": { "$ref": "#/$defs/nullable_denial_reason" },
        "denial_reason_token": { "$ref": "#/$defs/denial_reason_token" },
        "action_is_idempotent": { "type": "boolean" },
        "no_silent_public_fallback": { "type": "boolean" },
        "local_core_continuity_preserved": { "type": "boolean" },
        "no_bypass": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "raw_private_material_excluded": { "type": "boolean" }
      }
    },
    "continuity_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["records"],
      "properties": {
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/continuity_record" }
        }
      }
    },
    "continuity_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "record_id",
        "artifact_family_token",
        "continuity_route_token",
        "origin_scope_token",
        "egress_class_token",
        "mirror_offline_behavior_token",
        "stale_mirror_warning_token",
        "public_fallback_rule_token",
        "denial_reason_token",
        "no_bypass",
        "no_silent_public_fallback",
        "replay_idempotent_only",
        "local_core_continuity_preserved",
        "fallback_rule_consistent",
        "proof_freshness_token",
        "raw_private_material_excluded",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_mirror_offline_continuity_row_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_mirror_offline_continuity:v1"
        },
        "record_id": { "$ref": "#/$defs/opaque_id" },
        "artifact_family_token": { "$ref": "#/$defs/artifact_family_token" },
        "continuity_route_token": { "$ref": "#/$defs/continuity_route_token" },
        "origin_scope_token": { "$ref": "#/$defs/origin_scope_token" },
        "egress_class_token": { "$ref": "#/$defs/egress_class_token" },
        "mirror_offline_behavior_token": {
          "$ref": "#/$defs/mirror_offline_behavior_token"
        },
        "stale_mirror_warning_token": {
          "$ref": "#/$defs/stale_mirror_warning_token"
        },
        "public_fallback_rule_token": {
          "$ref": "#/$defs/public_fallback_rule_token"
        },
        "denial_reason_token": { "$ref": "#/$defs/denial_reason_token" },
        "no_bypass": { "type": "boolean" },
        "no_silent_public_fallback": { "type": "boolean" },
        "replay_idempotent_only": { "type": "boolean" },
        "local_core_continuity_preserved": { "type": "boolean" },
        "fallback_rule_consistent": { "type": "boolean" },
        "proof_freshness_token": { "$ref": "#/$defs/proof_freshness_token" },
        "raw_private_material_excluded": { "type": "boolean" },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "continuity_defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_mirror_offline_continuity_defect_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_mirror_offline_continuity:v1"
        },
        "defect_id": { "$ref": "#/$defs/non_empty_string" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "continuity_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "families_covered",
        "no_bypass_count",
        "local_core_continuity_preserved_count",
        "usable_proof_count",
        "fallback_rule_consistent_count",
        "route_counts",
        "overall_qualification_token"
      ],
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "families_covered": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact_family_token" }
        },
        "no_bypass_count": { "type": "integer", "minimum": 0 },
        "local_core_continuity_preserved_count": {
          "type": "integer",
          "minimum": 0
        },
        "usable_proof_count": { "type": "integer", "minimum": 0 },
        "fallback_rule_consistent_count": { "type": "integer", "minimum": 0 },
        "route_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_token" }
      }
    }
  }
}
