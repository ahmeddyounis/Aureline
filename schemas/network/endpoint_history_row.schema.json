{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/network/endpoint_history_row.schema.json",
  "title": "Aureline transport endpoint and denied-attempt history row",
  "description": "Boundary schema for transport_endpoint_row and denied_attempt_history_row records. Endpoint rows explain one target's component, permission, egress class, target class, auth mode, mirror-vs-origin posture, last outcome, reason, repair path, and freshness. Denied-attempt history rows explain typed denials, stale mirrors, safe offline deferrals, and trust failures without raw logs or provider-specific jargon. Raw URLs, host names, IP addresses, proxy credentials, certificate material, SSH host keys, tokens, request bodies, and response bodies never cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/transport_endpoint_row" },
    { "$ref": "#/$defs/denied_attempt_history_row" }
  ],
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280,
      "description": "Short privacy-safe sentence for UI, CLI, support exports, and admin audit. Raw endpoints, hosts, URLs, payloads, and credentials must not appear."
    },
    "monotonic_timestamp": { "type": "string", "format": "date-time" },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "linked_docs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "network_component_class": {
      "type": "string",
      "enum": [
        "desktop_shell_component",
        "cli_headless_component",
        "update_client_component",
        "extension_registry_component",
        "extension_host_component",
        "ai_broker_component",
        "docs_pack_component",
        "policy_distribution_component",
        "telemetry_sink_component",
        "remote_tunnel_component",
        "remote_ssh_component",
        "remote_agent_component",
        "managed_control_plane_component",
        "git_vcs_component",
        "notebook_kernel_component",
        "debugger_symbol_component",
        "api_client_component",
        "mirror_refresh_component",
        "browser_handoff_launcher_component",
        "provider_callback_receiver_component",
        "heuristic_unknown_component"
      ]
    },
    "network_permission_class": {
      "type": "string",
      "enum": [
        "core_update",
        "registry_read",
        "registry_write",
        "ai_context_egress",
        "ai_tool_egress",
        "docs_fetch",
        "remote_connect",
        "vcs_network",
        "extension_network",
        "policy_refresh",
        "telemetry_send",
        "tunnel_publish",
        "provider_callback_inbound",
        "mirror_refresh",
        "browser_handoff_launch",
        "api_client_request"
      ]
    },
    "network_target_class": {
      "type": "string",
      "enum": [
        "local_host_target",
        "device_local_loopback_target",
        "remote_ssh_target",
        "remote_agent_target",
        "managed_workspace_target",
        "connected_provider_target",
        "system_browser_target",
        "embedded_webview_target",
        "mirror_endpoint_target",
        "private_registry_target",
        "public_registry_target",
        "ai_provider_endpoint_target",
        "docs_mirror_target",
        "policy_endpoint_target",
        "update_feed_target",
        "telemetry_sink_target",
        "tunnel_exposed_target",
        "bridged_helper_target",
        "unknown_target"
      ]
    },
    "origin_scope_class": {
      "type": "string",
      "enum": [
        "desktop_client",
        "headless_runner",
        "extension_host",
        "remote_target",
        "managed_service",
        "system_browser",
        "local_helper"
      ]
    },
    "auth_mode_class": {
      "type": "string",
      "enum": [
        "no_auth_public",
        "api_key_handle",
        "oauth_delegated_handle",
        "device_code_handle",
        "mtls_client_cert",
        "ssh_host_key_pinned",
        "system_browser_callback_token",
        "org_ca_bundle_pinned",
        "managed_service_identity",
        "step_up_authenticator_required",
        "auth_unknown"
      ]
    },
    "route_class": {
      "type": "string",
      "enum": [
        "direct_local_loopback_route",
        "direct_target_local_route",
        "system_proxy_route",
        "manual_proxy_route",
        "pac_resolved_route",
        "environment_proxy_route",
        "mirror_proxy_route",
        "managed_relay_route",
        "remote_target_originated_route",
        "browser_system_route",
        "air_gap_no_network_route",
        "heuristic_unknown_route"
      ]
    },
    "egress_class": {
      "type": "string",
      "enum": [
        "local_only",
        "target_local",
        "org_approved_external",
        "public_internet",
        "deny_all"
      ]
    },
    "proxy_resolution_mode_class": {
      "type": "string",
      "enum": [
        "system_proxy",
        "pac_proxy",
        "environment_proxy",
        "manual_proxy",
        "direct_no_proxy",
        "proxy_unknown"
      ]
    },
    "mirror_route_class": {
      "type": "string",
      "enum": [
        "no_mirror_direct_origin",
        "customer_operated_mirror_active",
        "vendor_published_mirror_active",
        "offline_bundle_derived_mirror_active",
        "mirror_only_no_direct_allowed",
        "mirror_not_applicable"
      ]
    },
    "mirror_public_label_class": {
      "type": "string",
      "enum": [
        "public_origin",
        "org_approved_origin",
        "customer_operated_mirror",
        "vendor_published_mirror",
        "offline_bundle_mirror",
        "mirror_only_no_direct",
        "local_or_target_local",
        "no_route_selected"
      ]
    },
    "outcome_class": {
      "type": "string",
      "enum": [
        "outbound_allowed_completed",
        "outbound_allowed_in_flight",
        "outbound_allowed_completed_with_warning",
        "outbound_denied_by_policy",
        "outbound_denied_by_user_setting",
        "outbound_denied_by_offline_mode",
        "outbound_denied_by_egress_class_boundary",
        "outbound_denied_by_permission_missing",
        "outbound_denied_by_trust_failure",
        "outbound_denied_by_proxy_auth_required",
        "outbound_denied_by_deny_all_profile",
        "outbound_failed_transport_error",
        "outbound_failed_host_unreachable",
        "outbound_failed_tls_verification",
        "outbound_failed_ssh_host_key_mismatch",
        "outbound_failed_unknown",
        "inbound_callback_received",
        "inbound_callback_refused"
      ]
    },
    "transport_decision_code": {
      "type": "string",
      "enum": [
        "allow",
        "allow_mirror",
        "deny_policy",
        "deny_proxy_resolution",
        "deny_trust",
        "offline_deferred",
        "stale_mirror",
        "unsupported_auth_mode"
      ]
    },
    "deny_reason_detail_class": {
      "type": "string",
      "enum": [
        "admin_policy_denied",
        "user_setting_denied",
        "offline_mode_denied",
        "air_gap_profile_denied",
        "egress_class_boundary_denied",
        "permission_not_granted",
        "permission_floor_blocked",
        "extension_permission_missing",
        "extension_network_capability_revoked",
        "approval_ticket_missing",
        "approval_ticket_expired",
        "step_up_required_not_satisfied",
        "trust_store_verification_failed",
        "org_ca_bundle_not_loaded",
        "pinned_control_plane_trust_mismatch",
        "ssh_host_key_strict_mode_rejected",
        "proxy_auth_required",
        "proxy_auth_denied",
        "proxy_unreachable",
        "deny_all_profile_enforced",
        "region_pinned_target_out_of_region",
        "freshness_floor_unmet",
        "deny_reason_unknown_requires_review"
      ]
    },
    "trust_failure_state": {
      "type": "string",
      "enum": [
        "none",
        "ca_untrusted",
        "hostname_mismatch",
        "bundle_stale",
        "pin_mismatch",
        "rotation_required",
        "ssh_host_key_unknown",
        "ssh_host_key_mismatch",
        "client_certificate_required",
        "client_certificate_expired",
        "policy_blocked"
      ]
    },
    "last_outcome_freshness_class": {
      "type": "string",
      "enum": [
        "live_recent",
        "last_known_good",
        "stale",
        "current_denied",
        "current_failed",
        "in_flight",
        "unknown_requires_review"
      ]
    },
    "history_retention_class": {
      "type": "string",
      "enum": [
        "session_recent",
        "workspace_recent",
        "support_export_selected",
        "admin_audit_retained",
        "retention_policy_unknown"
      ]
    },
    "denial_category": {
      "type": "string",
      "enum": [
        "proxy",
        "certificate",
        "policy",
        "offline",
        "auth",
        "mirror_unavailable",
        "ssh_host_proof",
        "egress",
        "deny_all",
        "unknown_requires_review"
      ]
    },
    "repair_action_class": {
      "type": "string",
      "enum": [
        "review_proxy_settings",
        "add_ca_bundle",
        "refresh_policy",
        "reauth",
        "switch_mirror",
        "refresh_mirror",
        "review_ssh_host_proof",
        "renew_client_certificate",
        "retry_current_context",
        "inspect_only_no_action"
      ]
    },
    "retry_context_class": {
      "type": "string",
      "enum": [
        "same_context_after_repair",
        "same_context_retry_now_allowed",
        "new_auth_context_required",
        "new_policy_context_required",
        "new_mirror_context_required",
        "retry_not_allowed"
      ]
    },
    "no_bypass_status_class": {
      "type": "string",
      "enum": [
        "no_bypass_enforced",
        "bypass_not_applicable",
        "published_exception_required",
        "published_exception_active",
        "no_bypass_violation_detected"
      ]
    },
    "forbidden_bypass_class": {
      "type": "string",
      "enum": [
        "silent_direct_origin_fallback",
        "insecure_tls_fallback",
        "proxy_resolution_skip",
        "cli_desktop_proxy_divergence",
        "extension_ambient_egress",
        "remote_origin_hidden",
        "public_origin_on_mirror_only_profile",
        "feature_specific_retry_under_deny_all",
        "destructive_offline_defer",
        "generic_network_error_when_typed_reason_known"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "route_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin_scope",
        "route_class",
        "proxy_resolution_mode",
        "mirror_public_label",
        "mirror_route_class",
        "public_origin_allowed",
        "route_sentence"
      ],
      "properties": {
        "origin_scope": { "$ref": "#/$defs/origin_scope_class" },
        "route_class": { "$ref": "#/$defs/route_class" },
        "proxy_resolution_mode": { "$ref": "#/$defs/proxy_resolution_mode_class" },
        "mirror_public_label": { "$ref": "#/$defs/mirror_public_label_class" },
        "mirror_route_class": { "$ref": "#/$defs/mirror_route_class" },
        "public_origin_allowed": { "type": "boolean" },
        "route_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "last_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transport_decision_code",
        "outcome_class",
        "freshness_class",
        "outcome_captured_at",
        "outcome_sentence"
      ],
      "properties": {
        "transport_decision_code": { "$ref": "#/$defs/transport_decision_code" },
        "outcome_class": { "$ref": "#/$defs/outcome_class" },
        "freshness_class": { "$ref": "#/$defs/last_outcome_freshness_class" },
        "last_success_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/monotonic_timestamp" }
          ]
        },
        "outcome_captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "outcome_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "reason_detail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "denial_category",
        "deny_reason_class",
        "trust_failure_state",
        "reason_sentence"
      ],
      "properties": {
        "denial_category": { "$ref": "#/$defs/denial_category" },
        "deny_reason_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/deny_reason_detail_class" }
          ]
        },
        "trust_failure_state": { "$ref": "#/$defs/trust_failure_state" },
        "policy_rule_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "user_setting_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "reason_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "nullable_reason_detail": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/reason_detail" }
      ]
    },
    "repair_path_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repair_action_class",
        "repair_action_ref",
        "repair_sentence",
        "retry_context_class"
      ],
      "properties": {
        "repair_action_class": { "$ref": "#/$defs/repair_action_class" },
        "repair_action_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "repair_sentence": { "$ref": "#/$defs/reviewable_sentence" },
        "retry_context_class": { "$ref": "#/$defs/retry_context_class" },
        "retry_allowed": { "type": "boolean" }
      }
    },
    "freshness_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness_class",
        "captured_at",
        "freshness_sentence"
      ],
      "properties": {
        "freshness_class": { "$ref": "#/$defs/last_outcome_freshness_class" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "stale_after_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/monotonic_timestamp" }
          ]
        },
        "freshness_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "no_bypass_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_bypass_status",
        "direct_fallback_allowed",
        "insecure_fallback_allowed",
        "forbidden_bypass_classes",
        "no_bypass_sentence"
      ],
      "properties": {
        "no_bypass_status": { "$ref": "#/$defs/no_bypass_status_class" },
        "direct_fallback_allowed": { "type": "boolean" },
        "insecure_fallback_allowed": { "type": "boolean" },
        "forbidden_bypass_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/forbidden_bypass_class" },
          "uniqueItems": true
        },
        "exception_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "no_bypass_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "transport_endpoint_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "endpoint_row_id",
        "source_decision_ref",
        "component_class",
        "permission_class",
        "egress_class",
        "target_class",
        "target_identity_ref",
        "auth_mode",
        "route_summary",
        "last_outcome",
        "reason_detail",
        "repair_path",
        "freshness",
        "no_bypass_projection",
        "redaction_class",
        "narrative_refs"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "schema_version": { "type": "integer", "const": 1 },
        "record_kind": { "type": "string", "const": "transport_endpoint_row" },
        "endpoint_row_id": { "$ref": "#/$defs/opaque_id" },
        "source_decision_ref": { "$ref": "#/$defs/opaque_id" },
        "linked_attribution_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "component_class": { "$ref": "#/$defs/network_component_class" },
        "component_instance_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "component_label": { "$ref": "#/$defs/reviewable_sentence" },
        "permission_class": { "$ref": "#/$defs/network_permission_class" },
        "permission_grant_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "egress_class": { "$ref": "#/$defs/egress_class" },
        "target_class": { "$ref": "#/$defs/network_target_class" },
        "target_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "target_scope_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "auth_mode": { "$ref": "#/$defs/auth_mode_class" },
        "auth_handle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "route_summary": { "$ref": "#/$defs/route_summary" },
        "last_outcome": { "$ref": "#/$defs/last_outcome" },
        "reason_detail": { "$ref": "#/$defs/nullable_reason_detail" },
        "repair_path": {
          "type": "array",
          "items": { "$ref": "#/$defs/repair_path_item" }
        },
        "freshness": { "$ref": "#/$defs/freshness_summary" },
        "certificate_detail_card_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "denied_attempt_history_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "no_bypass_projection": { "$ref": "#/$defs/no_bypass_projection" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "export_safe": { "type": "boolean", "default": true },
        "narrative_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "notes": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" }
      },
      "allOf": [
        {
          "description": "Denied, failed, stale, or deferred endpoint rows must carry reason_detail and at least one repair path.",
          "if": {
            "properties": {
              "last_outcome": {
                "properties": {
                  "transport_decision_code": {
                    "enum": [
                      "deny_policy",
                      "deny_proxy_resolution",
                      "deny_trust",
                      "offline_deferred",
                      "stale_mirror",
                      "unsupported_auth_mode"
                    ]
                  }
                },
                "required": ["transport_decision_code"]
              }
            },
            "required": ["last_outcome"]
          },
          "then": {
            "properties": {
              "reason_detail": { "not": { "type": "null" } },
              "repair_path": { "minItems": 1 }
            },
            "required": ["reason_detail", "repair_path"]
          }
        }
      ]
    },
    "denied_attempt_history_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "history_row_id",
        "source_decision_ref",
        "attempt_captured_at",
        "component_class",
        "permission_class",
        "egress_class",
        "target_class",
        "target_identity_ref",
        "auth_mode",
        "origin_scope",
        "route_class",
        "mirror_public_label",
        "mirror_route_class",
        "public_origin_allowed",
        "transport_decision_code",
        "outcome_class",
        "denial_category",
        "deny_reason_class",
        "trust_failure_state",
        "reason_sentence",
        "repair_path",
        "freshness",
        "history_retention_class",
        "no_bypass_projection",
        "redaction_class",
        "narrative_refs"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "schema_version": { "type": "integer", "const": 1 },
        "record_kind": { "type": "string", "const": "denied_attempt_history_row" },
        "history_row_id": { "$ref": "#/$defs/opaque_id" },
        "source_decision_ref": { "$ref": "#/$defs/opaque_id" },
        "linked_endpoint_row_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "linked_attribution_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "attempt_captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "component_class": { "$ref": "#/$defs/network_component_class" },
        "component_instance_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "permission_class": { "$ref": "#/$defs/network_permission_class" },
        "permission_grant_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "egress_class": { "$ref": "#/$defs/egress_class" },
        "target_class": { "$ref": "#/$defs/network_target_class" },
        "target_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "auth_mode": { "$ref": "#/$defs/auth_mode_class" },
        "auth_handle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "origin_scope": { "$ref": "#/$defs/origin_scope_class" },
        "route_class": { "$ref": "#/$defs/route_class" },
        "mirror_public_label": { "$ref": "#/$defs/mirror_public_label_class" },
        "mirror_route_class": { "$ref": "#/$defs/mirror_route_class" },
        "public_origin_allowed": { "type": "boolean" },
        "transport_decision_code": {
          "type": "string",
          "enum": [
            "deny_policy",
            "deny_proxy_resolution",
            "deny_trust",
            "offline_deferred",
            "stale_mirror",
            "unsupported_auth_mode"
          ]
        },
        "outcome_class": { "$ref": "#/$defs/outcome_class" },
        "denial_category": { "$ref": "#/$defs/denial_category" },
        "deny_reason_class": { "$ref": "#/$defs/deny_reason_detail_class" },
        "trust_failure_state": { "$ref": "#/$defs/trust_failure_state" },
        "policy_rule_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "user_setting_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "reason_sentence": { "$ref": "#/$defs/reviewable_sentence" },
        "repair_path": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/repair_path_item" }
        },
        "freshness": { "$ref": "#/$defs/freshness_summary" },
        "history_retention_class": { "$ref": "#/$defs/history_retention_class" },
        "no_bypass_projection": { "$ref": "#/$defs/no_bypass_projection" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "export_safe": { "type": "boolean", "default": true },
        "narrative_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "notes": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" }
      },
      "allOf": [
        {
          "description": "History rows are no-bypass projections; direct public fallback is forbidden when the decision was stale_mirror, deny_trust, or deny_policy.",
          "if": {
            "properties": {
              "transport_decision_code": {
                "enum": ["stale_mirror", "deny_trust", "deny_policy"]
              }
            },
            "required": ["transport_decision_code"]
          },
          "then": {
            "properties": {
              "no_bypass_projection": {
                "properties": {
                  "direct_fallback_allowed": { "const": false }
                },
                "required": ["direct_fallback_allowed"]
              }
            }
          }
        }
      ]
    }
  }
}
