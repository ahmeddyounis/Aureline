{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/network/networked_surface_transport_decision.schema.json",
  "title": "Aureline networked-surface transport-decision log packet",
  "description": "Boundary schema for the stable TransportDecisionLogPage proof packet. The packet is the runtime decision layer that pairs with the frozen networked-surface transport matrix: for every network-capable action a surface takes, the shared transport-governance layer emits one inspectable transport decision that resolves a transport-policy snapshot (egress class, route choice, proxy-resolution tier with PAC -> manual -> system precedence, trust material, mirror/offline posture, policy epoch) against an endpoint descriptor and a typed outcome before the request crosses the boundary. Raw endpoint URLs, raw hostnames, raw ports, raw credentials, raw bearer/session tokens, raw cookie jars, raw private certificate bytes, raw SSH private material, and raw PAC bodies are excluded; only closed-vocabulary tokens, opaque handles and refs, plain-language summary sentences, and schema-version integers cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "page_label",
    "generated_at",
    "evidence_index_ref",
    "summary",
    "rows",
    "defects",
    "decision_snapshot"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "record_kind": {
      "type": "string",
      "const": "remote_networked_surface_transport_decision_page_record"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": {
      "type": "string",
      "const": "remote:networked_surface_transport_decision:v1"
    },
    "page_id": { "$ref": "#/$defs/opaque_id" },
    "page_label": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
    "evidence_index_ref": { "$ref": "#/$defs/non_empty_string" },
    "summary": { "$ref": "#/$defs/decision_summary" },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/decision_row" }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/decision_defect" }
    },
    "decision_snapshot": { "$ref": "#/$defs/decision_snapshot" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "monotonic_timestamp": { "type": "string", "format": "date-time" },
    "reviewable_sentence": { "type": "string", "minLength": 1, "maxLength": 800 },
    "opaque_ref": { "type": "string", "minLength": 1 },
    "nullable_opaque_ref": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_ref" }]
    },
    "surface_token": {
      "type": "string",
      "enum": [
        "ai_gateway",
        "docs_browser_fetcher",
        "request_api_client",
        "database_cloud_connector",
        "registry_read",
        "companion_handoff",
        "provider_mutation",
        "sync_offboarding",
        "remote_preview_route"
      ]
    },
    "origin_scope_token": {
      "type": "string",
      "enum": [
        "first_party",
        "third_party",
        "user_configured",
        "managed_tenant",
        "loopback_local"
      ]
    },
    "endpoint_class_token": {
      "type": "string",
      "enum": [
        "inference_gateway",
        "content_origin",
        "rest_api",
        "data_store",
        "artifact_registry",
        "peer_device",
        "vcs_host",
        "sync_service",
        "preview_origin"
      ]
    },
    "egress_class_token": {
      "type": "string",
      "enum": [
        "public_internet",
        "managed_endpoint",
        "mirror_only",
        "loopback_only",
        "air_gapped"
      ]
    },
    "route_choice_token": {
      "type": "string",
      "enum": [
        "direct",
        "system_proxy",
        "manual_proxy",
        "pac_resolved",
        "mirror_first",
        "offline"
      ]
    },
    "proxy_resolution_source_token": {
      "type": "string",
      "enum": [
        "direct_no_proxy",
        "pac_resolved",
        "manual_proxy",
        "system_proxy",
        "mirror_route",
        "offline_no_route"
      ]
    },
    "auth_posture_token": {
      "type": "string",
      "enum": [
        "anonymous",
        "bearer_token_handle",
        "oauth_delegated_handle",
        "api_key_handle",
        "client_certificate_handle",
        "ssh_key_handle",
        "session_cookie_handle"
      ]
    },
    "trust_material_token": {
      "type": "string",
      "enum": [
        "system_trust_store",
        "pinned_ca_handle",
        "managed_trust_bundle",
        "mirror_root_handle",
        "ssh_known_hosts_handle",
        "no_tls_loopback"
      ]
    },
    "denial_reason_token": {
      "type": "string",
      "enum": [
        "policy_blocked",
        "egress_class_forbidden",
        "trust_proof_missing",
        "trust_proof_expired",
        "auth_posture_rejected",
        "proxy_unreachable",
        "mirror_root_mismatch",
        "offline_no_fallback",
        "non_idempotent_replay_rejected"
      ]
    },
    "nullable_denial_reason_token": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/denial_reason_token" }]
    },
    "denial_reason_row_token": {
      "type": "string",
      "description": "Denial reason token, or the empty string when the decision was not denied.",
      "enum": [
        "",
        "policy_blocked",
        "egress_class_forbidden",
        "trust_proof_missing",
        "trust_proof_expired",
        "auth_posture_rejected",
        "proxy_unreachable",
        "mirror_root_mismatch",
        "offline_no_fallback",
        "non_idempotent_replay_rejected"
      ]
    },
    "mirror_offline_behavior_token": {
      "type": "string",
      "enum": [
        "mirror_first_then_deny",
        "cached_offline",
        "offline_grace",
        "deny_all",
        "local_core_only"
      ]
    },
    "proof_freshness_token": {
      "type": "string",
      "enum": ["fresh", "stale_within_window", "expired_beyond_window"]
    },
    "outcome_token": {
      "type": "string",
      "enum": [
        "allowed",
        "denied",
        "served_from_mirror",
        "served_from_cache",
        "offline_deferred",
        "offline_unavailable"
      ]
    },
    "qualification_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "raw_private_material_exposed",
        "bypassed_shared_governance",
        "silent_public_fallback_resolved",
        "non_idempotent_replay_queued",
        "required_surface_missing",
        "denial_reason_missing",
        "local_core_continuity_not_preserved",
        "trust_proof_missing",
        "policy_epoch_ref_missing",
        "transport_classification_incomplete",
        "proof_stale_beyond_window"
      ]
    },
    "endpoint_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "surface",
        "surface_token",
        "origin_scope",
        "origin_scope_token",
        "endpoint_class",
        "endpoint_class_token",
        "endpoint_handle",
        "endpoint_label",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_transport_decision_endpoint_descriptor_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_transport_decision:v1"
        },
        "surface": { "$ref": "#/$defs/surface_token" },
        "surface_token": { "$ref": "#/$defs/surface_token" },
        "origin_scope": { "$ref": "#/$defs/origin_scope_token" },
        "origin_scope_token": { "$ref": "#/$defs/origin_scope_token" },
        "endpoint_class": { "$ref": "#/$defs/endpoint_class_token" },
        "endpoint_class_token": { "$ref": "#/$defs/endpoint_class_token" },
        "endpoint_handle": { "$ref": "#/$defs/opaque_ref" },
        "endpoint_label": { "$ref": "#/$defs/non_empty_string" },
        "raw_private_material_excluded": { "type": "boolean" }
      }
    },
    "policy_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "snapshot_id",
        "captured_at",
        "surface",
        "surface_token",
        "egress_class",
        "egress_class_token",
        "route_choice",
        "route_choice_token",
        "proxy_resolution_source",
        "proxy_resolution_source_token",
        "trust_material",
        "trust_material_token",
        "trust_proof_ref",
        "trust_proof_freshness",
        "trust_proof_freshness_token",
        "mirror_offline_behavior",
        "mirror_offline_behavior_token",
        "policy_epoch_ref",
        "no_silent_public_fallback",
        "local_core_continuity_preserved",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_transport_decision_policy_snapshot_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_transport_decision:v1"
        },
        "snapshot_id": { "$ref": "#/$defs/opaque_id" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "surface": { "$ref": "#/$defs/surface_token" },
        "surface_token": { "$ref": "#/$defs/surface_token" },
        "egress_class": { "$ref": "#/$defs/egress_class_token" },
        "egress_class_token": { "$ref": "#/$defs/egress_class_token" },
        "route_choice": { "$ref": "#/$defs/route_choice_token" },
        "route_choice_token": { "$ref": "#/$defs/route_choice_token" },
        "proxy_resolution_source": {
          "$ref": "#/$defs/proxy_resolution_source_token"
        },
        "proxy_resolution_source_token": {
          "$ref": "#/$defs/proxy_resolution_source_token"
        },
        "trust_material": { "$ref": "#/$defs/trust_material_token" },
        "trust_material_token": { "$ref": "#/$defs/trust_material_token" },
        "trust_proof_ref": { "$ref": "#/$defs/opaque_ref" },
        "trust_proof_freshness": { "$ref": "#/$defs/proof_freshness_token" },
        "trust_proof_freshness_token": { "$ref": "#/$defs/proof_freshness_token" },
        "mirror_offline_behavior": {
          "$ref": "#/$defs/mirror_offline_behavior_token"
        },
        "mirror_offline_behavior_token": {
          "$ref": "#/$defs/mirror_offline_behavior_token"
        },
        "policy_epoch_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "no_silent_public_fallback": { "type": "boolean" },
        "local_core_continuity_preserved": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" }
      }
    },
    "transport_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "decision_id",
        "decided_at",
        "surface",
        "surface_token",
        "endpoint",
        "policy",
        "auth_posture",
        "auth_posture_token",
        "outcome",
        "outcome_token",
        "denial_reason",
        "denial_reason_token",
        "action_is_idempotent",
        "no_bypass",
        "summary",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_transport_decision_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_transport_decision:v1"
        },
        "decision_id": { "$ref": "#/$defs/opaque_id" },
        "decided_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "surface": { "$ref": "#/$defs/surface_token" },
        "surface_token": { "$ref": "#/$defs/surface_token" },
        "endpoint": { "$ref": "#/$defs/endpoint_descriptor" },
        "policy": { "$ref": "#/$defs/policy_snapshot" },
        "auth_posture": { "$ref": "#/$defs/auth_posture_token" },
        "auth_posture_token": { "$ref": "#/$defs/auth_posture_token" },
        "outcome": { "$ref": "#/$defs/outcome_token" },
        "outcome_token": { "$ref": "#/$defs/outcome_token" },
        "denial_reason": { "$ref": "#/$defs/nullable_denial_reason_token" },
        "denial_reason_token": { "$ref": "#/$defs/denial_reason_row_token" },
        "action_is_idempotent": { "type": "boolean" },
        "no_bypass": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "raw_private_material_excluded": { "type": "boolean" }
      }
    },
    "decision_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisions"],
      "properties": {
        "decisions": {
          "type": "array",
          "items": { "$ref": "#/$defs/transport_decision" }
        }
      }
    },
    "decision_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "decision_id",
        "surface_token",
        "origin_scope_token",
        "endpoint_class_token",
        "egress_class_token",
        "route_choice_token",
        "proxy_resolution_source_token",
        "auth_posture_token",
        "trust_material_token",
        "mirror_offline_behavior_token",
        "outcome_token",
        "denial_reason_token",
        "no_bypass",
        "no_silent_public_fallback",
        "replay_idempotent_only",
        "local_core_continuity_preserved",
        "policy_epoch_present",
        "proof_freshness_token",
        "raw_private_material_excluded",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_transport_decision_row_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_transport_decision:v1"
        },
        "decision_id": { "$ref": "#/$defs/opaque_id" },
        "surface_token": { "$ref": "#/$defs/surface_token" },
        "origin_scope_token": { "$ref": "#/$defs/origin_scope_token" },
        "endpoint_class_token": { "$ref": "#/$defs/endpoint_class_token" },
        "egress_class_token": { "$ref": "#/$defs/egress_class_token" },
        "route_choice_token": { "$ref": "#/$defs/route_choice_token" },
        "proxy_resolution_source_token": {
          "$ref": "#/$defs/proxy_resolution_source_token"
        },
        "auth_posture_token": { "$ref": "#/$defs/auth_posture_token" },
        "trust_material_token": { "$ref": "#/$defs/trust_material_token" },
        "mirror_offline_behavior_token": {
          "$ref": "#/$defs/mirror_offline_behavior_token"
        },
        "outcome_token": { "$ref": "#/$defs/outcome_token" },
        "denial_reason_token": { "$ref": "#/$defs/denial_reason_row_token" },
        "no_bypass": { "type": "boolean" },
        "no_silent_public_fallback": { "type": "boolean" },
        "replay_idempotent_only": { "type": "boolean" },
        "local_core_continuity_preserved": { "type": "boolean" },
        "policy_epoch_present": { "type": "boolean" },
        "proof_freshness_token": { "$ref": "#/$defs/proof_freshness_token" },
        "raw_private_material_excluded": { "type": "boolean" },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "decision_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "surfaces_covered",
        "no_bypass_count",
        "local_core_continuity_preserved_count",
        "policy_epoch_present_count",
        "usable_proof_count",
        "outcome_counts",
        "overall_qualification_token"
      ],
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "surfaces_covered": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_token" }
        },
        "no_bypass_count": { "type": "integer", "minimum": 0 },
        "local_core_continuity_preserved_count": { "type": "integer", "minimum": 0 },
        "policy_epoch_present_count": { "type": "integer", "minimum": 0 },
        "usable_proof_count": { "type": "integer", "minimum": 0 },
        "outcome_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 },
          "propertyNames": { "$ref": "#/$defs/outcome_token" }
        },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_token" }
      }
    },
    "decision_defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_transport_decision_defect_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_transport_decision:v1"
        },
        "defect_id": { "$ref": "#/$defs/non_empty_string" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    }
  }
}
