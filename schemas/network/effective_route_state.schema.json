{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/network/effective_route_state.schema.json",
  "title": "Aureline transport effective-route state",
  "description": "Boundary schema for one effective_route_state_record. The transport inspector projects this record so a reviewer can see, for one network attempt, the endpoint class, origin surface, execution location, proxy source, PAC result, mirror route, direct-route eligibility, trust-root or client-certificate posture, current policy or mirror constraints, the canonical route class with audience, TTL, approval posture, and revocation semantics, the bounded inspector actions and their per-profile availability, and remediation hints for proxy/PAC mismatch, certificate trust failure, client-certificate absence, SSH host-key drift, DNS or mirror issues, and the admin-versus-user repair boundary. The record reuses the shared transport-governance vocabulary and never carries raw URLs, raw host names, raw IP addresses, raw proxy credentials, PAC script bodies, certificate PEM, private keys, raw SSH keys, tokens, request bodies, or response bodies.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "effective_route_id",
    "captured_at",
    "linked_decision_refs",
    "endpoint_class_context",
    "origin_surface",
    "execution_location",
    "proxy_source",
    "pac_result",
    "mirror_route_state",
    "direct_route_eligibility",
    "trust_posture",
    "policy_constraints",
    "mirror_constraints",
    "canonical_route",
    "no_bypass_projection",
    "inspector_actions",
    "remediation_hints",
    "redaction_class",
    "narrative_refs"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "effective_route_state_record" },
    "effective_route_id": {
      "$ref": "#/$defs/opaque_id",
      "description": "Stable opaque id for this effective-route record. Must not contain raw endpoint names, raw hosts, raw IPs, or planning slugs."
    },
    "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
    "linked_decision_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/opaque_id" },
      "description": "Transport decision records this effective route projects. At least one decision ref must back the record."
    },
    "linked_attribution_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/opaque_id" }
    },
    "linked_endpoint_row_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/opaque_id" }
    },
    "linked_summary_strip_ref": { "$ref": "#/$defs/nullable_opaque_id" },
    "linked_certificate_card_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/opaque_id" }
    },
    "linked_denial_record_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/opaque_id" }
    },
    "endpoint_class_context": { "$ref": "#/$defs/endpoint_class_context" },
    "origin_surface": { "$ref": "#/$defs/origin_surface" },
    "execution_location": { "$ref": "#/$defs/execution_location" },
    "proxy_source": { "$ref": "#/$defs/proxy_source" },
    "pac_result": { "$ref": "#/$defs/pac_result" },
    "mirror_route_state": { "$ref": "#/$defs/mirror_route_state" },
    "direct_route_eligibility": { "$ref": "#/$defs/direct_route_eligibility" },
    "trust_posture": { "$ref": "#/$defs/trust_posture" },
    "policy_constraints": { "$ref": "#/$defs/policy_constraints" },
    "mirror_constraints": { "$ref": "#/$defs/mirror_constraints" },
    "canonical_route": { "$ref": "#/$defs/canonical_route" },
    "no_bypass_projection": { "$ref": "#/$defs/no_bypass_projection" },
    "inspector_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/inspector_action_projection" },
      "description": "Bounded inspector actions and their per-profile availability. Every action class must appear exactly once."
    },
    "remediation_hints": {
      "type": "array",
      "items": { "$ref": "#/$defs/remediation_hint" },
      "description": "Typed remediation hints. The list MAY be empty when nothing is broken; it MUST cover every applicable hint family when a typed failure is named on the linked decision or denial."
    },
    "route_history_summary": { "$ref": "#/$defs/route_history_summary" },
    "redaction_class": { "$ref": "#/$defs/redaction_class" },
    "export_safe": { "type": "boolean", "default": true },
    "narrative_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "notes": { "type": "string" },
    "__fixture__": { "$ref": "#/$defs/fixture_metadata" }
  },
  "allOf": [
    {
      "description": "Mirror-only routes never permit a direct public fallback.",
      "if": {
        "properties": {
          "mirror_route_state": {
            "properties": {
              "mirror_route_class": { "const": "mirror_only_no_direct_allowed" }
            },
            "required": ["mirror_route_class"]
          }
        },
        "required": ["mirror_route_state"]
      },
      "then": {
        "properties": {
          "mirror_route_state": {
            "properties": { "public_origin_allowed": { "const": false } },
            "required": ["public_origin_allowed"]
          },
          "direct_route_eligibility": {
            "properties": { "direct_route_allowed": { "const": false } },
            "required": ["direct_route_allowed"]
          },
          "no_bypass_projection": {
            "properties": {
              "direct_fallback_allowed": { "const": false },
              "insecure_fallback_allowed": { "const": false }
            },
            "required": ["direct_fallback_allowed", "insecure_fallback_allowed"]
          }
        }
      }
    },
    {
      "description": "Air-gapped or deny-all execution location forbids direct public fallback and forbids public-origin permission.",
      "if": {
        "properties": {
          "execution_location": {
            "properties": {
              "execution_location_class": {
                "enum": ["air_gap_local_only", "deny_all_offline_only"]
              }
            },
            "required": ["execution_location_class"]
          }
        },
        "required": ["execution_location"]
      },
      "then": {
        "properties": {
          "direct_route_eligibility": {
            "properties": { "direct_route_allowed": { "const": false } },
            "required": ["direct_route_allowed"]
          },
          "mirror_route_state": {
            "properties": { "public_origin_allowed": { "const": false } },
            "required": ["public_origin_allowed"]
          }
        }
      }
    },
    {
      "description": "When direct fallback is disallowed, the no-bypass projection must be enforced and direct/insecure fallback must be false.",
      "if": {
        "properties": {
          "direct_route_eligibility": {
            "properties": { "direct_route_allowed": { "const": false } },
            "required": ["direct_route_allowed"]
          }
        },
        "required": ["direct_route_eligibility"]
      },
      "then": {
        "properties": {
          "no_bypass_projection": {
            "properties": {
              "direct_fallback_allowed": { "const": false },
              "insecure_fallback_allowed": { "const": false }
            },
            "required": ["direct_fallback_allowed", "insecure_fallback_allowed"]
          }
        }
      }
    },
    {
      "description": "Trust failures must not collapse to none on the trust posture.",
      "if": {
        "properties": {
          "direct_route_eligibility": {
            "properties": {
              "direct_route_eligibility_class": { "const": "direct_disallowed_trust_floor" }
            },
            "required": ["direct_route_eligibility_class"]
          }
        },
        "required": ["direct_route_eligibility"]
      },
      "then": {
        "properties": {
          "trust_posture": {
            "properties": {
              "trust_failure_state": { "not": { "const": "none" } }
            },
            "required": ["trust_failure_state"]
          }
        }
      }
    },
    {
      "description": "An export-packet inspector action that is unavailable must name an unavailability reason.",
      "if": {
        "properties": {
          "inspector_actions": {
            "type": "array",
            "contains": {
              "properties": {
                "inspector_action_class": { "const": "export_packet" },
                "availability_class": { "not": { "const": "available" } }
              },
              "required": ["inspector_action_class", "availability_class"]
            }
          }
        }
      },
      "then": {
        "properties": {
          "inspector_actions": {
            "type": "array",
            "contains": {
              "properties": {
                "inspector_action_class": { "const": "export_packet" },
                "unavailable_reason_class": { "not": { "const": "not_applicable_no_unavailability" } }
              },
              "required": ["inspector_action_class", "unavailable_reason_class"]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "nullable_opaque_id": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_id" }]
    },
    "opaque_fingerprint": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[:_-][a-z0-9]+)+$"
    },
    "nullable_opaque_fingerprint": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_fingerprint" }]
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280,
      "description": "Short privacy-safe sentence for UI, CLI, support exports, and admin audit. Raw endpoints, hosts, URLs, payloads, and credentials must not appear."
    },
    "monotonic_timestamp": { "type": "string", "format": "date-time" },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "linked_docs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
