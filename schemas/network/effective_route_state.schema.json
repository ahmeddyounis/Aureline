    "remediation_hint_kind_class": {
      "type": "string",
      "enum": [
        "proxy_pac_mismatch",
        "certificate_trust_failure",
        "client_certificate_absence",
        "ssh_host_key_drift",
        "dns_or_mirror_issue",
        "admin_vs_user_repair_boundary"
      ]
    },
    "proxy_pac_mismatch_hint_class": {
      "type": "string",
      "enum": [
        "review_proxy_settings",
        "review_pac_resolution",
        "switch_to_system_proxy",
        "switch_to_manual_admin_policy",
        "refresh_pac_script",
        "request_admin_proxy_review",
        "no_proxy_repair_required"
      ]
    },
    "certificate_trust_failure_hint_class": {
      "type": "string",
      "enum": [
        "add_ca_bundle",
        "refresh_ca_bundle",
        "refresh_pinned_root",
        "request_admin_trust_review",
        "rotate_trust_anchor",
        "no_trust_repair_required"
      ]
    },
    "client_certificate_absence_hint_class": {
      "type": "string",
      "enum": [
        "renew_client_certificate",
        "request_managed_handle",
        "request_admin_to_provision_handle",
        "switch_to_supported_auth_path",
        "no_client_cert_repair_required"
      ]
    },
    "ssh_host_key_drift_hint_class": {
      "type": "string",
      "enum": [
        "review_ssh_host_proof",
        "request_admin_to_publish_pin",
        "refresh_known_hosts_from_policy",
        "rebind_to_new_host_proof_with_admin",
        "no_ssh_repair_required"
      ]
    },
    "dns_or_mirror_issue_hint_class": {
      "type": "string",
      "enum": [
        "switch_mirror",
        "refresh_mirror",
        "request_admin_mirror_review",
        "retry_after_mirror_refresh",
        "request_dns_review",
        "no_mirror_repair_required"
      ]
    },
    "admin_or_user_repair_boundary_class": {
      "type": "string",
      "enum": [
        "end_user_can_repair",
        "admin_must_repair",
        "support_assisted_repair",
        "managed_service_must_repair",
        "repair_unavailable_in_profile"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "endpoint_class_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_class",
        "permission_class",
        "target_class",
        "target_identity_ref",
        "egress_class",
        "auth_mode"
      ],
      "properties": {
        "component_class": { "$ref": "#/$defs/network_component_class" },
        "component_instance_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "component_label": { "$ref": "#/$defs/reviewable_sentence" },
        "permission_class": { "$ref": "#/$defs/network_permission_class" },
        "permission_grant_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "target_class": { "$ref": "#/$defs/network_target_class" },
        "target_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "target_scope_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "egress_class": { "$ref": "#/$defs/egress_class" },
        "auth_mode": { "$ref": "#/$defs/auth_mode_class" },
        "auth_handle_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "origin_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin_scope",
        "inspector_surface_class",
        "origin_surface_sentence"
      ],
      "properties": {
        "origin_scope": { "$ref": "#/$defs/origin_scope_class" },
        "inspector_surface_class": { "$ref": "#/$defs/inspector_surface_class" },
        "origin_surface_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "origin_surface_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "execution_location": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_location_class",
        "deployment_profile",
        "identity_mode",
        "execution_location_sentence"
      ],
      "properties": {
        "execution_location_class": { "$ref": "#/$defs/execution_location_class" },
        "execution_target_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "deployment_profile": { "$ref": "#/$defs/deployment_profile_class" },
        "identity_mode": { "$ref": "#/$defs/identity_mode" },
        "execution_location_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "proxy_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proxy_resolution_mode",
        "proxy_source_class",
        "effective_proxy_ref",
        "proxy_source_sentence"
      ],
      "properties": {
        "proxy_resolution_mode": { "$ref": "#/$defs/proxy_resolution_mode_class" },
        "proxy_source_class": { "$ref": "#/$defs/proxy_source_class" },
        "effective_proxy_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "proxy_config_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "proxy_source_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "pac_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pac_state_class",
        "pac_decision_class",
        "pac_result_sentence"
      ],
      "properties": {
        "pac_state_class": { "$ref": "#/$defs/pac_state_class" },
        "pac_script_fingerprint": { "$ref": "#/$defs/nullable_opaque_fingerprint" },
        "pac_decision_class": { "$ref": "#/$defs/pac_decision_class" },
        "pac_resolved_proxy_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "pac_result_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "mirror_route_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label_class",
        "mirror_route_class",
        "mirror_freshness_class",
        "public_origin_allowed",
        "mirror_state_sentence"
      ],
      "properties": {
        "label_class": { "$ref": "#/$defs/mirror_public_label_class" },
        "mirror_route_class": { "$ref": "#/$defs/mirror_route_class" },
        "mirror_endpoint_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "mirror_snapshot_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "mirror_freshness_class": { "$ref": "#/$defs/mirror_freshness_class" },
        "public_origin_allowed": { "type": "boolean" },
        "mirror_state_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "direct_route_eligibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "direct_route_allowed",
        "direct_route_eligibility_class",
        "eligibility_sentence"
      ],
      "properties": {
        "direct_route_allowed": { "type": "boolean" },
        "direct_route_eligibility_class": { "$ref": "#/$defs/direct_route_eligibility_class" },
        "exception_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "eligibility_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "trust_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust_store_source",
        "ssh_host_key_provenance",
        "client_certificate_state",
        "trust_failure_state",
        "trust_posture_sentence"
      ],
      "properties": {
        "trust_store_source": { "$ref": "#/$defs/trust_store_source_class" },
        "org_ca_bundle_fingerprint": { "$ref": "#/$defs/nullable_opaque_fingerprint" },
        "pinned_control_plane_trust_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "trust_anchor_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "ssh_host_key_provenance": { "$ref": "#/$defs/ssh_host_key_provenance_class" },
        "ssh_host_key_fingerprint": { "$ref": "#/$defs/nullable_opaque_fingerprint" },
        "client_certificate_state": { "$ref": "#/$defs/client_certificate_state" },
        "client_certificate_handle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "client_certificate_fingerprint": { "$ref": "#/$defs/nullable_opaque_fingerprint" },
        "trust_failure_state": { "$ref": "#/$defs/trust_failure_state" },
        "trust_posture_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "policy_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_source_class",
        "policy_freshness_class",
        "policy_constraint_classes",
        "policy_constraints_sentence"
      ],
      "properties": {
        "policy_source_class": { "$ref": "#/$defs/policy_source_class" },
        "policy_freshness_class": { "$ref": "#/$defs/policy_freshness_class" },
        "active_policy_bundle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "policy_epoch_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "policy_constraint_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/policy_constraint_class" }
        },
        "policy_constraints_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "mirror_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mirror_constraint_classes",
        "mirror_constraints_sentence"
      ],
      "properties": {
        "mirror_constraint_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/mirror_constraint_class" }
        },
        "mirror_constraints_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "canonical_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_route_class",
        "audience_class",
        "ttl_class",
        "approval_posture_class",
        "revocation_class",
        "canonical_route_sentence"
      ],
      "properties": {
        "canonical_route_class": { "$ref": "#/$defs/route_class" },
        "audience_class": { "$ref": "#/$defs/audience_class" },
        "ttl_seconds": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 0 }
          ]
        },
        "ttl_class": { "$ref": "#/$defs/ttl_class" },
        "approval_posture_class": { "$ref": "#/$defs/approval_posture_class" },
        "approval_evidence_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "revocation_class": { "$ref": "#/$defs/revocation_class" },
        "revocation_authority_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "canonical_route_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "no_bypass_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_bypass_status",
        "direct_fallback_allowed",
        "insecure_fallback_allowed",
        "forbidden_bypass_classes",
        "no_bypass_sentence"
      ],
      "properties": {
        "no_bypass_status": { "$ref": "#/$defs/no_bypass_status_class" },
        "direct_fallback_allowed": { "type": "boolean" },
        "insecure_fallback_allowed": { "type": "boolean" },
        "forbidden_bypass_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/forbidden_bypass_class" }
        },
        "exception_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "no_bypass_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "inspector_action_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inspector_action_class",
        "availability_class",
        "unavailable_reason_class",
        "action_sentence"
      ],
      "properties": {
        "inspector_action_class": { "$ref": "#/$defs/inspector_action_class" },
        "availability_class": { "$ref": "#/$defs/inspector_action_availability_class" },
        "unavailable_reason_class": { "$ref": "#/$defs/inspector_action_unavailable_reason_class" },
        "action_target_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "action_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "remediation_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "remediation_hint_kind_class",
        "hint_class",
        "repair_boundary_class",
        "hint_sentence"
      ],
      "properties": {
        "remediation_hint_kind_class": { "$ref": "#/$defs/remediation_hint_kind_class" },
        "hint_class": {
          "type": "string",
          "minLength": 1,
          "description": "Hint class drawn from the matching remediation_hint_kind_class vocabulary (proxy_pac_mismatch, certificate_trust_failure, client_certificate_absence, ssh_host_key_drift, dns_or_mirror_issue, or admin_vs_user_repair_boundary)."
        },
        "repair_boundary_class": { "$ref": "#/$defs/admin_or_user_repair_boundary_class" },
        "repair_target_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "exception_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "hint_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "remediation_hint_kind_class": { "const": "proxy_pac_mismatch" } },
            "required": ["remediation_hint_kind_class"]
          },
          "then": {
            "properties": { "hint_class": { "$ref": "#/$defs/proxy_pac_mismatch_hint_class" } }
          }
        },
        {
          "if": {
            "properties": { "remediation_hint_kind_class": { "const": "certificate_trust_failure" } },
            "required": ["remediation_hint_kind_class"]
          },
          "then": {
            "properties": { "hint_class": { "$ref": "#/$defs/certificate_trust_failure_hint_class" } }
          }
        },
        {
          "if": {
            "properties": { "remediation_hint_kind_class": { "const": "client_certificate_absence" } },
            "required": ["remediation_hint_kind_class"]
          },
          "then": {
            "properties": { "hint_class": { "$ref": "#/$defs/client_certificate_absence_hint_class" } }
          }
        },
        {
          "if": {
            "properties": { "remediation_hint_kind_class": { "const": "ssh_host_key_drift" } },
            "required": ["remediation_hint_kind_class"]
          },
          "then": {
            "properties": { "hint_class": { "$ref": "#/$defs/ssh_host_key_drift_hint_class" } }
          }
        },
        {
          "if": {
            "properties": { "remediation_hint_kind_class": { "const": "dns_or_mirror_issue" } },
            "required": ["remediation_hint_kind_class"]
          },
          "then": {
            "properties": { "hint_class": { "$ref": "#/$defs/dns_or_mirror_issue_hint_class" } }
          }
        },
        {
          "if": {
            "properties": { "remediation_hint_kind_class": { "const": "admin_vs_user_repair_boundary" } },
            "required": ["remediation_hint_kind_class"]
          },
          "then": {
            "properties": { "hint_class": { "$ref": "#/$defs/admin_or_user_repair_boundary_class" } }
          }
        }
      ]
    },
    "route_history_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "history_window_class",
        "recent_decision_refs",
        "recent_attribution_refs",
        "recent_history_sentence"
      ],
      "properties": {
        "history_window_class": {
          "type": "string",
          "enum": [
            "session_recent",
            "workspace_recent",
            "support_export_selected",
            "admin_audit_retained",
            "history_unavailable_in_profile"
          ]
        },
        "recent_decision_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "recent_attribution_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "recent_history_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    }
  }
}
