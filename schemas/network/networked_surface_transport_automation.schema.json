{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/network/networked_surface_transport_automation.schema.json",
  "title": "Aureline networked-surface transport-automation packet",
  "description": "Boundary schema for the stable TransportAutomationPage proof packet. The packet gives M5 network activity history, support exports, and headless automation one canonical transport-denial vocabulary (proxy_misconfigured, proxy_auth_required, ca_untrusted, ssh_host_key_unknown, egress_blocked_policy, mirror_unreachable, offline_mode, origin_scope_ambiguous), one set of network-activity filters, and one redaction-safe route/origin history join, so an M5 network failure is explained from a single packet set rather than reconstructed from per-feature logs. Raw URLs, raw hostnames, raw ports, raw paths, raw query strings, raw cookies, raw headers, raw bearer or session tokens, raw private certificate bytes, and raw SSH private material are excluded; only closed-vocabulary tokens, opaque refs, UTC timestamps, counts, and plain-language summary sentences cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "page_label",
    "generated_at",
    "evidence_index_ref",
    "summary",
    "rows",
    "defects",
    "activity_snapshot",
    "route_origin_joins",
    "filter_facets"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "record_kind": {
      "type": "string",
      "const": "remote_networked_surface_transport_automation_page_record"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": {
      "type": "string",
      "const": "remote:networked_surface_transport_automation:v1"
    },
    "page_id": { "$ref": "#/$defs/opaque_id" },
    "page_label": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
    "evidence_index_ref": { "$ref": "#/$defs/non_empty_string" },
    "summary": { "$ref": "#/$defs/automation_summary" },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/automation_row" }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/automation_defect" }
    },
    "activity_snapshot": { "$ref": "#/$defs/automation_snapshot" },
    "route_origin_joins": {
      "type": "array",
      "items": { "$ref": "#/$defs/route_origin_join" }
    },
    "filter_facets": {
      "type": "array",
      "items": { "$ref": "#/$defs/filter_facet" }
    }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "monotonic_timestamp": { "type": "string", "format": "date-time" },
    "reviewable_sentence": { "type": "string", "minLength": 1, "maxLength": 800 },
    "surface_token": {
      "type": "string",
      "enum": [
        "ai_gateway",
        "docs_browser_fetcher",
        "request_api_client",
        "database_cloud_connector",
        "registry_read",
        "companion_handoff",
        "provider_mutation",
        "sync_offboarding",
        "remote_preview_route"
      ]
    },
    "origin_scope_token": {
      "type": "string",
      "enum": [
        "first_party",
        "third_party",
        "user_configured",
        "managed_tenant",
        "loopback_local"
      ]
    },
    "endpoint_class_token": {
      "type": "string",
      "enum": [
        "inference_gateway",
        "content_origin",
        "rest_api",
        "data_store",
        "artifact_registry",
        "peer_device",
        "vcs_host",
        "sync_service",
        "preview_origin"
      ]
    },
    "egress_class_token": {
      "type": "string",
      "enum": [
        "public_internet",
        "managed_endpoint",
        "mirror_only",
        "loopback_only",
        "air_gapped"
      ]
    },
    "route_choice_token": {
      "type": "string",
      "enum": [
        "direct",
        "system_proxy",
        "manual_proxy",
        "pac_resolved",
        "mirror_first",
        "offline"
      ]
    },
    "disposition_token": {
      "type": "string",
      "enum": ["allowed", "denied", "deferred"]
    },
    "denial_code_token": {
      "type": "string",
      "enum": [
        "none",
        "proxy_misconfigured",
        "proxy_auth_required",
        "ca_untrusted",
        "ssh_host_key_unknown",
        "egress_blocked_policy",
        "mirror_unreachable",
        "offline_mode",
        "origin_scope_ambiguous"
      ]
    },
    "filter_dimension_token": {
      "type": "string",
      "enum": [
        "surface",
        "origin_scope",
        "endpoint_class",
        "route_choice",
        "disposition",
        "denial_code"
      ]
    },
    "qualification_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "raw_private_material_exposed",
        "bypassed_shared_governance",
        "non_idempotent_replay_queued",
        "required_surface_missing",
        "denied_without_canonical_code",
        "disposition_denial_code_mismatch",
        "denial_vocabulary_incomplete"
      ]
    },
    "activity_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "record_id",
        "sequence",
        "occurred_at",
        "surface",
        "surface_token",
        "surface_label",
        "origin_scope",
        "origin_scope_token",
        "endpoint_class",
        "endpoint_class_token",
        "egress_class",
        "egress_class_token",
        "route_choice",
        "route_choice_token",
        "disposition",
        "disposition_token",
        "denial_code",
        "denial_code_token",
        "action_is_idempotent",
        "no_bypass",
        "summary",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_transport_automation_activity_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_transport_automation:v1"
        },
        "record_id": { "$ref": "#/$defs/opaque_id" },
        "sequence": { "type": "integer", "minimum": 0 },
        "occurred_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "surface": { "$ref": "#/$defs/surface_token" },
        "surface_token": { "$ref": "#/$defs/surface_token" },
        "surface_label": { "$ref": "#/$defs/non_empty_string" },
        "origin_scope": { "$ref": "#/$defs/origin_scope_token" },
        "origin_scope_token": { "$ref": "#/$defs/origin_scope_token" },
        "endpoint_class": { "$ref": "#/$defs/endpoint_class_token" },
        "endpoint_class_token": { "$ref": "#/$defs/endpoint_class_token" },
        "egress_class": { "$ref": "#/$defs/egress_class_token" },
        "egress_class_token": { "$ref": "#/$defs/egress_class_token" },
        "route_choice": { "$ref": "#/$defs/route_choice_token" },
        "route_choice_token": { "$ref": "#/$defs/route_choice_token" },
        "disposition": { "$ref": "#/$defs/disposition_token" },
        "disposition_token": { "$ref": "#/$defs/disposition_token" },
        "denial_code": { "$ref": "#/$defs/denial_code_token" },
        "denial_code_token": { "$ref": "#/$defs/denial_code_token" },
        "action_is_idempotent": { "type": "boolean" },
        "no_bypass": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "raw_private_material_excluded": { "type": "boolean" }
      }
    },
    "automation_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["records"],
      "properties": {
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/activity_record" }
        }
      }
    },
    "automation_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "record_id",
        "surface_token",
        "origin_scope_token",
        "endpoint_class_token",
        "egress_class_token",
        "route_choice_token",
        "disposition_token",
        "denial_code_token",
        "no_bypass",
        "replay_idempotent_only",
        "disposition_code_consistent",
        "raw_private_material_excluded",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_transport_automation_row_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_transport_automation:v1"
        },
        "record_id": { "$ref": "#/$defs/opaque_id" },
        "surface_token": { "$ref": "#/$defs/surface_token" },
        "origin_scope_token": { "$ref": "#/$defs/origin_scope_token" },
        "endpoint_class_token": { "$ref": "#/$defs/endpoint_class_token" },
        "egress_class_token": { "$ref": "#/$defs/egress_class_token" },
        "route_choice_token": { "$ref": "#/$defs/route_choice_token" },
        "disposition_token": { "$ref": "#/$defs/disposition_token" },
        "denial_code_token": { "$ref": "#/$defs/denial_code_token" },
        "no_bypass": { "type": "boolean" },
        "replay_idempotent_only": { "type": "boolean" },
        "disposition_code_consistent": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "route_origin_join": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "join_id",
        "route_choice_token",
        "origin_scope_token",
        "total_count",
        "allowed_count",
        "denied_count",
        "deferred_count",
        "surfaces_present",
        "denial_codes_present"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_transport_automation_route_origin_join_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_transport_automation:v1"
        },
        "join_id": { "$ref": "#/$defs/non_empty_string" },
        "route_choice_token": { "$ref": "#/$defs/route_choice_token" },
        "origin_scope_token": { "$ref": "#/$defs/origin_scope_token" },
        "total_count": { "type": "integer", "minimum": 0 },
        "allowed_count": { "type": "integer", "minimum": 0 },
        "denied_count": { "type": "integer", "minimum": 0 },
        "deferred_count": { "type": "integer", "minimum": 0 },
        "surfaces_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_token" }
        },
        "denial_codes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/denial_code_token" }
        }
      }
    },
    "filter_facet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "dimension_token", "values"],
      "properties": {
        "dimension": { "$ref": "#/$defs/filter_dimension_token" },
        "dimension_token": { "$ref": "#/$defs/filter_dimension_token" },
        "values": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "automation_defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_transport_automation_defect_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_transport_automation:v1"
        },
        "defect_id": { "$ref": "#/$defs/non_empty_string" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "automation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "activity_count",
        "allowed_count",
        "denied_count",
        "deferred_count",
        "surfaces_covered",
        "no_bypass_count",
        "disposition_counts",
        "denial_code_counts",
        "denial_vocabulary",
        "overall_qualification_token"
      ],
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "activity_count": { "type": "integer", "minimum": 0 },
        "allowed_count": { "type": "integer", "minimum": 0 },
        "denied_count": { "type": "integer", "minimum": 0 },
        "deferred_count": { "type": "integer", "minimum": 0 },
        "surfaces_covered": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_token" }
        },
        "no_bypass_count": { "type": "integer", "minimum": 0 },
        "disposition_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "denial_code_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "denial_vocabulary": {
          "type": "array",
          "items": { "$ref": "#/$defs/denial_code_token" }
        },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_token" }
      }
    }
  }
}
