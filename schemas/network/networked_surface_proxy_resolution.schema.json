{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/network/networked_surface_proxy_resolution.schema.json",
  "title": "Aureline networked-surface proxy-resolution governance packet",
  "description": "Boundary schema for the stable ProxyResolutionGovernancePage proof packet. The packet makes the proxy-resolution step itself a first-class governed object: for every network-capable surface it freezes the ordered candidate chain resolution walked (PAC -> manual -> environment -> system -> declared direct, plus the out-of-ladder mirror-pinned and offline tiers), the winning tier, the typed outcome, and a typed deny_proxy_resolution reason when no tier may be honored, so the precedence is inspectable and no helper, client, or extension can ship a private proxy stack, a direct CA override, or a hidden direct-connect fallback. Raw proxy hosts, raw PAC bodies, raw CA bundles, raw certificate bytes, raw credentials, and raw bearer/session tokens are excluded; only closed-vocabulary tokens, opaque handles and refs, plain-language summary sentences, and schema-version integers cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "page_id",
    "page_label",
    "generated_at",
    "evidence_index_ref",
    "summary",
    "rows",
    "defects",
    "resolution_snapshot"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "record_kind": {
      "type": "string",
      "const": "remote_networked_surface_proxy_resolution_page_record"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "shared_contract_ref": {
      "type": "string",
      "const": "remote:networked_surface_proxy_resolution:v1"
    },
    "page_id": { "$ref": "#/$defs/opaque_id" },
    "page_label": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
    "evidence_index_ref": { "$ref": "#/$defs/non_empty_string" },
    "summary": { "$ref": "#/$defs/resolution_summary" },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/resolution_row" }
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/resolution_defect" }
    },
    "resolution_snapshot": { "$ref": "#/$defs/resolution_snapshot" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "monotonic_timestamp": { "type": "string", "format": "date-time" },
    "reviewable_sentence": { "type": "string", "minLength": 1, "maxLength": 800 },
    "opaque_ref": { "type": "string", "minLength": 1 },
    "nullable_opaque_ref": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_ref" }]
    },
    "surface_token": {
      "type": "string",
      "enum": [
        "ai_gateway",
        "docs_browser_fetcher",
        "request_api_client",
        "database_cloud_connector",
        "registry_read",
        "companion_handoff",
        "provider_mutation",
        "sync_offboarding",
        "remote_preview_route"
      ]
    },
    "origin_scope_token": {
      "type": "string",
      "enum": [
        "first_party",
        "third_party",
        "user_configured",
        "managed_tenant",
        "loopback_local"
      ]
    },
    "egress_class_token": {
      "type": "string",
      "enum": [
        "public_internet",
        "managed_endpoint",
        "mirror_only",
        "loopback_only",
        "air_gapped"
      ]
    },
    "tier_token": {
      "type": "string",
      "enum": [
        "pac_script",
        "manual_pinned",
        "environment_proxy",
        "system_proxy",
        "direct_no_proxy",
        "mirror_pinned",
        "offline_no_route"
      ]
    },
    "selected_tier_row_token": {
      "type": "string",
      "description": "Selected tier token, or the empty string when no tier was selected (denied/degraded/offline).",
      "enum": [
        "",
        "pac_script",
        "manual_pinned",
        "environment_proxy",
        "system_proxy",
        "direct_no_proxy",
        "mirror_pinned",
        "offline_no_route"
      ]
    },
    "nullable_tier_token": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/tier_token" }]
    },
    "outcome_token": {
      "type": "string",
      "enum": [
        "resolved",
        "mirror_pinned_no_proxy",
        "degraded_awaiting_policy",
        "denied_proxy_resolution",
        "offline_no_route"
      ]
    },
    "denial_reason_token": {
      "type": "string",
      "enum": [
        "contradictory_proxy_state",
        "private_proxy_stack_detected",
        "direct_ca_override_detected",
        "undeclared_public_fallback",
        "pac_unreachable",
        "proxy_unreachable",
        "no_resolvable_route",
        "mirror_only_no_proxy_permitted",
        "policy_epoch_unavailable"
      ]
    },
    "nullable_denial_reason_token": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/denial_reason_token" }]
    },
    "denial_reason_row_token": {
      "type": "string",
      "description": "Denial reason token, or the empty string when resolution was not denied.",
      "enum": [
        "",
        "contradictory_proxy_state",
        "private_proxy_stack_detected",
        "direct_ca_override_detected",
        "undeclared_public_fallback",
        "pac_unreachable",
        "proxy_unreachable",
        "no_resolvable_route",
        "mirror_only_no_proxy_permitted",
        "policy_epoch_unavailable"
      ]
    },
    "mirror_offline_behavior_token": {
      "type": "string",
      "enum": [
        "mirror_first_then_deny",
        "cached_offline",
        "offline_grace",
        "deny_all",
        "local_core_only"
      ]
    },
    "qualification_token": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "withdrawn"]
    },
    "narrow_reason_token": {
      "type": "string",
      "enum": [
        "not_narrowed",
        "raw_private_material_exposed",
        "private_proxy_stack_shipped",
        "direct_ca_override_shipped",
        "silent_direct_fallback_resolved",
        "required_surface_missing",
        "deny_reason_missing",
        "precedence_not_respected",
        "local_core_continuity_not_preserved",
        "policy_epoch_ref_missing",
        "proxy_chain_classification_incomplete"
      ]
    },
    "proxy_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "tier",
        "tier_token",
        "precedence_rank",
        "available",
        "selected",
        "is_private_stack",
        "candidate_handle",
        "note"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_proxy_resolution_candidate_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_proxy_resolution:v1"
        },
        "tier": { "$ref": "#/$defs/tier_token" },
        "tier_token": { "$ref": "#/$defs/tier_token" },
        "precedence_rank": { "type": "integer", "minimum": 0, "maximum": 255 },
        "available": { "type": "boolean" },
        "selected": { "type": "boolean" },
        "is_private_stack": { "type": "boolean" },
        "candidate_handle": { "$ref": "#/$defs/opaque_ref" },
        "note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "resolution_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "record_id",
        "resolved_at",
        "surface",
        "surface_token",
        "origin_scope",
        "origin_scope_token",
        "egress_class",
        "egress_class_token",
        "candidates",
        "selected_tier",
        "selected_tier_token",
        "outcome",
        "outcome_token",
        "denial_reason",
        "denial_reason_token",
        "mirror_offline_behavior",
        "mirror_offline_behavior_token",
        "policy_epoch_ref",
        "no_private_proxy_stack",
        "no_direct_ca_override",
        "no_silent_direct_fallback",
        "local_core_continuity_preserved",
        "summary",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_proxy_resolution_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_proxy_resolution:v1"
        },
        "record_id": { "$ref": "#/$defs/opaque_id" },
        "resolved_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "surface": { "$ref": "#/$defs/surface_token" },
        "surface_token": { "$ref": "#/$defs/surface_token" },
        "origin_scope": { "$ref": "#/$defs/origin_scope_token" },
        "origin_scope_token": { "$ref": "#/$defs/origin_scope_token" },
        "egress_class": { "$ref": "#/$defs/egress_class_token" },
        "egress_class_token": { "$ref": "#/$defs/egress_class_token" },
        "candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/proxy_candidate" }
        },
        "selected_tier": { "$ref": "#/$defs/nullable_tier_token" },
        "selected_tier_token": { "$ref": "#/$defs/selected_tier_row_token" },
        "outcome": { "$ref": "#/$defs/outcome_token" },
        "outcome_token": { "$ref": "#/$defs/outcome_token" },
        "denial_reason": { "$ref": "#/$defs/nullable_denial_reason_token" },
        "denial_reason_token": { "$ref": "#/$defs/denial_reason_row_token" },
        "mirror_offline_behavior": {
          "$ref": "#/$defs/mirror_offline_behavior_token"
        },
        "mirror_offline_behavior_token": {
          "$ref": "#/$defs/mirror_offline_behavior_token"
        },
        "policy_epoch_ref": { "$ref": "#/$defs/nullable_opaque_ref" },
        "no_private_proxy_stack": { "type": "boolean" },
        "no_direct_ca_override": { "type": "boolean" },
        "no_silent_direct_fallback": { "type": "boolean" },
        "local_core_continuity_preserved": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "raw_private_material_excluded": { "type": "boolean" }
      }
    },
    "resolution_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["records"],
      "properties": {
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/resolution_record" }
        }
      }
    },
    "resolution_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "record_id",
        "surface_token",
        "origin_scope_token",
        "egress_class_token",
        "candidate_tier_tokens",
        "selected_tier_token",
        "outcome_token",
        "denial_reason_token",
        "mirror_offline_behavior_token",
        "no_private_proxy_stack",
        "no_direct_ca_override",
        "no_silent_direct_fallback",
        "precedence_respected",
        "local_core_continuity_preserved",
        "policy_epoch_present",
        "raw_private_material_excluded",
        "qualification_token",
        "narrow_reason_token",
        "plain_language_summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_proxy_resolution_row_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_proxy_resolution:v1"
        },
        "record_id": { "$ref": "#/$defs/opaque_id" },
        "surface_token": { "$ref": "#/$defs/surface_token" },
        "origin_scope_token": { "$ref": "#/$defs/origin_scope_token" },
        "egress_class_token": { "$ref": "#/$defs/egress_class_token" },
        "candidate_tier_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/tier_token" }
        },
        "selected_tier_token": { "$ref": "#/$defs/selected_tier_row_token" },
        "outcome_token": { "$ref": "#/$defs/outcome_token" },
        "denial_reason_token": { "$ref": "#/$defs/denial_reason_row_token" },
        "mirror_offline_behavior_token": {
          "$ref": "#/$defs/mirror_offline_behavior_token"
        },
        "no_private_proxy_stack": { "type": "boolean" },
        "no_direct_ca_override": { "type": "boolean" },
        "no_silent_direct_fallback": { "type": "boolean" },
        "precedence_respected": { "type": "boolean" },
        "local_core_continuity_preserved": { "type": "boolean" },
        "policy_epoch_present": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "qualification_token": { "$ref": "#/$defs/qualification_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "plain_language_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "resolution_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_count",
        "stable_row_count",
        "beta_row_count",
        "preview_row_count",
        "withdrawn_row_count",
        "surfaces_covered",
        "no_private_proxy_stack_count",
        "no_direct_ca_override_count",
        "no_silent_direct_fallback_count",
        "precedence_respected_count",
        "local_core_continuity_preserved_count",
        "selected_tier_counts",
        "outcome_counts",
        "overall_qualification_token"
      ],
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "stable_row_count": { "type": "integer", "minimum": 0 },
        "beta_row_count": { "type": "integer", "minimum": 0 },
        "preview_row_count": { "type": "integer", "minimum": 0 },
        "withdrawn_row_count": { "type": "integer", "minimum": 0 },
        "surfaces_covered": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_token" }
        },
        "no_private_proxy_stack_count": { "type": "integer", "minimum": 0 },
        "no_direct_ca_override_count": { "type": "integer", "minimum": 0 },
        "no_silent_direct_fallback_count": { "type": "integer", "minimum": 0 },
        "precedence_respected_count": { "type": "integer", "minimum": 0 },
        "local_core_continuity_preserved_count": { "type": "integer", "minimum": 0 },
        "selected_tier_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 },
          "propertyNames": { "$ref": "#/$defs/tier_token" }
        },
        "outcome_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 },
          "propertyNames": { "$ref": "#/$defs/outcome_token" }
        },
        "overall_qualification_token": { "$ref": "#/$defs/qualification_token" }
      }
    },
    "resolution_defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "narrow_reason",
        "narrow_reason_token",
        "source",
        "note"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "remote_networked_surface_proxy_resolution_defect_record"
        },
        "schema_version": { "type": "integer", "const": 1 },
        "shared_contract_ref": {
          "type": "string",
          "const": "remote:networked_surface_proxy_resolution:v1"
        },
        "defect_id": { "$ref": "#/$defs/non_empty_string" },
        "narrow_reason": { "$ref": "#/$defs/narrow_reason_token" },
        "narrow_reason_token": { "$ref": "#/$defs/narrow_reason_token" },
        "source": { "$ref": "#/$defs/non_empty_string" },
        "note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    }
  }
}
