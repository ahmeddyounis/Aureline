{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/harden_critical_dependency_register_fork_replace_log_third_party_import_manifest_and_reuse_spdx_notice_coverage.schema.json",
  "title": "Aureline critical dependency register, fork/replace log, third-party import manifest, and REUSE/SPDX/notice coverage governance register",
  "description": "Canonical, machine-readable register binding each dependency and licensing governance lane (critical dependency register, fork/replace log, third-party import manifest, REUSE/SPDX/notice coverage) to the stable claim manifest entry whose lifecycle label it backs, a packet-freshness SLO, and lane rules that gate publication. Each lane may carry the claim's label or narrow below it but never wider. The register is metadata-only: typed states and opaque refs, never raw artifacts, logs, signatures, or credentials.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "artifact_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "stable_proof_index_ref",
    "lifecycle_labels",
    "lane_kinds",
    "lane_states",
    "gap_reasons",
    "lane_actions",
    "release_blocking_lane_refs",
    "rows",
    "rules",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "harden_critical_dependency_register_fork_replace_log_third_party_import_manifest_and_reuse_spdx_notice_coverage" },
    "artifact_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "stable_proof_index_ref": { "$ref": "#/$defs/non_empty_string" },
    "lifecycle_labels": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "lane_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/lane_kind" },
      "minItems": 1,
      "uniqueItems": true
    },
    "lane_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/lane_state" },
      "minItems": 1,
      "uniqueItems": true
    },
    "gap_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap_reason" },
      "minItems": 1,
      "uniqueItems": true
    },
    "lane_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/lane_action" },
      "minItems": 1,
      "uniqueItems": true
    },
    "release_blocking_lane_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/lane_row" },
      "minItems": 1
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/lane_rule" },
      "minItems": 1
    },
    "publication": { "$ref": "#/$defs/publication_decision_record" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "lane_kind": {
      "type": "string",
      "enum": [
        "critical_dependency_register",
        "fork_replace_log",
        "third_party_import_manifest",
        "reuse_spdx_notice_coverage"
      ]
    },
    "lane_state": {
      "type": "string",
      "enum": [
        "current",
        "on_waiver",
        "narrowed_stale",
        "narrowed_missing",
        "narrowed_unbacked",
        "narrowed_waiver_expired"
      ]
    },
    "gap_reason": {
      "type": "string",
      "enum": [
        "claim_label_narrowed",
        "packet_missing",
        "packet_freshness_breached",
        "evidence_incomplete",
        "artifact_unverified",
        "dependency_audit_gap",
        "fork_divergence",
        "import_mapping_failed",
        "license_coverage_gap",
        "waiver_expired",
        "owner_signoff_missing"
      ]
    },
    "lane_action": {
      "type": "string",
      "enum": [
        "hold_publication",
        "narrow_claim",
        "refresh_packet",
        "recapture_evidence",
        "request_owner_signoff"
      ]
    },
    "freshness_slo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
      "properties": {
        "target_max_age_days": { "type": "integer", "minimum": 1 },
        "warn_within_days": { "type": "integer", "minimum": 0 },
        "slo_register_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "freshness_slo_state": {
      "type": "string",
      "enum": ["current", "due_for_refresh", "breached", "missing"]
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_id", "packet_ref", "proof_index_ref", "freshness_slo", "slo_state"],
      "properties": {
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "proof_index_ref": { "$ref": "#/$defs/non_empty_string" },
        "captured_at": { "type": ["string", "null"], "format": "date" },
        "freshness_slo": { "$ref": "#/$defs/freshness_slo" },
        "slo_state": { "$ref": "#/$defs/freshness_slo_state" },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_ref", "signed_off"],
      "properties": {
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "signed_off": { "type": "boolean" },
        "signed_at": { "type": ["string", "null"], "format": "date" }
      }
    },
    "qualification_waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["waiver_ref", "expires_at", "reason"],
      "properties": {
        "waiver_ref": { "$ref": "#/$defs/non_empty_string" },
        "expires_at": { "type": "string", "format": "date" },
        "reason": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "lane_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "lane_kind",
        "subject_ref",
        "subject_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "lane_state",
        "proof_packet",
        "owner_signoff",
        "effective_label",
        "rationale"
      ],
      "properties": {
        "entry_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "lane_kind": { "$ref": "#/$defs/lane_kind" },
        "subject_ref": { "$ref": "#/$defs/non_empty_string" },
        "subject_summary": { "$ref": "#/$defs/non_empty_string" },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "$ref": "#/$defs/non_empty_string" },
        "claim_label": { "$ref": "#/$defs/non_empty_string" },
        "lane_state": { "$ref": "#/$defs/lane_state" },
        "proof_packet": { "$ref": "#/$defs/proof_packet" },
        "owner_signoff": { "$ref": "#/$defs/owner_signoff" },
        "waiver": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/qualification_waiver" }] },
        "active_gap_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/gap_reason" }
        },
        "effective_label": { "$ref": "#/$defs/non_empty_string" },
        "publication_destinations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "lane_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_states",
        "default_action",
        "blocks_publication",
        "rationale"
      ],
      "properties": {
        "rule_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "trigger_reason": { "$ref": "#/$defs/gap_reason" },
        "applies_to_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/lane_state" },
          "minItems": 1
        },
        "default_action": { "$ref": "#/$defs/lane_action" },
        "blocks_publication": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "publication_decision": {
      "type": "string",
      "enum": ["proceed", "hold"]
    },
    "publication_decision_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publication_gate", "decision", "rationale"],
      "properties": {
        "publication_gate": { "$ref": "#/$defs/non_empty_string" },
        "decision": { "$ref": "#/$defs/publication_decision" },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blocking_row_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows",
        "rows_holding_claim",
        "rows_narrowed",
        "rows_on_active_waiver",
        "total_active_gap_reasons",
        "rules_firing"
      ],
      "properties": {
        "total_rows": { "type": "integer", "minimum": 0 },
        "rows_holding_claim": { "type": "integer", "minimum": 0 },
        "rows_narrowed": { "type": "integer", "minimum": 0 },
        "rows_on_active_waiver": { "type": "integer", "minimum": 0 },
        "total_active_gap_reasons": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
