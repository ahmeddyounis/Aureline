{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/compatibility_row.schema.json",
  "title": "Aureline release compatibility row",
  "description": "Reusable row contract for release-time compatibility reports and certified-archetype reports. A row extends one seeded compat_row id from artifacts/compat/qualification_matrix_seed.yaml with source family/version, current report state, evidence refs, freshness, migration, deprecation, and export-routing fields so release, docs, support, and migration work all quote the same inspectable record.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "report_family",
    "row_id",
    "artifact_or_protocol_boundary_label",
    "claimed_surface",
    "source_family",
    "source_version",
    "support_class",
    "current_state",
    "qualification_evidence_status",
    "claimed_deployment_profiles",
    "version_skew_register_ref",
    "skew_window_class",
    "skew_window_summary",
    "current_skew_case_ref",
    "out_of_window_posture",
    "review_cadence",
    "retained_support_window",
    "deprecation_posture",
    "migration_guidance_refs",
    "issue_template_refs",
    "export_refs",
    "owner",
    "evidence_owner",
    "evidence_packet_refs",
    "supporting_evidence_refs",
    "known_deviations",
    "freshness",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for the release compatibility-row record."
    },
    "record_kind": {
      "type": "string",
      "const": "compatibility_row",
      "description": "Discriminator for the reusable row record."
    },
    "report_family": {
      "$ref": "#/$defs/report_family"
    },
    "row_id": {
      "type": "string",
      "pattern": "^compat_row:[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "description": "Stable row id from artifacts/compat/qualification_matrix_seed.yaml."
    },
    "artifact_or_protocol_boundary_label": {
      "type": "string",
      "pattern": "^boundary\\.[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "description": "Stable boundary label from the compatibility qualification matrix."
    },
    "claimed_surface": {
      "$ref": "#/$defs/non_empty_string",
      "description": "Claim-bearing surface this report row is speaking for."
    },
    "source_family": {
      "$ref": "#/$defs/non_empty_string",
      "description": "Family of source artifact, for example command_descriptor_schema, exact_build_identity, or reference_workspace_report."
    },
    "source_version": {
      "$ref": "#/$defs/non_empty_string",
      "description": "Semver, schema epoch, manifest revision, or similar source revision that was actually exercised."
    },
    "support_class": {
      "$ref": "#/$defs/support_class"
    },
    "current_state": {
      "$ref": "#/$defs/current_state"
    },
    "qualification_evidence_status": {
      "$ref": "#/$defs/qualification_evidence_status"
    },
    "claimed_deployment_profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/deployment_profile"
      },
      "description": "Deployment-profile ids this row currently speaks for."
    },
    "version_skew_register_ref": {
      "type": "string",
      "pattern": "^skew_register:[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "description": "Stable skew-register ref from artifacts/compat/version_skew_register.yaml."
    },
    "skew_window_class": {
      "$ref": "#/$defs/skew_window_class"
    },
    "skew_window_summary": {
      "$ref": "#/$defs/non_empty_string",
      "description": "Human-readable summary of the currently claimed compatibility or freshness window."
    },
    "current_skew_case_ref": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^skew_case:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
        }
      ],
      "description": "Current skew-case ref when the row maps directly to a named case from the register."
    },
    "out_of_window_posture": {
      "$ref": "#/$defs/out_of_window_posture"
    },
    "review_cadence": {
      "$ref": "#/$defs/review_cadence"
    },
    "retained_support_window": {
      "$ref": "#/$defs/non_empty_string",
      "description": "Plain-language statement of how long the claim remains supported after replacement or narrowing."
    },
    "deprecation_posture": {
      "$ref": "#/$defs/deprecation_posture"
    },
    "migration_guidance_refs": {
      "$ref": "#/$defs/ref_array",
      "description": "Docs, packet, or artifact refs that tell readers how to migrate or downgrade safely."
    },
    "issue_template_refs": {
      "allOf": [
        {
          "$ref": "#/$defs/ref_array"
        },
        {
          "minItems": 1
        }
      ],
      "description": "Issue-intake or template refs used when this row regresses."
    },
    "export_refs": {
      "allOf": [
        {
          "$ref": "#/$defs/ref_array"
        },
        {
          "minItems": 1
        }
      ],
      "description": "Stable export or downstream projection refs that carry this row to support, release, or other packet families."
    },
    "owner": {
      "$ref": "#/$defs/owner_ref",
      "description": "Primary owner for the row's compatibility burden."
    },
    "evidence_owner": {
      "$ref": "#/$defs/owner_ref",
      "description": "Owner accountable for the proof attached to this row."
    },
    "evidence_packet_refs": {
      "allOf": [
        {
          "$ref": "#/$defs/ref_array"
        },
        {
          "minItems": 1
        }
      ],
      "description": "Packet ids or packet paths that currently back the row's verdict."
    },
    "supporting_evidence_refs": {
      "allOf": [
        {
          "$ref": "#/$defs/ref_array"
        },
        {
          "minItems": 1
        }
      ],
      "description": "Supporting artifact refs such as schemas, fixtures, dashboards, or review docs."
    },
    "known_deviations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/known_deviation"
      },
      "description": "Known deviations or caveats that stay attached to the row."
    },
    "freshness": {
      "$ref": "#/$defs/freshness"
    },
    "archetype_matrix": {
      "$ref": "#/$defs/archetype_matrix"
    },
    "notes": {
      "$ref": "#/$defs/non_empty_string",
      "description": "Short free-form guidance that does not fit a structured field."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "report_family": {
            "const": "certified_archetype_report"
          }
        },
        "required": ["report_family"]
      },
      "then": {
        "required": ["archetype_matrix"]
      }
    }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "ref_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "owner_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Reviewable handle or team alias, for example '@release-dri' or 'release-evidence@team'."
    },
    "report_family": {
      "type": "string",
      "enum": [
        "compatibility_report",
        "certified_archetype_report"
      ],
      "description": "Which report family is carrying this row."
    },
    "support_class": {
      "type": "string",
      "enum": [
        "certified",
        "supported",
        "community",
        "experimental"
      ],
      "description": "Support-class taxonomy aligned with the PRD, the UX style guide, and the compatibility qualification seed."
    },
    "current_state": {
      "type": "string",
      "enum": [
        "supported",
        "best_effort",
        "untested",
        "degraded",
        "unsupported"
      ],
      "description": "Current report verdict for this row."
    },
    "qualification_evidence_status": {
      "type": "string",
      "enum": [
        "benchmark_seed_available",
        "schema_and_fixture_seeded",
        "normative_doc_seed_only",
        "reserved_no_fixture_yet"
      ],
      "description": "Seeded evidence-status vocabulary from artifacts/compat/qualification_matrix_seed.yaml."
    },
    "deployment_profile": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud"
      ],
      "description": "Deployment-profile vocabulary aligned with the compatibility qualification seed."
    },
    "skew_window_class": {
      "type": "string",
      "enum": [
        "coordinated_artifact_set_only",
        "exact_match",
        "same_schema_epoch_additive_only",
        "declared_adjacent_window",
        "published_sdk_support_window",
        "current_plus_previous_minor_or_lts",
        "certified_report_freshness_window"
      ],
      "description": "Skew-window taxonomy from the compatibility qualification seed."
    },
    "out_of_window_posture": {
      "type": "string",
      "enum": [
        "fail_closed",
        "read_only",
        "degraded",
        "explicitly_unsupported"
      ],
      "description": "Required posture once the row falls outside its declared window."
    },
    "review_cadence": {
      "type": "string",
      "enum": [
        "each_change",
        "per_milestone",
        "each_release"
      ],
      "description": "How frequently the row is expected to be reviewed."
    },
    "freshness_state": {
      "type": "string",
      "enum": [
        "current",
        "known_issues",
        "retest_pending",
        "stale",
        "community_reported",
        "unknown"
      ],
      "description": "Qualification-freshness vocabulary aligned with the UX style guide."
    },
    "known_deviation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deviation_id",
        "summary",
        "impact",
        "workaround",
        "owner",
        "issue_template_ref",
        "export_ref",
        "tracking_ref"
      ],
      "properties": {
        "deviation_id": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Stable local id for the deviation row."
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "impact": {
          "$ref": "#/$defs/non_empty_string"
        },
        "workaround": {
          "$ref": "#/$defs/non_empty_string"
        },
        "owner": {
          "$ref": "#/$defs/owner_ref"
        },
        "issue_template_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "export_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "tracking_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "deprecation_state": {
      "type": "string",
      "enum": [
        "none",
        "announced",
        "migration_required",
        "sunset_scheduled",
        "retired"
      ],
      "description": "Current deprecation posture of the row."
    },
    "deprecation_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "replacement_refs",
        "earliest_removal_scope",
        "disclosure_refs",
        "note"
      ],
      "properties": {
        "state": {
          "$ref": "#/$defs/deprecation_state"
        },
        "replacement_refs": {
          "$ref": "#/$defs/ref_array",
          "description": "Stable replacement refs when a row is being phased out."
        },
        "earliest_removal_scope": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/non_empty_string"
            }
          ],
          "description": "Release, channel, or date after which removal may happen."
        },
        "disclosure_refs": {
          "$ref": "#/$defs/ref_array",
          "description": "Release-note, docs, or known-limit refs that disclose the deprecation."
        },
        "note": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captured_at",
        "stale_after",
        "freshness_state",
        "next_review_target"
      ],
      "properties": {
        "captured_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 UTC timestamp when this row's evidence snapshot was captured."
        },
        "stale_after": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/non_empty_string"
            }
          ],
          "description": "ISO 8601 duration or another stable freshness token."
        },
        "freshness_state": {
          "$ref": "#/$defs/freshness_state"
        },
        "next_review_target": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Date, release train, or milestone target for the next required refresh."
        }
      }
    },
    "archetype_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "archetype_id",
        "hardware_profile_ref",
        "toolchain_ref",
        "reference_workspace_ref",
        "workflow_refs",
        "platform_profile_refs"
      ],
      "properties": {
        "archetype_id": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Canonical archetype id under review."
        },
        "hardware_profile_ref": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Reference hardware or host-profile ref backing the claim."
        },
        "toolchain_ref": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Toolchain version, declared-only assumption, or toolchain packet ref."
        },
        "reference_workspace_ref": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Reference workspace, repo slice, or archetype-seed ref."
        },
        "workflow_refs": {
          "allOf": [
            {
              "$ref": "#/$defs/ref_array"
            },
            {
              "minItems": 1
            }
          ],
          "description": "Workflow or benchmark-scenario refs that must pass for this archetype row."
        },
        "platform_profile_refs": {
          "allOf": [
            {
              "$ref": "#/$defs/ref_array"
            },
            {
              "minItems": 1
            }
          ],
          "description": "Claimed desktop-profile refs that narrow the archetype claim."
        }
      }
    }
  },
  "examples": [
    {
      "schema_version": 1,
      "record_kind": "compatibility_row",
      "report_family": "compatibility_report",
      "row_id": "compat_row:command_plane.command_descriptor_schema",
      "artifact_or_protocol_boundary_label": "boundary.commands.command_descriptor",
      "claimed_surface": "command_projection_and_execution_parity",
      "source_family": "command_descriptor_schema",
      "source_version": "schemas/commands/command_descriptor.schema.json@schema_version=1",
      "support_class": "supported",
      "current_state": "supported",
      "qualification_evidence_status": "schema_and_fixture_seeded",
      "claimed_deployment_profiles": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud"
      ],
      "version_skew_register_ref": "skew_register:command_plane.command_descriptor_schema",
      "skew_window_class": "same_schema_epoch_additive_only",
      "skew_window_summary": "Descriptor and invocation-session consumers stay in one additive schema epoch and preserve unknown additive fields.",
      "current_skew_case_ref": "skew_case:command_plane.same_schema_epoch",
      "out_of_window_posture": "fail_closed",
      "review_cadence": "each_change",
      "retained_support_window": "Retain support until the next published schema epoch or an explicit replacement packet narrows the claim.",
      "deprecation_posture": {
        "state": "none",
        "replacement_refs": [],
        "earliest_removal_scope": null,
        "disclosure_refs": [],
        "note": "No active deprecation notice on the command row."
      },
      "migration_guidance_refs": [
        "docs/commands/command_descriptor_contract.md"
      ],
      "issue_template_refs": [
        "docs/governance/dogfood_issue_taxonomy.md"
      ],
      "export_refs": [
        "support_bundle.semantic_readiness_packet"
      ],
      "owner": "@ahmeddyounis",
      "evidence_owner": "@ahmeddyounis",
      "evidence_packet_refs": [
        "compatibility.seed.command_plane"
      ],
      "supporting_evidence_refs": [
        "docs/commands/command_descriptor_contract.md",
        "schemas/commands/command_descriptor.schema.json",
        "fixtures/commands/command_descriptor_examples/README.md"
      ],
      "known_deviations": [
        {
          "deviation_id": "compat_deviation:command_plane.render_only_unknown_slot_hint",
          "summary": "A render-only surface may ignore a newly added additive UI-slot hint.",
          "impact": "Projection narrows but the record stays readable and attributable.",
          "workaround": "Keep the row at best_effort until the consumer learns the new hint.",
          "owner": "@ahmeddyounis",
          "issue_template_ref": "docs/governance/dogfood_issue_taxonomy.md",
          "export_ref": "support_bundle.semantic_readiness_packet",
          "tracking_ref": "skew_case:command_plane.render_only_unknown_slot_hint"
        }
      ],
      "freshness": {
        "captured_at": "2026-04-21T23:45:00Z",
        "stale_after": "P14D",
        "freshness_state": "current",
        "next_review_target": "next schema epoch change"
      },
      "notes": "Illustrative seed row only; this is not a live release packet."
    },
    {
      "schema_version": 1,
      "record_kind": "compatibility_row",
      "report_family": "certified_archetype_report",
      "row_id": "compat_row:certification.launch_archetype_matrix",
      "artifact_or_protocol_boundary_label": "boundary.certification.launch_archetype_matrix",
      "claimed_surface": "certified_archetype_and_launch_language_claims",
      "source_family": "reference_workspace_report",
      "source_version": "fixtures/benchmarks/corpus_manifest.yaml@manifest_revision=1",
      "support_class": "certified",
      "current_state": "supported",
      "qualification_evidence_status": "benchmark_seed_available",
      "claimed_deployment_profiles": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud"
      ],
      "version_skew_register_ref": "skew_register:certification.launch_archetype_matrix",
      "skew_window_class": "certified_report_freshness_window",
      "skew_window_summary": "Certified wording remains valid only while the linked reference workspace, workflow evidence, and caveat set remain fresh for the named build and profile set.",
      "current_skew_case_ref": "skew_case:certification.current_report_and_row_ids",
      "out_of_window_posture": "degraded",
      "review_cadence": "each_release",
      "retained_support_window": "Keep the row current until a fresher archetype report or an explicit downgrade notice replaces it.",
      "deprecation_posture": {
        "state": "none",
        "replacement_refs": [],
        "earliest_removal_scope": null,
        "disclosure_refs": [],
        "note": "No active deprecation notice on this archetype row."
      },
      "migration_guidance_refs": [
        "docs/release/compatibility_report_template.md"
      ],
      "issue_template_refs": [
        "docs/governance/dogfood_issue_taxonomy.md"
      ],
      "export_refs": [
        "release_evidence.claim_manifest"
      ],
      "owner": "@ahmeddyounis",
      "evidence_owner": "@ahmeddyounis",
      "evidence_packet_refs": [
        "certified_archetype.seed.rust_self_host"
      ],
      "supporting_evidence_refs": [
        "fixtures/workspaces/reference/small_rust_self_host_slice.json",
        "fixtures/benchmarks/corpus_manifest.yaml",
        "artifacts/perf/reference_laptop_matrix.yaml",
        "artifacts/platform/claimed_desktop_profiles.yaml"
      ],
      "known_deviations": [
        {
          "deviation_id": "compat_deviation:rust_self_host.profile_scope",
          "summary": "The example row is bounded to the macOS claimed desktop profile and the current self-host slice only.",
          "impact": "The row does not widen to other desktop profiles or a different repo slice without a refresh.",
          "workaround": "Treat every additional profile or slice as a separate row or refresh target.",
          "owner": "@ahmeddyounis",
          "issue_template_ref": "docs/governance/dogfood_issue_taxonomy.md",
          "export_ref": "release_evidence.claim_manifest",
          "tracking_ref": "compat_row:desktop.platform_conformance_profiles"
        }
      ],
      "freshness": {
        "captured_at": "2026-04-21T23:45:00Z",
        "stale_after": "P14D",
        "freshness_state": "current",
        "next_review_target": "stable-rc-1"
      },
      "archetype_matrix": {
        "archetype_id": "rust_workspace_self_host",
        "hardware_profile_ref": "ref.arm64.macos15.apple_silicon_14in",
        "toolchain_ref": "rust_toolchain_pinned_v1",
        "reference_workspace_ref": "refws.small_rust_self_host_slice",
        "workflow_refs": [
          "workflow.first_useful_edit_rust_self_host"
        ],
        "platform_profile_refs": [
          "macos_15_plus_universal"
        ]
      },
      "notes": "Illustrative seed row only; this is not a live launch claim."
    }
  ]
}
