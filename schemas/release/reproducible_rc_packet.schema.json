{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/reproducible_rc_packet.schema.json",
  "title": "Aureline reproducible release-candidate packet",
  "description": "Boundary schema for a reproducible_rc_packet record. The packet binds one promoted candidate, clean-room rebuild evidence, a rebuilt artifact-graph snapshot, exact-build publication checks, and support/export consumers into one auditable release-control artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "generated_at",
    "as_of",
    "owner",
    "claim_state",
    "source_refs",
    "candidate",
    "freshness",
    "clean_room_rebuild",
    "publication_checks",
    "support_projection",
    "consuming_lanes",
    "acceptance"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "record_kind": { "const": "reproducible_rc_packet" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/date_time" },
    "as_of": { "$ref": "#/$defs/date" },
    "owner": { "$ref": "#/$defs/non_empty_string" },
    "claim_state": { "$ref": "#/$defs/non_empty_string" },
    "source_refs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/repo_or_opaque_ref" }
    },
    "candidate": { "$ref": "#/$defs/candidate" },
    "freshness": { "$ref": "#/$defs/freshness" },
    "clean_room_rebuild": { "$ref": "#/$defs/clean_room_rebuild" },
    "publication_checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/publication_check" }
    },
    "support_projection": { "$ref": "#/$defs/support_projection" },
    "consuming_lanes": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "acceptance": { "$ref": "#/$defs/acceptance" }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "date_time": {
      "type": "string",
      "format": "date-time"
    },
    "duration": {
      "type": "string",
      "pattern": "^P[0-9]+D$"
    },
    "repo_or_opaque_ref": {
      "type": "string",
      "minLength": 1
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/repo_or_opaque_ref" },
      "uniqueItems": true
    },
    "non_empty_ref_array": {
      "allOf": [
        { "$ref": "#/$defs/ref_array" },
        { "minItems": 1 }
      ]
    },
    "release_candidate_ref": {
      "type": "string",
      "pattern": "^release_candidate:[a-z0-9]+(?:[._:-][a-z0-9_]+)*$"
    },
    "artifact_bundle_ref": {
      "type": "string",
      "pattern": "^artifact_bundle:[a-z0-9]+(?:[._:-][a-z0-9_]+)*$"
    },
    "exact_build_identity_ref": {
      "type": "string",
      "pattern": "^build-id:aureline:[a-z0-9._:-]+(?:-[a-z0-9._:-]+)*$"
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_candidate_ref",
        "version",
        "artifact_bundle_ref",
        "exact_build_identity_ref",
        "promoted_artifact_graph_ref",
        "promoted_support_projection_ref",
        "rebuilt_artifact_graph_ref"
      ],
      "properties": {
        "release_candidate_ref": { "$ref": "#/$defs/release_candidate_ref" },
        "version": { "$ref": "#/$defs/non_empty_string" },
        "artifact_bundle_ref": { "$ref": "#/$defs/artifact_bundle_ref" },
        "exact_build_identity_ref": { "$ref": "#/$defs/exact_build_identity_ref" },
        "promoted_artifact_graph_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "promoted_support_projection_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "rebuilt_artifact_graph_ref": { "$ref": "#/$defs/repo_or_opaque_ref" }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captured_at",
        "stale_after",
        "freshness_class",
        "stale_propagation_profile"
      ],
      "properties": {
        "captured_at": { "$ref": "#/$defs/date_time" },
        "stale_after": { "$ref": "#/$defs/duration" },
        "freshness_class": { "$ref": "#/$defs/non_empty_string" },
        "stale_propagation_profile": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "clean_room_rebuild": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rebuilt_artifact_graph_snapshot_id",
        "lane_command",
        "offline_command",
        "packet_ref",
        "capture_ref",
        "build_identity_ref",
        "evidence_state",
        "rebuild_result_state",
        "byte_identity_claimed",
        "accepted_rebuild_states",
        "evidence_refs"
      ],
      "properties": {
        "rebuilt_artifact_graph_snapshot_id": { "$ref": "#/$defs/non_empty_string" },
        "lane_command": { "$ref": "#/$defs/non_empty_string" },
        "offline_command": { "$ref": "#/$defs/non_empty_string" },
        "packet_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "capture_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "build_identity_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "evidence_state": { "$ref": "#/$defs/non_empty_string" },
        "rebuild_result_state": { "$ref": "#/$defs/non_empty_string" },
        "byte_identity_claimed": { "type": "boolean" },
        "accepted_rebuild_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "evidence_refs": { "$ref": "#/$defs/non_empty_ref_array" }
      }
    },
    "publication_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "check_class",
        "source_ref",
        "required_state",
        "actual_state",
        "blocks_publication",
        "support_ref"
      ],
      "properties": {
        "check_id": { "$ref": "#/$defs/non_empty_string" },
        "check_class": { "$ref": "#/$defs/non_empty_string" },
        "source_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "required_state": { "$ref": "#/$defs/non_empty_string" },
        "actual_state": { "$ref": "#/$defs/non_empty_string" },
        "blocks_publication": { "type": "boolean" },
        "support_ref": { "$ref": "#/$defs/repo_or_opaque_ref" }
      }
    },
    "support_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projection_id",
        "output_ref",
        "redaction_class",
        "consumer_refs"
      ],
      "properties": {
        "projection_id": { "$ref": "#/$defs/non_empty_string" },
        "output_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "redaction_class": { "$ref": "#/$defs/non_empty_string" },
        "consumer_refs": { "$ref": "#/$defs/non_empty_ref_array" }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validation_commands",
        "fixture_manifest_ref",
        "accepted_states",
        "known_limit_refs"
      ],
      "properties": {
        "validation_commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "minItems": 1
        },
        "fixture_manifest_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "accepted_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "known_limit_refs": { "$ref": "#/$defs/ref_array" }
      }
    }
  }
}
