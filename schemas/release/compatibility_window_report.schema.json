{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/compatibility_window_report.schema.json",
  "title": "Aureline compatibility-window report and migration-helper handoff record",
  "description": "Boundary schema for the compatibility_window_report_record frozen in docs/release/end_of_support_and_migration_contract.md. The record carries one machine-readable scope envelope (extensions, automations, command or action schemas, profiles and settings, workspace or layout schemas, remote agents, helpers or sidecars, marketplace listings, CLI or SDK surface, support-export format), one row-by-row category breakdown with typed window state per category, the export path the report MUST be downloadable through, the migration-helper handoff action set kept as DISTINCT entries (scan, preview, backup_or_checkpoint, apply, rollback, dry_run, export_environment_summary), the backup-or-checkpoint requirement gate that fires before any apply that alters durable user state or supported compatibility mode, and the cross-link back to the originating end-of-support notice. The migration-helper handoff actions are kept separate rather than collapsed into one opaque \"upgrade\" button: the schema enforces that an apply action cannot be admitted without paired rollback and backup_or_checkpoint actions on the same record. Raw extension manifests, raw user state, raw signing material, raw policy bodies, raw release prose, and raw artifact bytes never appear; records carry refs, typed states, and bounded reviewable summaries only.",
  "type": "object",
  "$ref": "#/$defs/compatibility_window_report_record",
  "$defs": {
    "compatibility_window_report_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the compatibility-window report payload shape. Current value is 1."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable identifier safe for live surfaces, support bundles, public-proof packets, diagnostics exports, release packets, and migration exports. Raw URLs, raw hostnames, raw absolute paths, raw policy rule bodies, and raw secret material never appear here."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "utc_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_utc_datetime": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/utc_datetime" }
      ]
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_id" },
      "uniqueItems": true
    },
    "non_empty_ref_array": {
      "allOf": [
        { "$ref": "#/$defs/ref_array" },
        { "minItems": 1 }
      ]
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario", "contract_sections"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "contract_sections": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "exercised_axes": { "type": "object", "additionalProperties": true }
      },
      "description": "Optional worked-example prelude carried on fixtures; never part of the runtime record."
    },
    "affected_category_class": {
      "type": "string",
      "enum": [
        "extensions",
        "automations_or_macros",
        "command_or_action_schemas",
        "profiles_and_settings",
        "workspace_or_layout_schemas",
        "remote_agents",
        "helpers_or_sidecars",
        "marketplace_listings",
        "cli_or_sdk_surface",
        "support_export_format"
      ],
      "description": "Closed affected-category vocabulary mirroring the affected_scope_class vocabulary on /schemas/release/end_of_support_notice.schema.json restricted to the categories that have row-by-row compatibility breakdowns. desktop_product_build and release_channel are notice-level scopes and are not category rows."
    },
    "category_window_state_class": {
      "type": "string",
      "enum": [
        "inside_supported_window_no_action",
        "approaching_end_of_window_action_within_named_window",
        "past_end_of_window_higher_risk_named",
        "breaking_change_ahead_inspect_and_export_before_ship",
        "actively_deprecated_with_replacement_named",
        "not_applicable_refusal_state"
      ],
      "description": "Closed category-window-state vocabulary. The not_applicable_refusal_state value is reserved for category rows whose compatibility cannot be evaluated yet (typically because a row has been registered but not seeded)."
    },
    "migration_helper_action_class": {
      "type": "string",
      "enum": [
        "scan_environment_read_only",
        "preview_planned_changes_dry_run",
        "backup_or_checkpoint_durable_state",
        "apply_planned_changes",
        "rollback_to_checkpoint",
        "dry_run_apply_no_durable_writes",
        "export_environment_summary_for_review"
      ],
      "description": "Closed migration-helper-action vocabulary. These are kept DISTINCT rather than collapsed into one opaque upgrade button; the schema enforces that an apply action requires paired rollback and backup actions on the same record."
    },
    "action_routing_kind_class": {
      "type": "string",
      "enum": [
        "interactive_user_initiated",
        "headless_dry_run_only",
        "support_export_only",
        "blocked_by_policy"
      ],
      "description": "Closed action-routing vocabulary. Determines which surfaces may invoke the action. Generic \"automatic\" routing is non-conforming."
    },
    "backup_requirement_class": {
      "type": "string",
      "enum": [
        "one_click_backup_required_before_apply",
        "one_click_checkpoint_required_before_apply",
        "backup_required_compat_mode_change",
        "backup_not_required_no_durable_state_altered",
        "backup_unsupported_inspect_only_report"
      ],
      "description": "Closed backup-or-checkpoint requirement vocabulary. apply actions whose mutation_class alters durable user state or supported compatibility mode MUST resolve to one_click_backup_required_before_apply, one_click_checkpoint_required_before_apply, or backup_required_compat_mode_change."
    },
    "mutation_class": {
      "type": "string",
      "enum": [
        "no_mutation_inspect_only",
        "alters_durable_user_state",
        "alters_supported_compatibility_mode",
        "alters_durable_user_state_and_compatibility_mode"
      ],
      "description": "Closed mutation-class vocabulary describing what an apply action mutates. Generic \"upgrade\" mutations are non-conforming; the migration helper MUST disclose which mutation class it lands in."
    },
    "export_path_class": {
      "type": "string",
      "enum": [
        "compatibility_window_report_yaml_export",
        "compatibility_window_report_json_export",
        "support_bundle_compatibility_packet",
        "headless_dry_run_packet",
        "release_evidence_packet_link"
      ],
      "description": "Closed export-path vocabulary. Every record MUST bind at least one export path so the report is downloadable BEFORE any platform change ships."
    },
    "export_path_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_path_class",
        "export_artifact_ref",
        "export_format_label",
        "export_summary"
      ],
      "properties": {
        "export_path_class": { "$ref": "#/$defs/export_path_class" },
        "export_artifact_ref": { "$ref": "#/$defs/opaque_id" },
        "export_format_label": { "$ref": "#/$defs/reviewable_label" },
        "export_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "category_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "affected_category_class",
        "category_window_state_class",
        "category_label",
        "compatibility_row_refs",
        "version_skew_register_refs",
        "support_window_badge_refs",
        "extension_impact_forecast_refs",
        "named_replacement_label",
        "remediation_summary"
      ],
      "properties": {
        "row_id": {
          "type": "string",
          "pattern": "^compat_window_row:[a-z0-9]+(?:[._-][a-z0-9]+)*$",
          "description": "Stable row id. Quoted by end-of-support notices, update-center banners, About panels, and migration-helper handoff packets."
        },
        "affected_category_class": { "$ref": "#/$defs/affected_category_class" },
        "category_window_state_class": { "$ref": "#/$defs/category_window_state_class" },
        "category_label": { "$ref": "#/$defs/reviewable_label" },
        "compatibility_row_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Refs into /schemas/release/compatibility_row.schema.json rows backing this category row. Empty when no qualified compatibility row exists yet (the row's window state MUST then be not_applicable_refusal_state or breaking_change_ahead_inspect_and_export_before_ship)."
        },
        "version_skew_register_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Refs into /artifacts/compat/version_skew_register.yaml rows so the skew posture is reviewable per category."
        },
        "support_window_badge_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Refs into /schemas/release/support_window_badge.schema.json badges that this row narrows."
        },
        "extension_impact_forecast_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Refs into /schemas/release/extension_impact_forecast.schema.json rows when the affected category is extensions, automations_or_macros, or marketplace_listings."
        },
        "named_replacement_label": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_label" }
          ],
          "description": "Reviewable label naming the supported replacement, supported archetype, or supported alternative. Required when category_window_state_class is actively_deprecated_with_replacement_named; null otherwise."
        },
        "remediation_summary": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "description": "actively_deprecated_with_replacement_named rows MUST quote a non-null named_replacement_label so the row never collapses to a generic \"deprecated\" chip.",
          "if": {
            "properties": {
              "category_window_state_class": { "const": "actively_deprecated_with_replacement_named" }
            },
            "required": ["category_window_state_class"]
          },
          "then": {
            "properties": {
              "named_replacement_label": { "not": { "type": "null" } }
            }
          }
        },
        {
          "description": "extensions, automations_or_macros, and marketplace_listings rows whose window state is past_end_of_window_higher_risk_named, actively_deprecated_with_replacement_named, or breaking_change_ahead_inspect_and_export_before_ship MUST cite at least one extension_impact_forecast_ref so the row is backed by typed forecast evidence rather than free-text caveats.",
          "if": {
            "properties": {
              "affected_category_class": {
                "enum": ["extensions", "automations_or_macros", "marketplace_listings"]
              },
              "category_window_state_class": {
                "enum": [
                  "past_end_of_window_higher_risk_named",
                  "actively_deprecated_with_replacement_named",
                  "breaking_change_ahead_inspect_and_export_before_ship"
                ]
              }
            },
            "required": ["affected_category_class", "category_window_state_class"]
          },
          "then": {
            "properties": {
              "extension_impact_forecast_refs": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "migration_helper_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_class",
        "action_label",
        "action_route_ref",
        "action_routing_kind_class",
        "mutation_class",
        "preview_diff_ref",
        "checkpoint_ref",
        "rollback_ref",
        "export_artifact_ref",
        "policy_ref",
        "action_summary"
      ],
      "properties": {
        "action_class": { "$ref": "#/$defs/migration_helper_action_class" },
        "action_label": { "$ref": "#/$defs/reviewable_label" },
        "action_route_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "action_routing_kind_class": { "$ref": "#/$defs/action_routing_kind_class" },
        "mutation_class": { "$ref": "#/$defs/mutation_class" },
        "preview_diff_ref": {
          "$ref": "#/$defs/nullable_opaque_id",
          "description": "Stable ref into a /schemas/migration/import_diff_preview.schema.json record or comparable preview packet. Required when action_class is preview_planned_changes_dry_run, dry_run_apply_no_durable_writes, or apply_planned_changes."
        },
        "checkpoint_ref": {
          "$ref": "#/$defs/nullable_opaque_id",
          "description": "Stable ref into a /schemas/migration/import_rollback_checkpoint.schema.json record or comparable durable-state checkpoint. Required when action_class is backup_or_checkpoint_durable_state, apply_planned_changes (whose mutation_class alters durable state or compatibility mode), or rollback_to_checkpoint."
        },
        "rollback_ref": {
          "$ref": "#/$defs/nullable_opaque_id",
          "description": "Stable ref into a rollback path packet (e.g. update_manifest rollback panel). Required when action_class is rollback_to_checkpoint."
        },
        "export_artifact_ref": {
          "$ref": "#/$defs/nullable_opaque_id",
          "description": "Stable ref into a release-evidence packet, support bundle, or compatibility-window report export. Required when action_class is export_environment_summary_for_review."
        },
        "policy_ref": {
          "$ref": "#/$defs/nullable_opaque_id",
          "description": "Stable ref into a policy packet when action_routing_kind_class is blocked_by_policy. Null otherwise."
        },
        "action_summary": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "description": "scan_environment_read_only and dry_run_apply_no_durable_writes actions MUST be inspect-only (mutation_class no_mutation_inspect_only).",
          "if": {
            "properties": {
              "action_class": {
                "enum": ["scan_environment_read_only", "dry_run_apply_no_durable_writes"]
              }
            },
            "required": ["action_class"]
          },
          "then": {
            "properties": {
              "mutation_class": { "const": "no_mutation_inspect_only" }
            }
          }
        },
        {
          "description": "preview_planned_changes_dry_run actions are inspect-only and MUST cite a non-null preview_diff_ref.",
          "if": {
            "properties": {
              "action_class": { "const": "preview_planned_changes_dry_run" }
            },
            "required": ["action_class"]
          },
          "then": {
            "properties": {
              "mutation_class": { "const": "no_mutation_inspect_only" },
              "preview_diff_ref": { "not": { "type": "null" } }
            }
          }
        },
        {
          "description": "backup_or_checkpoint_durable_state actions MUST cite a non-null checkpoint_ref.",
          "if": {
            "properties": {
              "action_class": { "const": "backup_or_checkpoint_durable_state" }
            },
            "required": ["action_class"]
          },
          "then": {
            "properties": {
              "checkpoint_ref": { "not": { "type": "null" } }
            }
          }
        },
        {
          "description": "rollback_to_checkpoint actions MUST cite a non-null rollback_ref AND a non-null checkpoint_ref so the rollback target is reviewable BEFORE invocation.",
          "if": {
            "properties": {
              "action_class": { "const": "rollback_to_checkpoint" }
            },
            "required": ["action_class"]
          },
          "then": {
            "properties": {
              "rollback_ref": { "not": { "type": "null" } },
              "checkpoint_ref": { "not": { "type": "null" } }
            }
          }
        },
        {
          "description": "apply_planned_changes actions MUST cite a non-null preview_diff_ref so the apply is reviewed BEFORE durable writes.",
          "if": {
            "properties": {
              "action_class": { "const": "apply_planned_changes" }
            },
            "required": ["action_class"]
          },
          "then": {
            "properties": {
              "preview_diff_ref": { "not": { "type": "null" } }
            }
          }
        },
        {
          "description": "apply_planned_changes actions whose mutation_class alters durable user state or supported compatibility mode MUST cite a non-null checkpoint_ref so the rollback target is reviewable BEFORE durable writes.",
          "if": {
            "properties": {
              "action_class": { "const": "apply_planned_changes" },
              "mutation_class": {
                "enum": [
                  "alters_durable_user_state",
                  "alters_supported_compatibility_mode",
                  "alters_durable_user_state_and_compatibility_mode"
                ]
              }
            },
            "required": ["action_class", "mutation_class"]
          },
          "then": {
            "properties": {
              "checkpoint_ref": { "not": { "type": "null" } }
            }
          }
        },
        {
          "description": "export_environment_summary_for_review actions MUST cite a non-null export_artifact_ref.",
          "if": {
            "properties": {
              "action_class": { "const": "export_environment_summary_for_review" }
            },
            "required": ["action_class"]
          },
          "then": {
            "properties": {
              "export_artifact_ref": { "not": { "type": "null" } }
            }
          }
        },
        {
          "description": "Actions whose action_routing_kind_class is blocked_by_policy MUST cite a non-null policy_ref so the block is reviewable.",
          "if": {
            "properties": {
              "action_routing_kind_class": { "const": "blocked_by_policy" }
            },
            "required": ["action_routing_kind_class"]
          },
          "then": {
            "properties": {
              "policy_ref": { "not": { "type": "null" } }
            }
          }
        }
      ]
    },
    "migration_helper_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actions", "backup_requirement", "handoff_summary"],
      "properties": {
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/migration_helper_action" },
          "description": "Migration-helper handoff actions. Each action_class is allowed at most once per record so the actions stay DISTINCT (uniqueness is enforced by the schema's per-class containment rules in the parent record)."
        },
        "backup_requirement": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "backup_requirement_class",
            "checkpoint_ref",
            "one_click_route_ref",
            "backup_summary"
          ],
          "properties": {
            "backup_requirement_class": { "$ref": "#/$defs/backup_requirement_class" },
            "checkpoint_ref": {
              "$ref": "#/$defs/nullable_opaque_id",
              "description": "Stable checkpoint ref the one-click backup or checkpoint produces. Required when backup_requirement_class is one of the three required-before-apply classes; null otherwise."
            },
            "one_click_route_ref": {
              "$ref": "#/$defs/nullable_opaque_id",
              "description": "Stable route ref into the surface that performs the one-click backup or checkpoint. Required when backup_requirement_class is one of the three required-before-apply classes; null otherwise."
            },
            "backup_summary": { "$ref": "#/$defs/reviewable_sentence" }
          },
          "allOf": [
            {
              "description": "one_click_backup_required_before_apply, one_click_checkpoint_required_before_apply, and backup_required_compat_mode_change MUST cite both a non-null checkpoint_ref and a non-null one_click_route_ref so the one-click control is reviewable BEFORE apply.",
              "if": {
                "properties": {
                  "backup_requirement_class": {
                    "enum": [
                      "one_click_backup_required_before_apply",
                      "one_click_checkpoint_required_before_apply",
                      "backup_required_compat_mode_change"
                    ]
                  }
                },
                "required": ["backup_requirement_class"]
              },
              "then": {
                "properties": {
                  "checkpoint_ref": { "not": { "type": "null" } },
                  "one_click_route_ref": { "not": { "type": "null" } }
                }
              }
            }
          ]
        },
        "handoff_summary": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "description": "An apply_planned_changes action on this handoff packet MUST be paired with a rollback_to_checkpoint action on the same packet so the rollback target is named BEFORE the apply runs. The migration-helper handoff vocabulary keeps these actions DISTINCT.",
          "if": {
            "properties": {
              "actions": {
                "contains": {
                  "properties": { "action_class": { "const": "apply_planned_changes" } },
                  "required": ["action_class"]
                }
              }
            }
          },
          "then": {
            "properties": {
              "actions": {
                "contains": {
                  "properties": { "action_class": { "const": "rollback_to_checkpoint" } },
                  "required": ["action_class"]
                }
              }
            }
          }
        },
        {
          "description": "An apply_planned_changes action whose mutation_class alters durable user state or supported compatibility mode MUST be paired with a backup_or_checkpoint_durable_state action AND with a backup_requirement_class that demands the one-click backup BEFORE apply.",
          "if": {
            "properties": {
              "actions": {
                "contains": {
                  "properties": {
                    "action_class": { "const": "apply_planned_changes" },
                    "mutation_class": {
                      "enum": [
                        "alters_durable_user_state",
                        "alters_supported_compatibility_mode",
                        "alters_durable_user_state_and_compatibility_mode"
                      ]
                    }
                  },
                  "required": ["action_class", "mutation_class"]
                }
              }
            }
          },
          "then": {
            "properties": {
              "actions": {
                "contains": {
                  "properties": {
                    "action_class": { "const": "backup_or_checkpoint_durable_state" }
                  },
                  "required": ["action_class"]
                }
              },
              "backup_requirement": {
                "properties": {
                  "backup_requirement_class": {
                    "enum": [
                      "one_click_backup_required_before_apply",
                      "one_click_checkpoint_required_before_apply",
                      "backup_required_compat_mode_change"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "description": "Action classes are admitted at most once per handoff packet so scan, preview, backup, apply, rollback, dry-run, and export remain distinct entries rather than collapsed into one opaque \"upgrade\" button. Enforced by per-class contains-then-not-contains-twice rules below.",
          "allOf": [
            {
              "if": {
                "properties": {
                  "actions": {
                    "contains": {
                      "properties": { "action_class": { "const": "scan_environment_read_only" } },
                      "required": ["action_class"]
                    }
                  }
                }
              },
              "then": {
                "properties": {
                  "actions": {
                    "not": {
                      "contains": {
                        "properties": { "action_class": { "const": "scan_environment_read_only" } },
                        "required": ["action_class"]
                      },
                      "minContains": 2
                    }
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "actions": {
                    "contains": {
                      "properties": { "action_class": { "const": "preview_planned_changes_dry_run" } },
                      "required": ["action_class"]
                    }
                  }
                }
              },
              "then": {
                "properties": {
                  "actions": {
                    "not": {
                      "contains": {
                        "properties": { "action_class": { "const": "preview_planned_changes_dry_run" } },
                        "required": ["action_class"]
                      },
                      "minContains": 2
                    }
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "actions": {
                    "contains": {
                      "properties": { "action_class": { "const": "backup_or_checkpoint_durable_state" } },
                      "required": ["action_class"]
                    }
                  }
                }
              },
              "then": {
                "properties": {
                  "actions": {
                    "not": {
                      "contains": {
                        "properties": { "action_class": { "const": "backup_or_checkpoint_durable_state" } },
                        "required": ["action_class"]
                      },
                      "minContains": 2
                    }
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "actions": {
                    "contains": {
                      "properties": { "action_class": { "const": "apply_planned_changes" } },
                      "required": ["action_class"]
                    }
                  }
                }
              },
              "then": {
                "properties": {
                  "actions": {
                    "not": {
                      "contains": {
