{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/install_diagnostics.schema.json",
  "title": "Aureline exact-build install diagnostics packet",
  "description": "Boundary schema for install diagnostics that expose install mode, channel, updater owner, state roots, exact-build identity, support-export truth, and fleet rollout inventory without leaking host-specific paths or secrets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "packet_id",
    "generated_from_topology_packet_id",
    "contract_refs",
    "exact_build_identity_refs",
    "rows"
  ],
  "properties": {
    "record_kind": { "const": "install_diagnostics_packet" },
    "schema_version": { "const": 1 },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_from_topology_packet_id": { "$ref": "#/$defs/non_empty_string" },
    "contract_refs": { "$ref": "#/$defs/contract_refs" },
    "exact_build_identity_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/exact_build_identity_ref" },
      "uniqueItems": true
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/diagnostic_row" }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "repo_or_opaque_ref": {
      "type": "string",
      "minLength": 1
    },
    "exact_build_identity_ref": {
      "type": "string",
      "pattern": "^build-id:aureline:[a-z0-9._:-]+(?:-[a-z0-9._:-]+)*$"
    },
    "platform_class": {
      "type": "string",
      "enum": ["windows", "macos", "linux", "air_gap_bundle_target"]
    },
    "install_mode_class": {
      "type": "string",
      "enum": [
        "per_user_installed",
        "per_machine_installed",
        "portable",
        "offline_bundle",
        "managed_deployed",
        "side_by_side_preview"
      ]
    },
    "channel_class": {
      "type": ["string", "null"],
      "enum": ["stable", "preview", "beta", "lts", "portable_stable", "portable_preview", null]
    },
    "updater_owner_class": {
      "type": "string",
      "enum": ["user", "admin", "external_package_manager", "managed_fleet", "none"]
    },
    "binary_root_class": {
      "type": "string",
      "enum": [
        "per_user_profile_program_area",
        "per_machine_program_area",
        "portable_directory",
        "offline_bundle_extracted_program_area",
        "admin_pinned_program_area",
        "external_package_manager_owned_area"
      ]
    },
    "rollout_ring_class": {
      "type": "string",
      "enum": ["canary", "pilot", "broad", "lts"]
    },
    "topology_surface_class": {
      "type": "string",
      "enum": ["about", "update", "diagnostics", "install_review", "cli", "support_export"]
    },
    "exact_build_manifest_state": {
      "type": "string",
      "enum": ["present", "reserved", "blocked"]
    },
    "state_root_isolation_class": {
      "type": "string",
      "enum": [
        "channel_owned",
        "portable_colocated",
        "admin_policy_owned",
        "mirror_metadata_owned",
        "shared_read_only"
      ]
    },
    "state_root_review_class": {
      "type": "string",
      "enum": [
        "no_review_needed",
        "explicit_import_review_required",
        "portable_no_os_ownership",
        "admin_policy_review_required",
        "mirror_verification_review_required"
      ]
    },
    "fleet_evidence_class": {
      "type": "string",
      "enum": [
        "ring_assignment",
        "exact_build_inventory",
        "managed_package_report",
        "policy_root",
        "rollback_target",
        "verification_status",
        "support_export"
      ]
    },
    "install_verification_state": {
      "type": "string",
      "enum": ["verified", "reserved", "blocked"]
    },
    "contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "install_topology_packet_ref",
        "install_topology_matrix_ref",
        "state_root_map_ref",
        "exact_build_identity_schema_ref",
        "artifact_graph_ref",
        "managed_package_report_seed_ref"
      ],
      "properties": {
        "install_topology_packet_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "install_topology_matrix_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "state_root_map_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "exact_build_identity_schema_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "artifact_graph_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "managed_package_report_seed_ref": { "$ref": "#/$defs/repo_or_opaque_ref" }
      }
    },
    "exact_build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exact_build_identity_ref",
        "build_identity_source_ref",
        "artifact_graph_ref",
        "release_channel_class",
        "product_version",
        "source_revision_ref",
        "manifest_state"
      ],
      "properties": {
        "exact_build_identity_ref": { "$ref": "#/$defs/exact_build_identity_ref" },
        "build_identity_source_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "artifact_graph_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "release_channel_class": {
          "type": "string",
          "enum": ["dev_local", "nightly", "preview", "beta", "stable", "lts", "hotfix"]
        },
        "product_version": { "$ref": "#/$defs/non_empty_string" },
        "source_revision_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "manifest_state": { "$ref": "#/$defs/exact_build_manifest_state" }
      }
    },
    "state_root": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_root_ref",
        "isolation_class",
        "owning_channel_class",
        "exposed_in_product",
        "exposed_in_cli",
        "exposed_in_support_export",
        "contains_secret_material",
        "review_class"
      ],
      "properties": {
        "state_root_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "isolation_class": { "$ref": "#/$defs/state_root_isolation_class" },
        "owning_channel_class": { "$ref": "#/$defs/channel_class" },
        "exposed_in_product": { "type": "boolean" },
        "exposed_in_cli": { "type": "boolean" },
        "exposed_in_support_export": { "type": "boolean" },
        "contains_secret_material": { "type": "boolean" },
        "review_class": { "$ref": "#/$defs/state_root_review_class" }
      }
    },
    "fleet_rollout": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "rollout_ring_class",
        "managed_package_report_ref",
        "inventory_probe_ref",
        "policy_root_refs",
        "rollback_target_class",
        "exact_build_identity_ref",
        "evidence",
        "inventory_probe_available",
        "deprovision_preserves_local_work"
      ],
      "properties": {
        "rollout_ring_class": { "$ref": "#/$defs/rollout_ring_class" },
        "managed_package_report_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "inventory_probe_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "policy_root_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/repo_or_opaque_ref" },
          "uniqueItems": true
        },
        "rollback_target_class": { "$ref": "#/$defs/non_empty_string" },
        "exact_build_identity_ref": { "$ref": "#/$defs/exact_build_identity_ref" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fleet_evidence_class" },
          "uniqueItems": true
        },
        "inventory_probe_available": { "type": "boolean" },
        "deprovision_preserves_local_work": { "type": "boolean" }
      }
    },
    "diagnostic_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diagnostic_row_id",
        "topology_row_id",
        "install_profile_card_ref",
        "platform_class",
        "install_mode_class",
        "channel_class",
        "paired_channel_class",
        "updater_owner_class",
        "binary_root_class",
        "exact_build",
        "durable_state_roots",
        "policy_root_refs",
        "side_by_side_peer_row_ids",
        "state_root_review_class",
        "fleet_rollout",
        "last_verification_state",
        "rollback_target_class",
        "support_bundle_ref",
        "redaction_class",
        "surface_claims"
      ],
      "properties": {
        "diagnostic_row_id": { "$ref": "#/$defs/non_empty_string" },
        "topology_row_id": { "$ref": "#/$defs/non_empty_string" },
        "install_profile_card_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "platform_class": { "$ref": "#/$defs/platform_class" },
        "install_mode_class": { "$ref": "#/$defs/install_mode_class" },
        "channel_class": { "$ref": "#/$defs/channel_class" },
        "paired_channel_class": { "$ref": "#/$defs/channel_class" },
        "updater_owner_class": { "$ref": "#/$defs/updater_owner_class" },
        "binary_root_class": { "$ref": "#/$defs/binary_root_class" },
        "exact_build": { "$ref": "#/$defs/exact_build" },
        "durable_state_roots": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/state_root" }
        },
        "policy_root_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/repo_or_opaque_ref" },
          "uniqueItems": true
        },
        "side_by_side_peer_row_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "state_root_review_class": { "$ref": "#/$defs/state_root_review_class" },
        "fleet_rollout": { "$ref": "#/$defs/fleet_rollout" },
        "last_verification_state": { "$ref": "#/$defs/install_verification_state" },
        "rollback_target_class": { "$ref": "#/$defs/non_empty_string" },
        "support_bundle_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "redaction_class": { "const": "metadata_only_no_paths_or_secrets" },
        "surface_claims": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/topology_surface_class" },
          "uniqueItems": true
        }
      }
    }
  }
}
