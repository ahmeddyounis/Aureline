{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/extension_impact_forecast.schema.json",
  "title": "Aureline extension and package impact forecast",
  "description": "Boundary schema for extension_impact_forecast_record frozen in docs/release/update_ready_review_contract.md. Forecast rows are consumed by update-ready review, release notes, what-is-new, compatibility reports, migration center, support exports, and headless dry-run output. They carry current evidence for extension, package, bridge, SDK, workflow-bundle, and marketplace impact without claiming certainty beyond the available evidence. Raw extension manifests, package lockfiles, package-manager output, credentials, policy bodies, and user state never cross this boundary; records carry refs, typed states, counts, and reviewable summaries only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "extension_impact_forecast_schema_version",
    "record_kind",
    "forecast_id",
    "review_ref",
    "emitted_at",
    "forecast_class",
    "subject",
    "target_context",
    "forecast_basis",
    "evidence_freshness",
    "policy_gate",
    "migration",
    "rollback_path",
    "local_state_safety",
    "parity",
    "notes"
  ],
  "properties": {
    "extension_impact_forecast_schema_version": {
      "$ref": "#/$defs/extension_impact_forecast_schema_version"
    },
    "record_kind": {
      "type": "string",
      "const": "extension_impact_forecast_record"
    },
    "forecast_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "review_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "emitted_at": {
      "$ref": "#/$defs/utc_datetime"
    },
    "forecast_class": {
      "$ref": "#/$defs/impact_forecast_class"
    },
    "subject": {
      "$ref": "#/$defs/forecast_subject"
    },
    "target_context": {
      "$ref": "#/$defs/target_context"
    },
    "forecast_basis": {
      "$ref": "#/$defs/forecast_basis"
    },
    "evidence_freshness": {
      "$ref": "#/$defs/evidence_freshness"
    },
    "policy_gate": {
      "$ref": "#/$defs/policy_gate"
    },
    "migration": {
      "$ref": "#/$defs/migration_forecast"
    },
    "rollback_path": {
      "$ref": "#/$defs/rollback_path"
    },
    "local_state_safety": {
      "$ref": "#/$defs/local_state_safety"
    },
    "parity": {
      "$ref": "#/$defs/parity_block"
    },
    "notes": {
      "$ref": "#/$defs/non_empty_string"
    }
  },
  "$defs": {
    "extension_impact_forecast_schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/non_empty_string" }
      ]
    },
    "utc_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_utc_datetime": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/utc_datetime" }
      ]
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "non_empty_ref_array": {
      "allOf": [
        { "$ref": "#/$defs/ref_array" },
        { "minItems": 1 }
      ]
    },
    "impact_forecast_class": {
      "type": "string",
      "enum": [
        "no_known_extension_impact",
        "compatible_with_warning",
        "uncertified_row",
        "migration_required",
        "blocked_by_policy",
        "rollback_ready_path_available"
      ],
      "description": "Closed forecast vocabulary. Forecasts describe current evidence and review behavior, not guaranteed post-restart behavior."
    },
    "forecast_subject_class": {
      "type": "string",
      "enum": [
        "extension_package",
        "extension_bridge",
        "extension_sdk",
        "workflow_bundle",
        "package_dependency",
        "package_lockfile",
        "marketplace_metadata",
        "policy_bundle",
        "runtime_helper",
        "remote_agent",
        "workspace_archetype"
      ]
    },
    "release_channel_class": {
      "type": "string",
      "enum": [
        "dev_local",
        "nightly",
        "preview",
        "beta",
        "stable",
        "lts",
        "hotfix",
        "portable_stable",
        "portable_preview",
        "remote_agent_runtime",
        "remote_helper_runtime"
      ]
    },
    "evidence_freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "current_with_waiver",
        "stale_blocking",
        "stale_non_blocking",
        "missing_blocking",
        "not_applicable"
      ]
    },
    "policy_gate_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "allowed",
        "allowed_with_warning",
        "requires_user_review",
        "requires_admin_review",
        "blocked_by_policy",
        "blocked_by_trust",
        "blocked_by_support_window"
      ]
    },
    "migration_task_class": {
      "type": "string",
      "enum": [
        "no_task_required",
        "migration_scan_required",
        "backup_before_migrate",
        "extension_bridge_repair",
        "extension_sdk_range_update",
        "package_lockfile_refresh",
        "package_runtime_floor_update",
        "profile_schema_migration",
        "cache_rebuild",
        "policy_acknowledgement",
        "admin_approval_required",
        "rollback_checkpoint_verify"
      ]
    },
    "task_timing_class": {
      "type": "string",
      "enum": [
        "not_required",
        "before_apply",
        "before_restart",
        "after_restart",
        "before_next_update",
        "manual_review_only"
      ]
    },
    "automation_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "automatic",
        "assistant_available",
        "manual_steps_required",
        "admin_action_required",
        "blocked"
      ]
    },
    "rollback_path_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "disable_or_quarantine_subject",
        "reinstall_previous_extension",
        "restore_package_lockfile_checkpoint",
        "repin_previous_marketplace_metadata",
        "rollback_to_last_known_good_update",
        "restore_profile_checkpoint",
        "manual_repair_required",
        "rollback_blocked"
      ]
    },
    "local_state_safety_class": {
      "type": "string",
      "enum": [
        "no_local_state_change_expected",
        "local_state_preserved",
        "cache_rebuild_only",
        "checkpoint_required_before_apply",
        "migration_writes_local_state",
        "policy_blocks_state_change",
        "unknown_requires_review"
      ]
    },
    "claim_language_class": {
      "type": "string",
      "enum": [
        "current_evidence_only",
        "warning_scoped",
        "stale_evidence_downgraded",
        "waiver_scoped",
        "blocked_no_claim",
        "not_applicable"
      ]
    },
    "forecast_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_class",
        "subject_ref",
        "display_name",
        "publisher_or_owner_ref",
        "current_version",
        "target_version",
        "current_support_window_ref",
        "target_support_window_ref"
      ],
      "properties": {
        "subject_class": { "$ref": "#/$defs/forecast_subject_class" },
        "subject_ref": { "$ref": "#/$defs/non_empty_string" },
        "display_name": { "$ref": "#/$defs/non_empty_string" },
        "publisher_or_owner_ref": { "$ref": "#/$defs/nullable_string" },
        "current_version": { "$ref": "#/$defs/nullable_string" },
        "target_version": { "$ref": "#/$defs/nullable_string" },
        "current_support_window_ref": { "$ref": "#/$defs/nullable_string" },
        "target_support_window_ref": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "target_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_channel_class",
        "target_channel_class",
        "current_version",
        "target_version",
        "artifact_family_refs",
        "compatibility_row_refs",
        "certification_delta_refs",
        "release_note_refs"
      ],
      "properties": {
        "current_channel_class": { "$ref": "#/$defs/release_channel_class" },
        "target_channel_class": { "$ref": "#/$defs/release_channel_class" },
        "current_version": { "$ref": "#/$defs/non_empty_string" },
        "target_version": { "$ref": "#/$defs/non_empty_string" },
        "artifact_family_refs": { "$ref": "#/$defs/ref_array" },
        "compatibility_row_refs": { "$ref": "#/$defs/ref_array" },
        "certification_delta_refs": { "$ref": "#/$defs/ref_array" },
        "release_note_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "forecast_basis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "basis_generated_at",
        "basis_class",
        "local_scan_refs",
        "compatibility_report_refs",
        "certification_report_refs",
        "extension_registry_refs",
        "package_lock_refs",
        "release_evidence_refs",
        "limitation_note"
      ],
      "properties": {
        "basis_generated_at": { "$ref": "#/$defs/utc_datetime" },
        "basis_class": {
          "type": "string",
          "enum": [
            "release_evidence_only",
            "release_and_local_scan",
            "local_scan_only",
            "mirror_import_preflight",
            "policy_simulation",
            "support_reconstruction"
          ]
        },
        "local_scan_refs": { "$ref": "#/$defs/ref_array" },
        "compatibility_report_refs": { "$ref": "#/$defs/ref_array" },
        "certification_report_refs": { "$ref": "#/$defs/ref_array" },
        "extension_registry_refs": { "$ref": "#/$defs/ref_array" },
        "package_lock_refs": { "$ref": "#/$defs/ref_array" },
        "release_evidence_refs": { "$ref": "#/$defs/ref_array" },
        "limitation_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "evidence_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness_class",
        "latest_evidence_at",
        "freshness_policy_ref",
        "stale_or_missing_reason",
        "waiver_refs"
      ],
      "properties": {
        "freshness_class": { "$ref": "#/$defs/evidence_freshness_class" },
        "latest_evidence_at": { "$ref": "#/$defs/nullable_utc_datetime" },
        "freshness_policy_ref": { "$ref": "#/$defs/non_empty_string" },
        "stale_or_missing_reason": { "$ref": "#/$defs/nullable_string" },
        "waiver_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "policy_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_gate_class",
        "policy_decision_refs",
        "policy_summary",
        "blocking"
      ],
      "properties": {
        "policy_gate_class": { "$ref": "#/$defs/policy_gate_class" },
        "policy_decision_refs": { "$ref": "#/$defs/ref_array" },
        "policy_summary": { "$ref": "#/$defs/non_empty_string" },
        "blocking": { "type": "boolean" }
      }
    },
    "migration_forecast": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "migration_task_class",
        "task_refs",
        "task_timing_class",
        "automation_class",
        "migration_guidance_refs",
        "blocks_restart",
        "summary"
      ],
      "properties": {
        "migration_task_class": { "$ref": "#/$defs/migration_task_class" },
        "task_refs": { "$ref": "#/$defs/ref_array" },
        "task_timing_class": { "$ref": "#/$defs/task_timing_class" },
        "automation_class": { "$ref": "#/$defs/automation_class" },
        "migration_guidance_refs": { "$ref": "#/$defs/ref_array" },
        "blocks_restart": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "rollback_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rollback_path_class",
        "rollback_path_ref",
        "checkpoint_or_manifest_refs",
        "retained_until",
        "rollback_summary"
      ],
      "properties": {
        "rollback_path_class": { "$ref": "#/$defs/rollback_path_class" },
        "rollback_path_ref": { "$ref": "#/$defs/nullable_string" },
        "checkpoint_or_manifest_refs": { "$ref": "#/$defs/ref_array" },
        "retained_until": { "$ref": "#/$defs/nullable_utc_datetime" },
        "rollback_summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "local_state_safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_state_safety_class",
        "affected_state_root_refs",
        "backup_or_checkpoint_refs",
        "state_safety_summary"
      ],
      "properties": {
        "local_state_safety_class": { "$ref": "#/$defs/local_state_safety_class" },
        "affected_state_root_refs": { "$ref": "#/$defs/ref_array" },
        "backup_or_checkpoint_refs": { "$ref": "#/$defs/ref_array" },
        "state_safety_summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "parity_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_note_refs",
        "what_is_new_refs",
        "compatibility_surface_refs",
        "migration_surface_refs",
        "support_export_refs",
        "claim_language_class",
        "no_overclaim_note"
      ],
      "properties": {
        "release_note_refs": { "$ref": "#/$defs/ref_array" },
        "what_is_new_refs": { "$ref": "#/$defs/ref_array" },
        "compatibility_surface_refs": { "$ref": "#/$defs/ref_array" },
        "migration_surface_refs": { "$ref": "#/$defs/ref_array" },
        "support_export_refs": { "$ref": "#/$defs/ref_array" },
        "claim_language_class": { "$ref": "#/$defs/claim_language_class" },
        "no_overclaim_note": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "forecast_class": { "const": "blocked_by_policy" }
        },
        "required": ["forecast_class"]
      },
      "then": {
        "properties": {
          "policy_gate": {
            "properties": {
              "blocking": { "const": true }
            },
            "required": ["blocking"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "forecast_class": { "const": "migration_required" }
        },
        "required": ["forecast_class"]
      },
      "then": {
        "properties": {
          "migration": {
            "properties": {
              "migration_task_class": {
                "not": { "const": "no_task_required" }
              }
            },
            "required": ["migration_task_class"]
          }
        }
      }
    }
  ]
}
