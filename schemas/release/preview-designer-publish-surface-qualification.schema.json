{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/preview-designer-publish-surface-qualification.schema.json",
  "title": "Preview, designer, and publish surface qualification packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "as_of",
    "release_doc_ref",
    "help_doc_ref",
    "schema_ref",
    "surfaces",
    "summary"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "record_kind": { "const": "preview_designer_publish_surface_qualification" },
    "packet_id": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "format": "date" },
    "release_doc_ref": { "type": "string", "minLength": 1 },
    "help_doc_ref": { "type": "string", "minLength": 1 },
    "schema_ref": { "type": "string", "minLength": 1 },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surface" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "level": {
      "type": "string",
      "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "preview_runtime",
        "device_viewport_preview",
        "designer_canvas",
        "share_export_sheet",
        "publish_deploy_preview"
      ]
    },
    "source_mapping_quality": {
      "type": "string",
      "enum": [
        "canonical_source_mapping",
        "approximate_mapping",
        "unsupported_construct",
        "generated_only",
        "snapshot_only"
      ]
    },
    "source_sync_state": {
      "type": "string",
      "enum": [
        "in_sync",
        "source_newer",
        "projection_newer_review_required",
        "drift_detected",
        "source_missing",
        "sync_blocked"
      ]
    },
    "generated_source_truth": {
      "type": "string",
      "enum": [
        "canonical_source",
        "live_runtime_output",
        "mock_output",
        "imported_output",
        "cached_output",
        "generated_projection",
        "preview_snapshot"
      ]
    },
    "safe_preview_posture": {
      "type": "string",
      "enum": [
        "safe_preview_default",
        "review_required_preview",
        "dry_run_available",
        "closest_safe_preview",
        "inspect_only",
        "no_safe_preview"
      ]
    },
    "action_safety_lineage": {
      "type": "string",
      "enum": [
        "inspect_only",
        "preview_diff",
        "dry_run",
        "apply_after_review",
        "revert_rollback_exportable",
        "no_side_effect"
      ]
    },
    "browser_inspection_boundary": {
      "type": "string",
      "enum": [
        "preview_only_no_inspection_claim",
        "runtime_identity_shared_inspection_governed_elsewhere",
        "external_browser_capture_only",
        "inspection_blocked_or_separate"
      ]
    },
    "exported_artifact_truth": {
      "type": "string",
      "enum": [
        "not_exporting",
        "canonical_source_export",
        "preview_snapshot_export",
        "generated_projection_export",
        "external_browser_capture_export",
        "publish_dry_run_packet"
      ]
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "captured_at",
        "freshness_slo",
        "slo_state",
        "evidence_refs"
      ],
      "properties": {
        "packet_id": { "type": "string", "minLength": 1 },
        "packet_ref": { "type": "string", "minLength": 1 },
        "proof_index_ref": { "type": "string", "minLength": 1 },
        "captured_at": { "type": ["string", "null"], "format": "date" },
        "freshness_slo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
          "properties": {
            "target_max_age_days": { "type": "integer", "minimum": 1 },
            "warn_within_days": { "type": "integer", "minimum": 0 },
            "slo_register_ref": { "type": "string", "minLength": 1 }
          }
        },
        "slo_state": {
          "type": "string",
          "enum": ["current", "due_for_refresh", "breached", "missing"]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_ref", "signed_off", "signed_at"],
      "properties": {
        "owner_ref": { "type": "string", "minLength": 1 },
        "signed_off": { "type": "boolean" },
        "signed_at": { "type": ["string", "null"], "format": "date" }
      }
    },
    "fallback_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "open_source",
        "open_diff",
        "raw_source_fallback",
        "rollback_lineage_export"
      ],
      "properties": {
        "open_source": { "type": "boolean" },
        "open_diff": { "type": "boolean" },
        "raw_source_fallback": { "type": "boolean" },
        "rollback_lineage_export": { "type": "boolean" }
      }
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "docs_help",
        "about_release_packets",
        "support_export",
        "share_export_publish_sheets",
        "product_surface_labels"
      ],
      "properties": {
        "docs_help": { "type": "boolean" },
        "about_release_packets": { "type": "boolean" },
        "support_export": { "type": "boolean" },
        "share_export_publish_sheets": { "type": "boolean" },
        "product_surface_labels": { "type": "boolean" }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "owner_signoff",
        "source_mapping_quality",
        "source_sync_state",
        "generated_source_truth",
        "safe_preview_posture",
        "action_safety_lineage",
        "browser_inspection_boundary",
        "exported_artifact_truth",
        "visible_lineage_labels",
        "unsupported_construct_cards",
        "fallback_paths",
        "projection",
        "evidence_refs",
        "rationale"
      ],
      "properties": {
        "surface_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "promoted_build_surface": { "type": "boolean" },
        "claim_label": { "$ref": "#/$defs/level" },
        "displayed_label": { "$ref": "#/$defs/level" },
        "qualification_packet": { "$ref": "#/$defs/proof_packet" },
        "owner_signoff": { "$ref": "#/$defs/owner_signoff" },
        "source_mapping_quality": { "$ref": "#/$defs/source_mapping_quality" },
        "source_sync_state": { "$ref": "#/$defs/source_sync_state" },
        "generated_source_truth": { "$ref": "#/$defs/generated_source_truth" },
        "safe_preview_posture": { "$ref": "#/$defs/safe_preview_posture" },
        "action_safety_lineage": {
          "type": "array",
          "items": { "$ref": "#/$defs/action_safety_lineage" }
        },
        "browser_inspection_boundary": { "$ref": "#/$defs/browser_inspection_boundary" },
        "exported_artifact_truth": { "$ref": "#/$defs/exported_artifact_truth" },
        "visible_lineage_labels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "unsupported_construct_cards": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "fallback_paths": { "$ref": "#/$defs/fallback_paths" },
        "projection": { "$ref": "#/$defs/projection" },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promoted_surface_count",
        "stable_surface_count",
        "narrowed_surface_count",
        "green_packet_count",
        "noncanonical_mapping_count",
        "side_effect_rows_with_safe_preview_count"
      ],
      "properties": {
        "promoted_surface_count": { "type": "integer", "minimum": 0 },
        "stable_surface_count": { "type": "integer", "minimum": 0 },
        "narrowed_surface_count": { "type": "integer", "minimum": 0 },
        "green_packet_count": { "type": "integer", "minimum": 0 },
        "noncanonical_mapping_count": { "type": "integer", "minimum": 0 },
        "side_effect_rows_with_safe_preview_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
