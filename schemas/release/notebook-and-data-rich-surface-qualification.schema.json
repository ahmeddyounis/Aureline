{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/notebook-and-data-rich-surface-qualification.schema.json",
  "title": "Aureline notebook and data-rich surface qualification packet",
  "description": "Canonical packet binding promoted notebook and data-rich surfaces to document/kernel/output trust, replay/export, snapshot/golden review, accessibility, support export, and downgrade-label evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "as_of",
    "release_doc_ref",
    "help_doc_ref",
    "schema_ref",
    "surfaces",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "notebook_and_data_rich_surface_qualification"
    },
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "release_doc_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "help_doc_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "schema_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "surfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/surface"
      },
      "minItems": 1
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "surface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "owner_signoff",
        "document_trust",
        "kernel_runtime_trust",
        "output_trust",
        "execution_origin",
        "freshness",
        "replay_export_posture",
        "review_modes",
        "visible_state_labels",
        "projection",
        "handoff_truth",
        "accessibility_refs",
        "snapshot_golden_refs",
        "support_export_refs",
        "rationale"
      ],
      "properties": {
        "surface_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_kind": {
          "type": "string",
          "enum": [
            "notebook_document",
            "notebook_review_export",
            "variable_explorer",
            "data_table",
            "result_grid",
            "chart_summary",
            "experiment_handoff",
            "api_database_response_viewer"
          ]
        },
        "claim_label": {
          "$ref": "#/$defs/lifecycle_label"
        },
        "displayed_label": {
          "$ref": "#/$defs/lifecycle_label"
        },
        "document_trust": {
          "$ref": "#/$defs/trust_posture"
        },
        "kernel_runtime_trust": {
          "$ref": "#/$defs/trust_posture"
        },
        "output_trust": {
          "$ref": "#/$defs/trust_posture"
        },
        "freshness": {
          "type": "string",
          "enum": [
            "live",
            "no_kernel",
            "disconnected_kernel",
            "stale_output",
            "imported_output",
            "captured_output"
          ]
        }
      }
    },
    "lifecycle_label": {
      "type": "string",
      "enum": [
        "lts",
        "stable",
        "beta",
        "preview",
        "withdrawn"
      ]
    },
    "trust_posture": {
      "type": "string",
      "enum": [
        "trusted",
        "untrusted",
        "mixed",
        "imported",
        "captured",
        "stale",
        "not_applicable"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promoted_surface_count",
        "stable_surface_count",
        "narrowed_surface_count",
        "green_packet_count",
        "preview_or_labs_count"
      ],
      "properties": {
        "promoted_surface_count": {
          "type": "integer",
          "minimum": 0
        },
        "stable_surface_count": {
          "type": "integer",
          "minimum": 0
        },
        "narrowed_surface_count": {
          "type": "integer",
          "minimum": 0
        },
        "green_packet_count": {
          "type": "integer",
          "minimum": 0
        },
        "preview_or_labs_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
