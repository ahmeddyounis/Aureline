{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/voice-and-dictation-surface-qualification.schema.json",
  "title": "Voice and dictation surface qualification packet",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "as_of",
    "release_doc_ref",
    "help_doc_ref",
    "schema_ref",
    "surfaces",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "record_kind": { "const": "voice_and_dictation_surface_qualification" },
    "packet_id": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "format": "date" },
    "release_doc_ref": { "type": "string", "minLength": 1 },
    "help_doc_ref": { "type": "string", "minLength": 1 },
    "schema_ref": { "type": "string", "minLength": 1 },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surface" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "level": {
      "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
    },
    "surface_kind": {
      "enum": [
        "command_overlay",
        "dictation_input",
        "transcript_correction",
        "provider_privacy_settings",
        "unavailable_fallback",
        "high_impact_action_review"
      ]
    },
    "voice_mode": {
      "enum": ["command", "dictation", "mode_selectable", "unavailable"]
    },
    "processing_class": {
      "enum": ["local", "trusted_enterprise", "third_party_provider", "unavailable"]
    },
    "activation_default": {
      "enum": [
        "push_to_talk",
        "explicit_tap_to_start",
        "continuous_opt_in",
        "wake_word_opt_in",
        "unavailable"
      ]
    },
    "retention": {
      "enum": [
        "ephemeral",
        "bounded_correction_buffer",
        "metadata_only",
        "enterprise_policy_retained",
        "not_captured"
      ]
    },
    "fallback_state": {
      "enum": [
        "no_microphone_permission",
        "policy_blocked",
        "offline",
        "provider_unavailable",
        "noisy_environment",
        "keyboard_fallback"
      ]
    },
    "proof_packet": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "owner_signoff": {
      "type": "object",
      "required": ["owner_ref", "signed_off", "signed_at"],
      "additionalProperties": false,
      "properties": {
        "owner_ref": { "type": "string", "minLength": 1 },
        "signed_off": { "type": "boolean" },
        "signed_at": { "type": ["string", "null"], "format": "date" }
      }
    },
    "ui_primitives": {
      "type": "object",
      "required": [
        "mic_state_pill",
        "transcript_strip",
        "command_disambiguation_sheet",
        "provider_privacy_row",
        "unavailable_banner",
        "capture_export_review_sheet"
      ],
      "additionalProperties": false,
      "properties": {
        "mic_state_pill": { "type": "boolean" },
        "transcript_strip": { "type": "boolean" },
        "command_disambiguation_sheet": { "type": "boolean" },
        "provider_privacy_row": { "type": "boolean" },
        "unavailable_banner": { "type": "boolean" },
        "capture_export_review_sheet": { "type": "boolean" }
      }
    },
    "command_parity": {
      "type": "object",
      "required": [
        "stable_command_ids",
        "disabled_with_reason",
        "preview_apply_revert",
        "approval_requirements",
        "undo_grouping",
        "audit_support_lineage",
        "high_impact_review"
      ],
      "additionalProperties": false,
      "properties": {
        "stable_command_ids": { "type": "boolean" },
        "disabled_with_reason": { "type": "boolean" },
        "preview_apply_revert": { "type": "boolean" },
        "approval_requirements": { "type": "boolean" },
        "undo_grouping": { "type": "boolean" },
        "audit_support_lineage": { "type": "boolean" },
        "high_impact_review": { "type": "boolean" }
      }
    },
    "transcript_privacy": {
      "type": "object",
      "required": [
        "bounded_correction_buffer",
        "delete_action",
        "export_action",
        "redaction_before_support_export",
        "raw_transcripts_excluded_by_default"
      ],
      "additionalProperties": false,
      "properties": {
        "bounded_correction_buffer": { "type": "boolean" },
        "delete_action": { "type": "boolean" },
        "export_action": { "type": "boolean" },
        "redaction_before_support_export": { "type": "boolean" },
        "raw_transcripts_excluded_by_default": { "type": "boolean" }
      }
    },
    "projection": {
      "type": "object",
      "required": [
        "docs_help",
        "about_service_health",
        "cli_headless_inspect",
        "support_export",
        "privacy_diagnostics"
      ],
      "additionalProperties": false,
      "properties": {
        "docs_help": { "type": "boolean" },
        "about_service_health": { "type": "boolean" },
        "cli_headless_inspect": { "type": "boolean" },
        "support_export": { "type": "boolean" },
        "privacy_diagnostics": { "type": "boolean" }
      }
    },
    "surface": {
      "type": "object",
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "qualification_packet",
        "owner_signoff",
        "mode",
        "explicit_mode_visible",
        "processing_class",
        "activation_default",
        "persistent_indicator",
        "mute_or_stop_action",
        "keyboard_fallback",
        "transcript_retention",
        "ui_primitives",
        "command_parity",
        "transcript_privacy",
        "fallback_states",
        "projection",
        "accessibility_refs",
        "regression_refs",
        "privacy_review_refs",
        "support_export_refs",
        "rationale"
      ],
      "additionalProperties": false,
      "properties": {
        "surface_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "promoted_build_surface": { "type": "boolean" },
        "claim_label": { "$ref": "#/$defs/level" },
        "displayed_label": { "$ref": "#/$defs/level" },
        "qualification_packet": { "$ref": "#/$defs/proof_packet" },
        "owner_signoff": { "$ref": "#/$defs/owner_signoff" },
        "mode": { "$ref": "#/$defs/voice_mode" },
        "explicit_mode_visible": { "type": "boolean" },
        "processing_class": { "$ref": "#/$defs/processing_class" },
        "activation_default": { "$ref": "#/$defs/activation_default" },
        "persistent_indicator": { "type": "boolean" },
        "mute_or_stop_action": { "type": "boolean" },
        "keyboard_fallback": { "type": "boolean" },
        "transcript_retention": { "$ref": "#/$defs/retention" },
        "ui_primitives": { "$ref": "#/$defs/ui_primitives" },
        "command_parity": { "$ref": "#/$defs/command_parity" },
        "transcript_privacy": { "$ref": "#/$defs/transcript_privacy" },
        "fallback_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/fallback_state" }
        },
        "projection": { "$ref": "#/$defs/projection" },
        "accessibility_refs": { "type": "array", "items": { "type": "string" } },
        "regression_refs": { "type": "array", "items": { "type": "string" } },
        "privacy_review_refs": { "type": "array", "items": { "type": "string" } },
        "support_export_refs": { "type": "array", "items": { "type": "string" } },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "promoted_surface_count",
        "stable_surface_count",
        "narrowed_surface_count",
        "green_packet_count",
        "preview_or_labs_count"
      ],
      "additionalProperties": false,
      "properties": {
        "promoted_surface_count": { "type": "integer", "minimum": 0 },
        "stable_surface_count": { "type": "integer", "minimum": 0 },
        "narrowed_surface_count": { "type": "integer", "minimum": 0 },
        "green_packet_count": { "type": "integer", "minimum": 0 },
        "preview_or_labs_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
