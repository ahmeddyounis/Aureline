{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/beta_durability_packet.schema.json",
  "title": "Aureline beta durability packet",
  "description": "Boundary schema for the protected-beta durability packet and its generated validation capture. The packet turns maintainer coverage, signing/quorum split-authority, and critical-upstream sustainment into release-bearing truth for protected beta paths and emergency release paths. It projects the canonical ownership matrix, signing-quorum action matrix, and critical-upstream health register; it does not mint a second authority inventory. Raw logs, secrets, customer data, and private ticket text are excluded; records carry stable repo-relative refs and metadata-safe summaries only.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/beta_durability_packet_record" },
    { "$ref": "#/$defs/beta_durability_validation_capture" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/non_empty_string" }
      ]
    },
    "iso_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "date_time": {
      "type": "string",
      "format": "date-time"
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "non_empty_ref_array": {
      "allOf": [
        { "$ref": "#/$defs/ref_array" },
        { "minItems": 1 }
      ]
    },
    "review_cadence": {
      "type": "string",
      "enum": [
        "per_milestone",
        "monthly",
        "quarterly",
        "before_beta_claim",
        "before_stable_claim"
      ]
    },
    "coverage_state": {
      "type": "string",
      "enum": ["covered", "waiver_backed", "uncovered"]
    },
    "path_kind": {
      "type": "string",
      "enum": ["beta_surface", "beta_archetype", "emergency_release_path"]
    },
    "health_rating": {
      "type": "string",
      "enum": ["green", "yellow", "orange", "red"]
    },
    "repo_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "single_maintainer_waiver_ref",
        "waiver_expires_on",
        "steady_state_required_for",
        "notes"
      ],
      "properties": {
        "single_maintainer_waiver_ref": { "$ref": "#/$defs/non_empty_string" },
        "waiver_expires_on": { "$ref": "#/$defs/iso_date" },
        "steady_state_required_for": { "$ref": "#/$defs/non_empty_ref_array" },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_manifest_ref",
        "ownership_matrix_ref",
        "signing_quorum_ref",
        "maintainer_coverage_policy_ref",
        "critical_upstream_health_register_ref",
        "upstream_health_scorecard_ref",
        "dependency_register_ref",
        "durability_doc_ref"
      ],
      "properties": {
        "claim_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "ownership_matrix_ref": { "$ref": "#/$defs/non_empty_string" },
        "signing_quorum_ref": { "$ref": "#/$defs/non_empty_string" },
        "maintainer_coverage_policy_ref": { "$ref": "#/$defs/non_empty_string" },
        "critical_upstream_health_register_ref": { "$ref": "#/$defs/non_empty_string" },
        "upstream_health_scorecard_ref": { "$ref": "#/$defs/non_empty_string" },
        "dependency_register_ref": { "$ref": "#/$defs/non_empty_string" },
        "durability_doc_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "generated_outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "critical_upstream_register_csv_ref",
        "signing_quorum_and_breakglass_md_ref",
        "validation_capture_ref"
      ],
      "properties": {
        "critical_upstream_register_csv_ref": { "$ref": "#/$defs/non_empty_string" },
        "signing_quorum_and_breakglass_md_ref": { "$ref": "#/$defs/non_empty_string" },
        "validation_capture_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "protected_path_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_id",
        "path_kind",
        "title",
        "claim_row_refs",
        "owning_packages",
        "primary_maintainer",
        "backup_maintainer",
        "backup_waiver_ref",
        "standing_reviewer_depth",
        "succession_note",
        "review_cadence",
        "next_review_due",
        "coverage_state"
      ],
      "properties": {
        "path_id": { "$ref": "#/$defs/non_empty_string" },
        "path_kind": { "$ref": "#/$defs/path_kind" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "claim_row_refs": { "$ref": "#/$defs/ref_array" },
        "owning_packages": { "$ref": "#/$defs/non_empty_ref_array" },
        "primary_maintainer": { "$ref": "#/$defs/non_empty_string" },
        "backup_maintainer": { "$ref": "#/$defs/nullable_string" },
        "backup_waiver_ref": { "$ref": "#/$defs/nullable_string" },
        "standing_reviewer_depth": { "type": "integer", "minimum": 1 },
        "succession_note": { "$ref": "#/$defs/non_empty_string" },
        "review_cadence": { "$ref": "#/$defs/review_cadence" },
        "next_review_due": { "$ref": "#/$defs/iso_date" },
        "coverage_state": { "$ref": "#/$defs/coverage_state" },
        "notes": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "signer_roster_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signer_id",
        "role",
        "named_humans",
        "backup_state",
        "backup_waiver_ref",
        "scopes"
      ],
      "properties": {
        "signer_id": { "$ref": "#/$defs/non_empty_string" },
        "role": { "$ref": "#/$defs/non_empty_string" },
        "named_humans": { "$ref": "#/$defs/non_empty_ref_array" },
        "backup_state": {
          "type": "string",
          "enum": ["named_backup", "single_maintainer_waiver"]
        },
        "backup_waiver_ref": { "$ref": "#/$defs/nullable_string" },
        "scopes": { "$ref": "#/$defs/non_empty_ref_array" }
      }
    },
    "split_authority_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority",
        "signing_quorum_action_id",
        "quorum_profile",
        "min_distinct_humans",
        "author_only_forbidden",
        "break_glass_profile"
      ],
      "properties": {
        "authority": {
          "type": "string",
          "enum": [
            "release_signing",
            "rollback",
            "revocation",
            "registry_emergency",
            "signer_roster_change"
          ]
        },
        "signing_quorum_action_id": { "$ref": "#/$defs/non_empty_string" },
        "quorum_profile": { "$ref": "#/$defs/non_empty_string" },
        "min_distinct_humans": { "type": "integer", "minimum": 1 },
        "author_only_forbidden": { "type": "boolean" },
        "break_glass_profile": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "break_glass_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "max_duration_hours",
        "forbidden_for",
        "required_audit_fields",
        "retrospective_quorum_profile"
      ],
      "properties": {
        "profile_id": { "$ref": "#/$defs/non_empty_string" },
        "max_duration_hours": { "type": "integer", "minimum": 1 },
        "forbidden_for": { "$ref": "#/$defs/non_empty_ref_array" },
        "required_audit_fields": { "$ref": "#/$defs/non_empty_ref_array" },
        "retrospective_quorum_profile": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "signing_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_ref",
        "policy_doc_ref",
        "no_single_human_principle",
        "signer_roster",
        "split_authority_actions",
        "break_glass"
      ],
      "properties": {
        "policy_ref": { "$ref": "#/$defs/non_empty_string" },
        "policy_doc_ref": { "$ref": "#/$defs/non_empty_string" },
        "no_single_human_principle": { "$ref": "#/$defs/non_empty_string" },
        "signer_roster": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/signer_roster_entry" }
        },
        "split_authority_actions": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/split_authority_action" }
        },
        "break_glass": { "$ref": "#/$defs/break_glass_contract" }
      }
    },
    "critical_upstream_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dependency_id",
        "dependency_name",
        "protected_path_refs",
        "owning_packages",
        "health_rating",
        "health_status",
        "license_class",
        "risk_posture",
        "sustainment_owner",
        "sponsor_or_sustainment_state",
        "fork_replace_strategy",
        "escalation_owner",
        "next_review_due",
        "source_register_ref",
        "evidence_refs"
      ],
      "properties": {
        "dependency_id": { "$ref": "#/$defs/non_empty_string" },
        "dependency_name": { "$ref": "#/$defs/non_empty_string" },
        "protected_path_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "owning_packages": { "$ref": "#/$defs/non_empty_ref_array" },
        "health_rating": { "$ref": "#/$defs/health_rating" },
        "health_status": { "$ref": "#/$defs/non_empty_string" },
        "license_class": { "$ref": "#/$defs/non_empty_string" },
        "risk_posture": { "$ref": "#/$defs/non_empty_string" },
        "sustainment_owner": { "$ref": "#/$defs/non_empty_string" },
        "sponsor_or_sustainment_state": { "$ref": "#/$defs/non_empty_string" },
        "fork_replace_strategy": { "$ref": "#/$defs/non_empty_string" },
        "escalation_owner": { "$ref": "#/$defs/non_empty_string" },
        "next_review_due": { "$ref": "#/$defs/iso_date" },
        "source_register_ref": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "beta_durability_packet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "packet_id",
        "packet_revision",
        "generated_at",
        "as_of",
        "milestone_id",
        "owner_dri",
        "status",
        "repo_posture",
        "source_refs",
        "generated_outputs",
        "protected_paths",
        "signing_authority",
        "critical_upstreams"
      ],
      "properties": {
        "record_kind": { "const": "beta_durability_packet" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "packet_revision": { "type": "integer", "minimum": 1 },
        "generated_at": { "$ref": "#/$defs/date_time" },
        "as_of": { "$ref": "#/$defs/date_time" },
        "milestone_id": { "$ref": "#/$defs/non_empty_string" },
        "owner_dri": { "$ref": "#/$defs/non_empty_string" },
        "status": { "$ref": "#/$defs/non_empty_string" },
        "notes": { "$ref": "#/$defs/nullable_string" },
        "repo_posture": { "$ref": "#/$defs/repo_posture" },
        "source_refs": { "$ref": "#/$defs/source_refs" },
        "generated_outputs": { "$ref": "#/$defs/generated_outputs" },
        "protected_paths": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/protected_path_row" }
        },
        "signing_authority": { "$ref": "#/$defs/signing_authority" },
        "critical_upstreams": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/critical_upstream_row" }
        }
      }
    },
    "beta_durability_validation_capture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "validated_at",
        "packet_id",
        "source_packet_ref",
        "passed",
        "coverage",
        "fixture_results",
        "findings"
      ],
      "properties": {
        "record_kind": { "const": "beta_durability_validation_capture" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "validated_at": { "$ref": "#/$defs/date_time" },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "source_packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "passed": { "type": "boolean" },
        "coverage": { "type": "object" },
        "fixture_results": { "type": "array" },
        "findings": { "type": "array" }
      }
    }
  }
}
