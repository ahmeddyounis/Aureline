{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/forms-parameter-source-and-staged-apply.schema.json",
  "title": "Forms parameter source and staged apply record",
  "description": "Boundary schema for the stable structured-input truth record consumed by settings, setup, scaffold, provider, policy, publish, and recovery surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "packet_id",
    "as_of",
    "surface_class",
    "client_scope",
    "title",
    "affected_scope",
    "fields",
    "precedence_audits",
    "staged_apply",
    "client_limitations",
    "accessibility_review",
    "support_export_lines"
  ],
  "properties": {
    "record_kind": { "const": "forms_parameter_source_and_staged_apply_record" },
    "schema_version": { "const": 1 },
    "notice": { "type": "string", "minLength": 1 },
    "shared_contract_ref": { "const": "shell:forms_parameter_source_staged_apply:v1" },
    "packet_id": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "minLength": 1 },
    "surface_class": { "$ref": "#/$defs/surface_class" },
    "client_scope": { "$ref": "#/$defs/client_scope" },
    "title": { "type": "string", "minLength": 1 },
    "affected_scope": { "type": "string", "minLength": 1 },
    "fields": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/field_row" } },
    "precedence_audits": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source_precedence_audit" }
    },
    "staged_apply": { "$ref": "#/$defs/staged_apply" },
    "wizard_state": { "anyOf": [{ "$ref": "#/$defs/wizard_state" }, { "type": "null" }] },
    "client_limitations": { "type": "array", "items": { "$ref": "#/$defs/client_limitation" } },
    "accessibility_review": { "$ref": "#/$defs/accessibility_review" },
    "support_export_lines": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "surface_class": {
      "type": "string",
      "enum": [
        "settings_editor",
        "setup_card",
        "scaffold_wizard",
        "provider_account_flow",
        "policy_review",
        "publish_review",
        "recovery_review"
      ]
    },
    "client_scope": {
      "type": "string",
      "enum": [
        "desktop",
        "remote_workspace",
        "managed_workspace",
        "browser_companion",
        "restricted_client",
        "offline_degraded"
      ]
    },
    "source": {
      "type": "string",
      "enum": [
        "default",
        "detected",
        "imported",
        "workspace",
        "policy",
        "user_override",
        "secret_reference",
        "runtime_prompt"
      ]
    },
    "apply_timing": {
      "type": "string",
      "enum": ["immediate", "staged", "preview_first", "policy_locked"]
    },
    "validation_class": {
      "type": "string",
      "enum": [
        "local_syntax",
        "schema_model",
        "environment_probe",
        "remote_auth",
        "policy_entitlement",
        "dry_run_preview"
      ]
    },
    "validation_state": {
      "type": "string",
      "enum": [
        "pristine",
        "incomplete",
        "invalid",
        "warning",
        "blocked",
        "ready",
        "pending",
        "stale"
      ]
    },
    "field_kind": {
      "type": "string",
      "enum": ["plain", "secret", "path", "object_reference", "code_backed"]
    },
    "field_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_class", "label"],
      "properties": {
        "action_class": {
          "type": "string",
          "enum": ["reset", "clear", "open_details", "reveal", "copy", "revoke"]
        },
        "label": { "type": "string", "minLength": 1 }
      }
    },
    "validation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validation_class",
        "state",
        "message",
        "blocks_submit",
        "last_known_state",
        "last_known_message",
        "validation_epoch",
        "target_epoch",
        "dependent_inputs",
        "invalidates_on_target_change"
      ],
      "properties": {
        "validation_class": { "$ref": "#/$defs/validation_class" },
        "state": { "$ref": "#/$defs/validation_state" },
        "message": { "type": "string", "minLength": 1 },
        "blocks_submit": { "type": "boolean" },
        "last_known_state": { "anyOf": [{ "$ref": "#/$defs/validation_state" }, { "type": "null" }] },
        "last_known_message": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
        "validation_epoch": { "type": "integer", "minimum": 0 },
        "target_epoch": { "type": "integer", "minimum": 0 },
        "dependent_inputs": { "type": "array", "items": { "type": "string" } },
        "invalidates_on_target_change": { "type": "boolean" }
      }
    },
    "field_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_id",
        "label",
        "current_value_summary",
        "requirement",
        "field_kind",
        "source_class",
        "source_label",
        "validation",
        "apply_timing",
        "actions",
        "secret_truth",
        "path_truth",
        "reference_truth",
        "code_backed_truth"
      ],
      "properties": {
        "field_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "current_value_summary": { "type": "string", "minLength": 1 },
        "requirement": { "type": "string", "enum": ["required", "optional", "conditional"] },
        "field_kind": { "$ref": "#/$defs/field_kind" },
        "source_class": { "$ref": "#/$defs/source" },
        "source_label": { "type": "string", "minLength": 1 },
        "validation": { "$ref": "#/$defs/validation_result" },
        "apply_timing": { "$ref": "#/$defs/apply_timing" },
        "actions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/field_action" } },
        "secret_truth": { "anyOf": [{ "$ref": "#/$defs/secret_truth" }, { "type": "null" }] },
        "path_truth": { "anyOf": [{ "$ref": "#/$defs/path_truth" }, { "type": "null" }] },
        "reference_truth": { "anyOf": [{ "$ref": "#/$defs/reference_truth" }, { "type": "null" }] },
        "code_backed_truth": { "anyOf": [{ "$ref": "#/$defs/code_backed_truth" }, { "type": "null" }] }
      }
    },
    "secret_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["storage_mode", "reveal_friction", "copy_warning", "clear_or_revoke_action", "export_behavior"],
      "properties": {
        "storage_mode": {
          "type": "string",
          "enum": ["session_only", "os_keychain", "policy_provided", "external_vault_reference", "delegated_identity"]
        },
        "reveal_friction": { "type": "string", "minLength": 1 },
        "copy_warning": { "type": "string", "minLength": 1 },
        "clear_or_revoke_action": { "type": "string", "minLength": 1 },
        "export_behavior": {
          "type": "string",
          "enum": ["reference_only", "redacted_by_default", "policy_owned_omitted"]
        }
      }
    },
    "path_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["basis", "location_class", "displayed_path", "basis_ref"],
      "properties": {
        "basis": { "type": "string", "enum": ["workspace_relative", "absolute"] },
        "location_class": { "type": "string", "enum": ["local", "remote", "container", "workspace"] },
        "displayed_path": { "type": "string", "minLength": 1 },
        "basis_ref": { "type": "string", "minLength": 1 }
      }
    },
    "reference_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_label", "stable_id_path"],
      "properties": {
        "display_label": { "type": "string", "minLength": 1 },
        "stable_id_path": { "type": "string", "minLength": 1 }
      }
    },
    "code_backed_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["diff_preview_ref", "preserves_comments", "preserves_unknown_fields", "broad_impact_disclosure"],
      "properties": {
        "diff_preview_ref": { "type": "string", "minLength": 1 },
        "preserves_comments": { "type": "boolean" },
        "preserves_unknown_fields": { "type": "boolean" },
        "broad_impact_disclosure": { "type": "string", "minLength": 1 }
      }
    },
    "source_precedence_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_id", "effective_source", "effective_value_summary", "winning_reason", "candidates"],
      "properties": {
        "field_id": { "type": "string", "minLength": 1 },
        "effective_source": { "$ref": "#/$defs/source" },
        "effective_value_summary": { "type": "string", "minLength": 1 },
        "winning_reason": { "type": "string", "minLength": 1 },
        "candidates": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/precedence_candidate" } }
      }
    },
    "precedence_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_class", "source_label", "value_summary", "precedence_rank", "effective", "superseded_by"],
      "properties": {
        "source_class": { "$ref": "#/$defs/source" },
        "source_label": { "type": "string", "minLength": 1 },
        "value_summary": { "type": "string", "minLength": 1 },
        "precedence_rank": { "type": "integer", "minimum": 0 },
        "effective": { "type": "boolean" },
        "superseded_by": { "anyOf": [{ "type": "string" }, { "type": "null" }] }
      }
    },
    "staged_apply": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "apply_timing",
        "dirty",
        "dirty_scopes",
        "dirty_state_persisted_across",
        "review_sheet_ref",
        "checkpoint_ref",
        "revert_action_label",
        "target_scope",
        "side_effects",
        "build_impact_class",
        "final_submit_label",
        "save_and_resume_disclosed"
      ],
      "properties": {
        "apply_timing": { "$ref": "#/$defs/apply_timing" },
        "dirty": { "type": "boolean" },
        "dirty_scopes": { "type": "array", "items": { "type": "string" } },
        "dirty_state_persisted_across": { "type": "array", "items": { "type": "string" } },
        "review_sheet_ref": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
        "checkpoint_ref": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
        "revert_action_label": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
        "target_scope": { "type": "string", "minLength": 1 },
        "side_effects": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["editor_only", "file_write", "process_spawn", "network_call", "remote_mutation", "policy_change"]
          }
        },
        "build_impact_class": {
          "type": "string",
          "enum": ["none", "narrow_local", "workspace_wide", "remote_or_provider", "policy_managed"]
        },
        "final_submit_label": { "type": "string", "minLength": 1 },
        "save_and_resume_disclosed": { "type": "boolean" }
      }
    },
    "wizard_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_step", "total_steps", "blocked_prerequisites", "save_and_resume_visible", "final_submit_label"],
      "properties": {
        "current_step": { "type": "integer", "minimum": 1 },
        "total_steps": { "type": "integer", "minimum": 1 },
        "blocked_prerequisites": { "type": "array", "items": { "type": "string" } },
        "save_and_resume_visible": { "type": "boolean" },
        "final_submit_label": { "type": "string", "minLength": 1 }
      }
    },
    "client_limitation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_id", "reason", "disclosed_before_final_step"],
      "properties": {
        "field_id": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "disclosed_before_final_step": { "type": "boolean" }
      }
    },
    "accessibility_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "keyboard_operable",
        "screen_reader_operable",
        "ime_safe",
        "rtl_safe",
        "reduced_motion_safe",
        "focus_return_target"
      ],
      "properties": {
        "keyboard_operable": { "type": "boolean" },
        "screen_reader_operable": { "type": "boolean" },
        "ime_safe": { "type": "boolean" },
        "rtl_safe": { "type": "boolean" },
        "reduced_motion_safe": { "type": "boolean" },
        "focus_return_target": { "type": "string", "minLength": 1 }
      }
    }
  }
}
