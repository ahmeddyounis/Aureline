{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/publish-the-signed-m4-stable-evidence-pack-plus.schema.json",
  "title": "Aureline signed M4 stable evidence pack",
  "description": "Canonical, machine-readable register binding each M4 evidence bundle (benchmark, compatibility, migration, accessibility, docs/help, security, artifact graph, qualification, release promotion, dependency) to the stable claim manifest entry whose lifecycle label it backs, an attestation or signature ref, a packet-freshness SLO, and bundle rules that gate publication. Each bundle may carry the claim's label or narrow below it but never wider. The register is metadata-only: typed states and opaque refs, never raw artifacts, logs, signatures, or credentials.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "pack_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "lifecycle_labels",
    "bundle_kinds",
    "bundle_states",
    "gap_reasons",
    "bundle_actions",
    "launch_cutline",
    "release_blocking_bundle_refs",
    "bundles",
    "bundle_rules",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "signed_m4_stable_evidence_pack" },
    "pack_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "lifecycle_labels": {
      "type": "array",
      "items": { "$ref": "#/$defs/lifecycle_label" },
      "minItems": 1,
      "uniqueItems": true
    },
    "bundle_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/bundle_kind" },
      "minItems": 1,
      "uniqueItems": true
    },
    "bundle_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/bundle_state" },
      "minItems": 1,
      "uniqueItems": true
    },
    "gap_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap_reason" },
      "minItems": 1,
      "uniqueItems": true
    },
    "bundle_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/bundle_action" },
      "minItems": 1,
      "uniqueItems": true
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_bundle_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "bundles": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_bundle_row" },
      "minItems": 1
    },
    "bundle_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/bundle_rule" },
      "minItems": 1
    },
    "publication": { "$ref": "#/$defs/publication_record" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_label": {
      "type": "string",
      "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
    },
    "bundle_kind": {
      "type": "string",
      "enum": [
        "benchmark",
        "compatibility",
        "migration",
        "accessibility",
        "docs_help",
        "security",
        "artifact_graph",
        "qualification",
        "release_promotion",
        "dependency"
      ]
    },
    "bundle_state": {
      "type": "string",
      "enum": [
        "signed_current",
        "signed_on_waiver",
        "unsigned_unattested",
        "narrowed_stale",
        "narrowed_claim_narrowed",
        "narrowed_waiver_expired",
        "narrowed_owner_signoff_missing"
      ]
    },
    "gap_reason": {
      "type": "string",
      "enum": [
        "claim_label_narrowed",
        "packet_missing",
        "packet_freshness_breached",
        "evidence_incomplete",
        "attestation_missing",
        "signature_invalid",
        "waiver_expired",
        "owner_signoff_missing"
      ]
    },
    "bundle_action": {
      "type": "string",
      "enum": [
        "hold_publication",
        "narrow_bundle_label",
        "refresh_packet",
        "recapture_evidence",
        "request_attestation",
        "request_owner_signoff"
      ]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cutline_level", "above_cutline_levels", "below_cutline_levels", "description"],
      "properties": {
        "cutline_level": { "$ref": "#/$defs/lifecycle_label" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" },
          "minItems": 1
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" },
          "minItems": 1
        },
        "description": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "bundle_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "title", "trigger_reason", "applies_to_labels", "default_action", "blocks_publication", "rationale"],
      "properties": {
        "rule_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "trigger_reason": { "$ref": "#/$defs/gap_reason" },
        "applies_to_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" },
          "minItems": 1
        },
        "default_action": { "$ref": "#/$defs/bundle_action" },
        "blocks_publication": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "evidence_bundle_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "bundle_kind",
        "upstream_artifact_ref",
        "subject_ref",
        "subject_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "bundle_state",
        "proof_packet",
        "owner_signoff",
        "active_gap_reasons",
        "effective_label",
        "publication_destinations",
        "rationale"
      ],
      "properties": {
        "entry_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "bundle_kind": { "$ref": "#/$defs/bundle_kind" },
        "upstream_artifact_ref": { "$ref": "#/$defs/non_empty_string" },
        "subject_ref": { "$ref": "#/$defs/non_empty_string" },
        "subject_summary": { "$ref": "#/$defs/non_empty_string" },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "$ref": "#/$defs/non_empty_string" },
        "claim_label": { "$ref": "#/$defs/lifecycle_label" },
        "bundle_state": { "$ref": "#/$defs/bundle_state" },
        "proof_packet": { "$ref": "#/$defs/proof_packet" },
        "attestation_ref": { "type": ["string", "null"] },
        "signature_ref": { "type": ["string", "null"] },
        "owner_signoff": { "$ref": "#/$defs/owner_signoff" },
        "waiver": { "type": ["object", "null"], "$ref": "#/$defs/qualification_waiver" },
        "active_gap_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/gap_reason" }
        },
        "effective_label": { "$ref": "#/$defs/lifecycle_label" },
        "publication_destinations": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_id", "packet_ref", "proof_index_ref", "freshness_slo", "slo_state", "evidence_refs"],
      "properties": {
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "proof_index_ref": { "$ref": "#/$defs/non_empty_string" },
        "captured_at": { "type": ["string", "null"] },
        "freshness_slo": { "$ref": "#/$defs/freshness_slo" },
        "slo_state": { "$ref": "#/$defs/freshness_slo_state" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "freshness_slo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
      "properties": {
        "target_max_age_days": { "type": "integer", "minimum": 1 },
        "warn_within_days": { "type": "integer", "minimum": 0 },
        "slo_register_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "freshness_slo_state": {
      "type": "string",
      "enum": ["current", "due_for_refresh", "breached", "missing"]
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_ref", "signed_off", "signed_at"],
      "properties": {
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "signed_off": { "type": "boolean" },
        "signed_at": { "type": ["string", "null"] }
      }
    },
    "qualification_waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["waiver_ref", "title", "expires_at", "rationale"],
      "properties": {
        "waiver_ref": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "expires_at": { "type": "string", "format": "date" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "publication_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publication_gate", "decision", "blocking_rule_ids", "blocking_entry_ids", "rationale"],
      "properties": {
        "publication_gate": { "$ref": "#/$defs/non_empty_string" },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "blocking_entry_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_bundles",
        "bundles_signed_current",
        "bundles_signed_on_waiver",
        "bundles_narrowed",
        "bundles_release_blocking",
        "bundles_release_blocking_narrowed",
        "bundles_on_waiver",
        "benchmark_bundles",
        "compatibility_bundles",
        "migration_bundles",
        "accessibility_bundles",
        "docs_help_bundles",
        "security_bundles",
        "artifact_graph_bundles",
        "qualification_bundles",
        "release_promotion_bundles",
        "dependency_bundles",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "rules_firing"
      ],
      "properties": {
        "total_bundles": { "type": "integer", "minimum": 0 },
        "bundles_signed_current": { "type": "integer", "minimum": 0 },
        "bundles_signed_on_waiver": { "type": "integer", "minimum": 0 },
        "bundles_narrowed": { "type": "integer", "minimum": 0 },
        "bundles_release_blocking": { "type": "integer", "minimum": 0 },
        "bundles_release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "bundles_on_waiver": { "type": "integer", "minimum": 0 },
        "benchmark_bundles": { "type": "integer", "minimum": 0 },
        "compatibility_bundles": { "type": "integer", "minimum": 0 },
        "migration_bundles": { "type": "integer", "minimum": 0 },
        "accessibility_bundles": { "type": "integer", "minimum": 0 },
        "docs_help_bundles": { "type": "integer", "minimum": 0 },
        "security_bundles": { "type": "integer", "minimum": 0 },
        "artifact_graph_bundles": { "type": "integer", "minimum": 0 },
        "qualification_bundles": { "type": "integer", "minimum": 0 },
        "release_promotion_bundles": { "type": "integer", "minimum": 0 },
        "dependency_bundles": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
