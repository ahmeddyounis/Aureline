{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/database-statement-safety-and-result-grid-qualification.schema.json",
  "title": "Database statement-safety and result-grid qualification packet",
  "description": "Release boundary schema for the promoted-build database qualification packet. The packet binds every exposed data-tooling surface to connection class, execution origin, auth source, write posture, statement safety, transaction posture, result scope, export redaction, query-history privacy, explain-plan freshness, and handoff lineage. It is a qualification and downgrade artifact, not a claim that mature live database tooling ships.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "as_of",
    "release_doc_ref",
    "help_doc_ref",
    "schema_ref",
    "surfaces",
    "connection_corpus",
    "statement_labs",
    "result_grid_labs",
    "query_history_labs",
    "explain_plan_labs",
    "handoff_labs",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": {
      "type": "string",
      "const": "database_statement_safety_and_result_grid_qualification"
    },
    "packet_id": { "$ref": "#/$defs/opaque_id" },
    "as_of": { "type": "string", "format": "date" },
    "release_doc_ref": { "$ref": "#/$defs/path_ref" },
    "help_doc_ref": { "$ref": "#/$defs/path_ref" },
    "schema_ref": { "$ref": "#/$defs/path_ref" },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surface" }
    },
    "connection_corpus": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/connection_corpus_row" }
    },
    "statement_labs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/statement_lab_row" }
    },
    "result_grid_labs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/result_grid_lab_row" }
    },
    "query_history_labs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/query_history_lab_row" }
    },
    "explain_plan_labs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/explain_plan_lab_row" }
    },
    "handoff_labs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/handoff_lab_row" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$"
    },
    "path_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 720
    },
    "qualification_label": {
      "type": "string",
      "enum": [
        "stable",
        "preview",
        "labs",
        "inspect_only",
        "import_only"
      ]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "connection_picker",
        "sql_run_bar",
        "statement_safety_review",
        "result_grid",
        "query_history",
        "explain_plan",
        "handoff_card",
        "row_mutation"
      ]
    },
    "connection_class": {
      "type": "string",
      "enum": [
        "embedded_local",
        "local_network_container_dev",
        "remote_controlled_env",
        "cloud_warehouse",
        "imported_snapshot"
      ]
    },
    "execution_origin": {
      "type": "string",
      "enum": [
        "desktop_sql_editor",
        "cli_headless_inspect",
        "notebook_or_chart_handoff",
        "ai_tool_review",
        "support_export",
        "admin_policy_review"
      ]
    },
    "auth_source_mode": {
      "type": "string",
      "enum": [
        "no_auth_local_file",
        "secret_broker_handle",
        "delegated_identity",
        "policy_injected_credential",
        "managed_service_identity",
        "imported_no_live_auth",
        "policy_blocked"
      ]
    },
    "write_posture": {
      "type": "string",
      "enum": [
        "read_only",
        "write_capable",
        "policy_blocked"
      ]
    },
    "statement_class": {
      "type": "string",
      "enum": [
        "read_only_query",
        "dml",
        "ddl",
        "session_affecting",
        "multi_statement",
        "ambiguous",
        "blocked"
      ]
    },
    "transaction_posture": {
      "type": "string",
      "enum": [
        "autocommit",
        "explicit_transaction",
        "explain_only",
        "not_executable",
        "unknown_requires_review"
      ]
    },
    "result_scope": {
      "type": "string",
      "enum": [
        "full_result",
        "visible_rows_only",
        "truncated",
        "streaming_unknown_total",
        "imported_snapshot"
      ]
    },
    "redaction_mode": {
      "type": "string",
      "enum": [
        "metadata_only",
        "redacted_typed",
        "reviewed_visible_values",
        "policy_blocked"
      ]
    },
    "plan_mode": {
      "type": "string",
      "enum": [
        "estimated",
        "actual",
        "imported_stale"
      ]
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "captured_at",
        "evidence_refs"
      ],
      "properties": {
        "packet_id": { "$ref": "#/$defs/opaque_id" },
        "packet_ref": { "$ref": "#/$defs/path_ref" },
        "proof_index_ref": { "$ref": "#/$defs/opaque_id" },
        "captured_at": { "type": "string", "format": "date" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/path_ref" }
        }
      }
    },
    "guards": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "connection_class_visible",
        "execution_origin_visible",
        "auth_source_visible",
        "target_identity_visible",
        "write_posture_visible",
        "statement_safety_visible",
        "transaction_posture_visible",
        "result_scope_visible",
        "export_redaction_visible"
      ],
      "properties": {
        "connection_class_visible": { "type": "boolean" },
        "execution_origin_visible": { "type": "boolean" },
        "auth_source_visible": { "type": "boolean" },
        "target_identity_visible": { "type": "boolean" },
        "write_posture_visible": { "type": "boolean" },
        "statement_safety_visible": { "type": "boolean" },
        "transaction_posture_visible": { "type": "boolean" },
        "result_scope_visible": { "type": "boolean" },
        "export_redaction_visible": { "type": "boolean" }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "displayed_label",
        "qualification_packet",
        "guards",
        "downgrade_if_missing",
        "rationale"
      ],
      "properties": {
        "surface_id": { "$ref": "#/$defs/opaque_id" },
        "title": { "$ref": "#/$defs/sentence" },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "promoted_build_surface": { "type": "boolean" },
        "claim_label": { "$ref": "#/$defs/qualification_label" },
        "displayed_label": { "$ref": "#/$defs/qualification_label" },
        "qualification_packet": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/proof" }
          ]
        },
        "guards": { "$ref": "#/$defs/guards" },
        "downgrade_if_missing": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/sentence" }
      }
    },
    "connection_corpus_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "connection_class",
        "execution_origin",
        "auth_source_mode",
        "write_posture",
        "target_identity_ref",
        "engine",
        "current_database_or_schema_ref",
        "picker_row",
        "run_bar",
        "history_row",
        "export_review",
        "explain_plan"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "connection_class": { "$ref": "#/$defs/connection_class" },
        "execution_origin": { "$ref": "#/$defs/execution_origin" },
        "auth_source_mode": { "$ref": "#/$defs/auth_source_mode" },
        "write_posture": { "$ref": "#/$defs/write_posture" },
        "target_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "engine": { "type": "string", "minLength": 1 },
        "current_database_or_schema_ref": { "$ref": "#/$defs/opaque_id" },
        "picker_row": { "type": "boolean", "const": true },
        "run_bar": { "type": "boolean", "const": true },
        "history_row": { "type": "boolean", "const": true },
        "export_review": { "type": "boolean", "const": true },
        "explain_plan": { "type": "boolean", "const": true }
      }
    },
    "statement_lab_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "statement_class",
        "transaction_posture",
        "write_posture",
        "object_impact_visible",
        "review_or_step_up_required",
        "blocked",
        "protected_target"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "statement_class": { "$ref": "#/$defs/statement_class" },
        "transaction_posture": { "$ref": "#/$defs/transaction_posture" },
        "write_posture": { "$ref": "#/$defs/write_posture" },
        "object_impact_visible": { "type": "boolean" },
        "review_or_step_up_required": { "type": "boolean" },
        "blocked": { "type": "boolean" },
        "protected_target": { "type": "boolean" }
      }
    },
    "result_grid_lab_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "result_scope",
        "redaction_mode",
        "virtualization",
        "large_cell_expansion",
        "typed_column_headers",
        "truncation_disclosed",
        "safe_preview_for_binary_or_rich_payloads",
        "copy_export_preserves_scope_format_redaction"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "result_scope": { "$ref": "#/$defs/result_scope" },
        "redaction_mode": { "$ref": "#/$defs/redaction_mode" },
        "virtualization": { "type": "boolean", "const": true },
        "large_cell_expansion": { "type": "boolean", "const": true },
        "typed_column_headers": { "type": "boolean", "const": true },
        "truncation_disclosed": { "type": "boolean", "const": true },
        "safe_preview_for_binary_or_rich_payloads": { "type": "boolean", "const": true },
        "copy_export_preserves_scope_format_redaction": { "type": "boolean", "const": true }
      }
    },
    "query_history_lab_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "local_first",
        "bounded",
        "redactable",
        "metadata_first",
        "statement_fingerprint_retained",
        "no_raw_secret_statement_or_payload"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "local_first": { "type": "boolean", "const": true },
        "bounded": { "type": "boolean", "const": true },
        "redactable": { "type": "boolean", "const": true },
        "metadata_first": { "type": "boolean", "const": true },
        "statement_fingerprint_retained": { "type": "boolean", "const": true },
        "no_raw_secret_statement_or_payload": { "type": "boolean", "const": true }
      }
    },
    "explain_plan_lab_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "plan_mode",
        "engine_version_ref",
        "captured_at",
        "implies_execution",
        "comparability_claimed",
        "stale_import_labeled"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "plan_mode": { "$ref": "#/$defs/plan_mode" },
        "engine_version_ref": { "$ref": "#/$defs/opaque_id" },
        "captured_at": { "type": "string", "format": "date-time" },
        "implies_execution": { "type": "boolean" },
        "comparability_claimed": { "type": "boolean" },
        "stale_import_labeled": { "type": "boolean" }
      }
    },
    "handoff_lab_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "destination_class",
        "source_refs_preserved",
        "row_column_scope_preserved",
        "type_fidelity_notes_preserved",
        "freshness_preserved",
        "share_local_restrictions_preserved"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "destination_class": { "type": "string", "minLength": 1 },
        "source_refs_preserved": { "type": "boolean", "const": true },
        "row_column_scope_preserved": { "type": "boolean", "const": true },
        "type_fidelity_notes_preserved": { "type": "boolean", "const": true },
        "freshness_preserved": { "type": "boolean", "const": true },
        "share_local_restrictions_preserved": { "type": "boolean", "const": true }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promoted_surface_count",
        "stable_surface_count",
        "narrowed_surface_count",
        "connection_corpus_count",
        "statement_lab_count",
        "result_grid_lab_count",
        "query_history_lab_count",
        "explain_plan_lab_count",
        "handoff_lab_count"
      ],
      "properties": {
        "promoted_surface_count": { "type": "integer", "minimum": 0 },
        "stable_surface_count": { "type": "integer", "minimum": 0 },
        "narrowed_surface_count": { "type": "integer", "minimum": 0 },
        "connection_corpus_count": { "type": "integer", "minimum": 0 },
        "statement_lab_count": { "type": "integer", "minimum": 0 },
        "result_grid_lab_count": { "type": "integer", "minimum": 0 },
        "query_history_lab_count": { "type": "integer", "minimum": 0 },
        "explain_plan_lab_count": { "type": "integer", "minimum": 0 },
        "handoff_lab_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
