{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/release_center.schema.json",
  "title": "Aureline beta release-center pack",
  "description": "Boundary schema for the release_center_pack record consumed by release-center, headless validation, docs/help truth, support export, security review, and compatibility review. The pack binds the candidate exact-build identity, artifact graph, symbol manifest, SBOM or attestation links, compatibility and claim evidence, support pivots, and freshness/completeness gates into one metadata-only beta packet.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "pack_id",
    "generated_at",
    "as_of",
    "owner",
    "status",
    "source_refs",
    "candidate",
    "artifact_graph_truth",
    "symbol_manifest",
    "proof_links",
    "compatibility_and_claims",
    "support_pivots",
    "completeness_checks",
    "freshness",
    "support_projection",
    "acceptance"
  ],
  "properties": {
    "schema_version": { "$ref": "#/$defs/schema_version" },
    "record_kind": { "type": "string", "const": "release_center_pack" },
    "pack_id": { "$ref": "#/$defs/non_empty_string" },
    "generated_at": { "$ref": "#/$defs/date_time" },
    "as_of": { "$ref": "#/$defs/date" },
    "owner": { "$ref": "#/$defs/non_empty_string" },
    "status": {
      "type": "string",
      "enum": [
        "current_beta_pack",
        "degraded_hold",
        "blocked_incomplete"
      ]
    },
    "source_refs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/repo_or_opaque_ref" }
    },
    "candidate": { "$ref": "#/$defs/candidate" },
    "artifact_graph_truth": { "$ref": "#/$defs/artifact_graph_truth" },
    "symbol_manifest": { "$ref": "#/$defs/symbol_manifest" },
    "proof_links": { "$ref": "#/$defs/proof_links" },
    "compatibility_and_claims": { "$ref": "#/$defs/compatibility_and_claims" },
    "support_pivots": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/support_pivot" }
    },
    "completeness_checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/completeness_check" }
    },
    "freshness": { "$ref": "#/$defs/freshness" },
    "support_projection": { "$ref": "#/$defs/support_projection" },
    "acceptance": { "$ref": "#/$defs/acceptance" }
  },
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "date_time": {
      "type": "string",
      "format": "date-time"
    },
    "repo_or_opaque_ref": {
      "type": "string",
      "minLength": 1
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/repo_or_opaque_ref" },
      "uniqueItems": true
    },
    "non_empty_ref_array": {
      "allOf": [
        { "$ref": "#/$defs/ref_array" },
        { "minItems": 1 }
      ]
    },
    "exact_build_identity_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^build-id:aureline:[a-z0-9._:-]+(?:-[a-z0-9._:-]+)*$"
      },
      "uniqueItems": true
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_candidate_ref",
        "version",
        "channel_class",
        "stage_class",
        "artifact_bundle_ref",
        "exact_build_identity_refs",
        "artifact_graph_ref",
        "artifact_graph_support_projection_ref",
        "rollback_target_ref"
      ],
      "properties": {
        "release_candidate_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "version": { "$ref": "#/$defs/non_empty_string" },
        "channel_class": { "$ref": "#/$defs/non_empty_string" },
        "stage_class": { "$ref": "#/$defs/non_empty_string" },
        "artifact_bundle_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "exact_build_identity_refs": { "$ref": "#/$defs/exact_build_identity_refs" },
        "artifact_graph_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "artifact_graph_support_projection_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "rollback_target_ref": { "$ref": "#/$defs/repo_or_opaque_ref" }
      }
    },
    "artifact_graph_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "graph_id",
        "graph_ref",
        "support_projection_ref",
        "artifact_bundle_ref",
        "artifact_node_count",
        "required_artifact_node_count",
        "family_classes",
        "node_refs",
        "required_node_refs",
        "release_center_object_refs"
      ],
      "properties": {
        "graph_id": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "graph_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "support_projection_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "artifact_bundle_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "artifact_node_count": { "type": "integer", "minimum": 1 },
        "required_artifact_node_count": { "type": "integer", "minimum": 1 },
        "family_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "node_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "required_node_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "release_center_object_refs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "release_candidate_ref",
            "publish_target_refs",
            "promotion_timeline_refs",
            "rollback_record_refs"
          ],
          "properties": {
            "release_candidate_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
            "publish_target_refs": { "$ref": "#/$defs/non_empty_ref_array" },
            "promotion_timeline_refs": { "$ref": "#/$defs/non_empty_ref_array" },
            "rollback_record_refs": { "$ref": "#/$defs/non_empty_ref_array" }
          }
        }
      }
    },
    "symbol_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_ref",
        "manifest_id",
        "primary_exact_build_identity_ref",
        "release_channel_class",
        "workspace_version",
        "target_triple",
        "module_count",
        "module_refs",
        "exact_build_identity_refs",
        "symbolication_identity_refs",
        "support_archive_identity_refs",
        "redaction_class",
        "storage_classes",
        "raw_private_material_excluded",
        "ambient_authority_excluded"
      ],
      "properties": {
        "manifest_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "manifest_id": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "primary_exact_build_identity_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "release_channel_class": { "$ref": "#/$defs/non_empty_string" },
        "workspace_version": { "$ref": "#/$defs/non_empty_string" },
        "target_triple": { "$ref": "#/$defs/non_empty_string" },
        "module_count": { "type": "integer", "minimum": 1 },
        "module_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "exact_build_identity_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "symbolication_identity_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "support_archive_identity_refs": { "$ref": "#/$defs/ref_array" },
        "redaction_class": { "$ref": "#/$defs/non_empty_string" },
        "storage_classes": { "$ref": "#/$defs/non_empty_ref_array" },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "ambient_authority_excluded": { "type": "boolean", "const": true }
      }
    },
    "proof_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "link_id",
        "link_class",
        "artifact_node_ref",
        "source_ref",
        "support_ref",
        "exact_build_identity_ref",
        "state"
      ],
      "properties": {
        "link_id": { "$ref": "#/$defs/non_empty_string" },
        "link_class": {
          "type": "string",
          "enum": [
            "sbom_document",
            "signed_attestation",
            "provenance_capture",
            "clean_room_rebuild",
            "release_evidence"
          ]
        },
        "artifact_node_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "source_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "support_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "exact_build_identity_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "state": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "proof_links": {
      "type": "object",
      "additionalProperties": false,
      "required": ["links", "sbom_or_attestation_required", "private_material_included"],
      "properties": {
        "links": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/proof_link" }
        },
        "sbom_or_attestation_required": { "type": "boolean", "const": true },
        "private_material_included": { "type": "boolean", "const": false }
      }
    },
    "compatibility_and_claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_manifest_ref",
        "compatibility_report_ref",
        "benchmark_snapshot_ref",
        "docs_truth_report_ref",
        "distributed_compatibility_refs",
        "support_projection_refs"
      ],
      "properties": {
        "claim_manifest_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "compatibility_report_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "benchmark_snapshot_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "docs_truth_report_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "distributed_compatibility_refs": { "$ref": "#/$defs/ref_array" },
        "support_projection_refs": { "$ref": "#/$defs/non_empty_ref_array" }
      }
    },
    "support_pivot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pivot_id",
        "pivot_class",
        "display_name",
        "primary_ref",
        "support_ref",
        "linked_refs",
        "consumer_refs",
        "private_lookup_required"
      ],
      "properties": {
        "pivot_id": { "$ref": "#/$defs/non_empty_string" },
        "pivot_class": {
          "type": "string",
          "enum": [
            "artifact_graph",
            "crash_symbolication",
            "security_advisory",
            "compatibility_report",
            "release_claims",
            "benchmark_public_proof",
            "docs_help_truth",
            "update_rollback",
            "distributed_compatibility",
            "reproducible_release_candidate",
            "support_export",
            "sbom_or_attestation"
          ]
        },
        "display_name": { "$ref": "#/$defs/non_empty_string" },
        "primary_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "support_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "linked_refs": { "$ref": "#/$defs/ref_array" },
        "consumer_refs": { "$ref": "#/$defs/ref_array" },
        "private_lookup_required": { "type": "boolean", "const": false }
      }
    },
    "completeness_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "check_class",
        "source_ref",
        "required_state",
        "actual_state",
        "blocks_promotion",
        "support_ref"
      ],
      "properties": {
        "check_id": { "$ref": "#/$defs/non_empty_string" },
        "check_class": { "$ref": "#/$defs/non_empty_string" },
        "source_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "required_state": { "$ref": "#/$defs/non_empty_string" },
        "actual_state": { "$ref": "#/$defs/non_empty_string" },
        "blocks_promotion": { "type": "boolean" },
        "support_ref": { "$ref": "#/$defs/repo_or_opaque_ref" }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captured_at",
        "stale_after",
        "freshness_class",
        "stale_propagation_profile"
      ],
      "properties": {
        "captured_at": { "$ref": "#/$defs/date_time" },
        "stale_after": {
          "type": "string",
          "pattern": "^P[0-9]+D$"
        },
        "freshness_class": { "$ref": "#/$defs/non_empty_string" },
        "stale_propagation_profile": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "support_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projection_id", "output_ref", "redaction_class", "consumer_refs"],
      "properties": {
        "projection_id": { "$ref": "#/$defs/non_empty_string" },
        "output_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "redaction_class": { "$ref": "#/$defs/non_empty_string" },
        "consumer_refs": { "$ref": "#/$defs/non_empty_ref_array" }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation_commands", "fixture_manifest_ref", "accepted_states"],
      "properties": {
        "validation_commands": { "$ref": "#/$defs/non_empty_ref_array" },
        "fixture_manifest_ref": { "$ref": "#/$defs/repo_or_opaque_ref" },
        "accepted_states": { "$ref": "#/$defs/non_empty_ref_array" }
      }
    }
  }
}
