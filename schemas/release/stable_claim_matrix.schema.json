{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/stable_claim_matrix.schema.json",
  "title": "Aureline stable claim matrix",
  "description": "Boundary schema for artifacts/release/stable_claim_matrix.json. The matrix freezes the stable claim matrix, launch cutline, qualification rows, and shiproom stop rules. Each row binds one claim subject to the stable level it is put forward as, a qualification row (proof refs, freshness window, optional waiver, owner sign-off), the qualification state earned, the active downgrade reasons, and the level it effectively holds after narrowing. The launch_cutline fixes the boundary between claimed-Stable and narrowed-below-Stable; the stop_rules name the closed conditions that gate stable promotion; and the promotion block records the resulting proceed/hold verdict. The typed consumer (aureline_release::stable_claim_matrix) and ci/check_stable_claim_matrix.py both read this artifact, so the structural invariants are enforced without a cargo build in CI. Date arithmetic (waiver expiry and evidence staleness against as_of) is enforced by the CI gate.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "matrix_id",
    "status",
    "overview_page",
    "as_of",
    "claim_levels",
    "qualification_states",
    "downgrade_reasons",
    "stop_rule_actions",
    "launch_cutline",
    "stop_rules",
    "rows",
    "promotion",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "stable_claim_matrix" },
    "matrix_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "overview_page": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "format": "date" },
    "claim_levels": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/claim_level" }
    },
    "qualification_states": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/qualification_state" }
    },
    "downgrade_reasons": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/downgrade_reason" }
    },
    "stop_rule_actions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/stop_action" }
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "const": "stable" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim_level" }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim_level" }
        },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "stop_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stop_rule" }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/row" }
    },
    "promotion": { "$ref": "#/$defs/promotion" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows",
        "rows_holding_stable",
        "rows_narrowed_below_cutline",
        "rows_on_active_waiver",
        "total_active_downgrade_reasons",
        "stop_rules_firing"
      ],
      "properties": {
        "total_rows": { "type": "integer", "minimum": 0 },
        "rows_holding_stable": { "type": "integer", "minimum": 0 },
        "rows_narrowed_below_cutline": { "type": "integer", "minimum": 0 },
        "rows_on_active_waiver": { "type": "integer", "minimum": 0 },
        "total_active_downgrade_reasons": { "type": "integer", "minimum": 0 },
        "stop_rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "claim_level": {
      "type": "string",
      "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
    },
    "qualification_state": {
      "type": "string",
      "enum": [
        "qualified",
        "provisional_on_waiver",
        "not_qualified",
        "evidence_stale",
        "waiver_expired"
      ]
    },
    "downgrade_reason": {
      "type": "string",
      "enum": [
        "qualification_evidence_missing",
        "qualification_evidence_stale",
        "waiver_expired",
        "freshness_window_exceeded",
        "owner_signoff_missing",
        "compatibility_row_degraded",
        "blocking_defect_open"
      ]
    },
    "stop_action": {
      "type": "string",
      "enum": [
        "hold_promotion",
        "narrow_claim",
        "refresh_evidence_packet",
        "staff_correction_lane",
        "block_milestone_close"
      ]
    },
    "ref_array": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "nullable_date": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "format": "date" }
      ]
    },
    "stop_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_levels",
        "default_action",
        "blocks_promotion",
        "rationale"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "trigger_reason": { "$ref": "#/$defs/downgrade_reason" },
        "applies_to_levels": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/claim_level" }
        },
        "default_action": { "$ref": "#/$defs/stop_action" },
        "blocks_promotion": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_refs", "proof_index_ref", "captured_at", "freshness_window_days"],
      "properties": {
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "proof_index_ref": { "type": "string", "minLength": 1 },
        "captured_at": { "$ref": "#/$defs/nullable_date" },
        "freshness_window_days": { "type": "integer", "minimum": 1 }
      }
    },
    "waiver": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["waiver_ref", "expires_at", "reason"],
          "properties": {
            "waiver_ref": { "type": "string", "minLength": 1 },
            "expires_at": { "type": "string", "format": "date" },
            "reason": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_ref", "signed_off", "signed_at"],
      "properties": {
        "owner_ref": { "type": "string", "minLength": 1 },
        "signed_off": { "type": "boolean" },
        "signed_at": { "$ref": "#/$defs/nullable_date" }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "title",
        "subject_family",
        "claimed_level",
        "qualification_state",
        "evidence",
        "waiver",
        "owner_signoff",
        "active_downgrade_reasons",
        "effective_level",
        "publication_destinations",
        "cutline_row_refs",
        "rationale"
      ],
      "properties": {
        "claim_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "subject_family": { "type": "string", "minLength": 1 },
        "claimed_level": { "$ref": "#/$defs/claim_level" },
        "qualification_state": { "$ref": "#/$defs/qualification_state" },
        "evidence": { "$ref": "#/$defs/evidence" },
        "waiver": { "$ref": "#/$defs/waiver" },
        "owner_signoff": { "$ref": "#/$defs/owner_signoff" },
        "active_downgrade_reasons": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/downgrade_reason" }
        },
        "effective_level": { "$ref": "#/$defs/claim_level" },
        "publication_destinations": { "$ref": "#/$defs/ref_array" },
        "cutline_row_refs": { "$ref": "#/$defs/ref_array" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_claim_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": { "$ref": "#/$defs/ref_array" },
        "blocking_claim_ids": { "$ref": "#/$defs/ref_array" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    }
  }
}
