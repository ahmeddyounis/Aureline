{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/promotion_timeline_entry.schema.json",
  "title": "Aureline release promotion timeline entry",
  "description": "Boundary schema for promotion_timeline_entry_record frozen in docs/release/release_status_surface_contract.md. Timeline entries explain how a candidate, artifact family, channel pointer, registry item, mirror feed, marketplace listing, docs claim, or deprecation state moved, what semantic change was involved, what reach widened, who owns the next gate, which evidence is linked, and which recovery window remains. The record projects release-center and update-manifest refs; it does not create a separate promotion vocabulary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "promotion_timeline_entry_schema_version",
    "record_kind",
    "timeline_entry_id",
    "release_status_card_ref",
    "candidate_ref",
    "source_refs",
    "timeline_event_class",
    "source_stage_class",
    "destination_stage_class",
    "current_stage_class",
    "semantic_change_class",
    "affected_artifact_scope",
    "widened_reach",
    "owner",
    "next_gate",
    "evidence_freshness",
    "linked_evidence",
    "reversible_window",
    "break_glass_state_class",
    "rendering_contract",
    "notes"
  ],
  "$defs": {
    "promotion_timeline_entry_schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/non_empty_string" }
      ]
    },
    "utc_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_utc_datetime": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/utc_datetime" }
      ]
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "non_empty_ref_array": {
      "allOf": [
        { "$ref": "#/$defs/ref_array" },
        { "minItems": 1 }
      ]
    },
    "release_stage_class": {
      "type": "string",
      "enum": [
        "draft",
        "local_preview",
        "internal_ring",
        "public_preview",
        "stable_candidate",
        "stable",
        "lts_candidate",
        "lts",
        "canary",
        "pilot",
        "broad",
        "mirror_staged",
        "mirror_published",
        "registry_published",
        "emergency_active",
        "paused",
        "rolled_back",
        "revoked",
        "yanked",
        "repinned",
        "reconciled"
      ]
    },
    "timeline_event_class": {
      "type": "string",
      "enum": [
        "local_build_recorded",
        "target_staged",
        "candidate_promoted",
        "stable_published",
        "lts_published",
        "mirror_published",
        "registry_published",
        "rollback_applied",
        "artifact_yanked",
        "artifact_revoked",
        "channel_repinned",
        "deprecation_announced",
        "reconciled"
      ]
    },
    "artifact_family_class": {
      "type": "string",
      "enum": [
        "ide_binary",
        "ide_debug_symbols",
        "cli_binary",
        "cli_debug_symbols",
        "sdk_library",
        "source_map_bundle",
        "docs_pack",
        "schema_export",
        "reference_pack",
        "sbom_document",
        "signed_attestation",
        "source_bundle",
        "crash_symbols_archive",
        "reproducibility_pack",
        "support_runbook_bundle",
        "release_evidence_packet",
        "update_metadata",
        "revocation_manifest",
        "policy_bundle",
        "extension_package",
        "marketplace_metadata",
        "remote_agent_tarball",
        "remote_helper_tarball"
      ]
    },
    "target_scope_class": {
      "type": "string",
      "enum": [
        "local_build_output",
        "update_channel",
        "managed_ring",
        "registry_namespace",
        "marketplace_listing",
        "mirror_feed",
        "air_gap_bundle",
        "docs_claim",
        "support_packet"
      ]
    },
    "semantic_change_class": {
      "type": "string",
      "enum": [
        "no_public_change",
        "patch",
        "minor",
        "major",
        "pre_release",
        "hotfix",
        "security_only",
        "backport",
        "schema_epoch",
        "manual_review_required"
      ]
    },
    "audience_class": {
      "type": "string",
      "enum": [
        "developer_local",
        "release_team",
        "internal_dogfood",
        "design_partner",
        "public_preview_user",
        "public_stable_user",
        "lts_admin",
        "mirror_operator",
        "air_gapped_admin",
        "registry_consumer",
        "marketplace_consumer",
        "security_responder",
        "affected_admin",
        "support_operator"
      ]
    },
    "visibility_class": {
      "type": "string",
      "enum": [
        "local_only",
        "internal",
        "private_partner",
        "public_preview",
        "public_stable",
        "public_lts",
        "mirror_only",
        "registry_public",
        "registry_private",
        "emergency_limited",
        "support_only"
      ]
    },
    "owner_actor_class": {
      "type": "string",
      "enum": [
        "developer",
        "release_operator",
        "security_operator",
        "mirror_operator",
        "registry_publisher",
        "headless_automation",
        "support_operator",
        "org_admin"
      ]
    },
    "gate_state_class": {
      "type": "string",
      "enum": [
        "not_started",
        "ready",
        "blocked",
        "waived",
        "waiting_for_evidence",
        "executed",
        "not_applicable"
      ]
    },
    "evidence_freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "current_with_waiver",
        "stale_blocking",
        "stale_non_blocking",
        "missing_blocking",
        "not_applicable"
      ]
    },
    "evidence_type_class": {
      "type": "string",
      "enum": [
        "release_evidence_packet",
        "compatibility_report",
        "benchmark_report",
        "schema_diff",
        "api_diff",
        "security_advisory",
        "attestation",
        "sbom",
        "checksum_bundle",
        "signature_receipt",
        "support_bundle",
        "migration_guidance",
        "waiver_packet",
        "manual_summary"
      ]
    },
    "break_glass_state_class": {
      "type": "string",
      "enum": [
        "not_used",
        "eligible_but_not_used",
        "active_pending_reconciliation",
        "reconciled",
        "superseded_by_signed_action",
        "expired_without_reconciliation",
        "forbidden_for_action"
      ]
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_center_event_ref",
        "publication_action_ref",
        "publish_target_ref",
        "update_manifest_ref",
        "support_bundle_refs"
      ],
      "properties": {
        "release_center_event_ref": { "$ref": "#/$defs/nullable_string" },
        "publication_action_ref": { "$ref": "#/$defs/nullable_string" },
        "publish_target_ref": { "$ref": "#/$defs/nullable_string" },
        "update_manifest_ref": { "$ref": "#/$defs/nullable_string" },
        "support_bundle_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "artifact_scope_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_family_class",
        "artifact_ref",
        "exact_build_identity_ref",
        "target_scope_class",
        "scope_note"
      ],
      "properties": {
        "artifact_family_class": { "$ref": "#/$defs/artifact_family_class" },
        "artifact_ref": { "$ref": "#/$defs/non_empty_string" },
        "exact_build_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "target_scope_class": { "$ref": "#/$defs/target_scope_class" },
        "scope_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "widened_reach": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_audience_class",
        "to_audience_class",
        "from_visibility_class",
        "to_visibility_class",
        "rollout_ring_ref",
        "deployment_profile_refs",
        "widened_claim_refs",
        "widening_note"
      ],
      "properties": {
        "from_audience_class": { "$ref": "#/$defs/nullable_string" },
        "to_audience_class": { "$ref": "#/$defs/nullable_string" },
        "from_visibility_class": { "$ref": "#/$defs/nullable_string" },
        "to_visibility_class": { "$ref": "#/$defs/nullable_string" },
        "rollout_ring_ref": { "$ref": "#/$defs/nullable_string" },
        "deployment_profile_refs": { "$ref": "#/$defs/ref_array" },
        "widened_claim_refs": { "$ref": "#/$defs/ref_array" },
        "widening_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_ref",
        "actor_class",
        "approval_refs",
        "owner_note"
      ],
      "properties": {
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "actor_class": { "$ref": "#/$defs/owner_actor_class" },
        "approval_refs": { "$ref": "#/$defs/ref_array" },
        "owner_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "next_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_ref",
        "gate_state_class",
        "next_stage_class",
        "required_evidence_refs",
        "blocking_reason_refs",
        "gate_note"
      ],
      "properties": {
        "gate_ref": { "$ref": "#/$defs/non_empty_string" },
        "gate_state_class": { "$ref": "#/$defs/gate_state_class" },
        "next_stage_class": { "$ref": "#/$defs/nullable_string" },
        "required_evidence_refs": { "$ref": "#/$defs/ref_array" },
        "blocking_reason_refs": { "$ref": "#/$defs/ref_array" },
        "gate_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "evidence_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness_class",
        "latest_evidence_at",
        "required_evidence_refs",
        "waiver_packet_refs",
        "freshness_policy_ref",
        "freshness_note"
      ],
      "properties": {
        "freshness_class": { "$ref": "#/$defs/evidence_freshness_class" },
        "latest_evidence_at": { "$ref": "#/$defs/nullable_utc_datetime" },
        "required_evidence_refs": { "$ref": "#/$defs/ref_array" },
        "waiver_packet_refs": { "$ref": "#/$defs/ref_array" },
        "freshness_policy_ref": { "$ref": "#/$defs/non_empty_string" },
        "freshness_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "linked_evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_type_class",
        "evidence_ref",
        "linked_artifact_refs",
        "generated_for_ref",
        "freshness_note"
      ],
      "properties": {
        "evidence_type_class": { "$ref": "#/$defs/evidence_type_class" },
        "evidence_ref": { "$ref": "#/$defs/non_empty_string" },
        "linked_artifact_refs": { "$ref": "#/$defs/ref_array" },
        "generated_for_ref": { "$ref": "#/$defs/non_empty_string" },
        "freshness_note": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  },
  "properties": {
    "promotion_timeline_entry_schema_version": {
      "$ref": "#/$defs/promotion_timeline_entry_schema_version"
    },
    "record_kind": {
      "type": "string",
      "const": "promotion_timeline_entry_record"
    },
    "timeline_entry_id": {
      "type": "string",
      "pattern": "^promotion_timeline:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "release_status_card_ref": { "$ref": "#/$defs/non_empty_string" },
    "candidate_ref": { "$ref": "#/$defs/non_empty_string" },
    "source_refs": { "$ref": "#/$defs/source_refs" },
    "timeline_event_class": { "$ref": "#/$defs/timeline_event_class" },
    "source_stage_class": { "$ref": "#/$defs/release_stage_class" },
    "destination_stage_class": { "$ref": "#/$defs/release_stage_class" },
    "current_stage_class": { "$ref": "#/$defs/release_stage_class" },
    "semantic_change_class": { "$ref": "#/$defs/semantic_change_class" },
    "affected_artifact_scope": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_scope_item" },
      "minItems": 1
    },
    "widened_reach": { "$ref": "#/$defs/widened_reach" },
    "owner": { "$ref": "#/$defs/owner" },
    "next_gate": { "$ref": "#/$defs/next_gate" },
    "evidence_freshness": { "$ref": "#/$defs/evidence_freshness" },
    "linked_evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/linked_evidence_item" },
      "minItems": 1
    },
    "reversible_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reversible",
        "reversible_until",
        "rollback_panel_ref",
        "repin_target_ref",
        "window_note"
      ],
      "properties": {
        "reversible": { "type": "boolean" },
        "reversible_until": { "$ref": "#/$defs/nullable_utc_datetime" },
        "rollback_panel_ref": { "$ref": "#/$defs/nullable_string" },
        "repin_target_ref": { "$ref": "#/$defs/nullable_string" },
        "window_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "break_glass_state_class": { "$ref": "#/$defs/break_glass_state_class" },
    "rendering_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stages_visible",
        "widened_reach_visible",
        "owner_visible",
        "next_gate_visible",
        "evidence_visible",
        "recovery_window_visible"
      ],
      "properties": {
        "stages_visible": { "type": "boolean", "const": true },
        "widened_reach_visible": { "type": "boolean", "const": true },
        "owner_visible": { "type": "boolean", "const": true },
        "next_gate_visible": { "type": "boolean", "const": true },
        "evidence_visible": { "type": "boolean", "const": true },
        "recovery_window_visible": { "type": "boolean", "const": true }
      }
    },
    "notes": { "$ref": "#/$defs/non_empty_string" }
  }
}
