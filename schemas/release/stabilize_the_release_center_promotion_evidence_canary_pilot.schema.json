{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/stabilize_the_release_center_promotion_evidence_canary_pilot.schema.json",
  "title": "Aureline ring promotion control register",
  "description": "Canonical, machine-readable register that binds each promotion subject \u2014 binary artifact graph or non-binary AI/provider/model/prompt/tool pack \u2014 to its ring state, soak windows, rollback-stop triggers, kill-switch posture, and linked verification packet. The register is metadata-only: it carries typed states and opaque refs, never raw artifacts, logs, signatures, or credentials.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "artifact_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "stable_proof_index_ref",
    "lifecycle_labels",
    "rings",
    "subject_kinds",
    "promotion_states",
    "gap_reasons",
    "actions",
    "kill_switch_postures",
    "rollback_trigger_kinds",
    "release_blocking_subject_refs",
    "rows",
    "rules",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "ring_promotion_control"
    },
    "artifact_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "$ref": "#/$defs/non_empty_string"
    },
    "overview_page": {
      "$ref": "#/$defs/non_empty_string"
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "claim_manifest_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "stable_proof_index_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim_level"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "rings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ring"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "subject_kinds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/subject_kind"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "promotion_states": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/promotion_state"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "gap_reasons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gap_reason"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "kill_switch_postures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/kill_switch_posture"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "rollback_trigger_kinds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rollback_trigger_kind"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "release_blocking_subject_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/promotion_subject_row"
      },
      "minItems": 1
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/promotion_rule"
      },
      "minItems": 1
    },
    "publication": {
      "$ref": "#/$defs/promotion_publication_record"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "ref_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "nullable_date": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "format": "date"
        }
      ]
    },
    "claim_level": {
      "type": "string",
      "enum": [
        "lts",
        "stable",
        "beta",
        "preview",
        "withdrawn"
      ]
    },
    "ring": {
      "type": "string",
      "enum": [
        "internal",
        "canary",
        "pilot",
        "broad"
      ]
    },
    "subject_kind": {
      "type": "string",
      "enum": [
        "binary_artifact_graph",
        "ai_provider_pack",
        "ai_model_pack",
        "ai_prompt_pack",
        "ai_tool_pack"
      ]
    },
    "promotion_state": {
      "type": "string",
      "enum": [
        "soaking",
        "qualified",
        "provisional_on_waiver",
        "blocked",
        "narrowed_stale",
        "narrowed_missing",
        "narrowed_regressed",
        "narrowed_waiver_expired",
        "rolled_back"
      ]
    },
    "gap_reason": {
      "type": "string",
      "enum": [
        "claim_label_narrowed",
        "soak_incomplete",
        "evidence_stale",
        "evidence_missing",
        "regression_detected",
        "waiver_expired",
        "owner_signoff_missing",
        "rollback_stop_triggered",
        "kill_switch_armed"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "hold_widening",
        "narrow_claim",
        "refresh_packet",
        "recapture_evidence",
        "request_owner_signoff",
        "trigger_rollback",
        "arm_kill_switch"
      ]
    },
    "kill_switch_posture": {
      "type": "string",
      "enum": [
        "disabled",
        "armed",
        "enabled"
      ]
    },
    "rollback_trigger_kind": {
      "type": "string",
      "enum": [
        "crash",
        "data_loss",
        "trust_regression",
        "protected_path_regression",
        "performance_regression",
        "compatibility_failure",
        "update_failure"
      ]
    },
    "freshness_slo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_max_age_days",
        "warn_within_days",
        "slo_register_ref"
      ],
      "properties": {
        "target_max_age_days": {
          "type": "integer",
          "minimum": 1
        },
        "warn_within_days": {
          "type": "integer",
          "minimum": 1
        },
        "slo_register_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "captured_at",
        "freshness_slo",
        "slo_state",
        "evidence_refs"
      ],
      "properties": {
        "packet_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "packet_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "proof_index_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "captured_at": {
          "type": "string",
          "format": "date"
        },
        "freshness_slo": {
          "$ref": "#/$defs/freshness_slo"
        },
        "slo_state": {
          "type": "string",
          "enum": [
            "current",
            "due_for_refresh",
            "breached",
            "missing"
          ]
        },
        "evidence_refs": {
          "$ref": "#/$defs/ref_array"
        }
      }
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_ref",
        "signed_off",
        "signed_at"
      ],
      "properties": {
        "owner_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "signed_off": {
          "type": "boolean"
        },
        "signed_at": {
          "$ref": "#/$defs/nullable_date"
        }
      }
    },
    "qualification_waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "waiver_ref",
        "expires_at",
        "reason"
      ],
      "properties": {
        "waiver_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "expires_at": {
          "type": "string",
          "format": "date"
        },
        "reason": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "soak_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transition",
        "minimum_duration_hours",
        "required_evidence_refs",
        "required_fitness_checks",
        "started_at",
        "completed_at",
        "is_complete"
      ],
      "properties": {
        "transition": {
          "$ref": "#/$defs/non_empty_string"
        },
        "minimum_duration_hours": {
          "type": "integer",
          "minimum": 0
        },
        "required_evidence_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "required_fitness_checks": {
          "$ref": "#/$defs/ref_array"
        },
        "started_at": {
          "type": "string",
          "format": "date"
        },
        "completed_at": {
          "$ref": "#/$defs/nullable_date"
        },
        "is_complete": {
          "type": "boolean"
        }
      }
    },
    "rollback_stop_trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger_id",
        "title",
        "trigger_kind",
        "ring_scope",
        "auto_rollback",
        "rationale"
      ],
      "properties": {
        "trigger_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "trigger_kind": {
          "$ref": "#/$defs/rollback_trigger_kind"
        },
        "ring_scope": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ring"
          },
          "minItems": 1
        },
        "auto_rollback": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "promotion_subject_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "subject_kind",
        "subject_ref",
        "subject_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "current_ring",
        "target_ring",
        "promotion_state",
        "soak_windows",
        "rollback_stop_triggers",
        "kill_switch_posture",
        "rollback_target_ring",
        "proof_packet",
        "owner_signoff",
        "waiver",
        "active_gap_reasons",
        "effective_label",
        "publication_destinations",
        "rationale"
      ],
      "properties": {
        "entry_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "subject_kind": {
          "$ref": "#/$defs/subject_kind"
        },
        "subject_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "subject_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "release_blocking": {
          "type": "boolean"
        },
        "claim_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "claim_label": {
          "$ref": "#/$defs/claim_level"
        },
        "current_ring": {
          "$ref": "#/$defs/ring"
        },
        "target_ring": {
          "$ref": "#/$defs/ring"
        },
        "promotion_state": {
          "$ref": "#/$defs/promotion_state"
        },
        "soak_windows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/soak_window"
          }
        },
        "rollback_stop_triggers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rollback_stop_trigger"
          }
        },
        "kill_switch_posture": {
          "$ref": "#/$defs/kill_switch_posture"
        },
        "rollback_target_ring": {
          "$ref": "#/$defs/ring"
        },
        "proof_packet": {
          "$ref": "#/$defs/proof_packet"
        },
        "owner_signoff": {
          "$ref": "#/$defs/owner_signoff"
        },
        "waiver": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/qualification_waiver"
            }
          ]
        },
        "active_gap_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gap_reason"
          }
        },
        "effective_label": {
          "$ref": "#/$defs/claim_level"
        },
        "publication_destinations": {
          "$ref": "#/$defs/ref_array"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "promotion_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_states",
        "default_action",
        "blocks_promotion",
        "rationale"
      ],
      "properties": {
        "rule_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "trigger_reason": {
          "$ref": "#/$defs/gap_reason"
        },
        "applies_to_states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/promotion_state"
          },
          "minItems": 1
        },
        "default_action": {
          "$ref": "#/$defs/action"
        },
        "blocks_promotion": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "promotion_publication_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_row_ids",
        "rationale"
      ],
      "properties": {
        "publication_gate": {
          "$ref": "#/$defs/non_empty_string"
        },
        "decision": {
          "type": "string",
          "enum": [
            "proceed",
            "hold"
          ]
        },
        "blocking_rule_ids": {
          "$ref": "#/$defs/ref_array"
        },
        "blocking_row_ids": {
          "$ref": "#/$defs/ref_array"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows",
        "rows_holding_claim",
        "rows_narrowed",
        "rows_on_active_waiver",
        "rows_soaking",
        "rows_blocked",
        "rows_rolled_back",
        "total_active_gap_reasons",
        "rules_firing",
        "canary_subjects",
        "pilot_subjects",
        "broad_subjects",
        "kill_switch_active"
      ],
      "properties": {
        "total_rows": {
          "type": "integer",
          "minimum": 0
        },
        "rows_holding_claim": {
          "type": "integer",
          "minimum": 0
        },
        "rows_narrowed": {
          "type": "integer",
          "minimum": 0
        },
        "rows_on_active_waiver": {
          "type": "integer",
          "minimum": 0
        },
        "rows_soaking": {
          "type": "integer",
          "minimum": 0
        },
        "rows_blocked": {
          "type": "integer",
          "minimum": 0
        },
        "rows_rolled_back": {
          "type": "integer",
          "minimum": 0
        },
        "total_active_gap_reasons": {
          "type": "integer",
          "minimum": 0
        },
        "rules_firing": {
          "type": "integer",
          "minimum": 0
        },
        "canary_subjects": {
          "type": "integer",
          "minimum": 0
        },
        "pilot_subjects": {
          "type": "integer",
          "minimum": 0
        },
        "broad_subjects": {
          "type": "integer",
          "minimum": 0
        },
        "kill_switch_active": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
