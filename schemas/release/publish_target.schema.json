{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/publish_target.schema.json",
  "title": "Aureline publish-target contract",
  "description": "Boundary schema for publish_target_record frozen in docs/release/release_center_object_model_contract.md. A publish target is the pre-action description of where a candidate, rollback, revocation, repin, mirror feed, registry item, or emergency channel update will land. The record makes target class, audience, visibility, mutability, rollback path, support class, auth-source class, dry-run availability, evidence freshness, exact-build linkage, and cross-surface refs explicit before UI or headless publication mutates any official channel, mirror, registry, or support-bearing packet. Raw credentials, raw bundle bodies, raw approval transcripts, and raw support attachments never cross this boundary; the record carries stable ids, typed classes, redaction-safe summaries, and refs.",
  "$ref": "#/$defs/publish_target_record",
  "$defs": {
    "publish_target_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for this publish-target export."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable opaque id safe for logs, manifests, support packets, and release-center rows. Raw URLs, raw file paths, raw secrets, and raw human identifiers do not appear here."
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/non_empty_string" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp."
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "non_empty_ref_array": {
      "allOf": [
        { "$ref": "#/$defs/ref_array" },
        { "minItems": 1 }
      ]
    },
    "publish_target_id": {
      "type": "string",
      "pattern": "^publish_target:[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "description": "Stable publish-target id shared by release center, headless automation, support exports, and audit rows."
    },
    "publish_target_class": {
      "type": "string",
      "enum": [
        "local_preview",
        "internal_ring",
        "public_preview",
        "stable",
        "lts",
        "mirror_feed",
        "registry_marketplace",
        "emergency_channel"
      ],
      "description": "Closed publish-target class vocabulary. These classes are product semantics, not UI labels."
    },
    "destination_class": {
      "type": "string",
      "enum": [
        "local_workspace",
        "release_channel",
        "managed_ring",
        "public_update_feed",
        "customer_mirror_feed",
        "air_gap_bundle",
        "registry_namespace",
        "marketplace_listing",
        "emergency_feed",
        "support_packet"
      ]
    },
    "visibility_class": {
      "type": "string",
      "enum": [
        "local_only",
        "internal",
        "private_partner",
        "public_preview",
        "public_stable",
        "public_lts",
        "mirror_only",
        "registry_public",
        "registry_private",
        "emergency_limited",
        "support_only"
      ]
    },
    "audience_class": {
      "type": "string",
      "enum": [
        "developer_local",
        "release_team",
        "internal_dogfood",
        "design_partner",
        "public_preview_user",
        "public_stable_user",
        "lts_admin",
        "mirror_operator",
        "air_gapped_admin",
        "registry_consumer",
        "marketplace_consumer",
        "security_responder",
        "affected_admin",
        "support_operator"
      ],
      "description": "Audience receiving the target, separate from visibility. A public target can still have admin-only support obligations, and a mirror target can be private but support-bearing."
    },
    "support_class": {
      "type": "string",
      "enum": [
        "unsupported_local",
        "internal_only",
        "preview_supported",
        "public_supported",
        "lts_supported",
        "mirror_operator_supported",
        "registry_supported",
        "emergency_support_only"
      ]
    },
    "mutability_class": {
      "type": "string",
      "enum": [
        "mutable_local_pointer",
        "mutable_ring_pointer",
        "immutable_version_mutable_pointer",
        "immutable_once_published",
        "mirror_snapshot_supersedable",
        "registry_version_immutable_metadata_mutable",
        "emergency_time_boxed"
      ],
      "description": "What may still change after publication. Version immutability, pointer mutability, yanking, and mirror supersedence are intentionally distinct."
    },
    "rollback_path_class": {
      "type": "string",
      "enum": [
        "discard_local_preview",
        "repin_previous_pointer",
        "staged_rollback_manifest",
        "lts_backport_or_repin",
        "mirror_snapshot_supersedence",
        "yank_then_republish",
        "revoke_or_disable",
        "emergency_reconciliation_required",
        "not_applicable"
      ]
    },
    "auth_source_class": {
      "type": "string",
      "enum": [
        "none_local",
        "local_dev_keychain",
        "ci_oidc_release_identity",
        "release_vault_token",
        "security_emergency_quorum",
        "mirror_operator_receipt",
        "registry_publisher_identity",
        "support_export_ref"
      ],
      "description": "Credential or authority source class disclosed before action. Raw credential material never appears."
    },
    "actor_class": {
      "type": "string",
      "enum": [
        "developer",
        "release_operator",
        "security_operator",
        "mirror_operator",
        "registry_publisher",
        "headless_automation",
        "support_operator",
        "org_admin"
      ]
    },
    "dry_run_availability_class": {
      "type": "string",
      "enum": [
        "required_current",
        "supported_current",
        "supported_stale",
        "unavailable_not_applicable",
        "unavailable_target_does_not_support",
        "failed"
      ],
      "description": "Whether a dry run or scope preview exists and is current enough before mutation."
    },
    "evidence_freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "current_with_waiver",
        "stale_blocking",
        "stale_non_blocking",
        "missing_blocking",
        "not_applicable"
      ]
    },
    "artifact_family_class": {
      "type": "string",
      "enum": [
        "ide_binary",
        "ide_debug_symbols",
        "cli_binary",
        "cli_debug_symbols",
        "sdk_library",
        "source_map_bundle",
        "docs_pack",
        "schema_export",
        "reference_pack",
        "sbom_document",
        "signed_attestation",
        "source_bundle",
        "crash_symbols_archive",
        "reproducibility_pack",
        "support_runbook_bundle",
        "release_evidence_packet",
        "update_metadata",
        "revocation_manifest",
        "policy_bundle",
        "extension_package",
        "marketplace_metadata"
      ]
    },
    "audience_semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audience_class",
        "audience_ref",
        "deployment_profile_scope",
        "resulting_visibility_class",
        "audience_note"
      ],
      "properties": {
        "audience_class": { "$ref": "#/$defs/audience_class" },
        "audience_ref": { "$ref": "#/$defs/opaque_id" },
        "deployment_profile_scope": { "$ref": "#/$defs/non_empty_ref_array" },
        "resulting_visibility_class": { "$ref": "#/$defs/visibility_class" },
        "audience_note": { "$ref": "#/$defs/non_empty_string" }
      },
      "description": "Audience and deployment scope the target will expose after action."
    },
    "auth_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auth_source_class",
        "auth_source_ref",
        "actor_class",
        "authority_policy_ref",
        "raw_secret_material_present",
        "disclosure_note"
      ],
      "properties": {
        "auth_source_class": { "$ref": "#/$defs/auth_source_class" },
        "auth_source_ref": { "$ref": "#/$defs/nullable_string" },
        "actor_class": { "$ref": "#/$defs/actor_class" },
        "authority_policy_ref": { "$ref": "#/$defs/nullable_string" },
        "raw_secret_material_present": {
          "type": "boolean",
          "const": false,
          "description": "Publish-target records may name credential source classes and stable refs only; they never carry raw secrets."
        },
        "disclosure_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "dry_run_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "availability_class",
        "dry_run_ref",
        "scope_preview_ref",
        "generated_at",
        "expires_at",
        "diff_summary",
        "blocking_findings"
      ],
      "properties": {
        "availability_class": { "$ref": "#/$defs/dry_run_availability_class" },
        "dry_run_ref": { "$ref": "#/$defs/nullable_string" },
        "scope_preview_ref": { "$ref": "#/$defs/nullable_string" },
        "generated_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/monotonic_timestamp" }
          ]
        },
        "expires_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/monotonic_timestamp" }
          ]
        },
        "diff_summary": { "$ref": "#/$defs/non_empty_string" },
        "blocking_findings": { "$ref": "#/$defs/ref_array" }
      }
    },
    "evidence_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness_class",
        "latest_evidence_at",
        "required_evidence_refs",
        "waiver_packet_refs",
        "freshness_policy_ref",
        "freshness_note"
      ],
      "properties": {
        "freshness_class": { "$ref": "#/$defs/evidence_freshness_class" },
        "latest_evidence_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/monotonic_timestamp" }
          ]
        },
        "required_evidence_refs": { "$ref": "#/$defs/ref_array" },
        "waiver_packet_refs": { "$ref": "#/$defs/ref_array" },
        "freshness_policy_ref": { "$ref": "#/$defs/non_empty_string" },
        "freshness_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "mutability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mutability_class",
        "immutable_fields",
        "mutable_fields",
        "repin_allowed",
        "yank_allowed",
        "revoke_allowed",
        "mutability_note"
      ],
      "properties": {
        "mutability_class": { "$ref": "#/$defs/mutability_class" },
        "immutable_fields": { "$ref": "#/$defs/non_empty_ref_array" },
        "mutable_fields": { "$ref": "#/$defs/ref_array" },
        "repin_allowed": { "type": "boolean" },
        "yank_allowed": { "type": "boolean" },
        "revoke_allowed": { "type": "boolean" },
        "mutability_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "rollback_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rollback_path_class",
        "last_known_good_ref",
        "rollback_manifest_ref",
        "rollback_window",
        "continuity_note"
      ],
      "properties": {
        "rollback_path_class": { "$ref": "#/$defs/rollback_path_class" },
        "last_known_good_ref": { "$ref": "#/$defs/nullable_string" },
        "rollback_manifest_ref": { "$ref": "#/$defs/nullable_string" },
        "rollback_window": { "$ref": "#/$defs/non_empty_string" },
        "continuity_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "exact_build_backreference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_family_class",
        "artifact_ref",
        "exact_build_identity_ref",
        "build_id",
        "provenance_row_refs",
        "about_provenance_row_refs",
        "support_bundle_refs"
      ],
      "properties": {
        "artifact_family_class": { "$ref": "#/$defs/artifact_family_class" },
        "artifact_ref": { "$ref": "#/$defs/opaque_id" },
        "exact_build_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "build_id": { "$ref": "#/$defs/opaque_id" },
        "provenance_row_refs": { "$ref": "#/$defs/ref_array" },
        "about_provenance_row_refs": { "$ref": "#/$defs/ref_array" },
        "support_bundle_refs": { "$ref": "#/$defs/ref_array" }
      },
      "description": "Backreference to the exact-build identity and provenance rows this target will expose."
    },
    "surface_parity_links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_center_event_ref",
        "headless_command_ref",
        "update_manifest_refs",
        "about_provenance_refs",
        "service_health_refs",
        "advisory_refs",
        "rollback_record_refs",
        "support_bundle_refs"
      ],
      "properties": {
        "release_center_event_ref": { "$ref": "#/$defs/nullable_string" },
        "headless_command_ref": { "$ref": "#/$defs/nullable_string" },
        "update_manifest_refs": { "$ref": "#/$defs/ref_array" },
        "about_provenance_refs": { "$ref": "#/$defs/ref_array" },
        "service_health_refs": { "$ref": "#/$defs/ref_array" },
        "advisory_refs": { "$ref": "#/$defs/ref_array" },
        "rollback_record_refs": { "$ref": "#/$defs/ref_array" },
        "support_bundle_refs": { "$ref": "#/$defs/ref_array" }
      },
      "description": "Refs every surface quotes so UI and headless flows do not invent separate release truth."
    },
    "pre_action_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_scope_visible",
        "auth_source_visible",
        "audience_visible",
        "mutability_visible",
        "dry_run_state_visible",
        "rollback_path_visible",
        "exact_build_linkage_visible",
        "support_linkage_visible"
      ],
      "properties": {
        "target_scope_visible": { "type": "boolean" },
        "auth_source_visible": { "type": "boolean" },
        "audience_visible": { "type": "boolean" },
        "mutability_visible": { "type": "boolean" },
        "dry_run_state_visible": { "type": "boolean" },
        "rollback_path_visible": { "type": "boolean" },
        "exact_build_linkage_visible": { "type": "boolean" },
        "support_linkage_visible": { "type": "boolean" }
      },
      "description": "Mechanical pre-action parity checklist consumed by UI sheets and headless review output."
    },
    "publish_target_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publish_target_schema_version",
        "record_kind",
        "publish_target_id",
        "target_class",
        "destination_class",
        "display_name",
        "visibility_class",
        "audience",
        "mutability",
        "rollback_path",
        "support_class",
        "auth_source",
        "dry_run",
        "evidence_freshness",
        "exact_build_backreferences",
        "surface_parity_links",
        "pre_action_disclosure",
        "notes"
      ],
      "properties": {
        "publish_target_schema_version": { "$ref": "#/$defs/publish_target_schema_version" },
        "record_kind": {
          "type": "string",
          "const": "publish_target_record"
        },
        "publish_target_id": { "$ref": "#/$defs/publish_target_id" },
        "target_class": { "$ref": "#/$defs/publish_target_class" },
        "destination_class": { "$ref": "#/$defs/destination_class" },
        "display_name": { "$ref": "#/$defs/non_empty_string" },
        "visibility_class": { "$ref": "#/$defs/visibility_class" },
        "audience": { "$ref": "#/$defs/audience_semantics" },
        "mutability": { "$ref": "#/$defs/mutability" },
        "rollback_path": { "$ref": "#/$defs/rollback_path" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "auth_source": { "$ref": "#/$defs/auth_source" },
        "dry_run": { "$ref": "#/$defs/dry_run_status" },
        "evidence_freshness": { "$ref": "#/$defs/evidence_freshness" },
        "exact_build_backreferences": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/exact_build_backreference" }
        },
        "surface_parity_links": { "$ref": "#/$defs/surface_parity_links" },
        "pre_action_disclosure": { "$ref": "#/$defs/pre_action_disclosure" },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  }
}
