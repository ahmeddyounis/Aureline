{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/finalize_ime_grapheme_bidi_unicode_high_contrast_zoom_density_pseudoloc_rtl_locale_pack_and_desktop_platform_conformance.schema.json",
  "title": "Aureline desktop platform conformance register",
  "description": "Canonical, machine-readable register that binds each desktop-platform conformance domain \u2014 IME/grapheme/bidi/Unicode, high contrast, zoom/density, pseudoloc/RTL, locale-pack, and desktop-platform \u2014 to its signoff state across per-domain checks. The register is metadata-only: it carries typed states and opaque refs, never raw artifacts, logs, signatures, or credentials.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "register_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "lifecycle_labels",
    "domain_kinds",
    "check_kinds",
    "signoff_states",
    "gap_reasons",
    "conformance_actions",
    "launch_cutline",
    "release_blocking_domain_refs",
    "rules",
    "rows",
    "promotion",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "desktop_platform_conformance"
    },
    "register_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "$ref": "#/$defs/non_empty_string"
    },
    "overview_page": {
      "$ref": "#/$defs/non_empty_string"
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "claim_manifest_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim_level"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "domain_kinds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/domain_kind"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "check_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "bidi_isolation",
          "community_pack_review",
          "coverage_threshold",
          "custom_high_contrast_support",
          "density_levels",
          "emoji_presentation",
          "fallback_chain",
          "file_association",
          "focus_indicator_visibility",
          "grapheme_clustering",
          "ime_composition",
          "message_id_parity",
          "minimum_readable_size",
          "native_menu_integration",
          "os_accessibility_bridge",
          "pack_signature_integrity",
          "protocol_handler_registration",
          "pseudoloc_coverage",
          "reflow_integrity",
          "rtl_layout",
          "rtl_text_rendering",
          "sandbox_posture",
          "system_theme_sync",
          "theme_contrast_ratio",
          "translation_parity",
          "unicode_normalization",
          "zoom_continuous"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "signoff_states": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signoff_state"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "gap_reasons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gap_reason"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "conformance_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conformance_action"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "launch_cutline": {
      "$ref": "#/$defs/launch_cutline"
    },
    "release_blocking_domain_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conformance_rule"
      },
      "minItems": 1
    },
    "rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conformance_row"
      },
      "minItems": 1
    },
    "promotion": {
      "$ref": "#/$defs/promotion"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "claim_level": {
      "type": "string",
      "enum": [
        "lts",
        "stable",
        "beta",
        "preview",
        "withdrawn"
      ]
    },
    "domain_kind": {
      "type": "string",
      "enum": [
        "ime_grapheme_bidi_unicode",
        "high_contrast",
        "zoom_density",
        "pseudoloc_rtl",
        "locale_pack",
        "desktop_platform"
      ]
    },
    "signoff_state": {
      "type": "string",
      "enum": [
        "qualified",
        "provisional_on_waiver",
        "not_qualified",
        "evidence_stale",
        "waiver_expired"
      ]
    },
    "gap_reason": {
      "type": "string",
      "enum": [
        "claim_label_narrowed",
        "check_blocked",
        "evidence_stale",
        "evidence_missing",
        "owner_signoff_missing",
        "waiver_expired"
      ]
    },
    "conformance_action": {
      "type": "string",
      "enum": [
        "hold_promotion",
        "narrow_claim",
        "refresh_evidence_packet",
        "request_owner_signoff"
      ]
    },
    "check_state": {
      "type": "string",
      "enum": [
        "passed",
        "partial",
        "blocked",
        "pending_evidence",
        "degraded"
      ]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": {
          "$ref": "#/$defs/claim_level"
        },
        "above_cutline_levels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/claim_level"
          }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/claim_level"
          }
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "freshness_slo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_max_age_days",
        "warn_within_days",
        "slo_register_ref"
      ],
      "properties": {
        "target_max_age_days": {
          "type": "integer",
          "minimum": 1
        },
        "warn_within_days": {
          "type": "integer",
          "minimum": 0
        },
        "slo_register_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "captured_at",
        "freshness_slo",
        "slo_state",
        "evidence_refs"
      ],
      "properties": {
        "packet_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "packet_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "proof_index_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "captured_at": {
          "anyOf": [
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "null"
            }
          ]
        },
        "freshness_slo": {
          "$ref": "#/$defs/freshness_slo"
        },
        "slo_state": {
          "type": "string",
          "enum": [
            "current",
            "due_for_refresh",
            "breached",
            "missing"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "conformance_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_kind",
        "check_state"
      ],
      "properties": {
        "check_kind": {
          "type": "string",
          "enum": [
            "bidi_isolation",
            "community_pack_review",
            "coverage_threshold",
            "custom_high_contrast_support",
            "density_levels",
            "emoji_presentation",
            "fallback_chain",
            "file_association",
            "focus_indicator_visibility",
            "grapheme_clustering",
            "ime_composition",
            "message_id_parity",
            "minimum_readable_size",
            "native_menu_integration",
            "os_accessibility_bridge",
            "pack_signature_integrity",
            "protocol_handler_registration",
            "pseudoloc_coverage",
            "reflow_integrity",
            "rtl_layout",
            "rtl_text_rendering",
            "sandbox_posture",
            "system_theme_sync",
            "theme_contrast_ratio",
            "translation_parity",
            "unicode_normalization",
            "zoom_continuous"
          ]
        },
        "check_state": {
          "$ref": "#/$defs/check_state"
        },
        "evidence_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_ref",
        "signed_off",
        "signed_at"
      ],
      "properties": {
        "owner_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "signed_off": {
          "type": "boolean"
        },
        "signed_at": {
          "anyOf": [
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "conformance_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_promotion",
        "rationale"
      ],
      "properties": {
        "rule_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "trigger_reason": {
          "$ref": "#/$defs/gap_reason"
        },
        "applies_to_labels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/claim_level"
          }
        },
        "default_action": {
          "$ref": "#/$defs/conformance_action"
        },
        "blocks_promotion": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "conformance_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "domain_kind",
        "domain_ref",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "signoff_state",
        "conformance_checks",
        "proof_packet",
        "waiver",
        "owner_signoff",
        "active_gap_reasons",
        "published_label",
        "publication_destinations"
      ],
      "properties": {
        "entry_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "domain_kind": {
          "$ref": "#/$defs/domain_kind"
        },
        "domain_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "release_blocking": {
          "type": "boolean"
        },
        "claim_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "claim_label": {
          "$ref": "#/$defs/claim_level"
        },
        "signoff_state": {
          "$ref": "#/$defs/signoff_state"
        },
        "conformance_checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/conformance_check"
          },
          "minItems": 1
        },
        "proof_packet": {
          "$ref": "#/$defs/proof_packet"
        },
        "waiver": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "object"
            }
          ]
        },
        "owner_signoff": {
          "$ref": "#/$defs/owner_signoff"
        },
        "active_gap_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gap_reason"
          }
        },
        "published_label": {
          "$ref": "#/$defs/claim_level"
        },
        "publication_destinations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_entry_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": {
          "$ref": "#/$defs/non_empty_string"
        },
        "decision": {
          "type": "string",
          "enum": [
            "proceed",
            "hold"
          ]
        },
        "blocking_rule_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "blocking_entry_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "total_claims",
        "entries_qualified",
        "entries_narrowed",
        "entries_on_active_waiver",
        "entries_blocked",
        "release_blocking_total",
        "release_blocking_qualified",
        "release_blocking_narrowed",
        "ime_entries",
        "high_contrast_entries",
        "zoom_density_entries",
        "pseudoloc_rtl_entries",
        "locale_pack_entries",
        "desktop_platform_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_gap_reasons",
        "rules_firing"
      ],
      "properties": {
        "total_entries": {
          "type": "integer",
          "minimum": 0
        },
        "total_claims": {
          "type": "integer",
          "minimum": 0
        },
        "entries_qualified": {
          "type": "integer",
          "minimum": 0
        },
        "entries_narrowed": {
          "type": "integer",
          "minimum": 0
        },
        "entries_on_active_waiver": {
          "type": "integer",
          "minimum": 0
        },
        "entries_blocked": {
          "type": "integer",
          "minimum": 0
        },
        "release_blocking_total": {
          "type": "integer",
          "minimum": 0
        },
        "release_blocking_qualified": {
          "type": "integer",
          "minimum": 0
        },
        "release_blocking_narrowed": {
          "type": "integer",
          "minimum": 0
        },
        "ime_entries": {
          "type": "integer",
          "minimum": 0
        },
        "high_contrast_entries": {
          "type": "integer",
          "minimum": 0
        },
        "zoom_density_entries": {
          "type": "integer",
          "minimum": 0
        },
        "pseudoloc_rtl_entries": {
          "type": "integer",
          "minimum": 0
        },
        "locale_pack_entries": {
          "type": "integer",
          "minimum": 0
        },
        "desktop_platform_entries": {
          "type": "integer",
          "minimum": 0
        },
        "packets_current": {
          "type": "integer",
          "minimum": 0
        },
        "packets_due_for_refresh": {
          "type": "integer",
          "minimum": 0
        },
        "packets_breached": {
          "type": "integer",
          "minimum": 0
        },
        "packets_missing": {
          "type": "integer",
          "minimum": 0
        },
        "total_active_gap_reasons": {
          "type": "integer",
          "minimum": 0
        },
        "rules_firing": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}