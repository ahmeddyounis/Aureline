{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/harden_docs_help_about_and_service_health_truth.schema.json",
  "title": "Aureline docs, Help, About, service-health, and package/dependency safety truth register",
  "description": "Canonical, machine-readable register binding each user-facing truth surface (docs, Help, About, service-health, package-safety) to the stable claim manifest entry whose lifecycle label it backs, a packet-freshness SLO, the service-contract state (for service-health rows), the About provenance card (for About rows), the package-safety disclosure (for package-safety rows), and truth rules that gate publication. Each surface may carry the claim's label or narrow below it but never wider. The register is metadata-only: typed states and opaque refs, never raw artifacts, logs, signatures, or credentials.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "register_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "docs_maintenance_packet_ref",
    "service_health_register_ref",
    "package_safety_template_ref",
    "lifecycle_labels",
    "surface_kinds",
    "service_contract_states",
    "destination_trust_classes",
    "truth_states",
    "gap_reasons",
    "truth_actions",
    "launch_cutline",
    "release_blocking_surface_refs",
    "truth_rules",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "docs_help_about_service_health_truth" },
    "register_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "docs_maintenance_packet_ref": { "$ref": "#/$defs/non_empty_string" },
    "service_health_register_ref": { "$ref": "#/$defs/non_empty_string" },
    "package_safety_template_ref": { "$ref": "#/$defs/non_empty_string" },
    "lifecycle_labels": {
      "type": "array",
      "items": { "$ref": "#/$defs/lifecycle_label" },
      "minItems": 1,
      "uniqueItems": true
    },
    "surface_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_kind" },
      "minItems": 1,
      "uniqueItems": true
    },
    "service_contract_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/service_contract_state" },
      "minItems": 1,
      "uniqueItems": true
    },
    "destination_trust_classes": {
      "type": "array",
      "items": { "$ref": "#/$defs/destination_trust_class" },
      "minItems": 1,
      "uniqueItems": true
    },
    "truth_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/truth_state" },
      "minItems": 1,
      "uniqueItems": true
    },
    "gap_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap_reason" },
      "minItems": 1,
      "uniqueItems": true
    },
    "truth_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/truth_action" },
      "minItems": 1,
      "uniqueItems": true
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_surface_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "truth_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/truth_rule" },
      "minItems": 1
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/truth_row" },
      "minItems": 1
    },
    "publication": { "$ref": "#/$defs/truth_publication_record" },
    "summary": { "$ref": "#/$defs/truth_summary" }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_label": {
      "type": "string",
      "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
    },
    "surface_kind": {
      "type": "string",
      "enum": ["docs", "help", "about", "service_health", "package_safety"]
    },
    "service_contract_state": {
      "type": "string",
      "enum": ["ready", "degraded", "local_only", "stale", "contract_mismatch", "policy_blocked", "unavailable"]
    },
    "destination_trust_class": {
      "type": "string",
      "enum": ["official", "community", "mirrored", "self_hosted", "vendor_owned"]
    },
    "truth_state": {
      "type": "string",
      "enum": ["current", "current_on_waiver", "narrowed_unbacked", "narrowed_claim_narrowed", "narrowed_stale", "narrowed_waiver_expired", "narrowed_contract_mismatch"]
    },
    "gap_reason": {
      "type": "string",
      "enum": ["claim_label_narrowed", "proof_packet_freshness_breached", "proof_packet_missing", "evidence_incomplete", "waiver_expired", "owner_signoff_missing", "claim_manifest_mismatch"]
    },
    "truth_action": {
      "type": "string",
      "enum": ["hold_publication", "narrow_label", "refresh_proof_packet", "recapture_evidence", "request_owner_signoff", "retest_claim_alignment"]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cutline_level", "above_cutline_levels", "below_cutline_levels", "description"],
      "properties": {
        "cutline_level": { "$ref": "#/$defs/lifecycle_label" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" },
          "minItems": 1
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" },
          "minItems": 1
        },
        "description": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "truth_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "title", "trigger_reason", "applies_to_labels", "default_action", "blocks_publication", "rationale"],
      "properties": {
        "rule_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "trigger_reason": { "$ref": "#/$defs/gap_reason" },
        "applies_to_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" },
          "minItems": 1
        },
        "default_action": { "$ref": "#/$defs/truth_action" },
        "blocks_publication": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "truth_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id", "title", "surface_kind", "surface_ref", "surface_summary",
        "release_blocking", "claim_ref", "claim_label", "truth_state", "proof_packet",
        "owner_signoff", "active_gap_reasons", "published_label", "publication_destinations", "rationale"
      ],
      "properties": {
        "entry_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "surface_ref": { "$ref": "#/$defs/non_empty_string" },
        "surface_summary": { "$ref": "#/$defs/non_empty_string" },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "$ref": "#/$defs/non_empty_string" },
        "claim_label": { "$ref": "#/$defs/lifecycle_label" },
        "truth_state": { "$ref": "#/$defs/truth_state" },
        "proof_packet": { "$ref": "#/$defs/proof_packet" },
        "service_contract_state": { "$ref": "#/$defs/service_contract_state" },
        "about_card": { "$ref": "#/$defs/about_provenance_card" },
        "package_safety": { "$ref": "#/$defs/package_safety_disclosure" },
        "waiver": { "$ref": "#/$defs/qualification_waiver" },
        "owner_signoff": { "$ref": "#/$defs/owner_signoff" },
        "active_gap_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/gap_reason" }
        },
        "published_label": { "$ref": "#/$defs/lifecycle_label" },
        "publication_destinations": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_id", "packet_ref", "proof_index_ref", "freshness_slo", "slo_state", "evidence_refs"],
      "properties": {
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "proof_index_ref": { "$ref": "#/$defs/non_empty_string" },
        "captured_at": { "type": ["string", "null"] },
        "freshness_slo": { "$ref": "#/$defs/freshness_slo" },
        "slo_state": { "$ref": "#/$defs/freshness_slo_state" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "freshness_slo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
      "properties": {
        "target_max_age_days": { "type": "integer", "minimum": 1 },
        "warn_within_days": { "type": "integer", "minimum": 0 },
        "slo_register_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "freshness_slo_state": {
      "type": "string",
      "enum": ["current", "due_for_refresh", "breached", "missing"]
    },
    "about_provenance_card": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "channel", "install_mode", "provenance_state", "copy_build_info_action", "destinations"],
      "properties": {
        "version": { "$ref": "#/$defs/non_empty_string" },
        "channel": { "$ref": "#/$defs/non_empty_string" },
        "install_mode": { "$ref": "#/$defs/non_empty_string" },
        "provenance_state": { "$ref": "#/$defs/non_empty_string" },
        "copy_build_info_action": { "$ref": "#/$defs/non_empty_string" },
        "destinations": {
          "type": "array",
          "items": { "$ref": "#/$defs/help_destination" },
          "minItems": 1
        }
      }
    },
    "help_destination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trust_class", "label", "destination_ref"],
      "properties": {
        "trust_class": { "$ref": "#/$defs/destination_trust_class" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "destination_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "package_safety_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_scope", "registry_auth_source", "script_risk", "native_build_risk", "lockfile_impact", "license_advisory_delta", "validation_tasks", "rollback_path"],
      "properties": {
        "manifest_scope": { "$ref": "#/$defs/non_empty_string" },
        "registry_auth_source": { "$ref": "#/$defs/non_empty_string" },
        "script_risk": { "type": "boolean" },
        "native_build_risk": { "type": "boolean" },
        "lockfile_impact": { "$ref": "#/$defs/non_empty_string" },
        "license_advisory_delta": { "$ref": "#/$defs/non_empty_string" },
        "validation_tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "minItems": 1
        },
        "rollback_path": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "qualification_waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["waiver_ref", "expires_at", "reason"],
      "properties": {
        "waiver_ref": { "$ref": "#/$defs/non_empty_string" },
        "expires_at": { "type": "string" },
        "reason": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_ref", "signed_off", "signed_at"],
      "properties": {
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "signed_off": { "type": "boolean" },
        "signed_at": { "type": ["string", "null"] }
      }
    },
    "truth_publication_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publication_gate", "decision", "blocking_rule_ids", "blocking_entry_ids", "rationale"],
      "properties": {
        "publication_gate": { "$ref": "#/$defs/non_empty_string" },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "blocking_entry_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries", "total_claims", "entries_published_stable",
        "entries_narrowed_below_cutline", "entries_on_active_waiver",
        "release_blocking_total", "release_blocking_published_stable",
        "release_blocking_narrowed", "docs_entries", "help_entries",
        "about_entries", "service_health_entries", "package_safety_entries",
        "packets_current", "packets_due_for_refresh", "packets_breached",
        "packets_missing", "total_active_gap_reasons", "truth_rules_firing"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "entries_published_stable": { "type": "integer", "minimum": 0 },
        "entries_narrowed_below_cutline": { "type": "integer", "minimum": 0 },
        "entries_on_active_waiver": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_published_stable": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "docs_entries": { "type": "integer", "minimum": 0 },
        "help_entries": { "type": "integer", "minimum": 0 },
        "about_entries": { "type": "integer", "minimum": 0 },
        "service_health_entries": { "type": "integer", "minimum": 0 },
        "package_safety_entries": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_active_gap_reasons": { "type": "integer", "minimum": 0 },
        "truth_rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
