{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/m3_claim_manifest.schema.json",
  "title": "Aureline M3 governed claim manifest",
  "description": "Boundary schema for the generated M3 claim manifest (artifacts/release/m3/claim_manifest.json). The manifest is generated by ci/check_m3_claim_manifest.py from the canonical claim-manifest seed, the claimed-surface register, the cohort/archetype scorecard register, the M3 compatibility report, the cohort guardrails, and the version-skew register. Each row binds one M3 claimed beta surface, claimed beta archetype, or canonical claim family to its canonical claim_row id with explicit support_class, lifecycle_state, freshness badge class, provenance label, evidence references, and downgrade reasons so docs, Help/About, service health, support exports, release packets, and partner packets all read one row shape.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "manifest_id",
    "manifest_revision",
    "milestone_id",
    "release_channel_scope",
    "manifest_state",
    "as_of",
    "generated_at",
    "owner",
    "backup_owner",
    "backup_waiver",
    "source_refs",
    "vocabularies",
    "consuming_surfaces",
    "rows",
    "notes"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "m3_claim_manifest" },
    "manifest_id": {
      "type": "string",
      "pattern": "^claim_manifest:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "manifest_revision": { "type": "integer", "minimum": 1 },
    "milestone_id": { "type": "string", "const": "m3" },
    "release_channel_scope": {
      "type": "string",
      "enum": ["nightly", "preview", "beta", "stable", "lts"]
    },
    "manifest_state": {
      "type": "string",
      "enum": ["draft", "ratified", "frozen", "retired"]
    },
    "as_of": { "type": "string", "format": "date" },
    "generated_at": { "type": "string", "format": "date-time" },
    "owner": { "type": "string", "minLength": 1 },
    "backup_owner": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "backup_waiver": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_manifest_seed",
        "claimed_surface_register",
        "scorecard_register",
        "compatibility_report",
        "cohort_guardrails",
        "version_skew_register"
      ],
      "properties": {
        "claim_manifest_seed": { "type": "string", "minLength": 1 },
        "claimed_surface_register": { "type": "string", "minLength": 1 },
        "scorecard_register": { "type": "string", "minLength": 1 },
        "compatibility_report": { "type": "string", "minLength": 1 },
        "cohort_guardrails": { "type": "string", "minLength": 1 },
        "version_skew_register": { "type": "string", "minLength": 1 }
      }
    },
    "vocabularies": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness_badge_class",
        "provenance_label",
        "claim_posture",
        "support_class",
        "lifecycle_label",
        "row_kind"
      ],
      "properties": {
        "freshness_badge_class": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "provenance_label": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "claim_posture": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "support_class": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "lifecycle_label": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "row_kind": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "consuming_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/manifest_row" }
    },
    "notes": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "freshness_badge_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },
    "provenance_label": {
      "type": "string",
      "enum": [
        "project_docs",
        "generated_reference",
        "mirrored_official_docs",
        "curated_knowledge_pack",
        "derived_explanation",
        "vendor_provider_docs",
        "support_runbook",
        "external_status_feed"
      ]
    },
    "claim_posture": {
      "type": "string",
      "enum": [
        "claim_bearing",
        "experimental",
        "limited",
        "policy_disabled",
        "replacement_grade",
        "seed_only",
        "withdrawn"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "certified",
        "supported",
        "limited",
        "experimental",
        "community",
        "retest_pending",
        "evidence_stale",
        "unsupported"
      ]
    },
    "lifecycle_label": {
      "type": "string",
      "enum": ["preview", "beta"]
    },
    "row_kind": {
      "type": "string",
      "enum": [
        "canonical_claim_family",
        "beta_surface_binding",
        "beta_archetype_binding"
      ]
    },
    "ref_array": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "freshness_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "badge_class",
        "evidence_date",
        "review_window_days",
        "freshness_derivation"
      ],
      "properties": {
        "badge_class": { "$ref": "#/$defs/freshness_badge_class" },
        "evidence_date": { "type": "string", "format": "date" },
        "review_window_days": { "type": "integer", "minimum": 0 },
        "freshness_derivation": { "type": "string", "minLength": 1 }
      }
    },
    "provenance_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "evidence_owner",
        "owner_handoff_path"
      ],
      "properties": {
        "label": { "$ref": "#/$defs/provenance_label" },
        "evidence_owner": { "type": "string", "minLength": 1 },
        "owner_handoff_path": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "intake_owner",
            "triage_owner",
            "release_owner",
            "escalation_ref"
          ],
          "properties": {
            "intake_owner": { "type": "string", "minLength": 1 },
            "triage_owner": { "type": "string", "minLength": 1 },
            "release_owner": { "type": "string", "minLength": 1 },
            "escalation_ref": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "claim_posture_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "declared",
        "effective",
        "active_downgrade_reasons"
      ],
      "properties": {
        "declared": { "$ref": "#/$defs/claim_posture" },
        "effective": { "$ref": "#/$defs/claim_posture" },
        "active_downgrade_reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "support_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "declared",
        "effective",
        "target_at_beta_exit",
        "target_at_stable",
        "downgrade_triggers_fired",
        "open_waiver_count"
      ],
      "properties": {
        "declared": { "$ref": "#/$defs/support_class" },
        "effective": { "$ref": "#/$defs/support_class" },
        "target_at_beta_exit": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/support_class" }
          ]
        },
        "target_at_stable": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/support_class" }
          ]
        },
        "downgrade_triggers_fired": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "open_waiver_count": { "type": "integer", "minimum": 0 }
      }
    },
    "lifecycle_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_lifecycle_label"],
      "properties": {
        "display_lifecycle_label": { "$ref": "#/$defs/lifecycle_label" }
      }
    },
    "evidence_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_evidence_id",
        "evidence_kind",
        "packet_ref",
        "freshness_expectation",
        "minimum_result_status",
        "link_requirement"
      ],
      "properties": {
        "claim_evidence_id": { "type": "string", "minLength": 1 },
        "evidence_kind": { "type": "string", "minLength": 1 },
        "packet_ref": { "type": "string", "minLength": 1 },
        "freshness_expectation": { "type": "string", "minLength": 1 },
        "minimum_result_status": { "type": "string", "minLength": 1 },
        "link_requirement": { "type": "string", "enum": ["required", "advisory"] }
      }
    },
    "manifest_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "row_kind",
        "headline",
        "claim_row_refs",
        "claim_family",
        "requirement_ids",
        "claim_posture",
        "support",
        "lifecycle",
        "freshness",
        "provenance",
        "primary_cohort_refs",
        "beta_surface_ref",
        "beta_archetype_ref",
        "archetype_row_ref",
        "scorecard_ref",
        "compatibility_row_refs",
        "version_skew_register_refs",
        "evidence_links",
        "known_limit_refs",
        "exclusion_note_refs",
        "channel_projections",
        "notes"
      ],
      "properties": {
        "row_id": {
          "type": "string",
          "pattern": "^m3_claim_row:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
        },
        "row_kind": { "$ref": "#/$defs/row_kind" },
        "headline": { "type": "string", "minLength": 1 },
        "claim_row_refs": {
          "allOf": [
            { "$ref": "#/$defs/ref_array" },
            { "minItems": 1 }
          ]
        },
        "claim_family": { "type": "string", "minLength": 1 },
        "requirement_ids": {
          "allOf": [
            { "$ref": "#/$defs/ref_array" },
            { "minItems": 1 }
          ]
        },
        "claim_posture": { "$ref": "#/$defs/claim_posture_summary" },
        "support": { "$ref": "#/$defs/support_summary" },
        "lifecycle": { "$ref": "#/$defs/lifecycle_summary" },
        "freshness": { "$ref": "#/$defs/freshness_summary" },
        "provenance": { "$ref": "#/$defs/provenance_summary" },
        "primary_cohort_refs": { "$ref": "#/$defs/ref_array" },
        "beta_surface_ref": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "beta_archetype_ref": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "archetype_row_ref": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "scorecard_ref": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "compatibility_row_refs": { "$ref": "#/$defs/ref_array" },
        "version_skew_register_refs": { "$ref": "#/$defs/ref_array" },
        "evidence_links": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_link" }
        },
        "known_limit_refs": { "$ref": "#/$defs/ref_array" },
        "exclusion_note_refs": { "$ref": "#/$defs/ref_array" },
        "channel_projections": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "channel_id",
              "binding_status",
              "projection_kind",
              "copy_field",
              "surface_ref"
            ],
            "properties": {
              "channel_id": { "type": "string", "minLength": 1 },
              "binding_status": { "type": "string", "minLength": 1 },
              "projection_kind": { "type": "string", "minLength": 1 },
              "copy_field": { "type": "string", "minLength": 1 },
              "surface_ref": { "type": "string", "minLength": 1 }
            }
          }
        },
        "notes": { "type": "string", "minLength": 1 }
      }
    }
  }
}
