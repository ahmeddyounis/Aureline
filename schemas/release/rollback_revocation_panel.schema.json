{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/rollback_revocation_panel.schema.json",
  "title": "Aureline rollback and revocation panel",
  "description": "Boundary schema for rollback_revocation_panel_record frozen in docs/release/release_status_surface_contract.md. The panel distinguishes rollback, yank, revoke, repin, and deprecate actions across installed clients, remote agents, registries, marketplace listings, update channels, mirrors, docs/schema packs, and support packets. It names affected artifact families, consumer scope, historical visibility, recovery path, provenance linkage, evidence freshness, support refs, audit refs, and advisory refs so review surfaces cannot collapse the decision into generic undo-update copy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rollback_revocation_panel_schema_version",
    "record_kind",
    "panel_id",
    "release_status_card_ref",
    "candidate_ref",
    "source_refs",
    "action_class",
    "panel_state_class",
    "affected_state_surfaces",
    "affected_artifact_scope",
    "consumer_scope",
    "historical_visibility",
    "recovery_path",
    "artifact_provenance_links",
    "evidence_freshness",
    "support_and_audit",
    "rendering_contract",
    "notes"
  ],
  "$defs": {
    "rollback_revocation_panel_schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/non_empty_string" }
      ]
    },
    "utc_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_utc_datetime": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/utc_datetime" }
      ]
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "non_empty_ref_array": {
      "allOf": [
        { "$ref": "#/$defs/ref_array" },
        { "minItems": 1 }
      ]
    },
    "release_action_class": {
      "type": "string",
      "enum": [
        "rollback",
        "yank",
        "revoke",
        "repin",
        "deprecate"
      ],
      "description": "Closed action vocabulary. These verbs are not synonyms."
    },
    "panel_state_class": {
      "type": "string",
      "enum": [
        "preview",
        "blocked",
        "ready_for_confirmation",
        "executed",
        "reconciled",
        "superseded"
      ]
    },
    "state_surface_class": {
      "type": "string",
      "enum": [
        "installed_client",
        "remote_agent",
        "registry_version",
        "marketplace_listing",
        "update_channel",
        "managed_ring",
        "mirror_feed",
        "air_gap_bundle",
        "docs_or_schema_pack",
        "support_packet"
      ]
    },
    "artifact_family_class": {
      "type": "string",
      "enum": [
        "ide_binary",
        "ide_debug_symbols",
        "cli_binary",
        "cli_debug_symbols",
        "sdk_library",
        "source_map_bundle",
        "docs_pack",
        "schema_export",
        "reference_pack",
        "sbom_document",
        "signed_attestation",
        "source_bundle",
        "crash_symbols_archive",
        "reproducibility_pack",
        "support_runbook_bundle",
        "release_evidence_packet",
        "update_metadata",
        "revocation_manifest",
        "policy_bundle",
        "extension_package",
        "marketplace_metadata",
        "remote_agent_tarball",
        "remote_helper_tarball"
      ]
    },
    "consumer_scope_class": {
      "type": "string",
      "enum": [
        "installed_users",
        "future_update_offers",
        "new_installs_only",
        "remote_attach_sessions",
        "registry_consumers",
        "marketplace_browsers",
        "mirror_operators",
        "air_gapped_admins",
        "support_readers",
        "docs_readers"
      ]
    },
    "historical_visibility_class": {
      "type": "string",
      "enum": [
        "audit_history_retained",
        "public_listing_hidden_audit_retained",
        "installability_removed_history_retained",
        "trust_revoked_history_retained",
        "deprecation_notice_visible",
        "support_only_history_retained"
      ]
    },
    "evidence_freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "current_with_waiver",
        "stale_blocking",
        "stale_non_blocking",
        "missing_blocking",
        "not_applicable"
      ]
    },
    "proof_state_class": {
      "type": "string",
      "enum": [
        "verified",
        "present_unverified",
        "not_checked_here",
        "missing",
        "revoked",
        "superseded",
        "blocked_by_policy",
        "not_applicable"
      ]
    },
    "origin_path_class": {
      "type": "string",
      "enum": [
        "official_origin",
        "local_build_output",
        "customer_mirror",
        "air_gap_bundle",
        "registry_namespace",
        "marketplace_listing",
        "managed_feed",
        "support_export"
      ]
    },
    "verifier_class": {
      "type": "string",
      "enum": [
        "release_pipeline",
        "local_tooling",
        "headless_automation",
        "mirror_import_preflight",
        "registry_preflight",
        "support_reconstruction",
        "not_checked_here"
      ]
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_center_event_ref",
        "publication_action_ref",
        "publish_target_ref",
        "update_manifest_ref",
        "advisory_refs",
        "support_bundle_refs"
      ],
      "properties": {
        "release_center_event_ref": { "$ref": "#/$defs/nullable_string" },
        "publication_action_ref": { "$ref": "#/$defs/nullable_string" },
        "publish_target_ref": { "$ref": "#/$defs/nullable_string" },
        "update_manifest_ref": { "$ref": "#/$defs/nullable_string" },
        "advisory_refs": { "$ref": "#/$defs/ref_array" },
        "support_bundle_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "affected_state_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_surface_class",
        "state_ref",
        "mutability_note",
        "impact_note"
      ],
      "properties": {
        "state_surface_class": { "$ref": "#/$defs/state_surface_class" },
        "state_ref": { "$ref": "#/$defs/non_empty_string" },
        "mutability_note": { "$ref": "#/$defs/non_empty_string" },
        "impact_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "artifact_scope_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_family_class",
        "artifact_ref",
        "exact_build_identity_ref",
        "artifact_effect_class",
        "scope_note"
      ],
      "properties": {
        "artifact_family_class": { "$ref": "#/$defs/artifact_family_class" },
        "artifact_ref": { "$ref": "#/$defs/non_empty_string" },
        "exact_build_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "artifact_effect_class": {
          "type": "string",
          "enum": [
            "rollback_target",
            "installability_removed",
            "trust_removed",
            "pointer_changed",
            "support_window_changed",
            "deprecation_notice_changed"
          ]
        },
        "scope_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "consumer_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer_scope_class",
        "affected_consumer_refs",
        "reach_note"
      ],
      "properties": {
        "consumer_scope_class": { "$ref": "#/$defs/consumer_scope_class" },
        "affected_consumer_refs": { "$ref": "#/$defs/ref_array" },
        "reach_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "historical_visibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "historical_visibility_class",
        "history_refs",
        "history_note"
      ],
      "properties": {
        "historical_visibility_class": { "$ref": "#/$defs/historical_visibility_class" },
        "history_refs": { "$ref": "#/$defs/ref_array" },
        "history_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "recovery_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "last_known_good_ref",
        "rollback_manifest_ref",
        "repin_target_ref",
        "replacement_artifact_ref",
        "deprecation_or_migration_refs",
        "manual_action_refs",
        "no_recovery_reason",
        "continuity_note"
      ],
      "properties": {
        "last_known_good_ref": { "$ref": "#/$defs/nullable_string" },
        "rollback_manifest_ref": { "$ref": "#/$defs/nullable_string" },
        "repin_target_ref": { "$ref": "#/$defs/nullable_string" },
        "replacement_artifact_ref": { "$ref": "#/$defs/nullable_string" },
        "deprecation_or_migration_refs": { "$ref": "#/$defs/ref_array" },
        "manual_action_refs": { "$ref": "#/$defs/ref_array" },
        "no_recovery_reason": { "$ref": "#/$defs/nullable_string" },
        "continuity_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "evidence_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness_class",
        "latest_evidence_at",
        "required_evidence_refs",
        "waiver_packet_refs",
        "freshness_policy_ref",
        "freshness_note"
      ],
      "properties": {
        "freshness_class": { "$ref": "#/$defs/evidence_freshness_class" },
        "latest_evidence_at": { "$ref": "#/$defs/nullable_utc_datetime" },
        "required_evidence_refs": { "$ref": "#/$defs/ref_array" },
        "waiver_packet_refs": { "$ref": "#/$defs/ref_array" },
        "freshness_policy_ref": { "$ref": "#/$defs/non_empty_string" },
        "freshness_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "value",
        "content_address_ref"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["sha256_content", "blake3_content", "not_checked_here"]
        },
        "value": { "$ref": "#/$defs/nullable_string" },
        "content_address_ref": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "artifact_provenance_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_family_class",
        "artifact_ref",
        "exact_build_identity_ref",
        "build_id",
        "digest",
        "signature_state",
        "attestation_state",
        "checksum_bundle_ref",
        "origin_path_class",
        "validated_at",
        "verifier_class",
        "limitation_note"
      ],
      "properties": {
        "artifact_family_class": { "$ref": "#/$defs/artifact_family_class" },
        "artifact_ref": { "$ref": "#/$defs/non_empty_string" },
        "exact_build_identity_ref": { "$ref": "#/$defs/non_empty_string" },
        "build_id": { "$ref": "#/$defs/non_empty_string" },
        "digest": { "$ref": "#/$defs/digest" },
        "signature_state": { "$ref": "#/$defs/proof_state_class" },
        "attestation_state": { "$ref": "#/$defs/proof_state_class" },
        "checksum_bundle_ref": { "$ref": "#/$defs/nullable_string" },
        "origin_path_class": { "$ref": "#/$defs/origin_path_class" },
        "validated_at": { "$ref": "#/$defs/nullable_utc_datetime" },
        "verifier_class": { "$ref": "#/$defs/verifier_class" },
        "limitation_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "support_and_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audit_event_refs",
        "support_bundle_refs",
        "support_packet_index_refs",
        "advisory_refs",
        "export_action_refs",
        "support_note"
      ],
      "properties": {
        "audit_event_refs": { "$ref": "#/$defs/ref_array" },
        "support_bundle_refs": { "$ref": "#/$defs/ref_array" },
        "support_packet_index_refs": { "$ref": "#/$defs/ref_array" },
        "advisory_refs": { "$ref": "#/$defs/ref_array" },
        "export_action_refs": { "$ref": "#/$defs/ref_array" },
        "support_note": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  },
  "properties": {
    "rollback_revocation_panel_schema_version": {
      "$ref": "#/$defs/rollback_revocation_panel_schema_version"
    },
    "record_kind": {
      "type": "string",
      "const": "rollback_revocation_panel_record"
    },
    "panel_id": {
      "type": "string",
      "pattern": "^rollback_revocation_panel:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "release_status_card_ref": { "$ref": "#/$defs/non_empty_string" },
    "candidate_ref": { "$ref": "#/$defs/non_empty_string" },
    "source_refs": { "$ref": "#/$defs/source_refs" },
    "action_class": { "$ref": "#/$defs/release_action_class" },
    "panel_state_class": { "$ref": "#/$defs/panel_state_class" },
    "affected_state_surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/affected_state_surface" },
      "minItems": 1
    },
    "affected_artifact_scope": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_scope_item" },
      "minItems": 1
    },
    "consumer_scope": { "$ref": "#/$defs/consumer_scope" },
    "historical_visibility": { "$ref": "#/$defs/historical_visibility" },
    "recovery_path": { "$ref": "#/$defs/recovery_path" },
    "artifact_provenance_links": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_provenance_link" },
      "minItems": 1
    },
    "evidence_freshness": { "$ref": "#/$defs/evidence_freshness" },
    "support_and_audit": { "$ref": "#/$defs/support_and_audit" },
    "rendering_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_class_visible",
        "affected_state_surfaces_visible",
        "affected_artifact_scope_visible",
        "consumer_scope_visible",
        "historical_visibility_visible",
        "recovery_path_visible",
        "support_export_visible"
      ],
      "properties": {
        "action_class_visible": { "type": "boolean", "const": true },
        "affected_state_surfaces_visible": { "type": "boolean", "const": true },
        "affected_artifact_scope_visible": { "type": "boolean", "const": true },
        "consumer_scope_visible": { "type": "boolean", "const": true },
        "historical_visibility_visible": { "type": "boolean", "const": true },
        "recovery_path_visible": { "type": "boolean", "const": true },
        "support_export_visible": { "type": "boolean", "const": true }
      }
    },
    "notes": { "$ref": "#/$defs/non_empty_string" }
  }
}
