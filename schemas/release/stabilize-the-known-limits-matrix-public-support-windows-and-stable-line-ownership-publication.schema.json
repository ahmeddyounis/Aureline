{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StabilizeTheKnownLimitsMatrixPublicSupportWindowsAndStableLineOwnershipPublication",
  "description": "Schema for the M04-182 known-limits matrix, public support windows, and stable-line ownership publication register.",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "register_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "known_limits_register_ref",
    "support_window_template_ref",
    "ownership_template_ref",
    "lifecycle_labels",
    "kinds",
    "publication_states",
    "gap_reasons",
    "publication_actions",
    "launch_cutline",
    "release_blocking_surface_refs",
    "publication_rules",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "stabilize_the_known_limits_matrix_public_support_windows_and_stable_line_ownership_publication"
      ]
    },
    "register_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "overview_page": {
      "type": "string"
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "claim_manifest_ref": {
      "type": "string"
    },
    "known_limits_register_ref": {
      "type": "string"
    },
    "support_window_template_ref": {
      "type": "string"
    },
    "ownership_template_ref": {
      "type": "string"
    },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "lts",
          "stable",
          "beta",
          "preview",
          "withdrawn"
        ]
      }
    },
    "kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "known_limit",
          "public_support_window",
          "stable_line_ownership"
        ]
      }
    },
    "publication_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "stabilized",
          "stabilized_on_waiver",
          "narrowed_unbacked",
          "narrowed_claim_narrowed",
          "narrowed_stale",
          "narrowed_waiver_expired",
          "narrowed_support_expired",
          "narrowed_ownership_missing"
        ]
      }
    },
    "gap_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "claim_label_narrowed",
          "surface_capability_absent",
          "evidence_incomplete",
          "proof_packet_freshness_breached",
          "proof_packet_missing",
          "waiver_expired",
          "owner_signoff_missing",
          "support_window_expired",
          "ownership_unpublished"
        ]
      }
    },
    "publication_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "hold_publication",
          "narrow_claim_label",
          "refresh_proof_packet",
          "recapture_evidence",
          "renew_support_window",
          "publish_ownership_record",
          "request_owner_signoff"
        ]
      }
    },
    "launch_cutline": {
      "type": "object",
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": {
          "type": "string",
          "enum": [
            "stable"
          ]
        },
        "above_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        }
      }
    },
    "release_blocking_surface_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publication_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "title",
          "trigger_reason",
          "applies_to_labels",
          "default_action",
          "blocks_publication",
          "rationale"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "trigger_reason": {
            "type": "string",
            "enum": [
              "claim_label_narrowed",
              "surface_capability_absent",
              "evidence_incomplete",
              "proof_packet_freshness_breached",
              "proof_packet_missing",
              "waiver_expired",
              "owner_signoff_missing",
              "support_window_expired",
              "ownership_unpublished"
            ]
          },
          "applies_to_labels": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "lts",
                "stable",
                "beta",
                "preview",
                "withdrawn"
              ]
            }
          },
          "default_action": {
            "type": "string",
            "enum": [
              "hold_publication",
              "narrow_claim_label",
              "refresh_proof_packet",
              "recapture_evidence",
              "renew_support_window",
              "publish_ownership_record",
              "request_owner_signoff"
            ]
          },
          "blocks_publication": {
            "type": "boolean"
          },
          "rationale": {
            "type": "string"
          }
        }
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entry_id",
          "title",
          "kind",
          "surface_ref",
          "surface_summary",
          "release_blocking",
          "claim_ref",
          "claim_label",
          "publication_state",
          "proof_packet",
          "owner_signoff",
          "active_gap_reasons",
          "published_label",
          "rationale"
        ],
        "properties": {
          "entry_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "known_limit",
              "public_support_window",
              "stable_line_ownership"
            ]
          },
          "surface_ref": {
            "type": "string"
          },
          "surface_summary": {
            "type": "string"
          },
          "release_blocking": {
            "type": "boolean"
          },
          "claim_ref": {
            "type": "string"
          },
          "claim_label": {
            "type": "string",
            "enum": [
              "lts",
              "stable",
              "beta",
              "preview",
              "withdrawn"
            ]
          },
          "publication_state": {
            "type": "string",
            "enum": [
              "stabilized",
              "stabilized_on_waiver",
              "narrowed_unbacked",
              "narrowed_claim_narrowed",
              "narrowed_stale",
              "narrowed_waiver_expired",
              "narrowed_support_expired",
              "narrowed_ownership_missing"
            ]
          },
          "proof_packet": {
            "type": "object",
            "required": [
              "packet_id",
              "packet_ref",
              "proof_index_ref",
              "captured_at",
              "freshness_slo",
              "slo_state",
              "evidence_refs"
            ],
            "properties": {
              "packet_id": {
                "type": "string"
              },
              "packet_ref": {
                "type": "string"
              },
              "proof_index_ref": {
                "type": "string"
              },
              "captured_at": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "freshness_slo": {
                "type": "object",
                "required": [
                  "target_max_age_days",
                  "warn_within_days",
                  "slo_register_ref"
                ],
                "properties": {
                  "target_max_age_days": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "warn_within_days": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "slo_register_ref": {
                    "type": "string"
                  }
                }
              },
              "slo_state": {
                "type": "string",
                "enum": [
                  "current",
                  "due_for_refresh",
                  "breached",
                  "missing"
                ]
              },
              "evidence_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "waiver": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "waiver_ref",
              "expires_at",
              "reason",
              "approved_by"
            ],
            "properties": {
              "waiver_ref": {
                "type": "string"
              },
              "expires_at": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "approved_by": {
                "type": "string"
              }
            }
          },
          "owner_signoff": {
            "type": "object",
            "required": [
              "owner_ref",
              "signed_off",
              "signed_at"
            ],
            "properties": {
              "owner_ref": {
                "type": "string"
              },
              "signed_off": {
                "type": "boolean"
              },
              "signed_at": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "active_gap_reasons": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "claim_label_narrowed",
                "surface_capability_absent",
                "evidence_incomplete",
                "proof_packet_freshness_breached",
                "proof_packet_missing",
                "waiver_expired",
                "owner_signoff_missing",
                "support_window_expired",
                "ownership_unpublished"
              ]
            }
          },
          "published_label": {
            "type": "string",
            "enum": [
              "lts",
              "stable",
              "beta",
              "preview",
              "withdrawn"
            ]
          },
          "publication_destinations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rationale": {
            "type": "string"
          }
        }
      }
    },
    "publication": {
      "type": "object",
      "required": [
        "publication_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_entry_ids",
        "rationale"
      ],
      "properties": {
        "publication_gate": {
          "type": "string"
        },
        "decision": {
          "type": "string",
          "enum": [
            "proceed",
            "hold"
          ]
        },
        "blocking_rule_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking_entry_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rationale": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total_entries",
        "total_claims",
        "entries_published_stable",
        "entries_narrowed_below_cutline",
        "entries_on_active_waiver",
        "release_blocking_total",
        "release_blocking_published_stable",
        "release_blocking_narrowed",
        "known_limit_entries",
        "support_window_entries",
        "ownership_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_gap_reasons",
        "publication_rules_firing"
      ],
      "properties": {
        "total_entries": {
          "type": "integer",
          "minimum": 0
        },
        "total_claims": {
          "type": "integer",
          "minimum": 0
        },
        "entries_published_stable": {
          "type": "integer",
          "minimum": 0
        },
        "entries_narrowed_below_cutline": {
          "type": "integer",
          "minimum": 0
        },
        "entries_on_active_waiver": {
          "type": "integer",
          "minimum": 0
        },
        "release_blocking_total": {
          "type": "integer",
          "minimum": 0
        },
        "release_blocking_published_stable": {
          "type": "integer",
          "minimum": 0
        },
        "release_blocking_narrowed": {
          "type": "integer",
          "minimum": 0
        },
        "known_limit_entries": {
          "type": "integer",
          "minimum": 0
        },
        "support_window_entries": {
          "type": "integer",
          "minimum": 0
        },
        "ownership_entries": {
          "type": "integer",
          "minimum": 0
        },
        "packets_current": {
          "type": "integer",
          "minimum": 0
        },
        "packets_due_for_refresh": {
          "type": "integer",
          "minimum": 0
        },
        "packets_breached": {
          "type": "integer",
          "minimum": 0
        },
        "packets_missing": {
          "type": "integer",
          "minimum": 0
        },
        "total_active_gap_reasons": {
          "type": "integer",
          "minimum": 0
        },
        "publication_rules_firing": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}