{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/finalize-qualification-packets-for-optional-surfaces-and-enforce.schema.json",
  "title": "Aureline finalize qualification packets for optional surfaces and enforce narrower-than-stable labeling register",
  "description": "Canonical, machine-readable M4 finalization register for optional surfaces that must narrow below Stable unless they carry their own current stable qualification packet, complete evidence, owner sign-off, unexpired waiver when needed, and a backing public claim at or above the cutline. Records per-deployment-target access modes so a missing packet forces automatic downgrade everywhere the surface appears.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "register_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "freshness_slo_register_ref",
    "lifecycle_labels",
    "surface_kinds",
    "surface_states",
    "narrow_reasons",
    "narrow_actions",
    "launch_cutline",
    "release_relevant_surface_refs",
    "stop_rules",
    "surfaces",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "finalize_qualification_packets_for_optional_surfaces_and_enforce"
    },
    "register_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "$ref": "#/$defs/non_empty_string"
    },
    "overview_page": {
      "$ref": "#/$defs/non_empty_string"
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "claim_manifest_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "freshness_slo_register_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lifecycle_label"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "surface_kinds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/surface_kind"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "surface_states": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/surface_state"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "narrow_reasons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/narrow_reason"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "narrow_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/narrow_action"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "launch_cutline": {
      "$ref": "#/$defs/launch_cutline"
    },
    "release_relevant_surface_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "stop_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stop_rule"
      },
      "minItems": 1
    },
    "surfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/surface"
      },
      "minItems": 1
    },
    "publication": {
      "$ref": "#/$defs/publication"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "ref_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "nullable_date": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "format": "date"
        }
      ]
    },
    "lifecycle_label": {
      "type": "string",
      "enum": [
        "lts",
        "stable",
        "beta",
        "preview",
        "withdrawn"
      ]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "opt_in_capability",
        "optional_integration",
        "secondary_platform",
        "experimental_preview"
      ]
    },
    "surface_state": {
      "type": "string",
      "enum": [
        "qualified_stable",
        "qualified_on_waiver",
        "narrowed_no_packet",
        "narrowed_incomplete",
        "narrowed_stale",
        "narrowed_claim_narrowed",
        "narrowed_waiver_expired"
      ]
    },
    "narrow_reason": {
      "type": "string",
      "enum": [
        "claim_label_narrowed",
        "qualification_packet_absent",
        "surface_capability_absent",
        "surface_evidence_incomplete",
        "qualification_packet_breached",
        "waiver_expired",
        "owner_signoff_missing"
      ]
    },
    "narrow_action": {
      "type": "string",
      "enum": [
        "hold_promotion",
        "narrow_surface_label",
        "author_qualification_packet",
        "refresh_qualification_packet",
        "recapture_surface_evidence",
        "request_owner_signoff"
      ]
    },
    "freshness_slo_state": {
      "type": "string",
      "enum": [
        "current",
        "due_for_refresh",
        "breached",
        "missing"
      ]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": {
          "type": "string",
          "const": "stable"
        },
        "above_cutline_levels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lifecycle_label"
          }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lifecycle_label"
          }
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "stop_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_promotion",
        "rationale"
      ],
      "properties": {
        "rule_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "trigger_reason": {
          "$ref": "#/$defs/narrow_reason"
        },
        "applies_to_labels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lifecycle_label"
          },
          "minItems": 1
        },
        "default_action": {
          "$ref": "#/$defs/narrow_action"
        },
        "blocks_promotion": {
          "type": "boolean"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "freshness_slo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_max_age_days",
        "warn_within_days",
        "slo_register_ref"
      ],
      "properties": {
        "target_max_age_days": {
          "type": "integer",
          "minimum": 1
        },
        "warn_within_days": {
          "type": "integer",
          "minimum": 0
        },
        "slo_register_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "qualification_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "captured_at",
        "freshness_slo",
        "slo_state",
        "evidence_refs"
      ],
      "properties": {
        "packet_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "packet_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "proof_index_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "captured_at": {
          "$ref": "#/$defs/nullable_date"
        },
        "freshness_slo": {
          "$ref": "#/$defs/freshness_slo"
        },
        "slo_state": {
          "$ref": "#/$defs/freshness_slo_state"
        },
        "evidence_refs": {
          "$ref": "#/$defs/ref_array"
        }
      }
    },
    "waiver": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "waiver_ref",
            "expires_at",
            "reason"
          ],
          "properties": {
            "waiver_ref": {
              "$ref": "#/$defs/non_empty_string"
            },
            "expires_at": {
              "type": "string",
              "format": "date"
            },
            "reason": {
              "$ref": "#/$defs/non_empty_string"
            }
          }
        }
      ]
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_ref",
        "signed_off",
        "signed_at"
      ],
      "properties": {
        "owner_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "signed_off": {
          "type": "boolean"
        },
        "signed_at": {
          "$ref": "#/$defs/nullable_date"
        }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "title",
        "surface_kind",
        "surface_ref",
        "surface_summary",
        "release_relevant",
        "claim_ref",
        "claim_label",
        "surface_state",
        "source_ref",
        "owner_signoff",
        "active_narrow_reasons",
        "displayed_label",
        "publication_destinations",
        "rationale"
      ],
      "properties": {
        "surface_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_kind": {
          "$ref": "#/$defs/surface_kind"
        },
        "surface_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "release_relevant": {
          "type": "boolean"
        },
        "claim_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "claim_label": {
          "$ref": "#/$defs/lifecycle_label"
        },
        "surface_state": {
          "$ref": "#/$defs/surface_state"
        },
        "source_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "qualification_packet": {
          "$ref": "#/$defs/qualification_packet"
        },
        "waiver": {
          "$ref": "#/$defs/waiver"
        },
        "owner_signoff": {
          "$ref": "#/$defs/owner_signoff"
        },
        "active_narrow_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/narrow_reason"
          },
          "uniqueItems": true
        },
        "displayed_label": {
          "$ref": "#/$defs/lifecycle_label"
        },
        "publication_destinations": {
          "$ref": "#/$defs/ref_array"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        },
        "deployment_qualifications": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/deployment_qualification"
          }
        }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_surface_ids",
        "rationale"
      ],
      "properties": {
        "publication_gate": {
          "$ref": "#/$defs/non_empty_string"
        },
        "decision": {
          "type": "string",
          "enum": [
            "proceed",
            "hold"
          ]
        },
        "blocking_rule_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        },
        "blocking_surface_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_surfaces",
        "total_claims",
        "surfaces_qualified_stable",
        "surfaces_narrowed_below_cutline",
        "surfaces_on_active_waiver",
        "surfaces_with_packet",
        "surfaces_without_packet",
        "release_relevant_total",
        "release_relevant_qualified",
        "release_relevant_narrowed",
        "opt_in_capability_surfaces",
        "optional_integration_surfaces",
        "secondary_platform_surfaces",
        "experimental_preview_surfaces",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "total_active_narrow_reasons",
        "stop_rules_firing"
      ],
      "properties": {
        "total_surfaces": {
          "type": "integer",
          "minimum": 0
        },
        "total_claims": {
          "type": "integer",
          "minimum": 0
        },
        "surfaces_qualified_stable": {
          "type": "integer",
          "minimum": 0
        },
        "surfaces_narrowed_below_cutline": {
          "type": "integer",
          "minimum": 0
        },
        "surfaces_on_active_waiver": {
          "type": "integer",
          "minimum": 0
        },
        "surfaces_with_packet": {
          "type": "integer",
          "minimum": 0
        },
        "surfaces_without_packet": {
          "type": "integer",
          "minimum": 0
        },
        "release_relevant_total": {
          "type": "integer",
          "minimum": 0
        },
        "release_relevant_qualified": {
          "type": "integer",
          "minimum": 0
        },
        "release_relevant_narrowed": {
          "type": "integer",
          "minimum": 0
        },
        "opt_in_capability_surfaces": {
          "type": "integer",
          "minimum": 0
        },
        "optional_integration_surfaces": {
          "type": "integer",
          "minimum": 0
        },
        "secondary_platform_surfaces": {
          "type": "integer",
          "minimum": 0
        },
        "experimental_preview_surfaces": {
          "type": "integer",
          "minimum": 0
        },
        "packets_current": {
          "type": "integer",
          "minimum": 0
        },
        "packets_due_for_refresh": {
          "type": "integer",
          "minimum": 0
        },
        "packets_breached": {
          "type": "integer",
          "minimum": 0
        },
        "total_active_narrow_reasons": {
          "type": "integer",
          "minimum": 0
        },
        "stop_rules_firing": {
          "type": "integer",
          "minimum": 0
        },
        "deployment_rows_stable": {
          "type": "integer",
          "minimum": 0
        },
        "deployment_rows_narrowed": {
          "type": "integer",
          "minimum": 0
        },
        "release_relevant_complete_coverage": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "deployment_target": {
      "type": "string",
      "enum": [
        "desktop_local",
        "remote_helper",
        "managed",
        "self_hosted",
        "air_gapped"
      ]
    },
    "deployment_access_mode": {
      "type": "string",
      "enum": [
        "stable",
        "preview",
        "inspect_only",
        "handoff_only",
        "hidden",
        "client_profile_limited"
      ]
    },
    "deployment_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deployment_target",
        "access_mode",
        "surface_state",
        "active_narrow_reasons",
        "rationale"
      ],
      "properties": {
        "deployment_target": {
          "$ref": "#/$defs/deployment_target"
        },
        "access_mode": {
          "$ref": "#/$defs/deployment_access_mode"
        },
        "surface_state": {
          "$ref": "#/$defs/surface_state"
        },
        "active_narrow_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/narrow_reason"
          }
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}