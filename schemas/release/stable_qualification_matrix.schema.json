{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/stable_qualification_matrix.schema.json",
  "title": "Aureline stable qualification matrix",
  "description": "Canonical, machine-readable qualification matrix for the desktop, remote/helper, ecosystem, state/schema, provider, and accessibility lanes. Every cross-binary or cross-service lane carries an explicit mixed-version section publishing the negotiated fields, supported skew window, upgrade order, rollback order, and unsupported-state behavior. A lane that cannot publish complete mixed-version data is coordinated-upgrade-only and may not inherit a Stable mixed-version claim. The matrix is metadata-only: it carries typed states and opaque refs, never raw artifacts, logs, signatures, or credentials.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "matrix_id",
    "status",
    "overview_page",
    "as_of",
    "claim_matrix_ref",
    "row_scopes",
    "claim_levels",
    "qualification_states",
    "downgrade_reasons",
    "downgrade_actions",
    "mixed_version_postures",
    "boundary_families",
    "out_of_window_postures",
    "launch_cutline",
    "downgrade_rules",
    "rows",
    "promotion",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "stable_qualification_matrix" },
    "matrix_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "claim_matrix_ref": { "$ref": "#/$defs/non_empty_string" },
    "row_scopes": {
      "type": "array",
      "items": { "$ref": "#/$defs/row_scope" },
      "minItems": 1,
      "uniqueItems": true
    },
    "claim_levels": {
      "type": "array",
      "items": { "$ref": "#/$defs/claim_level" },
      "minItems": 1,
      "uniqueItems": true
    },
    "qualification_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/qualification_state" },
      "minItems": 1,
      "uniqueItems": true
    },
    "downgrade_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/downgrade_reason" },
      "minItems": 1,
      "uniqueItems": true
    },
    "downgrade_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/downgrade_action" },
      "minItems": 1,
      "uniqueItems": true
    },
    "mixed_version_postures": {
      "type": "array",
      "items": { "$ref": "#/$defs/mixed_version_posture" },
      "minItems": 1,
      "uniqueItems": true
    },
    "boundary_families": {
      "type": "array",
      "items": { "$ref": "#/$defs/boundary_family" },
      "minItems": 1,
      "uniqueItems": true
    },
    "out_of_window_postures": {
      "type": "array",
      "items": { "$ref": "#/$defs/out_of_window_posture" },
      "minItems": 1,
      "uniqueItems": true
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "downgrade_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/downgrade_rule" },
      "minItems": 1
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/row" },
      "minItems": 1
    },
    "promotion": { "$ref": "#/$defs/promotion" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "nullable_date": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "format": "date" }
      ]
    },
    "row_scope": {
      "type": "string",
      "enum": [
        "desktop",
        "remote_helper",
        "ecosystem",
        "state_schema",
        "provider",
        "accessibility"
      ]
    },
    "claim_level": {
      "type": "string",
      "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
    },
    "qualification_state": {
      "type": "string",
      "enum": [
        "qualified",
        "provisional_on_waiver",
        "not_qualified",
        "evidence_stale",
        "waiver_expired"
      ]
    },
    "downgrade_reason": {
      "type": "string",
      "enum": [
        "qualification_evidence_missing",
        "qualification_evidence_stale",
        "waiver_expired",
        "freshness_window_exceeded",
        "owner_signoff_missing",
        "backing_claim_narrowed",
        "mixed_version_data_incomplete",
        "mixed_version_skew_unsupported"
      ]
    },
    "downgrade_action": {
      "type": "string",
      "enum": [
        "hold_promotion",
        "narrow_claim",
        "refresh_evidence_packet",
        "require_coordinated_upgrade",
        "staff_correction_lane"
      ]
    },
    "mixed_version_posture": {
      "type": "string",
      "enum": [
        "rolling_skew_supported",
        "bounded_skew_supported",
        "coordinated_upgrade_only"
      ]
    },
    "boundary_family": {
      "type": "string",
      "enum": [
        "launcher_and_local_sidecars",
        "desktop_cli_and_remote_agent",
        "desktop_cli_browser_and_managed_control_plane",
        "extension_host_and_abi",
        "saved_artifact_and_schema_readers_writers",
        "provider_adapters"
      ]
    },
    "out_of_window_posture": {
      "type": "string",
      "enum": ["fail_closed", "read_only", "degraded", "explicitly_unsupported"]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "type": "string", "const": "stable" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim_level" }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim_level" }
        },
        "description": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "downgrade_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_levels",
        "default_action",
        "blocks_promotion",
        "rationale"
      ],
      "properties": {
        "rule_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "trigger_reason": { "$ref": "#/$defs/downgrade_reason" },
        "applies_to_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim_level" },
          "minItems": 1
        },
        "default_action": { "$ref": "#/$defs/downgrade_action" },
        "blocks_promotion": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_refs", "proof_index_ref", "captured_at", "freshness_window_days"],
      "properties": {
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "proof_index_ref": { "$ref": "#/$defs/non_empty_string" },
        "captured_at": { "$ref": "#/$defs/nullable_date" },
        "freshness_window_days": { "type": "integer", "minimum": 1 }
      }
    },
    "waiver": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["waiver_ref", "expires_at", "reason"],
          "properties": {
            "waiver_ref": { "$ref": "#/$defs/non_empty_string" },
            "expires_at": { "type": "string", "format": "date" },
            "reason": { "$ref": "#/$defs/non_empty_string" }
          }
        }
      ]
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_ref", "signed_off", "signed_at"],
      "properties": {
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "signed_off": { "type": "boolean" },
        "signed_at": { "$ref": "#/$defs/nullable_date" }
      }
    },
    "order_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["declared_order", "notes"],
      "properties": {
        "declared_order": { "$ref": "#/$defs/ref_array" },
        "notes": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "skew_window": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["window_class", "summary", "skew_register_ref"],
          "properties": {
            "window_class": { "$ref": "#/$defs/non_empty_string" },
            "summary": { "$ref": "#/$defs/non_empty_string" },
            "skew_register_ref": { "$ref": "#/$defs/non_empty_string" }
          }
        }
      ]
    },
    "unsupported_state_behavior": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["state_class", "out_of_window_posture", "contract_rule"],
          "properties": {
            "state_class": { "$ref": "#/$defs/non_empty_string" },
            "out_of_window_posture": { "$ref": "#/$defs/out_of_window_posture" },
            "contract_rule": { "$ref": "#/$defs/non_empty_string" }
          }
        }
      ]
    },
    "mixed_version_section": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "boundary_family",
            "boundary_label",
            "claimed_posture",
            "effective_posture",
            "negotiated_fields",
            "supported_skew_window",
            "upgrade_order",
            "rollback_order",
            "unsupported_state_behavior",
            "evidence_refs",
            "rationale"
          ],
          "properties": {
            "boundary_family": { "$ref": "#/$defs/boundary_family" },
            "boundary_label": { "$ref": "#/$defs/non_empty_string" },
            "claimed_posture": { "$ref": "#/$defs/mixed_version_posture" },
            "effective_posture": { "$ref": "#/$defs/mixed_version_posture" },
            "negotiated_fields": { "$ref": "#/$defs/ref_array" },
            "supported_skew_window": { "$ref": "#/$defs/skew_window" },
            "upgrade_order": { "$ref": "#/$defs/order_record" },
            "rollback_order": { "$ref": "#/$defs/order_record" },
            "unsupported_state_behavior": { "$ref": "#/$defs/unsupported_state_behavior" },
            "evidence_refs": { "$ref": "#/$defs/ref_array" },
            "rationale": { "$ref": "#/$defs/non_empty_string" }
          }
        }
      ]
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "title",
        "row_scope",
        "subject_family",
        "backing_claim_ref",
        "claimed_level",
        "qualification_state",
        "evidence",
        "waiver",
        "owner_signoff",
        "active_downgrade_reasons",
        "effective_level",
        "mixed_version",
        "publication_destinations",
        "rationale"
      ],
      "properties": {
        "row_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "row_scope": { "$ref": "#/$defs/row_scope" },
        "subject_family": { "$ref": "#/$defs/non_empty_string" },
        "backing_claim_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/non_empty_string" }]
        },
        "claimed_level": { "$ref": "#/$defs/claim_level" },
        "qualification_state": { "$ref": "#/$defs/qualification_state" },
        "evidence": { "$ref": "#/$defs/evidence" },
        "waiver": { "$ref": "#/$defs/waiver" },
        "owner_signoff": { "$ref": "#/$defs/owner_signoff" },
        "active_downgrade_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/downgrade_reason" },
          "uniqueItems": true
        },
        "effective_level": { "$ref": "#/$defs/claim_level" },
        "mixed_version": { "$ref": "#/$defs/mixed_version_section" },
        "publication_destinations": { "$ref": "#/$defs/ref_array" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_row_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": { "$ref": "#/$defs/non_empty_string" },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": { "$ref": "#/$defs/ref_array" },
        "blocking_row_ids": { "$ref": "#/$defs/ref_array" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows",
        "rows_holding_stable",
        "rows_narrowed_below_cutline",
        "rows_on_active_waiver",
        "cross_binary_rows",
        "rows_with_stable_mixed_version_claim",
        "coordinated_upgrade_only_rows",
        "total_active_downgrade_reasons",
        "downgrade_rules_firing"
      ],
      "properties": {
        "total_rows": { "type": "integer", "minimum": 0 },
        "rows_holding_stable": { "type": "integer", "minimum": 0 },
        "rows_narrowed_below_cutline": { "type": "integer", "minimum": 0 },
        "rows_on_active_waiver": { "type": "integer", "minimum": 0 },
        "cross_binary_rows": { "type": "integer", "minimum": 0 },
        "rows_with_stable_mixed_version_claim": { "type": "integer", "minimum": 0 },
        "coordinated_upgrade_only_rows": { "type": "integer", "minimum": 0 },
        "total_active_downgrade_reasons": { "type": "integer", "minimum": 0 },
        "downgrade_rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
