{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/stable_publication_pack.schema.json",
  "title": "Aureline stable publication pack",
  "description": "Canonical, machine-readable pack governing the stable release line's outward-facing publications: known-limits publications, public benchmark publications, compatibility publications, and migration publications. Each row binds one publication to the proof packet that grounds it (a known-limits register, a benchmark-lab trace, a compatibility report, or a migration guide) and, for benchmark publications, the published p50/p95 budget it must hold (with corpus metadata, a benchmark-lab trace, and a tightened flag), and backs the publication against a public claim (a stable-claim-manifest entry) whose canonical lifecycle label is a hard ceiling; a publication may carry that label or narrow below it but never wider. A publication whose proof packet breached its freshness SLO or is missing, whose measured numbers regressed beyond the published budget, whose corpus metadata or trace is missing, whose waiver expired, whose evidence is incomplete, or whose backing public claim is itself below the cutline narrows below the launch cutline. The pack is metadata-only: it carries typed states, measured/published budget numbers, and opaque refs, never raw artifacts, logs, signatures, or credentials.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "pack_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "known_limits_register_ref",
    "benchmark_pack_template_ref",
    "compatibility_report_template_ref",
    "migration_contract_ref",
    "lifecycle_labels",
    "publication_kinds",
    "publication_states",
    "gap_reasons",
    "publication_actions",
    "launch_cutline",
    "release_blocking_surface_refs",
    "publication_rules",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "stable_publication_pack" },
    "pack_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "known_limits_register_ref": { "$ref": "#/$defs/non_empty_string" },
    "benchmark_pack_template_ref": { "$ref": "#/$defs/non_empty_string" },
    "compatibility_report_template_ref": { "$ref": "#/$defs/non_empty_string" },
    "migration_contract_ref": { "$ref": "#/$defs/non_empty_string" },
    "lifecycle_labels": {
      "type": "array",
      "items": { "$ref": "#/$defs/lifecycle_label" },
      "minItems": 1,
      "uniqueItems": true
    },
    "publication_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/publication_kind" },
      "minItems": 1,
      "uniqueItems": true
    },
    "publication_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/publication_state" },
      "minItems": 1,
      "uniqueItems": true
    },
    "gap_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap_reason" },
      "minItems": 1,
      "uniqueItems": true
    },
    "publication_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/publication_action" },
      "minItems": 1,
      "uniqueItems": true
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_surface_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "publication_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/publication_rule" },
      "minItems": 1
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/row" },
      "minItems": 1
    },
    "publication": { "$ref": "#/$defs/publication" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "nullable_date": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "format": "date" }
      ]
    },
    "lifecycle_label": {
      "type": "string",
      "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
    },
    "publication_kind": {
      "type": "string",
      "enum": ["known_limit", "benchmark", "compatibility", "migration"]
    },
    "freshness_slo_state": {
      "type": "string",
      "enum": ["current", "due_for_refresh", "breached", "missing"]
    },
    "publication_state": {
      "type": "string",
      "enum": [
        "published",
        "published_on_waiver",
        "narrowed_unbacked",
        "narrowed_claim_narrowed",
        "narrowed_stale",
        "narrowed_waiver_expired",
        "narrowed_budget_regressed"
      ]
    },
    "gap_reason": {
      "type": "string",
      "enum": [
        "claim_label_narrowed",
        "surface_capability_absent",
        "evidence_incomplete",
        "corpus_metadata_missing",
        "budget_regressed",
        "proof_packet_freshness_breached",
        "proof_packet_missing",
        "waiver_expired",
        "owner_signoff_missing"
      ]
    },
    "publication_action": {
      "type": "string",
      "enum": [
        "hold_publication",
        "narrow_publication_label",
        "refresh_proof_packet",
        "recapture_evidence",
        "retune_or_waive_budget",
        "request_owner_signoff"
      ]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "type": "string", "const": "stable" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" }
        },
        "description": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "publication_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_publication",
        "rationale"
      ],
      "properties": {
        "rule_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "trigger_reason": { "$ref": "#/$defs/gap_reason" },
        "applies_to_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" },
          "minItems": 1
        },
        "default_action": { "$ref": "#/$defs/publication_action" },
        "blocks_publication": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "benchmark_budget": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "metric_ref",
            "published_p50_ms",
            "published_p95_ms",
            "measured_p50_ms",
            "measured_p95_ms",
            "corpus_ref",
            "trace_ref",
            "tightened"
          ],
          "properties": {
            "metric_ref": { "$ref": "#/$defs/non_empty_string" },
            "published_p50_ms": { "type": "integer", "minimum": 0 },
            "published_p95_ms": { "type": "integer", "minimum": 0 },
            "measured_p50_ms": { "type": "integer", "minimum": 0 },
            "measured_p95_ms": { "type": "integer", "minimum": 0 },
            "corpus_ref": { "type": "string" },
            "trace_ref": { "type": "string" },
            "tightened": { "type": "boolean" }
          }
        }
      ]
    },
    "freshness_slo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
      "properties": {
        "target_max_age_days": { "type": "integer", "minimum": 1 },
        "warn_within_days": { "type": "integer", "minimum": 0 },
        "slo_register_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "captured_at",
        "freshness_slo",
        "slo_state",
        "evidence_refs"
      ],
      "properties": {
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "proof_index_ref": { "$ref": "#/$defs/non_empty_string" },
        "captured_at": { "$ref": "#/$defs/nullable_date" },
        "freshness_slo": { "$ref": "#/$defs/freshness_slo" },
        "slo_state": { "$ref": "#/$defs/freshness_slo_state" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "waiver": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["waiver_ref", "expires_at", "reason"],
          "properties": {
            "waiver_ref": { "$ref": "#/$defs/non_empty_string" },
            "expires_at": { "type": "string", "format": "date" },
            "reason": { "$ref": "#/$defs/non_empty_string" }
          }
        }
      ]
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_ref", "signed_off", "signed_at"],
      "properties": {
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "signed_off": { "type": "boolean" },
        "signed_at": { "$ref": "#/$defs/nullable_date" }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "publication_kind",
        "surface_ref",
        "surface_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "publication_state",
        "proof_packet",
        "benchmark_budget",
        "waiver",
        "owner_signoff",
        "active_gap_reasons",
        "published_label",
        "publication_destinations",
        "rationale"
      ],
      "properties": {
        "entry_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "publication_kind": { "$ref": "#/$defs/publication_kind" },
        "surface_ref": { "$ref": "#/$defs/non_empty_string" },
        "surface_summary": { "$ref": "#/$defs/non_empty_string" },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "$ref": "#/$defs/non_empty_string" },
        "claim_label": { "$ref": "#/$defs/lifecycle_label" },
        "publication_state": { "$ref": "#/$defs/publication_state" },
        "proof_packet": { "$ref": "#/$defs/proof_packet" },
        "benchmark_budget": { "$ref": "#/$defs/benchmark_budget" },
        "waiver": { "$ref": "#/$defs/waiver" },
        "owner_signoff": { "$ref": "#/$defs/owner_signoff" },
        "active_gap_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/gap_reason" },
          "uniqueItems": true
        },
        "published_label": { "$ref": "#/$defs/lifecycle_label" },
        "publication_destinations": { "$ref": "#/$defs/ref_array" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_entry_ids",
        "rationale"
      ],
      "properties": {
        "publication_gate": { "$ref": "#/$defs/non_empty_string" },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": { "$ref": "#/$defs/ref_array" },
        "blocking_entry_ids": { "$ref": "#/$defs/ref_array" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "total_claims",
        "entries_published_stable",
        "entries_narrowed_below_cutline",
        "entries_on_active_waiver",
        "release_blocking_total",
        "release_blocking_published_stable",
        "release_blocking_narrowed",
        "known_limit_entries",
        "benchmark_entries",
        "compatibility_entries",
        "migration_entries",
        "benchmark_budgets_within",
        "benchmark_budgets_regressed",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_gap_reasons",
        "publication_rules_firing"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "entries_published_stable": { "type": "integer", "minimum": 0 },
        "entries_narrowed_below_cutline": { "type": "integer", "minimum": 0 },
        "entries_on_active_waiver": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_published_stable": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "known_limit_entries": { "type": "integer", "minimum": 0 },
        "benchmark_entries": { "type": "integer", "minimum": 0 },
        "compatibility_entries": { "type": "integer", "minimum": 0 },
        "migration_entries": { "type": "integer", "minimum": 0 },
        "benchmark_budgets_within": { "type": "integer", "minimum": 0 },
        "benchmark_budgets_regressed": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_active_gap_reasons": { "type": "integer", "minimum": 0 },
        "publication_rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
