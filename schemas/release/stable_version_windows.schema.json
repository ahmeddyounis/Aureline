{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/stable_version_windows.schema.json",
  "title": "Aureline stable version-window freeze",
  "description": "Canonical, machine-readable freeze of the stable version windows and deprecation packets for the release line's public interface surfaces (CLI, schema, API, manifest). Each row pins one surface's version window (floor, current, ceiling, compatibility posture) and the deprecation packet that governs how older versions leave it, and backs the surface against a public claim (a stable-claim-manifest entry) whose canonical lifecycle label is a hard ceiling; a freeze may back that label or narrow below it but never wider. A surface whose freeze packet breached its freshness SLO or is missing, whose deprecation packet is incomplete or carries an overdue removal, whose waiver expired, whose surface evidence is incomplete, or whose backing public claim is itself below the cutline narrows below the launch cutline. The freeze is metadata-only: it carries typed states and opaque refs, never raw artifacts, logs, signatures, or credentials.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "freeze_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "lifecycle_labels",
    "surface_kinds",
    "compatibility_postures",
    "deprecation_statuses",
    "window_states",
    "gap_reasons",
    "window_actions",
    "launch_cutline",
    "release_blocking_surface_refs",
    "freeze_rules",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "stable_version_windows" },
    "freeze_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "lifecycle_labels": {
      "type": "array",
      "items": { "$ref": "#/$defs/lifecycle_label" },
      "minItems": 1,
      "uniqueItems": true
    },
    "surface_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_kind" },
      "minItems": 1,
      "uniqueItems": true
    },
    "compatibility_postures": {
      "type": "array",
      "items": { "$ref": "#/$defs/compatibility_posture" },
      "minItems": 1,
      "uniqueItems": true
    },
    "deprecation_statuses": {
      "type": "array",
      "items": { "$ref": "#/$defs/deprecation_status" },
      "minItems": 1,
      "uniqueItems": true
    },
    "window_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/window_state" },
      "minItems": 1,
      "uniqueItems": true
    },
    "gap_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap_reason" },
      "minItems": 1,
      "uniqueItems": true
    },
    "window_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/window_action" },
      "minItems": 1,
      "uniqueItems": true
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_surface_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "freeze_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/freeze_rule" },
      "minItems": 1
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/row" },
      "minItems": 1
    },
    "publication": { "$ref": "#/$defs/publication" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "nullable_date": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "format": "date" }
      ]
    },
    "lifecycle_label": {
      "type": "string",
      "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
    },
    "surface_kind": {
      "type": "string",
      "enum": ["cli", "schema", "api", "manifest"]
    },
    "compatibility_posture": {
      "type": "string",
      "enum": ["backward_compatible", "additive_only", "frozen_no_change", "breaking_major_only"]
    },
    "deprecation_status": {
      "type": "string",
      "enum": ["announced", "migration_available", "removed"]
    },
    "freshness_slo_state": {
      "type": "string",
      "enum": ["current", "due_for_refresh", "breached", "missing"]
    },
    "window_state": {
      "type": "string",
      "enum": [
        "frozen",
        "frozen_on_waiver",
        "unfrozen_unbacked",
        "unfrozen_claim_narrowed",
        "unfrozen_stale",
        "unfrozen_waiver_expired",
        "unfrozen_deprecation_overdue"
      ]
    },
    "gap_reason": {
      "type": "string",
      "enum": [
        "claim_label_narrowed",
        "surface_capability_absent",
        "freeze_evidence_incomplete",
        "deprecation_packet_incomplete",
        "deprecation_removal_overdue",
        "freeze_packet_freshness_breached",
        "freeze_packet_missing",
        "waiver_expired",
        "owner_signoff_missing"
      ]
    },
    "window_action": {
      "type": "string",
      "enum": [
        "hold_publication",
        "narrow_window_label",
        "refresh_freeze_packet",
        "complete_deprecation_packet",
        "recapture_surface_evidence",
        "request_owner_signoff"
      ]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "type": "string", "const": "stable" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" }
        },
        "description": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "freeze_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_publication",
        "rationale"
      ],
      "properties": {
        "rule_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "trigger_reason": { "$ref": "#/$defs/gap_reason" },
        "applies_to_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" },
          "minItems": 1
        },
        "default_action": { "$ref": "#/$defs/window_action" },
        "blocks_publication": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "version_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["floor_version", "current_version", "ceiling_version", "compatibility_posture"],
      "properties": {
        "floor_version": { "$ref": "#/$defs/non_empty_string" },
        "current_version": { "$ref": "#/$defs/non_empty_string" },
        "ceiling_version": { "$ref": "#/$defs/non_empty_string" },
        "compatibility_posture": { "$ref": "#/$defs/compatibility_posture" }
      }
    },
    "freshness_slo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
      "properties": {
        "target_max_age_days": { "type": "integer", "minimum": 1 },
        "warn_within_days": { "type": "integer", "minimum": 0 },
        "slo_register_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "freeze_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "captured_at",
        "freshness_slo",
        "slo_state",
        "evidence_refs"
      ],
      "properties": {
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "proof_index_ref": { "$ref": "#/$defs/non_empty_string" },
        "captured_at": { "$ref": "#/$defs/nullable_date" },
        "freshness_slo": { "$ref": "#/$defs/freshness_slo" },
        "slo_state": { "$ref": "#/$defs/freshness_slo_state" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "deprecation_notice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deprecated_version",
        "superseded_by",
        "announced_at",
        "removal_target_version",
        "removal_target_date",
        "migration_ref",
        "status"
      ],
      "properties": {
        "deprecated_version": { "$ref": "#/$defs/non_empty_string" },
        "superseded_by": { "type": "string" },
        "announced_at": { "type": "string" },
        "removal_target_version": { "type": "string" },
        "removal_target_date": { "type": "string" },
        "migration_ref": { "type": "string" },
        "status": { "$ref": "#/$defs/deprecation_status" }
      }
    },
    "deprecation_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_id", "deprecations"],
      "properties": {
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "deprecations": {
          "type": "array",
          "items": { "$ref": "#/$defs/deprecation_notice" }
        }
      }
    },
    "waiver": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["waiver_ref", "expires_at", "reason"],
          "properties": {
            "waiver_ref": { "$ref": "#/$defs/non_empty_string" },
            "expires_at": { "type": "string", "format": "date" },
            "reason": { "$ref": "#/$defs/non_empty_string" }
          }
        }
      ]
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_ref", "signed_off", "signed_at"],
      "properties": {
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "signed_off": { "type": "boolean" },
        "signed_at": { "$ref": "#/$defs/nullable_date" }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_id",
        "title",
        "surface_kind",
        "surface_ref",
        "surface_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "window_state",
        "version_window",
        "freeze_packet",
        "deprecation_packet",
        "waiver",
        "owner_signoff",
        "active_gap_reasons",
        "frozen_label",
        "publication_destinations",
        "rationale"
      ],
      "properties": {
        "window_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "surface_ref": { "$ref": "#/$defs/non_empty_string" },
        "surface_summary": { "$ref": "#/$defs/non_empty_string" },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "$ref": "#/$defs/non_empty_string" },
        "claim_label": { "$ref": "#/$defs/lifecycle_label" },
        "window_state": { "$ref": "#/$defs/window_state" },
        "version_window": { "$ref": "#/$defs/version_window" },
        "freeze_packet": { "$ref": "#/$defs/freeze_packet" },
        "deprecation_packet": { "$ref": "#/$defs/deprecation_packet" },
        "waiver": { "$ref": "#/$defs/waiver" },
        "owner_signoff": { "$ref": "#/$defs/owner_signoff" },
        "active_gap_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/gap_reason" },
          "uniqueItems": true
        },
        "frozen_label": { "$ref": "#/$defs/lifecycle_label" },
        "publication_destinations": { "$ref": "#/$defs/ref_array" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_window_ids",
        "rationale"
      ],
      "properties": {
        "publication_gate": { "$ref": "#/$defs/non_empty_string" },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": { "$ref": "#/$defs/ref_array" },
        "blocking_window_ids": { "$ref": "#/$defs/ref_array" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_surfaces",
        "total_claims",
        "surfaces_frozen_stable",
        "surfaces_narrowed_below_cutline",
        "surfaces_on_active_waiver",
        "release_blocking_total",
        "release_blocking_frozen_stable",
        "release_blocking_unfrozen",
        "cli_surfaces",
        "schema_surfaces",
        "api_surfaces",
        "manifest_surfaces",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_deprecations",
        "surfaces_deprecation_overdue",
        "total_active_gap_reasons",
        "freeze_rules_firing"
      ],
      "properties": {
        "total_surfaces": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "surfaces_frozen_stable": { "type": "integer", "minimum": 0 },
        "surfaces_narrowed_below_cutline": { "type": "integer", "minimum": 0 },
        "surfaces_on_active_waiver": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_frozen_stable": { "type": "integer", "minimum": 0 },
        "release_blocking_unfrozen": { "type": "integer", "minimum": 0 },
        "cli_surfaces": { "type": "integer", "minimum": 0 },
        "schema_surfaces": { "type": "integer", "minimum": 0 },
        "api_surfaces": { "type": "integer", "minimum": 0 },
        "manifest_surfaces": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_deprecations": { "type": "integer", "minimum": 0 },
        "surfaces_deprecation_overdue": { "type": "integer", "minimum": 0 },
        "total_active_gap_reasons": { "type": "integer", "minimum": 0 },
        "freeze_rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
