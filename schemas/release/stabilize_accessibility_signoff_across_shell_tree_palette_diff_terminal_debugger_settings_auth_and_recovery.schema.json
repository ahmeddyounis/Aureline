{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/stabilize_accessibility_signoff_across_shell_tree_palette_diff_terminal_debugger_settings_auth_and_recovery.schema.json",
  "title": "Aureline accessibility surface signoff register",
  "description": "Canonical, machine-readable register that binds each touched IDE surface — shell, tree, palette, diff, terminal, debugger, settings, auth, and recovery — to its accessibility signoff state across the six dimensions (keyboard, screen-reader, IME/grapheme/bidi, zoom, high-contrast, reduced-motion). The register is metadata-only: it carries typed states and opaque refs, never raw artifacts, logs, signatures, or credentials.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "register_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "lifecycle_labels",
    "surface_kinds",
    "dimension_kinds",
    "signoff_states",
    "gap_reasons",
    "signoff_actions",
    "launch_cutline",
    "release_blocking_surface_refs",
    "rules",
    "rows",
    "promotion",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "accessibility_surface_signoffs" },
    "register_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "lifecycle_labels": {
      "type": "array",
      "items": { "$ref": "#/$defs/claim_level" },
      "minItems": 1,
      "uniqueItems": true
    },
    "surface_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_kind" },
      "minItems": 1,
      "uniqueItems": true
    },
    "dimension_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/dimension_kind" },
      "minItems": 1,
      "uniqueItems": true
    },
    "signoff_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/signoff_state" },
      "minItems": 1,
      "uniqueItems": true
    },
    "gap_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap_reason" },
      "minItems": 1,
      "uniqueItems": true
    },
    "signoff_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/signoff_action" },
      "minItems": 1,
      "uniqueItems": true
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_surface_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/signoff_rule" },
      "minItems": 1
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/signoff_row" },
      "minItems": 1
    },
    "promotion": { "$ref": "#/$defs/promotion_record" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "nullable_date": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "format": "date" }
      ]
    },
    "claim_level": {
      "type": "string",
      "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "shell",
        "tree",
        "palette",
        "diff",
        "terminal",
        "debugger",
        "settings",
        "auth",
        "recovery"
      ]
    },
    "dimension_kind": {
      "type": "string",
      "enum": [
        "keyboard",
        "screen_reader",
        "ime_grapheme_bidi",
        "zoom",
        "high_contrast",
        "reduced_motion"
      ]
    },
    "dimension_state": {
      "type": "string",
      "enum": ["passed", "degraded", "partial", "blocked", "pending_evidence"]
    },
    "signoff_state": {
      "type": "string",
      "enum": ["qualified", "provisional_on_waiver", "not_qualified", "evidence_stale", "waiver_expired"]
    },
    "gap_reason": {
      "type": "string",
      "enum": [
        "claim_label_narrowed",
        "dimension_blocked",
        "evidence_stale",
        "evidence_missing",
        "owner_signoff_missing",
        "waiver_expired"
      ]
    },
    "signoff_action": {
      "type": "string",
      "enum": ["hold_promotion", "narrow_claim", "refresh_evidence_packet", "request_owner_signoff"]
    },
    "promotion_decision": {
      "type": "string",
      "enum": ["proceed", "hold"]
    },
    "freshness_slo_state": {
      "type": "string",
      "enum": ["current", "due_for_refresh", "breached", "missing"]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "type": "string", "const": "stable" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim_level" }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim_level" }
        },
        "description": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "freshness_slo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
      "properties": {
        "target_max_age_days": { "type": "integer", "minimum": 1 },
        "warn_within_days": { "type": "integer", "minimum": 0 },
        "slo_register_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "captured_at",
        "freshness_slo",
        "slo_state",
        "evidence_refs"
      ],
      "properties": {
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "proof_index_ref": { "$ref": "#/$defs/non_empty_string" },
        "captured_at": { "$ref": "#/$defs/nullable_date" },
        "freshness_slo": { "$ref": "#/$defs/freshness_slo" },
        "slo_state": { "$ref": "#/$defs/freshness_slo_state" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_ref", "signed_off", "signed_at"],
      "properties": {
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "signed_off": { "type": "boolean" },
        "signed_at": { "$ref": "#/$defs/nullable_date" }
      }
    },
    "waiver": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["waiver_ref", "expires_at", "reason"],
          "properties": {
            "waiver_ref": { "$ref": "#/$defs/non_empty_string" },
            "expires_at": { "type": "string", "format": "date" },
            "reason": { "$ref": "#/$defs/non_empty_string" }
          }
        }
      ]
    },
    "dimension_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "dimension_state"],
      "properties": {
        "dimension": { "$ref": "#/$defs/dimension_kind" },
        "dimension_state": { "$ref": "#/$defs/dimension_state" },
        "evidence_ref": {
          "oneOf": [
            { "$ref": "#/$defs/non_empty_string" },
            { "type": "null" }
          ]
        },
        "notes": {
          "oneOf": [
            { "$ref": "#/$defs/non_empty_string" },
            { "type": "null" }
          ]
        }
      }
    },
    "signoff_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_promotion",
        "rationale"
      ],
      "properties": {
        "rule_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "trigger_reason": { "$ref": "#/$defs/gap_reason" },
        "applies_to_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim_level" },
          "minItems": 1
        },
        "default_action": { "$ref": "#/$defs/signoff_action" },
        "blocks_promotion": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "signoff_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "surface_kind",
        "surface_ref",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "signoff_state",
        "dimension_checks",
        "proof_packet",
        "owner_signoff",
        "active_gap_reasons",
        "published_label",
        "publication_destinations",
        "rationale"
      ],
      "properties": {
        "entry_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "surface_ref": { "$ref": "#/$defs/non_empty_string" },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "$ref": "#/$defs/non_empty_string" },
        "claim_label": { "$ref": "#/$defs/claim_level" },
        "signoff_state": { "$ref": "#/$defs/signoff_state" },
        "dimension_checks": {
          "type": "array",
          "minItems": 6,
          "items": { "$ref": "#/$defs/dimension_check" }
        },
        "proof_packet": { "$ref": "#/$defs/proof_packet" },
        "waiver": { "$ref": "#/$defs/waiver" },
        "owner_signoff": { "$ref": "#/$defs/owner_signoff" },
        "active_gap_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/gap_reason" },
          "uniqueItems": true
        },
        "published_label": { "$ref": "#/$defs/claim_level" },
        "publication_destinations": { "$ref": "#/$defs/ref_array" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "promotion_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_entry_ids",
        "rationale"
      ],
      "properties": {
        "promotion_gate": { "$ref": "#/$defs/non_empty_string" },
        "decision": { "$ref": "#/$defs/promotion_decision" },
        "blocking_rule_ids": { "$ref": "#/$defs/ref_array" },
        "blocking_entry_ids": { "$ref": "#/$defs/ref_array" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "total_claims",
        "entries_qualified",
        "entries_narrowed",
        "entries_on_active_waiver",
        "entries_blocked",
        "release_blocking_total",
        "release_blocking_qualified",
        "release_blocking_narrowed",
        "shell_entries",
        "tree_entries",
        "palette_entries",
        "diff_entries",
        "terminal_entries",
        "debugger_entries",
        "settings_entries",
        "auth_entries",
        "recovery_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_gap_reasons",
        "rules_firing"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "entries_qualified": { "type": "integer", "minimum": 0 },
        "entries_narrowed": { "type": "integer", "minimum": 0 },
        "entries_on_active_waiver": { "type": "integer", "minimum": 0 },
        "entries_blocked": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_qualified": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "shell_entries": { "type": "integer", "minimum": 0 },
        "tree_entries": { "type": "integer", "minimum": 0 },
        "palette_entries": { "type": "integer", "minimum": 0 },
        "diff_entries": { "type": "integer", "minimum": 0 },
        "terminal_entries": { "type": "integer", "minimum": 0 },
        "debugger_entries": { "type": "integer", "minimum": 0 },
        "settings_entries": { "type": "integer", "minimum": 0 },
        "auth_entries": { "type": "integer", "minimum": 0 },
        "recovery_entries": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_active_gap_reasons": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
