{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FinalizeCompatibilityReportsDeprecationPacketsSchemaVersionWindows",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "register_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "lifecycle_labels",
    "kinds",
    "states",
    "gap_reasons",
    "actions",
    "launch_cutline",
    "release_blocking_surface_refs",
    "rules",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "compatibility_deprecation_schema_migration_finalize"
      ]
    },
    "register_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "overview_page": {
      "type": "string"
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "claim_manifest_ref": {
      "type": "string"
    },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "lts",
          "stable",
          "beta",
          "preview",
          "withdrawn"
        ]
      }
    },
    "kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "compatibility_report",
          "deprecation_packet",
          "schema_version_window",
          "migration_publication"
        ]
      }
    },
    "states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "finalized_stable",
          "finalized_on_waiver",
          "narrowed_unbacked",
          "narrowed_claim_narrowed",
          "narrowed_stale",
          "narrowed_waiver_expired",
          "narrowed_deprecation_overdue",
          "narrowed_evidence_incomplete"
        ]
      }
    },
    "gap_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "claim_label_narrowed",
          "surface_capability_absent",
          "evidence_incomplete",
          "report_ref_missing",
          "validity_window_expired",
          "scorecard_degraded",
          "deprecation_packet_incomplete",
          "deprecation_removal_overdue",
          "freeze_packet_freshness_breached",
          "freeze_packet_missing",
          "waiver_expired",
          "owner_signoff_missing"
        ]
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "hold_publication",
          "narrow_label",
          "refresh_proof_packet",
          "complete_deprecation_packet",
          "recapture_evidence",
          "request_owner_signoff"
        ]
      }
    },
    "launch_cutline": {
      "type": "object",
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": {
          "type": "string",
          "enum": [
            "stable"
          ]
        },
        "above_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "lts",
              "stable",
              "beta",
              "preview",
              "withdrawn"
            ]
          }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "lts",
              "stable",
              "beta",
              "preview",
              "withdrawn"
            ]
          }
        },
        "description": {
          "type": "string"
        }
      }
    },
    "release_blocking_surface_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "publication": {
      "type": "object"
    },
    "summary": {
      "type": "object"
    }
  }
}