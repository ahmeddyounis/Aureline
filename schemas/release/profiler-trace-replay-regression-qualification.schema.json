{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/profiler-trace-replay-regression-qualification.schema.json",
  "title": "Profiler, trace, replay, and regression qualification packet",
  "description": "Release schema for performance tooling rows that must prove profile-session provenance, immutable trace-bundle identity, replay capability, regression comparability, session-strip visibility, and export review defaults before claiming Stable.",
  "type": "object",
  "required": [
    "packet_id",
    "generated_at",
    "rows"
  ],
  "additionalProperties": false,
  "properties": {
    "packet_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "generated_at": {
      "$ref": "#/$defs/non_empty_string"
    },
    "source_contract_refs": {
      "$ref": "#/$defs/ref_array"
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/qualification_row"
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "ref_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "uniqueItems": true
    },
    "claim_label": {
      "enum": [
        "stable",
        "preview",
        "labs",
        "evidence_view_only",
        "unsupported"
      ]
    },
    "surface_kind": {
      "enum": [
        "profile_session",
        "flamegraph",
        "timeline",
        "call_tree",
        "allocation_view",
        "imported_profile_viewer",
        "reverse_replay_timeline",
        "regression_summary"
      ]
    },
    "capture_mode": {
      "enum": [
        "cpu_sample",
        "instrumented_cpu_profile",
        "wall_time_trace",
        "memory_sample",
        "allocation_snapshot",
        "replay_recording",
        "imported_profile"
      ]
    },
    "capture_source": {
      "enum": [
        "local",
        "remote",
        "container",
        "ci_artifact",
        "imported_bundle"
      ]
    },
    "evidence_state": {
      "enum": [
        "live",
        "imported",
        "cached",
        "stale",
        "not_recorded"
      ]
    },
    "mapping_quality": {
      "enum": [
        "exact",
        "approximate",
        "partial",
        "imported",
        "stale",
        "unavailable"
      ]
    },
    "metric_family": {
      "enum": [
        "cpu",
        "wall_time",
        "runtime_events",
        "memory",
        "io"
      ]
    },
    "redaction_mode": {
      "enum": [
        "metadata_and_hashes_only",
        "redacted_summary",
        "local_only_raw_retained",
        "raw_review_required",
        "withheld_by_policy"
      ]
    },
    "retention_class": {
      "enum": [
        "ephemeral_local",
        "rotating_local_evidence",
        "pinned_local_evidence",
        "support_manifest_only",
        "managed_archive"
      ]
    },
    "replay_degradation_state": {
      "enum": [
        "supported",
        "limited",
        "record_only",
        "profile_only",
        "import_view_only",
        "unsupported"
      ]
    },
    "replay_feature_state": {
      "enum": [
        "supported",
        "limited",
        "unsupported"
      ]
    },
    "projection_surface": {
      "enum": [
        "product_ui",
        "cli_headless",
        "support_export",
        "help_docs",
        "release_evidence"
      ]
    },
    "confounder_kind": {
      "enum": [
        "local_remote",
        "debug_release",
        "warm_cold",
        "hardware_class",
        "power_state"
      ]
    },
    "threshold_waiver_state": {
      "enum": [
        "threshold_active",
        "threshold_exceeded",
        "waiver_active",
        "waiver_expired",
        "advisory_only"
      ]
    },
    "qualification_row": {
      "type": "object",
      "required": [
        "row_id",
        "title",
        "surface_kind",
        "promoted_build_surface",
        "claim_label",
        "family_packet_ref",
        "profile_session",
        "trace_bundle",
        "replay_capability",
        "session_strip",
        "export_review",
        "projections",
        "evidence_refs"
      ],
      "additionalProperties": false,
      "properties": {
        "row_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_kind": {
          "$ref": "#/$defs/surface_kind"
        },
        "promoted_build_surface": {
          "type": "boolean"
        },
        "claim_label": {
          "$ref": "#/$defs/claim_label"
        },
        "family_packet_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "profile_session": {
          "$ref": "#/$defs/profile_session"
        },
        "trace_bundle": {
          "$ref": "#/$defs/trace_bundle"
        },
        "replay_capability": {
          "$ref": "#/$defs/replay_capability"
        },
        "session_strip": {
          "$ref": "#/$defs/session_strip"
        },
        "regression_comparison": {
          "$ref": "#/$defs/regression_comparison"
        },
        "reverse_replay_chrome": {
          "$ref": "#/$defs/reverse_replay_chrome"
        },
        "export_review": {
          "$ref": "#/$defs/export_review"
        },
        "projections": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/projection_surface"
          }
        },
        "evidence_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "disclosure_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "profile_session": {
      "type": "object",
      "required": [
        "session_id",
        "capture_mode",
        "capture_source",
        "execution_context_id",
        "build_runtime",
        "target",
        "capture_window",
        "overhead_class",
        "mapping_quality",
        "data_class",
        "export_posture"
      ],
      "additionalProperties": false,
      "properties": {
        "session_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "capture_mode": {
          "$ref": "#/$defs/capture_mode"
        },
        "capture_source": {
          "$ref": "#/$defs/capture_source"
        },
        "execution_context_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "build_runtime": {
          "$ref": "#/$defs/build_runtime"
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "capture_window": {
          "$ref": "#/$defs/capture_window"
        },
        "overhead_class": {
          "$ref": "#/$defs/non_empty_string"
        },
        "mapping_quality": {
          "$ref": "#/$defs/mapping_quality"
        },
        "data_class": {
          "$ref": "#/$defs/non_empty_string"
        },
        "export_posture": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "build_runtime": {
      "type": "object",
      "required": [
        "exact_build_identity_ref",
        "build_id",
        "commit_ref",
        "runtime_identity",
        "toolchain_identity_ref"
      ],
      "additionalProperties": false,
      "properties": {
        "exact_build_identity_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "build_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "commit_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "runtime_identity": {
          "$ref": "#/$defs/non_empty_string"
        },
        "toolchain_identity_ref": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "target": {
      "type": "object",
      "required": [
        "target_kind",
        "target_ref",
        "target_label"
      ],
      "additionalProperties": false,
      "properties": {
        "target_kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "capture_window": {
      "type": "object",
      "required": [
        "started_at",
        "ended_at",
        "duration_ms"
      ],
      "additionalProperties": false,
      "properties": {
        "started_at": {
          "$ref": "#/$defs/non_empty_string"
        },
        "ended_at": {
          "$ref": "#/$defs/non_empty_string"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "trace_bundle": {
      "type": "object",
      "required": [
        "bundle_id",
        "profile_session_ref",
        "execution_context_id",
        "chunk_refs",
        "metric_families",
        "mapping_refs",
        "redaction_mode",
        "retention_class",
        "derived_view_refs",
        "immutable"
      ],
      "additionalProperties": false,
      "properties": {
        "bundle_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "profile_session_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "execution_context_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "chunk_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "metric_families": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/metric_family"
          }
        },
        "mapping_refs": {
          "$ref": "#/$defs/mapping_refs"
        },
        "redaction_mode": {
          "$ref": "#/$defs/redaction_mode"
        },
        "retention_class": {
          "$ref": "#/$defs/retention_class"
        },
        "derived_view_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "immutable": {
          "const": true
        }
      }
    },
    "mapping_refs": {
      "type": "object",
      "required": [
        "symbol_manifest_ref",
        "source_map_manifest_ref",
        "mapping_quality"
      ],
      "additionalProperties": false,
      "properties": {
        "symbol_manifest_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_map_manifest_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "mapping_quality": {
          "$ref": "#/$defs/mapping_quality"
        }
      }
    },
    "replay_capability": {
      "type": "object",
      "required": [
        "backend_family",
        "backend_version",
        "supported_runtime_range",
        "supported_toolchain_range",
        "support_matrix",
        "degradation_state",
        "determinism_caveats"
      ],
      "additionalProperties": false,
      "properties": {
        "backend_family": {
          "$ref": "#/$defs/non_empty_string"
        },
        "backend_version": {
          "$ref": "#/$defs/non_empty_string"
        },
        "supported_runtime_range": {
          "$ref": "#/$defs/non_empty_string"
        },
        "supported_toolchain_range": {
          "$ref": "#/$defs/non_empty_string"
        },
        "support_matrix": {
          "$ref": "#/$defs/replay_support_matrix"
        },
        "degradation_state": {
          "$ref": "#/$defs/replay_degradation_state"
        },
        "determinism_caveats": {
          "$ref": "#/$defs/ref_array"
        },
        "disabled_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "guidance": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "replay_support_matrix": {
      "type": "object",
      "required": [
        "reverse_step",
        "frame_inspection",
        "timeline_scrub"
      ],
      "additionalProperties": false,
      "properties": {
        "reverse_step": {
          "$ref": "#/$defs/replay_feature_state"
        },
        "frame_inspection": {
          "$ref": "#/$defs/replay_feature_state"
        },
        "timeline_scrub": {
          "$ref": "#/$defs/replay_feature_state"
        }
      }
    },
    "session_strip": {
      "type": "object",
      "required": [
        "visible_before_chart",
        "workload",
        "build_runtime",
        "capture_mode",
        "mapping_quality",
        "evidence_state"
      ],
      "additionalProperties": false,
      "properties": {
        "visible_before_chart": {
          "const": true
        },
        "workload": {
          "$ref": "#/$defs/non_empty_string"
        },
        "build_runtime": {
          "$ref": "#/$defs/non_empty_string"
        },
        "capture_mode": {
          "$ref": "#/$defs/capture_mode"
        },
        "mapping_quality": {
          "$ref": "#/$defs/mapping_quality"
        },
        "evidence_state": {
          "$ref": "#/$defs/evidence_state"
        }
      }
    },
    "regression_comparison": {
      "type": "object",
      "required": [
        "baseline_source",
        "baseline_age_days",
        "comparison_key",
        "observed_delta",
        "threshold_or_waiver_state",
        "confounders",
        "open_trace_action_ref",
        "open_review_action_ref",
        "unlike_comparison_blocks_pass_fail"
      ],
      "additionalProperties": false,
      "properties": {
        "baseline_source": {
          "$ref": "#/$defs/non_empty_string"
        },
        "baseline_age_days": {
          "type": "integer",
          "minimum": 0
        },
        "comparison_key": {
          "$ref": "#/$defs/non_empty_string"
        },
        "observed_delta": {
          "$ref": "#/$defs/non_empty_string"
        },
        "threshold_or_waiver_state": {
          "$ref": "#/$defs/threshold_waiver_state"
        },
        "confounders": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/confounder"
          }
        },
        "open_trace_action_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "open_review_action_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "unlike_comparison_blocks_pass_fail": {
          "const": true
        }
      }
    },
    "confounder": {
      "type": "object",
      "required": [
        "kind",
        "label"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/confounder_kind"
        },
        "label": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "reverse_replay_chrome": {
      "type": "object",
      "required": [
        "lane_present",
        "chrome_visible",
        "controls_enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "lane_present": {
          "type": "boolean"
        },
        "chrome_visible": {
          "type": "boolean"
        },
        "controls_enabled": {
          "type": "boolean"
        },
        "disabled_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "guidance": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "export_review": {
      "type": "object",
      "required": [
        "manifest_export_default",
        "summary_export_default",
        "raw_trace_requires_review",
        "memory_payload_requires_review",
        "arguments_require_review",
        "environment_fragments_require_review"
      ],
      "additionalProperties": false,
      "properties": {
        "manifest_export_default": {
          "const": true
        },
        "summary_export_default": {
          "const": true
        },
        "raw_trace_requires_review": {
          "const": true
        },
        "memory_payload_requires_review": {
          "const": true
        },
        "arguments_require_review": {
          "const": true
        },
        "environment_fragments_require_review": {
          "const": true
        }
      }
    }
  }
}
