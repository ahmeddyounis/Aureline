{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "as_of": { "type": "string" },
    "help_doc_ref": { "type": "string" },
    "packet_id": { "type": "string" },
    "record_kind": { "const": "browser_mobile_companion_surface_qualification" },
    "release_doc_ref": { "type": "string" },
    "schema_ref": { "type": "string" },
    "schema_version": { "const": 1 },
    "summary": {
      "additionalProperties": false,
      "properties": {
        "green_packet_count": { "type": "integer", "minimum": 0 },
        "narrowed_surface_count": { "type": "integer", "minimum": 0 },
        "preview_or_labs_count": { "type": "integer", "minimum": 0 },
        "promoted_surface_count": { "type": "integer", "minimum": 0 },
        "stable_surface_count": { "type": "integer", "minimum": 0 }
      },
      "required": [
        "green_packet_count",
        "narrowed_surface_count",
        "preview_or_labs_count",
        "promoted_surface_count",
        "stable_surface_count"
      ],
      "type": "object"
    },
    "surfaces": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "authority": {
            "enum": [
              "observer_only",
              "follow_only",
              "join_only_control_re_request",
              "comment_only",
              "light_edit_bounded",
              "handoff_only",
              "desktop_authoritative"
            ]
          },
          "client_kind": {
            "enum": [
              "browser_companion",
              "mobile_companion",
              "companion_notification",
              "desktop_handoff"
            ]
          },
          "displayed_label": { "enum": ["lts", "stable", "beta", "preview", "withdrawn"] },
          "freshness": { "enum": ["live", "cached", "stale", "offline", "unknown"] },
          "scopes": {
            "items": {
              "enum": [
                "review",
                "docs",
                "follow",
                "join",
                "light_edit",
                "notification_triage",
                "handoff_only"
              ]
            },
            "minItems": 1,
            "type": "array"
          },
          "surface_id": { "type": "string" },
          "visible_label": {
            "enum": [
              "stable_companion",
              "beta_bounded",
              "preview",
              "labs",
              "unsupported_in_client"
            ]
          }
        },
        "required": [
          "authority",
          "client_kind",
          "displayed_label",
          "freshness",
          "scopes",
          "surface_id",
          "visible_label"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    }
  },
  "required": [
    "as_of",
    "help_doc_ref",
    "packet_id",
    "record_kind",
    "release_doc_ref",
    "schema_ref",
    "schema_version",
    "summary",
    "surfaces"
  ],
  "title": "Browser/mobile companion surface qualification packet",
  "type": "object"
}
