{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/open_paid_boundary_audit.schema.json",
  "title": "Aureline open-versus-paid boundary, licensing, provenance, and contribution-policy audit",
  "description": "Canonical, machine-readable audit of the governance facts the stable launch rests on: where the open-source core ends and the paid/managed tier begins, the licensing posture, the build provenance, and the contribution policy. Each row binds a public claim to an attestation packet and required audit controls, and narrows below Stable unless it carries current proof, satisfied controls, an unexpired waiver when relied on, an owner sign-off, and a backing public claim at or above the cutline.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "audit_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "stable_proof_index_ref",
    "lifecycle_labels",
    "audit_domains",
    "audit_states",
    "gap_reasons",
    "audit_actions",
    "launch_cutline",
    "release_blocking_audit_refs",
    "rules",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "open_paid_boundary_audit" },
    "audit_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "stable_proof_index_ref": { "$ref": "#/$defs/non_empty_string" },
    "lifecycle_labels": {
      "type": "array",
      "items": { "$ref": "#/$defs/lifecycle_label" },
      "minItems": 1,
      "uniqueItems": true
    },
    "audit_domains": {
      "type": "array",
      "items": { "$ref": "#/$defs/audit_domain" },
      "minItems": 1,
      "uniqueItems": true
    },
    "audit_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/audit_state" },
      "minItems": 1,
      "uniqueItems": true
    },
    "gap_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap_reason" },
      "minItems": 1,
      "uniqueItems": true
    },
    "audit_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/audit_action" },
      "minItems": 1,
      "uniqueItems": true
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_audit_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/rule" },
      "minItems": 1
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/row" },
      "minItems": 1
    },
    "publication": { "$ref": "#/$defs/publication" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "nullable_date": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "format": "date" }
      ]
    },
    "lifecycle_label": {
      "type": "string",
      "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
    },
    "audit_domain": {
      "type": "string",
      "enum": ["open_paid_boundary", "licensing", "provenance", "contribution_policy"]
    },
    "audit_state": {
      "type": "string",
      "enum": [
        "attested",
        "attested_on_waiver",
        "narrowed_unbacked",
        "narrowed_claim_narrowed",
        "narrowed_stale",
        "narrowed_waiver_expired"
      ]
    },
    "gap_reason": {
      "type": "string",
      "enum": [
        "claim_label_narrowed",
        "audit_evidence_incomplete",
        "attestation_packet_freshness_breached",
        "attestation_packet_missing",
        "waiver_expired",
        "owner_signoff_missing",
        "audit_control_unsatisfied"
      ]
    },
    "audit_action": {
      "type": "string",
      "enum": [
        "hold_publication",
        "narrow_audit_label",
        "refresh_attestation_packet",
        "satisfy_audit_control",
        "recapture_audit_evidence",
        "request_owner_signoff"
      ]
    },
    "freshness_slo_state": {
      "type": "string",
      "enum": ["current", "due_for_refresh", "breached", "missing"]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "type": "string", "const": "stable" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" }
        },
        "description": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_publication",
        "rationale"
      ],
      "properties": {
        "rule_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "trigger_reason": { "$ref": "#/$defs/gap_reason" },
        "applies_to_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" },
          "minItems": 1
        },
        "default_action": { "$ref": "#/$defs/audit_action" },
        "blocks_publication": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "freshness_slo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
      "properties": {
        "target_max_age_days": { "type": "integer", "minimum": 1 },
        "warn_within_days": { "type": "integer", "minimum": 0 },
        "slo_register_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "attestation_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "captured_at",
        "freshness_slo",
        "slo_state",
        "evidence_refs"
      ],
      "properties": {
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "proof_index_ref": { "$ref": "#/$defs/non_empty_string" },
        "captured_at": { "$ref": "#/$defs/nullable_date" },
        "freshness_slo": { "$ref": "#/$defs/freshness_slo" },
        "slo_state": { "$ref": "#/$defs/freshness_slo_state" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "waiver": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["waiver_ref", "expires_at", "reason"],
          "properties": {
            "waiver_ref": { "$ref": "#/$defs/non_empty_string" },
            "expires_at": { "type": "string", "format": "date" },
            "reason": { "$ref": "#/$defs/non_empty_string" }
          }
        }
      ]
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_ref", "signed_off", "signed_at"],
      "properties": {
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "signed_off": { "type": "boolean" },
        "signed_at": { "$ref": "#/$defs/nullable_date" }
      }
    },
    "audit_control": {
      "type": "object",
      "additionalProperties": false,
      "required": ["control_id", "title", "control_ref", "satisfied"],
      "properties": {
        "control_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "control_ref": { "$ref": "#/$defs/non_empty_string" },
        "satisfied": { "type": "boolean" }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "domain",
        "subject_ref",
        "subject_summary",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "audit_state",
        "attestation_packet",
        "owner_signoff",
        "audit_controls",
        "active_gap_reasons",
        "effective_label",
        "publication_destinations",
        "rationale"
      ],
      "properties": {
        "entry_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "domain": { "$ref": "#/$defs/audit_domain" },
        "subject_ref": { "$ref": "#/$defs/non_empty_string" },
        "subject_summary": { "$ref": "#/$defs/non_empty_string" },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "$ref": "#/$defs/non_empty_string" },
        "claim_label": { "$ref": "#/$defs/lifecycle_label" },
        "audit_state": { "$ref": "#/$defs/audit_state" },
        "attestation_packet": { "$ref": "#/$defs/attestation_packet" },
        "waiver": { "$ref": "#/$defs/waiver" },
        "owner_signoff": { "$ref": "#/$defs/owner_signoff" },
        "audit_controls": {
          "type": "array",
          "items": { "$ref": "#/$defs/audit_control" },
          "minItems": 1
        },
        "active_gap_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/gap_reason" },
          "uniqueItems": true
        },
        "effective_label": { "$ref": "#/$defs/lifecycle_label" },
        "publication_destinations": { "$ref": "#/$defs/ref_array" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_entry_ids",
        "rationale"
      ],
      "properties": {
        "publication_gate": { "$ref": "#/$defs/non_empty_string" },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "blocking_entry_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows",
        "total_claims",
        "rows_attested",
        "rows_narrowed_below_cutline",
        "release_blocking_total",
        "release_blocking_attested",
        "release_blocking_narrowed",
        "rows_on_active_waiver",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_controls",
        "controls_satisfied",
        "controls_unsatisfied",
        "total_active_gap_reasons",
        "rules_firing"
      ],
      "properties": {
        "total_rows": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "rows_attested": { "type": "integer", "minimum": 0 },
        "rows_narrowed_below_cutline": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_attested": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "rows_on_active_waiver": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_controls": { "type": "integer", "minimum": 0 },
        "controls_satisfied": { "type": "integer", "minimum": 0 },
        "controls_unsatisfied": { "type": "integer", "minimum": 0 },
        "total_active_gap_reasons": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
