{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/claim-publication-manifest.schema.json",
  "title": "Aureline claim publication manifest",
  "description": "Stable-line manifest consumed by docs, Help/About, service-health, CLI inspection, release notes, public proof, support export, and enterprise evaluation surfaces. Every claim entry links to current compatibility, reference-workspace, or evaluation report refs and carries the effective downgrade state that consuming surfaces must render.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "manifest_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "compatibility_report_ref",
    "reference_workspace_report_index_ref",
    "evaluation_evidence_pack_ref",
    "support_classes",
    "effective_claims",
    "evidence_states",
    "narrowing_reasons",
    "surface_ids",
    "publication_actions",
    "entries",
    "downgrade_rules",
    "evaluation_filters",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "claim_publication_manifest" },
    "manifest_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "$ref": "#/$defs/date" },
    "claim_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "compatibility_report_ref": { "$ref": "#/$defs/non_empty_string" },
    "reference_workspace_report_index_ref": { "$ref": "#/$defs/non_empty_string" },
    "evaluation_evidence_pack_ref": { "$ref": "#/$defs/non_empty_string" },
    "support_classes": {
      "type": "array",
      "prefixItems": [
        { "const": "certified" },
        { "const": "supported" },
        { "const": "limited" },
        { "const": "unsupported" }
      ],
      "items": false
    },
    "effective_claims": {
      "type": "array",
      "prefixItems": [
        { "const": "certified" },
        { "const": "supported" },
        { "const": "limited" },
        { "const": "retest_pending" },
        { "const": "unsupported" }
      ],
      "items": false
    },
    "evidence_states": {
      "type": "array",
      "prefixItems": [
        { "const": "current" },
        { "const": "due_for_refresh" },
        { "const": "stale" },
        { "const": "missing" },
        { "const": "dropped" }
      ],
      "items": false
    },
    "narrowing_reasons": {
      "type": "array",
      "prefixItems": [
        { "const": "evidence_stale" },
        { "const": "evidence_missing" },
        { "const": "compatibility_dropped" },
        { "const": "reference_workspace_stale" },
        { "const": "reference_workspace_missing" },
        { "const": "owner_signoff_missing" },
        { "const": "private_filter_narrowed" }
      ],
      "items": false
    },
    "surface_ids": {
      "type": "array",
      "prefixItems": [
        { "const": "release_notes" },
        { "const": "website_docs" },
        { "const": "enterprise_evaluation_packet" },
        { "const": "product_badges" },
        { "const": "help_about" },
        { "const": "service_health" },
        { "const": "cli_inspection" },
        { "const": "support_export" },
        { "const": "public_proof_packet" }
      ],
      "items": false
    },
    "publication_actions": {
      "type": "array",
      "prefixItems": [
        { "const": "publish_certified" },
        { "const": "publish_supported" },
        { "const": "downgrade_to_limited" },
        { "const": "downgrade_to_retest_pending" },
        { "const": "downgrade_to_unsupported" },
        { "const": "hold_overclaiming_surface" }
      ],
      "items": false
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entry" }
    },
    "downgrade_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule" }
    },
    "evaluation_filters": {
      "type": "array",
      "items": { "$ref": "#/$defs/evaluation_filter" }
    },
    "publication": { "$ref": "#/$defs/publication" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "support_class": { "enum": ["certified", "supported", "limited", "unsupported"] },
    "effective_claim": {
      "enum": ["certified", "supported", "limited", "retest_pending", "unsupported"]
    },
    "evidence_state": { "enum": ["current", "due_for_refresh", "stale", "missing", "dropped"] },
    "narrowing_reason": {
      "enum": [
        "evidence_stale",
        "evidence_missing",
        "compatibility_dropped",
        "reference_workspace_stale",
        "reference_workspace_missing",
        "owner_signoff_missing",
        "private_filter_narrowed"
      ]
    },
    "surface_id": {
      "enum": [
        "release_notes",
        "website_docs",
        "enterprise_evaluation_packet",
        "product_badges",
        "help_about",
        "service_health",
        "cli_inspection",
        "support_export",
        "public_proof_packet"
      ]
    },
    "publication_action": {
      "enum": [
        "publish_certified",
        "publish_supported",
        "downgrade_to_limited",
        "downgrade_to_retest_pending",
        "downgrade_to_unsupported",
        "hold_overclaiming_surface"
      ]
    },
    "validity_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["captured_at", "expires_at", "window_days"],
      "properties": {
        "captured_at": { "type": ["string", "null"] },
        "expires_at": { "type": ["string", "null"] },
        "window_days": { "type": "integer", "minimum": 1 }
      }
    },
    "report_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_ref",
        "report_family",
        "support_class",
        "owner_ref",
        "owner_signed",
        "validity_window",
        "evidence_state"
      ],
      "properties": {
        "report_ref": { "$ref": "#/$defs/non_empty_string" },
        "report_family": {
          "enum": [
            "claim_manifest",
            "compatibility_report",
            "reference_workspace_report",
            "evaluation_evidence_pack",
            "proof_packet"
          ]
        },
        "support_class": { "$ref": "#/$defs/support_class" },
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "owner_signed": { "type": "boolean" },
        "validity_window": { "$ref": "#/$defs/validity_window" },
        "evidence_state": { "$ref": "#/$defs/evidence_state" }
      }
    },
    "surface_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "destination_ref",
        "rendered_claim",
        "badge_label",
        "source_manifest_ref",
        "linked_report_refs",
        "publication_action"
      ],
      "properties": {
        "surface_id": { "$ref": "#/$defs/surface_id" },
        "destination_ref": { "$ref": "#/$defs/non_empty_string" },
        "rendered_claim": { "$ref": "#/$defs/effective_claim" },
        "badge_label": { "$ref": "#/$defs/non_empty_string" },
        "source_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "linked_report_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "publication_action": { "$ref": "#/$defs/publication_action" }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "declared_support_class",
        "effective_claim",
        "scope_caveat",
        "owner_ref",
        "validity_window",
        "linked_report_refs",
        "active_narrowing_reasons",
        "surface_projections",
        "rationale"
      ],
      "properties": {
        "entry_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "declared_support_class": { "$ref": "#/$defs/support_class" },
        "effective_claim": { "$ref": "#/$defs/effective_claim" },
        "scope_caveat": { "$ref": "#/$defs/non_empty_string" },
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "validity_window": { "$ref": "#/$defs/validity_window" },
        "linked_report_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/report_ref" }
        },
        "active_narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        },
        "surface_projections": {
          "type": "array",
          "minItems": 9,
          "items": { "$ref": "#/$defs/surface_projection" }
        },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "default_action",
        "target_claim",
        "blocks_publication_on_overclaim",
        "rationale"
      ],
      "properties": {
        "rule_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "trigger_reason": { "$ref": "#/$defs/narrowing_reason" },
        "default_action": { "$ref": "#/$defs/publication_action" },
        "target_claim": { "$ref": "#/$defs/effective_claim" },
        "blocks_publication_on_overclaim": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "evaluation_filter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "filter_id",
        "audience",
        "included_entry_refs",
        "excluded_entry_refs",
        "public_ceiling_manifest_ref",
        "max_effective_claim"
      ],
      "properties": {
        "filter_id": { "$ref": "#/$defs/non_empty_string" },
        "audience": { "$ref": "#/$defs/non_empty_string" },
        "included_entry_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "excluded_entry_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "public_ceiling_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "max_effective_claim": { "$ref": "#/$defs/effective_claim" }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publication_gate", "decision", "blocking_entry_ids", "blocking_surface_refs", "rationale"],
      "properties": {
        "publication_gate": { "$ref": "#/$defs/non_empty_string" },
        "decision": { "enum": ["proceed", "proceed_with_downgrades", "hold"] },
        "blocking_entry_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "blocking_surface_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "certified_entries_current",
        "entries_downgraded",
        "unsupported_entries",
        "surface_projection_rows",
        "overclaiming_surface_rows"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "certified_entries_current": { "type": "integer", "minimum": 0 },
        "entries_downgraded": { "type": "integer", "minimum": 0 },
        "unsupported_entries": { "type": "integer", "minimum": 0 },
        "surface_projection_rows": { "type": "integer", "minimum": 0 },
        "overclaiming_surface_rows": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
