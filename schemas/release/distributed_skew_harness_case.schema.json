{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/distributed_skew_harness_case.schema.json",
  "title": "Aureline beta distributed skew harness case",
  "description": "One protected skew-harness fixture for a generated distributed compatibility manifest. Cases exercise supported and unsupported windows by citing the generated manifest family, a seeded compatibility row, a source skew case, expected outcome, mutation posture, support-export visibility, and repair hints.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "case_id",
    "family",
    "manifest_ref",
    "compatibility_row_ref",
    "skew_window_ref",
    "skew_case_ref",
    "input_versions",
    "expected_status",
    "expected_outcome",
    "expected_out_of_window_posture",
    "mutation_allowed",
    "expected_support_exportable",
    "expected_repair_hints",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "distributed_skew_harness_case" },
    "case_id": {
      "type": "string",
      "pattern": "^skew_harness_case:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "family": {
      "type": "string",
      "enum": ["client_helper", "client_extension", "schema", "provider"]
    },
    "manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "compatibility_row_ref": {
      "type": "string",
      "pattern": "^compat_row:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "skew_window_ref": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "string",
          "pattern": "^skew_window:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
        }
      ]
    },
    "skew_case_ref": {
      "type": "string",
      "pattern": "^skew_case:[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "input_versions": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/non_empty_string" },
      "minProperties": 2
    },
    "expected_status": {
      "type": "string",
      "enum": ["supported", "unsupported"]
    },
    "expected_outcome": {
      "type": "string",
      "enum": ["allow", "degrade", "read_only", "refuse"]
    },
    "expected_out_of_window_posture": {
      "type": "string",
      "enum": ["fail_closed", "read_only", "degraded", "explicitly_unsupported"]
    },
    "mutation_allowed": { "type": "boolean" },
    "expected_support_exportable": { "type": "boolean", "const": true },
    "expected_repair_hints": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "expected_status": { "const": "unsupported" } },
        "required": ["expected_status"]
      },
      "then": {
        "properties": {
          "mutation_allowed": { "const": false }
        }
      }
    }
  ]
}
