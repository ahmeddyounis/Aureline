{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/silent_deployment_result.schema.json",
  "title": "Aureline silent-deployment result records",
  "description": "Boundary schema for unattended_deployment_result_record and unattended_deployment_result_packet as defined in docs/release/silent_deployment_contract.md and artifacts/release/silent_deployment_seed.yaml. The schema keeps silent install/update/pin/rollback/uninstall outcomes machine-readable and joinable to install-topology cards, state-root ids, managed-package inventory, and later support/export surfaces without relying on free-text-only installer output.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/unattended_deployment_result_record" },
    { "$ref": "#/$defs/unattended_deployment_result_packet" }
  ],
  "$defs": {
    "silent_deployment_result_schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/non_empty_string" }]
    },
    "non_empty_string_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "non_empty_non_empty_string_array": {
      "allOf": [{ "$ref": "#/$defs/non_empty_string_array" }, { "minItems": 1 }]
    },
    "result_kind": {
      "type": "string",
      "enum": ["install", "update", "pin", "rollback", "uninstall", "verify"]
    },
    "result_status": {
      "type": "string",
      "enum": ["success", "partial_success", "failed", "rolled_back", "verify_failed", "reboot_required"]
    },
    "return_code_family": {
      "type": "string",
      "enum": [
        "success",
        "partial_success",
        "user_config_error",
        "trust_policy_denial",
        "missing_dependency",
        "network_transport",
        "internal_failure",
        "rollback_required",
        "verification_failed",
        "admin_required"
      ]
    },
    "failure_reason_class_value": {
      "type": "string",
      "enum": [
        "signature_invalid",
        "signing_material_revoked",
        "mirror_metadata_stale",
        "policy_denied",
        "disk_space_exhausted",
        "path_permission_denied",
        "state_root_collision",
        "side_by_side_marker_corruption",
        "portable_spill_detected",
        "network_unreachable_offline_required",
        "missing_bootstrap_bundle",
        "toolchain_missing",
        "unsupported_platform",
        "internal_bug",
        "user_cancelled"
      ]
    },
    "failure_reason_class": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/failure_reason_class_value" }]
    },
    "remediation_pointer_class": {
      "type": "string",
      "enum": [
        "run_project_doctor",
        "inspect_support_bundle",
        "refresh_mirror_metadata",
        "contact_admin",
        "reissue_policy_bundle",
        "retry_from_offline_bundle",
        "reinstall_from_clean_state",
        "open_release_notes",
        "none"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": ["no_secrets_present", "secrets_redacted_before_emit", "support_bundle_only"]
    },
    "return_code_numeric": {
      "type": "integer",
      "enum": [0, 2, 3, 4, 5, 6, 7, 8, 9, 10]
    },
    "state_root_refs": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/non_empty_non_empty_string_array" }]
    },
    "unattended_deployment_result_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "silent_deployment_result_schema_version",
        "record_kind",
        "result_id",
        "result_kind",
        "result_status",
        "return_code_family",
        "return_code_numeric",
        "install_profile_card_ref",
        "failure_reason_class",
        "remediation_pointer_class",
        "redaction_class",
        "support_bundle_ref",
        "running_build_identity_ref",
        "policy_injection_context_ref",
        "rollback_evidence_ref",
        "fleet_ring_context_ref",
        "offline_bundle_signature_ref",
        "state_root_refs",
        "managed_package_report_ref"
      ],
      "properties": {
        "silent_deployment_result_schema_version": { "$ref": "#/$defs/silent_deployment_result_schema_version" },
        "record_kind": {
          "type": "string",
          "const": "unattended_deployment_result_record"
        },
        "result_id": { "$ref": "#/$defs/non_empty_string" },
        "result_kind": { "$ref": "#/$defs/result_kind" },
        "result_status": { "$ref": "#/$defs/result_status" },
        "return_code_family": { "$ref": "#/$defs/return_code_family" },
        "return_code_numeric": { "$ref": "#/$defs/return_code_numeric" },
        "install_profile_card_ref": { "$ref": "#/$defs/non_empty_string" },
        "failure_reason_class": { "$ref": "#/$defs/failure_reason_class" },
        "remediation_pointer_class": { "$ref": "#/$defs/remediation_pointer_class" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "support_bundle_ref": { "$ref": "#/$defs/nullable_string" },
        "running_build_identity_ref": { "$ref": "#/$defs/nullable_string" },
        "policy_injection_context_ref": { "$ref": "#/$defs/nullable_string" },
        "rollback_evidence_ref": { "$ref": "#/$defs/nullable_string" },
        "fleet_ring_context_ref": { "$ref": "#/$defs/nullable_string" },
        "offline_bundle_signature_ref": { "$ref": "#/$defs/nullable_string" },
        "state_root_refs": { "$ref": "#/$defs/state_root_refs" },
        "managed_package_report_ref": { "$ref": "#/$defs/nullable_string" },
        "notes": { "$ref": "#/$defs/nullable_string" }
      },
      "allOf": [
        {
          "if": { "properties": { "result_status": { "const": "success" } }, "required": ["result_status"] },
          "then": { "properties": { "failure_reason_class": { "type": "null" } } },
          "else": { "properties": { "failure_reason_class": { "$ref": "#/$defs/failure_reason_class_value" } } }
        },
        {
          "if": { "properties": { "return_code_family": { "const": "success" } }, "required": ["return_code_family"] },
          "then": {
            "properties": {
              "return_code_numeric": { "const": 0 },
              "result_status": { "const": "success" }
            }
          }
        },
        {
          "if": { "properties": { "return_code_family": { "const": "partial_success" } }, "required": ["return_code_family"] },
          "then": {
            "properties": {
              "return_code_numeric": { "const": 2 },
              "result_status": { "enum": ["partial_success", "reboot_required"] }
            }
          }
        },
        {
          "if": { "properties": { "return_code_family": { "const": "user_config_error" } }, "required": ["return_code_family"] },
          "then": {
            "properties": {
              "return_code_numeric": { "const": 3 },
              "result_status": { "const": "failed" }
            }
          }
        },
        {
          "if": { "properties": { "return_code_family": { "const": "trust_policy_denial" } }, "required": ["return_code_family"] },
          "then": {
            "properties": {
              "return_code_numeric": { "const": 4 },
              "result_status": { "const": "failed" },
              "result_kind": { "enum": ["install", "update", "pin", "rollback", "uninstall"] }
            }
          }
        },
        {
          "if": { "properties": { "return_code_family": { "const": "missing_dependency" } }, "required": ["return_code_family"] },
          "then": {
            "properties": {
              "return_code_numeric": { "const": 5 },
              "result_status": { "const": "failed" },
              "result_kind": { "enum": ["install", "update", "pin", "rollback", "verify"] }
            }
          }
        },
        {
          "if": { "properties": { "return_code_family": { "const": "network_transport" } }, "required": ["return_code_family"] },
          "then": {
            "properties": {
              "return_code_numeric": { "const": 6 },
              "result_status": { "const": "failed" },
              "result_kind": { "enum": ["install", "update", "pin", "rollback", "verify"] }
            }
          }
        },
        {
          "if": { "properties": { "return_code_family": { "const": "internal_failure" } }, "required": ["return_code_family"] },
          "then": { "properties": { "return_code_numeric": { "const": 7 }, "result_status": { "const": "failed" } } }
        },
        {
          "if": { "properties": { "return_code_family": { "const": "rollback_required" } }, "required": ["return_code_family"] },
          "then": {
            "properties": {
              "return_code_numeric": { "const": 8 },
              "result_status": { "enum": ["failed", "rolled_back"] },
              "result_kind": { "enum": ["install", "update", "rollback"] }
            }
          }
        },
        {
          "if": { "properties": { "return_code_family": { "const": "verification_failed" } }, "required": ["return_code_family"] },
          "then": {
            "properties": {
              "return_code_numeric": { "const": 9 },
              "result_status": { "const": "verify_failed" },
              "result_kind": { "const": "verify" }
            }
          }
        },
        {
          "if": { "properties": { "return_code_family": { "const": "admin_required" } }, "required": ["return_code_family"] },
          "then": { "properties": { "return_code_numeric": { "const": 10 }, "result_status": { "const": "failed" } } }
        },
        {
          "if": {
            "properties": { "return_code_family": { "enum": ["internal_failure", "verification_failed"] } },
            "required": ["return_code_family"]
          },
          "then": { "properties": { "support_bundle_ref": { "$ref": "#/$defs/non_empty_string" } } }
        },
        {
          "if": {
            "properties": {
              "failure_reason_class": {
                "enum": ["state_root_collision", "side_by_side_marker_corruption", "portable_spill_detected"]
              }
            },
            "required": ["failure_reason_class"]
          },
          "then": { "properties": { "state_root_refs": { "$ref": "#/$defs/non_empty_non_empty_string_array" } } }
        }
      ]
    },
    "unattended_deployment_result_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "silent_deployment_result_schema_version",
        "record_kind",
        "packet_id",
        "scenario_summary",
        "install_profile_card_refs",
        "results",
        "status"
      ],
      "properties": {
        "silent_deployment_result_schema_version": { "$ref": "#/$defs/silent_deployment_result_schema_version" },
        "record_kind": {
          "type": "string",
          "const": "unattended_deployment_result_packet"
        },
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "scenario_class": { "$ref": "#/$defs/nullable_string" },
        "scenario_summary": { "$ref": "#/$defs/non_empty_string" },
        "install_profile_card_refs": { "$ref": "#/$defs/non_empty_non_empty_string_array" },
        "state_root_refs": { "$ref": "#/$defs/state_root_refs" },
        "managed_package_report_refs": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/non_empty_string_array" }]
        },
        "expected_uninstall_behavior": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["removes", "preserves"],
              "properties": {
                "removes": { "$ref": "#/$defs/non_empty_string_array" },
                "preserves": { "$ref": "#/$defs/non_empty_string_array" }
              }
            }
          ]
        },
        "results": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/unattended_deployment_result_record" }
        },
        "status": {
          "type": "string",
          "enum": ["proposed", "seeded"]
        },
        "notes": { "$ref": "#/$defs/nullable_string" }
      }
    }
  }
}
