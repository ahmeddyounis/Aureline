{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/update_ready_review.schema.json",
  "title": "Aureline update-ready review",
  "description": "Boundary schema for update_ready_review_record frozen in docs/release/update_ready_review_contract.md. The record is emitted before update apply or restart so update center, release notes, what-is-new, compatibility, migration, support exports, and headless dry runs share one language for signed update verification, target version and channel, affected artifact families, extension/package impact forecasts, migration-task generation, restart-required class, support-window or compatibility-window risk, side-by-side install posture, emergency paths, and rollback visibility. Raw artifacts, raw signatures, raw installer logs, raw package lockfiles, raw extension manifests, raw policy bodies, raw support bundles, raw user state, and raw credentials never cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "update_ready_review_schema_version",
    "record_kind",
    "review_id",
    "emitted_at",
    "review_state_class",
    "source_refs",
    "current_state",
    "target_state",
    "verification",
    "affected_artifact_families",
    "impact_forecast_rollup",
    "migration_tasks",
    "restart",
    "rollback_visibility",
    "support_and_compatibility",
    "side_by_side_and_profile",
    "emergency_path",
    "parity",
    "final_gate",
    "notes"
  ],
  "properties": {
    "update_ready_review_schema_version": {
      "$ref": "#/$defs/update_ready_review_schema_version"
    },
    "record_kind": {
      "type": "string",
      "const": "update_ready_review_record"
    },
    "review_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "emitted_at": {
      "$ref": "#/$defs/utc_datetime"
    },
    "review_state_class": {
      "$ref": "#/$defs/review_state_class"
    },
    "source_refs": {
      "$ref": "#/$defs/source_refs"
    },
    "current_state": {
      "$ref": "#/$defs/install_update_state"
    },
    "target_state": {
      "$ref": "#/$defs/install_update_state"
    },
    "verification": {
      "$ref": "#/$defs/update_verification"
    },
    "affected_artifact_families": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/affected_artifact_family" }
    },
    "impact_forecast_rollup": {
      "$ref": "#/$defs/impact_forecast_rollup"
    },
    "migration_tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/migration_task" }
    },
    "restart": {
      "$ref": "#/$defs/restart_block"
    },
    "rollback_visibility": {
      "$ref": "#/$defs/rollback_visibility"
    },
    "support_and_compatibility": {
      "$ref": "#/$defs/support_and_compatibility"
    },
    "side_by_side_and_profile": {
      "$ref": "#/$defs/side_by_side_and_profile"
    },
    "emergency_path": {
      "$ref": "#/$defs/emergency_path"
    },
    "parity": {
      "$ref": "#/$defs/parity_block"
    },
    "final_gate": {
      "$ref": "#/$defs/final_gate"
    },
    "notes": {
      "$ref": "#/$defs/non_empty_string"
    }
  },
  "$defs": {
    "update_ready_review_schema_version": {
      "type": "integer",
      "const": 1
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/non_empty_string" }
      ]
    },
    "utc_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_utc_datetime": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/utc_datetime" }
      ]
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "non_empty_ref_array": {
      "allOf": [
        { "$ref": "#/$defs/ref_array" },
        { "minItems": 1 }
      ]
    },
    "review_state_class": {
      "type": "string",
      "enum": [
        "ready_to_apply",
        "ready_to_restart",
        "staged_side_by_side",
        "migration_required_before_restart",
        "blocked_before_apply",
        "policy_blocked",
        "rollback_ready_emergency",
        "review_only"
      ]
    },
    "release_channel_class": {
      "type": "string",
      "enum": [
        "dev_local",
        "nightly",
        "preview",
        "beta",
        "stable",
        "lts",
        "hotfix",
        "portable_stable",
        "portable_preview",
        "remote_agent_runtime",
        "remote_helper_runtime"
      ]
    },
    "release_stage_class": {
      "type": "string",
      "enum": [
        "draft",
        "canary",
        "pilot",
        "broad",
        "stable",
        "lts",
        "hotfix",
        "rollback_staged",
        "rollback_applied",
        "revoked",
        "yanked",
        "paused",
        "emergency_active"
      ]
    },
    "support_window_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "unsupported_local",
        "internal_only",
        "rolling_supported",
        "calendar_supported",
        "security_fixes_only",
        "end_of_support_risk",
        "past_end_of_support"
      ]
    },
    "support_window_change_class": {
      "type": "string",
      "enum": [
        "no_change",
        "window_widened",
        "window_narrowed",
        "security_only_after_update",
        "approaching_end_of_support",
        "past_end_of_support",
        "unknown_requires_review"
      ]
    },
    "compatibility_window_risk_class": {
      "type": "string",
      "enum": [
        "none",
        "compatible",
        "compatible_with_warnings",
        "certification_pending",
        "retest_pending",
        "migration_required",
        "blocked_by_policy",
        "past_window",
        "unknown_requires_review"
      ]
    },
    "end_of_support_risk_class": {
      "type": "string",
      "enum": [
        "none",
        "approaching_window_end",
        "security_only_window",
        "past_window",
        "unknown_pending_review"
      ]
    },
    "artifact_family_class": {
      "type": "string",
      "enum": [
        "ide_binary",
        "ide_debug_symbols",
        "cli_binary",
        "cli_debug_symbols",
        "sdk_library",
        "source_map_bundle",
        "docs_pack",
        "schema_export",
        "reference_pack",
        "sbom_document",
        "signed_attestation",
        "source_bundle",
        "crash_symbols_archive",
        "reproducibility_pack",
        "support_runbook_bundle",
        "release_evidence_packet",
        "update_metadata",
        "revocation_manifest",
        "policy_bundle",
        "extension_package",
        "marketplace_metadata",
        "package_lockfile",
        "workflow_bundle",
        "windows_msi",
        "windows_msix",
        "windows_signed_portable_zip",
        "macos_pkg",
        "macos_notarized_dmg",
        "macos_signed_app_zip",
        "linux_deb",
        "linux_rpm",
        "linux_appimage",
        "linux_tarball",
        "remote_agent_tarball",
        "remote_helper_tarball",
        "remote_agent_image_layer_bundle"
      ]
    },
    "artifact_effect_class": {
      "type": "string",
      "enum": [
        "unchanged",
        "added",
        "updated",
        "removed",
        "restarted",
        "migrated",
        "rebuilt",
        "side_by_side_staged",
        "rolled_back",
        "blocked"
      ]
    },
    "proof_state_class": {
      "type": "string",
      "enum": [
        "verified",
        "present_unverified",
        "not_checked_here",
        "missing",
        "revoked",
        "superseded",
        "blocked_by_policy",
        "failed",
        "not_applicable"
      ]
    },
    "signed_update_verification_state": {
      "type": "string",
      "enum": [
        "verified",
        "present_unverified",
        "missing",
        "revoked",
        "superseded",
        "blocked_by_policy",
        "failed",
        "stale_blocking",
        "not_checked"
      ]
    },
    "impact_forecast_class": {
      "type": "string",
      "enum": [
        "no_known_extension_impact",
        "compatible_with_warning",
        "uncertified_row",
        "migration_required",
        "blocked_by_policy",
        "rollback_ready_path_available"
      ]
    },
    "migration_task_class": {
      "type": "string",
      "enum": [
        "migration_scan_required",
        "backup_before_migrate",
        "extension_bridge_repair",
        "extension_sdk_range_update",
        "package_lockfile_refresh",
        "package_runtime_floor_update",
        "profile_schema_migration",
        "cache_rebuild",
        "policy_acknowledgement",
        "admin_approval_required",
        "rollback_checkpoint_verify"
      ]
    },
    "task_timing_class": {
      "type": "string",
      "enum": [
        "before_apply",
        "before_restart",
        "after_restart",
        "before_next_update",
        "manual_review_only"
      ]
    },
    "automation_class": {
      "type": "string",
      "enum": [
        "automatic",
        "assistant_available",
        "manual_steps_required",
        "admin_action_required",
        "blocked"
      ]
    },
    "restart_required_class": {
      "type": "string",
      "enum": [
        "no_restart_required",
        "window_reload_required",
        "desktop_restart_required",
        "helper_restart_required",
        "remote_agent_restart_required",
        "os_restart_required",
        "restart_blocked_until_migration",
        "restart_blocked_by_policy",
        "unknown_restart_impact"
      ]
    },
    "rollback_visibility_class": {
      "type": "string",
      "enum": [
        "rollback_ready_before_apply",
        "rollback_ready_after_apply_until_cleanup",
        "rollback_ready_emergency_path",
        "rollback_requires_manual_review",
        "rollback_blocked",
        "rollback_not_applicable",
        "rollback_unknown_blocking"
      ]
    },
    "rollback_path_class": {
      "type": "string",
      "enum": [
        "previous_build",
        "last_known_good",
        "lts_floor",
        "admin_pinned_target",
        "repair_transaction",
        "migration_journal",
        "backup_snapshot",
        "support_packet",
        "manual_review_ticket",
        "portable_extract_replace_self_contained",
        "break_glass_repin"
      ]
    },
    "install_profile_transition_class": {
      "type": "string",
      "enum": [
        "upgrade_in_place",
        "staged_side_by_side",
        "side_by_side_import_required",
        "portable_extract_replace",
        "managed_fleet_rollout",
        "revert_to_last_known_good",
        "break_glass_channel_switch",
        "review_only_no_apply"
      ]
    },
    "local_state_safety_class": {
      "type": "string",
      "enum": [
        "local_profiles_preserved",
        "cache_rebuild_only",
        "checkpoint_created_before_apply",
        "migration_writes_local_state",
        "state_roots_separate",
        "policy_blocks_state_change",
        "unknown_requires_review"
      ]
    },
    "emergency_action_class": {
      "type": "string",
      "enum": [
        "none",
        "rollback",
        "repin",
        "revoke",
        "yank",
        "mirror_only_emergency",
        "break_glass_channel_switch"
      ]
    },
    "evidence_freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "current_with_waiver",
        "stale_blocking",
        "stale_non_blocking",
        "missing_blocking",
        "not_applicable"
      ]
    },
    "claim_language_class": {
      "type": "string",
      "enum": [
        "current_evidence_only",
        "warning_scoped",
        "stale_evidence_downgraded",
        "waiver_scoped",
        "blocked_no_claim",
        "not_applicable"
      ]
    },
    "final_gate_class": {
      "type": "string",
      "enum": [
        "apply_allowed",
        "restart_allowed",
        "warning_requires_acknowledgement",
        "migration_required_before_restart",
        "side_by_side_stage_only",
        "blocked_by_policy",
        "blocked_by_verification",
        "rollback_ready_emergency",
        "review_only_no_apply"
      ]
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "update_manifest_ref",
        "release_candidate_card_ref",
        "release_center_event_refs",
        "release_note_refs",
        "what_is_new_refs",
        "compatibility_report_refs",
        "certification_delta_refs",
        "migration_session_refs",
        "support_bundle_refs",
        "policy_decision_refs",
        "install_profile_card_refs"
      ],
      "properties": {
        "update_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "release_candidate_card_ref": { "$ref": "#/$defs/nullable_string" },
        "release_center_event_refs": { "$ref": "#/$defs/ref_array" },
        "release_note_refs": { "$ref": "#/$defs/ref_array" },
        "what_is_new_refs": { "$ref": "#/$defs/ref_array" },
        "compatibility_report_refs": { "$ref": "#/$defs/ref_array" },
        "certification_delta_refs": { "$ref": "#/$defs/ref_array" },
        "migration_session_refs": { "$ref": "#/$defs/ref_array" },
        "support_bundle_refs": { "$ref": "#/$defs/ref_array" },
        "policy_decision_refs": { "$ref": "#/$defs/ref_array" },
        "install_profile_card_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "support_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_window_class",
        "starts_at",
        "ends_at",
        "policy_ref",
        "support_note"
      ],
      "properties": {
        "support_window_class": { "$ref": "#/$defs/support_window_class" },
        "starts_at": { "$ref": "#/$defs/nullable_utc_datetime" },
        "ends_at": { "$ref": "#/$defs/nullable_utc_datetime" },
        "policy_ref": { "$ref": "#/$defs/nullable_string" },
        "support_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "install_update_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version_label",
        "channel_class",
        "release_stage_class",
        "support_window",
        "exact_build_identity_refs",
        "install_profile_refs",
        "rollout_ring_ref",
        "local_state_safety_class",
        "state_summary"
      ],
      "properties": {
        "version_label": { "$ref": "#/$defs/non_empty_string" },
        "channel_class": { "$ref": "#/$defs/release_channel_class" },
        "release_stage_class": { "$ref": "#/$defs/release_stage_class" },
        "support_window": { "$ref": "#/$defs/support_window" },
        "exact_build_identity_refs": { "$ref": "#/$defs/non_empty_ref_array" },
        "install_profile_refs": { "$ref": "#/$defs/ref_array" },
        "rollout_ring_ref": { "$ref": "#/$defs/nullable_string" },
        "local_state_safety_class": { "$ref": "#/$defs/local_state_safety_class" },
        "state_summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "proof_layer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_state_class",
        "evidence_refs",
        "checked_at",
        "limitation_note"
      ],
      "properties": {
        "proof_state_class": { "$ref": "#/$defs/proof_state_class" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "checked_at": { "$ref": "#/$defs/nullable_utc_datetime" },
        "limitation_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "update_verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signed_update_verification_state",
        "digest",
        "signature",
        "platform_trust",
        "provenance",
        "metadata_freshness",
        "revocation",
        "mirror_or_import_receipt",
        "policy_gate_refs",
        "verification_summary"
      ],
      "properties": {
        "signed_update_verification_state": { "$ref": "#/$defs/signed_update_verification_state" },
        "digest": { "$ref": "#/$defs/proof_layer" },
        "signature": { "$ref": "#/$defs/proof_layer" },
        "platform_trust": { "$ref": "#/$defs/proof_layer" },
        "provenance": { "$ref": "#/$defs/proof_layer" },
        "metadata_freshness": { "$ref": "#/$defs/proof_layer" },
        "revocation": { "$ref": "#/$defs/proof_layer" },
        "mirror_or_import_receipt": { "$ref": "#/$defs/proof_layer" },
        "policy_gate_refs": { "$ref": "#/$defs/ref_array" },
        "verification_summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "affected_artifact_family": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_family_class",
        "artifact_ref",
        "effect_class",
        "rollback_atom_member",
        "restart_relevant",
        "support_scope_note"
      ],
      "properties": {
        "artifact_family_class": { "$ref": "#/$defs/artifact_family_class" },
        "artifact_ref": { "$ref": "#/$defs/non_empty_string" },
        "effect_class": { "$ref": "#/$defs/artifact_effect_class" },
        "rollback_atom_member": { "type": "boolean" },
        "restart_relevant": { "type": "boolean" },
        "support_scope_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "forecast_class_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_known_extension_impact",
        "compatible_with_warning",
        "uncertified_row",
        "migration_required",
        "blocked_by_policy",
        "rollback_ready_path_available"
      ],
      "properties": {
        "no_known_extension_impact": { "type": "integer", "minimum": 0 },
        "compatible_with_warning": { "type": "integer", "minimum": 0 },
        "uncertified_row": { "type": "integer", "minimum": 0 },
        "migration_required": { "type": "integer", "minimum": 0 },
        "blocked_by_policy": { "type": "integer", "minimum": 0 },
        "rollback_ready_path_available": { "type": "integer", "minimum": 0 }
      }
    },
    "impact_forecast_rollup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worst_forecast_class",
        "forecast_refs",
        "forecast_class_counts",
        "evidence_freshness_class",
        "latest_evidence_at",
        "forecast_summary",
        "no_overclaim_note"
      ],
      "properties": {
        "worst_forecast_class": { "$ref": "#/$defs/impact_forecast_class" },
        "forecast_refs": { "$ref": "#/$defs/ref_array" },
        "forecast_class_counts": { "$ref": "#/$defs/forecast_class_counts" },
        "evidence_freshness_class": { "$ref": "#/$defs/evidence_freshness_class" },
        "latest_evidence_at": { "$ref": "#/$defs/nullable_utc_datetime" },
        "forecast_summary": { "$ref": "#/$defs/non_empty_string" },
        "no_overclaim_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "migration_task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "task_class",
        "task_timing_class",
        "automation_class",
        "scope_ref",
        "trigger_ref",
        "blocks_restart",
        "backup_or_checkpoint_refs",
        "undo_or_rollback_note",
        "evidence_refs",
        "summary"
      ],
      "properties": {
        "task_id": { "$ref": "#/$defs/non_empty_string" },
        "task_class": { "$ref": "#/$defs/migration_task_class" },
        "task_timing_class": { "$ref": "#/$defs/task_timing_class" },
        "automation_class": { "$ref": "#/$defs/automation_class" },
        "scope_ref": { "$ref": "#/$defs/non_empty_string" },
        "trigger_ref": { "$ref": "#/$defs/non_empty_string" },
        "blocks_restart": { "type": "boolean" },
        "backup_or_checkpoint_refs": { "$ref": "#/$defs/ref_array" },
        "undo_or_rollback_note": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" },
        "summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "restart_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "restart_required_class",
        "restart_blocker_refs",
        "user_visible_effect",
        "state_preserved_note",
        "evidence_refs"
      ],
      "properties": {
        "restart_required_class": { "$ref": "#/$defs/restart_required_class" },
        "restart_blocker_refs": { "$ref": "#/$defs/ref_array" },
        "user_visible_effect": { "$ref": "#/$defs/non_empty_string" },
        "state_preserved_note": { "$ref": "#/$defs/non_empty_string" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "rollback_visibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rollback_visibility_class",
        "rollback_path_class",
        "rollback_path_ref",
        "last_known_good_ref",
        "rollback_manifest_ref",
        "checkpoint_refs",
        "retained_until",
        "unsupported_limits",
        "support_export_refs",
        "rollback_summary"
      ],
      "properties": {
        "rollback_visibility_class": { "$ref": "#/$defs/rollback_visibility_class" },
        "rollback_path_class": { "$ref": "#/$defs/rollback_path_class" },
        "rollback_path_ref": { "$ref": "#/$defs/nullable_string" },
        "last_known_good_ref": { "$ref": "#/$defs/nullable_string" },
        "rollback_manifest_ref": { "$ref": "#/$defs/nullable_string" },
        "checkpoint_refs": { "$ref": "#/$defs/ref_array" },
        "retained_until": { "$ref": "#/$defs/nullable_utc_datetime" },
        "unsupported_limits": { "$ref": "#/$defs/non_empty_string" },
        "support_export_refs": { "$ref": "#/$defs/ref_array" },
        "rollback_summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "support_and_compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_window_change_class",
        "end_of_support_risk_class",
        "compatibility_window_risk_class",
        "compatibility_report_refs",
        "certified_archetype_delta_refs",
        "migration_guidance_refs",
        "retained_support_note",
        "compatibility_summary"
      ],
      "properties": {
        "support_window_change_class": { "$ref": "#/$defs/support_window_change_class" },
        "end_of_support_risk_class": { "$ref": "#/$defs/end_of_support_risk_class" },
        "compatibility_window_risk_class": { "$ref": "#/$defs/compatibility_window_risk_class" },
        "compatibility_report_refs": { "$ref": "#/$defs/ref_array" },
        "certified_archetype_delta_refs": { "$ref": "#/$defs/ref_array" },
        "migration_guidance_refs": { "$ref": "#/$defs/ref_array" },
        "retained_support_note": { "$ref": "#/$defs/non_empty_string" },
        "compatibility_summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "side_by_side_and_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "install_profile_transition_class",
        "source_install_profile_refs",
        "target_install_profile_refs",
        "side_by_side_pair_ref",
        "state_root_isolation_refs",
        "import_decision_ref",
        "handler_ownership_note",
        "portable_or_managed_restrictions",
        "profile_summary"
      ],
      "properties": {
        "install_profile_transition_class": { "$ref": "#/$defs/install_profile_transition_class" },
        "source_install_profile_refs": { "$ref": "#/$defs/ref_array" },
        "target_install_profile_refs": { "$ref": "#/$defs/ref_array" },
        "side_by_side_pair_ref": { "$ref": "#/$defs/nullable_string" },
        "state_root_isolation_refs": { "$ref": "#/$defs/ref_array" },
        "import_decision_ref": { "$ref": "#/$defs/nullable_string" },
        "handler_ownership_note": { "$ref": "#/$defs/non_empty_string" },
        "portable_or_managed_restrictions": { "$ref": "#/$defs/non_empty_string" },
        "profile_summary": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "emergency_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active",
        "emergency_action_class",
        "approval_refs",
        "reason_refs",
        "break_glass_event_refs",
        "reconciliation_target_ref",
        "followup_refs",
        "local_state_safety_statement"
      ],
      "properties": {
        "active": { "type": "boolean" },
        "emergency_action_class": { "$ref": "#/$defs/emergency_action_class" },
        "approval_refs": { "$ref": "#/$defs/ref_array" },
        "reason_refs": { "$ref": "#/$defs/ref_array" },
        "break_glass_event_refs": { "$ref": "#/$defs/ref_array" },
        "reconciliation_target_ref": { "$ref": "#/$defs/nullable_string" },
        "followup_refs": { "$ref": "#/$defs/ref_array" },
        "local_state_safety_statement": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "parity_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_note_refs",
        "what_is_new_refs",
        "version_bump_row_refs",
        "archetype_delta_refs",
        "certification_delta_refs",
        "evidence_freshness_class",
        "local_state_safety_language_class",
        "claim_language_class",
        "no_overclaim_note"
      ],
      "properties": {
        "release_note_refs": { "$ref": "#/$defs/ref_array" },
        "what_is_new_refs": { "$ref": "#/$defs/ref_array" },
        "version_bump_row_refs": { "$ref": "#/$defs/ref_array" },
        "archetype_delta_refs": { "$ref": "#/$defs/ref_array" },
        "certification_delta_refs": { "$ref": "#/$defs/ref_array" },
        "evidence_freshness_class": { "$ref": "#/$defs/evidence_freshness_class" },
        "local_state_safety_language_class": { "$ref": "#/$defs/local_state_safety_class" },
        "claim_language_class": { "$ref": "#/$defs/claim_language_class" },
        "no_overclaim_note": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "final_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "final_gate_class",
        "blocking_reason_refs",
        "allowed_action_refs",
        "review_summary"
      ],
      "properties": {
        "final_gate_class": { "$ref": "#/$defs/final_gate_class" },
        "blocking_reason_refs": { "$ref": "#/$defs/ref_array" },
        "allowed_action_refs": { "$ref": "#/$defs/ref_array" },
        "review_summary": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "review_state_class": { "const": "policy_blocked" }
        },
        "required": ["review_state_class"]
      },
      "then": {
        "properties": {
          "final_gate": {
            "properties": {
              "final_gate_class": { "const": "blocked_by_policy" }
            },
            "required": ["final_gate_class"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "review_state_class": { "const": "migration_required_before_restart" }
        },
        "required": ["review_state_class"]
      },
      "then": {
        "properties": {
          "restart": {
            "properties": {
              "restart_required_class": { "const": "restart_blocked_until_migration" }
            },
            "required": ["restart_required_class"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "review_state_class": { "const": "rollback_ready_emergency" }
        },
        "required": ["review_state_class"]
      },
      "then": {
        "properties": {
          "emergency_path": {
            "properties": {
              "active": { "const": true }
            },
            "required": ["active"]
          }
        }
      }
    }
  ]
}
