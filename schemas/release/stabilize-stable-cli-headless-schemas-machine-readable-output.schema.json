{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StabilizeStableCliHeadlessSchemasMachineReadableOutput",
  "description": "Stabilization register for stable CLI/headless schemas, machine-readable output, and support/export compatibility promises.",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "register_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "lifecycle_labels",
    "kinds",
    "states",
    "gap_reasons",
    "actions",
    "launch_cutline",
    "release_blocking_surface_refs",
    "rules",
    "rows",
    "summary",
    "publication"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "record_kind": {
      "type": "string",
      "const": "cli_headless_schema_machine_readable_output_stabilize"
    },
    "register_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "overview_page": {
      "type": "string"
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "claim_manifest_ref": {
      "type": "string"
    },
    "lifecycle_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "lts",
          "stable",
          "beta",
          "preview",
          "withdrawn"
        ]
      }
    },
    "kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "cli_command_surface",
          "headless_output_schema",
          "machine_readable_format",
          "support_export_compatibility"
        ]
      }
    },
    "states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "finalized_stable",
          "finalized_on_waiver",
          "narrowed_unbacked",
          "narrowed_claim_narrowed",
          "narrowed_stale",
          "narrowed_waiver_expired",
          "narrowed_evidence_incomplete",
          "narrowed_schema_breaking"
        ]
      }
    },
    "gap_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "claim_label_narrowed",
          "surface_capability_absent",
          "evidence_incomplete",
          "schema_breaking_change",
          "output_format_unstable",
          "machine_readable_schema_missing",
          "support_export_compat_breached",
          "proof_packet_freshness_breached",
          "waiver_expired",
          "owner_signoff_missing"
        ]
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "hold_publication",
          "narrow_label",
          "refresh_proof_packet",
          "recapture_evidence",
          "request_owner_signoff"
        ]
      }
    },
    "launch_cutline": {
      "type": "object",
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": {
          "type": "string",
          "const": "stable"
        },
        "above_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        }
      }
    },
    "release_blocking_surface_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "title",
          "trigger_reason",
          "applies_to_labels",
          "default_action",
          "blocks_publication",
          "rationale"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "trigger_reason": {
            "type": "string"
          },
          "applies_to_labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "default_action": {
            "type": "string"
          },
          "blocks_publication": {
            "type": "boolean"
          },
          "rationale": {
            "type": "string"
          }
        }
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entry_id",
          "kind",
          "surface_ref",
          "surface_summary",
          "release_blocking",
          "claim_ref",
          "claim_label",
          "effective_label",
          "state",
          "active_gap_reasons",
          "proof_packet",
          "owner_signoff",
          "waiver",
          "schema_detail",
          "output_detail",
          "compat_detail"
        ],
        "properties": {
          "entry_id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "surface_ref": {
            "type": "string"
          },
          "surface_summary": {
            "type": "string"
          },
          "release_blocking": {
            "type": "boolean"
          },
          "claim_ref": {
            "type": "string"
          },
          "claim_label": {
            "type": "string"
          },
          "effective_label": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "active_gap_reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "proof_packet": {
            "type": "object",
            "required": [
              "packet_id",
              "packet_ref",
              "proof_index_ref",
              "freshness_slo",
              "slo_state"
            ],
            "properties": {
              "packet_id": {
                "type": "string"
              },
              "packet_ref": {
                "type": "string"
              },
              "proof_index_ref": {
                "type": "string"
              },
              "captured_at": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "freshness_slo": {
                "type": "object",
                "required": [
                  "target_max_age_days",
                  "warn_within_days",
                  "slo_register_ref"
                ],
                "properties": {
                  "target_max_age_days": {
                    "type": "integer"
                  },
                  "warn_within_days": {
                    "type": "integer"
                  },
                  "slo_register_ref": {
                    "type": "string"
                  }
                }
              },
              "slo_state": {
                "type": "string",
                "enum": [
                  "current",
                  "due_for_refresh",
                  "breached",
                  "missing"
                ]
              },
              "evidence_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "owner_signoff": {
            "type": "object",
            "required": [
              "owner_ref",
              "signed_off"
            ],
            "properties": {
              "owner_ref": {
                "type": "string"
              },
              "signed_off": {
                "type": "boolean"
              },
              "signed_at": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "waiver": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "waiver_ref",
              "expires_at",
              "reason"
            ],
            "properties": {
              "waiver_ref": {
                "type": "string"
              },
              "expires_at": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            }
          },
          "schema_detail": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "command_surface_version",
              "stable_commands",
              "stable_flags",
              "schema_doc_url"
            ],
            "properties": {
              "command_surface_version": {
                "type": "string"
              },
              "stable_commands": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "stable_flags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "schema_doc_url": {
                "type": "string"
              }
            }
          },
          "output_detail": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "output_format",
              "schema_version",
              "schema_doc_url",
              "stable_since"
            ],
            "properties": {
              "output_format": {
                "type": "string"
              },
              "schema_version": {
                "type": "string"
              },
              "schema_doc_url": {
                "type": "string"
              },
              "stable_since": {
                "type": "string"
              }
            }
          },
          "compat_detail": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "compat_promise",
              "supported_export_versions",
              "rollback_checkpoint_url"
            ],
            "properties": {
              "compat_promise": {
                "type": "string"
              },
              "supported_export_versions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "rollback_checkpoint_url": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total_entries",
        "total_claims",
        "entries_finalized_stable",
        "entries_narrowed_below_cutline",
        "entries_on_active_waiver",
        "release_blocking_total",
        "release_blocking_finalized_stable",
        "release_blocking_narrowed",
        "cli_command_surface_entries",
        "headless_output_schema_entries",
        "machine_readable_format_entries",
        "support_export_compatibility_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_gap_reasons",
        "rules_firing"
      ],
      "properties": {
        "total_entries": {
          "type": "integer"
        },
        "total_claims": {
          "type": "integer"
        },
        "entries_finalized_stable": {
          "type": "integer"
        },
        "entries_narrowed_below_cutline": {
          "type": "integer"
        },
        "entries_on_active_waiver": {
          "type": "integer"
        },
        "release_blocking_total": {
          "type": "integer"
        },
        "release_blocking_finalized_stable": {
          "type": "integer"
        },
        "release_blocking_narrowed": {
          "type": "integer"
        },
        "cli_command_surface_entries": {
          "type": "integer"
        },
        "headless_output_schema_entries": {
          "type": "integer"
        },
        "machine_readable_format_entries": {
          "type": "integer"
        },
        "support_export_compatibility_entries": {
          "type": "integer"
        },
        "packets_current": {
          "type": "integer"
        },
        "packets_due_for_refresh": {
          "type": "integer"
        },
        "packets_breached": {
          "type": "integer"
        },
        "packets_missing": {
          "type": "integer"
        },
        "total_active_gap_reasons": {
          "type": "integer"
        },
        "rules_firing": {
          "type": "integer"
        }
      }
    },
    "publication": {
      "type": "object",
      "required": [
        "decision",
        "blocking_rule_ids",
        "blocking_entry_ids",
        "recorded_at"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "proceed",
            "hold"
          ]
        },
        "blocking_rule_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking_entry_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recorded_at": {
          "type": "string"
        }
      }
    }
  }
}
