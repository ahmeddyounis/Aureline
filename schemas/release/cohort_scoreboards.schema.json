{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/cohort_scoreboards.schema.json",
  "title": "Aureline cohort scoreboards packet",
  "description": "Canonical, machine-readable packet that finalizes the design-partner, certified-archetype, and stable-cohort scoreboards. Each row binds a public claim to a scoreboard packet, metrics, and a required human signoff loop, and narrows below Stable unless it carries current proof, passing metrics, an unexpired waiver when relied on, complete signoffs, and a backing public claim at or above the cutline.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "packet_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "stable_proof_index_ref",
    "lifecycle_labels",
    "scoreboard_lanes",
    "scoreboard_states",
    "gap_reasons",
    "scoreboard_actions",
    "launch_cutline",
    "release_blocking_scoreboard_refs",
    "rules",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "cohort_scoreboards" },
    "packet_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "stable_proof_index_ref": { "$ref": "#/$defs/non_empty_string" },
    "lifecycle_labels": {
      "type": "array",
      "items": { "$ref": "#/$defs/lifecycle_label" },
      "minItems": 1,
      "uniqueItems": true
    },
    "scoreboard_lanes": {
      "type": "array",
      "items": { "$ref": "#/$defs/scoreboard_lane" },
      "minItems": 1,
      "uniqueItems": true
    },
    "scoreboard_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/scoreboard_state" },
      "minItems": 1,
      "uniqueItems": true
    },
    "gap_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap_reason" },
      "minItems": 1,
      "uniqueItems": true
    },
    "scoreboard_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/scoreboard_action" },
      "minItems": 1,
      "uniqueItems": true
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_scoreboard_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/rule" },
      "minItems": 1
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/row" },
      "minItems": 1
    },
    "publication": { "$ref": "#/$defs/publication" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "nullable_date": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "format": "date" }
      ]
    },
    "lifecycle_label": {
      "type": "string",
      "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
    },
    "scoreboard_lane": {
      "type": "string",
      "enum": ["design_partner", "certified_archetype", "stable_cohort"]
    },
    "scoreboard_state": {
      "type": "string",
      "enum": [
        "signed_off",
        "signed_off_on_waiver",
        "narrowed_unbacked",
        "narrowed_claim_narrowed",
        "narrowed_stale",
        "narrowed_waiver_expired"
      ]
    },
    "gap_reason": {
      "type": "string",
      "enum": [
        "claim_label_narrowed",
        "scoreboard_evidence_incomplete",
        "scoreboard_packet_freshness_breached",
        "scoreboard_packet_missing",
        "waiver_expired",
        "owner_signoff_missing",
        "required_signoff_missing",
        "score_below_threshold"
      ]
    },
    "scoreboard_action": {
      "type": "string",
      "enum": [
        "hold_publication",
        "narrow_scoreboard_label",
        "refresh_scoreboard_packet",
        "complete_signoff_loop",
        "recapture_scoreboard_evidence"
      ]
    },
    "freshness_slo_state": {
      "type": "string",
      "enum": ["current", "due_for_refresh", "breached", "missing"]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutline_level",
        "above_cutline_levels",
        "below_cutline_levels",
        "description"
      ],
      "properties": {
        "cutline_level": { "type": "string", "const": "stable" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" }
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" }
        },
        "description": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "title",
        "trigger_reason",
        "applies_to_labels",
        "default_action",
        "blocks_publication",
        "rationale"
      ],
      "properties": {
        "rule_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "trigger_reason": { "$ref": "#/$defs/gap_reason" },
        "applies_to_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" },
          "minItems": 1
        },
        "default_action": { "$ref": "#/$defs/scoreboard_action" },
        "blocks_publication": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "freshness_slo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
      "properties": {
        "target_max_age_days": { "type": "integer", "minimum": 1 },
        "warn_within_days": { "type": "integer", "minimum": 0 },
        "slo_register_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "scoreboard_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_ref",
        "proof_index_ref",
        "captured_at",
        "freshness_slo",
        "slo_state",
        "evidence_refs"
      ],
      "properties": {
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "proof_index_ref": { "$ref": "#/$defs/non_empty_string" },
        "captured_at": { "$ref": "#/$defs/nullable_date" },
        "freshness_slo": { "$ref": "#/$defs/freshness_slo" },
        "slo_state": { "$ref": "#/$defs/freshness_slo_state" },
        "evidence_refs": { "$ref": "#/$defs/ref_array" }
      }
    },
    "waiver": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["waiver_ref", "expires_at", "reason"],
          "properties": {
            "waiver_ref": { "$ref": "#/$defs/non_empty_string" },
            "expires_at": { "type": "string", "format": "date" },
            "reason": { "$ref": "#/$defs/non_empty_string" }
          }
        }
      ]
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_ref", "signed_off", "signed_at"],
      "properties": {
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "signed_off": { "type": "boolean" },
        "signed_at": { "$ref": "#/$defs/nullable_date" }
      }
    },
    "required_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role_ref", "signed_off"],
      "properties": {
        "role_ref": { "$ref": "#/$defs/non_empty_string" },
        "signed_off": { "type": "boolean" },
        "signer_ref": { "$ref": "#/$defs/nullable_date" },
        "signed_at": { "$ref": "#/$defs/nullable_date" }
      }
    },
    "signoff_loop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["loop_id", "cadence", "packet_ref", "required_signoffs"],
      "properties": {
        "loop_id": { "$ref": "#/$defs/non_empty_string" },
        "cadence": { "$ref": "#/$defs/non_empty_string" },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "required_signoffs": {
          "type": "array",
          "items": { "$ref": "#/$defs/required_signoff" },
          "minItems": 1
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric_id", "title", "unit", "threshold", "measured", "measurement_ref"],
      "properties": {
        "metric_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "unit": { "$ref": "#/$defs/non_empty_string" },
        "threshold": { "type": "integer" },
        "measured": {
          "oneOf": [{ "type": "null" }, { "type": "integer" }]
        },
        "measurement_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scoreboard_id",
        "title",
        "lane",
        "subject_family",
        "release_blocking",
        "claim_ref",
        "claim_label",
        "scoreboard_state",
        "scoreboard_packet",
        "owner_signoff",
        "signoff_loop",
        "metrics",
        "active_gap_reasons",
        "effective_label",
        "publication_destinations",
        "rationale"
      ],
      "properties": {
        "scoreboard_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "lane": { "$ref": "#/$defs/scoreboard_lane" },
        "subject_family": { "$ref": "#/$defs/non_empty_string" },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "$ref": "#/$defs/non_empty_string" },
        "claim_label": { "$ref": "#/$defs/lifecycle_label" },
        "scoreboard_state": { "$ref": "#/$defs/scoreboard_state" },
        "scoreboard_packet": { "$ref": "#/$defs/scoreboard_packet" },
        "waiver": { "$ref": "#/$defs/waiver" },
        "owner_signoff": { "$ref": "#/$defs/owner_signoff" },
        "signoff_loop": { "$ref": "#/$defs/signoff_loop" },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/metric" },
          "minItems": 1
        },
        "active_gap_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/gap_reason" },
          "uniqueItems": true
        },
        "effective_label": { "$ref": "#/$defs/lifecycle_label" },
        "publication_destinations": { "$ref": "#/$defs/ref_array" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_gate",
        "decision",
        "blocking_rule_ids",
        "blocking_scoreboard_ids",
        "rationale"
      ],
      "properties": {
        "publication_gate": { "$ref": "#/$defs/non_empty_string" },
        "decision": { "type": "string", "enum": ["proceed", "hold"] },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "blocking_scoreboard_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows",
        "total_claims",
        "rows_holding_stable",
        "rows_narrowed_below_cutline",
        "release_blocking_total",
        "release_blocking_holding_stable",
        "release_blocking_narrowed",
        "rows_on_active_waiver",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "complete_signoff_loops",
        "incomplete_signoff_loops",
        "total_metrics",
        "metrics_passing",
        "metrics_failing",
        "total_active_gap_reasons",
        "rules_firing"
      ],
      "properties": {
        "total_rows": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "rows_holding_stable": { "type": "integer", "minimum": 0 },
        "rows_narrowed_below_cutline": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_holding_stable": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "rows_on_active_waiver": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "complete_signoff_loops": { "type": "integer", "minimum": 0 },
        "incomplete_signoff_loops": { "type": "integer", "minimum": 0 },
        "total_metrics": { "type": "integer", "minimum": 0 },
        "metrics_passing": { "type": "integer", "minimum": 0 },
        "metrics_failing": { "type": "integer", "minimum": 0 },
        "total_active_gap_reasons": { "type": "integer", "minimum": 0 },
        "rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
