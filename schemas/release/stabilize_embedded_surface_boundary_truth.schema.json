{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/release/stabilize_embedded_surface_boundary_truth.schema.json",
  "title": "Aureline embedded-surface boundary truth register",
  "description": "Canonical, machine-readable register binding each embedded surface family (docs/help panes, extension webviews, marketplace/account pages, service dashboards, auth confirmation surfaces) to the stable claim manifest entry whose lifecycle label it backs, a packet-freshness SLO, a boundary state, owner/origin chrome snapshots, native-approval boundary snapshots, browser-fallback posture snapshots, auth-handoff snapshots (for auth rows), and truth rules that gate publication. Each surface may carry the claim's label or narrow below it but never wider. The register is metadata-only: typed states and opaque refs, never raw artifacts, logs, signatures, or credentials.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "register_id",
    "status",
    "overview_page",
    "as_of",
    "claim_manifest_ref",
    "embedded_boundary_alpha_ref",
    "browser_fallback_alpha_ref",
    "lifecycle_labels",
    "surface_kinds",
    "boundary_states",
    "truth_states",
    "gap_reasons",
    "truth_actions",
    "launch_cutline",
    "release_blocking_surface_refs",
    "truth_rules",
    "rows",
    "publication",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "record_kind": { "type": "string", "const": "embedded_surface_boundary_truth" },
    "register_id": { "$ref": "#/$defs/non_empty_string" },
    "status": { "$ref": "#/$defs/non_empty_string" },
    "overview_page": { "$ref": "#/$defs/non_empty_string" },
    "as_of": { "type": "string", "format": "date" },
    "claim_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
    "embedded_boundary_alpha_ref": { "$ref": "#/$defs/non_empty_string" },
    "browser_fallback_alpha_ref": { "$ref": "#/$defs/non_empty_string" },
    "lifecycle_labels": {
      "type": "array",
      "items": { "$ref": "#/$defs/lifecycle_label" },
      "minItems": 1,
      "uniqueItems": true
    },
    "surface_kinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_kind" },
      "minItems": 1,
      "uniqueItems": true
    },
    "boundary_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/boundary_state" },
      "minItems": 1,
      "uniqueItems": true
    },
    "truth_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/truth_state" },
      "minItems": 1,
      "uniqueItems": true
    },
    "gap_reasons": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap_reason" },
      "minItems": 1,
      "uniqueItems": true
    },
    "truth_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/truth_action" },
      "minItems": 1,
      "uniqueItems": true
    },
    "launch_cutline": { "$ref": "#/$defs/launch_cutline" },
    "release_blocking_surface_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "truth_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/truth_rule" },
      "minItems": 1
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/truth_row" },
      "minItems": 1
    },
    "publication": { "$ref": "#/$defs/truth_publication_record" },
    "summary": { "$ref": "#/$defs/truth_summary" }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_label": {
      "type": "string",
      "enum": ["lts", "stable", "beta", "preview", "withdrawn"]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "embedded_docs_help",
        "extension_hosted_surface",
        "embedded_marketplace_or_account",
        "embedded_service_dashboard",
        "embedded_auth_confirmation"
      ]
    },
    "boundary_state": {
      "type": "string",
      "enum": [
        "live_verified",
        "stale_snapshot",
        "policy_blocked",
        "certificate_failed",
        "cross_origin_limited",
        "offline_snapshot",
        "external_open_only"
      ]
    },
    "truth_state": {
      "type": "string",
      "enum": [
        "current",
        "current_on_waiver",
        "narrowed_unbacked",
        "narrowed_claim_narrowed",
        "narrowed_stale",
        "narrowed_waiver_expired",
        "narrowed_contract_mismatch"
      ]
    },
    "gap_reason": {
      "type": "string",
      "enum": [
        "claim_label_narrowed",
        "proof_packet_freshness_breached",
        "proof_packet_missing",
        "evidence_incomplete",
        "waiver_expired",
        "owner_signoff_missing",
        "claim_manifest_mismatch",
        "owner_origin_chrome_missing",
        "native_approval_boundary_leaked",
        "system_browser_default_missing",
        "browser_fallback_unavailable"
      ]
    },
    "truth_action": {
      "type": "string",
      "enum": [
        "hold_publication",
        "narrow_label",
        "refresh_proof_packet",
        "recapture_evidence",
        "request_owner_signoff",
        "retest_claim_alignment"
      ]
    },
    "launch_cutline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cutline_level", "above_cutline_levels", "below_cutline_levels", "description"],
      "properties": {
        "cutline_level": { "$ref": "#/$defs/lifecycle_label" },
        "above_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" },
          "minItems": 1
        },
        "below_cutline_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" },
          "minItems": 1
        },
        "description": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "truth_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "title", "trigger_reason", "applies_to_labels", "default_action", "blocks_publication", "rationale"],
      "properties": {
        "rule_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "trigger_reason": { "$ref": "#/$defs/gap_reason" },
        "applies_to_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycle_label" },
          "minItems": 1
        },
        "default_action": { "$ref": "#/$defs/truth_action" },
        "blocks_publication": { "type": "boolean" },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "truth_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id", "title", "surface_kind", "surface_ref", "surface_summary",
        "release_blocking", "claim_ref", "claim_label", "truth_state", "proof_packet",
        "boundary_state", "browser_fallback", "native_approval",
        "owner_signoff", "active_gap_reasons", "published_label", "publication_destinations", "rationale"
      ],
      "properties": {
        "entry_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "surface_ref": { "$ref": "#/$defs/non_empty_string" },
        "surface_summary": { "$ref": "#/$defs/non_empty_string" },
        "release_blocking": { "type": "boolean" },
        "claim_ref": { "$ref": "#/$defs/non_empty_string" },
        "claim_label": { "$ref": "#/$defs/lifecycle_label" },
        "truth_state": { "$ref": "#/$defs/truth_state" },
        "proof_packet": { "$ref": "#/$defs/proof_packet" },
        "boundary_state": { "$ref": "#/$defs/boundary_state" },
        "source_truth": { "$ref": "#/$defs/source_truth_snapshot" },
        "browser_fallback": { "$ref": "#/$defs/browser_fallback_snapshot" },
        "native_approval": { "$ref": "#/$defs/native_approval_snapshot" },
        "auth_handoff": { "$ref": "#/$defs/auth_handoff_snapshot" },
        "waiver": { "$ref": "#/$defs/qualification_waiver" },
        "owner_signoff": { "$ref": "#/$defs/owner_signoff" },
        "active_gap_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/gap_reason" }
        },
        "published_label": { "$ref": "#/$defs/lifecycle_label" },
        "publication_destinations": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "proof_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_id", "packet_ref", "proof_index_ref", "captured_at", "freshness_slo", "slo_state", "evidence_refs"],
      "properties": {
        "packet_id": { "$ref": "#/$defs/non_empty_string" },
        "packet_ref": { "$ref": "#/$defs/non_empty_string" },
        "proof_index_ref": { "$ref": "#/$defs/non_empty_string" },
        "captured_at": { "type": ["string", "null"], "format": "date" },
        "freshness_slo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_max_age_days", "warn_within_days", "slo_register_ref"],
          "properties": {
            "target_max_age_days": { "type": "integer", "minimum": 1 },
            "warn_within_days": { "type": "integer", "minimum": 0 },
            "slo_register_ref": { "$ref": "#/$defs/non_empty_string" }
          }
        },
        "slo_state": {
          "type": "string",
          "enum": ["current", "due_for_refresh", "breached", "missing"]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "source_truth_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_class", "version_match_state", "freshness_class", "snapshot_age_label"],
      "properties": {
        "source_class": { "$ref": "#/$defs/non_empty_string" },
        "version_match_state": { "$ref": "#/$defs/non_empty_string" },
        "freshness_class": { "$ref": "#/$defs/non_empty_string" },
        "snapshot_age_label": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "browser_fallback_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["posture_class", "fallback_target_class", "open_in_browser_available", "preserves_object_identity"],
      "properties": {
        "posture_class": { "$ref": "#/$defs/non_empty_string" },
        "fallback_target_class": { "$ref": "#/$defs/non_empty_string" },
        "open_in_browser_available": { "type": "boolean" },
        "preserves_object_identity": { "type": "boolean" }
      }
    },
    "native_approval_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "high_risk_approval_host_owned",
        "destructive_confirmation_host_owned",
        "trust_elevation_host_owned",
        "update_verification_host_owned",
        "ai_apply_review_host_owned"
      ],
      "properties": {
        "high_risk_approval_host_owned": { "type": "boolean" },
        "destructive_confirmation_host_owned": { "type": "boolean" },
        "trust_elevation_host_owned": { "type": "boolean" },
        "update_verification_host_owned": { "type": "boolean" },
        "ai_apply_review_host_owned": { "type": "boolean" }
      }
    },
    "auth_handoff_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system_browser_default", "return_path_labeled", "exact_target_preserved", "exception_disclosed"],
      "properties": {
        "system_browser_default": { "type": "boolean" },
        "return_path_labeled": { "type": "boolean" },
        "exact_target_preserved": { "type": "boolean" },
        "exception_disclosed": { "type": "boolean" }
      }
    },
    "qualification_waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["waiver_ref", "expires_at", "reason"],
      "properties": {
        "waiver_ref": { "$ref": "#/$defs/non_empty_string" },
        "expires_at": { "type": "string", "format": "date" },
        "reason": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "owner_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_ref", "signed_off", "signed_at"],
      "properties": {
        "owner_ref": { "$ref": "#/$defs/non_empty_string" },
        "signed_off": { "type": "boolean" },
        "signed_at": { "type": ["string", "null"], "format": "date" }
      }
    },
    "truth_publication_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publication_gate", "decision", "blocking_rule_ids", "blocking_entry_ids", "rationale"],
      "properties": {
        "publication_gate": { "$ref": "#/$defs/non_empty_string" },
        "decision": {
          "type": "string",
          "enum": ["hold", "proceed"]
        },
        "blocking_rule_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "blocking_entry_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "rationale": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "truth_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_entries",
        "total_claims",
        "entries_published_stable",
        "entries_narrowed_below_cutline",
        "entries_on_active_waiver",
        "release_blocking_total",
        "release_blocking_published_stable",
        "release_blocking_narrowed",
        "docs_help_entries",
        "extension_entries",
        "marketplace_entries",
        "service_dashboard_entries",
        "auth_confirmation_entries",
        "packets_current",
        "packets_due_for_refresh",
        "packets_breached",
        "packets_missing",
        "total_active_gap_reasons",
        "truth_rules_firing"
      ],
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "entries_published_stable": { "type": "integer", "minimum": 0 },
        "entries_narrowed_below_cutline": { "type": "integer", "minimum": 0 },
        "entries_on_active_waiver": { "type": "integer", "minimum": 0 },
        "release_blocking_total": { "type": "integer", "minimum": 0 },
        "release_blocking_published_stable": { "type": "integer", "minimum": 0 },
        "release_blocking_narrowed": { "type": "integer", "minimum": 0 },
        "docs_help_entries": { "type": "integer", "minimum": 0 },
        "extension_entries": { "type": "integer", "minimum": 0 },
        "marketplace_entries": { "type": "integer", "minimum": 0 },
        "service_dashboard_entries": { "type": "integer", "minimum": 0 },
        "auth_confirmation_entries": { "type": "integer", "minimum": 0 },
        "packets_current": { "type": "integer", "minimum": 0 },
        "packets_due_for_refresh": { "type": "integer", "minimum": 0 },
        "packets_breached": { "type": "integer", "minimum": 0 },
        "packets_missing": { "type": "integer", "minimum": 0 },
        "total_active_gap_reasons": { "type": "integer", "minimum": 0 },
        "truth_rules_firing": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
