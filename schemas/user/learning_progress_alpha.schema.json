{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/user/learning_progress_alpha.schema.json",
  "title": "Aureline user-owned learning progress alpha snapshot",
  "description": "Portable alpha snapshot for learning-mode profile state and per-step progress. The snapshot is user-owned state: it can tune tip intensity, jargon level, AI explanation posture, mutation guardrails, bookmarks, and dismissals without changing trust boundaries or data ownership. Progress rows preserve completed, dismissed, resumed, deferred, and blocked states with explicit local-only or sync posture; repo packs, classroom artifacts, and telemetry-style readers get no default access.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "snapshot_id",
    "generated_at",
    "profile_state",
    "progress_entries",
    "dismissal_entries",
    "bookmark_entries",
    "export_posture",
    "support_export_projection"
  ],
  "properties": {
    "record_kind": { "const": "learning_progress_alpha_snapshot_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "snapshot_id": { "$ref": "#/$defs/opaque_id" },
    "generated_at": { "$ref": "#/$defs/timestamp_or_fixture" },
    "profile_state": { "$ref": "#/$defs/profile_state" },
    "progress_entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/progress_entry" }
    },
    "dismissal_entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/dismissal_entry" }
    },
    "bookmark_entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/bookmark_entry" }
    },
    "export_posture": { "$ref": "#/$defs/export_posture" },
    "support_export_projection": { "$ref": "#/$defs/support_export_projection" }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "timestamp_or_fixture": {
      "type": "string",
      "minLength": 1
    },
    "sync_posture_class": {
      "type": "string",
      "enum": ["local_only", "portable_profile", "sync_opt_in", "sync_blocked_by_policy"]
    },
    "progress_state_class": {
      "type": "string",
      "enum": ["not_started", "in_progress", "completed", "dismissed", "resumed", "deferred", "blocked_by_package_state"]
    },
    "tip_intensity_class": {
      "type": "string",
      "enum": ["off", "quiet", "standard", "high_touch"]
    },
    "jargon_level_class": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced", "expert"]
    },
    "ai_explanation_posture": {
      "type": "string",
      "enum": ["disabled", "explain_only_cited", "explain_and_prepare_preview", "policy_disabled"]
    },
    "mutation_guardrail_class": {
      "type": "string",
      "enum": ["explain_only", "preview_required", "approval_required", "blocked_until_trust"]
    },
    "export_class": {
      "type": "string",
      "enum": ["portable_profile_metadata", "support_bundle_redacted", "local_only_not_exported", "policy_blocked"]
    },
    "profile_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_ref",
        "profile_scope",
        "tip_intensity_class",
        "jargon_level_class",
        "ai_explanation_posture",
        "mutation_guardrail_class",
        "data_ownership_class",
        "trust_boundary_change_allowed",
        "bookmarks_enabled",
        "dismissals_enabled"
      ],
      "properties": {
        "profile_ref": { "$ref": "#/$defs/opaque_id" },
        "profile_scope": { "$ref": "#/$defs/opaque_id" },
        "tip_intensity_class": { "$ref": "#/$defs/tip_intensity_class" },
        "jargon_level_class": { "$ref": "#/$defs/jargon_level_class" },
        "ai_explanation_posture": { "$ref": "#/$defs/ai_explanation_posture" },
        "mutation_guardrail_class": { "$ref": "#/$defs/mutation_guardrail_class" },
        "data_ownership_class": { "const": "user_owned_portable_profile" },
        "trust_boundary_change_allowed": { "type": "boolean", "const": false },
        "bookmarks_enabled": { "type": "boolean" },
        "dismissals_enabled": { "type": "boolean" }
      }
    },
    "progress_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "package_ref",
        "tour_ref",
        "step_ref",
        "progress_state_class",
        "resume_ref",
        "sync_posture_class",
        "export_class",
        "local_only_or_sync_posture_explicit",
        "repo_pack_read_default",
        "classroom_read_default",
        "telemetry_read_default",
        "exact_reopen_ref",
        "preserves_command_help_anchor"
      ],
      "properties": {
        "entry_id": { "$ref": "#/$defs/opaque_id" },
        "package_ref": { "$ref": "#/$defs/opaque_id" },
        "tour_ref": { "$ref": "#/$defs/opaque_id" },
        "step_ref": { "$ref": "#/$defs/opaque_id" },
        "progress_state_class": { "$ref": "#/$defs/progress_state_class" },
        "resume_ref": { "$ref": "#/$defs/opaque_id" },
        "sync_posture_class": { "$ref": "#/$defs/sync_posture_class" },
        "export_class": { "$ref": "#/$defs/export_class" },
        "local_only_or_sync_posture_explicit": { "type": "boolean", "const": true },
        "repo_pack_read_default": { "type": "boolean", "const": false },
        "classroom_read_default": { "type": "boolean", "const": false },
        "telemetry_read_default": { "type": "boolean", "const": false },
        "exact_reopen_ref": { "$ref": "#/$defs/opaque_id" },
        "preserves_command_help_anchor": { "type": "boolean", "const": true }
      }
    },
    "dismissal_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dismissal_id", "step_ref", "sync_posture_class", "reversible_from_learning_digest"],
      "properties": {
        "dismissal_id": { "$ref": "#/$defs/opaque_id" },
        "step_ref": { "$ref": "#/$defs/opaque_id" },
        "sync_posture_class": { "$ref": "#/$defs/sync_posture_class" },
        "reversible_from_learning_digest": { "type": "boolean", "const": true }
      }
    },
    "bookmark_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bookmark_id", "step_ref", "sync_posture_class", "exact_reopen_ref"],
      "properties": {
        "bookmark_id": { "$ref": "#/$defs/opaque_id" },
        "step_ref": { "$ref": "#/$defs/opaque_id" },
        "sync_posture_class": { "$ref": "#/$defs/sync_posture_class" },
        "exact_reopen_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "export_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "portable_profile_exportable",
        "support_bundle_exportable_redacted",
        "raw_step_body_exported",
        "raw_pack_body_exported",
        "user_can_delete_or_reset"
      ],
      "properties": {
        "portable_profile_exportable": { "type": "boolean" },
        "support_bundle_exportable_redacted": { "type": "boolean" },
        "raw_step_body_exported": { "type": "boolean", "const": false },
        "raw_pack_body_exported": { "type": "boolean", "const": false },
        "user_can_delete_or_reset": { "type": "boolean", "const": true }
      }
    },
    "support_export_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projection_id", "row_refs", "raw_profile_body_exported"],
      "properties": {
        "projection_id": { "$ref": "#/$defs/opaque_id" },
        "row_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "raw_profile_body_exported": { "type": "boolean", "const": false }
      }
    }
  }
}
