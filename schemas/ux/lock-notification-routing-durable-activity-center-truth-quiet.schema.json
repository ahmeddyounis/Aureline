{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/lock-notification-routing-durable-activity-center-truth-quiet.schema.json",
  "title": "Aureline durable-attention lock record",
  "description": "Boundary schema for notification_attention_lock_record, the single governed record the activity center, status bar, command palette, dock/taskbar badge, native OS notifications, companion fanout, diagnostics, support exports, Help/About, and docs all read for one claimed-stable durable attention class. It is minted by crates/aureline-shell/src/notification_attention_stable as a genuine projection of the live attention stack (crates/aureline-shell/src/notifications and crates/aureline-shell/src/attention_router) and binds, for one canonical attention identity: (1) one-envelope routing where every resolved surface keeps the same reopen target; (2) a durable activity-center job row that survives look-away, sleep/resume, and restart; (3) coherent quiet-hours / admin suppression that never erases the durable object, reopen target, or audit trail; (4) a summary-first, privacy-safe OS / lock-screen alert; (5) interruptibility so no launch-critical flow is toast-only and repeats coalesce by root cause; (6) deterministic exact-target reopen to the authoritative object or a truthful placeholder with no side effects from the notification surface; (7) acknowledge/resolve/dismiss/snooze/mute as distinct lifecycle transitions; (8) badge counts derived from durable item state; (9) a public claim ceiling no row may exceed; (10) a derived stable-claim verdict that narrows a row missing a pillar or on a below-Stable surface below Stable with a named reason; (11) recovery/route/accessibility parity across the activity center, command palette, status bar, and a menu command in normal/high-contrast/zoomed layouts; and (12) availability without an account or managed services. Minted refs are opaque aureline://<class>/<id> durable-object refs; upstream projection refs keep their source scheme.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "attention_class",
    "attention_class_label",
    "surface_lifecycle_marker",
    "title",
    "summary",
    "routing",
    "durable_job",
    "quiet_hours",
    "privacy",
    "interruptibility",
    "reopen",
    "lifecycle",
    "badge",
    "claim_ceiling",
    "stable_qualification",
    "recovery_routes",
    "surfaces",
    "routes",
    "accessibility",
    "available_without_account",
    "available_without_managed_services",
    "honesty_marker_present",
    "upstream",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": { "const": "notification_attention_lock_record" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "notice": { "type": "string", "minLength": 1 },
    "shared_contract_ref": { "const": "shell:notification_attention_lock_stable:v1" },
    "record_id": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "minLength": 1 },
    "attention_class": { "type": "string", "minLength": 1 },
    "attention_class_label": { "type": "string", "minLength": 1 },
    "surface_lifecycle_marker": { "$ref": "#/$defs/lifecycleMarker" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "routing": { "$ref": "#/$defs/routingDisclosure" },
    "durable_job": { "$ref": "#/$defs/durableJobRow" },
    "quiet_hours": { "$ref": "#/$defs/quietHoursPolicy" },
    "privacy": { "$ref": "#/$defs/privacySafeAlert" },
    "interruptibility": { "$ref": "#/$defs/interruptibility" },
    "reopen": { "$ref": "#/$defs/exactTargetReopen" },
    "lifecycle": { "$ref": "#/$defs/lifecycleSemantics" },
    "badge": { "$ref": "#/$defs/badgeDisclosure" },
    "claim_ceiling": { "$ref": "#/$defs/claimCeiling" },
    "stable_qualification": { "$ref": "#/$defs/stableQualification" },
    "recovery_routes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/recoveryRoute" }
    },
    "surfaces": { "$ref": "#/$defs/surfaceParity" },
    "routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/entryRoute" }
    },
    "accessibility": { "$ref": "#/$defs/accessibility" },
    "available_without_account": { "type": "boolean" },
    "available_without_managed_services": { "type": "boolean" },
    "honesty_marker_present": { "type": "boolean" },
    "upstream": { "$ref": "#/$defs/upstreamRefs" },
    "diagnostics_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "support_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } },
    "narrative_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } }
  },
  "$defs": {
    "canonicalRef": {
      "type": "string",
      "pattern": "^aureline://(?!home/|dashboard/|landing/|index/|overview/|start/|root/)[^/]+/.+$"
    },
    "presentRef": { "type": "string", "minLength": 1 },
    "lifecycleMarker": { "enum": ["preview", "beta", "stable"] },
    "claimClass": { "enum": ["stable", "beta", "preview", "not_claimed"] },
    "narrowingReason": {
      "enum": [
        "durable_attention_not_proven",
        "quiet_hours_not_coherent",
        "os_alert_not_privacy_safe",
        "badge_count_not_class_truthful",
        "exact_target_reopen_not_deterministic",
        "surface_not_yet_stable"
      ]
    },
    "routeSurface": {
      "enum": ["activity_center", "command_palette", "status_bar", "menu_command"]
    },
    "layoutMode": { "enum": ["normal", "high_contrast", "zoomed"] },
    "recoveryRole": { "enum": ["primary", "recovery", "secondary"] },
    "sourceSubsystem": {
      "enum": [
        "editor", "terminal", "review_and_diff", "palette_and_search",
        "install_update_attach", "ai_apply", "collaboration", "provider_bearing",
        "docs_help_service_health", "support_export", "build_system", "test_runner",
        "debug_session", "task_runner", "indexer", "vfs_save", "sync_mirror",
        "notebook_kernel", "remote_agent", "extension_host", "workspace_trust",
        "policy_resolver", "admin_policy", "secret_broker", "runtime_power_manager",
        "shell"
      ]
    },
    "severityClass": {
      "enum": ["info", "success", "warning", "degraded", "error", "blocking", "critical"]
    },
    "privacyClass": {
      "enum": ["summary_safe", "workspace_sensitive", "security_critical", "managed_sensitive"]
    },
    "privacyPayloadClass": {
      "enum": [
        "lock_screen_safe_generic", "lock_screen_safe_scoped", "in_product_only",
        "redacted_metadata_only", "policy_forbidden_on_lock_screen"
      ]
    },
    "redactionClass": {
      "enum": [
        "metadata_safe_default", "operator_only_restricted",
        "internal_support_restricted", "signing_evidence_only"
      ]
    },
    "dedupeKeyScheme": {
      "enum": [
        "canonical_event_id", "canonical_object_target_plus_event_class",
        "grouped_burst_id", "subsystem_plus_object_plus_phase",
        "cross_client_canonical_event_id"
      ]
    },
    "reopenTargetKind": {
      "enum": [
        "canonical_object", "canonical_route", "review_context", "durable_activity_row",
        "digest_group", "placeholder_announced", "denied_requires_revalidation"
      ]
    },
    "quietHoursMode": {
      "enum": [
        "mode_none", "mode_quiet_hours_user", "mode_do_not_disturb_user",
        "mode_focus_mode_user", "mode_presentation", "mode_screen_share",
        "mode_privacy_mode", "mode_reduced_attention_policy", "mode_power_saver_runtime",
        "mode_admin_suppression"
      ]
    },
    "badgeClass": {
      "enum": [
        "needs_review", "failed_runs", "mentions", "security_notices", "session_requests",
        "offline_publish_pending", "durable_running_count", "held_or_suppressed_count",
        "completion_unread"
      ]
    },
    "lifecycleActionKind": {
      "enum": ["dismiss", "acknowledge", "snooze", "mute", "clear", "resolve", "suppress"]
    },
    "lifecycleBadgeEffect": {
      "enum": ["leaves_active_badge", "clears_active_badge", "moves_to_held_count"]
    },
    "lifecycleRetentionEffect": {
      "enum": ["retains_active_row", "retains_history_only", "retains_resolved_record"]
    },
    "lifecycleExportEffect": {
      "enum": [
        "exported_as_active", "exported_as_dismissed", "exported_as_acknowledged",
        "exported_as_snoozed", "exported_as_muted", "exported_as_cleared",
        "exported_as_resolved"
      ]
    },
    "routingDisclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "envelope_id_ref", "route_outcome_id_ref", "canonical_event_id", "source_subsystem",
        "severity_class", "dedupe_key_scheme", "dedupe_key_ref", "resolved_surface_count",
        "visible_surface_count", "routes_from_one_envelope"
      ],
      "properties": {
        "envelope_id_ref": { "$ref": "#/$defs/presentRef" },
        "route_outcome_id_ref": { "$ref": "#/$defs/presentRef" },
        "canonical_event_id": { "$ref": "#/$defs/presentRef" },
        "source_subsystem": { "$ref": "#/$defs/sourceSubsystem" },
        "severity_class": { "$ref": "#/$defs/severityClass" },
        "dedupe_key_scheme": { "$ref": "#/$defs/dedupeKeyScheme" },
        "dedupe_key_ref": { "type": "string", "minLength": 1 },
        "resolved_surface_count": { "type": "integer", "minimum": 0 },
        "visible_surface_count": { "type": "integer", "minimum": 0 },
        "routes_from_one_envelope": { "type": "boolean" }
      }
    },
    "durableJobRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "job_id", "durable_object_ref", "actor_subsystem", "label", "current_phase",
        "cancelable", "retriable", "resolvable", "open_details_available",
        "durable_surface_present", "survives_lookaway", "survives_sleep_resume",
        "survives_restart_restore"
      ],
      "properties": {
        "job_id": { "type": "string", "minLength": 1 },
        "durable_object_ref": { "$ref": "#/$defs/canonicalRef" },
        "actor_subsystem": { "$ref": "#/$defs/sourceSubsystem" },
        "label": { "type": "string", "minLength": 1 },
        "current_phase": { "type": "string", "minLength": 1 },
        "cancelable": { "type": "boolean" },
        "retriable": { "type": "boolean" },
        "resolvable": { "type": "boolean" },
        "open_details_available": { "type": "boolean" },
        "durable_surface_present": { "type": "boolean" },
        "survives_lookaway": { "type": "boolean" },
        "survives_sleep_resume": { "type": "boolean" },
        "survives_restart_restore": { "type": "boolean" }
      }
    },
    "quietHoursPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_modes", "suppression_preserves_durable_object",
        "suppression_preserves_reopen_target", "suppression_audit_trail_present",
        "coherent_across_in_app_os_companion"
      ],
      "properties": {
        "active_modes": { "type": "array", "items": { "$ref": "#/$defs/quietHoursMode" } },
        "suppression_preserves_durable_object": { "type": "boolean" },
        "suppression_preserves_reopen_target": { "type": "boolean" },
        "suppression_audit_trail_present": { "type": "boolean" },
        "coherent_across_in_app_os_companion": { "type": "boolean" }
      }
    },
    "privacySafeAlert": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "privacy_class", "privacy_payload_class", "redaction_class",
        "lock_screen_safe_by_default", "summary_first", "exposes_restricted_detail",
        "companion_summary_only"
      ],
      "properties": {
        "privacy_class": { "$ref": "#/$defs/privacyClass" },
        "privacy_payload_class": { "$ref": "#/$defs/privacyPayloadClass" },
        "redaction_class": { "$ref": "#/$defs/redactionClass" },
        "lock_screen_safe_by_default": { "type": "boolean" },
        "summary_first": { "type": "boolean" },
        "exposes_restricted_detail": { "const": false },
        "companion_summary_only": { "type": "boolean" }
      }
    },
    "interruptibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_toast_only_truth", "durable_surface_present",
        "repeated_failures_coalesced_by_root_cause", "no_badge_or_toast_spam"
      ],
      "properties": {
        "no_toast_only_truth": { "type": "boolean" },
        "durable_surface_present": { "type": "boolean" },
        "repeated_failures_coalesced_by_root_cause": { "type": "boolean" },
        "no_badge_or_toast_spam": { "type": "boolean" }
      }
    },
    "exactTargetReopen": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reopen_target_kind", "reopen_target_ref", "resolves_to_exact_target",
        "degrades_to_truthful_placeholder", "no_generic_home_reopen",
        "all_routes_preserve_reopen_target", "no_side_effects_from_notification_surface"
      ],
      "properties": {
        "reopen_target_kind": { "$ref": "#/$defs/reopenTargetKind" },
        "reopen_target_ref": { "$ref": "#/$defs/presentRef" },
        "resolves_to_exact_target": { "type": "boolean" },
        "degrades_to_truthful_placeholder": { "type": "boolean" },
        "no_generic_home_reopen": { "type": "boolean" },
        "all_routes_preserve_reopen_target": { "type": "boolean" },
        "no_side_effects_from_notification_surface": { "type": "boolean" }
      }
    },
    "lifecycleAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_kind", "badge_effect", "retention_effect", "export_effect",
        "mutates_source_object", "requires_resume_condition", "requires_muted_class",
        "durable_history_preserved"
      ],
      "properties": {
        "action_kind": { "$ref": "#/$defs/lifecycleActionKind" },
        "badge_effect": { "$ref": "#/$defs/lifecycleBadgeEffect" },
        "retention_effect": { "$ref": "#/$defs/lifecycleRetentionEffect" },
        "export_effect": { "$ref": "#/$defs/lifecycleExportEffect" },
        "mutates_source_object": { "type": "boolean" },
        "requires_resume_condition": { "type": "boolean" },
        "requires_muted_class": { "type": "boolean" },
        "durable_history_preserved": { "type": "boolean" }
      }
    },
    "lifecycleSemantics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available_actions", "required_verbs_present", "verbs_distinct"],
      "properties": {
        "available_actions": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/lifecycleAction" }
        },
        "required_verbs_present": { "type": "boolean" },
        "verbs_distinct": { "type": "boolean" }
      }
    },
    "badgeDisclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "badge_class", "active_count", "held_or_suppressed_count",
        "durable_history_preserved", "derived_from_durable_item_state",
        "privacy_safe_summary_label"
      ],
      "properties": {
        "badge_class": { "$ref": "#/$defs/badgeClass" },
        "active_count": { "type": "integer", "minimum": 0 },
        "held_or_suppressed_count": { "type": "integer", "minimum": 0 },
        "durable_history_preserved": { "type": "boolean" },
        "derived_from_durable_item_state": { "type": "boolean" },
        "privacy_safe_summary_label": { "type": "string", "minLength": 1 }
      }
    },
    "claimCeiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asserts_durable_attention", "asserts_quiet_hours_coherent", "asserts_privacy_safe",
        "asserts_badge_count_class_truthful", "asserts_exact_target_reopen"
      ],
      "properties": {
        "asserts_durable_attention": { "type": "boolean" },
        "asserts_quiet_hours_coherent": { "type": "boolean" },
        "asserts_privacy_safe": { "type": "boolean" },
        "asserts_badge_count_class_truthful": { "type": "boolean" },
        "asserts_exact_target_reopen": { "type": "boolean" }
      }
    },
    "stableQualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_class", "qualifies_stable", "narrowing_reasons"],
      "properties": {
        "claim_class": { "$ref": "#/$defs/claimClass" },
        "qualifies_stable": { "type": "boolean" },
        "narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowingReason" }
        }
      }
    },
    "recoveryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_label", "action_role", "keyboard_reachable"],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_label": { "type": "string", "minLength": 1 },
        "action_role": { "$ref": "#/$defs/recoveryRole" },
        "keyboard_reachable": { "type": "boolean" }
      }
    },
    "surfaceParity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activity_center_row_id", "status_bar_item_id", "command_palette_command_id",
        "recovery_action_ids", "reopen_surfaces", "parity_holds"
      ],
      "properties": {
        "activity_center_row_id": { "type": "string", "minLength": 1 },
        "status_bar_item_id": { "type": "string", "minLength": 1 },
        "command_palette_command_id": { "type": "string", "minLength": 1 },
        "recovery_action_ids": { "type": "array", "items": { "type": "string" } },
        "reopen_surfaces": { "type": "array", "items": { "type": "string" } },
        "parity_holds": { "type": "boolean" }
      }
    },
    "entryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "route_ref", "keyboard_reachable", "activates_same_item"],
      "properties": {
        "surface": { "$ref": "#/$defs/routeSurface" },
        "route_ref": { "$ref": "#/$defs/canonicalRef" },
        "keyboard_reachable": { "type": "boolean" },
        "activates_same_item": { "type": "boolean" }
      }
    },
    "layoutModeDisclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "row_narration_available", "recovery_affordances_reachable"],
      "properties": {
        "mode": { "$ref": "#/$defs/layoutMode" },
        "row_narration_available": { "type": "boolean" },
        "recovery_affordances_reachable": { "type": "boolean" }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_order_index", "tab_stop_count", "row_narration", "action_labels", "layout_modes"
      ],
      "properties": {
        "focus_order_index": { "type": "integer", "minimum": 0 },
        "tab_stop_count": { "type": "integer", "minimum": 0 },
        "row_narration": { "type": "string", "minLength": 1 },
        "action_labels": { "type": "array", "items": { "type": "string" } },
        "layout_modes": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/layoutModeDisclosure" }
        }
      }
    },
    "upstreamRefs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["corpus_packet_ref", "case_id_ref", "route_outcome_id_ref", "envelope_id_ref"],
      "properties": {
        "corpus_packet_ref": { "$ref": "#/$defs/presentRef" },
        "case_id_ref": { "$ref": "#/$defs/presentRef" },
        "route_outcome_id_ref": { "$ref": "#/$defs/presentRef" },
        "envelope_id_ref": { "$ref": "#/$defs/presentRef" }
      }
    }
  }
}
