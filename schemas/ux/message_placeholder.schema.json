{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/message_placeholder.schema.json",
  "title": "Aureline translation-safe message placeholder record",
  "description": "Boundary schema for the message_placeholder_record frozen in docs/copy/translation_safe_content_ops_contract.md. The record is the copy-operations gate for placeholder-rich, launch-critical, docs/help, onboarding, export/report, screenshot/demo, trust/policy/recovery, and evidence-bearing messages before translation, pseudoloc, screenshot capture, demo captioning, export, support tooling, or late-copy review can consume them. Localized prose is never a business-logic key, analytics key, automation route, policy id, support-tool selector, export id, or docs anchor; machine identity lives in locale-neutral refs and typed placeholders.",
  "type": "object",
  "$ref": "#/$defs/message_placeholder_record",
  "$defs": {
    "message_placeholder_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for the translation-safe message placeholder family. Additive vocabulary growth bumps this const; repurposing an existing value is breaking."
    },
    "record_kind": {
      "type": "string",
      "const": "message_placeholder_record"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Stable opaque id safe for schema validation, fixtures, support packets, and review artifacts. Raw paths, raw URLs, secrets, raw prompt text, raw user identifiers, and raw private workspace content do not belong here."
    },
    "reviewable_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "description": "Review-safe human text for source-language templates, notes, labels, and repair actions."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "nullable_timestamp": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/timestamp" }
      ]
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "bcp47_locale_tag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/non_empty_string" },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        }
      }
    },
    "content_ops_surface_family": {
      "type": "string",
      "enum": [
        "launch_critical_string",
        "docs_help_snippet",
        "onboarding_surface",
        "export_report_heading",
        "screenshot_demo_caption",
        "trust_policy_recovery_text",
        "evidence_bearing_content",
        "pseudoloc_test_string"
      ]
    },
    "launch_criticality": {
      "type": "string",
      "enum": [
        "launch_blocking",
        "release_bearing",
        "review_required",
        "advisory"
      ]
    },
    "placeholder_kind": {
      "type": "string",
      "enum": [
        "count",
        "command_id_token",
        "analytics_key_token",
        "automation_route_token",
        "support_field_token",
        "policy_id_token",
        "file_path_token",
        "host_or_url_token",
        "tenant_or_account_token",
        "flag_or_argument_token",
        "version_or_build_token",
        "locale_tag_token",
        "glossary_term_token",
        "enumerated_state_token",
        "evidence_ref_token",
        "freeform_string"
      ]
    },
    "token_fidelity_class": {
      "type": "string",
      "enum": [
        "literal_unchanged",
        "controlled_vocabulary_translation",
        "locale_formatted_value",
        "human_translatable"
      ]
    },
    "placeholder_reorder_policy": {
      "type": "string",
      "enum": [
        "may_reorder_by_id",
        "fixed_order_required",
        "plural_select_controls_order"
      ]
    },
    "translator_note_class": {
      "type": "string",
      "enum": [
        "placeholder_semantics",
        "pluralization_rule",
        "mixed_direction_token",
        "glossary_term_ref",
        "screenshot_or_demo_caption_governance",
        "source_language_escape_hatch",
        "pseudoloc_truncation_review",
        "late_copy_controlled_delta",
        "policy_or_legal_review_required",
        "evidence_source_review"
      ]
    },
    "translator_note_preservation_state": {
      "type": "string",
      "enum": [
        "preserved",
        "rewritten_with_review",
        "not_required",
        "dropped_denied"
      ]
    },
    "glossary_term_role": {
      "type": "string",
      "enum": [
        "state_label",
        "policy_label",
        "trust_boundary",
        "recovery_action",
        "evidence_term",
        "support_term",
        "export_heading",
        "caption_term",
        "command_term"
      ]
    },
    "glossary_stability_class": {
      "type": "string",
      "enum": [
        "canonical_term",
        "approved_alias",
        "deprecated_alias",
        "pending_review"
      ]
    },
    "caption_asset_kind": {
      "type": "string",
      "enum": [
        "screenshot",
        "demo_recording",
        "presentation_overlay",
        "voiceover_script",
        "subtitle_track",
        "alt_text"
      ]
    },
    "caption_sync_state": {
      "type": "string",
      "enum": [
        "synced_with_source_messages",
        "source_messages_changed_pending_caption_review",
        "caption_changed_pending_product_review",
        "stale_denied"
      ]
    },
    "source_language_escape_hatch_class": {
      "type": "string",
      "enum": [
        "inline_source_language_toggle",
        "command_open_in_source_language",
        "docs_pane_source_language_route",
        "cli_locale_neutral_output_flag",
        "export_in_source_language_for_review",
        "support_packet_source_language_attachment"
      ]
    },
    "fallback_disclosure_state": {
      "type": "string",
      "enum": [
        "not_applicable_authoritative_locale",
        "disclosed_inline",
        "disclosed_in_review_panel",
        "disclosed_in_accessible_description",
        "policy_blocked_with_reason",
        "not_disclosed_denied"
      ]
    },
    "review_gate_kind": {
      "type": "string",
      "enum": [
        "placeholder_semantics",
        "translator_note_preservation",
        "pseudoloc_expansion",
        "truncation_review",
        "source_language_review",
        "glossary_term_review",
        "screenshot_caption_sync",
        "machine_identity_review"
      ]
    },
    "review_gate_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "blocked",
        "not_applicable",
        "pending_review"
      ]
    },
    "downstream_surface_class": {
      "type": "string",
      "enum": [
        "product_ui",
        "docs_help",
        "onboarding",
        "screenshot_or_demo",
        "export_or_report",
        "support_tooling",
        "automation",
        "analytics",
        "locale_pack",
        "accessibility",
        "public_proof"
      ]
    },
    "denial_reason": {
      "type": "string",
      "enum": [
        "content_ops_localized_prose_used_as_machine_identity",
        "content_ops_placeholder_missing_plural_rule",
        "content_ops_placeholder_token_fidelity_violation",
        "content_ops_mixed_direction_token_not_isolated",
        "content_ops_translator_note_dropped",
        "content_ops_glossary_ref_missing",
        "content_ops_screenshot_caption_metadata_missing",
        "content_ops_screenshot_caption_stale",
        "content_ops_source_language_fallback_missing",
        "content_ops_source_language_fallback_not_disclosed",
        "content_ops_pseudoloc_gate_failed",
        "content_ops_truncation_gate_failed",
        "content_ops_late_copy_uncontrolled_after_freeze",
        "content_ops_late_copy_missing_downstream_surface",
        "content_ops_late_copy_missing_verification",
        "content_ops_late_copy_widens_claim_without_source_update"
      ]
    },
    "invariant_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "not_applicable"
      ]
    },
    "placeholder_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "placeholder_id",
        "placeholder_kind",
        "token_fidelity_class",
        "reorder_policy",
        "bidi_isolation_required",
        "translator_note_refs"
      ],
      "properties": {
        "placeholder_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "placeholder_kind": { "$ref": "#/$defs/placeholder_kind" },
        "token_fidelity_class": { "$ref": "#/$defs/token_fidelity_class" },
        "reorder_policy": { "$ref": "#/$defs/placeholder_reorder_policy" },
        "bidi_isolation_required": { "type": "boolean" },
        "plural_rule_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "glossary_term_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "sample_value_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "translator_note_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "technical_token_comment": { "$ref": "#/$defs/reviewable_text" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "placeholder_kind": { "const": "count" } },
            "required": ["placeholder_kind"]
          },
          "then": {
            "required": ["plural_rule_ref"],
            "properties": {
              "plural_rule_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "placeholder_kind": {
                "enum": [
                  "command_id_token",
                  "analytics_key_token",
                  "automation_route_token",
                  "support_field_token",
                  "policy_id_token",
                  "file_path_token",
                  "host_or_url_token",
                  "tenant_or_account_token",
                  "flag_or_argument_token",
                  "version_or_build_token",
                  "locale_tag_token",
                  "evidence_ref_token"
                ]
              }
            },
            "required": ["placeholder_kind"]
          },
          "then": {
            "properties": {
              "token_fidelity_class": { "const": "literal_unchanged" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "placeholder_kind": {
                "enum": [
                  "glossary_term_token",
                  "enumerated_state_token"
                ]
              }
            },
            "required": ["placeholder_kind"]
          },
          "then": {
            "required": ["glossary_term_ref"],
            "properties": {
              "token_fidelity_class": { "const": "controlled_vocabulary_translation" },
              "glossary_term_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        }
      ]
    },
    "translator_note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "note_id",
        "note_class",
        "note_text",
        "required_for_translation",
        "preservation_state"
      ],
      "properties": {
        "note_id": { "$ref": "#/$defs/opaque_id" },
        "note_class": { "$ref": "#/$defs/translator_note_class" },
        "note_text": { "$ref": "#/$defs/reviewable_text" },
        "required_for_translation": { "type": "boolean" },
        "preservation_state": { "$ref": "#/$defs/translator_note_preservation_state" },
        "applies_to_placeholder_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true
        },
        "glossary_term_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "decision_row_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "required_for_translation": { "const": true } },
            "required": ["required_for_translation"]
          },
          "then": {
            "properties": {
              "preservation_state": {
                "enum": [
                  "preserved",
                  "rewritten_with_review"
                ]
              }
            }
          }
        }
      ]
    },
    "glossary_term_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "term_ref",
        "term_role",
        "stability_class",
        "source_anchor_ref"
      ],
      "properties": {
        "term_ref": { "$ref": "#/$defs/opaque_id" },
        "term_role": { "$ref": "#/$defs/glossary_term_role" },
        "stability_class": { "$ref": "#/$defs/glossary_stability_class" },
        "source_anchor_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "caption_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_ref",
        "asset_kind",
        "caption_message_id_ref",
        "source_message_id_refs",
        "captured_surface_ref",
        "capture_build_identity_ref",
        "capture_locale",
        "caption_sync_state",
        "product_and_caption_reviewed_together",
        "governance_ref"
      ],
      "properties": {
        "asset_ref": { "$ref": "#/$defs/opaque_id" },
        "asset_kind": { "$ref": "#/$defs/caption_asset_kind" },
        "caption_message_id_ref": { "$ref": "#/$defs/opaque_id" },
        "source_message_id_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "captured_surface_ref": { "$ref": "#/$defs/opaque_id" },
        "capture_build_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "capture_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "caption_sync_state": { "$ref": "#/$defs/caption_sync_state" },
        "product_and_caption_reviewed_together": { "type": "boolean" },
        "governance_ref": { "$ref": "#/$defs/opaque_id" },
        "alt_text_message_id_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "source_language_fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fallback_required",
        "requested_locale",
        "effective_locale",
        "source_language_locale",
        "fallback_chain",
        "disclosure_state",
        "escape_hatches",
        "review_surface_refs"
      ],
      "properties": {
        "fallback_required": { "type": "boolean" },
        "requested_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "effective_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "source_language_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "fallback_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bcp47_locale_tag" }
        },
        "disclosure_state": { "$ref": "#/$defs/fallback_disclosure_state" },
        "escape_hatches": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_language_escape_hatch_class" },
          "uniqueItems": true
        },
        "policy_block_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "review_surface_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "fallback_required": { "const": true } },
            "required": ["fallback_required"]
          },
          "then": {
            "properties": {
              "escape_hatches": {
                "type": "array",
                "minItems": 1
              },
              "disclosure_state": {
                "enum": [
                  "disclosed_inline",
                  "disclosed_in_review_panel",
                  "disclosed_in_accessible_description",
                  "policy_blocked_with_reason"
                ]
              }
            }
          }
        }
      ]
    },
    "machine_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "localized_prose_used_for_machine_binding",
        "business_logic_key_refs",
        "analytics_key_refs",
        "automation_route_refs",
        "support_field_refs",
        "policy_id_refs",
        "command_id_refs",
        "export_field_refs",
        "docs_anchor_refs"
      ],
      "properties": {
        "localized_prose_used_for_machine_binding": { "const": false },
        "business_logic_key_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "analytics_key_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "automation_route_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "support_field_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "policy_id_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "command_id_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "export_field_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "docs_anchor_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },
    "review_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_kind",
        "gate_status",
        "required_for_launch",
        "owner",
        "checked_at",
        "evidence_ref"
      ],
      "properties": {
        "gate_kind": { "$ref": "#/$defs/review_gate_kind" },
        "gate_status": { "$ref": "#/$defs/review_gate_status" },
        "required_for_launch": { "type": "boolean" },
        "owner": { "$ref": "#/$defs/non_empty_string" },
        "checked_at": { "$ref": "#/$defs/nullable_timestamp" },
        "evidence_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "denial_reason_on_failure": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/denial_reason" }
          ]
        },
        "repair_action": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_text" }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "gate_status": { "const": "failed" } },
            "required": ["gate_status"]
          },
          "then": {
            "required": ["denial_reason_on_failure", "repair_action"],
            "properties": {
              "denial_reason_on_failure": { "$ref": "#/$defs/denial_reason" },
              "repair_action": { "$ref": "#/$defs/reviewable_text" }
            }
          }
        }
      ]
    },
    "downstream_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "surface_ref",
        "affected"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/downstream_surface_class" },
        "surface_ref": { "$ref": "#/$defs/opaque_id" },
        "affected": { "type": "boolean" },
        "impact_summary": { "$ref": "#/$defs/reviewable_text" }
      }
    },
    "invariant_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "localized_prose_never_controls_machine_identity",
        "placeholder_tokens_resolve_by_id_not_position",
        "literal_technical_tokens_preserve_spelling",
        "count_placeholders_declare_plural_rules",
        "mixed_direction_literal_tokens_are_isolated",
        "required_translator_notes_are_preserved",
        "glossary_terms_use_stable_refs",
        "screenshot_captions_bind_to_source_messages",
        "source_language_fallback_is_declared_and_disclosed",
        "launch_critical_copy_passes_pseudoloc_and_truncation_gates",
        "late_copy_after_freeze_has_owner_verification_and_reversal",
        "downstream_surfaces_are_named_before_copy_changes_publish"
      ],
      "properties": {
        "localized_prose_never_controls_machine_identity": { "$ref": "#/$defs/invariant_status" },
        "placeholder_tokens_resolve_by_id_not_position": { "$ref": "#/$defs/invariant_status" },
        "literal_technical_tokens_preserve_spelling": { "$ref": "#/$defs/invariant_status" },
        "count_placeholders_declare_plural_rules": { "$ref": "#/$defs/invariant_status" },
        "mixed_direction_literal_tokens_are_isolated": { "$ref": "#/$defs/invariant_status" },
        "required_translator_notes_are_preserved": { "$ref": "#/$defs/invariant_status" },
        "glossary_terms_use_stable_refs": { "$ref": "#/$defs/invariant_status" },
        "screenshot_captions_bind_to_source_messages": { "$ref": "#/$defs/invariant_status" },
        "source_language_fallback_is_declared_and_disclosed": { "$ref": "#/$defs/invariant_status" },
        "launch_critical_copy_passes_pseudoloc_and_truncation_gates": { "$ref": "#/$defs/invariant_status" },
        "late_copy_after_freeze_has_owner_verification_and_reversal": { "$ref": "#/$defs/invariant_status" },
        "downstream_surfaces_are_named_before_copy_changes_publish": { "$ref": "#/$defs/invariant_status" }
      }
    },
    "conformance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected_conformance",
        "denial_reasons",
        "publication_allowed"
      ],
      "properties": {
        "expected_conformance": {
          "type": "string",
          "enum": [
            "conforming",
            "denied_until_repaired",
            "advisory"
          ]
        },
        "denial_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/denial_reason" },
          "uniqueItems": true
        },
        "publication_allowed": { "type": "boolean" }
      }
    },
    "message_placeholder_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "message_placeholder_schema_version",
        "message_id",
        "surface_family",
        "launch_criticality",
        "source_language_locale",
        "source_template",
        "placeholders",
        "translator_notes",
        "glossary_term_refs",
        "caption_metadata",
        "source_language_fallback",
        "machine_binding",
        "review_gates",
        "downstream_surfaces",
        "invariant_checks",
        "conformance",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "message_placeholder_schema_version": { "$ref": "#/$defs/message_placeholder_schema_version" },
        "message_id": { "$ref": "#/$defs/opaque_id" },
        "surface_family": { "$ref": "#/$defs/content_ops_surface_family" },
        "launch_criticality": { "$ref": "#/$defs/launch_criticality" },
        "source_language_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "source_template": { "$ref": "#/$defs/reviewable_text" },
        "placeholders": {
          "type": "array",
          "items": { "$ref": "#/$defs/placeholder_descriptor" },
          "uniqueItems": true
        },
        "translator_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/translator_note" },
          "uniqueItems": true
        },
        "glossary_term_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/glossary_term_ref" },
          "uniqueItems": true
        },
        "caption_metadata": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/caption_metadata" }
          ]
        },
        "source_language_fallback": { "$ref": "#/$defs/source_language_fallback" },
        "machine_binding": { "$ref": "#/$defs/machine_binding" },
        "review_gates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/review_gate" },
          "uniqueItems": true
        },
        "downstream_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/downstream_surface" },
          "uniqueItems": true
        },
        "invariant_checks": { "$ref": "#/$defs/invariant_checks" },
        "conformance": { "$ref": "#/$defs/conformance" },
        "minted_at": { "$ref": "#/$defs/timestamp" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "placeholders": {
                "minItems": 1
              }
            },
            "required": ["placeholders"]
          },
          "then": {
            "properties": {
              "translator_notes": {
                "type": "array",
                "contains": {
                  "type": "object",
                  "properties": {
                    "note_class": { "const": "placeholder_semantics" }
                  },
                  "required": ["note_class"]
                }
              },
              "review_gates": {
                "type": "array",
                "contains": {
                  "type": "object",
                  "properties": {
                    "gate_kind": { "const": "placeholder_semantics" }
                  },
                  "required": ["gate_kind"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "surface_family": { "const": "screenshot_demo_caption" }
            },
            "required": ["surface_family"]
          },
          "then": {
            "properties": {
              "caption_metadata": { "$ref": "#/$defs/caption_metadata" },
              "translator_notes": {
                "type": "array",
                "contains": {
                  "type": "object",
                  "properties": {
                    "note_class": { "const": "screenshot_or_demo_caption_governance" }
                  },
                  "required": ["note_class"]
                }
              },
              "review_gates": {
                "type": "array",
                "contains": {
                  "type": "object",
                  "properties": {
                    "gate_kind": { "const": "screenshot_caption_sync" }
                  },
                  "required": ["gate_kind"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "surface_family": {
                "enum": [
                  "trust_policy_recovery_text",
                  "evidence_bearing_content",
                  "docs_help_snippet",
                  "onboarding_surface",
                  "export_report_heading"
                ]
              }
            },
            "required": ["surface_family"]
          },
          "then": {
            "properties": {
              "source_language_fallback": {
                "type": "object",
                "properties": {
                  "fallback_required": { "const": true }
                },
                "required": ["fallback_required"]
              },
              "review_gates": {
                "type": "array",
                "contains": {
                  "type": "object",
                  "properties": {
                    "gate_kind": { "const": "source_language_review" }
                  },
                  "required": ["gate_kind"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "launch_criticality": {
                "enum": [
                  "launch_blocking",
                  "release_bearing"
                ]
              }
            },
            "required": ["launch_criticality"]
          },
          "then": {
            "properties": {
              "review_gates": {
                "type": "array",
                "allOf": [
                  {
                    "contains": {
                      "type": "object",
                      "properties": {
                        "gate_kind": { "const": "pseudoloc_expansion" }
                      },
                      "required": ["gate_kind"]
                    }
                  },
                  {
                    "contains": {
                      "type": "object",
                      "properties": {
                        "gate_kind": { "const": "truncation_review" }
                      },
                      "required": ["gate_kind"]
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "placeholders": {
                "contains": {
                  "type": "object",
                  "properties": {
                    "placeholder_kind": {
                      "enum": [
                        "glossary_term_token",
                        "enumerated_state_token"
                      ]
                    }
                  },
                  "required": ["placeholder_kind"]
                }
              }
            },
            "required": ["placeholders"]
          },
          "then": {
            "properties": {
              "glossary_term_refs": {
                "type": "array",
                "minItems": 1
              },
              "review_gates": {
                "type": "array",
                "contains": {
                  "type": "object",
                  "properties": {
                    "gate_kind": { "const": "glossary_term_review" }
                  },
                  "required": ["gate_kind"]
                }
              }
            }
          }
        }
      ]
    }
  }
}
