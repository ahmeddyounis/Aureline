{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/context_notice.schema.json",
  "title": "Aureline contextual notice contract: inline notices, banners, persistence, dismissal, and escalation",
  "description": "Boundary schema for contextual notices frozen in docs/ux/banner_notice_contract.md. The schema defines two record shapes: context_notice_record is one notice instance that names a long-lived condition (policy/trust restriction, quota warning, degraded mode, update required, storage safety, or recovery posture) along with its smallest truthful scope, required disclosure sentences (what_changed, what_still_works), command-backed inspect/repair actions, and dismissal/persistence semantics; context_notice_case_record is a worked contract case that includes one or more input conditions and the expected projected notice set, including banner coalescing rules and \"still visible after dismissal\" expectations. Toasts are not a context-notice surface kind; a toast may only mirror a notice that already has a durable/persistent representation. Raw paths, raw URLs, raw policy bodies, raw provider payloads, secret material, and customer-owned identifiers never cross this boundary; records carry opaque refs, closed vocabularies, timestamps, and privacy-safe labels only. Adding a new notice_class, presentation_kind, scope_kind, persistence_kind, dismissal_policy, or durable_indicator_kind value is additive-minor and bumps context_notice_schema_version; repurposing an existing value is breaking and requires a decision-row update.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/context_notice_record" },
    { "$ref": "#/$defs/context_notice_case_record" }
  ],
  "$defs": {
    "context_notice_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this contextual-notice contract export. Current value is 1."
    },

    "record_kind": {
      "type": "string",
      "enum": ["context_notice_record", "context_notice_case_record"],
      "description": "Discriminator for the concrete payload shape."
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "record_kinds_exercised": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "linked_docs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "description": "Optional worked-example prelude carried on fixtures."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$",
      "description": "Opaque, stable id safe to log, safe on RPC, safe in support bundles, and safe in exports."
    },

    "nullable_opaque_id": {
      "oneOf": [{ "$ref": "#/$defs/opaque_id" }, { "type": "null" }]
    },

    "command_id": {
      "type": "string",
      "pattern": "^cmd:[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "Canonical command id. Must resolve to command descriptors before shipping."
    },

    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "description": "Short privacy-safe label. Must not include raw paths, raw URLs, raw secrets, raw policy text, or customer-owned identifiers."
    },

    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 520,
      "description": "Privacy-safe sentence intended for rendering and export. Must be specific when a more precise statement is knowable."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },

    "notice_class": {
      "type": "string",
      "enum": ["info", "warning", "error", "restricted", "success_long_lived"],
      "description": "Meaning-bearing notice class that governs scope, persistence, and next-action posture."
    },

    "presentation_kind": {
      "type": "string",
      "enum": ["inline_notice", "banner", "review_sheet", "durable_activity_state"],
      "description": "Minimum surface kind required to present the condition."
    },

    "scope_kind": {
      "type": "string",
      "enum": ["pane", "file", "workspace", "account"],
      "description": "Smallest truthful scope kind for the condition."
    },

    "notice_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_kind", "scope_ref", "scope_label"],
      "properties": {
        "scope_kind": { "$ref": "#/$defs/scope_kind" },
        "scope_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "scope_label": { "$ref": "#/$defs/short_label_text" }
      },
      "description": "Scope identity and label for the affected pane/file/workspace/account."
    },

    "persistence_kind": {
      "type": "string",
      "enum": ["until_resolved", "until_scope_exit", "until_time_window", "until_acknowledged"],
      "description": "Persistence expectation. Dismissal does not necessarily resolve the underlying condition."
    },

    "dismissal_policy": {
      "type": "string",
      "enum": [
        "not_dismissible",
        "dismissible_until_resolved",
        "dismissible_until_scope_exit",
        "dismissible_acknowledges_success"
      ],
      "description": "Dismissal policy for the rendered notice."
    },

    "durable_indicator_kind": {
      "type": "string",
      "enum": [
        "status_strip_cue",
        "activity_row",
        "inspector_row",
        "lifecycle_card",
        "status_item_drawer_entry"
      ],
      "description": "Durable indicator kind that remains visible after dismissal when the condition is still active."
    },

    "durable_indicator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["indicator_kind", "indicator_ref", "indicator_label", "open_details_command_id"],
      "properties": {
        "indicator_kind": { "$ref": "#/$defs/durable_indicator_kind" },
        "indicator_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "indicator_label": { "$ref": "#/$defs/short_label_text" },
        "open_details_command_id": { "$ref": "#/$defs/command_id" }
      },
      "description": "Required durable representation for active conditions once the transient/banner instance is dismissed."
    },

    "notice_action_kind": {
      "type": "string",
      "enum": [
        "open_details",
        "inspect_policy_or_trust",
        "inspect_quota",
        "retry_or_reconnect",
        "open_update_flow",
        "open_storage_repair",
        "continue_limited",
        "export_diagnostics",
        "learn_more",
        "no_action_available"
      ],
      "description": "Closed action-kind vocabulary for context notices."
    },

    "notice_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "label_text", "action_kind", "command_id", "target_ref", "safety_sentence"],
      "properties": {
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "label_text": { "$ref": "#/$defs/short_label_text" },
        "action_kind": { "$ref": "#/$defs/notice_action_kind" },
        "command_id": { "$ref": "#/$defs/command_id" },
        "target_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "safety_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "description": "Command-backed action exposed by the notice."
    },

    "coalesce_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coalesce_key", "is_summary_notice", "member_notice_ids"],
      "properties": {
        "coalesce_key": { "$ref": "#/$defs/opaque_id" },
        "is_summary_notice": { "type": "boolean" },
        "member_notice_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      },
      "description": "Coalescing metadata for banner stacking avoidance. Summary notices carry member_notice_ids."
    },

    "context_notice_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "context_notice_schema_version",
        "notice_id",
        "notice_class",
        "presentation_kind",
        "scope",
        "summary_label",
        "what_changed",
        "what_still_works",
        "primary_action",
        "secondary_actions",
        "persistence_kind",
        "dismissal_policy",
        "durable_indicator_after_dismiss",
        "coalesce",
        "first_observed_at",
        "last_updated_at",
        "is_condition_active",
        "narrative_refs"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "context_notice_record" },
        "context_notice_schema_version": { "$ref": "#/$defs/context_notice_schema_version" },
        "notice_id": { "$ref": "#/$defs/opaque_id" },
        "notice_class": { "$ref": "#/$defs/notice_class" },
        "presentation_kind": { "$ref": "#/$defs/presentation_kind" },
        "scope": { "$ref": "#/$defs/notice_scope" },
        "summary_label": { "$ref": "#/$defs/short_label_text" },
        "what_changed": { "$ref": "#/$defs/reviewable_sentence" },
        "what_still_works": { "$ref": "#/$defs/reviewable_sentence" },
        "primary_action": { "$ref": "#/$defs/notice_action" },
        "secondary_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/notice_action" },
          "maxItems": 4
        },
        "persistence_kind": { "$ref": "#/$defs/persistence_kind" },
        "dismissal_policy": { "$ref": "#/$defs/dismissal_policy" },
        "durable_indicator_after_dismiss": { "$ref": "#/$defs/durable_indicator" },
        "coalesce": { "$ref": "#/$defs/coalesce_policy" },
        "first_observed_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "last_updated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "is_condition_active": { "type": "boolean" },
        "support_export_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "narrative_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "notice_class": { "const": "restricted" } },
            "required": ["notice_class"]
          },
          "then": {
            "properties": {
              "persistence_kind": { "enum": ["until_resolved"] },
              "dismissal_policy": {
                "enum": ["not_dismissible", "dismissible_until_resolved", "dismissible_until_scope_exit"]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "is_condition_active": { "const": true } },
            "required": ["is_condition_active"]
          },
          "then": {
            "properties": {
              "dismissal_policy": {
                "not": { "const": "dismissible_acknowledges_success" }
              }
            }
          }
        }
      ],
      "description": "One contextual notice instance rendered as inline notice, banner, review-sheet entry point, or durable activity state."
    },

    "case_assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_toast_only_representation",
        "banner_stacking_forbidden_when_summary_suffices",
        "active_conditions_remain_visible_after_dismiss"
      ],
      "properties": {
        "no_toast_only_representation": { "type": "boolean" },
        "banner_stacking_forbidden_when_summary_suffices": { "type": "boolean" },
        "active_conditions_remain_visible_after_dismiss": { "type": "boolean" },
        "scope_is_narrowest_truthful": { "type": "boolean" }
      }
    },

    "context_notice_case_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "context_notice_schema_version",
        "case_id",
        "scenario",
        "input_conditions",
        "expected_notices",
        "assertions",
        "captured_at",
        "narrative_refs"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "context_notice_case_record" },
        "context_notice_schema_version": { "$ref": "#/$defs/context_notice_schema_version" },
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "scenario": { "$ref": "#/$defs/reviewable_sentence" },
        "input_conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/context_notice_record" }
        },
        "expected_notices": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/context_notice_record" }
        },
        "assertions": { "$ref": "#/$defs/case_assertions" },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "narrative_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "description": "Worked case record for contextual notice selection, stacking avoidance, and dismissal/persistence expectations."
    }
  }
}

