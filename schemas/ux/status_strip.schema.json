{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/status_strip.schema.json",
  "title": "Aureline status-strip and readiness-banner family contract",
  "description": "Boundary schema for status_strip_record instances frozen in docs/ux/status_strip_family_contract.md. The record is the shared top-of-surface status strip and readiness banner family for workspace, environment, provider, graph, and framework surfaces. Every strip names the current scope or object, resolves to one shared readiness_state vocabulary (loading, warm, partial, stale, degraded, blocked, ready), discloses freshness and data backing, preserves blocker / warning / hidden-scope counts, exposes a command-backed primary next action, opens details through a keyboard-reachable path, and carries exactly one surface-specific variant block. Raw paths, raw URLs, raw host names, raw provider payloads, raw user identifiers, raw logs, raw prompts, raw command bodies, raw tokens, raw secret values, and raw policy bodies never cross this boundary; records carry opaque refs, controlled labels, typed counts, and reviewable sentences only. Adding a new status strip surface family, state, backing mode, detail surface, count reason, action kind, screenshot cue, or variant value is additive-minor and bumps status_strip_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "status_strip_schema_version",
    "status_strip_id",
    "surface_family",
    "presentation_class",
    "current_scope",
    "readiness",
    "counts",
    "primary_next_action",
    "open_details_path",
    "variant",
    "export_and_screenshot_safety",
    "accessibility",
    "narrative_refs"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "__fixture__": {
      "$ref": "#/$defs/fixture_metadata"
    },
    "record_kind": {
      "type": "string",
      "const": "status_strip_record"
    },
    "status_strip_schema_version": {
      "$ref": "#/$defs/status_strip_schema_version"
    },
    "status_strip_id": {
      "$ref": "#/$defs/opaque_id"
    },
    "surface_family": {
      "$ref": "#/$defs/status_strip_surface_family"
    },
    "presentation_class": {
      "$ref": "#/$defs/presentation_class"
    },
    "current_scope": {
      "$ref": "#/$defs/current_scope"
    },
    "readiness": {
      "$ref": "#/$defs/readiness_summary"
    },
    "counts": {
      "$ref": "#/$defs/count_summary"
    },
    "primary_next_action": {
      "$ref": "#/$defs/next_action"
    },
    "open_details_path": {
      "$ref": "#/$defs/open_details_path"
    },
    "variant": {
      "oneOf": [
        { "$ref": "#/$defs/workspace_variant" },
        { "$ref": "#/$defs/environment_variant" },
        { "$ref": "#/$defs/provider_variant" },
        { "$ref": "#/$defs/graph_variant" },
        { "$ref": "#/$defs/framework_variant" }
      ]
    },
    "export_and_screenshot_safety": {
      "$ref": "#/$defs/export_and_screenshot_safety"
    },
    "accessibility": {
      "$ref": "#/$defs/accessibility"
    },
    "narrative_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "surface_family": { "const": "workspace" } },
        "required": ["surface_family"]
      },
      "then": {
        "properties": { "variant": { "$ref": "#/$defs/workspace_variant" } }
      }
    },
    {
      "if": {
        "properties": { "surface_family": { "const": "environment" } },
        "required": ["surface_family"]
      },
      "then": {
        "properties": { "variant": { "$ref": "#/$defs/environment_variant" } }
      }
    },
    {
      "if": {
        "properties": { "surface_family": { "const": "provider" } },
        "required": ["surface_family"]
      },
      "then": {
        "properties": { "variant": { "$ref": "#/$defs/provider_variant" } }
      }
    },
    {
      "if": {
        "properties": { "surface_family": { "const": "graph" } },
        "required": ["surface_family"]
      },
      "then": {
        "properties": { "variant": { "$ref": "#/$defs/graph_variant" } }
      }
    },
    {
      "if": {
        "properties": { "surface_family": { "const": "framework" } },
        "required": ["surface_family"]
      },
      "then": {
        "properties": { "variant": { "$ref": "#/$defs/framework_variant" } }
      }
    },
    {
      "if": {
        "properties": {
          "readiness": {
            "properties": { "readiness_state": { "const": "ready" } },
            "required": ["readiness_state"]
          }
        },
        "required": ["readiness"]
      },
      "then": {
        "properties": {
          "readiness": {
            "properties": {
              "freshness_class": { "const": "authoritative_live" },
              "backing_mode": {
                "enum": [
                  "live",
                  "provider_backed_live",
                  "local_only"
                ]
              },
              "partial_readiness_disclosed": { "const": false },
              "stale_data_disclosed": { "const": false },
              "live_claim_class": { "const": "live_current" }
            }
          },
          "counts": {
            "properties": {
              "blocker_count": { "const": 0 },
              "warning_count": { "const": 0 },
              "hidden_scope_count": { "const": 0 },
              "hidden_scope_note": { "type": "null" },
              "partial_scope_note": { "type": "null" },
              "stale_note": { "type": "null" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "readiness": {
            "properties": { "readiness_state": { "const": "partial" } },
            "required": ["readiness_state"]
          }
        },
        "required": ["readiness"]
      },
      "then": {
        "properties": {
          "readiness": {
            "properties": {
              "partial_readiness_disclosed": { "const": true },
              "live_claim_class": { "const": "partial_labeled" }
            }
          },
          "counts": {
            "properties": {
              "partial_scope_note": { "$ref": "#/$defs/reviewable_sentence" }
            }
          },
          "export_and_screenshot_safety": {
            "properties": {
              "screenshot_required_cues": {
                "contains": { "const": "partial_readiness_label" }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "readiness": {
            "properties": { "readiness_state": { "const": "stale" } },
            "required": ["readiness_state"]
          }
        },
        "required": ["readiness"]
      },
      "then": {
        "properties": {
          "readiness": {
            "properties": {
              "freshness_class": { "const": "stale" },
              "stale_data_disclosed": { "const": true },
              "live_claim_class": { "const": "stale_labeled" }
            }
          },
          "counts": {
            "properties": {
              "stale_note": { "$ref": "#/$defs/reviewable_sentence" }
            }
          },
          "export_and_screenshot_safety": {
            "properties": {
              "screenshot_required_cues": {
                "contains": { "const": "stale_label" }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "readiness": {
            "properties": { "readiness_state": { "const": "degraded" } },
            "required": ["readiness_state"]
          }
        },
        "required": ["readiness"]
      },
      "then": {
        "properties": {
          "counts": {
            "anyOf": [
              {
                "properties": { "warning_count": { "minimum": 1 } },
                "required": ["warning_count"]
              },
              {
                "properties": { "blocker_count": { "minimum": 1 } },
                "required": ["blocker_count"]
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "readiness": {
            "properties": { "readiness_state": { "const": "blocked" } },
            "required": ["readiness_state"]
          }
        },
        "required": ["readiness"]
      },
      "then": {
        "properties": {
          "readiness": {
            "properties": { "live_claim_class": { "const": "blocked_no_live_claim" } }
          },
          "counts": {
            "properties": { "blocker_count": { "minimum": 1 } }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "counts": {
            "properties": { "hidden_scope_count": { "minimum": 1 } },
            "required": ["hidden_scope_count"]
          }
        },
        "required": ["counts"]
      },
      "then": {
        "properties": {
          "counts": {
            "properties": {
              "hidden_scope_note": { "$ref": "#/$defs/reviewable_sentence" },
              "hidden_scope_reasons": { "minItems": 1 }
            }
          },
          "export_and_screenshot_safety": {
            "properties": {
              "screenshot_required_cues": {
                "contains": { "const": "hidden_scope_note" }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "readiness": {
            "properties": {
              "backing_mode": {
                "enum": [
                  "provider_backed_live",
                  "provider_backed_cached",
                  "provider_backed_stale"
                ]
              }
            },
            "required": ["backing_mode"]
          }
        },
        "required": ["readiness"]
      },
      "then": {
        "properties": {
          "readiness": {
            "properties": { "provider_backing_disclosed": { "const": true } }
          },
          "export_and_screenshot_safety": {
            "properties": {
              "screenshot_required_cues": {
                "contains": { "const": "provider_backed_label" }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "readiness": {
            "properties": {
              "backing_mode": {
                "enum": [
                  "cached",
                  "provider_backed_cached",
                  "provider_backed_stale",
                  "imported_snapshot",
                  "mixed_live_and_cached"
                ]
              }
            },
            "required": ["backing_mode"]
          }
        },
        "required": ["readiness"]
      },
      "then": {
        "properties": {
          "export_and_screenshot_safety": {
            "properties": {
              "screenshot_required_cues": {
                "contains": { "const": "freshness_label" }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "status_strip_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this status-strip family vocabulary export."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario", "contract_sections"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "linked_docs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$",
      "description": "Opaque stable id safe for status records, support bundles, screenshots, and exports."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_id" },
        { "type": "null" }
      ]
    },
    "command_id": {
      "type": "string",
      "pattern": "^cmd:[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "Canonical command id. Launch-bearing commands must resolve to command descriptors before shipping."
    },
    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Short privacy-safe label text. Raw paths, URLs, host names, provider payloads, tokens, and secret material MUST NOT appear."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280,
      "description": "Short privacy-safe sentence suitable for status strips, screenshots, exports, support bundles, and accessibility announcements."
    },
    "status_strip_surface_family": {
      "type": "string",
      "enum": [
        "workspace",
        "environment",
        "provider",
        "graph",
        "framework"
      ]
    },
    "presentation_class": {
      "type": "string",
      "enum": [
        "top_of_surface_status_strip",
        "readiness_banner",
        "workflow_summary_strip",
        "support_export_summary",
        "compact_status_strip"
      ]
    },
    "scope_kind": {
      "type": "string",
      "enum": [
        "workspace",
        "workset",
        "root_set",
        "environment",
        "execution_target",
        "provider_lane",
        "provider_surface",
        "graph_slice",
        "result_set",
        "framework_pack",
        "active_file",
        "selected_object"
      ]
    },
    "current_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_ref",
        "scope_kind",
        "scope_label_text",
        "scope_summary_sentence",
        "source_record_refs"
      ],
      "properties": {
        "scope_ref": { "$ref": "#/$defs/opaque_id" },
        "scope_kind": { "$ref": "#/$defs/scope_kind" },
        "scope_label_text": { "$ref": "#/$defs/short_label_text" },
        "scope_summary_sentence": { "$ref": "#/$defs/reviewable_sentence" },
        "source_record_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "readiness_state": {
      "type": "string",
      "enum": [
        "loading",
        "warm",
        "partial",
        "stale",
        "degraded",
        "blocked",
        "ready"
      ],
      "description": "Shared top-level status-strip state vocabulary. Variant blocks may carry deeper owner states, but their top-level strip state maps to exactly one of these values."
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified",
        "not_applicable"
      ],
      "description": "Freshness vocabulary re-exported from capability lifecycle and adjacent UX contracts."
    },
    "backing_mode": {
      "type": "string",
      "enum": [
        "live",
        "cached",
        "provider_backed_live",
        "provider_backed_cached",
        "provider_backed_stale",
        "local_only",
        "imported_snapshot",
        "mixed_live_and_cached",
        "not_applicable"
      ],
      "description": "Names whether the rendered view is live, cached, provider-backed, local-only, imported, mixed, or not data-backed."
    },
    "live_claim_class": {
      "type": "string",
      "enum": [
        "live_current",
        "cached_labeled",
        "provider_backed_labeled",
        "partial_labeled",
        "stale_labeled",
        "blocked_no_live_claim",
        "no_live_claim"
      ]
    },
    "readiness_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readiness_state",
        "freshness_class",
        "backing_mode",
        "live_claim_class",
        "provider_backing_disclosed",
        "partial_readiness_disclosed",
        "stale_data_disclosed",
        "state_summary_sentence"
      ],
      "properties": {
        "readiness_state": { "$ref": "#/$defs/readiness_state" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "backing_mode": { "$ref": "#/$defs/backing_mode" },
        "live_claim_class": { "$ref": "#/$defs/live_claim_class" },
        "provider_backing_disclosed": { "type": "boolean" },
        "partial_readiness_disclosed": { "type": "boolean" },
        "stale_data_disclosed": { "type": "boolean" },
        "state_summary_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "hidden_scope_reason": {
      "type": "string",
      "enum": [
        "none",
        "policy_narrows_source",
        "trust_state_excludes_surface",
        "workset_excludes_scope",
        "unloaded_scope",
        "remote_shard_unreachable",
        "provider_authorization_missing",
        "redaction_narrowed",
        "user_filter_excludes_scope",
        "client_scope_excludes_surface"
      ]
    },
    "count_accuracy": {
      "type": "string",
      "enum": [
        "exact",
        "approximate",
        "upper_bound",
        "not_counted"
      ]
    },
    "count_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blocker_count",
        "warning_count",
        "hidden_scope_count",
        "hidden_scope_note",
        "hidden_scope_reasons",
        "partial_scope_note",
        "stale_note",
        "count_accuracy",
        "count_summary_sentence"
      ],
      "properties": {
        "blocker_count": { "type": "integer", "minimum": 0 },
        "warning_count": { "type": "integer", "minimum": 0 },
        "hidden_scope_count": { "type": "integer", "minimum": 0 },
        "hidden_scope_note": {
          "oneOf": [
            { "$ref": "#/$defs/reviewable_sentence" },
            { "type": "null" }
          ]
        },
        "hidden_scope_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/hidden_scope_reason" },
          "uniqueItems": true
        },
        "partial_scope_note": {
          "oneOf": [
            { "$ref": "#/$defs/reviewable_sentence" },
            { "type": "null" }
          ]
        },
        "stale_note": {
          "oneOf": [
            { "$ref": "#/$defs/reviewable_sentence" },
            { "type": "null" }
          ]
        },
        "count_accuracy": { "$ref": "#/$defs/count_accuracy" },
        "count_summary_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "action_kind": {
      "type": "string",
      "enum": [
        "open_blocker",
        "review_warnings",
        "open_details",
        "refresh",
        "reconnect",
        "widen_scope",
        "select_provider",
        "repair_context",
        "continue_limited",
        "wait_for_readiness",
        "no_action_available"
      ]
    },
    "action_enabled_state": {
      "type": "string",
      "enum": [
        "enabled",
        "disabled_blocked",
        "disabled_not_applicable"
      ]
    },
    "next_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "label_text",
        "action_kind",
        "command_id",
        "target_ref",
        "enabled_state",
        "safety_sentence"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "label_text": { "$ref": "#/$defs/short_label_text" },
        "action_kind": { "$ref": "#/$defs/action_kind" },
        "command_id": { "$ref": "#/$defs/command_id" },
        "target_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "enabled_state": { "$ref": "#/$defs/action_enabled_state" },
        "safety_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "detail_surface_class": {
      "type": "string",
      "enum": [
        "workspace_readiness_inspector",
        "environment_context_inspector",
        "provider_details_inspector",
        "graph_inspector",
        "framework_pack_details",
        "support_export_record",
        "status_item_drawer",
        "quick_open_explanation"
      ]
    },
    "open_details_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detail_surface_class",
        "activation_command_id",
        "focus_target_id",
        "accessible_name",
        "opens_without_pointer",
        "export_field_refs"
      ],
      "properties": {
        "detail_surface_class": { "$ref": "#/$defs/detail_surface_class" },
        "activation_command_id": { "$ref": "#/$defs/command_id" },
        "focus_target_id": { "$ref": "#/$defs/opaque_id" },
        "accessible_name": { "$ref": "#/$defs/short_label_text" },
        "opens_without_pointer": { "type": "boolean" },
        "export_field_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "status_cell_kind": {
      "type": "string",
      "enum": [
        "interpreter_or_toolchain_status",
        "sdk_status",
        "shell_status",
        "target_status"
      ]
    },
    "workspace_scope_class": {
      "type": "string",
      "enum": [
        "single_root",
        "multi_root",
        "active_workset",
        "sparse_slice",
        "managed_workspace",
        "restricted_workspace"
      ]
    },
    "workspace_variant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "variant_kind",
        "workspace_scope_class",
        "workspace_status_refs",
        "workspace_truth_refs",
        "root_count_summary",
        "local_editing_available",
        "local_continuation_sentence"
      ],
      "properties": {
        "variant_kind": {
          "type": "string",
          "const": "workspace_status_strip_variant"
        },
        "workspace_scope_class": { "$ref": "#/$defs/workspace_scope_class" },
        "workspace_status_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "minItems": 1,
          "uniqueItems": true
        },
        "workspace_truth_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "minItems": 1,
          "uniqueItems": true
        },
        "root_count_summary": {
          "$ref": "#/$defs/root_count_summary"
        },
        "local_editing_available": { "type": "boolean" },
        "local_continuation_sentence": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "root_count_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "included_root_count",
        "excluded_root_count",
        "hidden_root_count",
        "blocked_root_count"
      ],
      "properties": {
        "included_root_count": { "type": "integer", "minimum": 0 },
        "excluded_root_count": { "type": "integer", "minimum": 0 },
        "hidden_root_count": { "type": "integer", "minimum": 0 },
        "blocked_root_count": { "type": "integer", "minimum": 0 }
      }
    },
    "environment_variant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "variant_kind",
        "environment_status_strip_ref",
        "execution_context_snapshot_ref",
        "transport_posture_ref",
        "active_cell_kinds",
        "status_cell_refs",
        "target_ref"
      ],
      "properties": {
        "variant_kind": {
          "type": "string",
          "const": "environment_status_strip_variant"
        },
        "environment_status_strip_ref": { "$ref": "#/$defs/opaque_id" },
        "execution_context_snapshot_ref": { "$ref": "#/$defs/opaque_id" },
