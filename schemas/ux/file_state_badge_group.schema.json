{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/file_state_badge_group.schema.json",
  "title": "Aureline file-state badge group and reason-strip contract",
  "description": "Boundary schema for one file_state_badge_group_record frozen in docs/ux/file_state_badge_and_write_review_contract.md. The record gives editor, diff, preview, review, notebook, evidence, support export, and screenshot surfaces one vocabulary for read-only, generated, policy-locked, managed/mirrored, projection, and captured-snapshot file-like states. It keeps source-of-truth relation, write authority, dirty state, freshness, reason-strip copy, and next-safe action as separate facts. Raw file bodies, raw absolute paths, raw provider payloads, raw policy bodies, raw generator inputs, notebook output bytes, evidence payloads, credentials, and secrets never cross this boundary.",
  "type": "object",
  "$ref": "#/$defs/file_state_badge_group_record",
  "$defs": {
    "file_state_badge_group_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for file-state badge group payloads."
    },
    "record_kind": {
      "type": "string",
      "const": "file_state_badge_group_record"
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9]+(?:[A-Za-z0-9_.:/-]*[A-Za-z0-9])?$",
      "description": "Stable opaque id safe for logs, RPC, support bundles, screenshots, and fixtures. Raw absolute paths, raw URLs with sensitive components, raw payloads, policy bodies, and secrets never appear here."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_id" },
        { "type": "null" }
      ]
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 900,
      "description": "Bounded redaction-aware sentence suitable for review, screenshots, and support export."
    },
    "short_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "editor",
        "diff",
        "preview",
        "review",
        "notebook",
        "evidence",
        "explorer_search",
        "support_export"
      ]
    },
    "object_kind": {
      "type": "string",
      "enum": [
        "local_source_file",
        "generated_artifact",
        "policy_locked_file",
        "managed_mirror",
        "projection_view",
        "captured_snapshot",
        "compare_view",
        "structured_artifact"
      ]
    },
    "file_state_badge_class": {
      "type": "string",
      "enum": [
        "read_only",
        "generated",
        "policy_locked",
        "managed_mirrored",
        "projection",
        "captured_snapshot"
      ],
      "description": "Closed badge-group vocabulary shared by launch-critical file-like surfaces."
    },
    "source_of_truth_relation_class": {
      "type": "string",
      "enum": [
        "current_object_is_canonical",
        "canonical_source_elsewhere",
        "generator_output_from_canonical_source",
        "policy_rule_controls_current_object",
        "managed_upstream_is_canonical",
        "live_target_is_canonical",
        "captured_basis_is_canonical",
        "source_unknown"
      ]
    },
    "relation_owner_kind": {
      "type": "string",
      "enum": [
        "workspace_file",
        "generator",
        "policy_rule",
        "managed_upstream",
        "mirror_origin",
        "live_target",
        "notebook_kernel",
        "evidence_capture",
        "unknown"
      ]
    },
    "write_authority_class": {
      "type": "string",
      "enum": [
        "writable_here",
        "read_only_permission",
        "generated_regeneration_only",
        "policy_locked",
        "managed_admin_or_upstream_only",
        "mirror_refresh_or_detach_only",
        "projection_no_direct_write",
        "captured_snapshot_no_direct_write",
        "approval_required",
        "overlay_only",
        "unknown"
      ]
    },
    "dirty_state_class": {
      "type": "string",
      "enum": [
        "clean",
        "dirty_buffer_owned_here",
        "dirty_buffer_owned_elsewhere",
        "staged_overlay_dirty",
        "projection_selection_dirty",
        "conflict_dirty",
        "not_applicable"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "live_current",
        "current_snapshot",
        "fresh_snapshot",
        "stale",
        "partial",
        "unknown",
        "not_applicable"
      ]
    },
    "next_safe_action_class": {
      "type": "string",
      "enum": [
        "edit_current_object",
        "open_canonical_source",
        "duplicate",
        "detach",
        "regenerate",
        "create_editable_overlay",
        "request_approval",
        "export_evidence",
        "refresh_or_requery",
        "compare_against_source",
        "inspect_reason"
      ]
    },
    "enabled_state": {
      "type": "string",
      "enum": ["enabled", "disabled", "blocked", "pending_review"]
    },
    "current_object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_ref",
        "object_kind",
        "display_label",
        "surface_instance_ref",
        "owning_scope_ref"
      ],
      "properties": {
        "object_ref": { "$ref": "#/$defs/opaque_id" },
        "object_kind": { "$ref": "#/$defs/object_kind" },
        "display_label": { "$ref": "#/$defs/short_label" },
        "surface_instance_ref": { "$ref": "#/$defs/opaque_id" },
        "owning_scope_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "badge_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_badge_class",
        "active_badge_classes",
        "secondary_badge_classes",
        "visible_label",
        "required_surface_cues",
        "icon_only_forbidden"
      ],
      "properties": {
        "primary_badge_class": { "$ref": "#/$defs/file_state_badge_class" },
        "active_badge_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/file_state_badge_class" },
          "minItems": 1,
          "uniqueItems": true
        },
        "secondary_badge_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/file_state_badge_class" },
          "uniqueItems": true
        },
        "visible_label": { "$ref": "#/$defs/short_label" },
        "required_surface_cues": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "visible_text_label",
              "context_row",
              "status_strip",
              "sheet_reason_strip",
              "accessibility_label",
              "support_export_field",
              "screenshot_caption"
            ]
          },
          "minItems": 2,
          "uniqueItems": true
        },
        "icon_only_forbidden": { "type": "boolean", "const": true }
      },
      "allOf": [
        {
          "if": { "properties": { "primary_badge_class": { "const": "read_only" } }, "required": ["primary_badge_class"] },
          "then": { "properties": { "active_badge_classes": { "contains": { "const": "read_only" } } } }
        },
        {
          "if": { "properties": { "primary_badge_class": { "const": "generated" } }, "required": ["primary_badge_class"] },
          "then": { "properties": { "active_badge_classes": { "contains": { "const": "generated" } } } }
        },
        {
          "if": { "properties": { "primary_badge_class": { "const": "policy_locked" } }, "required": ["primary_badge_class"] },
          "then": { "properties": { "active_badge_classes": { "contains": { "const": "policy_locked" } } } }
        },
        {
          "if": { "properties": { "primary_badge_class": { "const": "managed_mirrored" } }, "required": ["primary_badge_class"] },
          "then": { "properties": { "active_badge_classes": { "contains": { "const": "managed_mirrored" } } } }
        },
        {
          "if": { "properties": { "primary_badge_class": { "const": "projection" } }, "required": ["primary_badge_class"] },
          "then": { "properties": { "active_badge_classes": { "contains": { "const": "projection" } } } }
        },
        {
          "if": { "properties": { "primary_badge_class": { "const": "captured_snapshot" } }, "required": ["primary_badge_class"] },
          "then": { "properties": { "active_badge_classes": { "contains": { "const": "captured_snapshot" } } } }
        }
      ]
    },
    "source_of_truth_relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation_class",
        "canonical_object_ref",
        "relation_owner_kind",
        "relation_owner_ref",
        "relation_label",
        "do_not_imply_canonical_source"
      ],
      "properties": {
        "relation_class": { "$ref": "#/$defs/source_of_truth_relation_class" },
        "canonical_object_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "relation_owner_kind": { "$ref": "#/$defs/relation_owner_kind" },
        "relation_owner_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "relation_label": { "$ref": "#/$defs/reviewable_sentence" },
        "do_not_imply_canonical_source": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "relation_class": { "const": "current_object_is_canonical" } }, "required": ["relation_class"] },
          "then": { "properties": { "do_not_imply_canonical_source": { "const": false } } },
          "else": { "properties": { "do_not_imply_canonical_source": { "const": true } } }
        }
      ]
    },
    "write_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_class",
        "direct_write_permitted",
        "authority_ref",
        "authority_summary",
        "required_review_ref"
      ],
      "properties": {
        "authority_class": { "$ref": "#/$defs/write_authority_class" },
        "direct_write_permitted": { "type": "boolean" },
        "authority_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "authority_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "required_review_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      },
      "allOf": [
        {
          "if": { "properties": { "authority_class": { "const": "writable_here" } }, "required": ["authority_class"] },
          "then": { "properties": { "direct_write_permitted": { "const": true } } },
          "else": { "properties": { "direct_write_permitted": { "const": false } } }
        }
      ]
    },
    "dirty_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dirty_state_class",
        "dirty_owner_ref",
        "dirty_scope_label",
        "dirty_summary"
      ],
      "properties": {
        "dirty_state_class": { "$ref": "#/$defs/dirty_state_class" },
        "dirty_owner_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "dirty_scope_label": { "$ref": "#/$defs/short_label" },
        "dirty_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness_class",
        "basis_ref",
        "evaluated_at",
        "freshness_summary"
      ],
      "properties": {
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "basis_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "evaluated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "freshness_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "canonical_source_relation_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation_class",
        "source_kind",
        "source_ref",
        "source_label",
        "source_freshness_class",
        "open_action_ref"
      ],
      "properties": {
        "relation_class": { "$ref": "#/$defs/source_of_truth_relation_class" },
        "source_kind": { "$ref": "#/$defs/relation_owner_kind" },
        "source_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "source_label": { "$ref": "#/$defs/reviewable_sentence" },
        "source_freshness_class": { "$ref": "#/$defs/freshness_class" },
        "open_action_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "reason_strip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cause_plain_language",
        "scope_plain_language",
        "boundary_plain_language",
        "safe_next_step_plain_language",
        "canonical_source_relation_row"
      ],
      "properties": {
        "cause_plain_language": { "$ref": "#/$defs/reviewable_sentence" },
        "scope_plain_language": { "$ref": "#/$defs/reviewable_sentence" },
        "boundary_plain_language": { "$ref": "#/$defs/reviewable_sentence" },
        "safe_next_step_plain_language": { "$ref": "#/$defs/reviewable_sentence" },
        "canonical_source_relation_row": { "$ref": "#/$defs/canonical_source_relation_row" }
      }
    },
    "next_safe_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_class",
        "label_text",
        "command_ref",
        "target_relation",
        "target_ref",
        "enabled_state",
        "action_summary"
      ],
      "properties": {
        "action_class": { "$ref": "#/$defs/next_safe_action_class" },
        "label_text": { "$ref": "#/$defs/short_label" },
        "command_ref": { "$ref": "#/$defs/opaque_id" },
        "target_relation": { "$ref": "#/$defs/source_of_truth_relation_class" },
        "target_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "enabled_state": { "$ref": "#/$defs/enabled_state" },
        "action_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "export_and_accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accessible_name",
        "screenshot_label",
        "support_export_field_refs",
        "state_vocabulary_preserved",
        "raw_private_material_excluded"
      ],
      "properties": {
        "accessible_name": { "$ref": "#/$defs/reviewable_sentence" },
        "screenshot_label": { "$ref": "#/$defs/short_label" },
        "support_export_field_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "minItems": 1,
          "uniqueItems": true
        },
        "state_vocabulary_preserved": { "type": "boolean", "const": true },
        "raw_private_material_excluded": { "type": "boolean", "const": true }
      }
    },
    "file_state_badge_group_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "file_state_badge_group_schema_version",
        "file_state_badge_group_id",
        "surface_family",
        "current_object",
        "badge_group",
        "source_of_truth_relation",
        "write_authority",
        "dirty_state",
        "freshness",
        "reason_strip",
        "next_safe_action",
        "export_and_accessibility",
        "narrative_refs"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "file_state_badge_group_schema_version": { "$ref": "#/$defs/file_state_badge_group_schema_version" },
        "file_state_badge_group_id": { "$ref": "#/$defs/opaque_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "current_object": { "$ref": "#/$defs/current_object" },
        "badge_group": { "$ref": "#/$defs/badge_group" },
        "source_of_truth_relation": { "$ref": "#/$defs/source_of_truth_relation" },
        "write_authority": { "$ref": "#/$defs/write_authority" },
        "dirty_state": { "$ref": "#/$defs/dirty_state" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "reason_strip": { "$ref": "#/$defs/reason_strip" },
        "next_safe_action": { "$ref": "#/$defs/next_safe_action" },
        "export_and_accessibility": { "$ref": "#/$defs/export_and_accessibility" },
        "narrative_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": { "properties": { "badge_group": { "properties": { "primary_badge_class": { "const": "generated" } }, "required": ["primary_badge_class"] } }, "required": ["badge_group"] },
          "then": {
            "properties": {
              "source_of_truth_relation": {
                "properties": { "relation_class": { "const": "generator_output_from_canonical_source" } }
              }
            }
          }
        },
        {
          "if": { "properties": { "badge_group": { "properties": { "primary_badge_class": { "const": "policy_locked" } }, "required": ["primary_badge_class"] } }, "required": ["badge_group"] },
          "then": {
            "properties": {
              "source_of_truth_relation": {
                "properties": { "relation_class": { "const": "policy_rule_controls_current_object" } }
              }
            }
          }
        },
        {
          "if": { "properties": { "badge_group": { "properties": { "primary_badge_class": { "const": "managed_mirrored" } }, "required": ["primary_badge_class"] } }, "required": ["badge_group"] },
          "then": {
            "properties": {
              "source_of_truth_relation": {
                "properties": { "relation_class": { "const": "managed_upstream_is_canonical" } }
              }
            }
          }
        },
        {
          "if": { "properties": { "badge_group": { "properties": { "primary_badge_class": { "const": "projection" } }, "required": ["primary_badge_class"] } }, "required": ["badge_group"] },
          "then": {
            "properties": {
              "source_of_truth_relation": {
                "properties": { "relation_class": { "const": "live_target_is_canonical" } }
              }
            }
          }
        },
        {
          "if": { "properties": { "badge_group": { "properties": { "primary_badge_class": { "const": "captured_snapshot" } }, "required": ["primary_badge_class"] } }, "required": ["badge_group"] },
          "then": {
            "properties": {
              "source_of_truth_relation": {
                "properties": { "relation_class": { "const": "captured_basis_is_canonical" } }
              }
            }
          }
        }
      ]
    }
  }
}
