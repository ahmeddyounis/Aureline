{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/stabilize-workspace-archetype-detection-readiness-preflight.schema.json",
  "title": "Aureline workspace archetype readiness preflight record",
  "description": "Boundary schema for workspace_archetype_readiness_preflight_record, the governed stable record that shell, diagnostics, support exports, Help/About, and docs read for workspace archetype detection, readiness preflight, admission checkpoints, and first-useful-work routing. It enforces M04-190 honesty invariants: source-labeled signals, distinct readiness buckets (blocking_now, recommended_soon, optional_later), inspectable and bounded first-useful-work routing, same-weight bypass actions, mixed-workspace boundary choices, and safety fields that prevent auto-install, auto-trust, hidden setup, and trust widening.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "detection_outcome",
    "detection_confidence",
    "support_claim",
    "detector_state",
    "compatible_bundle_refs",
    "source_labeled_signals",
    "evidence_freshness",
    "readiness_buckets",
    "entry_source",
    "landing_surface",
    "route_reason",
    "switch_options",
    "remembered_routing_effect",
    "boundary_choices",
    "same_weight_bypass_actions",
    "auto_install_allowed",
    "auto_trust_allowed",
    "hidden_setup_executed",
    "trust_widened",
    "summary",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": { "type": "string", "const": "workspace_archetype_readiness_preflight_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "notice": { "type": "string", "minLength": 1 },
    "shared_contract_ref": { "type": "string", "const": "workspace:archetype_readiness_preflight_stable:v1" },
    "record_id": { "$ref": "#/$defs/opaque_id" },
    "as_of": { "$ref": "#/$defs/utc_date_time" },
    "detection_outcome": { "$ref": "#/$defs/detection_outcome" },
    "detection_confidence": { "$ref": "#/$defs/detection_confidence_class" },
    "support_claim": { "$ref": "#/$defs/support_claim_class" },
    "detector_state": { "$ref": "#/$defs/detector_state" },
    "archetype_ref": { "oneOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] },
    "compatible_bundle_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "source_labeled_signals": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/detection_signal" } },
    "evidence_freshness": { "type": "array", "items": { "$ref": "#/$defs/evidence_freshness" } },
    "detected_fact_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "recommendation_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "policy_block_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "readiness_buckets": { "$ref": "#/$defs/readiness_buckets" },
    "entry_source": { "$ref": "#/$defs/first_useful_entry_source" },
    "landing_surface": { "$ref": "#/$defs/landing_surface" },
    "route_reason": { "$ref": "#/$defs/route_reason_class" },
    "switch_options": { "type": "array", "items": { "$ref": "#/$defs/route_switch_option" } },
    "remembered_routing_effect": { "$ref": "#/$defs/remembered_routing_effect" },
    "boundary_choices": { "type": "array", "items": { "$ref": "#/$defs/mixed_workspace_boundary_choice" } },
    "same_weight_bypass_actions": { "type": "array", "items": { "$ref": "#/$defs/continue_without_class" } },
    "auto_install_allowed": { "type": "boolean", "const": false },
    "auto_trust_allowed": { "type": "boolean", "const": false },
    "hidden_setup_executed": { "type": "boolean", "const": false },
    "trust_widened": { "type": "boolean", "const": false },
    "summary": { "type": "string", "minLength": 1, "maxLength": 2048 },
    "diagnostics_export_ref": { "$ref": "#/$defs/canonical_ref" },
    "support_export_ref": { "$ref": "#/$defs/canonical_ref" },
    "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/canonical_ref" } },
    "narrative_refs": { "type": "array", "items": { "$ref": "#/$defs/canonical_ref" } }
  },
  "$defs": {
    "opaque_id": { "type": "string", "minLength": 1, "maxLength": 200 },
    "canonical_ref": {
      "type": "string",
      "description": "Opaque durable-object ref of the form aureline://<class>/<id>; <class> is not a generic landing page.",
      "pattern": "^aureline://(?!(home|dashboard|landing|index|overview|start|root)/)[^/]+/.+$",
      "maxLength": 200
    },
    "utc_date_time": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "detection_outcome": {
      "type": "string",
      "enum": [
        "certified_archetype_match",
        "probable_archetype",
        "mixed_or_ambiguous_workspace",
        "unknown_or_generic_workspace",
        "restricted_or_policy_blocked",
        "missing_prerequisite"
      ]
    },
    "detection_confidence_class": {
      "type": "string",
      "enum": [
        "certified_exact",
        "high_probable",
        "medium_probable",
        "mixed_conflicting",
        "generic_unknown",
        "restricted_by_policy",
        "prerequisite_missing"
      ]
    },
    "support_claim_class": {
      "type": "string",
      "enum": [
        "certified_current",
        "certified_retest_pending",
        "supported_scoped",
        "community_or_extension_path",
        "experimental_preview",
        "generic_no_claim",
        "claim_blocked_by_policy",
        "claim_unavailable_missing_prerequisite"
      ]
    },
    "detector_state": {
      "type": "string",
      "enum": [
        "detecting",
        "ready_enough",
        "partial",
        "stale",
        "retest_needed",
        "blocked",
        "unknown"
      ]
    },
    "detection_signal_source_class": {
      "type": "string",
      "enum": [
        "manifest",
        "bundle_marker",
        "workspace_file",
        "import_packet",
        "admin_policy",
        "extension_contribution",
        "previous_user_choice",
        "filesystem_layout",
        "lockfile",
        "runtime_probe",
        "vcs_metadata"
      ]
    },
    "signal_material_effect": {
      "type": "string",
      "enum": [
        "trust",
        "support_claim",
        "recommendation",
        "route_selection",
        "policy",
        "readiness",
        "diagnostic_only"
      ]
    },
    "signal_freshness_class": {
      "type": "string",
      "enum": [
        "fresh_current",
        "cached_current_enough",
        "stale_retest_needed",
        "imported_snapshot",
        "policy_epoch_current",
        "policy_epoch_unknown",
        "unknown_freshness"
      ]
    },
    "detection_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signal_ref", "source_class", "material_effects", "summary"],
      "properties": {
        "signal_ref": { "$ref": "#/$defs/opaque_id" },
        "source_class": { "$ref": "#/$defs/detection_signal_source_class" },
        "material_effects": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/signal_material_effect" },
          "uniqueItems": true
        },
        "freshness_class": { "$ref": "#/$defs/signal_freshness_class" },
        "summary": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },
    "evidence_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_ref", "freshness_class", "summary"],
      "properties": {
        "evidence_ref": { "$ref": "#/$defs/opaque_id" },
        "freshness_class": { "$ref": "#/$defs/signal_freshness_class" },
        "reviewed_on": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "stale_after": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },
    "readiness_bucket": {
      "type": "string",
      "enum": ["blocking_now", "recommended_soon", "optional_later"]
    },
    "readiness_task_class": {
      "type": "string",
      "enum": [
        "trust_review",
        "policy_review",
        "toolchain_detect",
        "toolchain_install",
        "dependency_restore",
        "extension_recommendation",
        "extension_install",
        "runtime_attach",
        "remote_agent_reconnect",
        "devcontainer_build",
        "package_manager_select",
        "index_warmup",
        "docs_import",
        "test_discovery",
        "user_boundary_choice",
        "imported_state_compare",
        "restore_review",
        "deep_link_clone_required"
      ]
    },
    "readiness_task_state": {
      "type": "string",
      "enum": [
        "ready",
        "pending",
        "blocked_by_policy",
        "blocked_by_trust",
        "missing_prerequisite",
        "deferred_by_user",
        "optional",
        "unavailable"
      ]
    },
    "execution_boundary": {
      "type": "string",
      "enum": [
        "local_machine",
        "container",
        "remote_agent",
        "managed_workspace",
        "browser_handoff",
        "no_execution"
      ]
    },
    "side_effect_class": {
      "type": "string",
      "enum": [
        "reads_workspace",
        "writes_workspace_files",
        "installs_packages",
        "downloads_dependencies",
        "widens_trust",
        "widens_network",
        "contacts_remote",
        "starts_process",
        "attaches_runtime",
        "changes_layout",
        "no_side_effect"
      ]
    },
    "blocked_reason_class": {
      "type": "string",
      "enum": [
        "blocked_by_trust",
        "blocked_by_policy",
        "blocked_by_missing_prerequisite",
        "blocked_by_deployment_profile"
      ]
    },
    "optional_reason_class": {
      "type": "string",
      "enum": [
        "optional_additive",
        "optional_recommended_only",
        "optional_user_dismissed",
        "optional_freshness_based"
      ]
    },
    "readiness_task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_ref",
        "task_class",
        "bucket",
        "state",
        "execution_boundary",
        "side_effects",
        "source_signal_refs",
        "summary"
      ],
      "properties": {
        "task_ref": { "$ref": "#/$defs/opaque_id" },
        "task_class": { "$ref": "#/$defs/readiness_task_class" },
        "bucket": { "$ref": "#/$defs/readiness_bucket" },
        "state": { "$ref": "#/$defs/readiness_task_state" },
        "execution_boundary": { "$ref": "#/$defs/execution_boundary" },
        "side_effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/side_effect_class" }
        },
        "source_signal_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "recommendation_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "policy_block_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "blocked_reason_class": { "$ref": "#/$defs/blocked_reason_class" },
        "optional_reason_class": { "$ref": "#/$defs/optional_reason_class" },
        "summary": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },
    "readiness_buckets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocking_now", "recommended_soon", "optional_later"],
      "properties": {
        "blocking_now": { "type": "array", "items": { "$ref": "#/$defs/readiness_task" } },
        "recommended_soon": { "type": "array", "items": { "$ref": "#/$defs/readiness_task" } },
        "optional_later": { "type": "array", "items": { "$ref": "#/$defs/readiness_task" } }
      }
    },
    "first_useful_entry_source": {
      "type": "string",
      "enum": [
        "single_file_open",
        "folder_or_repo_open",
        "repository_clone",
        "review_or_incident_deep_link",
        "restore_last_session",
        "imported_state_or_handoff_packet"
      ]
    },
    "landing_surface": {
      "type": "string",
      "enum": [
        "file_editor_with_root_cues",
        "explorer_plus_readme_or_changed_files",
        "post_clone_handoff",
        "linked_review_incident_or_work_item",
        "restored_layout_with_placeholders",
        "import_compare_or_restore_sheet",
        "generic_shell_with_diagnostics",
        "nested_root_choice_sheet"
      ]
    },
    "route_reason_class": {
      "type": "string",
      "enum": [
        "standalone_file",
        "repo_evidence",
        "clone_materialized_no_setup_run",
        "linked_object_arrival",
        "restore_provenance",
        "imported_packet_review",
        "policy_or_trust_narrowing",
        "mixed_workspace_boundary_choice",
        "unknown_generic_safe_default",
        "missing_prerequisite_limited_ready"
      ]
    },
    "route_switch_option": {
      "type": "string",
      "enum": [
        "open_plain_explorer",
        "open_last_file",
        "open_readme",
        "open_changed_files",
        "review_trust",
        "choose_root_or_workset",
        "compare_import",
        "open_minimal",
        "set_up_later",
        "open_clone_or_local_checkout",
        "open_project_doctor"
      ]
    },
    "remembered_routing_effect": {
      "type": "string",
      "enum": [
        "not_remembered",
        "narrowing_hint_only",
        "expired_requires_review",
        "blocked_by_policy"
      ]
    },
    "mixed_workspace_boundary_choice": {
      "type": "string",
      "enum": [
        "open_whole_repo",
        "open_probable_project",
        "open_current_folder_only",
        "create_workset_or_slice"
      ]
    },
    "continue_without_class": {
      "type": "string",
      "enum": [
        "set_up_later",
        "open_minimal",
        "open_plain_explorer",
        "continue_in_restricted_mode",
        "inspect_only",
        "compare_before_restore",
        "dismiss_recommendation",
        "no_continue_without_action_available"
      ]
    }
  }
}
