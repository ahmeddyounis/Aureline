{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/teaching_session.schema.json",
  "title": "Aureline teaching session authoring artifact",
  "description": "Boundary schema for the shared teaching / presentation session authoring artifact frozen in docs/ux/learning_artifact_object_model.md. One teaching_session_artifact record per authored teaching, classroom, walkthrough, or presentation session bundle. The record is the portable authoring object pack authors ship; the runtime presentation_session_record on schemas/ux/presentation_mode_state.schema.json carries render-time state for an active session and resolves against this artifact by id. Authority on this artifact MUST NOT confer mutation; mutating control rides a control_grant_record on schemas/collaboration/control_grant.schema.json. The contract mints no new share_state_class, audience_visibility_class, speaker_note_locality_class, presenter_bar_visibility_class, replay_retention_class, reduced_motion_posture_class, accessibility_keyboard_class, local_remote_shared_boundary_class, breakaway_recovery_class, evidence_hook_class, deployment_profile_id, or redaction_class vocabulary; those re-export verbatim from schemas/ux/presentation_mode_state.schema.json, schemas/ux/guided_tour.schema.json, schemas/governance/capability_lifecycle.schema.json, and artifacts/governance/deployment_profiles.yaml.",
  "type": "object",
  "$ref": "#/$defs/teaching_session_artifact",
  "$defs": {
    "teaching_session_artifact_schema_version": {
      "type": "integer",
      "const": 1
    },

    "record_kind": {
      "type": "string",
      "const": "teaching_session_artifact"
    },

    "opaque_id": { "type": "string", "minLength": 1 },

    "monotonic_timestamp": { "type": "string", "format": "date-time" },

    "short_label_text": { "type": "string", "minLength": 1, "maxLength": 200 },

    "bcp47_locale_tag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": { "type": "object", "additionalProperties": true },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "session_class": {
      "type": "string",
      "enum": [
        "facilitator_led_walkthrough",
        "classroom_managed_session",
        "live_pair_review",
        "architecture_map_walkthrough",
        "release_or_demo_walkthrough",
        "local_only_dry_run"
      ],
      "description": "Closed teaching-session authoring class. local_only_dry_run is admissible on local-only envelopes; classroom_managed_session is admissible only on managed-cloud or enterprise-online deployment profiles."
    },

    "share_state_class": {
      "type": "string",
      "enum": [
        "local_only_no_share",
        "shared_to_named_audience",
        "shared_to_classroom_managed_pool",
        "shared_to_facilitator_only",
        "shared_blocked_by_policy",
        "shared_unavailable_in_envelope"
      ],
      "description": "Re-exported from schemas/ux/presentation_mode_state.schema.json."
    },

    "audience_visibility_class": {
      "type": "string",
      "enum": [
        "audience_sees_workspace_surfaces_only",
        "audience_sees_workspace_plus_agenda_rail",
        "audience_sees_workspace_plus_spotlight_frame",
        "audience_sees_workspace_plus_breakaway_banner",
        "audience_sees_nothing_local_view_only"
      ],
      "description": "Re-exported from schemas/ux/presentation_mode_state.schema.json."
    },

    "speaker_note_locality_class": {
      "type": "string",
      "enum": [
        "speaker_notes_facilitator_only_local",
        "speaker_notes_co_presenter_visible",
        "speaker_notes_hidden_no_facilitator_route",
        "speaker_notes_blocked_by_policy"
      ],
      "description": "Re-exported from schemas/ux/presentation_mode_state.schema.json."
    },

    "presenter_bar_visibility_class": {
      "type": "string",
      "enum": [
        "presenter_bar_visible_to_presenter_only",
        "presenter_bar_visible_to_co_presenters",
        "presenter_bar_hidden_audience_facing",
        "presenter_bar_unavailable_degraded_projection"
      ],
      "description": "Re-exported from schemas/ux/presentation_mode_state.schema.json."
    },

    "local_remote_shared_boundary_class": {
      "type": "string",
      "enum": [
        "local_only_machine_bound",
        "remote_relay_required",
        "shared_audience_managed_pool",
        "shared_audience_named_invitees",
        "boundary_unavailable_in_envelope"
      ],
      "description": "Re-exported from schemas/ux/presentation_mode_state.schema.json."
    },

    "follow_state_class": {
      "type": "string",
      "enum": [
        "no_follow_local_only",
        "presenter_broadcast_follow",
        "optional_follow_audience_choice",
        "audience_pinned_to_presenter",
        "follow_blocked_by_envelope"
      ],
      "description": "Closed follow-state vocabulary on the artifact. Reads as a posture, not as authority; mutating control rides a control_grant_record."
    },

    "replay_retention_class": {
      "type": "string",
      "enum": [
        "no_replay_retained",
        "metadata_only_replay_local_redacted",
        "metadata_only_replay_in_support_bundle_redacted",
        "replay_blocked_by_policy",
        "classroom_artifact_privacy_bounded"
      ],
      "description": "Re-exported from schemas/ux/presentation_mode_state.schema.json."
    },

    "reduced_motion_posture_class": {
      "type": "string",
      "enum": [
        "respects_user_reduced_motion_setting",
        "forced_reduced_motion_classroom_default",
        "forced_reduced_motion_policy_locked",
        "motion_unavailable_local_view_only"
      ],
      "description": "Re-exported from schemas/ux/presentation_mode_state.schema.json."
    },

    "accessibility_keyboard_class": {
      "type": "string",
      "enum": [
        "full_keyboard_route_required",
        "screen_reader_announcements_required",
        "high_contrast_focus_required",
        "no_special_accessibility_route_admitted_facilitator_only"
      ],
      "description": "Re-exported from schemas/ux/presentation_mode_state.schema.json."
    },

    "breakaway_recovery_class": {
      "type": "string",
      "enum": [
        "auto_rejoin_on_relay_recovery",
        "manual_rejoin_invite_required",
        "opt_out_until_session_end",
        "presenter_revoked_no_rejoin",
        "envelope_narrowed_no_rejoin"
      ],
      "description": "Re-exported from schemas/ux/presentation_mode_state.schema.json."
    },

    "evidence_hook_class": {
      "type": "string",
      "enum": [
        "tour_citation_audit",
        "cached_pack_continuity",
        "presentation_role_review",
        "layout_restore_proof",
        "privacy_bounded_classroom_artifact"
      ],
      "description": "Re-exported from schemas/ux/guided_tour.schema.json."
    },

    "deployment_profile_id": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud",
        "air_gapped_mirror_only"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": { "type": "string", "enum": ["trusted", "restricted"] },
        "execution_context_id": { "type": "string", "minLength": 1 }
      }
    },

    "denial_reason": {
      "type": "string",
      "enum": [
        "learning_artifact_session_share_state_envelope_mismatch",
        "learning_artifact_session_replay_retention_envelope_mismatch",
        "learning_artifact_session_authority_inferred_for_mutation",
        "learning_artifact_session_local_only_with_shared_audience",
        "teaching_session_artifact_schema_version_lagging"
      ]
    },

    "teaching_session_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "teaching_session_artifact_schema_version",
        "session_artifact_id",
        "session_class",
        "default_locale",
        "share_state_class",
        "audience_visibility_class",
        "speaker_note_locality_class",
        "presenter_bar_visibility_class",
        "local_remote_shared_boundary_class",
        "follow_state_class",
        "replay_retention_class",
        "reduced_motion_posture_class",
        "accessibility_keyboard_class",
        "breakaway_recovery_default_class",
        "deployment_profile_refs",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "teaching_session_artifact_schema_version": {
          "$ref": "#/$defs/teaching_session_artifact_schema_version"
        },
        "session_artifact_id": { "$ref": "#/$defs/opaque_id" },
        "session_class": { "$ref": "#/$defs/session_class" },
        "default_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "tour_pack_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Optional opaque pin to a tour pack the session walks through."
        },
        "glossary_pack_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "command_tip_pack_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "speaker_note_pack_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "share_state_class": { "$ref": "#/$defs/share_state_class" },
        "audience_visibility_class": { "$ref": "#/$defs/audience_visibility_class" },
        "speaker_note_locality_class": { "$ref": "#/$defs/speaker_note_locality_class" },
        "presenter_bar_visibility_class": { "$ref": "#/$defs/presenter_bar_visibility_class" },
        "local_remote_shared_boundary_class": { "$ref": "#/$defs/local_remote_shared_boundary_class" },
        "follow_state_class": { "$ref": "#/$defs/follow_state_class" },
        "replay_retention_class": { "$ref": "#/$defs/replay_retention_class" },
        "reduced_motion_posture_class": { "$ref": "#/$defs/reduced_motion_posture_class" },
        "accessibility_keyboard_class": { "$ref": "#/$defs/accessibility_keyboard_class" },
        "breakaway_recovery_default_class": { "$ref": "#/$defs/breakaway_recovery_class" },
        "deployment_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "evidence_hooks_reserved": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_hook_class" },
          "uniqueItems": true
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "denial_reason_on_deny": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/denial_reason" }
          ]
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "local_only_dry_run sessions forbid sharing, broadcast follow, and audience-visible surfaces.",
          "if": {
            "properties": { "session_class": { "const": "local_only_dry_run" } },
            "required": ["session_class"]
          },
          "then": {
            "properties": {
              "share_state_class": { "const": "local_only_no_share" },
              "audience_visibility_class": { "const": "audience_sees_nothing_local_view_only" },
              "follow_state_class": {
                "enum": ["no_follow_local_only", "follow_blocked_by_envelope"]
              },
              "local_remote_shared_boundary_class": {
                "enum": ["local_only_machine_bound", "boundary_unavailable_in_envelope"]
              }
            }
          }
        },
        {
          "description": "classroom_managed_session is admissible only on enterprise_online or managed_cloud profiles.",
          "if": {
            "properties": { "session_class": { "const": "classroom_managed_session" } },
            "required": ["session_class"]
          },
          "then": {
            "properties": {
              "deployment_profile_refs": {
                "type": "array",
                "contains": {
                  "enum": ["enterprise_online", "managed_cloud"]
                }
              },
              "share_state_class": {
                "enum": ["shared_to_classroom_managed_pool", "shared_to_facilitator_only"]
              }
            }
          }
        },
        {
          "description": "shared_to_classroom_managed_pool is admissible only on enterprise_online or managed_cloud profiles.",
          "if": {
            "properties": { "share_state_class": { "const": "shared_to_classroom_managed_pool" } },
            "required": ["share_state_class"]
          },
          "then": {
            "properties": {
              "deployment_profile_refs": {
                "type": "array",
                "contains": {
                  "enum": ["enterprise_online", "managed_cloud"]
                }
              }
            }
          }
        },
        {
          "description": "replay_blocked_by_policy and classroom_artifact_privacy_bounded retention classes MUST attach an evidence-hook reserve.",
          "if": {
            "properties": {
              "replay_retention_class": {
                "enum": ["replay_blocked_by_policy", "classroom_artifact_privacy_bounded"]
              }
            },
            "required": ["replay_retention_class"]
          },
          "then": {
            "properties": {
              "evidence_hooks_reserved": {
                "type": "array",
                "minItems": 1
              }
            },
            "required": ["evidence_hooks_reserved"]
          }
        },
        {
          "description": "local_only_no_share share state forbids audience-visible surfaces other than local_view_only.",
          "if": {
            "properties": { "share_state_class": { "const": "local_only_no_share" } },
            "required": ["share_state_class"]
          },
          "then": {
            "properties": {
              "audience_visibility_class": { "const": "audience_sees_nothing_local_view_only" }
            }
          }
        }
      ],
      "description": "One teaching session authoring artifact. See docs/ux/learning_artifact_object_model.md §1.5."
    }
  }
}
