{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/finish-the-migration-center-diff-rollback-and-unsupported.schema.json",
  "title": "Aureline migration-flow disclosure record",
  "description": "Boundary schema for migration_flow_disclosure_record, the single governed record the migration center, settings import history, command palette, diagnostics, support exports, Help/About, and docs all read for one imported-user flow on the claimed stable matrix. It is minted by crates/aureline-shell/src/migration_center_stable and binds, for one canonical migration identity: (1) the before/after diff — reviewed before apply, every row carrying both sides and citing one rollback checkpoint; (2) the rollback — a pre-apply checkpoint protecting every touched domain, with undo and compare routes when (and only when) the evidence is live for this flow; (3) the Exact/Translated/Partial/Shimmed/Unsupported taxonomy — with every Unsupported and Shimmed gap visible before apply; (4) a public claim ceiling — no row may assert the diff was reviewed, rollback is available, there are no unsupported gaps, or the import was full-fidelity unless the product can prove it; (5) a derived stable-claim verdict — a flow missing any pillar of evidence is narrowed below Stable with a named reason rather than inheriting an adjacent green row; (6) recovery/route/accessibility parity across the migration center, settings import history, command palette, and a menu command in normal/high-contrast/zoomed layouts; and (7) availability without an account or managed services. Top-level refs are opaque aureline://<class>/<id> durable-object refs; upstream and gap refs are upstream source paths.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "migration_session_ref",
    "source_ecosystem",
    "source_ecosystem_label",
    "title",
    "summary",
    "diff",
    "rollback",
    "taxonomy",
    "claim_ceiling",
    "stable_qualification",
    "recovery_routes",
    "surfaces",
    "routes",
    "accessibility",
    "available_without_account",
    "available_without_managed_services",
    "honesty_marker_present",
    "upstream",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": { "type": "string", "const": "migration_flow_disclosure_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "notice": { "$ref": "#/$defs/reviewable_sentence" },
    "shared_contract_ref": {
      "type": "string",
      "const": "shell:migration_flow_disclosure_stable:v1"
    },
    "record_id": { "$ref": "#/$defs/stable_token" },
    "as_of": { "$ref": "#/$defs/utc_date_time" },
    "migration_session_ref": { "$ref": "#/$defs/canonical_ref" },
    "source_ecosystem": { "$ref": "#/$defs/source_ecosystem" },
    "source_ecosystem_label": { "$ref": "#/$defs/non_empty_string" },
    "title": { "$ref": "#/$defs/reviewable_sentence" },
    "summary": { "$ref": "#/$defs/reviewable_sentence" },
    "diff": { "$ref": "#/$defs/diff_disclosure" },
    "rollback": { "$ref": "#/$defs/rollback_disclosure" },
    "taxonomy": { "$ref": "#/$defs/gap_taxonomy" },
    "claim_ceiling": { "$ref": "#/$defs/claim_ceiling" },
    "stable_qualification": { "$ref": "#/$defs/stable_qualification" },
    "recovery_routes": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/recovery_route" }
    },
    "surfaces": { "$ref": "#/$defs/surface_parity" },
    "routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/entry_route" }
    },
    "accessibility": { "$ref": "#/$defs/accessibility" },
    "available_without_account": { "type": "boolean", "const": true },
    "available_without_managed_services": { "type": "boolean", "const": true },
    "honesty_marker_present": { "type": "boolean" },
    "upstream": { "$ref": "#/$defs/upstream_refs" },
    "diagnostics_export_ref": { "$ref": "#/$defs/canonical_ref" },
    "support_export_ref": { "$ref": "#/$defs/canonical_ref" },
    "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/canonical_ref" } },
    "narrative_refs": { "type": "array", "items": { "$ref": "#/$defs/canonical_ref" } }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1, "maxLength": 200 },
    "reviewable_sentence": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "stable_token": { "type": "string", "minLength": 1, "maxLength": 200 },
    "source_path": { "type": "string", "minLength": 1, "maxLength": 300 },
    "utc_date_time": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "canonical_ref": {
      "type": "string",
      "description": "Opaque durable-object ref of the form aureline://<class>/<id>; <class> is not a generic landing page.",
      "pattern": "^aureline://(?!(home|dashboard|landing|index|overview|start|root)/)[^/]+/.+$",
      "maxLength": 200
    },
    "source_ecosystem": {
      "type": "string",
      "enum": ["vs_code_code_oss", "jetbrains_family", "vim_neovim", "emacs"]
    },
    "classification": {
      "type": "string",
      "enum": ["exact", "translated", "partial", "shimmed", "unsupported"]
    },
    "gap_classification": {
      "type": "string",
      "enum": ["shimmed", "unsupported"]
    },
    "import_domain": {
      "type": "string",
      "enum": [
        "settings",
        "shortcuts",
        "keymaps",
        "themes_and_visuals",
        "snippets_and_templates",
        "tasks_and_run_configs",
        "launch_debug",
        "extensions_and_providers",
        "workspace_profile"
      ]
    },
    "claim_class": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "not_claimed"]
    },
    "narrowing_reason": {
      "type": "string",
      "enum": [
        "diff_not_reviewed_before_apply",
        "rollback_evidence_incomplete",
        "unsupported_gaps_hidden_before_apply",
        "taxonomy_incomplete"
      ]
    },
    "recovery_action_role": {
      "type": "string",
      "enum": ["primary", "recovery", "secondary"]
    },
    "route_surface": {
      "type": "string",
      "enum": ["migration_center", "settings_import_history", "command_palette", "menu_command"]
    },
    "layout_mode": {
      "type": "string",
      "enum": ["normal", "high_contrast", "zoomed"]
    },
    "diff_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diff_preview_ref",
        "reviewed_before_apply",
        "row_count",
        "every_row_has_before_after",
        "every_row_uses_one_checkpoint"
      ],
      "properties": {
        "diff_preview_ref": { "$ref": "#/$defs/canonical_ref" },
        "reviewed_before_apply": { "type": "boolean" },
        "row_count": { "type": "integer", "minimum": 0 },
        "every_row_has_before_after": { "type": "boolean" },
        "every_row_uses_one_checkpoint": { "type": "boolean" }
      }
    },
    "rollback_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_ref",
        "restore_record_ref",
        "created_before_apply",
        "protects_every_domain",
        "verified_for_this_flow",
        "undo_available",
        "compare_available"
      ],
      "properties": {
        "checkpoint_ref": { "$ref": "#/$defs/canonical_ref" },
        "restore_record_ref": { "$ref": "#/$defs/canonical_ref" },
        "created_before_apply": { "type": "boolean" },
        "protects_every_domain": { "type": "boolean" },
        "verified_for_this_flow": { "type": "boolean" },
        "undo_available": { "type": "boolean" },
        "undo_action_ref": { "$ref": "#/$defs/canonical_ref" },
        "compare_available": { "type": "boolean" },
        "compare_action_ref": { "$ref": "#/$defs/canonical_ref" }
      }
    },
    "unsupported_gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gap_id",
        "domain",
        "classification",
        "source_label",
        "gap_summary",
        "visible_before_apply",
        "retained_after_apply",
        "docs_help_refs",
        "support_export_refs"
      ],
      "properties": {
        "gap_id": { "$ref": "#/$defs/stable_token" },
        "domain": { "$ref": "#/$defs/import_domain" },
        "classification": { "$ref": "#/$defs/gap_classification" },
        "source_label": { "$ref": "#/$defs/non_empty_string" },
        "gap_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "visible_before_apply": { "type": "boolean", "const": true },
        "retained_after_apply": { "type": "boolean" },
        "docs_help_refs": { "type": "array", "items": { "$ref": "#/$defs/source_path" } },
        "support_export_refs": { "type": "array", "items": { "$ref": "#/$defs/source_path" } }
      }
    },
    "gap_taxonomy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exact",
        "translated",
        "partial",
        "shimmed",
        "unsupported",
        "classifications_present",
        "unsupported_gaps_visible_before_apply",
        "gaps"
      ],
      "properties": {
        "exact": { "type": "integer", "minimum": 0 },
        "translated": { "type": "integer", "minimum": 0 },
        "partial": { "type": "integer", "minimum": 0 },
        "shimmed": { "type": "integer", "minimum": 0 },
        "unsupported": { "type": "integer", "minimum": 0 },
        "classifications_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/classification" }
        },
        "unsupported_gaps_visible_before_apply": { "type": "boolean", "const": true },
        "gaps": { "type": "array", "items": { "$ref": "#/$defs/unsupported_gap" } }
      }
    },
    "claim_ceiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asserts_diff_reviewed_before_apply",
        "asserts_rollback_available",
        "asserts_no_unsupported_gaps",
        "asserts_full_fidelity_import"
      ],
      "properties": {
        "asserts_diff_reviewed_before_apply": { "type": "boolean" },
        "asserts_rollback_available": { "type": "boolean" },
        "asserts_no_unsupported_gaps": { "type": "boolean" },
        "asserts_full_fidelity_import": { "type": "boolean" }
      }
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_class", "qualifies_stable", "narrowing_reasons"],
      "properties": {
        "claim_class": { "$ref": "#/$defs/claim_class" },
        "qualifies_stable": { "type": "boolean" },
        "narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        }
      }
    },
    "recovery_route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_label", "action_role", "keyboard_reachable"],
      "properties": {
        "action_id": { "$ref": "#/$defs/stable_token" },
        "action_label": { "$ref": "#/$defs/non_empty_string" },
        "action_role": { "$ref": "#/$defs/recovery_action_role" },
        "keyboard_reachable": { "type": "boolean", "const": true }
      }
    },
    "entry_route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "route_ref", "keyboard_reachable", "activates_same_flow"],
      "properties": {
        "surface": { "$ref": "#/$defs/route_surface" },
        "route_ref": { "$ref": "#/$defs/canonical_ref" },
        "keyboard_reachable": { "type": "boolean", "const": true },
        "activates_same_flow": { "type": "boolean", "const": true }
      }
    },
    "surface_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "migration_center_row_id",
        "settings_import_history_row_id",
        "command_palette_command_id",
        "recovery_action_ids",
        "reopen_surfaces",
        "parity_holds"
      ],
      "properties": {
        "migration_center_row_id": { "$ref": "#/$defs/stable_token" },
        "settings_import_history_row_id": { "$ref": "#/$defs/stable_token" },
        "command_palette_command_id": { "$ref": "#/$defs/non_empty_string" },
        "recovery_action_ids": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "reopen_surfaces": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "parity_holds": { "type": "boolean", "const": true }
      }
    },
    "layout_mode_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "row_narration_available", "recovery_affordances_reachable"],
      "properties": {
        "mode": { "$ref": "#/$defs/layout_mode" },
        "row_narration_available": { "type": "boolean", "const": true },
        "recovery_affordances_reachable": { "type": "boolean", "const": true }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_order_index",
        "tab_stop_count",
        "row_narration",
        "action_labels",
        "layout_modes"
      ],
      "properties": {
        "focus_order_index": { "type": "integer", "minimum": 0 },
        "tab_stop_count": { "type": "integer", "minimum": 1 },
        "row_narration": { "$ref": "#/$defs/reviewable_sentence" },
        "action_labels": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "layout_modes": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/layout_mode_disclosure" }
        }
      }
    },
    "upstream_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wizard_session_ref",
        "wizard_mapping_report_ref",
        "rollback_checkpoint_ref",
        "import_diff_preview_ref",
        "corpus_scoreboard_ref",
        "corpus_section_ref"
      ],
      "properties": {
        "wizard_session_ref": { "$ref": "#/$defs/non_empty_string" },
        "wizard_mapping_report_ref": { "$ref": "#/$defs/non_empty_string" },
        "rollback_checkpoint_ref": { "$ref": "#/$defs/non_empty_string" },
        "import_diff_preview_ref": { "$ref": "#/$defs/non_empty_string" },
        "corpus_scoreboard_ref": { "$ref": "#/$defs/non_empty_string" },
        "corpus_section_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  }
}
