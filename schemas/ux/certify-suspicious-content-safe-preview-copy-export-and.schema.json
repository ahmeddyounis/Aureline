{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/certify-suspicious-content-safe-preview-copy-export-and.schema.json",
  "title": "Aureline shell safe-preview record",
  "description": "Boundary schema for shell_safe_preview_record, the single governed record the shell surface, the activity center, the CLI inspector, Help/About, the diagnostics support export, and docs all read for one shell-adjacent surface posture that can render or hand off ambiguous content on the claimed-stable desktop matrix. It is minted by crates/aureline-shell/src/shell_safe_preview_stable as a genuine projection of the live content-safety detector and trust-class / representation vocabulary (crate aureline-content-safety). It binds, for one shell-adjacent surface identity: (1) the consumed trust class (RawText, SanitizedRich, TrustedLocalActive, IsolatedRemoteActive) and detector outcome; (2) explicit representation cues — a raw/reveal affordance, a representation label, and Copy raw / Copy rendered / Copy escaped choices that stay explicit whenever rendered meaning can differ from source bytes; (3) surfaced suspicious-content findings that keep their reveal affordances and a reachable escaped-copy path; (4) cue survival across the notification, activity-center, browser-handoff, support-export, and screenshot/evidence carriers without flattening to a generic preview; (5) a stricter preview boundary that trust-sensitive actions (install, attach, approve, publish, delete, open-external) show before commit; (6) accessibility cues announced rather than color-only across normal, high-contrast, and zoomed layouts; (7) per-OS conformance for macOS, Windows, and Linux; (8) a public claim ceiling no posture may exceed; and (9) a derived stable-claim verdict that narrows a posture which cannot prove a pillar, or whose lowest binding surface marker is below Stable, below Stable with a named reason. Minted refs are opaque aureline://<class>/<id> object refs; upstream refs keep their source scheme.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "posture_id",
    "posture_label",
    "title",
    "summary",
    "surface_class",
    "surface_id_ref",
    "is_trust_sensitive_action",
    "renders_rich_content",
    "surface_lifecycle_marker",
    "trust_class",
    "detector_outcome",
    "suspicious_content_present",
    "representation",
    "suspicious_findings",
    "representation_choices",
    "cue_survival",
    "a11y_cues",
    "platform_conformance",
    "surface_projections",
    "pillars",
    "claim_ceiling",
    "stable_qualification",
    "recovery_routes",
    "routes",
    "accessibility",
    "available_without_account",
    "available_without_managed_services",
    "honesty_marker_present",
    "upstream",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": { "const": "shell_safe_preview_record" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "notice": { "type": "string", "minLength": 1 },
    "shared_contract_ref": { "const": "shell:safe_preview_stable:v1" },
    "record_id": { "$ref": "#/$defs/presentRef" },
    "as_of": { "type": "string", "minLength": 1 },
    "posture_id": { "$ref": "#/$defs/presentRef" },
    "posture_label": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "surface_class": { "$ref": "#/$defs/surfaceClass" },
    "surface_id_ref": { "$ref": "#/$defs/presentRef" },
    "is_trust_sensitive_action": { "type": "boolean" },
    "renders_rich_content": { "type": "boolean" },
    "surface_lifecycle_marker": { "$ref": "#/$defs/lifecycleMarker" },
    "trust_class": { "$ref": "#/$defs/trustClass" },
    "detector_outcome": { "$ref": "#/$defs/detectorOutcome" },
    "suspicious_content_present": { "type": "boolean" },
    "representation": { "$ref": "#/$defs/representationCues" },
    "suspicious_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/suspiciousFinding" }
    },
    "representation_choices": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/representationChoice" }
    },
    "cue_survival": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/cueCarrierRow" }
    },
    "stricter_boundary": { "$ref": "#/$defs/stricterBoundary" },
    "a11y_cues": { "$ref": "#/$defs/a11yCues" },
    "platform_conformance": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/platformConformanceRow" }
    },
    "surface_projections": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/surfaceProjection" }
    },
    "pillars": { "$ref": "#/$defs/pillars" },
    "claim_ceiling": { "$ref": "#/$defs/claimCeiling" },
    "stable_qualification": { "$ref": "#/$defs/qualification" },
    "recovery_routes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/recoveryRoute" }
    },
    "routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/entryRoute" }
    },
    "accessibility": { "$ref": "#/$defs/accessibility" },
    "available_without_account": { "type": "boolean" },
    "available_without_managed_services": { "type": "boolean" },
    "honesty_marker_present": { "type": "boolean" },
    "upstream": { "$ref": "#/$defs/upstream" },
    "diagnostics_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "support_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } },
    "narrative_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } }
  },
  "$defs": {
    "canonicalRef": {
      "type": "string",
      "pattern": "^aureline://(?!home/|dashboard/|landing/|index/|overview/|start/|root/)[^/]+/.+$"
    },
    "presentRef": { "type": "string", "minLength": 1 },
    "lifecycleMarker": { "type": "string", "enum": ["preview", "beta", "stable"] },
    "claimClass": { "type": "string", "enum": ["stable", "beta", "preview", "not_claimed"] },
    "surfaceClass": {
      "type": "string",
      "enum": [
        "notification",
        "activity_center",
        "browser_handoff",
        "support_export",
        "screenshot_evidence",
        "install_review",
        "attach_review",
        "approve_surface",
        "publish_review",
        "delete_review",
        "open_external_handoff"
      ]
    },
    "trustClass": {
      "type": "string",
      "enum": ["RawText", "SanitizedRich", "TrustedLocalActive", "IsolatedRemoteActive"]
    },
    "detectorOutcome": {
      "type": "string",
      "enum": ["allow", "sanitize", "isolate", "block", "route_to_system_browser"]
    },
    "suspiciousContentClass": {
      "type": "string",
      "enum": [
        "bidi_control",
        "invisible_formatting",
        "mixed_script_confusable",
        "whole_script_confusable",
        "raw_rendered_divergence"
      ]
    },
    "representationActionId": {
      "type": "string",
      "enum": [
        "copy_raw",
        "copy_rendered",
        "copy_escaped",
        "export_sanitized_snapshot",
        "export_metadata_only"
      ]
    },
    "representationClass": {
      "type": "string",
      "enum": ["raw", "rendered", "escaped", "sanitized", "blocked_metadata_only"]
    },
    "bodyPosture": {
      "type": "string",
      "enum": [
        "exact_source_bytes",
        "rendered_view",
        "escaped_source_text",
        "sanitized_static_snapshot",
        "metadata_only_envelope"
      ]
    },
    "cueCarrier": {
      "type": "string",
      "enum": [
        "notification",
        "activity_center",
        "browser_handoff",
        "support_export",
        "screenshot_evidence"
      ]
    },
    "truthSurface": {
      "type": "string",
      "enum": ["shell_surface", "activity_center", "cli_inspect", "help_about", "support_export"]
    },
    "narrowingReason": {
      "type": "string",
      "enum": [
        "representation_cues_not_explicit",
        "suspicious_findings_flattened",
        "copy_export_not_labeled",
        "cues_flattened_on_carrier",
        "stricter_boundary_not_shown_before_commit",
        "accessibility_cues_incomplete",
        "platform_conformance_incomplete",
        "surface_not_yet_stable"
      ]
    },
    "profileClass": { "type": "string", "enum": ["macos", "windows", "linux"] },
    "recoveryRole": { "type": "string", "enum": ["primary", "recovery", "secondary"] },
    "routeSurface": {
      "type": "string",
      "enum": ["activity_center", "command_palette", "status_bar", "menu_command"]
    },
    "layoutMode": { "type": "string", "enum": ["normal", "high_contrast", "zoomed"] },
    "representationCues": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_reveal_available",
        "representation_label_present",
        "representation_label",
        "copy_raw_present",
        "copy_rendered_present",
        "explicit_when_meaning_differs"
      ],
      "properties": {
        "raw_reveal_available": { "type": "boolean" },
        "representation_label_present": { "type": "boolean" },
        "representation_label": { "type": "string", "minLength": 1 },
        "copy_raw_present": { "type": "boolean" },
        "copy_rendered_present": { "type": "boolean" },
        "explicit_when_meaning_differs": { "type": "boolean" }
      }
    },
    "suspiciousFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "content_class",
        "visibility_impact",
        "representation_label",
        "reveal_affordances",
        "raw_toggle_available",
        "escaped_copy_available"
      ],
      "properties": {
        "finding_id": { "type": "string", "minLength": 1 },
        "content_class": { "$ref": "#/$defs/suspiciousContentClass" },
        "visibility_impact": { "type": "string", "minLength": 1 },
        "representation_label": { "type": "string", "minLength": 1 },
        "reveal_affordances": { "type": "array", "items": { "type": "string" } },
        "raw_toggle_available": { "type": "boolean" },
        "escaped_copy_available": { "type": "boolean" }
      }
    },
    "representationChoice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "representation_class",
        "body_posture",
        "label",
        "raw_source_required",
        "active_content_removed"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/representationActionId" },
        "representation_class": { "$ref": "#/$defs/representationClass" },
        "body_posture": { "$ref": "#/$defs/bodyPosture" },
        "label": { "type": "string", "minLength": 1 },
        "raw_source_required": { "type": "boolean" },
        "active_content_removed": { "type": "boolean" }
      }
    },
    "cueCarrierRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "carrier",
        "preserves_trust_class",
        "preserves_representation_label",
        "preserves_suspicious_warning",
        "does_not_flatten_to_generic_preview",
        "carried_summary"
      ],
      "properties": {
        "carrier": { "$ref": "#/$defs/cueCarrier" },
        "preserves_trust_class": { "type": "boolean" },
        "preserves_representation_label": { "type": "boolean" },
        "preserves_suspicious_warning": { "type": "boolean" },
        "does_not_flatten_to_generic_preview": { "type": "boolean" },
        "carried_summary": { "type": "string", "minLength": 1 }
      }
    },
    "stricterBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "enforces_stricter_preview_class",
        "ordinary_browsing_class",
        "enforced_preview_class",
        "shows_boundary_before_commit",
        "commit_blocked_until_acknowledged",
        "boundary_disclosure"
      ],
      "properties": {
        "action": { "$ref": "#/$defs/surfaceClass" },
        "enforces_stricter_preview_class": { "type": "boolean" },
        "ordinary_browsing_class": { "$ref": "#/$defs/trustClass" },
        "enforced_preview_class": { "$ref": "#/$defs/trustClass" },
        "shows_boundary_before_commit": { "type": "boolean" },
        "commit_blocked_until_acknowledged": { "type": "boolean" },
        "boundary_disclosure": { "type": "string", "minLength": 1 }
      }
    },
    "a11yCues": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "warning_announced_not_color_only",
        "representation_label_announced",
        "trust_class_announced",
        "reveal_affordance_keyboard_reachable",
        "warning_summary_label"
      ],
      "properties": {
        "warning_announced_not_color_only": { "type": "boolean" },
        "representation_label_announced": { "type": "boolean" },
        "trust_class_announced": { "type": "boolean" },
        "reveal_affordance_keyboard_reachable": { "type": "boolean" },
        "warning_summary_label": { "type": "string", "minLength": 1 }
      }
    },
    "platformConformanceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "profile_id", "covered", "proof_ref", "named_behaviors"],
      "properties": {
        "profile": { "$ref": "#/$defs/profileClass" },
        "profile_id": { "type": "string", "minLength": 1 },
        "covered": { "type": "boolean" },
        "proof_ref": { "type": "string", "minLength": 1 },
        "named_behaviors": { "type": "array", "items": { "type": "string" } }
      }
    },
    "surfaceProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "surface_marker", "reads_shared_record", "summary_line"],
      "properties": {
        "surface": { "$ref": "#/$defs/truthSurface" },
        "surface_marker": { "$ref": "#/$defs/lifecycleMarker" },
        "reads_shared_record": { "type": "boolean" },
        "summary_line": { "type": "string", "minLength": 1 }
      }
    },
    "pillars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "representation_cues_explicit",
        "suspicious_findings_surfaced",
        "copy_export_labeled",
        "cues_survive_all_carriers",
        "stricter_boundary_shown_before_commit",
        "accessibility_cues_complete",
        "platform_conformance_complete"
      ],
      "properties": {
        "representation_cues_explicit": { "type": "boolean" },
        "suspicious_findings_surfaced": { "type": "boolean" },
        "copy_export_labeled": { "type": "boolean" },
        "cues_survive_all_carriers": { "type": "boolean" },
        "stricter_boundary_shown_before_commit": { "type": "boolean" },
        "accessibility_cues_complete": { "type": "boolean" },
        "platform_conformance_complete": { "type": "boolean" }
      }
    },
    "claimCeiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asserts_representation_cues_explicit",
        "asserts_suspicious_findings_surfaced",
        "asserts_copy_export_labeled",
        "asserts_cues_survive_all_carriers",
        "asserts_stricter_boundary_shown_before_commit",
        "asserts_accessibility_cues_complete",
        "asserts_platform_conformance_complete"
      ],
      "properties": {
        "asserts_representation_cues_explicit": { "type": "boolean" },
        "asserts_suspicious_findings_surfaced": { "type": "boolean" },
        "asserts_copy_export_labeled": { "type": "boolean" },
        "asserts_cues_survive_all_carriers": { "type": "boolean" },
        "asserts_stricter_boundary_shown_before_commit": { "type": "boolean" },
        "asserts_accessibility_cues_complete": { "type": "boolean" },
        "asserts_platform_conformance_complete": { "type": "boolean" }
      }
    },
    "qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_class", "qualifies_stable", "narrowing_reasons"],
      "properties": {
        "claim_class": { "$ref": "#/$defs/claimClass" },
        "qualifies_stable": { "type": "boolean" },
        "narrowing_reasons": { "type": "array", "items": { "$ref": "#/$defs/narrowingReason" } }
      }
    },
    "recoveryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_label", "action_role", "keyboard_reachable"],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_label": { "type": "string", "minLength": 1 },
        "action_role": { "$ref": "#/$defs/recoveryRole" },
        "keyboard_reachable": { "type": "boolean" }
      }
    },
    "entryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "route_ref", "keyboard_reachable", "activates_same_item"],
      "properties": {
        "surface": { "$ref": "#/$defs/routeSurface" },
        "route_ref": { "$ref": "#/$defs/canonicalRef" },
        "keyboard_reachable": { "type": "boolean" },
        "activates_same_item": { "type": "boolean" }
      }
    },
    "layoutModeDisclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "row_narration_available", "recovery_affordances_reachable"],
      "properties": {
        "mode": { "$ref": "#/$defs/layoutMode" },
        "row_narration_available": { "type": "boolean" },
        "recovery_affordances_reachable": { "type": "boolean" }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_order_index",
        "tab_stop_count",
        "row_narration",
        "action_labels",
        "layout_modes"
      ],
      "properties": {
        "focus_order_index": { "type": "integer", "minimum": 0 },
        "tab_stop_count": { "type": "integer", "minimum": 0 },
        "row_narration": { "type": "string", "minLength": 1 },
        "action_labels": { "type": "array", "items": { "type": "string" } },
        "layout_modes": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/layoutModeDisclosure" }
        }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content_safety_contract_ref",
        "trust_class_schema_version",
        "representation_policy_schema_version",
        "contributing_case_refs"
      ],
      "properties": {
        "content_safety_contract_ref": { "$ref": "#/$defs/presentRef" },
        "trust_class_schema_version": { "type": "integer", "minimum": 1 },
        "representation_policy_schema_version": { "type": "integer", "minimum": 1 },
        "contributing_case_refs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
