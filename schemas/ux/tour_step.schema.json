{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/tour_step.schema.json",
  "title": "Aureline tour step authoring artifact",
  "description": "Boundary schema for the tour step authoring artifact frozen in docs/ux/learning_artifact_object_model.md. One tour_step_artifact record per authored step in a tour pack. The record is the portable authoring object pack authors ship; the runtime tour_waypoint_record on schemas/ux/guided_tour.schema.json carries the render-time state for a step and resolves against this artifact by id. The contract mints no new layout_target_class, source_language_fallback_class, freshness_class, deployment_profile_id, or redaction_class vocabulary; those re-export verbatim from schemas/ux/guided_tour.schema.json, schemas/docs/citation_anchor.schema.json, schemas/governance/capability_lifecycle.schema.json, and artifacts/governance/deployment_profiles.yaml. Adding a new jargon_level_class, tip_intensity_class, target_ref_kind, completion_detector_kind, privacy_scope_class, or denial_reason is additive-minor and bumps tour_step_artifact_schema_version; repurposing an existing value is breaking and requires a new decision row. Raw URLs, raw absolute paths, raw screen coordinates, raw step bodies, raw prompt / completion text, and raw credential material never cross this boundary.",
  "type": "object",
  "$ref": "#/$defs/tour_step_artifact",
  "$defs": {
    "tour_step_artifact_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this tour-step artifact vocabulary export. Current value is 1."
    },

    "record_kind": {
      "type": "string",
      "const": "tour_step_artifact"
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests. Raw URLs, raw absolute paths, raw screen coordinates, raw step bodies, and raw credential material never appear here."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Short privacy-safe label text. Raw paths, raw URLs, raw secrets, and raw prompt / completion text are forbidden."
    },

    "body_summary_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Short privacy-safe step body summary. The authoritative body lives in the docs pack the citation anchor resolves against; this field is the bounded step-card body."
    },

    "bcp47_locale_tag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": { "type": "object", "additionalProperties": true },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "jargon_level_class": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced", "expert"],
      "description": "Closed jargon-level vocabulary."
    },

    "tip_intensity_class": {
      "type": "string",
      "enum": [
        "silent_inline_only",
        "gentle_hint",
        "prompted_acknowledge",
        "mandatory_step_required"
      ],
      "description": "Closed tip-intensity vocabulary. mandatory_step_required is admissible only on classroom-managed or facilitator-led profiles (see learning_artifact_object_model.md §7)."
    },

    "privacy_scope_class": {
      "type": "string",
      "enum": [
        "local_only_machine_bound",
        "profile_portable",
        "classroom_managed_pool",
        "facilitator_only",
        "audience_visible"
      ]
    },

    "derivation_class": {
      "type": "string",
      "enum": ["primary", "derived", "derived_with_upstream_anchors"],
      "description": "Re-exported from schemas/docs/citation_anchor.schema.json derivation."
    },

    "source_language_fallback_class": {
      "type": "string",
      "enum": [
        "no_fallback_locale_native",
        "fallback_to_source_language_disclosed",
        "fallback_blocked_locale_unavailable",
        "fallback_blocked_pack_missing"
      ],
      "description": "Re-exported from schemas/ux/guided_tour.schema.json without modification."
    },

    "layout_target_class": {
      "type": "string",
      "enum": [
        "start_center",
        "command_palette",
        "workspace_switcher",
        "primary_editor",
        "docs_pane",
        "architecture_map_canvas",
        "review_pane",
        "activity_center",
        "support_center",
        "settings_pane",
        "no_canvas_target_facilitator_only"
      ],
      "description": "Re-exported from schemas/ux/guided_tour.schema.json. Raw coordinates are forbidden."
    },

    "deployment_profile_id": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud",
        "air_gapped_mirror_only"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": { "type": "string", "enum": ["trusted", "restricted"] },
        "execution_context_id": { "type": "string", "minLength": 1 }
      }
    },

    "target_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_kind"],
      "oneOf": [
        { "required": ["target_kind", "command_id_ref"] },
        { "required": ["target_kind", "docs_citation_anchor_ref"] },
        { "required": ["target_kind", "symbol_linked_reference_ref"] },
        { "required": ["target_kind", "keymap_bridge_ref"] },
        { "required": ["target_kind", "layout_target_class"] }
      ],
      "properties": {
        "target_kind": {
          "type": "string",
          "enum": [
            "command_id_target",
            "docs_citation_anchor_target",
            "symbol_linked_reference_target",
            "keymap_bridge_target",
            "layout_target"
          ],
          "description": "Discriminator naming which typed stable target ref is populated. Raw screen coordinates and pixel rects are forbidden."
        },
        "command_id_ref": { "$ref": "#/$defs/opaque_id" },
        "docs_citation_anchor_ref": { "$ref": "#/$defs/opaque_id" },
        "symbol_linked_reference_ref": { "$ref": "#/$defs/opaque_id" },
        "keymap_bridge_ref": { "$ref": "#/$defs/opaque_id" },
        "layout_target_class": { "$ref": "#/$defs/layout_target_class" }
      },
      "description": "Stable target ref the step lands on. See learning_artifact_object_model.md §3."
    },

    "completion_detector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["detector_kind"],
      "allOf": [
        {
          "if": { "properties": { "detector_kind": { "const": "command_invocation_detector" } }, "required": ["detector_kind"] },
          "then": { "required": ["command_id_ref"] }
        },
        {
          "if": { "properties": { "detector_kind": { "const": "docs_anchor_seen_detector" } }, "required": ["detector_kind"] },
          "then": { "required": ["docs_citation_anchor_ref"] }
        },
        {
          "if": { "properties": { "detector_kind": { "const": "layout_focus_detector" } }, "required": ["detector_kind"] },
          "then": { "required": ["layout_target_class"] }
        },
        {
          "if": { "properties": { "detector_kind": { "const": "time_window_detector" } }, "required": ["detector_kind"] },
          "then": { "required": ["max_duration_seconds"] }
        }
      ],
      "properties": {
        "detector_kind": {
          "type": "string",
          "enum": [
            "command_invocation_detector",
            "docs_anchor_seen_detector",
            "layout_focus_detector",
            "time_window_detector",
            "manual_acknowledge_detector"
          ],
          "description": "Closed completion-detector vocabulary."
        },
        "command_id_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Required for command_invocation_detector. The detector fires when the user successfully invokes the canonical command_id; mutating exercise steps MUST pin the same command_id_ref the action was authored against (see §6 rule 2)."
        },
        "docs_citation_anchor_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Required for docs_anchor_seen_detector. The detector fires when the user reaches the cited anchor in the docs pane."
        },
        "layout_target_class": {
          "$ref": "#/$defs/layout_target_class",
          "description": "Required for layout_focus_detector. The detector fires when keyboard or pointer focus reaches the canonical layout target."
        },
        "max_duration_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400,
          "description": "Required (and >0) for time_window_detector. A time window with no cap is non-conforming."
        }
      },
      "description": "Closed completion-detector record. See §6."
    },

    "denial_reason": {
      "type": "string",
      "enum": [
        "learning_artifact_target_ref_not_canonical",
        "learning_artifact_promised_citation_missing",
        "learning_artifact_cites_forbidden_target",
        "learning_artifact_hidden_write_path",
        "learning_artifact_completion_detector_missing",
        "learning_artifact_tip_intensity_envelope_mismatch",
        "learning_artifact_privacy_scope_envelope_mismatch",
        "tour_step_artifact_schema_version_lagging"
      ],
      "description": "Closed denial-reason set publishers MUST emit when a tour-step artifact would otherwise carry inconsistent state."
    },

    "tour_step_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "tour_step_artifact_schema_version",
        "step_id",
        "tour_pack_ref",
        "pack_revision_ref",
        "position_index",
        "default_locale",
        "title_short_label",
        "body_summary",
        "jargon_level_class",
        "tip_intensity_class",
        "target_ref",
        "completion_detector",
        "allowed_action_refs",
        "derivation_class",
        "source_language_fallback_class",
        "deployment_profile_refs",
        "privacy_scope_class",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "tour_step_artifact_schema_version": {
          "$ref": "#/$defs/tour_step_artifact_schema_version"
        },
        "step_id": { "$ref": "#/$defs/opaque_id" },
        "tour_pack_ref": { "$ref": "#/$defs/opaque_id" },
        "pack_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "position_index": { "type": "integer", "minimum": 0 },
        "default_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "title_short_label": { "$ref": "#/$defs/short_label_text" },
        "body_summary": { "$ref": "#/$defs/body_summary_text" },
        "jargon_level_class": { "$ref": "#/$defs/jargon_level_class" },
        "tip_intensity_class": { "$ref": "#/$defs/tip_intensity_class" },
        "target_ref": { "$ref": "#/$defs/target_ref" },
        "completion_detector": { "$ref": "#/$defs/completion_detector" },
        "allowed_action_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Opaque pins to canonical command_ids on schemas/commands/command_registry_entry.schema.json. The shell MUST resolve every inline action on the rendered step through one of these and only these. A pack-private verb that is not a registry command_id is non-conforming (denial_reason = learning_artifact_hidden_write_path). Empty array is admissible for read-only walkthrough steps."
        },
        "primary_docs_citation_anchor_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Optional for layout-only steps; required when body_summary paraphrases or summarizes a docs source. The cited anchor MUST list a teaching reuse_surface (onboarding, glossary_card, ai_explanation_overlay, docs_pane, hosted_review_evidence)."
        },
        "upstream_citation_anchor_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Required (non-empty) when derivation_class = derived_with_upstream_anchors; empty otherwise."
        },
        "derivation_class": { "$ref": "#/$defs/derivation_class" },
        "source_language_fallback_class": { "$ref": "#/$defs/source_language_fallback_class" },
        "deployment_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "privacy_scope_class": { "$ref": "#/$defs/privacy_scope_class" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "denial_reason_on_deny": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/denial_reason" }
          ]
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "derived_with_upstream_anchors requires at least one upstream anchor; primary forbids them.",
          "if": {
            "properties": { "derivation_class": { "const": "derived_with_upstream_anchors" } },
            "required": ["derivation_class"]
          },
          "then": {
            "properties": {
              "upstream_citation_anchor_refs": { "type": "array", "minItems": 1 }
            }
          }
        },
        {
          "description": "primary derivation forbids upstream anchors.",
          "if": {
            "properties": { "derivation_class": { "const": "primary" } },
            "required": ["derivation_class"]
          },
          "then": {
            "properties": {
              "upstream_citation_anchor_refs": { "type": "array", "maxItems": 0 }
            }
          }
        },
        {
          "description": "command_invocation_detector pins a command_id_ref that MUST also appear in allowed_action_refs so completion follows from a permitted action.",
          "if": {
            "properties": {
              "completion_detector": {
                "properties": { "detector_kind": { "const": "command_invocation_detector" } }
              }
            }
          },
          "then": {
            "properties": {
              "completion_detector": { "required": ["command_id_ref"] }
            }
          }
        },
        {
          "description": "fallback_to_source_language_disclosed requires either no_fallback_locale_native is not used elsewhere; downstream waypoint records carry the locale_fallback_disclosed render flag.",
          "if": {
            "properties": {
              "source_language_fallback_class": {
                "const": "fallback_blocked_locale_unavailable"
              }
            }
          },
          "then": {
            "properties": {
              "primary_docs_citation_anchor_ref": { "type": "null" }
            }
          }
        }
      ],
      "description": "One tour step authoring artifact. See docs/ux/learning_artifact_object_model.md §1.2."
    }
  }
}
