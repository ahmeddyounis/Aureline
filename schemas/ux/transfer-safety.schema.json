{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/transfer-safety.schema.json",
  "title": "Aureline transfer-safety packet",
  "description": "Boundary schema for transfer_safety_packet, the shared record consumed by editor, terminal, notebook, docs, shell, and support surfaces to preserve plain-text copy truth, rich-content trust, boundary labels, high-risk paste guardrails, drag/drop verb previews, large-transfer feedback, and named undo-group lineage.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "schema_ref",
    "packet_id",
    "title",
    "summary",
    "surface",
    "action",
    "representation",
    "sensitive_review",
    "boundary_context",
    "paste_guardrail",
    "drop_preview",
    "undo_group",
    "large_transfer",
    "rich_content",
    "surface_projections",
    "support_export_refs"
  ],
  "properties": {
    "record_kind": { "const": "transfer_safety_packet" },
    "schema_version": { "const": 1 },
    "schema_ref": { "const": "schemas/ux/transfer-safety.schema.json" },
    "packet_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "surface": { "$ref": "#/$defs/surface" },
    "action": { "$ref": "#/$defs/action" },
    "representation": { "$ref": "#/$defs/representationTruth" },
    "sensitive_review": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/sensitiveReview" }
      ]
    },
    "boundary_context": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/boundaryContext" }
      ]
    },
    "paste_guardrail": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/pasteGuardrail" }
      ]
    },
    "drop_preview": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/dropPreview" }
      ]
    },
    "undo_group": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/undoGroup" }
      ]
    },
    "large_transfer": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/largeTransfer" }
      ]
    },
    "rich_content": { "$ref": "#/$defs/richContent" },
    "surface_projections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surfaceProjection" }
    },
    "support_export_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "surface": {
      "type": "string",
      "enum": ["editor", "terminal", "notebook", "docs", "support", "shell"]
    },
    "action": {
      "type": "string",
      "enum": [
        "copy",
        "paste",
        "drag_drop",
        "import",
        "attach",
        "open",
        "move",
        "split",
        "multi_file_replace",
        "ai_apply",
        "settings_import"
      ]
    },
    "representationClass": {
      "type": "string",
      "enum": [
        "raw",
        "rendered",
        "escaped",
        "sanitized",
        "sandboxed",
        "generated",
        "blocked_metadata_only"
      ]
    },
    "dropVerb": {
      "type": "string",
      "enum": ["move", "copy", "attach", "open", "import", "split"]
    },
    "boundaryClass": {
      "type": "string",
      "enum": [
        "local",
        "ssh_remote",
        "container",
        "managed_workspace",
        "browser_companion",
        "support_export"
      ]
    },
    "trustClass": {
      "type": "string",
      "enum": ["RawText", "SanitizedRich", "TrustedLocalActive", "IsolatedRemoteActive"]
    },
    "recoveryClass": {
      "type": "string",
      "enum": [
        "exact_undo",
        "restore_from_checkpoint",
        "compensating_rollback",
        "evidence_only_no_rerun"
      ]
    },
    "representationTruth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_plain_text_preserved",
        "raw_copy_available",
        "rendered_copy_available",
        "escaped_copy_available",
        "default_representation",
        "representation_label"
      ],
      "properties": {
        "default_plain_text_preserved": { "type": "boolean" },
        "raw_copy_available": { "type": "boolean" },
        "rendered_copy_available": { "type": "boolean" },
        "escaped_copy_available": { "type": "boolean" },
        "default_representation": { "$ref": "#/$defs/representationClass" },
        "representation_label": { "type": "string", "minLength": 1 }
      }
    },
    "sensitiveReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content_classes",
        "visible_label",
        "preview_before_commit",
        "boundary_crossing",
        "policy_gate_present"
      ],
      "properties": {
        "content_classes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "visible_label": { "type": "string", "minLength": 1 },
        "preview_before_commit": { "type": "boolean" },
        "boundary_crossing": { "type": "boolean" },
        "policy_gate_present": { "type": "boolean" }
      }
    },
    "boundaryContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["boundary_class", "visible_boundary_label", "shown_before_commit"],
      "properties": {
        "boundary_class": { "$ref": "#/$defs/boundaryClass" },
        "visible_boundary_label": { "type": "string", "minLength": 1 },
        "shown_before_commit": { "type": "boolean" }
      }
    },
    "pasteGuardrail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "line_count",
        "bracketed_paste_available",
        "automatic_submit_disabled",
        "confirmation_required",
        "review_summary"
      ],
      "properties": {
        "line_count": { "type": "integer", "minimum": 0 },
        "bracketed_paste_available": { "type": "boolean" },
        "automatic_submit_disabled": { "type": "boolean" },
        "confirmation_required": { "type": "boolean" },
        "review_summary": { "type": "string", "minLength": 1 }
      }
    },
    "dropPreview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verb",
        "insertion_indicator_visible",
        "modifier_cues_visible",
        "keyboard_route_available",
        "command_fallback_id"
      ],
      "properties": {
        "verb": { "$ref": "#/$defs/dropVerb" },
        "insertion_indicator_visible": { "type": "boolean" },
        "modifier_cues_visible": { "type": "boolean" },
        "keyboard_route_available": { "type": "boolean" },
        "command_fallback_id": { "type": "string", "minLength": 1 }
      }
    },
    "undoGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "named",
        "group_label",
        "source_attribution",
        "mutation_journal_entry_ref",
        "recovery_class",
        "history_surfaces"
      ],
      "properties": {
        "named": { "type": "boolean" },
        "group_label": { "type": "string", "minLength": 1 },
        "source_attribution": { "type": "string", "minLength": 1 },
        "mutation_journal_entry_ref": { "type": "string", "minLength": 1 },
        "recovery_class": { "$ref": "#/$defs/recoveryClass" },
        "history_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "largeTransfer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "progress_visible",
        "cancellation_available",
        "post_action_summary_present",
        "result_summary"
      ],
      "properties": {
        "progress_visible": { "type": "boolean" },
        "cancellation_available": { "type": "boolean" },
        "post_action_summary_present": { "type": "boolean" },
        "result_summary": { "type": "string", "minLength": 1 }
      }
    },
    "richContent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust_class",
        "active_content_blocked_or_isolated",
        "raw_source_available",
        "copy_plain_text_available"
      ],
      "properties": {
        "trust_class": { "$ref": "#/$defs/trustClass" },
        "active_content_blocked_or_isolated": { "type": "boolean" },
        "raw_source_available": { "type": "boolean" },
        "copy_plain_text_available": { "type": "boolean" }
      }
    },
    "surfaceProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "reads_shared_record", "summary_line"],
      "properties": {
        "surface": { "$ref": "#/$defs/surface" },
        "reads_shared_record": { "type": "boolean" },
        "summary_line": { "type": "string", "minLength": 1 }
      }
    }
  }
}
