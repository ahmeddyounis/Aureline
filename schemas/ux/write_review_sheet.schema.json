{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/write_review_sheet.schema.json",
  "title": "Aureline file-state write-review sheet contract",
  "description": "Boundary schema for one write_review_sheet_record frozen in docs/ux/file_state_badge_and_write_review_contract.md. The record is emitted when a user attempts a write-like action through a read-only, generated, policy-locked, managed/mirrored, projection, or captured-snapshot surface. It defines duplicate, detach, regenerate, create editable overlay, open canonical source, request approval, and export evidence actions, and requires each action to disclose side effects plus rollback/checkpoint posture. Raw file bodies, raw absolute paths, raw provider payloads, raw policy bodies, raw generated inputs, notebook output bytes, evidence payloads, credentials, and secrets never cross this boundary.",
  "type": "object",
  "$ref": "#/$defs/write_review_sheet_record",
  "$defs": {
    "write_review_sheet_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "write_review_sheet_record"
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9]+(?:[A-Za-z0-9_.:/-]*[A-Za-z0-9])?$"
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_id" },
        { "type": "null" }
      ]
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 900
    },
    "short_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "editor",
        "diff",
        "preview",
        "review",
        "notebook",
        "evidence",
        "support_export"
      ]
    },
    "object_kind": {
      "type": "string",
      "enum": [
        "local_source_file",
        "generated_artifact",
        "policy_locked_file",
        "managed_mirror",
        "projection_view",
        "captured_snapshot",
        "structured_artifact"
      ]
    },
    "file_state_badge_class": {
      "type": "string",
      "enum": [
        "read_only",
        "generated",
        "policy_locked",
        "managed_mirrored",
        "projection",
        "captured_snapshot"
      ]
    },
    "source_relation_class": {
      "type": "string",
      "enum": [
        "current_object_is_canonical",
        "canonical_source_elsewhere",
        "generator_output_from_canonical_source",
        "policy_rule_controls_current_object",
        "managed_upstream_is_canonical",
        "live_target_is_canonical",
        "captured_basis_is_canonical",
        "source_unknown"
      ]
    },
    "write_review_action_class": {
      "type": "string",
      "enum": [
        "duplicate",
        "detach",
        "regenerate",
        "create_editable_overlay",
        "open_canonical_source",
        "request_approval",
        "export_evidence"
      ]
    },
    "enabled_state": {
      "type": "string",
      "enum": ["enabled", "disabled", "blocked", "pending_review"]
    },
    "target_relation": {
      "type": "string",
      "enum": [
        "current_object",
        "canonical_source",
        "managed_upstream",
        "generator_plan",
        "policy_owner",
        "editable_overlay",
        "evidence_export",
        "local_duplicate"
      ]
    },
    "side_effect_class": {
      "type": "string",
      "enum": [
        "no_source_mutation",
        "local_duplicate_created",
        "managed_link_detached",
        "generated_artifact_replaced",
        "editable_overlay_created",
        "canonical_source_opened",
        "approval_ticket_requested",
        "evidence_export_created",
        "metadata_only_audit_event",
        "existing_object_preserved"
      ]
    },
    "checkpoint_class": {
      "type": "string",
      "enum": [
        "not_required_no_mutation",
        "pre_action_checkpoint_required",
        "checkpoint_already_minted",
        "reversible_by_deleting_duplicate",
        "rollback_by_regeneration",
        "rollback_by_reattach_or_restore",
        "approval_ticket_no_local_change",
        "evidence_export_no_source_mutation",
        "manual_recovery_required"
      ]
    },
    "resulting_state_class": {
      "type": "string",
      "enum": [
        "no_state_change",
        "editable_duplicate_created",
        "detached_editable_file",
        "generated_artifact_updated",
        "editable_overlay_created",
        "canonical_source_focused",
        "approval_pending",
        "evidence_exported"
      ]
    },
    "confirmation_requirement": {
      "type": "string",
      "enum": [
        "none",
        "required_before_action",
        "required_when_detaching_manager",
        "required_when_replacing_artifact",
        "approval_required_elsewhere"
      ]
    },
    "opened_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_family",
        "surface_instance_ref",
        "invoking_command_ref",
        "return_focus_ref"
      ],
      "properties": {
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "surface_instance_ref": { "$ref": "#/$defs/opaque_id" },
        "invoking_command_ref": { "$ref": "#/$defs/opaque_id" },
        "return_focus_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "current_object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_ref",
        "object_kind",
        "display_label",
        "current_badge_classes",
        "source_relation_class"
      ],
      "properties": {
        "object_ref": { "$ref": "#/$defs/opaque_id" },
        "object_kind": { "$ref": "#/$defs/object_kind" },
        "display_label": { "$ref": "#/$defs/short_label" },
        "current_badge_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/file_state_badge_class" },
          "minItems": 1,
          "uniqueItems": true
        },
        "source_relation_class": { "$ref": "#/$defs/source_relation_class" }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger_class",
        "requested_write_summary",
        "blocked_reason_ref"
      ],
      "properties": {
        "trigger_class": {
          "type": "string",
          "enum": [
            "attempted_write",
            "save_blocked",
            "direct_edit_requested",
            "drift_detected",
            "export_requested",
            "policy_review_requested"
          ]
        },
        "requested_write_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "blocked_reason_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "side_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "side_effect_class",
        "scope_ref",
        "summary"
      ],
      "properties": {
        "side_effect_class": { "$ref": "#/$defs/side_effect_class" },
        "scope_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "checkpoint_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_class",
        "checkpoint_ref",
        "local_history_entry_ref",
        "preserves_original_object",
        "rollback_or_recovery_summary"
      ],
      "properties": {
        "checkpoint_class": { "$ref": "#/$defs/checkpoint_class" },
        "checkpoint_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "local_history_entry_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "preserves_original_object": { "type": "boolean" },
        "rollback_or_recovery_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "result_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resulting_state_class",
        "resulting_object_ref",
        "closes_sheet",
        "followup_surface_ref"
      ],
      "properties": {
        "resulting_state_class": { "$ref": "#/$defs/resulting_state_class" },
        "resulting_object_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "closes_sheet": { "type": "boolean" },
        "followup_surface_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },
    "write_review_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "action_class",
        "label_text",
        "enabled_state",
        "command_ref",
        "target_relation",
        "target_ref",
        "side_effects",
        "checkpoint_posture",
        "result_state",
        "confirmation_requirement",
        "accessibility_summary"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "action_class": { "$ref": "#/$defs/write_review_action_class" },
        "label_text": { "$ref": "#/$defs/short_label" },
        "enabled_state": { "$ref": "#/$defs/enabled_state" },
        "command_ref": { "$ref": "#/$defs/opaque_id" },
        "target_relation": { "$ref": "#/$defs/target_relation" },
        "target_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "side_effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/side_effect" },
          "minItems": 1
        },
        "checkpoint_posture": { "$ref": "#/$defs/checkpoint_posture" },
        "result_state": { "$ref": "#/$defs/result_state" },
        "confirmation_requirement": { "$ref": "#/$defs/confirmation_requirement" },
        "accessibility_summary": { "$ref": "#/$defs/reviewable_sentence" }
      },
      "allOf": [
        {
          "if": { "properties": { "action_class": { "const": "duplicate" } }, "required": ["action_class"] },
          "then": {
            "properties": {
              "side_effects": { "contains": { "properties": { "side_effect_class": { "const": "local_duplicate_created" } }, "required": ["side_effect_class"] } },
              "checkpoint_posture": { "properties": { "checkpoint_class": { "enum": ["reversible_by_deleting_duplicate", "pre_action_checkpoint_required", "checkpoint_already_minted"] } } }
            }
          }
        },
        {
          "if": { "properties": { "action_class": { "const": "detach" } }, "required": ["action_class"] },
          "then": {
            "properties": {
              "side_effects": { "contains": { "properties": { "side_effect_class": { "const": "managed_link_detached" } }, "required": ["side_effect_class"] } },
              "checkpoint_posture": { "properties": { "checkpoint_class": { "enum": ["pre_action_checkpoint_required", "checkpoint_already_minted", "rollback_by_reattach_or_restore"] } } }
            }
          }
        },
        {
          "if": { "properties": { "action_class": { "const": "regenerate" } }, "required": ["action_class"] },
          "then": {
            "properties": {
              "side_effects": { "contains": { "properties": { "side_effect_class": { "const": "generated_artifact_replaced" } }, "required": ["side_effect_class"] } },
              "checkpoint_posture": { "properties": { "checkpoint_class": { "enum": ["pre_action_checkpoint_required", "checkpoint_already_minted", "rollback_by_regeneration"] } } }
            }
          }
        },
        {
          "if": { "properties": { "action_class": { "const": "create_editable_overlay" } }, "required": ["action_class"] },
          "then": {
            "properties": {
              "side_effects": { "contains": { "properties": { "side_effect_class": { "const": "editable_overlay_created" } }, "required": ["side_effect_class"] } },
              "checkpoint_posture": { "properties": { "checkpoint_class": { "enum": ["not_required_no_mutation", "checkpoint_already_minted"] } } }
            }
          }
        },
        {
          "if": { "properties": { "action_class": { "const": "open_canonical_source" } }, "required": ["action_class"] },
          "then": {
            "properties": {
              "side_effects": { "contains": { "properties": { "side_effect_class": { "const": "canonical_source_opened" } }, "required": ["side_effect_class"] } },
              "checkpoint_posture": { "properties": { "checkpoint_class": { "const": "not_required_no_mutation" } } }
            }
          }
        },
        {
          "if": { "properties": { "action_class": { "const": "request_approval" } }, "required": ["action_class"] },
          "then": {
            "properties": {
              "side_effects": { "contains": { "properties": { "side_effect_class": { "const": "approval_ticket_requested" } }, "required": ["side_effect_class"] } },
              "checkpoint_posture": { "properties": { "checkpoint_class": { "const": "approval_ticket_no_local_change" } } }
            }
          }
        },
        {
          "if": { "properties": { "action_class": { "const": "export_evidence" } }, "required": ["action_class"] },
          "then": {
            "properties": {
              "side_effects": { "contains": { "properties": { "side_effect_class": { "const": "evidence_export_created" } }, "required": ["side_effect_class"] } },
              "checkpoint_posture": { "properties": { "checkpoint_class": { "const": "evidence_export_no_source_mutation" } } }
            }
          }
        }
      ]
    },
    "action_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommended_primary_action_class",
        "safe_default_action_id",
        "destructive_action_present",
        "all_actions_have_side_effects_and_checkpoint"
      ],
      "properties": {
        "recommended_primary_action_class": { "$ref": "#/$defs/write_review_action_class" },
        "safe_default_action_id": { "$ref": "#/$defs/opaque_id" },
        "destructive_action_present": { "type": "boolean" },
        "all_actions_have_side_effects_and_checkpoint": { "type": "boolean", "const": true }
      }
    },
    "consequence_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "side_effect_summary",
        "rollback_summary",
        "irreversible_warning",
        "safe_cancel_available"
      ],
      "properties": {
        "side_effect_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "rollback_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "irreversible_warning": {
          "oneOf": [
            { "$ref": "#/$defs/reviewable_sentence" },
            { "type": "null" }
          ]
        },
        "safe_cancel_available": { "type": "boolean" }
      }
    },
    "close_and_focus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "close_behavior_class",
        "esc_behavior_class",
        "focus_return_ref"
      ],
      "properties": {
        "close_behavior_class": {
          "type": "string",
          "enum": [
            "cancel_no_state_change",
            "explicit_discard_required",
            "blocked_until_review_decision",
            "handoff_then_close",
            "platform_host_owned"
          ]
        },
        "esc_behavior_class": {
          "type": "string",
          "enum": [
            "same_as_cancel",
            "returns_to_sheet",
            "opens_discard_review",
            "ignored_while_required_step_pending"
          ]
        },
        "focus_return_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "export_and_accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accessible_name",
        "support_export_field_refs",
        "raw_private_material_excluded",
        "state_vocabulary_preserved"
      ],
      "properties": {
        "accessible_name": { "$ref": "#/$defs/reviewable_sentence" },
        "support_export_field_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "minItems": 1,
          "uniqueItems": true
        },
        "raw_private_material_excluded": { "type": "boolean", "const": true },
        "state_vocabulary_preserved": { "type": "boolean", "const": true }
      }
    },
    "write_review_sheet_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "write_review_sheet_schema_version",
        "write_review_sheet_id",
        "opened_from",
        "current_object",
        "badge_group_ref",
        "trigger",
        "action_summary",
        "available_actions",
        "consequence_block",
        "close_and_focus",
        "export_and_accessibility",
        "narrative_refs"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "write_review_sheet_schema_version": { "$ref": "#/$defs/write_review_sheet_schema_version" },
        "write_review_sheet_id": { "$ref": "#/$defs/opaque_id" },
        "opened_from": { "$ref": "#/$defs/opened_from" },
        "current_object": { "$ref": "#/$defs/current_object" },
        "badge_group_ref": { "$ref": "#/$defs/opaque_id" },
        "trigger": { "$ref": "#/$defs/trigger" },
        "action_summary": { "$ref": "#/$defs/action_summary" },
        "available_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/write_review_action" },
          "minItems": 1
        },
        "consequence_block": { "$ref": "#/$defs/consequence_block" },
        "close_and_focus": { "$ref": "#/$defs/close_and_focus" },
        "export_and_accessibility": { "$ref": "#/$defs/export_and_accessibility" },
        "narrative_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  }
}
