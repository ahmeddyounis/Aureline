{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/locale_fallback_state.schema.json",
  "title": "Aureline locale fallback state record",
  "description": "Boundary schema for the locale_fallback_state_record frozen in docs/ux/localization_and_locale_pack_contract.md. Every presentation event that renders a localized surface from anything other than an authoritative requested-locale pack — partial coverage, base-locale fill, source-language fallback, pack signature failure, missing pack, or policy-disabled locale — emits one record of this shape, naming the fallback origin, the degraded-localization state, the fallback chain that was walked, the pack refs and signature states consulted, the disclosure flag, the source-language escape hatches that remain available, the surface family the fallback applies to, and the command-id preservation state across the fallback. Adding a new locale_fallback_origin_class, degraded_localization_state, command_id_preservation_state, or denial_reason is additive-minor and bumps message_catalog_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "$ref": "#/$defs/locale_fallback_state_record",
  "$defs": {
    "message_catalog_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Lock-step with schemas/ux/message_catalog_entry.schema.json and schemas/ux/locale_pack_manifest.schema.json."
    },

    "record_kind": {
      "type": "string",
      "const": "locale_fallback_state_record"
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests / support bundles."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },

    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },

    "bcp47_locale_tag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$",
      "description": "BCP-47 language tag re-exported from schemas/docs/citation_anchor.schema.json without modification."
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "message_surface_family": {
      "type": "string",
      "enum": [
        "shell_chrome",
        "command_label",
        "settings_help_or_error",
        "docs_tour_or_auth_text",
        "extension_contributed_ui",
        "cli_help_text",
        "export_or_report_heading",
        "screenshot_or_demo_caption",
        "glossary_or_terminology_term",
        "policy_legal_or_recovery_text",
        "pseudoloc_only_test_string"
      ],
      "description": "Re-exported from schemas/ux/message_catalog_entry.schema.json without modification."
    },

    "locale_fallback_origin_class": {
      "type": "string",
      "enum": [
        "requested_locale_authoritative",
        "requested_locale_partial_with_base_fill",
        "base_locale_fallback",
        "source_language_fallback",
        "pack_signature_failed_source_language_only",
        "pack_missing_source_language_only",
        "policy_disabled_source_language_only"
      ],
      "description": "Closed locale-fallback origin-class vocabulary. See §7."
    },

    "degraded_localization_state": {
      "type": "string",
      "enum": [
        "fully_localized",
        "partial_translation_disclosed",
        "mixed_locale_strict_separation",
        "glossary_only_localized",
        "source_language_with_pseudoloc",
        "failed_pack_source_language_only"
      ],
      "description": "Closed degraded-localization state vocabulary. See §7."
    },

    "source_language_escape_hatch_class": {
      "type": "string",
      "enum": [
        "inline_source_language_toggle",
        "command_open_in_source_language",
        "docs_pane_source_language_route",
        "cli_locale_neutral_output_flag",
        "export_in_source_language_for_review"
      ],
      "description": "Re-exported from schemas/ux/message_catalog_entry.schema.json without modification."
    },

    "machine_output_locale_class": {
      "type": "string",
      "enum": [
        "locale_neutral_canonical",
        "locale_neutral_with_translated_human_field",
        "locale_native_human_only",
        "forbidden_for_machine_output"
      ],
      "description": "Re-exported from schemas/ux/message_catalog_entry.schema.json without modification."
    },

    "locale_pack_signature_state": {
      "type": "string",
      "enum": [
        "signed_verified",
        "signed_unverified",
        "unsigned_explicit_acceptance",
        "signature_failed_blocked",
        "not_applicable_built_in"
      ],
      "description": "Re-exported from schemas/ux/locale_pack_manifest.schema.json without modification."
    },

    "command_id_preservation_state": {
      "type": "string",
      "enum": [
        "command_id_unchanged_across_fallback",
        "command_id_drifted_blocked",
        "not_applicable"
      ],
      "description": "Closed command-id preservation state vocabulary. See §7. command_id_drifted_blocked forces a denial."
    },

    "denial_reason": {
      "type": "string",
      "enum": [
        "localization_message_id_collision",
        "localization_command_id_inferred_from_translated_label",
        "localization_locale_pack_signature_failed",
        "localization_locale_pack_compatibility_drift",
        "localization_translation_in_locale_neutral_output",
        "localization_fallback_chain_not_disclosed",
        "localization_source_language_escape_hatch_missing",
        "localization_screenshot_caption_lacks_governance",
        "localization_glossary_term_paraphrased_without_ref",
        "localization_policy_or_legal_text_translated_without_review",
        "localization_late_copy_change_after_string_freeze_unreviewed",
        "localization_extension_overlay_overrides_canonical_command_label",
        "localization_pseudoloc_string_rendered_in_production",
        "localization_placeholder_semantics_violated",
        "localization_message_catalog_schema_version_lagging"
      ],
      "description": "Re-exported from schemas/ux/message_catalog_entry.schema.json without modification."
    },

    "deployment_profile_id": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud"
      ],
      "description": "Re-exported from artifacts/governance/deployment_profiles.yaml deployment_profile_vocabulary without modification."
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ],
      "description": "Re-exported from schemas/governance/capability_lifecycle.schema.json without modification (ADR-0011)."
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted"]
        },
        "execution_context_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },

    "pack_consultation_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pack_ref", "signature_state"],
      "properties": {
        "pack_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque pin to a locale_pack_manifest_record consulted during fallback resolution."
        },
        "signature_state": { "$ref": "#/$defs/locale_pack_signature_state" },
        "consulted_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "produced_message": {
          "type": "boolean",
          "description": "True when this pack contributed the rendered message; false when it was consulted but skipped (signature failure, missing surface family, compatibility drift)."
        }
      }
    },

    "locale_fallback_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "message_catalog_schema_version",
        "state_id",
        "requested_locale",
        "effective_locale",
        "source_language_locale",
        "fallback_origin_class",
        "degraded_localization_state",
        "fallback_chain_walked",
        "packs_consulted",
        "disclosed_to_reviewer",
        "source_language_escape_hatches_active",
        "surface_family",
        "command_id_preservation_state",
        "machine_output_locale_class",
        "deployment_profile_refs",
        "policy_context",
        "redaction_class",
        "target_build_identity_ref",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "locale_fallback_state_record" },
        "message_catalog_schema_version": { "$ref": "#/$defs/message_catalog_schema_version" },
        "state_id": { "$ref": "#/$defs/opaque_id" },
        "requested_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "effective_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "source_language_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "fallback_origin_class": { "$ref": "#/$defs/locale_fallback_origin_class" },
        "degraded_localization_state": { "$ref": "#/$defs/degraded_localization_state" },
        "fallback_chain_walked": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bcp47_locale_tag" },
          "uniqueItems": true,
          "description": "Ordered BCP-47 list of locales that were checked. Begins with requested_locale; ends with effective_locale."
        },
        "packs_consulted": {
          "type": "array",
          "items": { "$ref": "#/$defs/pack_consultation_descriptor" },
          "uniqueItems": true,
          "description": "Pack-level consultation trail. Empty only when the rendering surface is built-in chrome with no pack consultation."
        },
        "message_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Opaque pin to the message_catalog_entry_record this fallback event applies to. Null on aggregate / surface-wide events that cover many ids."
        },
        "command_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Opaque pin to the canonical command_id when surface_family = command_label. The id MUST NOT change across locales."
        },
        "disclosed_to_reviewer": {
          "type": "boolean",
          "description": "True when the surface presents a fallback disclosure (chip, badge, banner, JSON metadata field) to the reviewer. MUST be true for any fallback_origin_class != requested_locale_authoritative."
        },
        "source_language_escape_hatches_active": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_language_escape_hatch_class" },
          "uniqueItems": true,
          "description": "Escape-hatch routes that remain available to the user under this fallback. Required (minItems 1) for any non-authoritative origin."
        },
        "surface_family": { "$ref": "#/$defs/message_surface_family" },
        "command_id_preservation_state": { "$ref": "#/$defs/command_id_preservation_state" },
        "machine_output_locale_class": { "$ref": "#/$defs/machine_output_locale_class" },
        "deployment_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "denial_reason_on_deny": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/denial_reason" }
          ],
          "description": "Required (non-null) when the fallback resolution was denied (e.g. signature failure rendered as an error, command-id drift blocked, schema version lag)."
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "target_build_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "presentation_subtitle": { "$ref": "#/$defs/short_label_text" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Authoritative origin requires fully_localized state and effective_locale = requested_locale.",
          "if": {
            "properties": {
              "fallback_origin_class": { "const": "requested_locale_authoritative" }
            },
            "required": ["fallback_origin_class"]
          },
          "then": {
            "properties": {
              "degraded_localization_state": { "const": "fully_localized" }
            }
          }
        },
        {
          "description": "Non-authoritative origins MUST disclose to the reviewer.",
          "if": {
            "properties": {
              "fallback_origin_class": {
                "enum": [
                  "requested_locale_partial_with_base_fill",
                  "base_locale_fallback",
                  "source_language_fallback",
                  "pack_signature_failed_source_language_only",
                  "pack_missing_source_language_only",
                  "policy_disabled_source_language_only"
                ]
              }
            },
            "required": ["fallback_origin_class"]
          },
          "then": {
            "properties": {
              "disclosed_to_reviewer": { "const": true },
              "source_language_escape_hatches_active": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        },
        {
          "description": "Authoritative origin permits an empty escape-hatch list (the surface is fully localized).",
          "if": {
            "properties": {
              "fallback_origin_class": { "const": "requested_locale_authoritative" }
            },
            "required": ["fallback_origin_class"]
          },
          "then": {
            "properties": {
              "degraded_localization_state": { "const": "fully_localized" }
            }
          }
        },
        {
          "description": "Source-language-only origins force degraded_localization_state and effective_locale alignment.",
          "if": {
            "properties": {
              "fallback_origin_class": {
                "enum": [
                  "source_language_fallback",
                  "pack_missing_source_language_only",
                  "policy_disabled_source_language_only"
                ]
              }
            },
            "required": ["fallback_origin_class"]
          },
          "then": {
            "properties": {
              "degraded_localization_state": {
                "enum": [
                  "source_language_with_pseudoloc",
                  "glossary_only_localized",
                  "mixed_locale_strict_separation",
                  "failed_pack_source_language_only",
                  "partial_translation_disclosed"
                ]
              }
            }
          }
        },
        {
          "description": "Signature-failure origin forces failed_pack_source_language_only state.",
          "if": {
            "properties": {
              "fallback_origin_class": { "const": "pack_signature_failed_source_language_only" }
            },
            "required": ["fallback_origin_class"]
          },
          "then": {
            "properties": {
              "degraded_localization_state": { "const": "failed_pack_source_language_only" }
            }
          }
        },
        {
          "description": "command_label fallback events MUST preserve the canonical command id.",
          "if": {
            "properties": { "surface_family": { "const": "command_label" } },
            "required": ["surface_family"]
          },
          "then": {
            "properties": {
              "command_id_preservation_state": { "const": "command_id_unchanged_across_fallback" },
              "command_id_ref": { "$ref": "#/$defs/opaque_id" }
            },
            "required": ["command_id_ref"]
          }
        },
        {
          "description": "command_id_drifted_blocked forces a denial reason.",
          "if": {
            "properties": {
              "command_id_preservation_state": { "const": "command_id_drifted_blocked" }
            },
            "required": ["command_id_preservation_state"]
          },
          "then": {
            "properties": {
              "denial_reason_on_deny": { "const": "localization_command_id_inferred_from_translated_label" }
            },
            "required": ["denial_reason_on_deny"]
          }
        },
        {
          "description": "cli_help_text fallback events MUST advertise cli_locale_neutral_output_flag.",
          "if": {
            "properties": { "surface_family": { "const": "cli_help_text" } },
            "required": ["surface_family"]
          },
          "then": {
            "properties": {
              "source_language_escape_hatches_active": {
                "type": "array",
                "minItems": 1,
                "contains": { "const": "cli_locale_neutral_output_flag" }
              }
            }
          }
        }
      ],
      "description": "One locale fallback state record. See docs/ux/localization_and_locale_pack_contract.md §1.3 / §7."
    }
  }
}
