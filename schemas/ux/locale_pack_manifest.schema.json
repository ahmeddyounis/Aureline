{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/locale_pack_manifest.schema.json",
  "title": "Aureline locale-pack manifest record",
  "description": "Boundary schema for the locale_pack_manifest_record frozen in docs/ux/localization_and_locale_pack_contract.md. Every locale pack — built-in, mirrored official, community-supplied, extension overlay, or air-gapped offline — declares its identity, fallback chain, distribution class, signature state, mirrorability, compatibility range to the running build, the surface families it covers, the partial-coverage families that force fallback disclosure, the extension overlay packs riding it, and the deployment profiles it is admissible under. Adding a new locale_pack_distribution_class, locale_pack_signature_state, or locale_pack_mirrorability_class is additive-minor and bumps message_catalog_schema_version; repurposing an existing value is breaking and requires a new decision row. Raw pack bodies, raw URLs, raw absolute paths, raw signing keys, and raw credential material never cross this boundary.",
  "type": "object",
  "$ref": "#/$defs/locale_pack_manifest_record",
  "$defs": {
    "message_catalog_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Lock-step with schemas/ux/message_catalog_entry.schema.json and schemas/ux/locale_fallback_state.schema.json."
    },

    "record_kind": {
      "type": "string",
      "const": "locale_pack_manifest_record"
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests / support bundles. Raw URLs, raw absolute paths, raw signing keys never appear here."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },

    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "description": "Short privacy-safe label text. MUST NOT embed raw paths, raw URLs, raw secret material."
    },

    "bcp47_locale_tag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$",
      "description": "BCP-47 language tag re-exported from schemas/docs/citation_anchor.schema.json without modification."
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "message_surface_family": {
      "type": "string",
      "enum": [
        "shell_chrome",
        "command_label",
        "settings_help_or_error",
        "docs_tour_or_auth_text",
        "extension_contributed_ui",
        "cli_help_text",
        "export_or_report_heading",
        "screenshot_or_demo_caption",
        "glossary_or_terminology_term",
        "policy_legal_or_recovery_text",
        "pseudoloc_only_test_string"
      ],
      "description": "Re-exported from schemas/ux/message_catalog_entry.schema.json without modification."
    },

    "locale_pack_distribution_class": {
      "type": "string",
      "enum": [
        "built_in_with_product",
        "mirrored_official_pack",
        "community_supplied_pack",
        "extension_overlay_pack",
        "air_gapped_offline_pack"
      ],
      "description": "Closed locale-pack distribution-class vocabulary. See §5."
    },

    "locale_pack_signature_state": {
      "type": "string",
      "enum": [
        "signed_verified",
        "signed_unverified",
        "unsigned_explicit_acceptance",
        "signature_failed_blocked",
        "not_applicable_built_in"
      ],
      "description": "Closed locale-pack signature-state vocabulary. See §5. signature_failed_blocked packs MUST NOT render messages."
    },

    "locale_pack_mirrorability_class": {
      "type": "string",
      "enum": [
        "mirror_allowed",
        "mirror_with_attribution_required",
        "mirror_forbidden",
        "air_gapped_only",
        "not_mirrorable_signed_blob"
      ],
      "description": "Closed locale-pack mirrorability-class vocabulary. See §5."
    },

    "version_match_state": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ],
      "description": "Re-exported from schemas/docs/citation_anchor.schema.json version_match_state without modification (ADR-0013)."
    },

    "deployment_profile_id": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud"
      ],
      "description": "Re-exported from artifacts/governance/deployment_profiles.yaml deployment_profile_vocabulary without modification."
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ],
      "description": "Re-exported from schemas/governance/capability_lifecycle.schema.json without modification (ADR-0011)."
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted"]
        },
        "execution_context_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },

    "compatibility_build_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_build_identity_ref", "max_build_identity_ref"],
      "properties": {
        "min_build_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "max_build_identity_ref": { "$ref": "#/$defs/opaque_id" }
      },
      "description": "Inclusive [min, max] build-identity range this pack revision is compatible with. Outside the range, compatibility_class MUST resolve to incompatible_drift_detected."
    },

    "locale_pack_manifest_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "message_catalog_schema_version",
        "pack_id",
        "pack_revision_ref",
        "locale",
        "coverage_locales",
        "source_language_locale",
        "base_locale_fallback_chain",
        "distribution_class",
        "signature_state",
        "mirrorability_class",
        "compatibility_class",
        "compatibility_build_range",
        "covered_surface_families",
        "partially_translated_surface_families",
        "extension_overlay_pack_refs",
        "permitted_deployment_profiles",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "locale_pack_manifest_record" },
        "message_catalog_schema_version": { "$ref": "#/$defs/message_catalog_schema_version" },
        "pack_id": { "$ref": "#/$defs/opaque_id" },
        "pack_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "coverage_locales": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bcp47_locale_tag" },
          "uniqueItems": true,
          "description": "BCP-47 tags this pack revision is admissible under (e.g. pt-BR plus pt as a coverage proxy). Always includes locale."
        },
        "source_language_locale": {
          "$ref": "#/$defs/bcp47_locale_tag",
          "description": "BCP-47 tag for the project source language (typically en or en-US). The base_locale_fallback_chain MUST terminate at this tag."
        },
        "base_locale_fallback_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bcp47_locale_tag" },
          "uniqueItems": true,
          "description": "Ordered list of BCP-47 tags consulted when a message id is missing from the requested locale. MUST end at source_language_locale."
        },
        "distribution_class": { "$ref": "#/$defs/locale_pack_distribution_class" },
        "signature_state": { "$ref": "#/$defs/locale_pack_signature_state" },
        "mirrorability_class": { "$ref": "#/$defs/locale_pack_mirrorability_class" },
        "compatibility_class": { "$ref": "#/$defs/version_match_state" },
        "compatibility_build_range": { "$ref": "#/$defs/compatibility_build_range" },
        "covered_surface_families": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/message_surface_family" },
          "uniqueItems": true,
          "description": "Surface families this pack revision covers. Empty packs are non-conforming."
        },
        "partially_translated_surface_families": {
          "type": "array",
          "items": { "$ref": "#/$defs/message_surface_family" },
          "uniqueItems": true,
          "description": "Subset of covered_surface_families whose coverage is partial. Forces a locale_fallback_state_record disclosure for the gaps."
        },
        "extension_overlay_pack_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Opaque ids of extension locale overlay packs riding this pack."
        },
        "extension_namespace_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "When distribution_class = extension_overlay_pack, the extension namespace(s) this pack contributes overlay entries for. Required (minItems 1) for extension_overlay_pack distribution; forbidden (maxItems 0) otherwise."
        },
        "permitted_deployment_profiles": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "explicit_acceptance_decision_row_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Opaque pin to the decision row authorising rendering for unsigned_explicit_acceptance packs. Required (non-null) when signature_state = unsigned_explicit_acceptance."
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "built_in_with_product packs MUST carry signature_state = not_applicable_built_in.",
          "if": {
            "properties": { "distribution_class": { "const": "built_in_with_product" } },
            "required": ["distribution_class"]
          },
          "then": {
            "properties": {
              "signature_state": { "const": "not_applicable_built_in" }
            }
          }
        },
        {
          "description": "Non-built-in packs MUST NOT carry signature_state = not_applicable_built_in.",
          "if": {
            "properties": {
              "distribution_class": {
                "enum": [
                  "mirrored_official_pack",
                  "community_supplied_pack",
                  "extension_overlay_pack",
                  "air_gapped_offline_pack"
                ]
              }
            },
            "required": ["distribution_class"]
          },
          "then": {
            "properties": {
              "signature_state": {
                "enum": [
                  "signed_verified",
                  "signed_unverified",
                  "unsigned_explicit_acceptance",
                  "signature_failed_blocked"
                ]
              }
            }
          }
        },
        {
          "description": "air_gapped_offline_pack distribution restricts mirrorability.",
          "if": {
            "properties": { "distribution_class": { "const": "air_gapped_offline_pack" } },
            "required": ["distribution_class"]
          },
          "then": {
            "properties": {
              "mirrorability_class": {
                "enum": [
                  "mirror_allowed",
                  "mirror_with_attribution_required",
                  "air_gapped_only"
                ]
              }
            }
          }
        },
        {
          "description": "extension_overlay_pack distribution requires extension_namespace_refs.",
          "if": {
            "properties": { "distribution_class": { "const": "extension_overlay_pack" } },
            "required": ["distribution_class"]
          },
          "then": {
            "properties": {
              "extension_namespace_refs": {
                "type": "array",
                "minItems": 1
              }
            }
          },
          "else": {
            "properties": {
              "extension_namespace_refs": {
                "type": "array",
                "maxItems": 0
              }
            }
          }
        },
        {
          "description": "unsigned_explicit_acceptance packs MUST cite a decision row.",
          "if": {
            "properties": { "signature_state": { "const": "unsigned_explicit_acceptance" } },
            "required": ["signature_state"]
          },
          "then": {
            "required": ["explicit_acceptance_decision_row_ref"],
            "properties": {
              "explicit_acceptance_decision_row_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        },
        {
          "description": "partially_translated_surface_families MUST be a subset of covered_surface_families. (Schema-level subset is enforced by enumerating the same vocabulary; consumers cross-check the actual set.)"
        }
      ],
      "description": "One locale-pack manifest record. See docs/ux/localization_and_locale_pack_contract.md §1.2 / §5."
    }
  }
}
