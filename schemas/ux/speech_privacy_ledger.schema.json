{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/speech_privacy_ledger.schema.json",
  "title": "Aureline speech-privacy ledger contract: capture events, transcript corrections, transcript exports, and privacy-ledger manifests",
  "description": "Boundary schema for the speech_capture_event_record, transcript_correction_record, transcript_export_record, and speech_privacy_ledger_manifest_record frozen in docs/ux/voice_and_dictation_contract.md. Every audio capture window resolves through one speech_capture_event_record naming the audio_locality_class, the transcript_locality_class, the consent_class, the bound voice-mode session, and the bound speech-provider entry so a reviewer can tell whether audio stays on the device, whether a transcript is retained, and whether consent was explicit before the capture began. Every transcript correction before commit resolves through one transcript_correction_record. Every transcript export resolves through one transcript_export_record naming the export_redaction_class and export_destination_class. Every aggregator declares the eight const-true invariants on a speech_privacy_ledger_manifest_record. The contract mints no new redaction_class, deployment_profile_id, or trust_state vocabulary; those re-export verbatim from artifacts/governance/deployment_profiles.yaml and the shell-interaction-safety / settings-resolver lanes. Adding a new audio_locality_class, transcript_locality_class, consent_class, correction_origin_class, export_redaction_class, export_destination_class, evidence_hook_class, invariant_id, or denial_reason is additive-minor and bumps speech_privacy_ledger_schema_version; repurposing an existing value is breaking and requires a new decision row. Raw audio bytes, raw transcript text, raw paths, raw URLs, raw account identifiers, raw provider payloads, and raw credential material never cross this boundary; the schema carries opaque ids, typed vocabulary, short privacy-safe labels, and typed policy / redaction metadata only.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/speech_capture_event_record" },
    { "$ref": "#/$defs/transcript_correction_record" },
    { "$ref": "#/$defs/transcript_export_record" },
    { "$ref": "#/$defs/speech_privacy_ledger_manifest_record" }
  ],
  "$defs": {
    "speech_privacy_ledger_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this speech-privacy-ledger vocabulary export. Current value is 1. Bumped only on breaking payload changes; additive-optional fields do not bump this version."
    },

    "record_kind": {
      "type": "string",
      "enum": [
        "speech_capture_event_record",
        "transcript_correction_record",
        "transcript_export_record",
        "speech_privacy_ledger_manifest_record"
      ],
      "description": "Discriminator for the concrete payload shape. Every record carries exactly one kind."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests / portable profile packages / support bundles. Raw URLs, raw absolute paths, raw audio bodies, raw transcript bodies, raw account identifiers, and raw credential material never appear here."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },

    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Short privacy-safe label text. MUST NOT embed raw paths, raw URLs, raw secret material, raw audio bodies, or raw transcript text."
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": { "type": "object", "additionalProperties": true },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "audio_locality_class": {
      "type": "string",
      "enum": [
        "local_machine_only_in_process",
        "local_machine_only_sandbox_process",
        "local_machine_only_companion_service",
        "sent_to_byok_remote_vendor_direct",
        "sent_to_byok_remote_self_hosted_direct",
        "sent_to_enterprise_gateway",
        "sent_to_vendor_hosted_first_party_managed",
        "audio_blocked_by_policy",
        "audio_unavailable_in_envelope"
      ],
      "description": "Closed audio-locality-class vocabulary. local_machine_only_* classes guarantee audio never leaves the device; sent_to_* classes MUST be paired with a *_handoff_disclosed disclosure on the speech-provider-entry schema before the capture begins."
    },

    "transcript_locality_class": {
      "type": "string",
      "enum": [
        "transcript_local_only",
        "transcript_returned_from_remote_provider_local_persisted",
        "transcript_returned_from_remote_provider_ephemeral",
        "transcript_blocked_by_policy",
        "transcript_unavailable_in_envelope"
      ],
      "description": "Closed transcript-locality-class vocabulary. transcript_returned_from_remote_provider_local_persisted is admitted only when the bound provider's retention_stance_class allows local persistence."
    },

    "consent_class": {
      "type": "string",
      "enum": [
        "explicit_user_opt_in_each_session",
        "explicit_user_opt_in_remembered_per_profile",
        "implicit_user_initiated_push_to_talk",
        "no_consent_required_local_inert_metadata_only",
        "consent_blocked_by_policy",
        "consent_unavailable_in_envelope"
      ],
      "description": "Closed consent-class vocabulary. Implicit push-to-talk MUST resolve to implicit_user_initiated_push_to_talk explicitly rather than be inferred from absence; an event without a declared consent class denies."
    },

    "correction_origin_class": {
      "type": "string",
      "enum": [
        "user_inline_correction",
        "user_palette_correction",
        "transcript_committed_without_correction_user_choice",
        "transcript_committed_without_correction_blocked_by_envelope",
        "correction_skipped_inert_metadata_only"
      ],
      "description": "Closed correction-origin-class vocabulary. Privileged commits forbid transcript_committed_without_correction_* and correction_skipped_inert_metadata_only."
    },

    "export_redaction_class": {
      "type": "string",
      "enum": [
        "redacted_metadata_only",
        "redacted_full_transcript_blocked",
        "redacted_partial_with_disclosure",
        "exported_unredacted_with_explicit_consent",
        "export_blocked_by_policy",
        "export_unavailable_in_envelope"
      ],
      "description": "Closed export-redaction-class vocabulary. exported_unredacted_with_explicit_consent requires a matching consent class on the bound capture event(s); silent unredacted export denies."
    },

    "export_destination_class": {
      "type": "string",
      "enum": [
        "support_bundle_metadata_safe_default",
        "portable_profile_package_redacted",
        "evidence_packet_redacted",
        "no_export_local_only",
        "export_blocked_by_policy_destination",
        "export_destination_unavailable_in_envelope"
      ],
      "description": "Closed export-destination-class vocabulary. no_export_local_only MUST be paired with redaction_class = redacted_full_transcript_blocked or redacted_metadata_only."
    },

    "deployment_profile_id": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud",
        "air_gapped_mirror_only"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": { "type": "string", "enum": ["trusted", "restricted"] },
        "execution_context_id": { "type": "string", "minLength": 1 }
      }
    },

    "evidence_hook_class": {
      "type": "string",
      "enum": [
        "speech_handoff_audit",
        "local_pack_continuity",
        "voice_mode_parity_review",
        "transcript_correction_audit",
        "privacy_bounded_export_artifact"
      ],
      "description": "Reserved evidence-hook vocabulary capture-event, correction, export, and manifest records may attach without redefining object shape."
    },

    "denial_reason": {
      "type": "string",
      "enum": [
        "speech_privacy_audio_left_device_without_disclosure",
        "speech_privacy_transcript_retained_beyond_declared_class",
        "speech_privacy_export_unredacted_without_consent",
        "speech_privacy_correction_skipped_for_privileged_commit",
        "speech_privacy_consent_class_inferred_not_declared",
        "speech_privacy_schema_version_lagging"
      ],
      "description": "Closed denial-reason vocabulary."
    },

    "invariant_assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["invariant_id", "asserted_true"],
      "properties": {
        "invariant_id": {
          "type": "string",
          "enum": [
            "audio_leaving_device_disclosed_at_or_before_capture",
            "transcript_retention_matches_provider_retention_stance",
            "unredacted_export_requires_explicit_consent",
            "privileged_commit_passes_through_correction_window",
            "consent_class_declared_not_inferred",
            "local_pack_unverified_forces_voice_suppression_not_silent_remote_fallback",
            "transcript_export_redaction_class_matches_destination",
            "evidence_hooks_reserved_for_privacy_bounded_export_artifact"
          ]
        },
        "asserted_true": { "type": "boolean", "const": true },
        "notes": { "$ref": "#/$defs/short_label_text" }
      }
    },

    "speech_capture_event_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "speech_privacy_ledger_schema_version",
        "event_id",
        "voice_mode_session_ref",
        "speech_provider_entry_ref",
        "audio_locality_class",
        "transcript_locality_class",
        "consent_class",
        "deployment_profile_refs",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "speech_capture_event_record" },
        "speech_privacy_ledger_schema_version": { "$ref": "#/$defs/speech_privacy_ledger_schema_version" },
        "event_id": { "$ref": "#/$defs/opaque_id" },
        "voice_mode_session_ref": { "$ref": "#/$defs/opaque_id" },
        "speech_provider_entry_ref": { "$ref": "#/$defs/opaque_id" },
        "speech_provider_handoff_disclosure_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Required when audio_locality_class is any sent_to_* class; opaque pin to the speech_provider_handoff_disclosure_record minted at or before the capture."
        },
        "audio_locality_class": { "$ref": "#/$defs/audio_locality_class" },
        "transcript_locality_class": { "$ref": "#/$defs/transcript_locality_class" },
        "consent_class": { "$ref": "#/$defs/consent_class" },
        "deployment_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "evidence_hooks_reserved": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_hook_class" },
          "uniqueItems": true
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "denial_reason_on_deny": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/denial_reason" }
          ]
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Audio leaving the device requires a paired handoff disclosure.",
          "if": {
            "properties": {
              "audio_locality_class": {
                "enum": [
                  "sent_to_byok_remote_vendor_direct",
                  "sent_to_byok_remote_self_hosted_direct",
                  "sent_to_enterprise_gateway",
                  "sent_to_vendor_hosted_first_party_managed"
                ]
              }
            },
            "required": ["audio_locality_class"]
          },
          "then": {
            "required": ["speech_provider_handoff_disclosure_ref"]
          }
        },
        {
          "description": "Air-gapped envelopes forbid sent_to_* audio locality.",
          "if": {
            "properties": {
              "deployment_profile_refs": {
                "type": "array",
                "contains": { "enum": ["air_gapped", "air_gapped_mirror_only"] }
              }
            },
            "required": ["deployment_profile_refs"]
          },
          "then": {
            "properties": {
              "audio_locality_class": {
                "enum": [
                  "local_machine_only_in_process",
                  "local_machine_only_sandbox_process",
                  "local_machine_only_companion_service",
                  "audio_blocked_by_policy",
                  "audio_unavailable_in_envelope"
                ]
              }
            }
          }
        }
      ],
      "description": "One audio capture event. See voice_and_dictation_contract.md §1.3 and §5."
    },

    "transcript_correction_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "speech_privacy_ledger_schema_version",
        "correction_id",
        "capture_event_ref",
        "correction_origin_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "transcript_correction_record" },
        "speech_privacy_ledger_schema_version": { "$ref": "#/$defs/speech_privacy_ledger_schema_version" },
        "correction_id": { "$ref": "#/$defs/opaque_id" },
        "capture_event_ref": { "$ref": "#/$defs/opaque_id" },
        "voice_mode_session_ref": { "$ref": "#/$defs/opaque_id" },
        "command_descriptor_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Optional opaque pin to the command_descriptor_record on schemas/commands/command_descriptor.schema.json whose intent the correction altered. Lets a reviewer audit whether a corrected transcript changed the resolved command."
        },
        "correction_origin_class": { "$ref": "#/$defs/correction_origin_class" },
        "evidence_hooks_reserved": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_hook_class" },
          "uniqueItems": true
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "denial_reason_on_deny": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/denial_reason" }
          ]
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "description": "One transcript-correction-before-commit row. See voice_and_dictation_contract.md §5 rule 4."
    },

    "transcript_export_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "speech_privacy_ledger_schema_version",
        "export_id",
        "capture_event_refs",
        "export_redaction_class",
        "export_destination_class",
        "consent_class",
        "deployment_profile_refs",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "transcript_export_record" },
        "speech_privacy_ledger_schema_version": { "$ref": "#/$defs/speech_privacy_ledger_schema_version" },
        "export_id": { "$ref": "#/$defs/opaque_id" },
        "capture_event_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "voice_mode_session_ref": { "$ref": "#/$defs/opaque_id" },
        "export_redaction_class": { "$ref": "#/$defs/export_redaction_class" },
        "export_destination_class": { "$ref": "#/$defs/export_destination_class" },
        "consent_class": { "$ref": "#/$defs/consent_class" },
        "deployment_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "evidence_hooks_reserved": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_hook_class" },
          "uniqueItems": true
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "denial_reason_on_deny": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/denial_reason" }
          ]
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "exported_unredacted_with_explicit_consent forbids implicit / no-consent classes; consent_class MUST be explicit.",
          "if": {
            "properties": { "export_redaction_class": { "const": "exported_unredacted_with_explicit_consent" } },
            "required": ["export_redaction_class"]
          },
          "then": {
            "properties": {
              "consent_class": {
                "enum": [
                  "explicit_user_opt_in_each_session",
                  "explicit_user_opt_in_remembered_per_profile"
                ]
              }
            }
          }
        },
        {
          "description": "no_export_local_only forces a redaction class that blocks transcript bodies from exiting the local machine.",
          "if": {
            "properties": { "export_destination_class": { "const": "no_export_local_only" } },
            "required": ["export_destination_class"]
          },
          "then": {
            "properties": {
              "export_redaction_class": {
                "enum": ["redacted_full_transcript_blocked", "redacted_metadata_only"]
              }
            }
          }
        }
      ],
      "description": "One transcript-export row. See voice_and_dictation_contract.md §5 rules 2 and 3."
    },

    "speech_privacy_ledger_manifest_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "speech_privacy_ledger_schema_version",
        "manifest_id",
        "voice_mode_session_refs",
        "deployment_profile_refs",
        "invariants",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "speech_privacy_ledger_manifest_record" },
        "speech_privacy_ledger_schema_version": { "$ref": "#/$defs/speech_privacy_ledger_schema_version" },
        "manifest_id": { "$ref": "#/$defs/opaque_id" },
        "voice_mode_session_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "capture_event_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "correction_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "export_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "deployment_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "evidence_hooks_reserved": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_hook_class" },
          "uniqueItems": true
        },
        "invariants": {
          "type": "array",
          "minItems": 8,
          "items": { "$ref": "#/$defs/invariant_assertion" },
          "uniqueItems": true
        },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "description": "Top-level aggregator declaring const-true invariants for the speech-privacy ledger. See voice_and_dictation_contract.md §7."
    }
  }
}
