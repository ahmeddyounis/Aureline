{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/migration_center_beta.schema.json",
  "title": "Aureline migration center / learnability surface (beta) schema",
  "description": "Boundary schema for the beta migration-center projection produced by aureline-shell. Each record carries the shared contract ref `shell:migration_center_beta:v1`. Adding a value to any closed vocabulary (section_kind, entry_kind, keyboard_reach, claim_class, lifecycle_class, freshness_class, recovery_route_class, defect_kind) is additive-minor; repurposing or weakening any keyboard-reach or claim invariant is breaking.",
  "type": "object",
  "$ref": "#/$defs/page",
  "$defs": {
    "iso_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp."
    },
    "stable_id": {
      "type": "string",
      "minLength": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "shell:migration_center_beta:v1"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "section_kind": {
      "type": "string",
      "enum": [
        "docs_help_anchors",
        "glossary_packs",
        "migration_reports",
        "known_limits",
        "recovery_routes",
        "first_run_confusion_exits"
      ]
    },
    "entry_kind": {
      "type": "string",
      "enum": [
        "docs_help_anchor",
        "glossary_anchor",
        "migration_report_reopen",
        "known_limits_lane",
        "recovery_action",
        "first_run_confusion_exit",
        "keymap_reference"
      ]
    },
    "keyboard_reach_class": {
      "type": "string",
      "enum": [
        "keyboard_first_command_invocation",
        "keyboard_reachable_focus_path",
        "keyboard_chord_reference"
      ]
    },
    "claim_class": {
      "type": "string",
      "enum": [
        "stable_claimed",
        "beta_claimed",
        "alpha_claimed",
        "labs_experiment_claimed",
        "not_claimed"
      ]
    },
    "lifecycle_class": {
      "type": "string",
      "enum": ["stable", "beta", "alpha", "preview", "labs_experiment"]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "review_due_soon",
        "review_overdue",
        "unverified_but_current",
        "degraded_but_current"
      ]
    },
    "recovery_route_class": {
      "type": "string",
      "enum": [
        "safe_mode",
        "factory_reset_review",
        "corruption_rescue",
        "restore_chooser",
        "crash_loop_containment",
        "migration_rollback",
        "support_export"
      ]
    },
    "defect_kind": {
      "type": "string",
      "enum": [
        "entry_requires_account_detour",
        "entry_requires_marketplace_detour",
        "entry_keyboard_unreachable",
        "entry_command_id_missing",
        "docs_anchor_ref_missing",
        "glossary_pack_ref_missing",
        "migration_report_ref_missing",
        "known_limit_ref_missing",
        "recovery_route_class_missing",
        "section_missing_required_kind",
        "section_unknown_entry",
        "duplicate_entry_id",
        "duplicate_section_kind",
        "freshness_review_overdue_on_claimed_row",
        "claim_lifecycle_freshness_drift",
        "support_row_vocabulary_drift",
        "support_row_unknown_entry"
      ]
    },
    "learnability_claim": {
      "type": "object",
      "required": [
        "claim_class_token",
        "lifecycle_class_token",
        "freshness_class_token",
        "review_window_days",
        "evidence_date",
        "as_of"
      ],
      "properties": {
        "claim_class": { "$ref": "#/$defs/claim_class" },
        "claim_class_token": { "$ref": "#/$defs/claim_class" },
        "lifecycle_class": { "$ref": "#/$defs/lifecycle_class" },
        "lifecycle_class_token": { "$ref": "#/$defs/lifecycle_class" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "freshness_class_token": { "$ref": "#/$defs/freshness_class" },
        "review_window_days": { "type": "integer", "minimum": 1 },
        "evidence_date": { "$ref": "#/$defs/iso_timestamp" },
        "as_of": { "$ref": "#/$defs/iso_timestamp" }
      }
    },
    "section": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "section_id",
        "section_kind",
        "section_kind_token",
        "title_label",
        "description_label",
        "entry_ids"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "shell_migration_center_beta_section_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "section_id": { "$ref": "#/$defs/stable_id" },
        "section_kind": { "$ref": "#/$defs/section_kind" },
        "section_kind_token": { "$ref": "#/$defs/section_kind" },
        "title_label": { "type": "string", "minLength": 1 },
        "description_label": { "type": "string", "minLength": 1 },
        "entry_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" }
        }
      }
    },
    "entry": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "entry_id",
        "section_id",
        "section_kind",
        "section_kind_token",
        "entry_kind",
        "entry_kind_token",
        "title_label",
        "description_label",
        "keyboard_reach",
        "keyboard_reach_token",
        "requires_account_detour",
        "requires_marketplace_detour",
        "learnability_claim",
        "support_row_id"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "shell_migration_center_beta_entry_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "entry_id": { "$ref": "#/$defs/stable_id" },
        "section_id": { "$ref": "#/$defs/stable_id" },
        "section_kind": { "$ref": "#/$defs/section_kind" },
        "section_kind_token": { "$ref": "#/$defs/section_kind" },
        "entry_kind": { "$ref": "#/$defs/entry_kind" },
        "entry_kind_token": { "$ref": "#/$defs/entry_kind" },
        "title_label": { "type": "string", "minLength": 1 },
        "description_label": { "type": "string", "minLength": 1 },
        "command_id": { "type": ["string", "null"] },
        "docs_help_anchor_ref": { "type": ["string", "null"] },
        "glossary_pack_ref": { "type": ["string", "null"] },
        "migration_report_ref": { "type": ["string", "null"] },
        "known_limit_ref": { "type": ["string", "null"] },
        "recovery_route_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/recovery_route_class" }
          ]
        },
        "recovery_route_class_token": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/recovery_route_class" }
          ]
        },
        "keyboard_chord_ref": { "type": ["string", "null"] },
        "keyboard_reach": { "$ref": "#/$defs/keyboard_reach_class" },
        "keyboard_reach_token": { "$ref": "#/$defs/keyboard_reach_class" },
        "requires_account_detour": { "type": "boolean" },
        "requires_marketplace_detour": { "type": "boolean" },
        "learnability_claim": { "$ref": "#/$defs/learnability_claim" },
        "support_row_id": { "$ref": "#/$defs/stable_id" }
      }
    },
    "support_row": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "support_row_id",
        "entry_id",
        "section_kind_token",
        "entry_kind_token",
        "keyboard_reach_token",
        "claim_class_token",
        "lifecycle_class_token",
        "freshness_class_token",
        "raw_body_exported"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "shell_migration_center_beta_support_row_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "support_row_id": { "$ref": "#/$defs/stable_id" },
        "entry_id": { "$ref": "#/$defs/stable_id" },
        "section_kind_token": { "$ref": "#/$defs/section_kind" },
        "entry_kind_token": { "$ref": "#/$defs/entry_kind" },
        "keyboard_reach_token": { "$ref": "#/$defs/keyboard_reach_class" },
        "claim_class_token": { "$ref": "#/$defs/claim_class" },
        "lifecycle_class_token": { "$ref": "#/$defs/lifecycle_class" },
        "freshness_class_token": { "$ref": "#/$defs/freshness_class" },
        "command_id": { "type": ["string", "null"] },
        "docs_help_anchor_ref": { "type": ["string", "null"] },
        "migration_report_ref": { "type": ["string", "null"] },
        "known_limit_ref": { "type": ["string", "null"] },
        "recovery_route_class_token": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/recovery_route_class" }
          ]
        },
        "raw_body_exported": { "type": "boolean", "const": false }
      }
    },
    "defect": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "defect_kind",
        "defect_kind_token",
        "row_id",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "shell_migration_center_beta_defect_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_id": { "$ref": "#/$defs/stable_id" },
        "defect_kind": { "$ref": "#/$defs/defect_kind" },
        "defect_kind_token": { "$ref": "#/$defs/defect_kind" },
        "row_id": { "$ref": "#/$defs/stable_id" },
        "field": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "upstream_refs": {
      "type": "object",
      "required": [
        "wizard_session_ref",
        "wizard_mapping_report_ref",
        "wizard_rollback_checkpoint_ref",
        "wizard_shared_contract_ref",
        "corpus_scoreboard_ref",
        "corpus_shared_contract_ref"
      ],
      "properties": {
        "wizard_session_ref": { "$ref": "#/$defs/stable_id" },
        "wizard_mapping_report_ref": { "$ref": "#/$defs/stable_id" },
        "wizard_rollback_checkpoint_ref": { "$ref": "#/$defs/stable_id" },
        "wizard_shared_contract_ref": {
          "type": "string",
          "const": "shell:migration_wizard_beta:v1"
        },
        "corpus_scoreboard_ref": { "$ref": "#/$defs/stable_id" },
        "corpus_shared_contract_ref": {
          "type": "string",
          "const": "shell:migration_corpus_beta:v1"
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "section_count",
        "entry_count",
        "keyboard_first_count",
        "recovery_route_count",
        "docs_help_count",
        "known_limit_count",
        "migration_report_reopen_count",
        "glossary_anchor_count",
        "first_run_exit_count",
        "defect_count"
      ],
      "properties": {
        "section_count": { "type": "integer", "minimum": 0 },
        "entry_count": { "type": "integer", "minimum": 0 },
        "keyboard_first_count": { "type": "integer", "minimum": 0 },
        "recovery_route_count": { "type": "integer", "minimum": 0 },
        "docs_help_count": { "type": "integer", "minimum": 0 },
        "known_limit_count": { "type": "integer", "minimum": 0 },
        "migration_report_reopen_count": { "type": "integer", "minimum": 0 },
        "glossary_anchor_count": { "type": "integer", "minimum": 0 },
        "first_run_exit_count": { "type": "integer", "minimum": 0 },
        "defect_count": { "type": "integer", "minimum": 0 }
      }
    },
    "page": {
      "type": "object",
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "page_id",
        "generated_at",
        "learnability_claim",
        "upstream_refs",
        "sections",
        "entries",
        "support_rows",
        "defects",
        "summary"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "shell_migration_center_beta_page_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "page_id": { "$ref": "#/$defs/stable_id" },
        "generated_at": { "$ref": "#/$defs/iso_timestamp" },
        "learnability_claim": { "$ref": "#/$defs/learnability_claim" },
        "upstream_refs": { "$ref": "#/$defs/upstream_refs" },
        "sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/section" }
        },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/entry" }
        },
        "support_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/support_row" }
        },
        "defects": {
          "type": "array",
          "items": { "$ref": "#/$defs/defect" }
        },
        "summary": { "$ref": "#/$defs/summary" }
      }
    }
  }
}
