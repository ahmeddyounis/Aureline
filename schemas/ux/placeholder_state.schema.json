{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/placeholder_state.schema.json",
  "title": "Aureline placeholder-state honesty record",
  "description": "Boundary schema for placeholder_state_record instances frozen in docs/ux/empty_loading_placeholder_contract.md. The record gives shell, Start Center, search, docs/help, install-review, provider-backed, list/tree, and status-strip surfaces one shared way to describe empty, first-run, loading, indexing, probing, blocked, degraded, missing extension/provider, partial-data, and stale-cached placeholder states without implying readiness. Raw file bodies, raw query bodies, raw provider payloads, raw logs, raw URLs, raw hostnames, raw absolute filesystem paths, raw credentials, and raw secret material never cross this boundary; records carry opaque refs, controlled labels, typed state classes, and redaction-aware reviewable summaries only. Adding a new surface family, state class, presentation pattern, coexistence class, cue label, action kind, denial reason, or projection class is additive-minor and bumps placeholder_state_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "placeholder_state_schema_version",
    "case_id",
    "surface_family",
    "state_class",
    "truth_classes",
    "degraded_state_tokens",
    "state_summary",
    "content_policy",
    "prior_content",
    "visible_cues",
    "next_actions",
    "readiness_guards",
    "cross_surface_projection",
    "accessibility",
    "support_export",
    "narrative_refs"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "__fixture__": {
      "$ref": "#/$defs/fixture_metadata"
    },
    "record_kind": {
      "type": "string",
      "const": "placeholder_state_record"
    },
    "placeholder_state_schema_version": {
      "$ref": "#/$defs/placeholder_state_schema_version"
    },
    "case_id": {
      "$ref": "#/$defs/opaque_id"
    },
    "surface_family": {
      "$ref": "#/$defs/surface_family"
    },
    "state_class": {
      "$ref": "#/$defs/state_class"
    },
    "truth_classes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/truth_class"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "degraded_state_tokens": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/degraded_state_token"
      },
      "uniqueItems": true
    },
    "state_summary": {
      "$ref": "#/$defs/state_summary"
    },
    "content_policy": {
      "$ref": "#/$defs/content_policy"
    },
    "prior_content": {
      "$ref": "#/$defs/prior_content"
    },
    "visible_cues": {
      "$ref": "#/$defs/visible_cues"
    },
    "next_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/next_action"
      },
      "minItems": 1
    },
    "readiness_guards": {
      "$ref": "#/$defs/readiness_guards"
    },
    "cross_surface_projection": {
      "$ref": "#/$defs/cross_surface_projection"
    },
    "accessibility": {
      "$ref": "#/$defs/accessibility"
    },
    "support_export": {
      "$ref": "#/$defs/support_export"
    },
    "narrative_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "state_class": {
            "enum": [
              "loading",
              "indexing",
              "probing",
              "blocked",
              "degraded",
              "missing_extension_or_provider",
              "partial_data",
              "stale_cached_content"
            ]
          }
        },
        "required": ["state_class"]
      },
      "then": {
        "properties": {
          "readiness_guards": {
            "properties": {
              "green_status_allowed": {
                "const": false
              },
              "rendered_ready_label_allowed": {
                "const": false
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state_class": {
            "const": "stale_cached_content"
          }
        },
        "required": ["state_class"]
      },
      "then": {
        "properties": {
          "prior_content": {
            "properties": {
              "coexistence_class": {
                "const": "stale_prior_content_visible"
              },
              "label_required": {
                "const": true
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state_class": {
            "const": "empty_no_results"
          }
        },
        "required": ["state_class"]
      },
      "then": {
        "properties": {
          "content_policy": {
            "properties": {
              "presentation_pattern": {
                "const": "explicit_empty_text"
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "placeholder_state_schema_version": {
      "type": "integer",
      "const": 1
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "scenario": {
          "type": "string",
          "minLength": 1
        },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1
    },
    "redaction_aware_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "nullable_label": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 1024
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "shell",
        "start_center",
        "search",
        "docs_help",
        "install_review",
        "provider_backed",
        "tree_or_list",
        "status_strip",
        "generic_surface"
      ]
    },
    "state_class": {
      "type": "string",
      "enum": [
        "empty_no_results",
        "empty_first_run",
        "loading",
        "indexing",
        "probing",
        "blocked",
        "degraded",
        "missing_extension_or_provider",
        "partial_data",
        "stale_cached_content"
      ]
    },
    "truth_class": {
      "type": "string",
      "enum": [
        "user_authored_durable_truth",
        "workspace_vcs_truth",
        "runtime_observed_truth",
        "derived_indexed_truth",
        "session_collaboration_truth",
        "ai_inferred_truth"
      ]
    },
    "degraded_state_token": {
      "type": "string",
      "enum": [
        "Warming",
        "Cached",
        "Partial",
        "Stale",
        "Offline",
        "PolicyBlocked",
        "Limited",
        "Unsupported",
        "Experimental",
        "RetestPending"
      ]
    },
    "state_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "area_purpose",
        "cause_class",
        "cause_summary",
        "preserved_capability",
        "reduced_or_blocked_capability",
        "readiness_basis"
      ],
      "properties": {
        "area_purpose": {
          "$ref": "#/$defs/redaction_aware_label"
        },
        "cause_class": {
          "type": "string",
          "enum": [
            "no_work_started",
            "filter_or_scope_zero",
            "not_ready_warming",
            "background_index_incomplete",
            "probe_in_progress",
            "provider_unreachable",
            "extension_missing",
            "policy_or_trust_blocked",
            "partial_scope",
            "stale_prior_content",
            "cached_owner_unreachable",
            "failed_last_attempt"
          ]
        },
        "cause_summary": {
          "$ref": "#/$defs/redaction_aware_label"
        },
        "preserved_capability": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/redaction_aware_label"
          },
          "minItems": 1
        },
        "reduced_or_blocked_capability": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/redaction_aware_label"
          }
        },
        "readiness_basis": {
          "$ref": "#/$defs/redaction_aware_label"
        },
        "owner_ref": {
          "$ref": "#/$defs/opaque_ref"
        }
      }
    },
    "content_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "presentation_pattern",
        "animation_policy",
        "content_shaped_placeholder_allowed",
        "simulates_real_content",
        "must_downgrade_to_explicit_text",
        "progressive_hydration"
      ],
      "properties": {
        "presentation_pattern": {
          "type": "string",
          "enum": [
            "explicit_empty_text",
            "skeleton_rows",
            "static_placeholder",
            "progressive_partial_results",
            "top_of_pane_progress",
            "retained_prior_content",
            "placeholder_row",
            "explicit_blocked_text"
          ]
        },
        "animation_policy": {
          "type": "string",
          "enum": [
            "none",
            "static",
            "reduced_motion_static_with_progress_text",
            "subtle_shimmer_allowed",
            "shimmer_forbidden"
          ]
        },
        "content_shaped_placeholder_allowed": {
          "type": "boolean"
        },
        "simulates_real_content": {
          "type": "boolean",
          "const": false
        },
        "must_downgrade_to_explicit_text": {
          "type": "boolean"
        },
        "placeholder_label": {
          "$ref": "#/$defs/nullable_label"
        },
        "progressive_hydration": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allowed",
            "hydration_label_required",
            "row_reorder_above_fold_allowed"
          ],
          "properties": {
            "allowed": {
              "type": "boolean"
            },
            "hydration_label_required": {
              "type": "boolean"
            },
            "row_reorder_above_fold_allowed": {
              "type": "boolean",
              "const": false
            }
          }
        }
      }
    },
    "prior_content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coexistence_class",
        "label_required",
        "basis_label",
        "freshness_label",
        "staleness_or_cache_cause",
        "mutating_actions_require_revalidation"
      ],
      "properties": {
        "coexistence_class": {
          "type": "string",
          "enum": [
            "no_prior_content",
            "prior_content_hidden",
            "cached_prior_content_visible",
            "stale_prior_content_visible",
            "partial_current_content_visible",
            "mixed_cached_and_live_visible",
            "policy_hidden_prior_content"
          ]
        },
        "label_required": {
          "type": "boolean"
        },
        "basis_label": {
          "$ref": "#/$defs/nullable_label"
        },
        "freshness_label": {
          "$ref": "#/$defs/nullable_label"
        },
        "staleness_or_cache_cause": {
          "$ref": "#/$defs/nullable_label"
        },
        "mutating_actions_require_revalidation": {
          "type": "boolean"
        }
      }
    },
    "visible_cues": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_label",
        "cause_label",
        "readiness_badge_label",
        "accessible_name",
        "details_route_label"
      ],
      "properties": {
        "primary_label": {
          "$ref": "#/$defs/redaction_aware_label"
        },
        "cause_label": {
          "$ref": "#/$defs/redaction_aware_label"
        },
        "readiness_badge_label": {
          "type": "string",
          "enum": [
            "No results",
            "First run",
            "Loading",
            "Indexing",
            "Probing",
            "Blocked",
            "Degraded",
            "Missing provider",
            "Missing extension",
            "Partial",
            "Stale",
            "Cached"
          ]
        },
        "accessible_name": {
          "$ref": "#/$defs/redaction_aware_label"
        },
        "details_route_label": {
          "$ref": "#/$defs/redaction_aware_label"
        }
      }
    },
    "next_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "label",
        "action_kind",
        "command_id",
        "safe_without_revalidation",
        "preserves_current_work"
      ],
      "properties": {
        "action_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "label": {
          "$ref": "#/$defs/redaction_aware_label"
        },
        "action_kind": {
          "type": "string",
          "enum": [
            "open",
            "clear_filter",
            "widen_scope",
            "narrow_scope",
            "open_details",
            "retry",
            "cancel",
            "continue_locally",
            "continue_read_only",
            "install_or_enable",
            "open_offline_fallback",
            "request_access",
            "export_evidence",
            "repair_or_rebuild"
          ]
        },
        "command_id": {
          "type": "string",
          "pattern": "^cmd\\.[A-Za-z0-9_.:-]+$"
        },
        "safe_without_revalidation": {
          "type": "boolean"
        },
        "preserves_current_work": {
          "type": "boolean"
        }
      }
    },
    "readiness_guards": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claims_ready_without_evidence",
        "green_status_allowed",
        "rendered_ready_label_allowed",
        "success_icon_allowed",
        "state_tooltip_only_allowed",
        "forbidden_renderings"
      ],
      "properties": {
        "claims_ready_without_evidence": {
          "type": "boolean",
          "const": false
        },
        "green_status_allowed": {
          "type": "boolean"
        },
        "rendered_ready_label_allowed": {
          "type": "boolean"
        },
        "success_icon_allowed": {
          "type": "boolean"
        },
        "state_tooltip_only_allowed": {
          "type": "boolean",
          "const": false
        },
        "forbidden_renderings": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ready_label",
              "green_success_state",
              "fake_content_row",
              "whole_shell_spinner",
              "generic_loading_copy",
              "generic_unavailable_copy",
              "blank_panel",
              "tooltip_only_state",
              "unlabeled_cached_content",
              "unlabeled_stale_content",
              "no_results_before_scope_complete"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "cross_surface_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projection_class",
        "status_strip_state",
        "view_freshness_class",
        "search_readiness_state",
        "reuses_shared_readiness_language"
      ],
      "properties": {
        "projection_class": {
          "type": "string",
          "enum": [
            "shell",
            "start_center",
            "search",
            "docs_help",
            "install_review",
            "provider_backed",
            "generic"
          ]
        },
        "status_strip_state": {
          "type": ["string", "null"],
          "enum": [
            "loading",
            "warm",
            "partial",
            "stale",
            "degraded",
            "blocked",
            "ready",
            null
          ]
        },
        "view_freshness_class": {
          "type": ["string", "null"],
          "enum": [
            "live_exact",
            "snapshot_exact",
            "partial",
            "stale",
            "approximate_derived",
            null
          ]
        },
        "search_readiness_state": {
          "type": ["string", "null"],
          "enum": [
            "not_indexed",
            "hot_set_ready",
            "partial_index",
            "warm_index",
            "fully_indexed",
            "stale_index",
            "reindexing",
            "index_unavailable",
            null
          ]
        },
        "reuses_shared_readiness_language": {
          "type": "boolean",
          "const": true
        },
        "surface_contract_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_ref"
          },
          "uniqueItems": true
        }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_target_id",
        "state_announced",
        "next_action_keyboard_reachable",
        "details_keyboard_reachable",
        "reduced_motion_equivalent"
      ],
      "properties": {
        "focus_target_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "state_announced": {
          "type": "boolean",
          "const": true
        },
        "next_action_keyboard_reachable": {
          "type": "boolean",
          "const": true
        },
        "details_keyboard_reachable": {
          "type": "boolean",
          "const": true
        },
        "reduced_motion_equivalent": {
          "$ref": "#/$defs/redaction_aware_label"
        }
      }
    },
    "support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_field_refs",
        "redaction_class",
        "state_class_preserved",
        "content_basis_preserved",
        "stale_or_cached_basis_preserved",
        "next_action_preserved"
      ],
      "properties": {
        "export_field_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_ref"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "redaction_class": {
          "type": "string",
          "enum": [
            "metadata_safe_default",
            "operator_only_restricted",
            "support_restricted"
          ]
        },
        "state_class_preserved": {
          "type": "boolean",
          "const": true
        },
        "content_basis_preserved": {
          "type": "boolean",
          "const": true
        },
        "stale_or_cached_basis_preserved": {
          "type": "boolean"
        },
        "next_action_preserved": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
