{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/durable_job_envelope.schema.json",
  "title": "Aureline durable-job envelope contract",
  "description": "Boundary schema for one durable_job_envelope_record frozen in docs/ux/durable_job_envelope_contract.md. Every long-running, queued, reviewable, held, or suppressed piece of work mints exactly one envelope under one canonical_event_id and one canonical_object_target_ref. Toasts, modal spinners, status-bar flickers, OS notifications, lock-screen summaries, companion push, badges, and durable rows derive their state from this envelope; a surface that renders durable work without naming an upstream envelope is non-conforming. The record composes with schemas/ux/activity_event_envelope.schema.json for delivery-surface, quiet-hours, suppression, dedupe, dismissal, privacy-payload, badge-class, and source-subsystem vocabulary, with schemas/ux/job_row.schema.json for the render-level row that projects this envelope, with schemas/ux/notification_event.schema.json for surface-class routing, and with schemas/ux/event_lineage.schema.json for cross-client lineage. Raw bodies, raw paths, raw URLs, raw provider payloads, raw prompt or completion text, raw command bodies, raw logs, tokens, credential material, and secret values never cross this boundary. Adding a new phase class, progress form class, badge source class, fanout receipt state, action kind, sensitivity axis, or expected boundary class is additive-minor and bumps durable_job_envelope_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "durable_job_envelope_schema_version",
    "envelope_id",
    "durable_job_id",
    "canonical_event_id",
    "canonical_object_target_ref",
    "subject_class",
    "actor",
    "target",
    "phase",
    "progress",
    "sensitivity",
    "affordances",
    "badge_source",
    "notification_linkage",
    "lineage",
    "audit",
    "support_export",
    "policy_context",
    "timestamps",
    "narrative_refs"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
    "record_kind": { "type": "string", "const": "durable_job_envelope_record" },
    "durable_job_envelope_schema_version": { "$ref": "#/$defs/durable_job_envelope_schema_version" },
    "envelope_id": { "$ref": "#/$defs/opaque_id" },
    "durable_job_id": { "$ref": "#/$defs/opaque_id" },
    "canonical_event_id": { "$ref": "#/$defs/opaque_id" },
    "canonical_object_target_ref": { "$ref": "#/$defs/opaque_id" },
    "subject_class": { "$ref": "#/$defs/durable_job_subject_class" },
    "actor": { "$ref": "#/$defs/actor_summary" },
    "target": { "$ref": "#/$defs/target_summary" },
    "phase": { "$ref": "#/$defs/phase_summary" },
    "progress": { "$ref": "#/$defs/progress_summary" },
    "sensitivity": { "$ref": "#/$defs/sensitivity_summary" },
    "affordances": { "$ref": "#/$defs/affordances_summary" },
    "badge_source": { "$ref": "#/$defs/badge_source_summary" },
    "notification_linkage": { "$ref": "#/$defs/notification_linkage_summary" },
    "lineage": { "$ref": "#/$defs/lineage_summary" },
    "audit": { "$ref": "#/$defs/audit_summary" },
    "support_export": { "$ref": "#/$defs/support_export_summary" },
    "policy_context": { "$ref": "#/$defs/policy_context" },
    "timestamps": { "$ref": "#/$defs/timestamp_summary" },
    "narrative_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "description": "queued envelopes MUST name queue_reason_label and expected_boundary_class.",
      "if": {
        "properties": { "phase": { "properties": { "phase_class": { "const": "queued" } }, "required": ["phase_class"] } },
        "required": ["phase"]
      },
      "then": {
        "properties": {
          "phase": {
            "required": ["queue_reason_label", "expected_boundary_class"],
            "properties": {
              "queue_reason_label": { "$ref": "#/$defs/reviewable_sentence" },
              "expected_boundary_class": { "$ref": "#/$defs/expected_boundary_class" }
            }
          }
        }
      }
    },
    {
      "description": "running envelopes MUST carry phase_label and exactly one of labeled_progress_bar (with progress_bar) or spinner_only (with indeterminate_reason_label).",
      "if": {
        "properties": { "phase": { "properties": { "phase_class": { "const": "running" } }, "required": ["phase_class"] } },
        "required": ["phase"]
      },
      "then": {
        "properties": {
          "phase": {
            "required": ["phase_label"],
            "properties": { "phase_label": { "$ref": "#/$defs/short_label_text" } }
          },
          "progress": {
            "anyOf": [
              {
                "properties": {
                  "progress_form_class": { "const": "labeled_progress_bar" },
                  "progress_bar": { "$ref": "#/$defs/progress_bar" }
                },
                "required": ["progress_form_class", "progress_bar"]
              },
              {
                "properties": {
                  "progress_form_class": { "const": "spinner_only" },
                  "indeterminate_reason_label": { "$ref": "#/$defs/short_label_text" }
                },
                "required": ["progress_form_class", "indeterminate_reason_label"]
              }
            ]
          }
        }
      }
    },
    {
      "description": "preparing envelopes MUST carry phase_label and a phase_only or spinner_only progress form with an indeterminate reason when spinner_only.",
      "if": {
        "properties": { "phase": { "properties": { "phase_class": { "const": "preparing" } }, "required": ["phase_class"] } },
        "required": ["phase"]
      },
      "then": {
        "properties": {
          "phase": {
            "required": ["phase_label"],
            "properties": { "phase_label": { "$ref": "#/$defs/short_label_text" } }
          },
          "progress": {
            "properties": {
              "progress_form_class": { "enum": ["phase_only", "spinner_only", "labeled_progress_bar"] }
            },
            "required": ["progress_form_class"]
          }
        }
      }
    },
    {
      "description": "spinner_only progress MUST carry indeterminate_reason_label.",
      "if": {
        "properties": { "progress": { "properties": { "progress_form_class": { "const": "spinner_only" } }, "required": ["progress_form_class"] } },
        "required": ["progress"]
      },
      "then": {
        "properties": {
          "progress": {
            "required": ["indeterminate_reason_label"],
            "properties": { "indeterminate_reason_label": { "$ref": "#/$defs/short_label_text" } }
          }
        }
      }
    },
    {
      "description": "labeled_progress_bar progress MUST carry progress_bar.",
      "if": {
        "properties": { "progress": { "properties": { "progress_form_class": { "const": "labeled_progress_bar" } }, "required": ["progress_form_class"] } },
        "required": ["progress"]
      },
      "then": {
        "properties": {
          "progress": {
            "required": ["progress_bar"],
            "properties": { "progress_bar": { "$ref": "#/$defs/progress_bar" } }
          }
        }
      }
    },
    {
      "description": "waiting_input envelopes MUST carry waiting_for_label and approval_source_label and expose review_approval (or other typed handoff) in additional_action_kinds.",
      "if": {
        "properties": { "phase": { "properties": { "phase_class": { "const": "waiting_input" } }, "required": ["phase_class"] } },
        "required": ["phase"]
      },
      "then": {
        "properties": {
          "phase": {
            "required": ["waiting_for_label", "approval_source_label"],
            "properties": {
              "waiting_for_label": { "$ref": "#/$defs/reviewable_sentence" },
              "approval_source_label": { "$ref": "#/$defs/short_label_text" }
            }
          },
          "affordances": {
            "properties": {
              "additional_action_kinds": {
                "type": "array",
                "minItems": 1,
                "contains": {
                  "enum": [
                    "review_approval",
                    "inspect_policy",
                    "release_hold",
                    "open_evidence",
                    "open_history"
                  ]
                }
              }
            },
            "required": ["additional_action_kinds"]
          }
        }
      }
    },
    {
      "description": "failed envelopes MUST carry failure_or_partial_summary_label and finished_at.",
      "if": {
        "properties": { "phase": { "properties": { "phase_class": { "const": "failed" } }, "required": ["phase_class"] } },
        "required": ["phase"]
      },
      "then": {
        "properties": {
          "phase": {
            "required": ["failure_or_partial_summary_label"],
            "properties": { "failure_or_partial_summary_label": { "$ref": "#/$defs/reviewable_sentence" } }
          },
          "timestamps": {
            "required": ["finished_at"],
            "properties": { "finished_at": { "$ref": "#/$defs/monotonic_timestamp" } }
          }
        }
      }
    },
    {
      "description": "partially_complete envelopes MUST carry failure_or_partial_summary_label and counts.",
      "if": {
        "properties": { "phase": { "properties": { "phase_class": { "const": "partially_complete" } }, "required": ["phase_class"] } },
        "required": ["phase"]
      },
      "then": {
        "properties": {
          "phase": {
            "required": ["failure_or_partial_summary_label"],
            "properties": { "failure_or_partial_summary_label": { "$ref": "#/$defs/reviewable_sentence" } }
          },
          "progress": {
            "required": ["included_count", "excluded_count", "failed_count"],
            "properties": {
              "included_count": { "type": "integer", "minimum": 0 },
              "excluded_count": { "type": "integer", "minimum": 0 },
              "failed_count": { "type": "integer", "minimum": 0 }
            }
          },
          "timestamps": {
            "required": ["finished_at"],
            "properties": { "finished_at": { "$ref": "#/$defs/monotonic_timestamp" } }
          }
        }
      }
    },
    {
      "description": "completed envelopes MUST carry completion_summary_label and finished_at.",
      "if": {
        "properties": { "phase": { "properties": { "phase_class": { "const": "completed" } }, "required": ["phase_class"] } },
        "required": ["phase"]
      },
      "then": {
        "properties": {
          "phase": {
            "required": ["completion_summary_label"],
            "properties": { "completion_summary_label": { "$ref": "#/$defs/reviewable_sentence" } }
          },
          "timestamps": {
            "required": ["finished_at"],
            "properties": { "finished_at": { "$ref": "#/$defs/monotonic_timestamp" } }
          }
        }
      }
    },
    {
      "description": "cancelled envelopes MUST carry failure_or_partial_summary_label naming the cancellation actor and finished_at.",
      "if": {
        "properties": { "phase": { "properties": { "phase_class": { "const": "cancelled" } }, "required": ["phase_class"] } },
        "required": ["phase"]
      },
      "then": {
        "properties": {
          "phase": {
            "required": ["failure_or_partial_summary_label"],
            "properties": { "failure_or_partial_summary_label": { "$ref": "#/$defs/reviewable_sentence" } }
          },
          "timestamps": {
            "required": ["finished_at"],
            "properties": { "finished_at": { "$ref": "#/$defs/monotonic_timestamp" } }
          }
        }
      }
    },
    {
      "description": "held envelopes MUST carry hold_or_suppression_reason_label, name at least one suppression reason, and have non-empty audit refs.",
      "if": {
        "properties": { "phase": { "properties": { "phase_class": { "const": "held" } }, "required": ["phase_class"] } },
        "required": ["phase"]
      },
      "then": {
        "properties": {
          "phase": {
            "required": ["hold_or_suppression_reason_label", "suppression_reasons", "quiet_hours_modes"],
            "properties": {
              "hold_or_suppression_reason_label": { "$ref": "#/$defs/reviewable_sentence" },
              "suppression_reasons": {
                "type": "array",
                "items": { "$ref": "#/$defs/suppression_reason" },
                "minItems": 1,
                "uniqueItems": true
              },
              "quiet_hours_modes": {
                "type": "array",
                "items": { "$ref": "#/$defs/quiet_hours_mode" },
                "minItems": 1,
                "uniqueItems": true
              }
            }
          },
          "audit": {
            "required": ["audit_event_refs"],
            "properties": {
              "audit_event_refs": {
                "type": "array",
                "items": { "$ref": "#/$defs/opaque_id" },
                "minItems": 1,
                "uniqueItems": true
              }
            }
          }
        }
      }
    },
    {
      "description": "suppressed envelopes MUST carry hold_or_suppression_reason_label, a non-null policy_source_ref, and non-empty audit refs.",
      "if": {
        "properties": { "phase": { "properties": { "phase_class": { "const": "suppressed" } }, "required": ["phase_class"] } },
        "required": ["phase"]
      },
      "then": {
        "properties": {
          "phase": {
            "required": ["hold_or_suppression_reason_label", "policy_source_ref"],
            "properties": {
              "hold_or_suppression_reason_label": { "$ref": "#/$defs/reviewable_sentence" },
              "policy_source_ref": { "$ref": "#/$defs/opaque_id" }
            }
          },
          "audit": {
            "required": ["audit_event_refs"],
            "properties": {
              "audit_event_refs": {
                "type": "array",
                "items": { "$ref": "#/$defs/opaque_id" },
                "minItems": 1,
                "uniqueItems": true
              }
            }
          }
        }
      }
    },
    {
      "description": "Any sensitive axis (cost, policy, network, trust, provider state, recovery posture) requires detail_or_evidence_required true and a non-null detail_or_evidence_ref.",
      "if": {
        "properties": {
          "sensitivity": {
            "anyOf": [
              { "properties": { "affects_cost": { "const": true } }, "required": ["affects_cost"] },
              { "properties": { "affects_policy": { "const": true } }, "required": ["affects_policy"] },
              { "properties": { "affects_network": { "const": true } }, "required": ["affects_network"] },
              { "properties": { "affects_trust": { "const": true } }, "required": ["affects_trust"] },
              { "properties": { "affects_provider_state": { "const": true } }, "required": ["affects_provider_state"] },
              { "properties": { "affects_recovery_posture": { "const": true } }, "required": ["affects_recovery_posture"] }
            ]
          }
        },
        "required": ["sensitivity"]
      },
      "then": {
        "properties": {
          "sensitivity": {
            "required": ["detail_or_evidence_required", "detail_or_evidence_ref"],
            "properties": {
              "detail_or_evidence_required": { "const": true },
              "detail_or_evidence_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        }
      }
    },
    {
      "description": "open_details affordance MUST always be present.",
      "properties": {
        "affordances": {
          "required": ["open_details"],
          "properties": {
            "open_details": {
              "required": ["availability_class", "label", "target_ref"],
              "properties": {
                "availability_class": { "const": "enabled" }
              }
            }
          }
        }
      }
    },
    {
      "description": "When the envelope's cancel affordance is enabled, an open-details affordance MUST also be enabled and the cancel command_id MUST be non-null.",
      "if": {
        "properties": {
          "affordances": {
            "properties": {
              "cancel": {
                "properties": { "availability_class": { "const": "enabled" } },
                "required": ["availability_class"]
              }
            },
            "required": ["cancel"]
          }
        },
        "required": ["affordances"]
      },
      "then": {
        "properties": {
          "affordances": {
            "properties": {
              "cancel": {
                "required": ["command_id", "cancellability_class"],
                "properties": {
                  "command_id": { "$ref": "#/$defs/opaque_id" },
                  "cancellability_class": { "const": "cancellable" }
                }
              }
            }
          }
        }
      }
    },
    {
      "description": "When the envelope's retry affordance is enabled, the retry command_id MUST be non-null and the retry availability MUST be enabled.",
      "if": {
        "properties": {
          "affordances": {
            "properties": {
              "retry": {
                "properties": { "availability_class": { "const": "enabled" } },
                "required": ["availability_class"]
              }
            },
            "required": ["retry"]
          }
        },
        "required": ["affordances"]
      },
      "then": {
        "properties": {
          "affordances": {
            "properties": {
              "retry": {
                "required": ["command_id"],
                "properties": { "command_id": { "$ref": "#/$defs/opaque_id" } }
              }
            }
          }
        }
      }
    },
    {
      "description": "badge_source = derived_from_envelope_state requires emitted_badge_classes non-empty and a partition_rule_label.",
      "if": {
        "properties": {
          "badge_source": {
            "properties": { "badge_source_class": { "const": "derived_from_envelope_state" } },
            "required": ["badge_source_class"]
          }
        },
        "required": ["badge_source"]
      },
      "then": {
        "properties": {
          "badge_source": {
            "required": ["emitted_badge_classes", "partition_rule_label"],
            "properties": {
              "emitted_badge_classes": {
                "type": "array",
                "items": { "$ref": "#/$defs/badge_class" },
                "minItems": 1,
                "uniqueItems": true
              },
              "partition_rule_label": { "$ref": "#/$defs/short_label_text" }
            }
          }
        }
      }
    },
    {
      "description": "badge_source = derived_from_canonical_object requires emitted_badge_classes non-empty and a partition_rule_label.",
      "if": {
        "properties": {
          "badge_source": {
            "properties": { "badge_source_class": { "const": "derived_from_canonical_object" } },
            "required": ["badge_source_class"]
          }
        },
        "required": ["badge_source"]
      },
      "then": {
        "properties": {
          "badge_source": {
            "required": ["emitted_badge_classes", "partition_rule_label"],
            "properties": {
              "emitted_badge_classes": {
                "type": "array",
                "items": { "$ref": "#/$defs/badge_class" },
                "minItems": 1,
                "uniqueItems": true
              },
              "partition_rule_label": { "$ref": "#/$defs/short_label_text" }
            }
          }
        }
      }
    },
    {
      "description": "badge_source = aggregated_grouped_burst requires grouped_burst_id_ref non-null and dedupe_key_scheme = grouped_burst_id.",
      "if": {
        "properties": {
          "badge_source": {
            "properties": { "badge_source_class": { "const": "aggregated_grouped_burst" } },
            "required": ["badge_source_class"]
          }
        },
        "required": ["badge_source"]
      },
      "then": {
        "properties": {
          "badge_source": {
            "required": ["grouped_burst_id_ref", "dedupe_key_scheme"],
            "properties": {
              "grouped_burst_id_ref": { "$ref": "#/$defs/opaque_id" },
              "dedupe_key_scheme": { "const": "grouped_burst_id" }
            }
          }
        }
      }
    },
    {
      "description": "badge_source = not_a_badge_source requires emitted_badge_classes empty.",
      "if": {
        "properties": {
          "badge_source": {
            "properties": { "badge_source_class": { "const": "not_a_badge_source" } },
            "required": ["badge_source_class"]
          }
        },
        "required": ["badge_source"]
      },
      "then": {
        "properties": {
          "badge_source": {
            "properties": {
              "emitted_badge_classes": { "type": "array", "maxItems": 0 }
            },
            "required": ["emitted_badge_classes"]
          }
        }
      }
    },
    {
      "description": "notification_linkage.shared_canonical_event_id MUST mirror the envelope's canonical_event_id.",
      "properties": {
        "notification_linkage": {
          "required": ["shared_canonical_event_id", "shared_canonical_object_target_ref"],
          "properties": {
            "shared_canonical_event_id": { "$ref": "#/$defs/opaque_id" },
            "shared_canonical_object_target_ref": { "$ref": "#/$defs/opaque_id" }
          }
        }
      }
    }
  ],
  "$defs": {
    "durable_job_envelope_schema_version": {
      "type": "integer",
      "const": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe for logs, RPC, support bundles, manifests, OS notification payloads, and lock-screen summaries. Never contains raw paths, raw URLs, raw secret material, raw provider payloads, raw prompt or completion text, or raw logs."
    },
    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": { "type": "object", "additionalProperties": true },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "source_subsystem": {
      "type": "string",
      "enum": [
        "editor",
        "terminal",
        "review_and_diff",
        "palette_and_search",
        "install_update_attach",
        "ai_apply",
        "collaboration",
        "provider_bearing",
        "docs_help_service_health",
        "support_export",
        "build_system",
        "test_runner",
        "debug_session",
        "task_runner",
        "indexer",
        "vfs_save",
        "sync_mirror",
        "notebook_kernel",
        "remote_agent",
        "extension_host",
        "workspace_trust",
        "policy_resolver",
        "admin_policy",
        "secret_broker",
        "runtime_power_manager",
        "shell"
      ],
      "description": "Re-exported from schemas/ux/activity_event_envelope.schema.json without modification."
    },
    "client_scope": {
      "type": "string",
      "enum": [
        "desktop_product",
        "cli",
        "companion_surface",
        "remote_agent",
        "sdk_or_api",
        "managed_admin_surface"
      ],
      "description": "Re-exported from schemas/governance/capability_lifecycle.schema.json without modification."
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ],
      "description": "Re-exported from schemas/governance/capability_lifecycle.schema.json without modification."
    },
    "execution_origin_class": {
      "type": "string",
      "enum": [
        "user_initiated",
        "system_background",
        "extension_initiated",
        "remote_agent_initiated",
        "managed_policy_initiated",
        "ai_agent_initiated",
        "provider_callback"
      ]
    },
    "durable_job_subject_class": {
      "type": "string",
      "enum": [
        "build",
        "test",
        "debug_session",
        "task_run",
        "indexer_pass",
        "save_or_sync",
        "update_install",
        "restore_or_recovery",
        "download_or_upload",
        "notebook_execution",
        "ai_apply_execution",
        "review_apply_execution",
        "provider_handoff",
        "remote_attach",
        "collaboration_session",
        "admin_policy_refresh"
      ],
      "description": "Re-exported from schemas/ux/activity_event_envelope.schema.json without modification."
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "build",
        "test_run",
