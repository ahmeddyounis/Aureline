    "phase_class": {
      "type": "string",
      "enum": [
        "preparing",
        "queued",
        "running",
        "waiting_input",
        "partially_complete",
        "completed",
        "failed",
        "cancelled",
        "held",
        "suppressed"
      ],
      "description": "Frozen progress-phase grammar. Every envelope resolves to exactly one phase class. Phase splits emit a new envelope under the same durable_job_id and canonical_event_id."
    },
    "progress_form_class": {
      "type": "string",
      "enum": [
        "labeled_progress_bar",
        "spinner_only",
        "phase_only",
        "queue_only",
        "approval_only",
        "hold_only",
        "completion_only",
        "failure_only",
        "cancelled_only"
      ],
      "description": "Frozen progress-form grammar. labeled_progress_bar is preferred for measurable work; spinner_only is allowed only with an indeterminate reason and a phase label; phase_only / queue_only / approval_only / hold_only / completion_only / failure_only / cancelled_only render terminal-or-blocked states without a numeric bar."
    },
