{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/stabilize-the-start-center-recent-work-list-workspace.schema.json",
  "title": "Aureline entry-target disclosure record",
  "description": "Boundary schema for entry_target_disclosure_record, the single governed record the Start Center, recent-work list, workspace switcher, command palette, menus, diagnostics, support exports, Help/About, and docs all read for one entry target on the claimed stable matrix. It is minted by crates/aureline-shell/src/start_center_stable and binds, for one canonical recent-work identity: (1) target-kind disclosure — the canonical target kind, path/host/provider subtitle, last-opened time, trust posture, and restore availability shown before the user commits, reusing the aureline_workspace recent-work vocabulary rather than a parallel model; (2) a public claim ceiling — no row may assert a live open for an unavailable target, remote availability for a disconnected remote, restore fidelity beyond what restore proves, or trust the row cannot prove; (3) recovery before commit — Locate, Reconnect/Reauthorize, an open-minimal route where safe, and a metadata-only Remove, with a failed open keeping rather than silently discarding the stale entry; (4) one model across surfaces — the Start Center and switcher projections share identity and recovery behavior, and the switcher keeps a cancel/reopen-previous return path; (5) route parity — the same target opens from the Start Center, switcher, command palette, and a menu command, each keyboard reachable; (6) accessibility — tab order, row narration, action labels, and recovery affordances reachable in normal, high-contrast, and zoomed layouts; and (7) availability — every row stays listed without an account or managed services. Refs are opaque aureline://<class>/<id> durable-object refs; subtitles are short presentation strings only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "recent_work_ref",
    "title",
    "summary",
    "target_kind",
    "target_kind_label",
    "target_class",
    "target_state",
    "failure_state",
    "trust_state",
    "restore_availability",
    "location_subtitle",
    "subtitle_kind",
    "last_opened_at",
    "pinned",
    "list_section",
    "disclosure",
    "claim_ceiling",
    "recovery_routes",
    "discards_stale_entry_on_failure",
    "surfaces",
    "routes",
    "accessibility",
    "available_without_account",
    "available_without_managed_services",
    "honesty_marker_present",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": { "type": "string", "const": "entry_target_disclosure_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "notice": { "$ref": "#/$defs/reviewable_sentence" },
    "shared_contract_ref": {
      "type": "string",
      "const": "shell:entry_target_disclosure_stable:v1"
    },
    "record_id": { "$ref": "#/$defs/stable_token" },
    "as_of": { "$ref": "#/$defs/utc_date_time" },
    "recent_work_ref": { "$ref": "#/$defs/canonical_ref" },
    "title": { "$ref": "#/$defs/reviewable_sentence" },
    "summary": { "$ref": "#/$defs/reviewable_sentence" },
    "target_kind": { "$ref": "#/$defs/target_kind" },
    "target_kind_label": { "$ref": "#/$defs/non_empty_string" },
    "target_class": { "$ref": "#/$defs/target_class" },
    "target_state": { "$ref": "#/$defs/target_state" },
    "failure_state": { "$ref": "#/$defs/failure_state" },
    "trust_state": { "$ref": "#/$defs/trust_state" },
    "restore_availability": { "$ref": "#/$defs/restore_availability" },
    "location_subtitle": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 200
    },
    "subtitle_kind": { "$ref": "#/$defs/subtitle_kind" },
    "last_opened_at": { "$ref": "#/$defs/non_empty_string" },
    "pinned": { "type": "boolean" },
    "list_section": { "$ref": "#/$defs/list_section" },
    "disclosure": { "$ref": "#/$defs/disclosure_facts" },
    "claim_ceiling": { "$ref": "#/$defs/claim_ceiling" },
    "recovery_routes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/recovery_route" }
    },
    "discards_stale_entry_on_failure": { "type": "boolean", "const": false },
    "surfaces": { "$ref": "#/$defs/surface_parity" },
    "routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/entry_route" }
    },
    "accessibility": { "$ref": "#/$defs/accessibility" },
    "available_without_account": { "type": "boolean", "const": true },
    "available_without_managed_services": { "type": "boolean", "const": true },
    "honesty_marker_present": { "type": "boolean" },
    "diagnostics_export_ref": { "$ref": "#/$defs/canonical_ref" },
    "support_export_ref": { "$ref": "#/$defs/canonical_ref" },
    "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/canonical_ref" } },
    "narrative_refs": { "type": "array", "items": { "$ref": "#/$defs/canonical_ref" } }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1, "maxLength": 200 },
    "reviewable_sentence": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "stable_token": { "type": "string", "minLength": 1, "maxLength": 200 },
    "utc_date_time": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "canonical_ref": {
      "type": "string",
      "description": "Opaque durable-object ref of the form aureline://<class>/<id>; <class> is not a generic landing page.",
      "pattern": "^aureline://(?!(home|dashboard|landing|index|overview|start|root)/)[^/]+/.+$",
      "maxLength": 200
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "local_file",
        "local_folder",
        "local_repo_root",
        "workspace_manifest",
        "workset_manifest",
        "remote_repository",
        "ssh_workspace",
        "container_workspace",
        "devcontainer_workspace",
        "managed_cloud_workspace",
        "portable_state_package",
        "handoff_packet",
        "competitor_config_root",
        "template_or_prebuild_snapshot",
        "review_or_work_item_deep_link",
        "recovery_checkpoint"
      ]
    },
    "target_class": {
      "type": "string",
      "enum": ["local", "remote_backed", "managed"]
    },
    "target_state": {
      "type": "string",
      "enum": [
        "reachable",
        "stale_metadata",
        "missing_target",
        "moved_target_detected",
        "remote_unreachable",
        "authority_expired",
        "locked_by_other_instance",
        "policy_blocked",
        "quarantined",
        "mode_downgraded",
        "unknown"
      ]
    },
    "failure_state": {
      "type": "string",
      "enum": [
        "ready",
        "missing_path",
        "moved_root",
        "reconnect_required",
        "inspect_only",
        "blocked",
        "unknown"
      ]
    },
    "trust_state": {
      "type": "string",
      "enum": ["trusted", "restricted", "pending_evaluation"]
    },
    "restore_availability": {
      "type": "string",
      "enum": ["exact", "compatible", "layout_only", "evidence_only", "none"]
    },
    "subtitle_kind": {
      "type": "string",
      "enum": ["path", "host", "provider", "target_only", "none"]
    },
    "list_section": {
      "type": "string",
      "enum": ["pinned", "recent"]
    },
    "recovery_action_role": {
      "type": "string",
      "enum": ["primary", "recovery", "secondary", "destructive_metadata_only"]
    },
    "entry_route_surface": {
      "type": "string",
      "enum": ["start_center", "workspace_switcher", "command_palette", "menu_command"]
    },
    "layout_mode": {
      "type": "string",
      "enum": ["normal", "high_contrast", "zoomed"]
    },
    "disclosure_facts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "discloses_target_kind",
        "discloses_subtitle",
        "discloses_last_opened",
        "discloses_trust_state",
        "discloses_restore_availability",
        "discloses_recovery_routes"
      ],
      "properties": {
        "discloses_target_kind": { "type": "boolean", "const": true },
        "discloses_subtitle": { "type": "boolean", "const": true },
        "discloses_last_opened": { "type": "boolean", "const": true },
        "discloses_trust_state": { "type": "boolean", "const": true },
        "discloses_restore_availability": { "type": "boolean", "const": true },
        "discloses_recovery_routes": { "type": "boolean", "const": true }
      }
    },
    "claim_ceiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asserts_live_open",
        "asserts_remote_available",
        "asserts_full_restore_fidelity",
        "asserts_trusted_without_evaluation"
      ],
      "properties": {
        "asserts_live_open": { "type": "boolean" },
        "asserts_remote_available": { "type": "boolean" },
        "asserts_full_restore_fidelity": { "type": "boolean" },
        "asserts_trusted_without_evaluation": { "type": "boolean" }
      }
    },
    "recovery_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "action_label",
        "action_role",
        "requires_confirmation",
        "metadata_only_cleanup",
        "preserves_unrelated_state"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/stable_token" },
        "action_label": { "$ref": "#/$defs/non_empty_string" },
        "action_role": { "$ref": "#/$defs/recovery_action_role" },
        "requires_confirmation": { "type": "boolean" },
        "metadata_only_cleanup": { "type": "boolean" },
        "preserves_unrelated_state": { "type": "boolean", "const": true }
      }
    },
    "entry_route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "route_ref", "keyboard_reachable", "activates_same_target"],
      "properties": {
        "surface": { "$ref": "#/$defs/entry_route_surface" },
        "route_ref": { "$ref": "#/$defs/canonical_ref" },
        "keyboard_reachable": { "type": "boolean", "const": true },
        "activates_same_target": { "type": "boolean", "const": true }
      }
    },
    "surface_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_center_row_id",
        "workspace_switcher_row_id",
        "switcher_entry_classes",
        "switch_failure_actions",
        "recovery_action_ids",
        "parity_holds"
      ],
      "properties": {
        "start_center_row_id": { "$ref": "#/$defs/stable_token" },
        "workspace_switcher_row_id": { "$ref": "#/$defs/stable_token" },
        "switcher_entry_classes": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "switch_failure_actions": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "recovery_action_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "parity_holds": { "type": "boolean", "const": true }
      }
    },
    "layout_mode_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "row_narration_available", "recovery_affordances_reachable"],
      "properties": {
        "mode": { "$ref": "#/$defs/layout_mode" },
        "row_narration_available": { "type": "boolean", "const": true },
        "recovery_affordances_reachable": { "type": "boolean", "const": true }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_order_index",
        "tab_stop_count",
        "row_narration",
        "action_labels",
        "layout_modes"
      ],
      "properties": {
        "focus_order_index": { "type": "integer", "minimum": 0 },
        "tab_stop_count": { "type": "integer", "minimum": 1 },
        "row_narration": { "$ref": "#/$defs/reviewable_sentence" },
        "action_labels": { "type": "array", "items": { "$ref": "#/$defs/non_empty_string" } },
        "layout_modes": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/layout_mode_disclosure" }
        }
      }
    }
  }
}
