{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/finalize-the-settings-ui-with-effective-value-inspector.schema.json",
  "title": "Aureline settings-UI certification record",
  "description": "Boundary schema for settings_ui_certification_record, the single governed record the settings effective-configuration inspector, command palette, status bar, diagnostics, support exports, Help/About, migration review, dashboards, and docs all read for one settings posture. It is minted by crates/aureline-settings/src/settings_ui_stable as a genuine projection of the live settings runtime (crate::schema::SchemaRegistry, crate::resolver::EffectiveSettingsResolver, crate::inspector) and binds, for one posture: (1) one effective-setting record per visible setting carrying value, winning scope, lock state/reason, restart posture, and the setting-definition registry fields; (2) a shadow contributor chain classifying the built-in default, channel default, active profile, temporary profile, machine-local, synced, workspace, folder/language overrides, and the policy-owned ceiling so a setting never implies one flat value; (3) scope-explicit previewable writes with the target artifact, the blocked-write reason and a Diagnostics Center entry point when denied, the restart impact, and any experiment/lifecycle dependency; (4) cross-surface parity across the desktop UI, CLI inspect, Help/About, diagnostics/support export, and migration/import review; (5) a profile-switch review summarizing immediate changes, restart-required deltas, excluded machine-local state, narrowing effects, and rollback-checkpoint posture; (6) a public claim ceiling no posture may exceed; and (7) a derived stable-claim verdict that narrows a posture which cannot prove a pillar, or whose lowest surface marker is below Stable, below Stable with a named reason. Minted refs are opaque aureline://<class>/<id> object refs; upstream projection refs keep their source scheme.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "posture_id",
    "posture_label",
    "title",
    "summary",
    "surface_lifecycle_marker",
    "effective_settings",
    "previewable_writes",
    "surface_parity",
    "profile_switch_review",
    "contributor_coverage",
    "pillars",
    "claim_ceiling",
    "stable_qualification",
    "recovery_routes",
    "routes",
    "accessibility",
    "available_without_account",
    "available_without_managed_services",
    "honesty_marker_present",
    "upstream",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": { "const": "settings_ui_certification_record" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "notice": { "type": "string", "minLength": 1 },
    "shared_contract_ref": { "const": "settings:settings_ui_stable:v1" },
    "record_id": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "minLength": 1 },
    "posture_id": { "type": "string", "minLength": 1 },
    "posture_label": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "surface_lifecycle_marker": { "$ref": "#/$defs/lifecycleMarker" },
    "effective_settings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/effectiveSettingRow" }
    },
    "previewable_writes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/previewableWriteRow" }
    },
    "surface_parity": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/surfaceParityRow" }
    },
    "profile_switch_review": { "$ref": "#/$defs/profileSwitchReview" },
    "contributor_coverage": {
      "type": "array",
      "items": { "$ref": "#/$defs/contributorClass" }
    },
    "pillars": { "$ref": "#/$defs/pillars" },
    "claim_ceiling": { "$ref": "#/$defs/claimCeiling" },
    "stable_qualification": { "$ref": "#/$defs/stableQualification" },
    "recovery_routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/recoveryRoute" }
    },
    "routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/entryRoute" }
    },
    "accessibility": { "$ref": "#/$defs/accessibility" },
    "available_without_account": { "type": "boolean" },
    "available_without_managed_services": { "type": "boolean" },
    "honesty_marker_present": { "type": "boolean" },
    "upstream": { "$ref": "#/$defs/upstream" },
    "diagnostics_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "support_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } },
    "narrative_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } }
  },
  "$defs": {
    "canonicalRef": {
      "type": "string",
      "pattern": "^aureline://(?!home/|landing/|root/)[^/]+/.+",
      "maxLength": 200
    },
    "presentRef": { "type": "string", "minLength": 1, "maxLength": 200 },
    "token": { "type": "string", "minLength": 1 },
    "lifecycleMarker": { "enum": ["preview", "beta", "stable"] },
    "claimClass": { "enum": ["stable", "beta", "preview", "not_claimed"] },
    "contributorClass": {
      "enum": [
        "built_in_default",
        "channel_default",
        "active_profile",
        "temporary_profile",
        "machine_local",
        "synced_profile",
        "workspace",
        "folder_override",
        "language_override",
        "session_override",
        "policy_owned"
      ]
    },
    "surfaceClass": {
      "enum": [
        "desktop_ui",
        "cli_inspect",
        "help_about",
        "diagnostics_support_export",
        "migration_import_review"
      ]
    },
    "routeSurface": {
      "enum": ["settings_inspector", "command_palette", "status_bar", "menu_command"]
    },
    "recoveryRole": { "enum": ["primary", "recovery", "secondary"] },
    "layoutMode": { "enum": ["normal", "high_contrast", "zoomed"] },
    "narrowingReason": {
      "enum": [
        "setting_resolution_incomplete",
        "shadow_chain_flattened",
        "write_not_scope_explicit",
        "surface_clones_prose",
        "profile_switch_review_incomplete",
        "setting_id_not_canonical",
        "surface_not_yet_stable"
      ]
    },
    "shadowContributorRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "contributor_class",
        "source_label",
        "value_preview",
        "relation",
        "winner"
      ],
      "properties": {
        "scope": { "$ref": "#/$defs/token" },
        "contributor_class": { "$ref": "#/$defs/contributorClass" },
        "source_label": { "type": "string", "minLength": 1 },
        "value_preview": { "type": "string" },
        "relation": { "$ref": "#/$defs/token" },
        "winner": { "type": "boolean" }
      }
    },
    "effectiveSettingRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "setting_id",
        "declared_type",
        "winning_value_summary",
        "winning_scope",
        "winning_contributor",
        "source_label",
        "setting_lifecycle",
        "surface_marker",
        "allowed_scopes",
        "default_value_preview",
        "migration_aliases",
        "restart_posture",
        "restart_required",
        "sensitivity_class",
        "redaction_class",
        "preview_class",
        "capability_dependencies",
        "lock_state",
        "lock_reason",
        "escalation_path_ref",
        "shadow_chain",
        "effective_record_ref",
        "setting_id_canonical",
        "resolves_through_one_record",
        "conforms"
      ],
      "properties": {
        "setting_id": { "type": "string", "minLength": 1 },
        "declared_type": { "$ref": "#/$defs/token" },
        "winning_value_summary": { "type": "string" },
        "winning_scope": { "$ref": "#/$defs/token" },
        "winning_contributor": { "$ref": "#/$defs/contributorClass" },
        "source_label": { "type": "string", "minLength": 1 },
        "setting_lifecycle": { "$ref": "#/$defs/lifecycleMarker" },
        "surface_marker": { "$ref": "#/$defs/lifecycleMarker" },
        "allowed_scopes": { "type": "array", "items": { "$ref": "#/$defs/token" } },
        "default_value_preview": { "type": "string" },
        "migration_aliases": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "restart_posture": { "$ref": "#/$defs/token" },
        "restart_required": { "type": "boolean" },
        "sensitivity_class": { "$ref": "#/$defs/token" },
        "redaction_class": { "$ref": "#/$defs/token" },
        "preview_class": { "$ref": "#/$defs/token" },
        "capability_dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "help_doc_ref": { "$ref": "#/$defs/presentRef" },
        "lock_state": { "$ref": "#/$defs/token" },
        "lock_reason": { "$ref": "#/$defs/token" },
        "escalation_path_ref": { "$ref": "#/$defs/canonicalRef" },
        "shadow_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/shadowContributorRow" }
        },
        "effective_record_ref": { "$ref": "#/$defs/canonicalRef" },
        "setting_id_canonical": { "type": "boolean" },
        "resolves_through_one_record": { "type": "boolean" },
        "waiver_ref": { "$ref": "#/$defs/presentRef" },
        "conforms": { "type": "boolean" }
      }
    },
    "previewableWriteRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "setting_id",
        "target_scope",
        "target_contributor",
        "target_artifact_ref",
        "scope_explicit",
        "verdict",
        "denied",
        "diagnostics_entry_ref",
        "restart_posture",
        "restart_impact",
        "preview_required",
        "checkpoint_required",
        "approval_required",
        "conforms"
      ],
      "properties": {
        "setting_id": { "type": "string", "minLength": 1 },
        "target_scope": { "$ref": "#/$defs/token" },
        "target_contributor": { "$ref": "#/$defs/contributorClass" },
        "target_artifact_ref": { "$ref": "#/$defs/canonicalRef" },
        "scope_explicit": { "type": "boolean" },
        "verdict": { "$ref": "#/$defs/token" },
        "denied": { "type": "boolean" },
        "blocked_write_reason": { "type": "string", "minLength": 1 },
        "diagnostics_entry_ref": { "$ref": "#/$defs/canonicalRef" },
        "restart_posture": { "$ref": "#/$defs/token" },
        "restart_impact": { "type": "string", "minLength": 1 },
        "preview_required": { "type": "boolean" },
        "checkpoint_required": { "type": "boolean" },
        "approval_required": { "type": "boolean" },
        "lifecycle_dependency": { "type": "string", "minLength": 1 },
        "conforms": { "type": "boolean" }
      }
    },
    "surfaceParityRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "consumes_shared_record",
        "clones_prose",
        "shared_contract_ref",
        "record_ref",
        "conforms"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/surfaceClass" },
        "consumes_shared_record": { "type": "boolean" },
        "clones_prose": { "type": "boolean" },
        "shared_contract_ref": { "$ref": "#/$defs/token" },
        "record_ref": { "$ref": "#/$defs/canonicalRef" },
        "waiver_ref": { "$ref": "#/$defs/presentRef" },
        "conforms": { "type": "boolean" }
      }
    },
    "profileSwitchChange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "setting_id",
        "before_value_preview",
        "after_value_preview",
        "restart_required",
        "narrowed"
      ],
      "properties": {
        "setting_id": { "type": "string", "minLength": 1 },
        "before_value_preview": { "type": "string" },
        "after_value_preview": { "type": "string" },
        "restart_required": { "type": "boolean" },
        "narrowed": { "type": "boolean" }
      }
    },
    "profileSwitchReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_profile_ref",
        "to_profile_ref",
        "to_profile_is_temporary",
        "immediate_changes",
        "restart_required_changes",
        "excluded_machine_specific",
        "narrowing_effects",
        "creates_rollback_checkpoint",
        "summary",
        "conforms"
      ],
      "properties": {
        "from_profile_ref": { "$ref": "#/$defs/presentRef" },
        "to_profile_ref": { "$ref": "#/$defs/presentRef" },
        "to_profile_is_temporary": { "type": "boolean" },
        "immediate_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/profileSwitchChange" }
        },
        "restart_required_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/profileSwitchChange" }
        },
        "excluded_machine_specific": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "narrowing_effects": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "creates_rollback_checkpoint": { "type": "boolean" },
        "rollback_checkpoint_ref": { "$ref": "#/$defs/canonicalRef" },
        "summary": { "type": "string", "minLength": 1 },
        "conforms": { "type": "boolean" }
      }
    },
    "pillars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "every_setting_resolves_one_record",
        "shadow_chain_exposes_contributors",
        "writes_scope_explicit",
        "surfaces_share_one_truth",
        "profile_switch_review_complete",
        "setting_ids_canonical_in_exports"
      ],
      "properties": {
        "every_setting_resolves_one_record": { "type": "boolean" },
        "shadow_chain_exposes_contributors": { "type": "boolean" },
        "writes_scope_explicit": { "type": "boolean" },
        "surfaces_share_one_truth": { "type": "boolean" },
        "profile_switch_review_complete": { "type": "boolean" },
        "setting_ids_canonical_in_exports": { "type": "boolean" }
      }
    },
    "claimCeiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asserts_every_setting_resolves_one_record",
        "asserts_shadow_chain_exposes_contributors",
        "asserts_writes_scope_explicit",
        "asserts_surfaces_share_one_truth",
        "asserts_profile_switch_review_complete",
        "asserts_setting_ids_canonical"
      ],
      "properties": {
        "asserts_every_setting_resolves_one_record": { "type": "boolean" },
        "asserts_shadow_chain_exposes_contributors": { "type": "boolean" },
        "asserts_writes_scope_explicit": { "type": "boolean" },
        "asserts_surfaces_share_one_truth": { "type": "boolean" },
        "asserts_profile_switch_review_complete": { "type": "boolean" },
        "asserts_setting_ids_canonical": { "type": "boolean" }
      }
    },
    "stableQualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_class", "qualifies_stable", "narrowing_reasons"],
      "properties": {
        "claim_class": { "$ref": "#/$defs/claimClass" },
        "qualifies_stable": { "type": "boolean" },
        "narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowingReason" }
        }
      }
    },
    "recoveryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_label", "action_role", "keyboard_reachable"],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_label": { "type": "string", "minLength": 1 },
        "action_role": { "$ref": "#/$defs/recoveryRole" },
        "keyboard_reachable": { "const": true }
      }
    },
    "entryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "route_ref", "keyboard_reachable", "activates_same_record"],
      "properties": {
        "surface": { "$ref": "#/$defs/routeSurface" },
        "route_ref": { "$ref": "#/$defs/canonicalRef" },
        "keyboard_reachable": { "const": true },
        "activates_same_record": { "const": true }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_order_index",
        "tab_stop_count",
        "row_narration",
        "action_labels",
        "layout_modes"
      ],
      "properties": {
        "focus_order_index": { "type": "integer", "minimum": 0 },
        "tab_stop_count": { "type": "integer", "minimum": 0 },
        "row_narration": { "type": "string", "minLength": 1 },
        "action_labels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "layout_modes": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["mode", "row_narration_available", "recovery_affordances_reachable"],
            "properties": {
              "mode": { "$ref": "#/$defs/layoutMode" },
              "row_narration_available": { "const": true },
              "recovery_affordances_reachable": { "const": true }
            }
          }
        }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_ref",
        "resolver_state_ref",
        "inspector_contract_ref",
        "certified_setting_ids"
      ],
      "properties": {
        "registry_ref": { "$ref": "#/$defs/presentRef" },
        "resolver_state_ref": { "$ref": "#/$defs/presentRef" },
        "inspector_contract_ref": { "$ref": "#/$defs/presentRef" },
        "certified_setting_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
