{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/learning_mode_profile.schema.json",
  "title": "Aureline learning-mode profile authoring artifact",
  "description": "Boundary schema for the learning-mode profile authoring artifact frozen in docs/ux/learning_artifact_object_model.md. One learning_mode_profile_artifact record per portable learning-mode profile bundle. The record is the portable authoring object pack authors ship; the runtime learning_mode_profile_record on schemas/ux/guided_surface_state.schema.json carries render-time state for an active profile and resolves against this artifact by id. The contract mints no new learning_mode_profile_class, dismissal_class, reset_class, progress_export_class, deployment_profile_id, share_state_class, or replay_retention_class vocabulary; those re-export verbatim from schemas/ux/guided_surface_state.schema.json, schemas/ux/onboarding_portability_state.schema.json, schemas/ux/presentation_mode_state.schema.json, schemas/governance/capability_lifecycle.schema.json, and artifacts/governance/deployment_profiles.yaml. Adding a new jargon_level_class, tip_intensity_class, follow_state_class, state_portability_class, invariant_id, or denial_reason is additive-minor and bumps learning_mode_profile_artifact_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "$ref": "#/$defs/learning_mode_profile_artifact",
  "$defs": {
    "learning_mode_profile_artifact_schema_version": {
      "type": "integer",
      "const": 1
    },

    "record_kind": {
      "type": "string",
      "const": "learning_mode_profile_artifact"
    },

    "opaque_id": { "type": "string", "minLength": 1 },

    "monotonic_timestamp": { "type": "string", "format": "date-time" },

    "short_label_text": { "type": "string", "minLength": 1, "maxLength": 200 },

    "bcp47_locale_tag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": { "type": "object", "additionalProperties": true },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "profile_class": {
      "type": "string",
      "enum": [
        "default_individual_learner",
        "classroom_managed_pool",
        "facilitator_led_session",
        "air_gapped_offline_pack",
        "privacy_reduced_local_only",
        "policy_disabled"
      ],
      "description": "Re-exported from schemas/ux/guided_surface_state.schema.json learning_mode_profile_class."
    },

    "jargon_level_class": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced", "expert"]
    },

    "tip_intensity_class": {
      "type": "string",
      "enum": [
        "silent_inline_only",
        "gentle_hint",
        "prompted_acknowledge",
        "mandatory_step_required"
      ]
    },

    "dismissal_class": {
      "type": "string",
      "enum": [
        "per_session_one_shot",
        "per_profile_dismissable",
        "per_device_dismissable",
        "policy_locked",
        "not_dismissable"
      ],
      "description": "Re-exported from schemas/ux/guided_surface_state.schema.json."
    },

    "reset_class": {
      "type": "string",
      "enum": [
        "resettable_per_profile",
        "resettable_per_device",
        "resettable_per_account",
        "resettable_by_policy",
        "not_resettable_locally"
      ],
      "description": "Re-exported from schemas/ux/onboarding_portability_state.schema.json."
    },

    "progress_export_class": {
      "type": "string",
      "enum": [
        "in_portable_profile_package",
        "in_portable_profile_package_redacted",
        "in_support_bundle_redacted",
        "not_exported_machine_local",
        "blocked_by_policy"
      ],
      "description": "Re-exported from schemas/ux/guided_surface_state.schema.json."
    },

    "state_portability_class": {
      "type": "string",
      "enum": [
        "portable_profile_state",
        "machine_local_diagnostic",
        "device_scoped",
        "account_scoped",
        "policy_scoped",
        "ephemeral_session"
      ],
      "description": "Re-exported from schemas/ux/onboarding_portability_state.schema.json without modification."
    },

    "share_state_class": {
      "type": "string",
      "enum": [
        "local_only_no_share",
        "shared_to_named_audience",
        "shared_to_classroom_managed_pool",
        "shared_to_facilitator_only",
        "shared_blocked_by_policy",
        "shared_unavailable_in_envelope"
      ],
      "description": "Re-exported from schemas/ux/presentation_mode_state.schema.json without modification."
    },

    "follow_state_class": {
      "type": "string",
      "enum": [
        "no_follow_local_only",
        "presenter_broadcast_follow",
        "optional_follow_audience_choice",
        "audience_pinned_to_presenter",
        "follow_blocked_by_envelope"
      ],
      "description": "Closed follow-state vocabulary on the artifact. Reads as a posture, not as authority; mutating control rides a control_grant_record on schemas/collaboration/control_grant.schema.json."
    },

    "replay_retention_class": {
      "type": "string",
      "enum": [
        "no_replay_retained",
        "metadata_only_replay_local_redacted",
        "metadata_only_replay_in_support_bundle_redacted",
        "replay_blocked_by_policy",
        "classroom_artifact_privacy_bounded"
      ],
      "description": "Re-exported from schemas/ux/presentation_mode_state.schema.json without modification."
    },

    "deployment_profile_id": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud",
        "air_gapped_mirror_only"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": { "type": "string", "enum": ["trusted", "restricted"] },
        "execution_context_id": { "type": "string", "minLength": 1 }
      }
    },

    "invariant_assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["invariant_id", "asserted_true"],
      "properties": {
        "invariant_id": {
          "type": "string",
          "enum": [
            "every_guided_surface_cites_command_or_docs_anchor",
            "derived_guided_surface_retains_upstream",
            "no_private_mutation_path_outside_command_registry",
            "stale_or_unverified_surface_suppresses_or_discloses",
            "portable_dismissal_never_leaks_account_or_policy_state",
            "policy_disabled_learning_surface_never_renders",
            "locale_fallback_is_disclosed",
            "exercise_steps_respect_workspace_trust",
            "imported_teaching_pack_is_verified_before_render",
            "presentation_adjunct_preserves_command_identity",
            "learning_mode_profile_exports_match_portability_lanes",
            "every_guided_surface_resolves_against_rule_record"
          ],
          "description": "Closed invariant-id vocabulary re-exported from schemas/ux/guided_surface_state.schema.json. Every learning_mode_profile_artifact declares all twelve const-true."
        },
        "asserted_true": { "type": "boolean", "const": true },
        "notes": { "$ref": "#/$defs/short_label_text" }
      }
    },

    "denial_reason": {
      "type": "string",
      "enum": [
        "learning_artifact_profile_envelope_mismatch",
        "learning_artifact_profile_export_class_mismatch",
        "learning_artifact_profile_share_state_envelope_mismatch",
        "learning_mode_profile_artifact_schema_version_lagging"
      ]
    },

    "learning_mode_profile_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "learning_mode_profile_artifact_schema_version",
        "profile_artifact_id",
        "profile_class",
        "profile_artifact_version",
        "default_jargon_level_class",
        "default_tip_intensity_class",
        "default_locale",
        "default_dismissal_class",
        "default_reset_class",
        "default_progress_export_class",
        "default_share_state_class",
        "default_follow_state_class",
        "default_replay_retention_class",
        "deployment_profile_refs",
        "state_portability_class",
        "policy_context",
        "redaction_class",
        "invariants",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "learning_mode_profile_artifact_schema_version": {
          "$ref": "#/$defs/learning_mode_profile_artifact_schema_version"
        },
        "profile_artifact_id": { "$ref": "#/$defs/opaque_id" },
        "profile_class": { "$ref": "#/$defs/profile_class" },
        "profile_artifact_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32,
          "description": "Semver-style short label for the profile artifact (e.g. 1.0.0). Independent from the underlying shell render-time schema version."
        },
        "default_jargon_level_class": { "$ref": "#/$defs/jargon_level_class" },
        "default_tip_intensity_class": { "$ref": "#/$defs/tip_intensity_class" },
        "default_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "default_dismissal_class": { "$ref": "#/$defs/dismissal_class" },
        "default_reset_class": { "$ref": "#/$defs/reset_class" },
        "default_progress_export_class": { "$ref": "#/$defs/progress_export_class" },
        "default_share_state_class": { "$ref": "#/$defs/share_state_class" },
        "default_follow_state_class": { "$ref": "#/$defs/follow_state_class" },
        "default_replay_retention_class": { "$ref": "#/$defs/replay_retention_class" },
        "glossary_pack_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "tour_pack_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "command_tip_pack_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "docs_pack_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "deployment_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "state_portability_class": { "$ref": "#/$defs/state_portability_class" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "invariants": {
          "type": "array",
          "minItems": 12,
          "items": { "$ref": "#/$defs/invariant_assertion" },
          "uniqueItems": true,
          "description": "Every learning_mode_profile_artifact declares all twelve const-true invariants from the learnability contract so the artifact and the runtime profile record read the same lanes."
        },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "denial_reason_on_deny": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/denial_reason" }
          ]
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "policy_disabled profiles forbid portable progress exports and forbid sharing.",
          "if": {
            "properties": { "profile_class": { "const": "policy_disabled" } },
            "required": ["profile_class"]
          },
          "then": {
            "properties": {
              "default_progress_export_class": {
                "enum": ["blocked_by_policy", "in_support_bundle_redacted"]
              },
              "default_share_state_class": {
                "enum": ["shared_blocked_by_policy", "shared_unavailable_in_envelope", "local_only_no_share"]
              }
            }
          }
        },
        {
          "description": "air_gapped_offline_pack profiles forbid shared share states; the envelope cannot reach a relay.",
          "if": {
            "properties": { "profile_class": { "const": "air_gapped_offline_pack" } },
            "required": ["profile_class"]
          },
          "then": {
            "properties": {
              "default_share_state_class": {
                "enum": ["local_only_no_share", "shared_unavailable_in_envelope"]
              },
              "default_follow_state_class": {
                "enum": ["no_follow_local_only", "follow_blocked_by_envelope"]
              },
              "default_replay_retention_class": {
                "enum": ["no_replay_retained", "metadata_only_replay_local_redacted", "metadata_only_replay_in_support_bundle_redacted"]
              }
            }
          }
        },
        {
          "description": "privacy_reduced_local_only profiles forbid portable export.",
          "if": {
            "properties": { "profile_class": { "const": "privacy_reduced_local_only" } },
            "required": ["profile_class"]
          },
          "then": {
            "properties": {
              "default_progress_export_class": {
                "enum": ["not_exported_machine_local", "in_support_bundle_redacted", "blocked_by_policy"]
              },
              "state_portability_class": {
                "enum": ["machine_local_diagnostic", "device_scoped", "policy_scoped", "ephemeral_session"]
              }
            }
          }
        }
      ],
      "description": "One portable learning-mode profile authoring artifact. See docs/ux/learning_artifact_object_model.md §1.4."
    }
  }
}
