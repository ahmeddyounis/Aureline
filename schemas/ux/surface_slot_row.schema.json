{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/surface_slot_row.schema.json",
  "title": "Aureline UI composition surface-slot matrix rows and admission decisions",
  "description": "Boundary schema for the surface-slot catalog frozen in docs/ux/ui_composition_surface_slot_matrix.md and artifacts/ux/surface_slot_matrix.yaml. The schema defines slot-definition records, surface-to-slot mapping records, and admission-decision records used by fixtures and future conformance tooling. Raw absolute paths, raw URLs, raw provider payloads, raw credentials, raw user content, raw prompt text, and product planning identifiers never cross this boundary; records carry stable slot ids, closed vocabularies, and redaction-aware summaries only.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/surface_slot_definition_record" },
    { "$ref": "#/$defs/surface_slot_surface_mapping_record" },
    { "$ref": "#/$defs/surface_slot_admission_decision_record" }
  ],
  "$defs": {
    "surface_slot_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for surface-slot matrix records."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "surface_slot_definition_record",
        "surface_slot_surface_mapping_record",
        "surface_slot_admission_decision_record"
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9]+(?:[A-Za-z0-9_.:/-]*[A-Za-z0-9])?$",
      "description": "Stable opaque id safe for logs, support bundles, fixtures, and review packets."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_id" },
        { "type": "null" }
      ]
    },
    "slot_id": {
      "type": "string",
      "enum": [
        "slot.title_context_bar.identity",
        "slot.activity_rail.primary_routes",
        "slot.sidebar.section_surface",
        "slot.main_workspace.working_set",
        "slot.main_workspace.review_surface",
        "slot.right_inspector.contextual_detail",
        "slot.bottom_panel.tool_panels",
        "status.slot.recovery.primary",
        "status.slot.extension.scoped",
        "slot.overlay.command_palette",
        "slot.overlay.dialog_or_sheet",
        "slot.notification.toast_lane",
        "slot.notification.banner_lane",
        "slot.surface.status_strip",
        "slot.out_of_shell.companion_surface"
      ],
      "description": "Stable slot id exported by the surface-slot matrix."
    },
    "nullable_slot_id": {
      "oneOf": [
        { "$ref": "#/$defs/slot_id" },
        { "type": "null" }
      ]
    },
    "shell_zone": {
      "type": "string",
      "enum": [
        "title_context_bar",
        "activity_rail",
        "left_sidebar",
        "main_workspace",
        "right_inspector",
        "bottom_panel",
        "status_bar",
        "transient_overlay"
      ],
      "description": "Shell-zone id re-exported from the shell-zone contract."
    },
    "nullable_shell_zone": {
      "oneOf": [
        { "$ref": "#/$defs/shell_zone" },
        { "type": "null" }
      ]
    },
    "protection_class": {
      "type": "string",
      "enum": [
        "protected_host_only",
        "host_owned_with_budget",
        "surface_owner_with_insertion",
        "open_surface_container"
      ],
      "description": "Slot protection class; protected slots are host-owned control-plane truth."
    },
    "extension_insertion_policy": {
      "type": "string",
      "enum": [
        "prohibited",
        "allowed_via_budgeted_schema",
        "allowed_via_owner_contract",
        "allowed_with_explicit_admission_row"
      ],
      "description": "Whether and how extension/provider surfaces may be admitted into the slot."
    },
    "persistence_class": {
      "type": "string",
      "enum": [
        "required_chrome_always_present",
        "restorable_window_topology",
        "restorable_workspace_state",
        "durable_until_resolved_or_archived",
        "transient_window_local",
        "os_managed_mirror",
        "out_of_shell"
      ]
    },
    "content_class": {
      "type": "string",
      "enum": [
        "identity_chrome",
        "primary_route_map",
        "structural_navigation",
        "working_set_container",
        "review_or_approval_surface",
        "contextual_detail",
        "execution_output_panel",
        "activity_center",
        "status_item_cluster",
        "transient_overlay",
        "toast_or_banner_lane",
        "embedded_surface_with_boundary_card",
        "extension_surface",
        "companion_surface"
      ]
    },
    "path_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?:\\.?\\.\\/)?(?:[A-Za-z0-9_.-]+\\/)*[A-Za-z0-9_.-]+(?:\\.[A-Za-z0-9_.-]+)?$",
      "description": "Repository-relative path reference used to cite an owning contract or schema."
    },
    "safe_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1600,
      "description": "Bounded redaction-aware summary safe for review packets and fixtures."
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "first_party",
        "first_party_or_embedded",
        "first_party_host_owned",
        "first_party_or_provider_backed",
        "extension_surface",
        "companion_surface"
      ]
    },
    "admission_outcome": {
      "type": "string",
      "enum": [
        "admitted",
        "denied_protected_slot",
        "denied_no_admission_row",
        "denied_policy_or_trust",
        "placeholder_required",
        "reroute_to_allowed_slot"
      ]
    },
    "surface_slot_definition_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "surface_slot_schema_version",
        "slot_id",
        "slot_label",
        "protection_class",
        "extension_insertion_policy",
        "allowed_content_classes",
        "persistence_class",
        "owner_refs"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "surface_slot_definition_record" },
        "surface_slot_schema_version": { "$ref": "#/$defs/surface_slot_schema_version" },
        "slot_id": { "$ref": "#/$defs/slot_id" },
        "shell_zone": { "$ref": "#/$defs/nullable_shell_zone" },
        "slot_label": { "type": "string", "minLength": 1, "maxLength": 180 },
        "owner_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/path_ref" }
        },
        "protection_class": { "$ref": "#/$defs/protection_class" },
        "extension_insertion_policy": { "$ref": "#/$defs/extension_insertion_policy" },
        "allowed_content_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/content_class" }
        },
        "lifecycle_notes": {
          "anyOf": [
            { "$ref": "#/$defs/safe_summary" },
            { "type": "null" }
          ]
        },
        "focus_policy_ref": {
          "anyOf": [
            { "type": "string", "minLength": 1, "maxLength": 256 },
            { "type": "null" }
          ]
        },
        "persistence_class": { "$ref": "#/$defs/persistence_class" },
        "collapse_overflow_notes": {
          "anyOf": [
            { "$ref": "#/$defs/safe_summary" },
            { "type": "null" }
          ]
        }
      }
    },
    "surface_slot_surface_mapping_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "surface_slot_schema_version",
        "surface_family_id",
        "surface_label",
        "surface_kind",
        "allowed_slots",
        "banned_slots"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "surface_slot_surface_mapping_record" },
        "surface_slot_schema_version": { "$ref": "#/$defs/surface_slot_schema_version" },
        "surface_family_id": { "$ref": "#/$defs/opaque_id" },
        "surface_label": { "type": "string", "minLength": 1, "maxLength": 180 },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "allowed_slots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/slot_id" }
        },
        "banned_slots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/slot_id" }
        },
        "notes": {
          "anyOf": [
            { "$ref": "#/$defs/safe_summary" },
            { "type": "null" }
          ]
        }
      }
    },
    "surface_slot_admission_decision_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "surface_slot_schema_version",
        "decision_id",
        "requested_surface_family_id",
        "requested_slot_id",
        "requesting_actor_kind",
        "outcome",
        "rationale"
      ],
      "properties": {
        "record_kind": { "type": "string", "const": "surface_slot_admission_decision_record" },
        "surface_slot_schema_version": { "$ref": "#/$defs/surface_slot_schema_version" },
        "decision_id": { "$ref": "#/$defs/opaque_id" },
        "requested_surface_family_id": { "$ref": "#/$defs/opaque_id" },
        "requested_slot_id": { "$ref": "#/$defs/slot_id" },
        "requesting_actor_kind": {
          "type": "string",
          "enum": ["first_party", "extension", "provider_hosted", "companion_surface"]
        },
        "outcome": { "$ref": "#/$defs/admission_outcome" },
        "fallback_slot_id": { "$ref": "#/$defs/nullable_slot_id" },
        "rationale": { "$ref": "#/$defs/safe_summary" }
      }
    }
  }
}
