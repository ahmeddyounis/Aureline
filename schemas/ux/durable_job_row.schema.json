{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/durable_job_row.schema.json",
  "title": "Aureline durable job-row conformance packet",
  "description": "Boundary schema for the durable-attention conformance packet generated by the shell durable-attention beta inspector. The packet composes with schemas/ux/job_row.schema.json, schemas/ux/durable_job_envelope.schema.json, schemas/ux/notification_envelope.schema.json, and schemas/ux/notification_suppression_record.schema.json. It proves that long-running, reviewable, held, suppressed, repeated-failure, badge-counting, and exact-reopen work maps to authoritative durable rows or truthful placeholders instead of transient toasts, spinner-only rows, generic home reopen paths, or support exports that scrape rendered copy. Raw paths, raw URLs, raw provider payloads, prompt or completion text, logs, tokens, credential material, and secret values do not cross this boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "shared_contract_ref",
    "packet_id",
    "generated_at",
    "summary",
    "state_machine",
    "cases",
    "badge_audit",
    "quiet_hours_audit",
    "exact_reopen_proofs",
    "support_export_lineage"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "record_kind": {
      "const": "shell_durable_attention_beta_packet_record"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "shell:durable_attention_beta:v1"
    },
    "packet_id": {
      "$ref": "#/$defs/opaque_ref"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "state_machine": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/state_machine_entry"
      },
      "minItems": 7,
      "uniqueItems": true
    },
    "cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conformance_case"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "badge_audit": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/badge_audit_row"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "quiet_hours_audit": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/quiet_hours_audit_row"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "exact_reopen_proofs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/exact_reopen_proof"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "support_export_lineage": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/support_lineage_row"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "$defs": {
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:#/\\-]+$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "state_class": {
      "enum": [
        "running",
        "queued_waiting",
        "needs_approval",
        "completed",
        "failed",
        "cancelled",
        "history_only"
      ]
    },
    "activity_partition": {
      "enum": [
        "current_work",
        "needs_attention",
        "completed",
        "suppressed_held"
      ]
    },
    "job_family": {
      "enum": [
        "indexing",
        "restore",
        "install_update_download",
        "remote_reconnect",
        "task_run",
        "test_run",
        "debug_session",
        "ai_review",
        "git_review",
        "companion_handoff",
        "admin_policy"
      ]
    },
    "coverage_source": {
      "enum": [
        "activity_center_beta_row",
        "notification_privacy_beta_row",
        "contract_fixture"
      ]
    },
    "source_subsystem": {
      "enum": [
        "editor",
        "terminal",
        "review_and_diff",
        "palette_and_search",
        "install_update_attach",
        "ai_apply",
        "collaboration",
        "provider_bearing",
        "docs_help_service_health",
        "support_export",
        "build_system",
        "test_runner",
        "debug_session",
        "task_runner",
        "indexer",
        "vfs_save",
        "sync_mirror",
        "notebook_kernel",
        "remote_agent",
        "extension_host",
        "workspace_trust",
        "policy_resolver",
        "admin_policy",
        "secret_broker",
        "runtime_power_manager",
        "shell"
      ]
    },
    "badge_class": {
      "enum": [
        "needs_review",
        "failed_runs",
        "mentions",
        "security_notices",
        "session_requests",
        "offline_publish_pending",
        "durable_running_count",
        "held_or_suppressed_count",
        "completion_unread"
      ]
    },
    "badge_source_class": {
      "enum": [
        "derived_from_envelope_state",
        "derived_from_canonical_object",
        "aggregated_grouped_burst",
        "not_a_badge_source"
      ]
    },
    "dedupe_key_scheme": {
      "enum": [
        "canonical_event_id",
        "canonical_object_target_plus_event_class",
        "grouped_burst_id",
        "subsystem_plus_object_plus_phase",
        "cross_client_canonical_event_id"
      ]
    },
    "quiet_hours_decision": {
      "enum": [
        "not_suppressed",
        "held_quiet_hours",
        "admin_suppressed",
        "critical_bypass",
        "cross_client_deduped"
      ]
    },
    "quiet_hours_mode": {
      "enum": [
        "mode_none",
        "mode_quiet_hours_user",
        "mode_do_not_disturb_user",
        "mode_focus_mode_user",
        "mode_presentation",
        "mode_screen_share",
        "mode_privacy_mode",
        "mode_reduced_attention_policy",
        "mode_power_saver_runtime",
        "mode_admin_suppression"
      ]
    },
    "suppression_reason": {
      "enum": [
        "quiet_hours_user_policy",
        "do_not_disturb_user_policy",
        "focus_mode_user_policy",
        "presentation_mode_active",
        "screen_share_active",
        "privacy_mode_active",
        "admin_policy_suppression",
        "reduced_attention_posture",
        "power_saver_background_pause",
        "dedupe_same_canonical_event",
        "dedupe_same_grouped_burst",
        "class_muted_by_user",
        "class_snoozed_by_user",
        "release_pending_next_unsuppressed_surface"
      ]
    },
    "fanout_surface": {
      "enum": [
        "durable_job_row",
        "status_strip",
        "status_item",
        "activity_center_digest_card",
        "toast",
        "contextual_banner",
        "os_notification",
        "lock_screen_summary",
        "companion_push",
        "digest_group_row",
        "not_delivered_held"
      ]
    },
    "reopen_class": {
      "enum": [
        "exact_durable_object",
        "truthful_placeholder",
        "denied_requires_revalidation"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_count",
        "state_machine_entry_count",
        "exact_reopen_proof_count",
        "badge_audit_row_count",
        "quiet_hours_audit_row_count",
        "support_lineage_row_count",
        "job_families_present",
        "state_classes_present",
        "coalesced_repeated_failure_case_count",
        "held_or_suppressed_case_count",
        "exact_durable_object_reopen_count",
        "truthful_placeholder_reopen_count",
        "denied_reopen_count"
      ],
      "properties": {
        "case_count": {
          "type": "integer",
          "minimum": 1
        },
        "state_machine_entry_count": {
          "type": "integer",
          "minimum": 7
        },
        "exact_reopen_proof_count": {
          "type": "integer",
          "minimum": 1
        },
        "badge_audit_row_count": {
          "type": "integer",
          "minimum": 1
        },
        "quiet_hours_audit_row_count": {
          "type": "integer",
          "minimum": 1
        },
        "support_lineage_row_count": {
          "type": "integer",
          "minimum": 1
        },
        "job_families_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/job_family"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "state_classes_present": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/state_class"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "coalesced_repeated_failure_case_count": {
          "type": "integer",
          "minimum": 0
        },
        "held_or_suppressed_case_count": {
          "type": "integer",
          "minimum": 0
        },
        "exact_durable_object_reopen_count": {
          "type": "integer",
          "minimum": 0
        },
        "truthful_placeholder_reopen_count": {
          "type": "integer",
          "minimum": 0
        },
        "denied_reopen_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "state_machine_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "state_class",
        "valid_activity_partitions",
        "required_phase_fields",
        "required_visible_cues",
        "required_actions",
        "exact_reopen_or_placeholder_required",
        "support_export_lineage_required",
        "transient_only_allowed"
      ],
      "properties": {
        "record_kind": {
          "const": "durable_job_row_state_machine_entry_record"
        },
        "schema_version": {
          "const": 1
        },
        "shared_contract_ref": {
          "const": "shell:durable_attention_beta:v1"
        },
        "state_class": {
          "$ref": "#/$defs/state_class"
        },
        "valid_activity_partitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/activity_partition"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "required_phase_fields": {
          "$ref": "#/$defs/string_list"
        },
        "required_visible_cues": {
          "$ref": "#/$defs/string_list"
        },
        "required_actions": {
          "$ref": "#/$defs/string_list"
        },
        "exact_reopen_or_placeholder_required": {
          "const": true
        },
        "support_export_lineage_required": {
          "const": true
        },
        "transient_only_allowed": {
          "const": false
        }
      }
    },
    "conformance_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "case_id",
        "case_label",
        "job_family",
        "coverage_source",
        "source_projection_ref",
        "state_class",
        "activity_partition",
        "source_subsystem",
        "actor_or_subsystem_label",
        "execution_origin_class",
        "scope_label",
        "phase_label",
        "age_label",
        "durable_job_id_ref",
        "canonical_event_id",
        "canonical_object_target_ref",
        "badge_source_class",
        "dedupe_key_scheme",
        "quiet_hours_decision",
        "reopen_class",
        "badge_audit_id_ref",
        "quiet_hours_audit_id_ref",
        "reopen_proof_id_ref",
        "support_export_lineage_id_ref",
        "has_authoritative_durable_object",
        "represented_by_durable_row",
        "transient_only_denied",
        "repeated_failure_root_cause_count",
        "repeated_failures_coalesced",
        "privacy_safe_external_payload",
        "no_shortcut_bypass",
        "support_export_can_reconstruct_lineage",
        "raw_private_material_excluded",
        "fixture_refs",
        "narrative"
      ],
      "properties": {
        "record_kind": {
          "const": "durable_attention_conformance_case_record"
        },
        "schema_version": {
          "const": 1
        },
        "shared_contract_ref": {
          "const": "shell:durable_attention_beta:v1"
        },
        "case_id": {
          "$ref": "#/$defs/opaque_ref"
        },
        "case_label": {
          "$ref": "#/$defs/label"
        },
        "job_family": {
          "$ref": "#/$defs/job_family"
        },
        "coverage_source": {
          "$ref": "#/$defs/coverage_source"
        },
        "source_projection_ref": {
          "$ref": "#/$defs/label"
        },
        "state_class": {
          "$ref": "#/$defs/state_class"
        },
        "activity_partition": {
          "$ref": "#/$defs/activity_partition"
        },
        "source_subsystem": {
          "$ref": "#/$defs/source_subsystem"
        },
        "actor_or_subsystem_label": {
          "$ref": "#/$defs/label"
        },
        "execution_origin_class": {
          "$ref": "#/$defs/label"
        },
        "scope_label": {
          "$ref": "#/$defs/label"
        },
        "phase_label": {
          "$ref": "#/$defs/label"
        },
        "age_label": {
          "$ref": "#/$defs/label"
        },
        "durable_job_id_ref": {
          "$ref": "#/$defs/opaque_ref"
        },
        "canonical_event_id": {
          "$ref": "#/$defs/opaque_ref"
        },
        "canonical_object_target_ref": {
          "$ref": "#/$defs/opaque_ref"
        },
        "badge_class": {
          "$ref": "#/$defs/badge_class"
        },
        "badge_source_class": {
          "$ref": "#/$defs/badge_source_class"
        },
        "dedupe_key_scheme": {
          "$ref": "#/$defs/dedupe_key_scheme"
        },
        "quiet_hours_decision": {
          "$ref": "#/$defs/quiet_hours_decision"
        },
        "reopen_class": {
          "$ref": "#/$defs/reopen_class"
        },
        "exact_target_identity_ref": {
          "$ref": "#/$defs/opaque_ref"
        },
        "placeholder_reason_label": {
          "$ref": "#/$defs/label"
        },
        "denial_reason_label": {
          "$ref": "#/$defs/label"
        },
        "badge_audit_id_ref": {
          "$ref": "#/$defs/opaque_ref"
        },
        "quiet_hours_audit_id_ref": {
          "$ref": "#/$defs/opaque_ref"
        },
        "reopen_proof_id_ref": {
          "$ref": "#/$defs/opaque_ref"
        },
        "support_export_lineage_id_ref": {
          "$ref": "#/$defs/opaque_ref"
        },
        "has_authoritative_durable_object": {
          "const": true
        },
        "represented_by_durable_row": {
          "const": true
        },
        "transient_only_denied": {
          "const": true
        },
        "repeated_failure_root_cause_count": {
          "type": "integer",
          "minimum": 1
        },
        "repeated_failures_coalesced": {
          "type": "boolean"
        },
        "privacy_safe_external_payload": {
          "const": true
        },
        "no_shortcut_bypass": {
          "const": true
        },
        "support_export_can_reconstruct_lineage": {
          "const": true
        },
        "raw_private_material_excluded": {
          "const": true
        },
        "fixture_refs": {
          "$ref": "#/$defs/string_list"
        },
        "narrative": {
          "$ref": "#/$defs/label"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "reopen_class": {
                "const": "exact_durable_object"
              }
            },
            "required": [
              "reopen_class"
            ]
          },
          "then": {
            "required": [
              "exact_target_identity_ref"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "reopen_class": {
                "const": "truthful_placeholder"
              }
            },
            "required": [
              "reopen_class"
            ]
          },
          "then": {
            "required": [
              "placeholder_reason_label"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "reopen_class": {
                "const": "denied_requires_revalidation"
              }
            },
            "required": [
              "reopen_class"
            ]
          },
          "then": {
            "required": [
              "denial_reason_label"
            ]
          }
        }
      ]
    },
    "badge_audit_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "audit_id",
        "case_id",
        "badge_source_class",
        "dedupe_key_scheme",
        "active_count_delta",
        "held_or_suppressed_count_delta",
        "mixed_class_count_denied",
        "count_source_ref",
        "maps_to_authoritative_object",
        "support_export_ref"
      ],
      "properties": {
        "record_kind": {
          "const": "durable_attention_badge_class_audit_row_record"
        },
        "schema_version": {
          "const": 1
        },
        "shared_contract_ref": {
          "const": "shell:durable_attention_beta:v1"
        },
        "audit_id": {
          "$ref": "#/$defs/opaque_ref"
        },
        "case_id": {
          "$ref": "#/$defs/opaque_ref"
        },
        "badge_class": {
          "$ref": "#/$defs/badge_class"
        },
        "badge_source_class": {
          "$ref": "#/$defs/badge_source_class"
        },
        "dedupe_key_scheme": {
          "$ref": "#/$defs/dedupe_key_scheme"
        },
        "active_count_delta": {
          "type": "integer",
          "minimum": 0
        },
        "held_or_suppressed_count_delta": {
          "type": "integer",
          "minimum": 0
        },
        "mixed_class_count_denied": {
          "const": true
        },
        "count_source_ref": {
          "$ref": "#/$defs/opaque_ref"
        },
        "maps_to_authoritative_object": {
          "const": true
        },
        "support_export_ref": {
          "$ref": "#/$defs/opaque_ref"
        }
      }
    },
    "quiet_hours_audit_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "audit_id",
        "case_id",
        "decision_class",
        "active_modes",
        "suppression_reasons",
        "intended_surfaces",
        "preserved_durable_surfaces",
        "durable_history_preserved",
        "suppression_audit_trail_present",
        "audit_trail_ref",
        "release_rule_label",
        "critical_safety_bypassed_hold",
        "admin_policy_narrowed_without_widening",
        "support_export_ref"
      ],
      "properties": {
        "record_kind": {
          "const": "durable_attention_quiet_hours_audit_row_record"
        },
        "schema_version": {
          "const": 1
        },
        "shared_contract_ref": {
          "const": "shell:durable_attention_beta:v1"
        },
        "audit_id": {
          "$ref": "#/$defs/opaque_ref"
        },
        "case_id": {
          "$ref": "#/$defs/opaque_ref"
        },
        "decision_class": {
          "$ref": "#/$defs/quiet_hours_decision"
        },
        "active_modes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/quiet_hours_mode"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "suppression_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/suppression_reason"
          },
          "uniqueItems": true
        },
        "intended_surfaces": {
          "$ref": "#/$defs/fanout_surface_list"
        },
        "preserved_durable_surfaces": {
          "$ref": "#/$defs/fanout_surface_list"
        },
        "durable_history_preserved": {
          "const": true
        },
        "suppression_audit_trail_present": {
          "const": true
        },
        "audit_trail_ref": {
          "$ref": "#/$defs/opaque_ref"
        },
        "release_rule_label": {
          "$ref": "#/$defs/label"
        },
        "critical_safety_bypassed_hold": {
          "type": "boolean"
        },
        "admin_policy_narrowed_without_widening": {
          "const": true
        },
        "support_export_ref": {
          "$ref": "#/$defs/opaque_ref"
        }
      }
    },
    "exact_reopen_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "proof_id",
        "case_id",
        "reopen_class",
        "activation_surfaces",
        "canonical_event_id",
        "canonical_object_target_ref",
        "open_details_command_id",
        "generic_home_fallback_denied",
        "preserves_preview_approval_trust_logic"
      ],
      "properties": {
        "record_kind": {
          "const": "durable_attention_exact_reopen_proof_record"
        },
        "schema_version": {
          "const": 1
        },
        "shared_contract_ref": {
          "const": "shell:durable_attention_beta:v1"
        },
        "proof_id": {
          "$ref": "#/$defs/opaque_ref"
        },
        "case_id": {
          "$ref": "#/$defs/opaque_ref"
        },
        "reopen_class": {
          "$ref": "#/$defs/reopen_class"
        },
        "activation_surfaces": {
          "$ref": "#/$defs/fanout_surface_list"
        },
        "canonical_event_id": {
          "$ref": "#/$defs/opaque_ref"
        },
        "canonical_object_target_ref": {
          "$ref": "#/$defs/opaque_ref"
        },
        "exact_target_identity_ref": {
          "$ref": "#/$defs/opaque_ref"
        },
        "placeholder_reason_label": {
          "$ref": "#/$defs/label"
        },
        "denial_reason_label": {
          "$ref": "#/$defs/label"
        },
        "open_details_command_id": {
          "$ref": "#/$defs/opaque_ref"
        },
        "generic_home_fallback_denied": {
          "const": true
        },
        "preserves_preview_approval_trust_logic": {
          "const": true
        }
      }
    },
    "support_lineage_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "lineage_id",
        "case_id",
        "canonical_event_id",
        "durable_job_id_ref",
        "canonical_object_target_ref",
        "source_subsystem",
        "target_scope_label",
        "state_class",
        "badge_audit_id_ref",
