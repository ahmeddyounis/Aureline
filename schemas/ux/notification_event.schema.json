          "items": { "$ref": "#/$defs/durability_class" }
        },
        "allowed_state_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/notification_state_class" }
        },
        "forbidden_state_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/notification_state_class" }
        },
        "default_quiet_hours_policy": { "$ref": "#/$defs/quiet_hours_policy" },
        "badge_count_rule_label": { "$ref": "#/$defs/short_label_text" }
      }
    }
  }
