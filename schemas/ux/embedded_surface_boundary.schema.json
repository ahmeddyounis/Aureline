          "$ref": "#/$defs/data_boundary_class"
        },
        "boundary_state": { "$ref": "#/$defs/boundary_state" },
        "boundary_card": { "$ref": "#/$defs/boundary_card" },
        "required_chrome_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/required_chrome_field" },
          "minItems": 5,
          "uniqueItems": true
        },
        "capability_limitations": {
          "type": "array",
          "items": { "$ref": "#/$defs/capability_limitation" },
          "uniqueItems": true
        },
        "native_reserved_surfaces_host_owned": {
          "type": "array",
          "items": { "$ref": "#/$defs/native_reserved_surface" },
          "minItems": 1,
          "uniqueItems": true
        },
        "high_risk_action_posture": {
          "$ref": "#/$defs/high_risk_action_posture"
        },
        "source_truth": { "$ref": "#/$defs/source_truth" },
        "provider_identity": {
          "$ref": "#/$defs/provider_identity"
        },
        "auth_handoff": { "$ref": "#/$defs/auth_handoff" },
        "external_open_fallback": {
