        },
        "repair_hook_ref": { "$ref": "#/$defs/repair_hook_ref" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "surface_family": { "const": "embedded_docs_help" }
            },
            "required": ["surface_family"]
          },
          "then": {
            "required": ["source_truth"],
            "properties": {
              "required_chrome_fields": {
                "contains": { "const": "source_version_freshness" }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "surface_family": {
                "enum": [
                  "embedded_marketplace_or_account",
                  "embedded_service_dashboard"
                ]
              }
            },
            "required": ["surface_family"]
          },
          "then": {
            "required": ["provider_identity"],
            "properties": {
              "required_chrome_fields": {
                "contains": { "const": "provider_scope_and_actor" }
              },
              "high_risk_action_posture": { "const": "host_native_only" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "surface_family": { "const": "embedded_auth_confirmation" }
            },
            "required": ["surface_family"]
          },
          "then": {
            "required": ["auth_handoff"],
            "properties": {
              "required_chrome_fields": {
                "contains": {
                  "const": "flow_type_and_return_target"
                }
              },
              "high_risk_action_posture": { "const": "host_native_only" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "boundary_state": {
                "enum": [
                  "stale_snapshot",
                  "policy_blocked",
                  "certificate_failed",
                  "cross_origin_limited",
                  "offline_snapshot",
                  "external_open_only"
                ]
              }
            },
            "required": ["boundary_state"]
          },
          "then": {
            "required": ["repair_hook_ref"]
          }
        },
        {
          "if": {
            "properties": {
              "auth_handoff": {
                "properties": {
                  "flow_class": {
                    "const": "system_browser"
                  }
                },
                "required": ["flow_class"]
              }
            },
            "required": ["auth_handoff"]
          },
          "then": {
            "properties": {
              "auth_handoff": {
                "properties": {
                  "credential_collection_mode": {
                    "const": "no_embedded_collection"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "auth_handoff": {
                "properties": {
                  "flow_class": {
                    "const": "device_code"
                  }
                },
                "required": ["flow_class"]
              }
            },
            "required": ["auth_handoff"]
          },
          "then": {
            "properties": {
              "auth_handoff": {
                "properties": {
                  "credential_collection_mode": {
                    "const": "device_code_copy_only"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "auth_handoff": {
                "properties": {
                  "flow_class": {
                    "const": "embedded_session_refresh"
                  }
                },
                "required": ["flow_class"]
              }
            },
            "required": ["auth_handoff"]
          },
          "then": {
            "properties": {
              "auth_handoff": {
                "properties": {
                  "credential_collection_mode": {
                    "const": "session_refresh_without_password"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "auth_handoff": {
                "properties": {
                  "flow_class": {
                    "const": "embedded_password_exception"
                  }
                },
                "required": ["flow_class"]
              }
            },
            "required": ["auth_handoff"]
          },
          "then": {
            "properties": {
              "auth_handoff": {
                "required": ["exception_ref"],
                "properties": {
                  "credential_collection_mode": {
                    "const": "password_entry_exception"
                  },
                  "lower_trust_cues": {
                    "contains": { "const": "lower_trust_badge" },
                    "allOf": [
                      {
                        "contains": {
                          "const": "host_native_approval_still_required"
                        }
                      }
                    ]
                  }
                }
              },
              "high_risk_action_posture": {
                "const": "host_native_only"
              }
            }
          }
        }
      ]
    },

    "embedded_auth_exception_record": {
