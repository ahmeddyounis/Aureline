{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/harden-component-state-registry-and-theme-token-parity.schema.json",
  "title": "Aureline component-state registry certification record",
  "description": "Boundary schema for component_state_registry_certification_record, the single governed record the settings / design-system panel, command palette, status bar, diagnostics, support exports, Help/About, design-QA packets, dashboards, and docs all read for one posture of the hardened component-state registry. It is minted by crates/aureline-settings/src/component_state_registry_stable as a genuine projection of the live design-system component-state registry (aureline_design_system::seeded_component_state_registry), the live extension appearance-conformance packet (aureline_extensions::appearance_conformance::seeded_appearance_conformance_packet), the live screenshot-diff packet (aureline_design_system::seeded_screenshot_diff_packet), and the shared UI taxonomy (aureline_ui::components::ComponentStateClass). It binds, for one posture: (1) one registry value every family, normalized-state, zone, and fixture row resolves against; (2) family coverage across core controls, dense rows, tabs, trees, palettes, popovers, dialogs, banners, job rows, and inline notices, each declaring supported states, required affordances, and an accessibility note and proving it is token-driven with focus and screen-reader semantics preserved; (3) normalized disabled, blocked, policy-locked, reconnecting, warming, partial, stale, and recovering states consistent across shell, review, settings, and support with a narratable reason and an action path and never hue or animation alone; (4) extension/embedded inheritance honesty per appearance axis with any gap surfacing in review, diagnostics, and support export; (5) shell-zoning slot names, docked-versus-sheet state, min/max chrome metrics, density semantics, reduced-motion behavior, and placeholder cards that are token-driven; (6) per-permutation state-fixture coverage; (7) a public claim ceiling no posture may exceed; and (8) a derived stable-claim verdict that narrows a posture which cannot prove a pillar, or whose lowest family marker is below Stable, below Stable with a named reason. Minted refs are opaque aureline://<class>/<id> object refs; upstream projection refs keep their source scheme.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "posture_id",
    "posture_label",
    "title",
    "summary",
    "registry_binding",
    "surface_lifecycle_marker",
    "component_families",
    "normalized_states",
    "extension_inheritance",
    "shell_zones",
    "state_fixtures",
    "pillars",
    "claim_ceiling",
    "stable_qualification",
    "recovery_routes",
    "routes",
    "accessibility",
    "available_without_account",
    "available_without_managed_services",
    "honesty_marker_present",
    "upstream",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": { "const": "component_state_registry_certification_record" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "notice": { "type": "string", "minLength": 1 },
    "shared_contract_ref": { "const": "settings:component_state_registry_stable:v1" },
    "record_id": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "minLength": 1 },
    "posture_id": { "type": "string", "minLength": 1 },
    "posture_label": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "registry_binding": { "$ref": "#/$defs/registryBinding" },
    "surface_lifecycle_marker": { "$ref": "#/$defs/lifecycleMarker" },
    "component_families": {
      "type": "array",
      "minItems": 10,
      "items": { "$ref": "#/$defs/componentFamilyRow" }
    },
    "normalized_states": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/normalizedStateRow" }
    },
    "extension_inheritance": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/extensionInheritanceRow" }
    },
    "shell_zones": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/shellZoneRow" }
    },
    "state_fixtures": {
      "type": "array",
      "minItems": 10,
      "items": { "$ref": "#/$defs/stateFixtureRow" }
    },
    "pillars": { "$ref": "#/$defs/pillars" },
    "claim_ceiling": { "$ref": "#/$defs/claimCeiling" },
    "stable_qualification": { "$ref": "#/$defs/stableQualification" },
    "recovery_routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/recoveryRoute" }
    },
    "routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/entryRoute" }
    },
    "accessibility": { "$ref": "#/$defs/accessibility" },
    "available_without_account": { "type": "boolean" },
    "available_without_managed_services": { "type": "boolean" },
    "honesty_marker_present": { "type": "boolean" },
    "upstream": { "$ref": "#/$defs/upstream" },
    "diagnostics_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "support_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } },
    "narrative_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } }
  },
  "$defs": {
    "canonicalRef": {
      "type": "string",
      "pattern": "^aureline://(?!home/|landing/|root/)[^/]+/.+",
      "maxLength": 200
    },
    "presentRef": { "type": "string", "minLength": 1, "maxLength": 200 },
    "lifecycleMarker": { "enum": ["preview", "beta", "stable"] },
    "claimClass": { "enum": ["stable", "beta", "preview", "not_claimed"] },
    "densityClass": { "enum": ["compact", "standard", "comfortable"] },
    "motionPosture": {
      "enum": [
        "motion_standard",
        "motion_reduced",
        "motion_low_motion",
        "motion_power_saver",
        "motion_critical_hot_path"
      ]
    },
    "componentFamilyClass": {
      "enum": [
        "core_control",
        "dense_row",
        "tab",
        "tree",
        "palette",
        "popover",
        "dialog",
        "banner",
        "job_row",
        "inline_notice"
      ]
    },
    "componentStateName": {
      "enum": [
        "hover",
        "focus",
        "selected",
        "disabled",
        "loading",
        "warning",
        "error",
        "blocked",
        "policy_locked",
        "reconnecting",
        "warming",
        "partial",
        "stale",
        "recovering",
        "degraded"
      ]
    },
    "taxonomyStateClass": {
      "enum": [
        "idle",
        "hover",
        "focus",
        "focus_visible",
        "pressed",
        "selected",
        "current",
        "disabled",
        "read_only",
        "loading",
        "pending",
        "degraded",
        "stale",
        "restricted",
        "policy_blocked",
        "locked",
        "warning",
        "destructive",
        "reconnecting",
        "completed",
        "restored",
        "quiet_hours_held"
      ]
    },
    "canonicalStateClass": {
      "enum": ["empty", "loading", "pending", "degraded", "blocked", "error", "completed"]
    },
    "launchSurfaceClass": {
      "enum": [
        "shell_chrome",
        "start_center",
        "command_palette",
        "search_surface",
        "dialog_sheet",
        "trust_prompt",
        "notification_envelope",
        "help_about_row",
        "settings_root",
        "activity_center_row"
      ]
    },
    "appearanceAxisClass": {
      "enum": ["theme", "density", "focus_ring", "high_contrast", "reduced_motion", "host_token"]
    },
    "appearanceSupportClass": {
      "enum": [
        "full_inheritance",
        "reduced_support",
        "unsupported_private_styling",
        "undisclosed_gap"
      ]
    },
    "nonColorCue": {
      "enum": [
        "label_text",
        "icon",
        "border",
        "shape",
        "focus_ring",
        "progress_indicator",
        "lock_or_shield_glyph",
        "selection_marker"
      ]
    },
    "requiredAffordance": {
      "enum": [
        "keyboard_focus_visible",
        "screen_reader_label",
        "persistent_disclosure",
        "narratable_reason",
        "action_path",
        "non_color_cue"
      ]
    },
    "registrySurfaceClass": { "enum": ["shell", "review", "settings", "support"] },
    "shellZoneClass": {
      "enum": [
        "navigation_rail",
        "primary_sidebar",
        "editor_group",
        "secondary_panel",
        "status_strip",
        "companion_sheet"
      ]
    },
    "zoneLayoutMode": { "enum": ["docked", "sheet"] },
    "routeSurface": {
      "enum": ["settings_appearance", "command_palette", "status_bar", "menu_command"]
    },
    "layoutMode": { "enum": ["normal", "high_contrast", "zoomed"] },
    "recoveryActionRole": { "enum": ["primary", "recovery", "secondary"] },
    "narrowingReason": {
      "enum": [
        "registry_family_coverage_incomplete",
        "state_normalization_inconsistent",
        "extension_gap_undisclosed",
        "shell_zoning_hardcoded",
        "state_fixture_coverage_incomplete",
        "focus_or_screen_reader_regression",
        "hue_or_animation_only_cue",
        "surface_not_yet_stable"
      ]
    },
    "registryBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_id",
        "registry_revision",
        "value_ref",
        "taxonomy_ref",
        "source_refs"
      ],
      "properties": {
        "registry_id": { "type": "string", "minLength": 1 },
        "registry_revision": { "type": "integer", "minimum": 0 },
        "value_ref": { "$ref": "#/$defs/canonicalRef" },
        "taxonomy_ref": { "$ref": "#/$defs/presentRef" },
        "source_refs": { "type": "array", "items": { "$ref": "#/$defs/presentRef" } }
      }
    },
    "componentFamilyRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_class",
        "display_label",
        "supported_states",
        "required_affordances",
        "non_color_cues",
        "accessibility_note",
        "token_driven",
        "hardcoded_styling_absent",
        "hue_only_forbidden",
        "animation_only_forbidden",
        "focus_visible_preserved",
        "screen_reader_semantics_preserved",
        "surface_marker",
        "conforms"
      ],
      "properties": {
        "family_class": { "$ref": "#/$defs/componentFamilyClass" },
        "display_label": { "type": "string", "minLength": 1 },
        "supported_states": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/componentStateName" }
        },
        "required_affordances": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/requiredAffordance" }
        },
        "non_color_cues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonColorCue" }
        },
        "accessibility_note": { "type": "string", "minLength": 1 },
        "token_driven": { "type": "boolean" },
        "hardcoded_styling_absent": { "type": "boolean" },
        "hue_only_forbidden": { "type": "boolean" },
        "animation_only_forbidden": { "type": "boolean" },
        "focus_visible_preserved": { "type": "boolean" },
        "screen_reader_semantics_preserved": { "type": "boolean" },
        "surface_marker": { "$ref": "#/$defs/lifecycleMarker" },
        "waiver_ref": { "$ref": "#/$defs/presentRef" },
        "conforms": { "type": "boolean" }
      }
    },
    "normalizedStateRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_name",
        "taxonomy_ref",
        "display_label",
        "non_color_cues",
        "hue_only_forbidden",
        "animation_only_forbidden",
        "consistent_across_surfaces",
        "narratable_reason",
        "action_path",
        "screen_reader_label",
        "conforms"
      ],
      "properties": {
        "state_name": { "$ref": "#/$defs/componentStateName" },
        "taxonomy_ref": { "$ref": "#/$defs/taxonomyStateClass" },
        "display_label": { "type": "string", "minLength": 1 },
        "non_color_cues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonColorCue" }
        },
        "hue_only_forbidden": { "type": "boolean" },
        "animation_only_forbidden": { "type": "boolean" },
        "consistent_across_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/registrySurfaceClass" }
        },
        "narratable_reason": { "type": "string", "minLength": 1 },
        "action_path": { "type": "string", "minLength": 1 },
        "screen_reader_label": { "type": "string", "minLength": 1 },
        "conforms": { "type": "boolean" }
      }
    },
    "extensionInheritanceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "axis",
        "support_class",
        "gap_disclosed_in_review",
        "gap_surfaced_in_diagnostics",
        "gap_surfaced_in_support_export",
        "caveat",
        "conforms"
      ],
      "properties": {
        "axis": { "$ref": "#/$defs/appearanceAxisClass" },
        "support_class": { "$ref": "#/$defs/appearanceSupportClass" },
        "gap_disclosed_in_review": { "type": "boolean" },
        "gap_surfaced_in_diagnostics": { "type": "boolean" },
        "gap_surfaced_in_support_export": { "type": "boolean" },
        "caveat": { "type": "string", "minLength": 1 },
        "waiver_ref": { "$ref": "#/$defs/presentRef" },
        "conforms": { "type": "boolean" }
      }
    },
    "shellZoneRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "zone_class",
        "slot_name",
        "layout_mode",
        "min_chrome_px",
        "max_chrome_px",
        "density_class",
        "reduced_motion_posture",
        "metrics_token_driven",
        "placeholder_token_driven",
        "responsive_fallback_token_driven",
        "conforms"
      ],
      "properties": {
        "zone_class": { "$ref": "#/$defs/shellZoneClass" },
        "slot_name": { "type": "string", "minLength": 1 },
        "layout_mode": { "$ref": "#/$defs/zoneLayoutMode" },
        "min_chrome_px": { "type": "integer", "minimum": 0 },
        "max_chrome_px": { "type": "integer", "minimum": 0 },
        "density_class": { "$ref": "#/$defs/densityClass" },
        "reduced_motion_posture": { "$ref": "#/$defs/motionPosture" },
        "metrics_token_driven": { "type": "boolean" },
        "placeholder_token_driven": { "type": "boolean" },
        "responsive_fallback_token_driven": { "type": "boolean" },
        "waiver_ref": { "$ref": "#/$defs/presentRef" },
        "conforms": { "type": "boolean" }
      }
    },
    "stateFixtureRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "state_class",
        "screenshot_ref",
        "fixture_ref",
        "focus_visible_preserved",
        "screen_reader_semantics_preserved",
        "transition_narrated",
        "non_color_cue_present",
        "hover_only_critical_action_absent",
        "conforms"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/launchSurfaceClass" },
        "state_class": { "$ref": "#/$defs/canonicalStateClass" },
        "screenshot_ref": { "$ref": "#/$defs/canonicalRef" },
        "fixture_ref": { "$ref": "#/$defs/canonicalRef" },
        "focus_visible_preserved": { "type": "boolean" },
        "screen_reader_semantics_preserved": { "type": "boolean" },
        "transition_narrated": { "type": "boolean" },
        "non_color_cue_present": { "type": "boolean" },
        "hover_only_critical_action_absent": { "type": "boolean" },
        "conforms": { "type": "boolean" }
      }
    },
    "pillars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_covers_all_families",
        "states_normalized_consistently",
        "extension_gaps_disclosed",
        "shell_zoning_token_driven",
        "state_fixtures_cover_permutations",
        "focus_and_screen_reader_preserved",
        "no_hue_or_animation_only"
      ],
      "properties": {
        "registry_covers_all_families": { "type": "boolean" },
        "states_normalized_consistently": { "type": "boolean" },
        "extension_gaps_disclosed": { "type": "boolean" },
        "shell_zoning_token_driven": { "type": "boolean" },
        "state_fixtures_cover_permutations": { "type": "boolean" },
        "focus_and_screen_reader_preserved": { "type": "boolean" },
        "no_hue_or_animation_only": { "type": "boolean" }
      }
    },
    "claimCeiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asserts_registry_family_coverage",
        "asserts_state_normalization",
        "asserts_extension_gaps_disclosed",
        "asserts_shell_zoning_token_driven",
        "asserts_state_fixture_coverage",
        "asserts_focus_and_screen_reader",
        "asserts_no_hue_or_animation_only"
      ],
      "properties": {
        "asserts_registry_family_coverage": { "type": "boolean" },
        "asserts_state_normalization": { "type": "boolean" },
        "asserts_extension_gaps_disclosed": { "type": "boolean" },
        "asserts_shell_zoning_token_driven": { "type": "boolean" },
        "asserts_state_fixture_coverage": { "type": "boolean" },
        "asserts_focus_and_screen_reader": { "type": "boolean" },
        "asserts_no_hue_or_animation_only": { "type": "boolean" }
      }
    },
    "stableQualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_class", "qualifies_stable", "narrowing_reasons"],
      "properties": {
        "claim_class": { "$ref": "#/$defs/claimClass" },
        "qualifies_stable": { "type": "boolean" },
        "narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowingReason" }
        }
      }
    },
    "recoveryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_label", "action_role", "keyboard_reachable"],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_label": { "type": "string", "minLength": 1 },
        "action_role": { "$ref": "#/$defs/recoveryActionRole" },
        "keyboard_reachable": { "type": "boolean" }
      }
    },
    "entryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "route_ref", "keyboard_reachable", "activates_same_record"],
      "properties": {
        "surface": { "$ref": "#/$defs/routeSurface" },
        "route_ref": { "$ref": "#/$defs/canonicalRef" },
        "keyboard_reachable": { "type": "boolean" },
        "activates_same_record": { "type": "boolean" }
      }
    },
    "layoutModeDisclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "row_narration_available", "recovery_affordances_reachable"],
      "properties": {
        "mode": { "$ref": "#/$defs/layoutMode" },
        "row_narration_available": { "type": "boolean" },
        "recovery_affordances_reachable": { "type": "boolean" }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_order_index",
        "tab_stop_count",
        "row_narration",
        "action_labels",
        "layout_modes"
      ],
      "properties": {
        "focus_order_index": { "type": "integer", "minimum": 0 },
        "tab_stop_count": { "type": "integer", "minimum": 0 },
        "row_narration": { "type": "string", "minLength": 1 },
        "action_labels": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "layout_modes": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/layoutModeDisclosure" }
        }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_state_registry_ref",
        "appearance_conformance_packet_ref",
        "screenshot_diff_packet_ref",
        "taxonomy_ref",
        "contributing_fixture_refs"
      ],
      "properties": {
        "component_state_registry_ref": { "$ref": "#/$defs/presentRef" },
        "appearance_conformance_packet_ref": { "$ref": "#/$defs/presentRef" },
        "screenshot_diff_packet_ref": { "$ref": "#/$defs/presentRef" },
        "taxonomy_ref": { "$ref": "#/$defs/presentRef" },
        "contributing_fixture_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/presentRef" }
        }
      }
    }
  }
}
