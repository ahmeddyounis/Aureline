{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/harden-multi-window-pane-detach-split-layout-mixed.schema.json",
  "title": "Aureline window-topology restore record",
  "description": "Boundary schema for window_topology_restore_record, the single governed record the desktop restore-review surface, the CLI restore inspector, Help/About, the diagnostics support export, and docs all read for one window reopen on the claimed-stable desktop matrix. It is minted by crates/aureline-shell/src/window_topology_restore_stable as a genuine projection of the live windows workspace-management page (crates/aureline-shell/src/windows) and the restore-provenance contract (crates/aureline-shell/src/restore) and binds, for one window identity: (1) authority / topology separation — workspace authority (dirty buffers, recovery journals, trust and policy, VFS identity, attached execution contexts) stays centralized and shared while pane-tree layout, focus history, zoom/follow state, and visible surfaces stay window-local; (2) a versioned pane tree keyed by stable pane IDs that split, move, float, pin, and close-pane mutate; (3) skeleton-first / hydrate-second restore where session-scoped panes (terminal, debug, notebook, query-console, preview-route, profiler-capture, incident-workspace, remote-backed, AI, test, pipeline) hydrate into a truthful placeholder or reconnect state and never silently reacquire live authority; (4) restore-no-rerun honesty — every session-scoped pane that did not survive keeps its slot with an in-place placeholder card that forbids command rerun and authority reacquire until an explicit user action; (5) display-topology and downgrade provenance — monitor changes, missing-extension substitutions, expired managed/remote sessions, and any downgrade from Exact to Compatible, Layout-only, or placeholder-backed recorded so the layout change is explainable in diagnostics and support export without scraping localized UI copy; (6) a public claim ceiling no reopen may exceed; and (7) a derived stable-claim verdict that narrows a reopen which cannot prove a pillar, or whose lowest binding surface marker is below Stable, below Stable with a named reason. Minted refs are opaque aureline://<class>/<id> object refs; upstream projection refs keep their source scheme.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "posture_id",
    "posture_label",
    "title",
    "summary",
    "window_id",
    "window_role",
    "surface_lifecycle_marker",
    "authority",
    "pane_tree",
    "display_topology",
    "restore_provenance",
    "recovery_chrome",
    "surface_projections",
    "pillars",
    "claim_ceiling",
    "stable_qualification",
    "recovery_routes",
    "routes",
    "accessibility",
    "available_without_account",
    "available_without_managed_services",
    "honesty_marker_present",
    "upstream",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": { "const": "window_topology_restore_record" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "notice": { "type": "string", "minLength": 1 },
    "shared_contract_ref": { "const": "shell:window_topology_restore_stable:v1" },
    "record_id": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "minLength": 1 },
    "posture_id": { "type": "string", "minLength": 1 },
    "posture_label": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "window_id": { "$ref": "#/$defs/presentRef" },
    "window_role": { "$ref": "#/$defs/windowRole" },
    "surface_lifecycle_marker": { "$ref": "#/$defs/lifecycleMarker" },
    "authority": { "$ref": "#/$defs/authoritySeparation" },
    "pane_tree": { "$ref": "#/$defs/paneTree" },
    "display_topology": { "$ref": "#/$defs/displayTopology" },
    "restore_provenance": { "$ref": "#/$defs/restoreProvenance" },
    "recovery_chrome": { "$ref": "#/$defs/recoveryChrome" },
    "surface_projections": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/surfaceProjection" }
    },
    "pillars": { "$ref": "#/$defs/pillars" },
    "claim_ceiling": { "$ref": "#/$defs/claimCeiling" },
    "stable_qualification": { "$ref": "#/$defs/stableQualification" },
    "recovery_routes": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/recoveryRoute" }
    },
    "routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/entryRoute" }
    },
    "accessibility": { "$ref": "#/$defs/accessibility" },
    "available_without_account": { "type": "boolean" },
    "available_without_managed_services": { "type": "boolean" },
    "honesty_marker_present": { "type": "boolean" },
    "upstream": { "$ref": "#/$defs/upstreamRefs" },
    "diagnostics_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "support_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } },
    "narrative_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } }
  },
  "$defs": {
    "canonicalRef": {
      "type": "string",
      "pattern": "^aureline://(?!home/|dashboard/|landing/|index/|overview/|start/|root/)[^/]+/.+$"
    },
    "presentRef": { "type": "string", "minLength": 1 },
    "lifecycleMarker": { "enum": ["preview", "beta", "stable"] },
    "claimClass": { "enum": ["stable", "beta", "preview", "not_claimed"] },
    "windowRole": {
      "enum": ["primary_workspace", "secondary_workspace", "review_window", "inspector_window"]
    },
    "splitAxis": { "enum": ["vertical", "horizontal"] },
    "workspaceAuthorityClass": {
      "enum": [
        "dirty_buffers",
        "recovery_journals",
        "trust_and_policy",
        "vfs_identity",
        "attached_execution_contexts"
      ]
    },
    "windowLocalTopologyClass": {
      "enum": ["pane_tree_layout", "focus_history", "zoom_follow_state", "visible_surfaces"]
    },
    "paneSurfaceClass": {
      "enum": [
        "editor", "diff", "search", "problems", "scm", "docs", "explorer",
        "terminal", "debugger", "notebook", "query_console", "preview",
        "profiler_capture", "remote_backed", "ai_panel", "test", "pipeline",
        "incident_workspace", "custom_extension"
      ]
    },
    "paneHydrationClass": {
      "enum": ["skeleton_recreated", "hydrated_live", "placeholder_card"]
    },
    "panePlaceholderState": {
      "enum": [
        "transcript_restored",
        "session_ended",
        "reconnect_available",
        "rerun_required",
        "context_unavailable"
      ]
    },
    "paneSubstitutionReason": {
      "enum": [
        "missing_extension",
        "expired_remote_session",
        "expired_managed_session",
        "unsupported_display_topology",
        "revoked_permission",
        "runtime_did_not_survive"
      ]
    },
    "paneRecoveryAction": {
      "enum": [
        "reconnect_session",
        "rerun_explicitly",
        "install_extension",
        "open_without",
        "compare_evidence",
        "export_evidence",
        "remove_pane"
      ]
    },
    "restoreFidelityClass": {
      "enum": ["exact", "compatible", "layout_only", "placeholder_backed"]
    },
    "restoreDowngradeReason": {
      "enum": [
        "display_topology_change",
        "missing_extension_substitution",
        "expired_managed_session",
        "expired_remote_session",
        "unsupported_display_topology",
        "runtime_did_not_survive",
        "schema_translation_required"
      ]
    },
    "topologyChangeClass": {
      "enum": [
        "display_removed",
        "safe_bounds_changed",
        "scale_changed",
        "wake_or_reconnect",
        "docking_changed"
      ]
    },
    "restoreAdjustmentClass": {
      "enum": [
        "snapped_to_safe_bounds",
        "moved_to_primary_display",
        "scale_normalized",
        "fullscreen_cleared",
        "dialog_recentered_to_owner",
        "layout_only_fallback"
      ]
    },
    "restoreTruthSurface": {
      "enum": ["desktop_restore_review", "cli_inspect", "help_about", "diagnostics_support_export"]
    },
    "narrowingReason": {
      "enum": [
        "authority_topology_not_separated",
        "pane_tree_not_versioned_stable",
        "hydration_not_skeleton_first",
        "silent_rerun_possible",
        "provenance_not_export_safe",
        "recovery_chrome_not_reachable",
        "surface_not_yet_stable"
      ]
    },
    "routeSurface": {
      "enum": ["activity_center", "command_palette", "status_bar", "menu_command"]
    },
    "layoutMode": { "enum": ["normal", "high_contrast", "zoomed"] },
    "recoveryRole": { "enum": ["primary", "recovery", "secondary"] },
    "authoritySeparation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_authority_ref",
        "workspace_authority_classes",
        "window_local_topology_classes",
        "workspace_authority_centralized",
        "topology_window_local"
      ],
      "properties": {
        "workspace_authority_ref": { "$ref": "#/$defs/canonicalRef" },
        "workspace_authority_classes": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/workspaceAuthorityClass" }
        },
        "window_local_topology_classes": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/windowLocalTopologyClass" }
        },
        "workspace_authority_centralized": { "type": "boolean" },
        "topology_window_local": { "type": "boolean" }
      }
    },
    "paneTreeNode": {
      "type": "object",
      "required": ["node_kind"],
      "oneOf": [
        {
          "additionalProperties": false,
          "required": ["node_kind", "pane_id"],
          "properties": {
            "node_kind": { "const": "leaf" },
            "pane_id": { "type": "string", "minLength": 1 }
          }
        },
        {
          "additionalProperties": false,
          "required": ["node_kind", "axis", "first_weight", "second_weight", "first", "second"],
          "properties": {
            "node_kind": { "const": "split" },
            "axis": { "$ref": "#/$defs/splitAxis" },
            "first_weight": { "type": "integer", "minimum": 1 },
            "second_weight": { "type": "integer", "minimum": 1 },
            "first": { "$ref": "#/$defs/paneTreeNode" },
            "second": { "$ref": "#/$defs/paneTreeNode" }
          }
        }
      ]
    },
    "paneSlot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pane_id",
        "surface_class",
        "hydration",
        "runtime_survived",
        "command_rerun_forbidden",
        "authority_reacquire_forbidden",
        "reopen_target_ref",
        "recovery_actions",
        "note"
      ],
      "properties": {
        "pane_id": { "type": "string", "minLength": 1 },
        "surface_class": { "$ref": "#/$defs/paneSurfaceClass" },
        "title_hint": { "type": "string", "minLength": 1 },
        "hydration": { "$ref": "#/$defs/paneHydrationClass" },
        "placeholder_state": { "$ref": "#/$defs/panePlaceholderState" },
        "substitution_reason": { "$ref": "#/$defs/paneSubstitutionReason" },
        "runtime_survived": { "type": "boolean" },
        "command_rerun_forbidden": { "type": "boolean" },
        "authority_reacquire_forbidden": { "type": "boolean" },
        "reopen_target_ref": { "$ref": "#/$defs/canonicalRef" },
        "evidence_ref": { "$ref": "#/$defs/canonicalRef" },
        "recovery_actions": { "type": "array", "items": { "$ref": "#/$defs/paneRecoveryAction" } },
        "note": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "comment": "A placeholder-backed pane must disclose its restore-no-rerun state, forbid rerun and authority reacquire, and offer at least one recovery action.",
          "if": {
            "properties": { "hydration": { "const": "placeholder_card" } }
          },
          "then": {
            "required": ["placeholder_state"],
            "properties": {
              "command_rerun_forbidden": { "const": true },
              "authority_reacquire_forbidden": { "const": true },
              "runtime_survived": { "const": false },
              "recovery_actions": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "paneTree": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pane_tree_schema_version", "root", "slots"],
      "properties": {
        "pane_tree_schema_version": { "type": "integer", "minimum": 1 },
        "root": { "$ref": "#/$defs/paneTreeNode" },
        "slots": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/paneSlot" } }
      }
    },
    "displayTopology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topology_change_classes", "adjustments", "layout_adjusted_note_required"],
      "properties": {
        "topology_change_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/topologyChangeClass" }
        },
        "adjustments": {
          "type": "array",
          "items": { "$ref": "#/$defs/restoreAdjustmentClass" }
        },
        "layout_adjusted_note_required": { "type": "boolean" }
      }
    },
    "restoreDowngrade": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_fidelity", "to_fidelity", "reason", "note"],
      "properties": {
        "from_fidelity": { "$ref": "#/$defs/restoreFidelityClass" },
        "to_fidelity": { "$ref": "#/$defs/restoreFidelityClass" },
        "reason": { "$ref": "#/$defs/restoreDowngradeReason" },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "restoreProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["restore_provenance_ref", "resulting_fidelity", "summary"],
      "properties": {
        "restore_provenance_ref": { "$ref": "#/$defs/canonicalRef" },
        "resulting_fidelity": { "$ref": "#/$defs/restoreFidelityClass" },
        "downgrade": { "$ref": "#/$defs/restoreDowngrade" },
        "compare_ref": { "$ref": "#/$defs/canonicalRef" },
        "export_ref": { "$ref": "#/$defs/canonicalRef" },
        "summary": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "comment": "Only an exact reopen may omit the downgrade record; any non-exact reopen must carry one.",
          "if": {
            "properties": { "resulting_fidelity": { "not": { "const": "exact" } } }
          },
          "then": { "required": ["downgrade"] }
        }
      ]
    },
    "recoveryChrome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title_context_visible",
        "restore_details_reachable",
        "command_palette_reachable",
        "keyboard_focus_reachable",
        "activity_center_visible"
      ],
      "properties": {
        "title_context_visible": { "type": "boolean" },
        "restore_details_reachable": { "type": "boolean" },
        "command_palette_reachable": { "type": "boolean" },
        "keyboard_focus_reachable": { "type": "boolean" },
        "activity_center_visible": { "type": "boolean" }
      }
    },
    "surfaceProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "surface_marker", "reads_shared_record", "summary_line"],
      "properties": {
        "surface": { "$ref": "#/$defs/restoreTruthSurface" },
        "surface_marker": { "$ref": "#/$defs/lifecycleMarker" },
        "reads_shared_record": { "type": "boolean" },
        "summary_line": { "type": "string", "minLength": 1 }
      }
    },
    "pillars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_topology_separated",
        "pane_tree_versioned_stable_ids",
        "skeleton_first_hydrate_second",
        "no_silent_rerun_or_reacquire",
        "restore_provenance_export_safe",
        "recovery_chrome_reachable"
      ],
      "properties": {
        "authority_topology_separated": { "type": "boolean" },
        "pane_tree_versioned_stable_ids": { "type": "boolean" },
        "skeleton_first_hydrate_second": { "type": "boolean" },
        "no_silent_rerun_or_reacquire": { "type": "boolean" },
        "restore_provenance_export_safe": { "type": "boolean" },
        "recovery_chrome_reachable": { "type": "boolean" }
      }
    },
    "claimCeiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asserts_authority_topology_separated",
        "asserts_pane_tree_versioned",
        "asserts_skeleton_first_hydrate_second",
        "asserts_no_silent_rerun",
        "asserts_provenance_export_safe",
        "asserts_recovery_chrome_reachable"
      ],
      "properties": {
        "asserts_authority_topology_separated": { "type": "boolean" },
        "asserts_pane_tree_versioned": { "type": "boolean" },
        "asserts_skeleton_first_hydrate_second": { "type": "boolean" },
        "asserts_no_silent_rerun": { "type": "boolean" },
        "asserts_provenance_export_safe": { "type": "boolean" },
        "asserts_recovery_chrome_reachable": { "type": "boolean" }
      }
    },
    "stableQualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_class", "qualifies_stable", "narrowing_reasons"],
      "properties": {
        "claim_class": { "$ref": "#/$defs/claimClass" },
        "qualifies_stable": { "type": "boolean" },
        "narrowing_reasons": { "type": "array", "items": { "$ref": "#/$defs/narrowingReason" } }
      }
    },
    "recoveryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_label", "action_role", "keyboard_reachable"],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_label": { "type": "string", "minLength": 1 },
        "action_role": { "$ref": "#/$defs/recoveryRole" },
        "keyboard_reachable": { "type": "boolean" }
      }
    },
    "entryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "route_ref", "keyboard_reachable", "activates_same_item"],
      "properties": {
        "surface": { "$ref": "#/$defs/routeSurface" },
        "route_ref": { "$ref": "#/$defs/canonicalRef" },
        "keyboard_reachable": { "type": "boolean" },
        "activates_same_item": { "type": "boolean" }
      }
    },
    "layoutModeDisclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "row_narration_available", "recovery_affordances_reachable"],
      "properties": {
        "mode": { "$ref": "#/$defs/layoutMode" },
        "row_narration_available": { "type": "boolean" },
        "recovery_affordances_reachable": { "type": "boolean" }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_order_index", "tab_stop_count", "row_narration", "action_labels", "layout_modes"
      ],
      "properties": {
        "focus_order_index": { "type": "integer", "minimum": 0 },
        "tab_stop_count": { "type": "integer", "minimum": 0 },
        "row_narration": { "type": "string", "minLength": 1 },
        "action_labels": { "type": "array", "items": { "type": "string" } },
        "layout_modes": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/layoutModeDisclosure" }
        }
      }
    },
    "upstreamRefs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["windows_page_ref", "restore_provenance_kind_ref", "contributing_case_refs"],
      "properties": {
        "windows_page_ref": { "$ref": "#/$defs/presentRef" },
        "restore_provenance_kind_ref": { "$ref": "#/$defs/presentRef" },
        "contributing_case_refs": { "type": "array", "items": { "$ref": "#/$defs/presentRef" } }
      }
    }
  }
}
