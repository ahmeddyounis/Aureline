{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/choice_control_state.schema.json",
  "title": "Aureline choice control (checkbox/radio/toggle/segmented) contract",
  "description": "Boundary schema for choice-control records frozen in docs/ux/toggle_and_choice_control_contract.md. A record captures the control family (checkbox/radio/toggle/segmented_control), live-vs-staged apply timing, mixed/indeterminate semantics, source-value provenance (default/imported/user/policy/staged/live), lock/disabled truth, required disclosure copy slots, reset/revert/undo posture, and the keyboard model (tab stops vs roving focus) needed for parity. Records and fixtures carry opaque refs, controlled vocabulary, and short review-safe copy only; they avoid raw policy bodies, raw provider payloads, raw hostnames/URLs, raw filesystem paths, secrets, or user-authored content. Adding enum values or optional fields is additive-minor and bumps choice_control_state_schema_version when payload semantics change; repurposing an existing value is breaking and requires a governance decision.",
  "type": "object",
  "$ref": "#/$defs/choice_control_state_record",
  "$defs": {
    "choice_control_state_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the choice-control contract."
    },
    "record_kind": {
      "type": "string",
      "const": "choice_control_state_record"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[a-z0-9]+(?:[a-z0-9_.:/-]*[a-z0-9])?$",
      "description": "Stable opaque id safe for logs, RPC, fixtures, and support exports."
    },
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "description": "Repo-relative doc ref, schema ref, fixture ref, or opaque locator."
    },
    "nullable_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/ref" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 900
    },
    "nullable_sentence": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/reviewable_sentence" }
      ]
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "settings",
        "onboarding",
        "install_review",
        "admin_policy",
        "package_review",
        "migration_import",
        "connection_setup",
        "request_runtime",
        "editor",
        "command_surface",
        "generic_form"
      ]
    },
    "control_family_class": {
      "type": "string",
      "enum": ["checkbox", "radio", "toggle", "segmented_control"]
    },
    "choice_control_role_class": {
      "type": "string",
      "enum": [
        "boolean_value",
        "batch_inclusion_value",
        "single_choice_value",
        "mode_switch",
        "selection_check_cell"
      ],
      "description": "Semantic role of the choice control in the surface."
    },
    "actionability_class": {
      "type": "string",
      "enum": [
        "enabled",
        "disabled_no_valid_action",
        "read_only_inspectable",
        "locked_policy_or_managed",
        "locked_permission_or_trust",
        "busy_temporarily_blocked",
        "pending_validation_blocked",
        "preview_required",
        "review_required",
        "destructive_confirmation_required"
      ]
    },
    "lock_state_class": {
      "type": "string",
      "enum": [
        "unlocked",
        "policy_locked",
        "managed_locked",
        "permission_locked",
        "trust_locked",
        "source_locked",
        "capability_locked"
      ]
    },
    "source_value_state_class": {
      "type": "string",
      "enum": [
        "not_value_control",
        "default_value",
        "detected_value",
        "imported_value",
        "user_value",
        "policy_value",
        "staged_value",
        "live_value"
      ]
    },
    "disabled_reason_class": {
      "type": "string",
      "enum": [
        "none",
        "no_valid_action",
        "policy_blocked",
        "dependency_missing",
        "degraded_index",
        "wrong_target",
        "read_only",
        "host_unavailable",
        "unsupported_current_mode",
        "quota_or_budget_exhausted",
        "preview_only",
        "stale_context"
      ]
    },
    "apply_timing_class": {
      "type": "string",
      "enum": [
        "immediate_live_apply",
        "staged_apply_required",
        "preview_first_apply_required",
        "dry_run_then_apply",
        "policy_locked_no_apply",
        "observe_only_no_apply"
      ]
    },
    "choice_value_state_class": {
      "type": "string",
      "enum": [
        "unchecked",
        "checked",
        "mixed_indeterminate",
        "unselected",
        "selected",
        "mixed_selection",
        "none_selected"
      ]
    },
    "apply_disclosure_class": {
      "type": "string",
      "enum": [
        "implied_by_switch",
        "inline_helper_text",
        "staged_dirty_chip_and_apply_bar",
        "routes_to_preview_or_dry_run",
        "locked_with_explanation_route",
        "read_only_with_inspection_route"
      ]
    },
    "reversal_posture_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "undo_available_one_step",
        "revert_staged_changes_available",
        "reset_to_next_winning_source_available",
        "reset_or_revert_blocked_by_policy"
      ]
    },
    "bulk_scope_class": {
      "type": "string",
      "enum": [
        "single_target",
        "all_selected_targets",
        "all_matching_targets",
        "staged_draft_only",
        "selection_only_not_value"
      ]
    },
    "bulk_context_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bulk_scope_class", "scope_summary"],
      "properties": {
        "bulk_scope_class": { "$ref": "#/$defs/bulk_scope_class" },
        "scope_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "choice_option_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["option_id", "visible_label", "value_state_class", "actionability_class"],
      "properties": {
        "option_id": { "$ref": "#/$defs/opaque_id" },
        "visible_label": { "type": "string", "minLength": 1, "maxLength": 120 },
        "value_state_class": { "$ref": "#/$defs/choice_value_state_class" },
        "actionability_class": { "$ref": "#/$defs/actionability_class" },
        "lock_state_class": { "$ref": "#/$defs/lock_state_class" },
        "disabled_reason_class": { "$ref": "#/$defs/disabled_reason_class" },
        "explanation_ref": { "$ref": "#/$defs/nullable_ref" }
      }
    },
    "state_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actionability_class",
        "lock_state_class",
        "source_value_state_class",
        "disabled_reason_class",
        "explanation_ref",
        "state_summary"
      ],
      "properties": {
        "actionability_class": { "$ref": "#/$defs/actionability_class" },
        "lock_state_class": { "$ref": "#/$defs/lock_state_class" },
        "source_value_state_class": { "$ref": "#/$defs/source_value_state_class" },
        "disabled_reason_class": { "$ref": "#/$defs/disabled_reason_class" },
        "explanation_ref": { "$ref": "#/$defs/nullable_ref" },
        "state_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "apply_model_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["apply_timing_class", "apply_disclosure_class", "disclosure_summary", "reversal_posture_class"],
      "properties": {
        "apply_timing_class": { "$ref": "#/$defs/apply_timing_class" },
        "apply_disclosure_class": { "$ref": "#/$defs/apply_disclosure_class" },
        "disclosure_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "reversal_posture_class": { "$ref": "#/$defs/reversal_posture_class" },
        "primary_reversal_action_ref": { "$ref": "#/$defs/nullable_ref" },
        "secondary_reversal_action_ref": { "$ref": "#/$defs/nullable_ref" }
      }
    },
    "content_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["group_label", "helper_text"],
      "properties": {
        "group_label": { "type": "string", "minLength": 1, "maxLength": 160 },
        "helper_text": { "$ref": "#/$defs/nullable_sentence" },
        "mixed_state_helper_text": { "$ref": "#/$defs/nullable_sentence" },
        "source_label_text": { "$ref": "#/$defs/nullable_sentence" }
      }
    },
    "focus_model_class": {
      "type": "string",
      "enum": [
        "single_control_tab_stop",
        "multi_item_tab_stops",
        "roving_focus_group",
        "collection_row_focus_space_toggles_selection"
      ]
    },
    "keyboard_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_model_class",
        "activation_keys",
        "navigation_keys",
        "keyboard_summary"
      ],
      "properties": {
        "focus_model_class": { "$ref": "#/$defs/focus_model_class" },
        "activation_keys": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1, "maxLength": 20 }
        },
        "navigation_keys": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1, "maxLength": 20 }
        },
        "keyboard_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "accessibility_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accessible_name", "accessible_description", "announces_state_changes"],
      "properties": {
        "accessible_name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "accessible_description": { "$ref": "#/$defs/reviewable_sentence" },
        "announces_state_changes": { "type": "boolean" },
        "announces_mixed_state": { "type": "boolean" },
        "focus_return_ref": { "$ref": "#/$defs/nullable_ref" }
      }
    },
    "__fixture_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario", "exercised_axes"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "scenario": { "$ref": "#/$defs/reviewable_sentence" },
        "exercised_axes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1, "maxLength": 64 }
        }
      }
    },
    "choice_control_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "choice_control_state_schema_version",
        "record_kind",
        "choice_control_id",
        "surface_family",
        "control_family_class",
        "control_role_class",
        "state",
        "apply_model",
        "bulk_context",
        "content",
        "options",
        "keyboard",
        "accessibility",
        "emitted_at",
        "narrative_refs"
      ],
      "properties": {
        "choice_control_state_schema_version": { "$ref": "#/$defs/choice_control_state_schema_version" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "choice_control_id": { "$ref": "#/$defs/opaque_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "control_family_class": { "$ref": "#/$defs/control_family_class" },
        "control_role_class": { "$ref": "#/$defs/choice_control_role_class" },
        "state": { "$ref": "#/$defs/state_block" },
        "apply_model": { "$ref": "#/$defs/apply_model_block" },
        "bulk_context": { "$ref": "#/$defs/bulk_context_record" },
        "content": { "$ref": "#/$defs/content_block" },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/choice_option_record" }
        },
        "keyboard": { "$ref": "#/$defs/keyboard_block" },
        "accessibility": { "$ref": "#/$defs/accessibility_block" },
        "emitted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "narrative_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ref" }
        },
        "__fixture__": { "$ref": "#/$defs/__fixture_block" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "control_family_class": { "enum": ["radio", "segmented_control"] } },
            "required": ["control_family_class"]
          },
          "then": {
            "properties": {
              "keyboard": {
                "properties": {
                  "focus_model_class": { "const": "roving_focus_group" }
                },
                "required": ["focus_model_class"]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "control_family_class": { "const": "toggle" } },
            "required": ["control_family_class"]
          },
          "then": {
            "properties": {
              "apply_model": {
                "properties": { "apply_disclosure_class": { "enum": ["implied_by_switch", "inline_helper_text"] } },
                "required": ["apply_disclosure_class"]
              }
            }
          }
        }
      ]
    }
  }
}

