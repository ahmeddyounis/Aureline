        "companion_safe",
        "system_notification_safe"
      ],
      "properties": {
        "$schema": { "$ref": "#/$defs/instance_schema_hint" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "privacy_safe_payload_rule_record" },
        "notification_suppression_schema_version": { "$ref": "#/$defs/notification_suppression_schema_version" },
        "rule_id": { "$ref": "#/$defs/opaque_id" },
        "privacy_payload_class": { "$ref": "#/$defs/privacy_payload_class" },
        "applies_to_surface_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/delivery_surface_class" }
        },
        "allowed_label_kinds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/allowed_label_kind" }
        },
        "forbidden_label_kinds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/forbidden_label_kind" }
        },
        "allowed_action_kinds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/allowed_action_kind" }
        },
        "forbidden_shortcut_action_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/forbidden_shortcut_action_class" }
        },
        "redacted_summary_template_label": { "$ref": "#/$defs/short_label_text" },
        "redaction_template_tokens": {
