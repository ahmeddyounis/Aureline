        "record_kind": { "const": "notification_suppression_record" },
        "notification_suppression_schema_version": { "$ref": "#/$defs/notification_suppression_schema_version" },
        "suppression_record_id": { "$ref": "#/$defs/opaque_id" },
        "canonical_event_id": { "$ref": "#/$defs/opaque_id" },
