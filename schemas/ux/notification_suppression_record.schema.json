          "uniqueItems": true,
          "items": { "$ref": "#/$defs/redaction_summary_template_token" }
        },
        "max_label_text_length": { "type": "integer", "minimum": 1, "maximum": 160 },
        "requires_in_product_open_for_actions": { "type": "boolean" },
        "must_resolve_through_in_product_surface_for_high_risk": {
          "type": "boolean",
          "const": true
        },
        "lock_screen_safe": { "type": "boolean" },
        "companion_safe": { "type": "boolean" },
        "system_notification_safe": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "privacy_payload_class": { "const": "in_product_only" }
            },
            "required": ["privacy_payload_class"]
          },
          "then": {
            "properties": {
              "lock_screen_safe": { "const": false },
              "applies_to_surface_classes": {
                "not": {
                  "type": "array",
                  "contains": { "const": "lock_screen_summary" }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "privacy_payload_class": { "const": "policy_forbidden_on_lock_screen" }
            },
            "required": ["privacy_payload_class"]
          },
          "then": {
            "properties": {
              "lock_screen_safe": { "const": false },
              "allowed_action_kinds": {
                "type": "array",
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "privacy_payload_class": { "const": "lock_screen_safe_generic" }
            },
            "required": ["privacy_payload_class"]
          },
          "then": {
            "properties": {
              "lock_screen_safe": { "const": true },
              "allowed_label_kinds": {
                "type": "array",
                "items": {
                  "enum": [
                    "category_label_only",
                    "summary_member_count_label",
                    "severity_class_label",
                    "lifecycle_phase_label",
                    "audit_only_marker",
                    "privacy_redacted_placeholder"
                  ]
                }
              }
            }
          }
        }
      ]
