        },
        "bypass_protection": { "$ref": "#/$defs/bypass_protection" },
        "desktop_summary_affordance_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "client_scopes": {
          "type": "array",
          "minItems": 1,
