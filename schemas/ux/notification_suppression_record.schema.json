      "type": "string",
      "enum": [
        "os_notification_action",
        "dock_taskbar_progress",
        "dock_taskbar_badge",
        "system_tray_summary",
        "lock_screen_quick_action",
        "companion_push_action",
        "desktop_widget_summary"
      ]
    },
    "desktop_affordance_effect_class": {
      "type": "string",
      "enum": [
        "read_only_reopen_canonical_object",
        "read_only_reopen_review_context",
        "read_only_reopen_durable_row",
        "read_only_reopen_digest_group",
        "read_only_reopen_attention_item",
        "read_only_reopen_placeholder",
        "read_only_progress_mirror",
        "read_only_badge_mirror",
        "read_only_summary_count_mirror",
        "mutation_via_review_path_only",
        "mutation_via_in_product_only",
        "forbidden_mutation_shortcut"
      ],
      "description": "What an OS-notification action, dock / taskbar progress mirror, dock / taskbar badge, system-tray summary, lock-screen quick action, companion push action, or desktop widget summary may do. Read-only effects MUST resolve through the in-product surface that owns the canonical object; mutation effects MUST route through a review sheet, approval workflow, or in-product mutation surface and MUST NEVER be completable inside the OS shortcut path."
    },
    "progress_value_basis_class": {
      "type": "string",
      "enum": [
        "derived_from_durable_job_phase",
        "derived_from_envelope_progress",
        "derived_from_grouped_burst_member_count",
        "derived_from_canonical_object_state",
        "not_a_progress_source"
      ]
    },
