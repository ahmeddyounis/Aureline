      "properties": {
        "$schema": { "$ref": "#/$defs/instance_schema_hint" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "desktop_summary_affordance_record" },
        "notification_suppression_schema_version": { "$ref": "#/$defs/notification_suppression_schema_version" },
        "desktop_affordance_id": { "$ref": "#/$defs/opaque_id" },
        "affordance_class": { "$ref": "#/$defs/desktop_affordance_class" },
        "mirrors_canonical_event_id": { "$ref": "#/$defs/opaque_id" },
        "mirrors_canonical_object_target_ref": { "$ref": "#/$defs/opaque_id" },
        "mirrors_durable_job_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "effect_class": { "$ref": "#/$defs/desktop_affordance_effect_class" },
        "review_sheet_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "approval_workflow_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "requires_in_product_review_for_destructive": {
          "type": "boolean",
          "const": true
        },
        "forbidden_shortcut_action_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/forbidden_shortcut_action_class" }
        },
        "privacy_payload_class": { "$ref": "#/$defs/privacy_payload_class" },
        "visible_label_text_template": { "$ref": "#/$defs/short_label_text" },
        "redaction_template_tokens": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/redaction_summary_template_token" }
        },
        "progress_value_basis_class": { "$ref": "#/$defs/progress_value_basis_class" },
        "last_synced_durable_job_phase_class": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "string",
              "enum": [
                "preparing",
                "queued",
                "running",
                "waiting_input",
                "partially_complete",
                "completed",
                "failed",
                "cancelled",
                "held",
                "suppressed"
              ]
            }
          ],
          "description": "Re-exported from schemas/ux/durable_job_envelope.schema.json without modification."
        },
        "announce_actions_to_assistive_tech": { "type": "boolean" },
        "audit_event_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "client_scope": { "$ref": "#/$defs/client_scope" },
        "exact_reopen_linkage": { "$ref": "#/$defs/exact_reopen_linkage" },
        "preserves_durable_history": {
          "type": "boolean",
          "const": true
        },
        "preserves_canonical_event_id": {
          "type": "boolean",
          "const": true
        },
        "preserves_canonical_object_identity": {
          "type": "boolean",
          "const": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "effect_class": { "const": "forbidden_mutation_shortcut" }
            },
            "required": ["effect_class"]
          },
          "then": {
            "properties": {
              "forbidden_shortcut_action_classes": {
                "type": "array",
                "minItems": 1
              }
            },
            "required": ["forbidden_shortcut_action_classes"]
          }
        },
        {
          "if": {
            "properties": {
              "effect_class": {
                "enum": [
                  "mutation_via_review_path_only",
                  "mutation_via_in_product_only"
                ]
              }
            },
            "required": ["effect_class"]
          },
          "then": {
            "properties": {
              "review_sheet_ref": { "$ref": "#/$defs/opaque_id" }
            },
            "required": ["review_sheet_ref"]
          }
        },
        {
          "if": {
            "properties": {
              "affordance_class": { "const": "lock_screen_quick_action" }
            },
            "required": ["affordance_class"]
          },
          "then": {
            "properties": {
              "privacy_payload_class": {
                "enum": [
                  "lock_screen_safe_generic",
                  "lock_screen_safe_scoped",
                  "policy_forbidden_on_lock_screen"
                ]
              },
              "effect_class": {
                "enum": [
                  "read_only_reopen_canonical_object",
                  "read_only_reopen_review_context",
                  "read_only_reopen_durable_row",
                  "read_only_reopen_digest_group",
                  "read_only_reopen_attention_item",
                  "read_only_reopen_placeholder",
                  "read_only_progress_mirror",
                  "read_only_badge_mirror",
                  "read_only_summary_count_mirror",
                  "forbidden_mutation_shortcut"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "affordance_class": {
                "enum": ["dock_taskbar_progress", "dock_taskbar_badge", "desktop_widget_summary", "system_tray_summary"]
              }
            },
            "required": ["affordance_class"]
          },
          "then": {
            "properties": {
              "effect_class": {
                "enum": [
                  "read_only_reopen_canonical_object",
                  "read_only_reopen_review_context",
                  "read_only_reopen_durable_row",
                  "read_only_reopen_digest_group",
                  "read_only_reopen_attention_item",
                  "read_only_reopen_placeholder",
                  "read_only_progress_mirror",
                  "read_only_badge_mirror",
                  "read_only_summary_count_mirror",
                  "forbidden_mutation_shortcut"
                ]
              }
            }
          }
        }
      ]
    }
  }
