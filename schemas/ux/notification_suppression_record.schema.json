            { "type": "null" },
            { "$ref": "#/$defs/monotonic_timestamp" }
          ]
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "preserves_durable_history": {
          "type": "boolean",
          "const": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "suppression_class": {
                "enum": [
                  "collapsed_dedupe_same_canonical_event",
                  "collapsed_dedupe_same_grouped_burst"
                ]
              }
            },
            "required": ["suppression_class"]
          },
          "then": {
            "properties": {
              "suppression_outcome": { "const": "not_delivered_collapsed" }
            },
            "required": ["suppression_outcome"]
          }
        },
        {
          "if": {
            "properties": {
              "suppression_class": { "const": "collapsed_dedupe_same_grouped_burst" }
            },
            "required": ["suppression_class"]
          },
          "then": {
            "properties": {
              "collapse_into_grouped_burst_id_ref": { "$ref": "#/$defs/opaque_id" }
            },
            "required": ["collapse_into_grouped_burst_id_ref"]
          }
        },
        {
          "if": {
            "properties": {
              "suppression_class": { "const": "collapsed_dedupe_same_canonical_event" }
            },
            "required": ["suppression_class"]
          },
          "then": {
            "properties": {
              "collapse_into_canonical_event_id_ref": { "$ref": "#/$defs/opaque_id" }
            },
            "required": ["collapse_into_canonical_event_id_ref"]
          }
        },
        {
          "if": {
            "properties": {
              "suppression_class": { "const": "denied_policy_forbidden_on_lock_screen" }
            },
            "required": ["suppression_class"]
          },
          "then": {
            "properties": {
              "intended_delivery_surface_class": { "const": "lock_screen_summary" },
              "suppression_outcome": {
                "enum": [
                  "delivered_in_product_only",
                  "not_delivered_audit_trail_only",
                  "delivered_admin_narrowed_durable_only"
                ]
              }
            },
            "required": ["intended_delivery_surface_class", "suppression_outcome"]
          }
        },
        {
          "if": {
            "properties": {
              "suppression_class": { "const": "denied_audit_trail_only" }
            },
            "required": ["suppression_class"]
          },
          "then": {
            "properties": {
              "suppression_outcome": { "const": "not_delivered_audit_trail_only" },
              "preserved_durable_linkback": {
                "type": "object",
                "properties": {
                  "kind": { "const": "audit_trail_only" }
                },
                "required": ["kind"]
              }
            },
            "required": ["suppression_outcome", "preserved_durable_linkback"]
          }
        },
        {
          "if": {
            "properties": {
              "suppression_class": { "const": "held_admin_suppression" }
            },
            "required": ["suppression_class"]
          },
          "then": {
            "properties": {
              "active_quiet_hours_modes_at_decision": {
                "type": "array",
                "contains": { "const": "mode_admin_suppression" }
              },
              "intended_interruptibility_tier": {
                "not": { "const": "tier_critical_safety" }
              }
            },
            "required": ["active_quiet_hours_modes_at_decision"]
          }
        },
        {
          "if": {
            "properties": {
              "suppression_class": { "const": "held_privacy_mode" }
            },
            "required": ["suppression_class"]
          },
          "then": {
            "properties": {
              "active_quiet_hours_modes_at_decision": {
                "type": "array",
                "contains": { "const": "mode_privacy_mode" }
              }
            },
            "required": ["active_quiet_hours_modes_at_decision"]
          }
        },
        {
          "if": {
            "properties": {
              "suppression_class": { "const": "held_quiet_hours_user_policy" }
            },
            "required": ["suppression_class"]
          },
          "then": {
            "properties": {
              "active_quiet_hours_modes_at_decision": {
                "type": "array",
                "contains": { "const": "mode_quiet_hours_user" }
              }
            },
            "required": ["active_quiet_hours_modes_at_decision"]
          }
        }
      ]
    },
    "privacy_safe_payload_rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "notification_suppression_schema_version",
        "rule_id",
        "privacy_payload_class",
