{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/notification_suppression_record.schema.json",
  "title": "Aureline notification suppression audit, lock-screen privacy, exact-reopen, and desktop-summary affordance contract",
  "description": "Boundary schema for the notification_suppression_record, privacy_safe_payload_rule_record, and desktop_summary_affordance_record frozen in docs/ux/os_notification_and_quiet_hours_contract.md. The suppression record is the auditable trail for a notification that was held, delayed, collapsed, redacted, or denied; the privacy-safe payload rule freezes what each privacy_payload_class may carry on lock-screen, companion, and system-notification surfaces and which shortcut actions are forbidden; the desktop-summary affordance record freezes how OS-notification actions, dock / taskbar progress, dock / taskbar badges, system-tray summaries, lock-screen quick actions, companion push actions, and desktop widget summaries may reflect durable work without becoming privileged mutation paths. Records compose with schemas/ux/notification_event.schema.json, schemas/ux/event_lineage.schema.json, schemas/ux/durable_job_envelope.schema.json, and schemas/ux/activity_event_envelope.schema.json without re-minting delivery-surface, quiet-hours, suppression-reason, privacy-payload, dedupe, or reopen-target vocabulary. Raw paths, raw URLs, raw provider payloads, raw prompt or completion text, raw command bodies, secret material, and customer-owned identifiers never cross this boundary. Adding a new suppression class, suppression outcome, desktop-affordance class, desktop-affordance effect class, forbidden-shortcut-action class, allowed-label kind, allowed-action kind, or progress-value basis class is additive-minor and requires a notification_suppression_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/notification_suppression_record" },
    { "$ref": "#/$defs/privacy_safe_payload_rule_record" },
    { "$ref": "#/$defs/desktop_summary_affordance_record" }
  ],
  "$defs": {
    "notification_suppression_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this notification-suppression vocabulary export. Current value is 1."
    },
    "instance_schema_hint": {
      "type": "string",
      "format": "uri-reference",
      "description": "Optional schema hint carried on worked fixtures."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for RPC, manifests, journals, support bundles, claim manifests, OS notification payloads, lock-screen summaries, and companion push payloads."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },
    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "description": "Short privacy-safe label text. Must not contain raw paths, raw URLs, raw provider payloads, raw secret material, raw customer-owned identifiers, or raw prompt / completion text."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "notification_suppression_record",
        "privacy_safe_payload_rule_record",
        "desktop_summary_affordance_record"
      ]
    },
    "source_subsystem": {
      "type": "string",
      "enum": [
        "editor",
        "terminal",
        "review_and_diff",
        "palette_and_search",
        "install_update_attach",
        "ai_apply",
        "collaboration",
        "provider_bearing",
        "docs_help_service_health",
        "support_export",
        "build_system",
        "test_runner",
        "debug_session",
        "task_runner",
        "indexer",
        "vfs_save",
        "sync_mirror",
        "notebook_kernel",
        "remote_agent",
        "extension_host",
        "workspace_trust",
        "policy_resolver",
        "admin_policy",
        "secret_broker",
        "runtime_power_manager",
        "shell"
      ],
      "description": "Re-exported from schemas/ux/activity_event_envelope.schema.json without modification."
    },
    "client_scope": {
      "type": "string",
      "enum": [
        "desktop_product",
        "cli",
        "companion_surface",
        "remote_agent",
        "sdk_or_api",
        "managed_admin_surface"
      ]
    },
    "delivery_surface_class": {
      "type": "string",
      "enum": [
        "toast",
        "contextual_banner",
        "status_item",
        "durable_job_row",
        "attention_item",
        "activity_center_digest_card",
        "digest_group_row",
        "os_notification",
        "os_badge_app_icon",
        "lock_screen_summary",
        "companion_push",
        "not_delivered_held"
      ],
      "description": "Re-exported from schemas/ux/activity_event_envelope.schema.json without modification."
    },
    "quiet_hours_mode": {
      "type": "string",
      "enum": [
        "mode_none",
        "mode_quiet_hours_user",
        "mode_do_not_disturb_user",
        "mode_focus_mode_user",
        "mode_presentation",
        "mode_screen_share",
        "mode_privacy_mode",
        "mode_reduced_attention_policy",
        "mode_power_saver_runtime",
        "mode_admin_suppression"
      ]
    },
    "suppression_reason": {
      "type": "string",
      "enum": [
        "quiet_hours_user_policy",
        "do_not_disturb_user_policy",
        "focus_mode_user_policy",
        "presentation_mode_active",
        "screen_share_active",
        "privacy_mode_active",
        "admin_policy_suppression",
        "reduced_attention_posture",
        "power_saver_background_pause",
        "dedupe_same_canonical_event",
        "dedupe_same_grouped_burst",
        "class_muted_by_user",
        "class_snoozed_by_user",
        "release_pending_next_unsuppressed_surface"
      ],
      "description": "Re-exported from schemas/ux/notification_event.schema.json without modification."
    },
    "privacy_payload_class": {
      "type": "string",
      "enum": [
        "lock_screen_safe_generic",
        "lock_screen_safe_scoped",
        "in_product_only",
        "redacted_metadata_only",
        "policy_forbidden_on_lock_screen"
      ]
    },
    "dedupe_key_scheme": {
      "type": "string",
      "enum": [
        "canonical_event_id",
        "canonical_object_target_plus_event_class",
        "grouped_burst_id",
        "subsystem_plus_object_plus_phase",
        "cross_client_canonical_event_id"
      ]
    },
    "interruptibility_tier": {
      "type": "string",
      "enum": [
        "tier_ambient",
        "tier_transient",
        "tier_durable",
        "tier_actionable",
        "tier_blocking_trust",
        "tier_critical_safety"
      ]
    },
    "reopen_target_kind": {
      "type": "string",
      "enum": [
        "canonical_object",
        "canonical_route",
        "review_context",
        "durable_activity_row",
        "digest_group",
        "placeholder_announced",
        "denied_requires_revalidation"
      ],
      "description": "Re-exported from schemas/ux/notification_event.schema.json. Generic home-screen reopen is intentionally not a value."
    },
    "linkback_kind": {
      "type": "string",
      "enum": [
        "durable_job_row_exact",
        "attention_item_exact",
        "activity_center_item",
        "history_lane_row",
        "evidence_packet_row",
        "review_sheet",
        "diff_view",
        "canonical_object_target_exact",
        "export_preview_row",
        "audit_trail_only"
      ],
      "description": "Re-exported from schemas/ux/event_lineage.schema.json. Linkback kinds are a closed set; audit_trail_only is an explicit class, not a fallback."
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "$ref": "#/$defs/opaque_id" },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted"]
        },
        "execution_context_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "suppression_class": {
      "type": "string",
      "enum": [
        "held_quiet_hours_user_policy",
        "held_do_not_disturb_user_policy",
        "held_focus_mode_user_policy",
        "held_presentation_mode",
        "held_screen_share",
        "held_privacy_mode",
        "held_admin_suppression",
        "held_power_saver_runtime",
        "held_reduced_attention_policy",
        "delayed_release_pending_next_unsuppressed_surface",
        "collapsed_dedupe_same_canonical_event",
        "collapsed_dedupe_same_grouped_burst",
        "redacted_for_lock_screen",
        "redacted_for_companion_push",
        "redacted_for_system_notification",
        "denied_policy_forbidden_on_lock_screen",
        "denied_audit_trail_only"
      ],
      "description": "Why a notification was held, delayed, collapsed, redacted, or denied. One value per suppression record. The chosen class names the cause explicitly so an audit trail can be reviewed mechanically."
    },
    "suppression_outcome": {
      "type": "string",
      "enum": [
        "not_delivered_held",
        "not_delivered_collapsed",
        "not_delivered_audit_trail_only",
        "delivered_redacted",
        "delivered_in_product_only",
        "delivered_durable_only",
        "delivered_admin_narrowed_durable_only",
        "released_as_grouped_digest",
        "released_immediately_on_escalation",
        "released_via_user_explicit_show_held",
        "released_via_cross_client_collapse",
        "released_via_reopen_revalidation_completed"
      ],
      "description": "What actually happened to the suppressed delivery. A held envelope opens with a not_delivered_* outcome and may transition to a released_* outcome on mode exit, escalation, user-explicit show, cross-client collapse, or reopen-revalidation completion."
    },
    "release_trigger_class": {
      "type": "string",
      "enum": [
        "mode_exit_grouped_digest",
        "user_explicit_show_held",
        "escalation_to_critical_safety",
        "cross_client_collapse",
        "reopen_revalidation_completed",
        "no_release_audit_trail_only"
      ],
      "description": "Mirrors the release-step kinds named in docs/ux/notification_delivery_contract.md so a suppression record can carry the release rule that applies on mode exit (or note that the record is audit_trail_only)."
    },
    "delay_until_condition_class": {
      "type": "string",
      "enum": [
        "next_unsuppressed_surface",
        "mode_exit",
        "user_explicit_show_held",
        "lock_screen_unlock",
        "policy_epoch_advance",
        "trust_state_restored",
        "no_delay_collapsed_or_denied"
      ]
    },
    "forbidden_shortcut_action_class": {
      "type": "string",
      "enum": [
        "destructive_publish_or_apply",
        "secret_or_credential_reveal",
        "irreversible_high_blast",
        "bypass_review_sheet",
        "bypass_approval_workflow",
        "cross_workspace_mutation",
        "direct_mutation_from_lock_screen",
        "direct_mutation_from_companion_push",
        "direct_mutation_from_dock_or_taskbar",
        "direct_mutation_from_system_tray",
        "policy_override_from_os_shortcut",
        "trust_state_change_from_os_shortcut",
        "provider_grant_change_from_os_shortcut"
      ],
      "description": "Action classes that MUST NOT be completable from an OS notification action, lock-screen quick action, dock / taskbar shortcut, system-tray summary, or companion push action. A high-risk action that resolves to one of these classes MUST route through the in-product review sheet, approval workflow, or revalidation flow."
    },
    "allowed_label_kind": {
      "type": "string",
      "enum": [
        "category_label_only",
        "scoped_workspace_label",
        "scoped_session_label",
        "next_action_label",
        "summary_member_count_label",
        "privacy_redacted_placeholder",
        "actor_role_label",
        "severity_class_label",
        "lifecycle_phase_label",
        "audit_only_marker"
      ],
      "description": "What kinds of label text a privacy_payload_class permits on a lock-screen, companion, or system-notification surface. Raw object identity, raw paths, raw URLs, raw provider payloads, raw prompt or completion text, and raw secret material are never permitted."
    },
    "forbidden_label_kind": {
      "type": "string",
      "enum": [
        "raw_path",
        "raw_url",
        "raw_email",
        "raw_provider_payload",
        "raw_secret_material",
        "raw_prompt_text",
        "raw_completion_text",
        "raw_command_body",
        "customer_owned_identifier",
        "destructive_intent_phrase",
        "object_identity_on_lock_screen",
        "actor_real_name_on_lock_screen",
        "review_diff_excerpt_on_lock_screen"
      ]
    },
    "allowed_action_kind": {
      "type": "string",
      "enum": [
        "open_in_product",
        "open_review_context_in_product",
        "open_canonical_object_in_product",
        "open_durable_row_in_product",
        "open_digest_group_in_product",
        "open_attention_item_in_product",
        "snooze_until_unlocked",
        "snooze_until_resume_condition",
        "acknowledge_clears_badge_only",
        "dismiss_transient_only",
        "show_held_in_product"
      ],
      "description": "Closed set of actions a privacy-safe payload may surface as a shortcut. Every kind is read-only or transient-only with respect to the canonical object and routes the user back into the product surface that owns the underlying state."
    },
    "redaction_summary_template_token": {
      "type": "string",
      "enum": [
        "{category}",
        "{workspace_label}",
        "{session_label}",
        "{member_count}",
        "{actor_role}",
        "{severity_class}",
        "{lifecycle_phase}",
        "{audit_only_marker}"
      ],
      "description": "Closed set of substitution tokens a privacy-safe payload template may carry. Any token outside the set is non-conforming."
    },
    "preserved_durable_linkback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "target_identity_ref",
        "is_durable",
        "announcement_label",
        "preserves_canonical_event_id",
        "preserves_canonical_object_identity"
      ],
      "properties": {
        "kind": { "$ref": "#/$defs/linkback_kind" },
        "target_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "is_durable": { "type": "boolean" },
        "announcement_label": { "$ref": "#/$defs/short_label_text" },
        "preserves_canonical_event_id": {
          "type": "boolean",
          "const": true
        },
        "preserves_canonical_object_identity": {
          "type": "boolean",
          "const": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": { "const": "audit_trail_only" }
            },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "is_durable": { "const": false }
            },
            "required": ["is_durable"]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "not": { "const": "audit_trail_only" }
              }
            },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "is_durable": { "const": true }
            },
            "required": ["is_durable"]
          }
        }
      ]
    },
    "release_step_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_trigger_class",
        "released_to_delivery_surface_class",
        "released_with_privacy_payload_class",
        "occurred_at",
        "grouped_burst_id_ref",
        "member_count",
        "preserves_durable_history"
      ],
      "properties": {
        "release_trigger_class": { "$ref": "#/$defs/release_trigger_class" },
        "released_to_delivery_surface_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/delivery_surface_class" }
          ]
        },
        "released_with_privacy_payload_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/privacy_payload_class" }
          ]
        },
        "occurred_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "grouped_burst_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "member_count": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 1 }
          ]
        },
        "preserves_durable_history": {
          "type": "boolean",
          "const": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "release_trigger_class": { "const": "no_release_audit_trail_only" }
            },
            "required": ["release_trigger_class"]
          },
          "then": {
            "properties": {
              "released_to_delivery_surface_class": { "type": "null" },
              "released_with_privacy_payload_class": { "type": "null" },
              "grouped_burst_id_ref": { "type": "null" },
              "member_count": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "release_trigger_class": { "const": "mode_exit_grouped_digest" }
            },
            "required": ["release_trigger_class"]
          },
          "then": {
            "properties": {
              "grouped_burst_id_ref": { "$ref": "#/$defs/opaque_id" },
              "member_count": { "type": "integer", "minimum": 1 }
            },
            "required": ["grouped_burst_id_ref", "member_count"]
          }
        }
      ]
    },
    "bypass_protection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "must_route_through_review_sheet",
        "review_sheet_ref",
        "must_route_through_approval_workflow",
        "approval_workflow_ref",
        "requires_revalidation",
        "revalidation_reason_label",
        "interaction_safety_packet_id_ref"
      ],
      "properties": {
        "must_route_through_review_sheet": { "type": "boolean" },
        "review_sheet_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "must_route_through_approval_workflow": { "type": "boolean" },
        "approval_workflow_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "requires_revalidation": { "type": "boolean" },
        "revalidation_reason_label": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/short_label_text" }
          ]
        },
        "interaction_safety_packet_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "must_route_through_review_sheet": { "const": true } },
            "required": ["must_route_through_review_sheet"]
          },
          "then": {
            "properties": {
              "review_sheet_ref": { "$ref": "#/$defs/opaque_id" }
            },
            "required": ["review_sheet_ref"]
          }
        },
        {
          "if": {
            "properties": { "must_route_through_approval_workflow": { "const": true } },
            "required": ["must_route_through_approval_workflow"]
          },
          "then": {
            "properties": {
              "approval_workflow_ref": { "$ref": "#/$defs/opaque_id" }
            },
            "required": ["approval_workflow_ref"]
          }
        },
        {
          "if": {
            "properties": { "requires_revalidation": { "const": true } },
            "required": ["requires_revalidation"]
          },
          "then": {
            "properties": {
              "revalidation_reason_label": { "$ref": "#/$defs/short_label_text" }
            },
            "required": ["revalidation_reason_label"]
          }
        }
      ]
    },
    "privacy_redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applied_payload_class",
        "lock_screen_safe",
        "companion_safe",
        "system_notification_safe",
        "redacted_summary_label",
        "redaction_template_tokens",
        "stripped_label_kinds"
      ],
      "properties": {
        "applied_payload_class": { "$ref": "#/$defs/privacy_payload_class" },
        "lock_screen_safe": { "type": "boolean" },
        "companion_safe": { "type": "boolean" },
        "system_notification_safe": { "type": "boolean" },
        "redacted_summary_label": { "$ref": "#/$defs/short_label_text" },
        "redaction_template_tokens": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/redaction_summary_template_token" }
        },
        "stripped_label_kinds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/forbidden_label_kind" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "applied_payload_class": { "const": "policy_forbidden_on_lock_screen" }
            },
            "required": ["applied_payload_class"]
          },
          "then": {
            "properties": {
              "lock_screen_safe": { "const": false }
            },
            "required": ["lock_screen_safe"]
          }
        },
        {
          "if": {
            "properties": {
              "applied_payload_class": { "const": "in_product_only" }
            },
            "required": ["applied_payload_class"]
          },
          "then": {
            "properties": {
              "lock_screen_safe": { "const": false }
            },
            "required": ["lock_screen_safe"]
          }
        }
      ]
    },
    "exact_reopen_linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reopen_target_kind",
        "target_identity_ref",
        "canonical_route_ref",
        "review_context_ref",
        "command_id_ref",
        "returns_to_invoking_window",
        "preserves_canonical_event_id",
        "preserves_canonical_object_identity",
        "must_resolve_through_in_product_surface"
      ],
      "properties": {
        "reopen_target_kind": { "$ref": "#/$defs/reopen_target_kind" },
        "target_identity_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "canonical_route_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "review_context_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "command_id_ref": { "$ref": "#/$defs/opaque_id" },
        "returns_to_invoking_window": { "type": "boolean" },
        "preserves_canonical_event_id": {
          "type": "boolean",
          "const": true
        },
        "preserves_canonical_object_identity": {
          "type": "boolean",
          "const": true
        },
        "must_resolve_through_in_product_surface": {
          "type": "boolean",
          "const": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "reopen_target_kind": {
                "enum": [
                  "canonical_object",
                  "canonical_route",
                  "review_context",
                  "durable_activity_row",
                  "digest_group"
                ]
              }
            },
            "required": ["reopen_target_kind"]
          },
          "then": {
            "properties": {
              "target_identity_ref": { "$ref": "#/$defs/opaque_id" }
            },
            "required": ["target_identity_ref"]
          }
        }
      ]
    },
    "notification_suppression_record": {
      "type": "object",
