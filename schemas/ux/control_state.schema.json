{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/control_state.schema.json",
  "title": "Aureline core-control state boundary",
  "description": "Boundary schema for one control_state_record frozen in docs/ux/control_family_contract.md. A record captures one reusable control's family, role, size, density, focus, actionability, disabled / locked / read-only / loading / pending / destructive posture, value-source semantics, labels, helper text, inline validation, source labels, clear / reveal / split-button affordances, async feedback, live-vs-staged apply timing, optimistic-update posture, keyboard behavior, accessibility announcements, and support handoff. Raw secrets, raw policy bodies, raw provider payloads, raw hostnames, raw URLs, raw filesystem paths, raw prompts, raw command payloads, and private tenant identifiers never cross this boundary; records carry opaque refs, class labels, and reviewable summaries only. Adding an enum value is additive-minor and bumps control_state_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "$ref": "#/$defs/control_state_record",
  "$defs": {
    "control_state_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "control_state_record"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_ref": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/ref" }
      ]
    },
    "nullable_sentence": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/reviewable_sentence" }
      ]
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$",
      "description": "Stable opaque id safe for logs, RPC, support bundles, CLI JSON, and issue handoff."
    },
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 760
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "settings",
        "onboarding",
        "install_review",
        "admin_policy",
        "package_review",
        "migration_import",
        "connection_setup",
        "request_runtime",
        "editor",
        "command_surface",
        "generic_form"
      ]
    },
    "control_family_class": {
      "type": "string",
      "enum": [
        "button",
        "icon_button",
        "split_button",
        "checkbox",
        "radio",
        "toggle",
        "text_input",
        "select",
        "combobox",
        "segmented_control",
        "form_submit_action",
        "form_review_action"
      ]
    },
    "control_role_class": {
      "type": "string",
      "enum": [
        "primary_action",
        "secondary_action",
        "destructive_action",
        "inline_action",
        "source_inspection",
        "boolean_value",
        "single_choice_value",
        "text_value",
        "select_value",
        "mode_switch",
        "form_apply",
        "form_revert",
        "review_open",
        "review_submit"
      ]
    },
    "size_class": {
      "type": "string",
      "enum": ["small", "medium", "large"]
    },
    "density_class": {
      "type": "string",
      "enum": ["compact", "standard", "comfortable"]
    },
    "component_taxonomy_state_class": {
      "type": "string",
      "enum": [
        "default",
        "hover",
        "focus_visible",
        "pressed_active",
        "selected",
        "current",
        "disabled",
        "read_only",
        "loading",
        "pending",
        "warning_error",
        "locked",
        "degraded"
      ]
    },
    "actionability_class": {
      "type": "string",
      "enum": [
        "enabled",
        "disabled_no_valid_action",
        "read_only_inspectable",
        "locked_policy_or_managed",
        "locked_permission_or_trust",
        "busy_temporarily_blocked",
        "pending_validation_blocked",
        "preview_required",
        "review_required",
        "destructive_confirmation_required"
      ]
    },
    "focus_state_class": {
      "type": "string",
      "enum": ["not_focused", "focus_visible", "focus_inactive"]
    },
    "destructive_state_class": {
      "type": "string",
      "enum": [
        "not_destructive",
        "destructive_local_reversible",
        "destructive_external_or_irreversible",
        "destructive_requires_review"
      ]
    },
    "lock_state_class": {
      "type": "string",
      "enum": [
        "unlocked",
        "policy_locked",
        "managed_locked",
        "permission_locked",
        "trust_locked",
        "source_locked",
        "capability_locked"
      ]
    },
    "source_value_state_class": {
      "type": "string",
      "enum": [
        "not_value_control",
        "default_value",
        "detected_value",
        "imported_value",
        "user_value",
        "policy_value",
        "staged_value",
        "live_value"
      ]
    },
    "disabled_reason_class": {
      "type": "string",
      "enum": [
        "none",
        "no_valid_action",
        "policy_blocked",
        "dependency_missing",
        "degraded_index",
        "wrong_target",
        "read_only",
        "host_unavailable",
        "unsupported_current_mode",
        "quota_or_budget_exhausted",
        "preview_only",
        "stale_context"
      ]
    },
    "label_role_class": {
      "type": "string",
      "enum": [
        "verb_first_action",
        "noun_phrase_field",
        "boolean_statement",
        "option_label",
        "segmented_mode_label",
        "review_action_label"
      ]
    },
    "helper_text_class": {
      "type": "string",
      "enum": [
        "none",
        "inline_help",
        "validation_message",
        "source_explanation",
        "policy_explanation",
        "async_feedback",
        "review_scope_summary"
      ]
    },
    "validation_state_class": {
      "type": "string",
      "enum": [
        "none",
        "pristine",
        "valid",
        "warning",
        "invalid",
        "blocking",
        "pending",
        "stale",
        "policy_blocked"
      ]
    },
    "source_label_state_class": {
      "type": "string",
      "enum": [
        "hidden_not_applicable",
        "visible_default",
        "visible_detected",
        "visible_imported",
        "visible_policy",
        "visible_external_provider",
        "visible_managed"
      ]
    },
    "clear_affordance_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "available_when_value_present",
        "disabled_with_reason",
        "forbidden_by_policy"
      ]
    },
    "reveal_affordance_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "available_with_friction",
        "hold_to_reveal",
        "disabled_by_policy",
        "forbidden_for_secret"
      ]
    },
    "split_button_default_action_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "clear_safe_default",
        "default_requires_preview",
        "default_disabled_until_context",
        "no_default_forbidden"
      ]
    },
    "async_state_class": {
      "type": "string",
      "enum": [
        "not_async",
        "loading_context",
        "validating",
        "submitted_busy",
        "queued",
        "running_local",
        "running_remote",
        "running_provider",
        "waiting_for_review",
        "completed",
        "failed"
      ]
    },
    "progress_indicator_class": {
      "type": "string",
      "enum": [
        "none",
        "spinner",
        "labeled_spinner",
        "progress_bar",
        "status_text"
      ]
    },
    "boundary_crossing_class": {
      "type": "string",
      "enum": [
        "local_only",
        "local_workspace",
        "remote_host",
        "provider_backed",
        "managed_admin",
        "external_network"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": ["not_applicable", "pending", "current", "stale", "unknown"]
    },
    "apply_timing_class": {
      "type": "string",
      "enum": [
        "immediate_live_apply",
        "staged_apply_required",
        "preview_first_apply_required",
        "dry_run_then_apply",
        "policy_locked_no_apply",
        "observe_only_no_apply"
      ]
    },
    "optimistic_update_policy_class": {
      "type": "string",
      "enum": [
        "allowed_local_reversible",
        "allowed_after_local_validation",
        "denied_requires_staging",
        "denied_requires_preview",
        "denied_policy_locked",
        "denied_destructive_or_external",
        "not_applicable"
      ]
    },
    "mutation_scope_class": {
      "type": "string",
      "enum": [
        "no_mutation",
        "local_view_only",
        "local_workspace",
        "user_profile",
        "remote_host",
        "provider_backed",
        "managed_admin",
        "external_irreversible"
      ]
    },
    "tab_stop_class": {
      "type": "string",
      "enum": [
        "focusable",
        "roving_tabindex",
        "focus_delegates_to_input",
        "not_focusable_explained"
      ]
    },
    "key_class": {
      "type": "string",
      "enum": [
        "Enter",
        "Space",
        "ArrowUp",
        "ArrowDown",
        "ArrowLeft",
        "ArrowRight",
        "Home",
        "End",
        "Escape",
        "Tab",
        "ShiftTab",
        "PrintableText"
      ]
    },
    "escape_behavior_class": {
      "type": "string",
      "enum": [
        "no_effect",
        "clears_value",
        "closes_menu",
        "cancels_pending",
        "returns_focus"
      ]
    },
    "enter_behavior_class": {
      "type": "string",
      "enum": [
        "activates_control",
        "submits_form",
        "opens_menu",
        "commits_option",
        "inserts_newline",
        "no_effect"
      ]
    },
    "aria_role_class": {
      "type": "string",
      "enum": [
        "button",
        "checkbox",
        "radio",
        "switch",
        "textbox",
        "combobox",
        "listbox",
        "tab",
        "menuitem",
        "form"
      ]
    },
    "extension_contract_posture_class": {
      "type": "string",
      "enum": [
        "host_owned",
        "must_match",
        "may_narrow_with_disclosure",
        "handoff_only"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe",
        "class_label_only",
        "secret_handle_only",
        "support_restricted"
      ]
    },
    "reserved_semantic_class": {
      "type": "string",
      "enum": [
        "disabled",
        "locked",
        "busy",
        "pending_validation",
        "destructive",
        "staged",
        "default_value",
        "detected_value",
        "imported_value",
        "live_value"
      ]
    },
    "size_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "size_class",
        "visual_height_px",
        "min_hit_target_px",
        "horizontal_padding_token_ref",
        "preserves_label_width_while_busy"
      ],
      "properties": {
        "size_class": { "$ref": "#/$defs/size_class" },
        "visual_height_px": {
          "type": "integer",
          "enum": [24, 28, 32]
        },
        "min_hit_target_px": {
          "type": "integer",
          "minimum": 28
        },
        "horizontal_padding_token_ref": { "$ref": "#/$defs/ref" },
        "preserves_label_width_while_busy": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "size_class": { "const": "small" } }, "required": ["size_class"] },
          "then": { "properties": { "visual_height_px": { "const": 24 } } }
        },
        {
          "if": { "properties": { "size_class": { "const": "medium" } }, "required": ["size_class"] },
          "then": { "properties": { "visual_height_px": { "const": 28 } } }
        },
        {
          "if": { "properties": { "size_class": { "const": "large" } }, "required": ["size_class"] },
          "then": { "properties": { "visual_height_px": { "const": 32 } } }
        }
      ]
    },
    "state_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_state_refs",
        "actionability_class",
        "focus_state_class",
        "destructive_state_class",
        "lock_state_class",
        "source_value_state_class",
        "disabled_reason_class",
        "explanation_ref",
        "source_ref",
        "state_summary"
      ],
      "properties": {
        "component_state_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/component_taxonomy_state_class" },
          "uniqueItems": true
        },
        "actionability_class": { "$ref": "#/$defs/actionability_class" },
        "focus_state_class": { "$ref": "#/$defs/focus_state_class" },
        "destructive_state_class": { "$ref": "#/$defs/destructive_state_class" },
        "lock_state_class": { "$ref": "#/$defs/lock_state_class" },
        "source_value_state_class": { "$ref": "#/$defs/source_value_state_class" },
        "disabled_reason_class": { "$ref": "#/$defs/disabled_reason_class" },
        "explanation_ref": { "$ref": "#/$defs/nullable_ref" },
        "source_ref": { "$ref": "#/$defs/nullable_ref" },
        "state_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "inline_validation_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validation_state_class",
        "message",
        "anchor_ref",
        "focuses_exact_blocked_value"
      ],
      "properties": {
        "validation_state_class": { "$ref": "#/$defs/validation_state_class" },
        "message": { "$ref": "#/$defs/nullable_sentence" },
        "anchor_ref": { "$ref": "#/$defs/nullable_ref" },
        "focuses_exact_blocked_value": { "type": "boolean" }
      }
    },
    "source_label_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_label_state_class",
        "source_label_text",
        "source_ref",
        "inspector_action_ref"
      ],
      "properties": {
        "source_label_state_class": { "$ref": "#/$defs/source_label_state_class" },
        "source_label_text": { "$ref": "#/$defs/nullable_sentence" },
        "source_ref": { "$ref": "#/$defs/nullable_ref" },
        "inspector_action_ref": { "$ref": "#/$defs/nullable_ref" }
      }
    },
    "affordances_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clear_affordance_class",
        "reveal_affordance_class",
        "split_button_default_action_class",
        "helper_action_ref",
        "clear_action_ref",
        "reveal_action_ref",
        "secondary_menu_ref"
      ],
      "properties": {
        "clear_affordance_class": { "$ref": "#/$defs/clear_affordance_class" },
        "reveal_affordance_class": { "$ref": "#/$defs/reveal_affordance_class" },
        "split_button_default_action_class": { "$ref": "#/$defs/split_button_default_action_class" },
        "helper_action_ref": { "$ref": "#/$defs/nullable_ref" },
        "clear_action_ref": { "$ref": "#/$defs/nullable_ref" },
        "reveal_action_ref": { "$ref": "#/$defs/nullable_ref" },
        "secondary_menu_ref": { "$ref": "#/$defs/nullable_ref" }
      }
    },
    "content_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "visible_label",
        "label_role_class",
        "canonical_label_ref",
        "helper_text_class",
        "helper_text",
        "inline_validation",
        "source_label",
        "affordances"
      ],
      "properties": {
        "visible_label": { "$ref": "#/$defs/non_empty_string" },
        "label_role_class": { "$ref": "#/$defs/label_role_class" },
        "canonical_label_ref": { "$ref": "#/$defs/ref" },
        "helper_text_class": { "$ref": "#/$defs/helper_text_class" },
        "helper_text": { "$ref": "#/$defs/nullable_sentence" },
        "inline_validation": { "$ref": "#/$defs/inline_validation_block" },
        "source_label": { "$ref": "#/$defs/source_label_block" },
        "affordances": { "$ref": "#/$defs/affordances_block" }
      }
    },
    "async_feedback_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "async_state_class",
        "busy_blocks_activation",
        "pending_validation_disclosed",
        "work_label",
        "progress_indicator_class",
        "cancellation_action_ref",
        "retry_action_ref",
        "boundary_crossing_class",
        "boundary_disclosure_required",
        "freshness_class",
        "result_summary"
      ],
      "properties": {
        "async_state_class": { "$ref": "#/$defs/async_state_class" },
        "busy_blocks_activation": { "type": "boolean" },
        "pending_validation_disclosed": { "type": "boolean" },
        "work_label": { "$ref": "#/$defs/nullable_sentence" },
        "progress_indicator_class": { "$ref": "#/$defs/progress_indicator_class" },
        "cancellation_action_ref": { "$ref": "#/$defs/nullable_ref" },
        "retry_action_ref": { "$ref": "#/$defs/nullable_ref" },
        "boundary_crossing_class": { "$ref": "#/$defs/boundary_crossing_class" },
        "boundary_disclosure_required": { "type": "boolean" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "result_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "apply_model_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "apply_timing_class",
        "optimistic_update_policy_class",
        "review_surface_required",
        "review_surface_ref",
        "command_id_ref",
        "mutation_scope_class",
        "side_effect_summary"
      ],
      "properties": {
        "apply_timing_class": { "$ref": "#/$defs/apply_timing_class" },
        "optimistic_update_policy_class": { "$ref": "#/$defs/optimistic_update_policy_class" },
        "review_surface_required": { "type": "boolean" },
        "review_surface_ref": { "$ref": "#/$defs/nullable_ref" },
        "command_id_ref": { "$ref": "#/$defs/nullable_ref" },
        "mutation_scope_class": { "$ref": "#/$defs/mutation_scope_class" },
        "side_effect_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "keyboard_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tab_stop_class",
        "focus_visible_required",
        "activation_keys",
        "navigation_keys",
        "escape_behavior_class",
        "enter_behavior_class",
        "aria_role_class",
        "keyboard_summary"
      ],
      "properties": {
        "tab_stop_class": { "$ref": "#/$defs/tab_stop_class" },
        "focus_visible_required": { "type": "boolean", "const": true },
        "activation_keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/key_class" },
          "uniqueItems": true
        },
        "navigation_keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/key_class" },
          "uniqueItems": true
        },
        "escape_behavior_class": { "$ref": "#/$defs/escape_behavior_class" },
        "enter_behavior_class": { "$ref": "#/$defs/enter_behavior_class" },
        "aria_role_class": { "$ref": "#/$defs/aria_role_class" },
        "keyboard_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "accessibility_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accessible_name",
        "accessible_description",
        "announces_state_changes",
        "announces_busy",
        "announces_source",
        "announces_validation",
        "focus_return_ref"
      ],
      "properties": {
        "accessible_name": { "$ref": "#/$defs/non_empty_string" },
        "accessible_description": { "$ref": "#/$defs/nullable_sentence" },
        "announces_state_changes": { "type": "boolean" },
        "announces_busy": { "type": "boolean" },
        "announces_source": { "type": "boolean" },
        "announces_validation": { "type": "boolean" },
        "focus_return_ref": { "$ref": "#/$defs/nullable_ref" }
      }
    },
    "extension_semantics_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_specific_packets_may_extend",
        "family_specific_packets_may_redefine_core_semantics",
        "reserved_semantics"
      ],
      "properties": {
        "family_specific_packets_may_extend": { "type": "boolean", "const": true },
        "family_specific_packets_may_redefine_core_semantics": { "type": "boolean", "const": false },
        "reserved_semantics": {
          "type": "array",
          "minItems": 10,
          "items": { "$ref": "#/$defs/reserved_semantic_class" },
          "uniqueItems": true
        }
      }
    },
    "support_handoff_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_refs",
        "docs_help_anchor_refs",
        "extension_contract_posture_class",
        "raw_payload_excluded",
        "redaction_class"
      ],
      "properties": {
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/ref" },
          "uniqueItems": true
        },
        "docs_help_anchor_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/ref" },
          "uniqueItems": true
        },
        "extension_contract_posture_class": { "$ref": "#/$defs/extension_contract_posture_class" },
        "raw_payload_excluded": { "type": "boolean", "const": true },
        "redaction_class": { "$ref": "#/$defs/redaction_class" }
      }
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario", "exercised_axes"],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/reviewable_sentence" },
        "exercised_axes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        }
      }
    },
    "control_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_state_schema_version",
        "record_kind",
        "control_state_id",
        "surface_family",
        "control_family_class",
        "control_role_class",
        "size",
        "density_class",
        "state",
        "content",
        "async_feedback",
        "apply_model",
        "keyboard",
        "accessibility",
        "extension_semantics",
        "support_handoff",
        "emitted_at",
        "narrative_refs"
      ],
      "properties": {
        "control_state_schema_version": { "$ref": "#/$defs/control_state_schema_version" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "control_state_id": { "$ref": "#/$defs/opaque_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "control_family_class": { "$ref": "#/$defs/control_family_class" },
        "control_role_class": { "$ref": "#/$defs/control_role_class" },
        "size": { "$ref": "#/$defs/size_block" },
        "density_class": { "$ref": "#/$defs/density_class" },
        "state": { "$ref": "#/$defs/state_block" },
        "content": { "$ref": "#/$defs/content_block" },
        "async_feedback": { "$ref": "#/$defs/async_feedback_block" },
        "apply_model": { "$ref": "#/$defs/apply_model_block" },
        "keyboard": { "$ref": "#/$defs/keyboard_block" },
        "accessibility": { "$ref": "#/$defs/accessibility_block" },
        "extension_semantics": { "$ref": "#/$defs/extension_semantics_block" },
        "support_handoff": { "$ref": "#/$defs/support_handoff_block" },
        "emitted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "narrative_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ref" },
          "uniqueItems": true
        },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "properties": { "actionability_class": { "const": "disabled_no_valid_action" } },
                "required": ["actionability_class"]
              }
            },
            "required": ["state"]
          },
          "then": {
            "properties": {
              "state": {
                "properties": {
                  "component_state_refs": { "contains": { "const": "disabled" } },
                  "lock_state_class": { "const": "unlocked" }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "properties": {
                  "actionability_class": {
                    "enum": ["locked_policy_or_managed", "locked_permission_or_trust"]
                  }
                },
                "required": ["actionability_class"]
              }
            },
            "required": ["state"]
          },
          "then": {
            "properties": {
              "state": {
                "properties": {
                  "component_state_refs": { "contains": { "const": "locked" } },
                  "lock_state_class": {
                    "not": { "const": "unlocked" }
                  },
                  "explanation_ref": { "$ref": "#/$defs/ref" },
                  "source_ref": { "$ref": "#/$defs/ref" }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "async_feedback": {
                "properties": { "async_state_class": { "const": "loading_context" } },
                "required": ["async_state_class"]
              }
            },
            "required": ["async_feedback"]
          },
          "then": {
            "properties": {
              "state": {
                "properties": {
                  "component_state_refs": { "contains": { "const": "loading" } }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "async_feedback": {
                "properties": {
                  "async_state_class": {
                    "enum": [
                      "validating",
                      "submitted_busy",
                      "queued",
                      "running_local",
                      "running_remote",
                      "running_provider",
                      "waiting_for_review"
                    ]
                  }
                },
                "required": ["async_state_class"]
              }
            },
            "required": ["async_feedback"]
          },
          "then": {
            "properties": {
              "state": {
                "properties": {
                  "component_state_refs": { "contains": { "const": "pending" } }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "apply_model": {
                "properties": {
                  "apply_timing_class": {
                    "enum": ["preview_first_apply_required", "dry_run_then_apply"]
                  }
                },
                "required": ["apply_timing_class"]
              }
            },
            "required": ["apply_model"]
          },
          "then": {
            "properties": {
              "apply_model": {
                "properties": {
                  "review_surface_required": { "const": true },
                  "review_surface_ref": { "$ref": "#/$defs/ref" },
                  "optimistic_update_policy_class": {
                    "enum": ["denied_requires_preview", "denied_destructive_or_external"]
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "apply_model": {
                "properties": { "apply_timing_class": { "const": "policy_locked_no_apply" } },
                "required": ["apply_timing_class"]
              }
            },
            "required": ["apply_model"]
          },
          "then": {
            "properties": {
              "apply_model": {
                "properties": {
                  "optimistic_update_policy_class": { "const": "denied_policy_locked" },
                  "review_surface_required": { "const": false }
                }
              },
              "state": {
                "properties": {
                  "component_state_refs": { "contains": { "const": "locked" } },
                  "lock_state_class": {
                    "enum": ["policy_locked", "managed_locked"]
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "control_family_class": { "const": "split_button" }
            },
            "required": ["control_family_class"]
          },
          "then": {
            "properties": {
              "content": {
                "properties": {
                  "affordances": {
                    "properties": {
                      "split_button_default_action_class": {
                        "not": { "const": "not_applicable" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
