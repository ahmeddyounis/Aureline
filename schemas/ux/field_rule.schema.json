{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/field_rule.schema.json",
  "title": "Aureline high-risk field-rule boundary",
  "description": "Boundary schema for one field_rule_record frozen in docs/ux/field_rules_contract.md. A field-rule record captures the UI, validation, review, evaluation-context, redaction, copy/export, paste/drop, duplicate, normalization, and authority-disclosure behavior for high-risk fields. It is shared by settings, request workspaces, package-manager auth, notebook kernels, transport configuration, repair flows, support exports, and future inspectors. Raw secrets, raw delegated tokens, private keys, raw certificate material, raw request bodies, raw auth headers, raw registry credentials, raw proxy credentials, raw provider payloads, raw URLs with sensitive components, and raw filesystem paths that policy marks sensitive do not cross this boundary; use refs, class labels, fingerprints, summaries, and redaction reports. Adding an enum value is additive-minor and bumps field_rule_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "$ref": "#/$defs/field_rule_record",
  "$defs": {
    "field_rule_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "field_rule_record"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$",
      "description": "Stable opaque id safe for logs, RPC, support bundles, and issue handoff."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 760
    },
    "field_rule_class": {
      "type": "string",
      "enum": [
        "secret_handle_field",
        "raw_secret_input",
        "filesystem_path_ref",
        "uri_endpoint",
        "code_backed_expression",
        "command_template",
        "environment_ref",
        "certificate_ref",
        "provider_resource_identifier"
      ]
    },
    "risk_class": {
      "type": "string",
      "enum": [
        "secret_bearing",
        "raw_secret_exposure",
        "filesystem_authority",
        "network_target",
        "evaluated_code",
        "shell_execution",
        "environment_resolution",
        "trust_material",
        "external_resource_identity"
      ]
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "settings_form",
        "request_workspace",
        "package_manager_auth",
        "notebook_kernel",
        "network_transport_form",
        "repair_flow",
        "support_export",
        "data_connection_form",
        "template_scaffold_form",
        "runtime_target_form",
        "generic_high_impact_form"
      ]
    },
    "field_display_class": {
      "type": "string",
      "enum": [
        "single_value",
        "multi_value_list",
        "key_value_map",
        "structured_fragment",
        "attachment_or_drop_target"
      ]
    },
    "field_value_shape_class": {
      "type": "string",
      "enum": [
        "secret_handle_ref",
        "raw_secret_literal",
        "generic_path_ref",
        "file_ref",
        "folder_ref",
        "archive_inner_path_ref",
        "uri_ref",
        "endpoint_ref",
        "code_fragment",
        "json_fragment",
        "yaml_fragment",
        "command_template",
        "environment_key",
        "certificate_binding",
        "provider_resource_ref",
        "multi_value_list",
        "key_value_map"
      ],
      "description": "Shape axis that keeps path/file/folder, code/JSON/YAML, endpoint, key/value, and multi-value surfaces reusable without collapsing into generic text inputs."
    },
    "storage_class": {
      "type": "string",
      "enum": [
        "handle_ref_only",
        "session_memory_only",
        "literal_session_entry",
        "path_locator_ref",
        "endpoint_locator_ref",
        "expression_source_ref",
        "command_template_ref",
        "environment_key_ref",
        "certificate_binding_ref",
        "provider_resource_ref"
      ]
    },
    "display_redaction_class": {
      "type": "string",
      "enum": [
        "not_secret",
        "masked_value",
        "class_label_only",
        "secret_handle_only",
        "redacted_summary",
        "metadata_only"
      ]
    },
    "copy_posture": {
      "type": "string",
      "enum": [
        "copy_disabled",
        "copy_redacted_summary",
        "copy_handle_alias",
        "copy_literal_with_review",
        "copy_path_with_basis",
        "copy_endpoint_summary",
        "copy_metadata_only"
      ]
    },
    "review_affordance_class": {
      "type": "string",
      "enum": [
        "storage_mode_label",
        "reveal_friction",
        "basis_disclosure",
        "preview_diff",
        "dry_run_preview",
        "unsafe_warning",
        "policy_explanation",
        "scope_authority_disclosure",
        "duplicate_resolution",
        "lossy_normalization_warning",
        "raw_source_inspection",
        "redaction_preview"
      ]
    },
    "resolver_actor_class": {
      "type": "string",
      "enum": [
        "user_local",
        "desktop_client",
        "remote_agent",
        "managed_control_plane",
        "notebook_kernel",
        "request_runtime",
        "package_adapter",
        "transport_resolver",
        "repair_supervisor",
        "support_exporter",
        "unknown_requires_review"
      ]
    },
    "execution_location_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "local_client",
        "workspace_host",
        "remote_target",
        "managed_workspace",
        "notebook_kernel_runtime",
        "request_runtime",
        "package_manager_process",
        "repair_supervisor",
        "support_export_assembler"
      ]
    },
    "basis_field": {
      "type": "string",
      "enum": [
        "workspace_root",
        "containing_file",
        "active_profile",
        "environment_layer",
        "policy_epoch",
        "selected_target",
        "current_working_directory",
        "kernel_identity",
        "request_environment",
        "package_manifest_scope",
        "certificate_store",
        "provider_account",
        "support_bundle_scope"
      ]
    },
    "resolution_time_class": {
      "type": "string",
      "enum": [
        "edit_time",
        "review_time",
        "apply_time",
        "run_time",
        "export_time",
        "deferred_until_use",
        "not_applicable"
      ]
    },
    "validation_class": {
      "type": "string",
      "enum": [
        "local_syntax",
        "schema",
        "local_capability",
        "secret_resolution",
        "external_probe",
        "remote_auth",
        "policy",
        "dry_run",
        "dependency_graph",
        "target_discovery"
      ]
    },
    "validation_timing_class": {
      "type": "string",
      "enum": [
        "sync_non_mutating",
        "async_non_mutating",
        "dry_run_non_mutating",
        "preview_required",
        "mutating_validation_forbidden"
      ]
    },
    "stale_behavior_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "block_until_current",
        "allow_with_stale_ack",
        "allow_when_skipped_with_reason",
        "observe_only"
      ]
    },
    "unsafe_value_warning_trigger": {
      "type": "string",
      "enum": [
        "raw_secret_literal_detected",
        "plaintext_export_attempt",
        "missing_relative_path_basis",
        "path_escape_or_symlink_alias",
        "path_not_reachable_in_target_context",
        "endpoint_retarget_or_origin_change",
        "code_evaluates_with_workspace_authority",
        "command_shell_interpolation",
        "env_ref_unresolved_or_shadowed",
        "certificate_expired_or_untrusted",
        "provider_resource_ambiguous",
        "duplicate_value_collision",
        "lossy_normalization_detected",
        "bulk_paste_requires_review",
        "drag_drop_requires_target_disclosure",
        "policy_narrows_authority"
      ]
    },
    "default_export_class": {
      "type": "string",
      "enum": [
        "excluded",
        "metadata_only",
        "handle_ref_only",
        "redacted_summary",
        "ref_with_fingerprint",
        "path_with_basis",
        "endpoint_summary",
        "structured_safe_value"
      ]
    },
    "elevated_export_class": {
      "type": "string",
      "enum": [
        "none",
        "explicit_user_review",
        "admin_policy_required",
        "support_case_required",
        "local_only_export"
      ]
    },
    "export_metadata_field": {
      "type": "string",
      "enum": [
        "field_rule_class",
        "field_label",
        "source_class",
        "storage_mode",
        "evaluation_context",
        "risk_class",
        "freshness",
        "redaction_report",
        "omitted_value_reason",
        "authority_scope",
        "fingerprint",
        "path_basis",
        "duplicate_policy",
        "normalization_report"
      ]
    },
    "duplicate_handling_class": {
      "type": "string",
      "enum": [
        "reject_duplicates",
        "preserve_order_with_duplicate_warning",
        "merge_by_stable_id",
        "last_value_wins_requires_review",
        "not_applicable"
      ]
    },
    "lossy_normalization_policy": {
      "type": "string",
      "enum": [
        "block",
        "warn_and_preserve_raw_ref",
        "warn_and_apply_canonical_form",
        "allowed_no_warning",
        "not_applicable"
      ]
    },
    "relative_path_basis_policy": {
      "type": "string",
      "enum": [
        "not_applicable",
        "workspace_root_required",
        "containing_file_required",
        "selected_target_required",
        "user_chosen_basis_required",
        "reject_relative_paths"
      ]
    },
    "review_surface_class": {
      "type": "string",
      "enum": [
        "inline_section",
        "side_sheet",
        "full_sheet",
        "modal_dialog",
        "cli_json_summary",
        "headless_summary",
        "support_packet_projection"
      ]
    },
    "scope_authority_field": {
      "type": "string",
      "enum": [
        "actor",
        "target",
        "workspace_root",
        "remote_host",
        "account_or_tenant",
        "policy_source",
        "credential_scope",
        "execution_location",
        "export_destination"
      ]
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name",
        "scenario"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/reviewable_sentence" },
        "exercised_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        }
      }
    },
    "value_representation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "storage_class",
        "display_redaction_class",
        "raw_value_allowed_at_rest",
        "raw_value_allowed_in_export",
        "copy_posture"
      ],
      "properties": {
        "storage_class": { "$ref": "#/$defs/storage_class" },
        "display_redaction_class": { "$ref": "#/$defs/display_redaction_class" },
        "raw_value_allowed_at_rest": { "type": "boolean" },
        "raw_value_allowed_in_export": { "type": "boolean" },
        "copy_posture": { "$ref": "#/$defs/copy_posture" },
        "value_ref": { "$ref": "#/$defs/opaque_id" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "evaluation_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_required_before_apply",
        "unsafe_when_missing_context",
        "resolver_actor_class",
        "execution_location_class",
        "resolution_time_class",
        "basis_fields"
      ],
      "properties": {
        "context_required_before_apply": { "type": "boolean" },
        "unsafe_when_missing_context": { "type": "boolean" },
        "resolver_actor_class": { "$ref": "#/$defs/resolver_actor_class" },
        "execution_location_class": { "$ref": "#/$defs/execution_location_class" },
        "resolution_time_class": { "$ref": "#/$defs/resolution_time_class" },
        "basis_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/basis_field" },
          "uniqueItems": true
        },
        "context_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "validation_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validation_class",
        "validation_timing_class",
        "required_for_apply",
        "stale_behavior",
        "hook_summary"
      ],
      "properties": {
        "validation_class": { "$ref": "#/$defs/validation_class" },
        "validation_timing_class": { "$ref": "#/$defs/validation_timing_class" },
        "required_for_apply": { "type": "boolean" },
        "stale_behavior": { "$ref": "#/$defs/stale_behavior_class" },
        "hook_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "export_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_export_class",
        "elevated_export_class",
        "never_export_raw_secret",
        "downgrade_requires_class_change",
        "included_metadata"
      ],
      "properties": {
        "default_export_class": { "$ref": "#/$defs/default_export_class" },
        "elevated_export_class": { "$ref": "#/$defs/elevated_export_class" },
        "never_export_raw_secret": { "type": "boolean" },
        "downgrade_requires_class_change": { "type": "boolean" },
        "included_metadata": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/export_metadata_field" },
          "uniqueItems": true
        },
        "export_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "multi_value_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supports_bulk_paste",
        "supports_drag_drop",
        "duplicate_handling",
        "lossy_normalization_policy",
        "relative_path_basis_policy"
      ],
      "properties": {
        "supports_bulk_paste": { "type": "boolean" },
        "supports_drag_drop": { "type": "boolean" },
        "duplicate_handling": { "$ref": "#/$defs/duplicate_handling_class" },
        "lossy_normalization_policy": { "$ref": "#/$defs/lossy_normalization_policy" },
        "relative_path_basis_policy": { "$ref": "#/$defs/relative_path_basis_policy" },
        "multi_value_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "unsafe_value_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_before_apply",
        "review_surface_class",
        "scope_authority_fields"
      ],
      "properties": {
        "required_before_apply": { "type": "boolean" },
        "review_surface_class": { "$ref": "#/$defs/review_surface_class" },
        "scope_authority_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/scope_authority_field" },
          "uniqueItems": true
        },
        "review_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "field_rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "field_rule_id",
        "field_rule_class",
        "risk_class",
        "surface_families",
        "field_display_class",
        "value_shape_classes",
        "field_label",
        "value_representation",
        "review_affordances",
        "evaluation_context",
        "validation_hooks",
        "unsafe_value_warnings",
        "export_policy",
        "multi_value_policy",
        "unsafe_value_review",
        "narrative_refs",
        "emitted_at"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/field_rule_schema_version" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "field_rule_id": { "$ref": "#/$defs/opaque_id" },
        "field_rule_class": { "$ref": "#/$defs/field_rule_class" },
        "risk_class": { "$ref": "#/$defs/risk_class" },
        "surface_families": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_family" },
          "uniqueItems": true
        },
        "field_display_class": { "$ref": "#/$defs/field_display_class" },
        "value_shape_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field_value_shape_class" },
          "uniqueItems": true
        },
        "field_label": { "$ref": "#/$defs/non_empty_string" },
        "value_representation": { "$ref": "#/$defs/value_representation" },
        "review_affordances": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/review_affordance_class" },
          "uniqueItems": true
        },
        "evaluation_context": { "$ref": "#/$defs/evaluation_context" },
        "validation_hooks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/validation_hook" }
        },
        "unsafe_value_warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/unsafe_value_warning_trigger" },
          "uniqueItems": true
        },
        "export_policy": { "$ref": "#/$defs/export_policy" },
        "multi_value_policy": { "$ref": "#/$defs/multi_value_policy" },
        "unsafe_value_review": { "$ref": "#/$defs/unsafe_value_review" },
        "narrative_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "emitted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" }
      },
      "allOf": [
        {
          "description": "Secret-bearing fields must not permit raw value export or downgrade to plaintext export.",
          "if": {
            "properties": {
              "field_rule_class": {
                "enum": [
                  "secret_handle_field",
                  "raw_secret_input"
                ]
              }
            },
            "required": ["field_rule_class"]
          },
          "then": {
            "properties": {
              "value_representation": {
                "properties": {
                  "raw_value_allowed_in_export": { "const": false }
                },
                "required": ["raw_value_allowed_in_export"]
              },
              "export_policy": {
                "properties": {
                  "never_export_raw_secret": { "const": true },
                  "downgrade_requires_class_change": { "const": true }
                },
                "required": [
                  "never_export_raw_secret",
                  "downgrade_requires_class_change"
                ]
              }
            }
          }
        },
        {
          "description": "Secret-handle fields always use the secret-bearing risk class.",
          "if": {
            "properties": {
              "field_rule_class": { "const": "secret_handle_field" }
            },
            "required": ["field_rule_class"]
          },
          "then": {
            "properties": {
              "risk_class": { "const": "secret_bearing" }
            },
            "required": ["risk_class"]
          }
        },
        {
          "description": "Raw secret inputs are session-only or literal-session entry surfaces, never durable plaintext.",
          "if": {
            "properties": {
              "field_rule_class": { "const": "raw_secret_input" }
            },
            "required": ["field_rule_class"]
          },
          "then": {
            "properties": {
              "risk_class": { "const": "raw_secret_exposure" },
              "value_representation": {
                "properties": {
                  "storage_class": {
                    "enum": [
                      "session_memory_only",
                      "literal_session_entry"
                    ]
                  },
                  "raw_value_allowed_at_rest": { "const": false }
                },
                "required": [
                  "storage_class",
                  "raw_value_allowed_at_rest"
                ]
              }
            }
          }
        },
        {
          "description": "Filesystem path refs always use the filesystem-authority risk class.",
          "if": {
            "properties": {
              "field_rule_class": { "const": "filesystem_path_ref" }
            },
            "required": ["field_rule_class"]
          },
          "then": {
            "properties": {
              "risk_class": { "const": "filesystem_authority" }
            },
            "required": ["risk_class"]
          }
        },
        {
          "description": "URI and endpoint fields always use the network-target risk class.",
          "if": {
            "properties": {
              "field_rule_class": { "const": "uri_endpoint" }
            },
            "required": ["field_rule_class"]
          },
          "then": {
            "properties": {
              "risk_class": { "const": "network_target" }
            },
            "required": ["risk_class"]
          }
        },
        {
          "description": "Code-backed expressions always use the evaluated-code risk class.",
          "if": {
            "properties": {
              "field_rule_class": { "const": "code_backed_expression" }
            },
            "required": ["field_rule_class"]
          },
          "then": {
            "properties": {
              "risk_class": { "const": "evaluated_code" }
            },
            "required": ["risk_class"]
          }
        },
        {
          "description": "Command templates always use the shell-execution risk class.",
          "if": {
            "properties": {
              "field_rule_class": { "const": "command_template" }
            },
            "required": ["field_rule_class"]
          },
          "then": {
            "properties": {
              "risk_class": { "const": "shell_execution" }
            },
            "required": ["risk_class"]
          }
        },
        {
          "description": "Environment refs always use the environment-resolution risk class.",
          "if": {
            "properties": {
              "field_rule_class": { "const": "environment_ref" }
            },
            "required": ["field_rule_class"]
          },
          "then": {
            "properties": {
              "risk_class": { "const": "environment_resolution" }
            },
            "required": ["risk_class"]
          }
        },
        {
          "description": "Certificate refs always use the trust-material risk class and never export raw private material.",
          "if": {
            "properties": {
              "field_rule_class": { "const": "certificate_ref" }
            },
            "required": ["field_rule_class"]
          },
          "then": {
            "properties": {
              "risk_class": { "const": "trust_material" },
              "value_representation": {
                "properties": {
                  "raw_value_allowed_in_export": { "const": false }
                },
                "required": ["raw_value_allowed_in_export"]
              },
              "export_policy": {
                "properties": {
                  "never_export_raw_secret": { "const": true },
                  "downgrade_requires_class_change": { "const": true }
                },
                "required": [
                  "never_export_raw_secret",
                  "downgrade_requires_class_change"
                ]
              }
            },
            "required": ["risk_class"]
          }
        },
        {
          "description": "Provider/resource identifiers always use the external-resource-identity risk class.",
          "if": {
            "properties": {
              "field_rule_class": { "const": "provider_resource_identifier" }
            },
            "required": ["field_rule_class"]
          },
          "then": {
            "properties": {
              "risk_class": { "const": "external_resource_identity" }
            },
            "required": ["risk_class"]
          }
        },
        {
          "description": "Path, code, command, endpoint, environment, certificate, and provider-resource fields require context before apply.",
          "if": {
            "properties": {
              "field_rule_class": {
                "enum": [
                  "filesystem_path_ref",
                  "uri_endpoint",
                  "code_backed_expression",
                  "command_template",
                  "environment_ref",
                  "certificate_ref",
                  "provider_resource_identifier"
                ]
              }
            },
            "required": ["field_rule_class"]
          },
          "then": {
            "properties": {
              "evaluation_context": {
                "properties": {
                  "context_required_before_apply": { "const": true },
                  "unsafe_when_missing_context": { "const": true }
                },
                "required": [
                  "context_required_before_apply",
                  "unsafe_when_missing_context"
                ]
              }
            }
          }
        },
        {
          "description": "Evaluated code and command templates always require a review surface before apply.",
          "if": {
            "properties": {
              "field_rule_class": {
                "enum": [
                  "code_backed_expression",
                  "command_template"
                ]
              }
            },
            "required": ["field_rule_class"]
          },
          "then": {
            "properties": {
              "unsafe_value_review": {
                "properties": {
                  "required_before_apply": { "const": true }
                },
                "required": ["required_before_apply"]
              }
            }
          }
        },
        {
          "description": "Filesystem path refs must declare a relative-path policy instead of leaving the basis implicit.",
          "if": {
            "properties": {
              "field_rule_class": { "const": "filesystem_path_ref" }
            },
            "required": ["field_rule_class"]
          },
          "then": {
            "properties": {
              "multi_value_policy": {
                "properties": {
                  "relative_path_basis_policy": {
                    "not": { "const": "not_applicable" }
                  }
                },
                "required": ["relative_path_basis_policy"]
              }
            }
          }
        }
      ]
    }
  }
}
