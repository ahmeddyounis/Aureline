{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/template-prebuild-entry.schema.json",
  "title": "Template, starter, and prebuild entry disclosure record",
  "description": "Boundary schema for the template, starter, and prebuild entry disclosure contract frozen in docs/ux/m4/stabilize-template-starter-prebuild-entry.md. The record is the single governed truth that Start Center, CLI / headless entry, docs, and support packets read before a template, starter, or prebuild is applied. It discloses identity, source, support, runtime, freshness, setup expectations, side-effect envelope, resulting mode, bypass paths, trust/auth boundaries, cleanup/rollback, failure summary, and export safety.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "accelerator_identity",
    "source_review",
    "support_review",
    "runtime_review",
    "freshness_review",
    "setup_review",
    "side_effect_envelope",
    "resulting_mode",
    "bypass_paths",
    "trust_auth_boundaries",
    "cleanup_rollback",
    "support_export",
    "honesty_marker_present"
  ],
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "template_starter_prebuild_entry_record",
      "description": "Discriminator for the concrete payload shape."
    },
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this record family. Bumped only on breaking payload changes."
    },
    "notice": {
      "type": "string",
      "description": "Reviewer-facing notice rendered on every disclosure surface."
    },
    "shared_contract_ref": {
      "type": "string",
      "description": "Shared contract ref consumed by every surface that ingests this record."
    },
    "record_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable opaque record id."
    },
    "as_of": {
      "type": "string",
      "description": "UTC timestamp when the record was minted."
    },
    "accelerator_identity": {
      "$ref": "#/$defs/accelerator_identity"
    },
    "source_review": {
      "$ref": "#/$defs/source_review"
    },
    "support_review": {
      "$ref": "#/$defs/support_review"
    },
    "runtime_review": {
      "$ref": "#/$defs/runtime_review"
    },
    "freshness_review": {
      "$ref": "#/$defs/freshness_review"
    },
    "setup_review": {
      "$ref": "#/$defs/setup_review"
    },
    "side_effect_envelope": {
      "$ref": "#/$defs/side_effect_envelope"
    },
    "resulting_mode": {
      "type": "string",
      "enum": [
        "resume_live_workspace",
        "start_from_snapshot",
        "clone_fresh",
        "open_prebuild_with_setup_actions",
        "open_prebuild_minimal",
        "open_without_starter",
        "create_empty_workspace",
        "create_project",
        "create_service",
        "add_module"
      ],
      "description": "Closed set of resulting modes for template/starter/prebuild entry."
    },
    "bypass_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/bypass_path"
      },
      "description": "Same-weight bypass paths shown before setup begins."
    },
    "trust_auth_boundaries": {
      "$ref": "#/$defs/trust_auth_boundaries"
    },
    "cleanup_rollback": {
      "$ref": "#/$defs/cleanup_rollback"
    },
    "failure_summary": {
      "$ref": "#/$defs/failure_summary"
    },
    "support_export": {
      "$ref": "#/$defs/support_export_metadata"
    },
    "honesty_marker_present": {
      "type": "boolean",
      "description": "True when any honesty marker is present (stale, restricted, partial, etc.)."
    }
  },
  "$defs": {
    "accelerator_identity": {
      "type": "object",
      "required": [
        "accelerator_id",
        "display_label",
        "summary",
        "accelerator_version",
        "bound_manifest_ref",
        "entry_kind"
      ],
      "properties": {
        "accelerator_id": {
          "type": "string",
          "minLength": 1
        },
        "display_label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "accelerator_version": {
          "type": "string",
          "minLength": 1
        },
        "bound_manifest_ref": {
          "type": "string",
          "minLength": 1
        },
        "entry_kind": {
          "type": "string",
          "enum": ["template", "starter", "prebuild"]
        }
      }
    },
    "source_review": {
      "type": "object",
      "required": [
        "source_class",
        "source_distribution_class",
        "signature_state",
        "publisher_label",
        "trust_root_ref"
      ],
      "properties": {
        "source_class": {
          "type": "string",
          "enum": [
            "first_party",
            "team_managed",
            "community",
            "local_only",
            "mirror_cached",
            "uncertified"
          ]
        },
        "source_distribution_class": {
          "type": "string",
          "minLength": 1
        },
        "signature_state": {
          "type": "string",
          "minLength": 1
        },
        "publisher_label": {
          "type": "string",
          "minLength": 1
        },
        "trust_root_ref": {
          "type": "string",
          "minLength": 1
        },
        "trust_notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          }
        }
      }
    },
    "support_review": {
      "type": "object",
      "required": ["support_class", "lifecycle_class"],
      "properties": {
        "support_class": {
          "type": "string",
          "enum": [
            "officially_supported",
            "community_supported",
            "experimental",
            "legacy_deprecated",
            "unsupported",
            "support_unknown"
          ]
        },
        "lifecycle_class": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtime_review": {
      "type": "object",
      "required": [
        "runtime_scope_class",
        "host_boundary_class",
        "supported_ecosystems",
        "supported_platforms"
      ],
      "properties": {
        "runtime_scope_class": {
          "type": "string",
          "enum": [
            "local_only",
            "local_with_devcontainer",
            "local_with_container",
            "remote_image_required",
            "managed_cloud_required",
            "mixed_local_and_remote",
            "not_declared"
          ]
        },
        "host_boundary_class": {
          "type": "string",
          "enum": [
            "host_local_device_only",
            "host_local_with_devcontainer_attached",
            "host_local_with_container_attached",
            "host_remote_image_required",
            "host_managed_workspace_required",
            "host_mixed_local_and_remote",
            "host_boundary_unknown_requires_review"
          ]
        },
        "supported_ecosystems": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "supported_platforms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "freshness_review": {
      "type": "object",
      "required": [
        "freshness_class",
        "producer_class",
        "signer_posture"
      ],
      "properties": {
        "freshness_class": {
          "type": "string",
          "enum": [
            "fresh_under_window",
            "near_expiry",
            "stale_over_window",
            "expired",
            "unknown_requires_revalidation"
          ]
        },
        "age_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "max_age_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "producer_class": {
          "type": "string",
          "minLength": 1
        },
        "signer_posture": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "setup_review": {
      "type": "object",
      "required": [
        "expected_actions",
        "estimated_duration_label",
        "connectivity_required",
        "connectivity_expectation_label"
      ],
      "properties": {
        "expected_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "download_dependency_index",
              "install_extension",
              "provision_remote_environment",
              "run_scaffold_hook",
              "restore_cached_artifact",
              "authenticate_to_registry",
              "trust_workspace",
              "none"
            ]
          }
        },
        "estimated_duration_label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "connectivity_required": {
          "type": "boolean"
        },
        "connectivity_expectation_label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    },
    "side_effect_envelope": {
      "type": "object",
      "required": [
        "required_network_egress_class",
        "required_extension_install_class",
        "required_remote_provisioning_class",
        "required_managed_service_class",
        "required_credential_provisioning_class",
        "declared_hook_count",
        "declared_setup_task_count"
      ],
      "properties": {
        "required_network_egress_class": {
          "type": "string",
          "enum": [
            "no_network_egress_required",
            "egress_to_first_party_origin_only",
            "egress_to_team_managed_mirror_only",
            "egress_to_community_origin_user_review_required",
            "egress_to_managed_workspace_envelope_only",
            "egress_envelope_unknown_requires_review"
          ]
        },
        "required_extension_install_class": {
          "type": "string",
          "enum": [
            "no_extension_install_required",
            "first_party_extension_install_required",
            "organization_curated_extension_install_required",
            "marketplace_extension_install_user_review_required",
            "managed_only_channel_extension_install_required",
            "extension_install_review_required_signature_unverified",
            "extension_install_class_unknown_requires_review"
          ]
        },
        "required_remote_provisioning_class": {
          "type": "string",
          "enum": [
            "no_remote_provisioning_required",
            "devcontainer_attach_required",
            "container_attach_required",
            "remote_image_required",
            "managed_workspace_required",
            "mixed_local_and_remote_provisioning_required",
            "remote_provisioning_unknown_requires_review"
          ]
        },
        "required_managed_service_class": {
          "type": "string",
          "enum": [
            "no_managed_service_required",
            "managed_workspace_envelope_required",
            "managed_only_channel_invocation_required",
            "third_party_connected_provider_required",
            "first_party_managed_service_required",
            "managed_service_class_unknown_requires_review"
          ]
        },
        "required_credential_provisioning_class": {
          "type": "string",
          "enum": [
            "no_credential_provisioning_required",
            "secret_broker_handle_required",
            "credential_provisioning_step_required",
            "remote_attach_handshake_required",
            "credential_provisioning_class_unknown_requires_review"
          ]
        },
        "declared_hook_count": {
          "type": "integer",
          "minimum": 0
        },
        "declared_setup_task_count": {
          "type": "integer",
          "minimum": 0
        },
        "side_effect_notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          }
        }
      }
    },
    "bypass_path": {
      "type": "object",
      "required": [
        "path_class",
        "route_label",
        "bypass_continuity_class"
      ],
      "properties": {
        "path_class": {
          "type": "string",
          "enum": [
            "open_folder_without_starter",
            "open_workspace_without_starter",
            "clone_repository_without_starter",
            "create_empty_workspace",
            "open_prebuild_minimal",
            "set_up_later",
            "continue_without_starter"
          ]
        },
        "route_label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "bypass_continuity_class": {
          "type": "string",
          "const": "equal_weight_with_apply"
        },
        "keyboard_shortcut_hint": {
          "type": "string"
        }
      }
    },
    "trust_auth_boundaries": {
      "type": "object",
      "required": [
        "trust_posture_class",
        "auth_required",
        "registry_mirror_required",
        "managed_service_boundary",
        "download_provisioning_boundary",
        "significant_download_label"
      ],
      "properties": {
        "trust_posture_class": {
          "type": "string",
          "enum": [
            "trusted",
            "restricted",
            "pending_evaluation",
            "revoked",
            "managed_locked"
          ]
        },
        "auth_required": {
          "type": "boolean"
        },
        "registry_mirror_required": {
          "type": "boolean"
        },
        "managed_service_boundary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "download_provisioning_boundary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "significant_download_label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    },
    "cleanup_rollback": {
      "type": "object",
      "required": [
        "cleanup_path_available",
        "rollback_path_available",
        "cleanup_summary",
        "rollback_summary"
      ],
      "properties": {
        "cleanup_path_available": {
          "type": "boolean"
        },
        "rollback_path_available": {
          "type": "boolean"
        },
        "cleanup_summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "rollback_summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    },
    "failure_summary": {
      "type": "object",
      "required": [
        "succeeded",
        "skipped",
        "partially_applied",
        "failed",
        "cleanup_ran",
        "remaining_user_review"
      ],
      "properties": {
        "succeeded": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failure_summary_item"
          }
        },
        "skipped": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failure_summary_item"
          }
        },
        "partially_applied": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failure_summary_item"
          }
        },
        "failed": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failure_summary_item"
          }
        },
        "cleanup_ran": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failure_summary_item"
          }
        },
        "remaining_user_review": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    },
    "failure_summary_item": {
      "type": "object",
      "required": ["item_label", "outcome", "detail"],
      "properties": {
        "item_label": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "enum": [
            "succeeded",
            "skipped",
            "partially_applied",
            "failed",
            "cleanup_ran"
          ]
        },
        "detail": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    },
    "support_export_metadata": {
      "type": "object",
      "required": [
        "exportable",
        "redaction_class",
        "versioned_identity_included",
        "side_effect_envelope_included",
        "raw_secret_export_allowed",
        "raw_command_export_allowed",
        "raw_url_export_allowed"
      ],
      "properties": {
        "exportable": {
          "type": "boolean"
        },
        "redaction_class": {
          "type": "string",
          "minLength": 1
        },
        "versioned_identity_included": {
          "type": "boolean"
        },
        "side_effect_envelope_included": {
          "type": "boolean"
        },
        "raw_secret_export_allowed": {
          "type": "boolean",
          "const": false
        },
        "raw_command_export_allowed": {
          "type": "boolean",
          "const": false
        },
        "raw_url_export_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
