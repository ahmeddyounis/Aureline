{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/bundle_detail_page.schema.json",
  "title": "Aureline Start Center bundle detail page",
  "description": "Boundary schema for the start_center_bundle_detail_page_record frozen in docs/ux/start_center_bundle_surfaces.md §5. The detail page enumerates the eleven bundle component-kind sections plus identity, mirror / offline posture, changelog, known-limits, lifecycle and successor, dependency markers, and review actions, and projects them onto the same surface families a bundle card renders on. Sections render absence as empty arrays, never as missing keys, so reviewers see the absence. Raw signing keys, raw certificate material, raw repository URLs, raw absolute paths, raw secrets, raw extension binaries, and raw user-authored content never cross this boundary; records carry opaque refs, closed vocabulary, timestamps, and short reviewable summaries only. Adding a new bundle_detail_page_section_id, bundle_detail_page_zone, or review_action_id value is additive-minor and bumps bundle_detail_page_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "$ref": "#/$defs/start_center_bundle_detail_page_record",
  "$defs": {
    "bundle_detail_page_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version. Current value is 1. Bumped on additive-minor enum or field additions; repurposing or removal is breaking and requires a decision row."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "redaction_aware_text": {
      "type": "string",
      "maxLength": 1024
    },
    "monotonic_timestamp": {
      "type": "string",
      "minLength": 1
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true
    },

    "bundle_card_surface_family": {
      "type": "string",
      "enum": [
        "start_center_bundle_row",
        "gallery_browse_bundles_row",
        "workspace_switcher_bundle_row",
        "update_detail_entry",
        "export_facing_bundle_summary"
      ]
    },

    "bundle_evidence_badge_id": {
      "type": "string",
      "enum": [
        "badge.certified",
        "badge.managed_approved",
        "badge.community",
        "badge.imported",
        "badge.local_draft",
        "badge.retest_pending",
        "badge.deprecated",
        "badge.status_unknown",
        "badge.signed_offline_bundle",
        "badge.mirror_only",
        "badge.live_or_mirror",
        "badge.live_origin_only",
        "badge.offline_no_bundle"
      ]
    },

    "bundle_component_kind": {
      "type": "string",
      "enum": [
        "extension_set",
        "profile_preset",
        "surface_preset",
        "task_recipe",
        "launch_recipe",
        "debug_recipe",
        "template_or_scaffold_ref",
        "docs_pack",
        "tour_pack",
        "glossary_pack",
        "migration_mapping",
        "certification_target",
        "evidence_link"
      ],
      "description": "Re-exported from schemas/workflow/bundle_manifest.schema.json. See docs/workflow/workflow_bundle_object_model.md §3.8."
    },

    "bundle_detail_page_section_id": {
      "type": "string",
      "enum": [
        "section.identity_and_class",
        "section.extension_set",
        "section.presets",
        "section.task_recipes",
        "section.launch_recipes",
        "section.debug_recipes",
        "section.template_or_scaffold",
        "section.docs_pack",
        "section.tour_pack",
        "section.glossary_pack",
        "section.migration_mapping",
        "section.certification_targets",
        "section.evidence_links",
        "section.mirror_or_offline_posture",
        "section.changelog",
        "section.known_limits",
        "section.lifecycle_and_successor",
        "section.dependency_markers",
        "section.review_actions"
      ]
    },

    "bundle_detail_page_zone": {
      "type": "string",
      "enum": [
        "detail_page.body",
        "detail_page.review_actions_rail",
        "detail_page.lifecycle_rail",
        "detail_page.evidence_rail"
      ]
    },

    "lifecycle_state_class": {
      "type": "string",
      "enum": [
        "active_supported",
        "soft_deprecated_with_successor",
        "hard_deprecated_remove_recommended",
        "retest_needed",
        "evidence_aged",
        "removed_unavailable",
        "rollback_recommended",
        "lifecycle_unknown"
      ]
    },
    "evidence_age_class": {
      "type": "string",
      "enum": [
        "fresh_current",
        "aging_within_window",
        "stale_past_window",
        "age_unknown"
      ]
    },
    "retest_needed_posture": {
      "type": "string",
      "enum": [
        "not_required",
        "retest_recommended",
        "retest_required",
        "retest_blocked"
      ]
    },
    "successor_recommendation_class": {
      "type": "string",
      "enum": [
        "no_successor",
        "successor_recommended_same_class",
        "successor_recommended_different_class",
        "successor_recommended_first_party_native",
        "successor_unknown"
      ]
    },
    "removal_surface_kind": {
      "type": "string",
      "enum": [
        "start_center_browse_bundles",
        "bundle_detail_panel",
        "project_doctor_recommended_action",
        "support_export_recommendation",
        "cli_or_headless_remove",
        "org_policy_recall",
        "not_applicable_local_draft"
      ]
    },
    "rollback_surface_kind": {
      "type": "string",
      "enum": [
        "bundle_detail_panel",
        "project_doctor_recommended_action",
        "support_export_recommendation",
        "cli_or_headless_rollback",
        "org_policy_pinned_revision",
        "not_applicable_no_prior_revision"
      ]
    },
    "mirror_or_offline_packaging_posture": {
      "type": "string",
      "enum": [
        "live_origin_only",
        "live_or_mirror",
        "mirror_only",
        "signed_offline_bundle",
        "offline_no_bundle",
        "packaging_posture_unknown"
      ]
    },
    "disabled_reason_code": {
      "type": "string",
      "enum": [
        "policy_narrowed_fleet",
        "policy_narrowed_admin",
        "policy_narrowed_workspace_trust",
        "mirror_only_cached_subset",
        "signature_review_required",
        "uncertified_excluded",
        "target_runtime_unavailable",
        "network_unreachable",
        "rebuild_required"
      ]
    },

    "review_action_id": {
      "type": "string",
      "enum": [
        "review.review_bundle",
        "review.compare_with_installed",
        "review.view_certification_sheet",
        "review.view_successor",
        "review.retest_now",
        "review.remove",
        "review.rollback_to_previous_revision",
        "review.open_without_this_bundle"
      ]
    },

    "review_action_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "keyboard_reachable", "rendered_state"],
      "properties": {
        "action_id": { "$ref": "#/$defs/review_action_id" },
        "keyboard_reachable": { "type": "boolean" },
        "rendered_state": {
          "type": "string",
          "enum": ["enabled", "visible_disabled", "hidden_not_applicable"]
        },
        "disabled_reason_code": { "$ref": "#/$defs/disabled_reason_code" },
        "presentation_label": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },

    "successor_recommendation_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["successor_recommendation_class"],
      "properties": {
        "successor_recommendation_class": { "$ref": "#/$defs/successor_recommendation_class" },
        "successor_bundle_id": { "$ref": "#/$defs/nullable_opaque_id" },
        "successor_bundle_revision": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 1 }
          ]
        },
        "successor_summary_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "decision_row_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      }
    },

    "bundle_detail_page_section_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_id",
        "component_refs",
        "evidence_link_refs",
        "policy_notice_refs",
        "disclosed_in_zone",
        "keyboard_reachable"
      ],
      "properties": {
        "section_id": { "$ref": "#/$defs/bundle_detail_page_section_id" },
        "section_summary_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "component_kind": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/bundle_component_kind" }
          ],
          "description": "One of bundle_component_kind for inventory sections; null for identity / mirror / changelog / known_limits / lifecycle / dependency_markers / review_actions sections."
        },
        "component_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Opaque refs to manifest component_id entries this section renders. Empty array allowed when manifest emits an empty slot."
        },
        "evidence_link_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "policy_notice_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "disclosed_in_zone": { "$ref": "#/$defs/bundle_detail_page_zone" },
        "keyboard_reachable": { "const": true }
      }
    },

    "start_center_bundle_detail_page_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "bundle_detail_page_schema_version",
        "detail_page_id",
        "bundle_id",
        "bundle_revision",
        "bundle_card_ref",
        "bundle_card_surface_family",
        "sections",
        "evidence_badge_ids",
        "review_actions",
        "mirror_or_offline_posture_chip",
        "successor_recommendation",
        "lifecycle_state_class",
        "evidence_age_class",
        "retest_needed_posture",
        "removal_surface_kind",
        "rollback_surface_kind",
        "keyboard_reachable",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "start_center_bundle_detail_page_record" },
        "bundle_detail_page_schema_version": { "$ref": "#/$defs/bundle_detail_page_schema_version" },
        "detail_page_id": { "$ref": "#/$defs/opaque_id" },
        "bundle_id": { "$ref": "#/$defs/opaque_id" },
        "bundle_revision": { "type": "integer", "minimum": 1 },
        "bundle_card_ref": { "$ref": "#/$defs/opaque_id" },
        "bundle_card_surface_family": { "$ref": "#/$defs/bundle_card_surface_family" },
        "sections": {
          "type": "array",
          "minItems": 19,
          "maxItems": 19,
          "items": { "$ref": "#/$defs/bundle_detail_page_section_record" },
          "description": "All nineteen sections in §3.4 are required; an empty array on a section is allowed but missing keys are non-conforming."
        },
        "evidence_badge_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bundle_evidence_badge_id" },
          "uniqueItems": true,
          "description": "Re-exported verbatim from the companion bundle card. Detail pages MUST NOT mint badges the card does not."
        },
        "review_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/review_action_record" }
        },
        "mirror_or_offline_posture_chip": { "$ref": "#/$defs/mirror_or_offline_packaging_posture" },
        "successor_recommendation": { "$ref": "#/$defs/successor_recommendation_block" },
        "lifecycle_state_class": { "$ref": "#/$defs/lifecycle_state_class" },
        "evidence_age_class": { "$ref": "#/$defs/evidence_age_class" },
        "retest_needed_posture": { "$ref": "#/$defs/retest_needed_posture" },
        "certification_sheet_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "removal_surface_kind": { "$ref": "#/$defs/removal_surface_kind" },
        "rollback_surface_kind": { "$ref": "#/$defs/rollback_surface_kind" },
        "disclosed_freshness_window_class": { "$ref": "#/$defs/nullable_opaque_id" },
        "keyboard_reachable": { "const": true },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "presentation_label": { "$ref": "#/$defs/redaction_aware_text" },
        "presentation_subtitle": { "$ref": "#/$defs/redaction_aware_text" }
      },
      "allOf": [
        {
          "description": "All nineteen section ids in §3.4 MUST appear exactly once across sections[].",
          "properties": {
            "sections": {
              "allOf": [
                { "contains": { "properties": { "section_id": { "const": "section.identity_and_class" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.extension_set" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.presets" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.task_recipes" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.launch_recipes" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.debug_recipes" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.template_or_scaffold" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.docs_pack" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.tour_pack" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.glossary_pack" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.migration_mapping" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.certification_targets" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.evidence_links" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.mirror_or_offline_posture" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.changelog" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.known_limits" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.lifecycle_and_successor" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.dependency_markers" } }, "required": ["section_id"] } },
                { "contains": { "properties": { "section_id": { "const": "section.review_actions" } }, "required": ["section_id"] } }
              ]
            }
          },
          "required": ["sections"]
        },
        {
          "description": "Review actions MUST include review.review_bundle (enabled or visible_disabled per §7.2).",
          "properties": {
            "review_actions": {
              "contains": {
                "type": "object",
                "properties": { "action_id": { "const": "review.review_bundle" } },
                "required": ["action_id"]
              }
            }
          },
          "required": ["review_actions"]
        },
        {
          "description": "Review actions MUST include review.open_without_this_bundle (typed bypass; same-weight per §5.3 rule 7).",
          "properties": {
            "review_actions": {
              "contains": {
                "type": "object",
                "properties": { "action_id": { "const": "review.open_without_this_bundle" } },
                "required": ["action_id"]
              }
            }
          },
          "required": ["review_actions"]
        },
        {
          "description": "When evidence_badge_ids contains badge.certified, certification_sheet_refs MUST be non-empty.",
          "if": {
            "properties": {
              "evidence_badge_ids": {
                "type": "array",
                "contains": { "const": "badge.certified" }
              }
            },
            "required": ["evidence_badge_ids"]
          },
          "then": {
            "required": ["certification_sheet_refs"],
            "properties": {
              "certification_sheet_refs": { "minItems": 1 }
            }
          }
        }
      ],
      "description": "Detail page for one bundle revision. Renders all nineteen sections in §3.4 plus typed review / removal / rollback / retest / open-without-this-bundle actions. See docs/ux/start_center_bundle_surfaces.md §5."
    }
  }
}
