{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/certify-the-design-token-runtime-across-dark-light.schema.json",
  "title": "Aureline design-token runtime certification record",
  "description": "Boundary schema for design_token_runtime_certification_record, the single governed record the settings appearance panel, command palette, status bar, diagnostics, support exports, Help/About, dashboards, and docs all read for one appearance posture of the design-token runtime. It is minted by crates/aureline-settings/src/design_token_runtime_stable as a genuine projection of the live appearance runtime (aureline_design_system::seeded_appearance_session_beta_contract, aureline_design_system::seeded_component_state_registry, aureline_ui::tokens::seeded_token_registry, aureline_ui::motion) and binds, for one posture: (1) one appearance-session value every golden capture and accessibility packet is attributable to; (2) mode conformance across dark, light, high-contrast (dark and light), reduced-motion, and density rows, each proving the token registry resolves and that focus rings, state badges, severity cues, and keyboard affordances survive the mode change; (3) protected cues (diagnostics, policy lock, trust warning, execution target, selection, focus) that never rely on hue alone but carry a text, shape, border, icon, or focus-ring cue surviving contrast and motion modes; (4) per-axis live-apply posture that applies live, applies live behind a checkpoint, requires confirmation, or discloses a reload/restart, never a silent lag; (5) motion suppression modeled in the token runtime rather than improvised per surface; (6) launch-surface conformance with no hard-coded stable styling; (7) a public claim ceiling no posture may exceed; and (8) a derived stable-claim verdict that narrows a posture which cannot prove a pillar, or whose lowest surface marker is below Stable, below Stable with a named reason. Minted refs are opaque aureline://<class>/<id> object refs; upstream projection refs keep their source scheme.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "posture_id",
    "posture_label",
    "title",
    "summary",
    "appearance_session",
    "surface_lifecycle_marker",
    "mode_rows",
    "protected_cues",
    "live_apply_axes",
    "motion_suppression",
    "launch_surfaces",
    "pillars",
    "claim_ceiling",
    "stable_qualification",
    "recovery_routes",
    "routes",
    "accessibility",
    "available_without_account",
    "available_without_managed_services",
    "honesty_marker_present",
    "upstream",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": { "const": "design_token_runtime_certification_record" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "notice": { "type": "string", "minLength": 1 },
    "shared_contract_ref": { "const": "settings:design_token_runtime_stable:v1" },
    "record_id": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "minLength": 1 },
    "posture_id": { "type": "string", "minLength": 1 },
    "posture_label": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "appearance_session": { "$ref": "#/$defs/appearanceSession" },
    "surface_lifecycle_marker": { "$ref": "#/$defs/lifecycleMarker" },
    "mode_rows": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/modeRow" }
    },
    "protected_cues": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/protectedCueRow" }
    },
    "live_apply_axes": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/liveApplyAxisRow" }
    },
    "motion_suppression": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/motionSuppressionRow" }
    },
    "launch_surfaces": {
      "type": "array",
      "minItems": 10,
      "items": { "$ref": "#/$defs/launchSurfaceRow" }
    },
    "pillars": { "$ref": "#/$defs/pillars" },
    "claim_ceiling": { "$ref": "#/$defs/claimCeiling" },
    "stable_qualification": { "$ref": "#/$defs/stableQualification" },
    "recovery_routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/recoveryRoute" }
    },
    "routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/entryRoute" }
    },
    "accessibility": { "$ref": "#/$defs/accessibility" },
    "available_without_account": { "type": "boolean" },
    "available_without_managed_services": { "type": "boolean" },
    "honesty_marker_present": { "type": "boolean" },
    "upstream": { "$ref": "#/$defs/upstream" },
    "diagnostics_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "support_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } },
    "narrative_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } }
  },
  "$defs": {
    "canonicalRef": {
      "type": "string",
      "pattern": "^aureline://(?!home/|landing/|root/)[^/]+/.+",
      "maxLength": 200
    },
    "presentRef": { "type": "string", "minLength": 1, "maxLength": 200 },
    "lifecycleMarker": { "enum": ["preview", "beta", "stable"] },
    "claimClass": { "enum": ["stable", "beta", "preview", "not_claimed"] },
    "themeClass": {
      "enum": ["dark_reference", "light_parity", "high_contrast_dark", "high_contrast_light"]
    },
    "densityClass": { "enum": ["compact", "standard", "comfortable"] },
    "contrastMode": {
      "enum": ["contrast_standard", "contrast_high", "contrast_forced_colors"]
    },
    "accentSource": {
      "enum": [
        "system_accent",
        "theme_package_accent",
        "user_selected_accent",
        "policy_locked_accent",
        "not_applicable"
      ]
    },
    "motionPosture": {
      "enum": [
        "motion_standard",
        "motion_reduced",
        "motion_low_motion",
        "motion_power_saver",
        "motion_critical_hot_path"
      ]
    },
    "followSystemPosture": {
      "enum": [
        "follow_system",
        "manual_override",
        "managed_policy_override",
        "unavailable_platform_signal"
      ]
    },
    "appearanceModeClass": {
      "enum": [
        "dark",
        "light",
        "high_contrast_dark",
        "high_contrast_light",
        "reduced_motion",
        "density"
      ]
    },
    "protectedCueClass": {
      "enum": [
        "diagnostics",
        "policy_lock",
        "trust_warning",
        "execution_target",
        "selection",
        "focus"
      ]
    },
    "nonColorCueClass": {
      "enum": ["label_text", "icon", "border", "shape", "focus_ring"]
    },
    "appearanceAxis": {
      "enum": [
        "mode_theme_class",
        "contrast_mode",
        "accent_source",
        "density_class",
        "text_scale",
        "reduced_motion_posture",
        "follow_system_posture"
      ]
    },
    "liveApplyClass": {
      "enum": [
        "apply_live",
        "apply_live_checkpointed",
        "confirm_required",
        "reload_required",
        "restart_required",
        "policy_blocked"
      ]
    },
    "launchSurfaceClass": {
      "enum": [
        "shell_chrome",
        "start_center",
        "command_palette",
        "search_surface",
        "dialog_sheet",
        "trust_prompt",
        "notification_envelope",
        "help_about_row",
        "settings_root",
        "activity_center_row"
      ]
    },
    "routeSurface": {
      "enum": ["settings_appearance", "command_palette", "status_bar", "menu_command"]
    },
    "recoveryRole": { "enum": ["primary", "recovery", "secondary"] },
    "layoutMode": { "enum": ["normal", "high_contrast", "zoomed"] },
    "narrowingReason": {
      "enum": [
        "mode_conformance_not_proven",
        "protected_cue_hue_only_risk",
        "captures_not_one_session",
        "live_apply_silent_lag",
        "motion_suppression_not_in_runtime",
        "hardcoded_stable_styling",
        "surface_not_yet_stable"
      ]
    },
    "appearanceSession": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "appearance_session_id",
        "session_revision",
        "active_theme_package_ref",
        "active_theme_revision_ref",
        "mode_theme_class",
        "contrast_mode",
        "accent_source",
        "density_class",
        "text_scale_percent",
        "reduced_motion_posture",
        "follow_system_posture",
        "live_follow_system_policy_ref",
        "value_ref"
      ],
      "properties": {
        "appearance_session_id": { "type": "string", "minLength": 1 },
        "session_revision": { "type": "integer", "minimum": 0 },
        "active_theme_package_ref": { "type": "string", "minLength": 1 },
        "active_theme_revision_ref": { "type": "string", "minLength": 1 },
        "mode_theme_class": { "$ref": "#/$defs/themeClass" },
        "contrast_mode": { "$ref": "#/$defs/contrastMode" },
        "accent_source": { "$ref": "#/$defs/accentSource" },
        "density_class": { "$ref": "#/$defs/densityClass" },
        "text_scale_percent": { "type": "integer", "minimum": 1 },
        "reduced_motion_posture": { "$ref": "#/$defs/motionPosture" },
        "follow_system_posture": { "$ref": "#/$defs/followSystemPosture" },
        "live_follow_system_policy_ref": { "type": "string", "minLength": 1 },
        "value_ref": { "$ref": "#/$defs/canonicalRef" }
      }
    },
    "modeRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode_class",
        "theme_class",
        "density_class",
        "motion_posture",
        "token_registry_resolves",
        "certified_token_refs",
        "focus_ring_preserved",
        "state_badges_preserved",
        "severity_cues_preserved",
        "keyboard_affordances_preserved",
        "protected_cues_survive",
        "golden_capture_ref",
        "accessibility_packet_ref",
        "appearance_session_value_ref",
        "surface_marker",
        "conforms"
      ],
      "properties": {
        "mode_class": { "$ref": "#/$defs/appearanceModeClass" },
        "theme_class": { "$ref": "#/$defs/themeClass" },
        "density_class": { "$ref": "#/$defs/densityClass" },
        "motion_posture": { "$ref": "#/$defs/motionPosture" },
        "token_registry_resolves": { "type": "boolean" },
        "certified_token_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "focus_ring_preserved": { "type": "boolean" },
        "state_badges_preserved": { "type": "boolean" },
        "severity_cues_preserved": { "type": "boolean" },
        "keyboard_affordances_preserved": { "type": "boolean" },
        "protected_cues_survive": { "type": "boolean" },
        "golden_capture_ref": { "$ref": "#/$defs/canonicalRef" },
        "accessibility_packet_ref": { "$ref": "#/$defs/canonicalRef" },
        "appearance_session_value_ref": { "$ref": "#/$defs/canonicalRef" },
        "surface_marker": { "$ref": "#/$defs/lifecycleMarker" },
        "conforms": { "type": "boolean" }
      }
    },
    "protectedCueRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cue_class",
        "non_color_cues",
        "hue_only_forbidden",
        "survives_high_contrast",
        "survives_forced_colors",
        "survives_reduced_motion",
        "conforms"
      ],
      "properties": {
        "cue_class": { "$ref": "#/$defs/protectedCueClass" },
        "non_color_cues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonColorCueClass" }
        },
        "hue_only_forbidden": { "type": "boolean" },
        "survives_high_contrast": { "type": "boolean" },
        "survives_forced_colors": { "type": "boolean" },
        "survives_reduced_motion": { "type": "boolean" },
        "conforms": { "type": "boolean" }
      }
    },
    "liveApplyAxisRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "axis",
        "live_apply_class",
        "disclosure_required",
        "silently_lags_system",
        "note"
      ],
      "properties": {
        "axis": { "$ref": "#/$defs/appearanceAxis" },
        "live_apply_class": { "$ref": "#/$defs/liveApplyClass" },
        "disclosure_required": { "type": "boolean" },
        "silently_lags_system": { "const": false },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "motionSuppressionRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "posture",
        "modeled_in_token_runtime",
        "non_essential_motion_suppressed",
        "substitution_class",
        "per_surface_improvisation_absent"
      ],
      "properties": {
        "posture": { "$ref": "#/$defs/motionPosture" },
        "modeled_in_token_runtime": { "type": "boolean" },
        "non_essential_motion_suppressed": { "type": "boolean" },
        "substitution_class": { "type": "string", "minLength": 1 },
        "per_surface_improvisation_absent": { "type": "boolean" }
      }
    },
    "launchSurfaceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "honors_token_runtime",
        "hardcoded_styling_absent",
        "surface_marker",
        "certified_modes",
        "conforms"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/launchSurfaceClass" },
        "honors_token_runtime": { "type": "boolean" },
        "hardcoded_styling_absent": { "type": "boolean" },
        "surface_marker": { "$ref": "#/$defs/lifecycleMarker" },
        "certified_modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/appearanceModeClass" }
        },
        "waiver_ref": { "$ref": "#/$defs/presentRef" },
        "conforms": { "type": "boolean" }
      }
    },
    "pillars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_modes_conform",
        "protected_cues_never_hue_only",
        "captures_share_one_session",
        "live_apply_no_silent_lag",
        "motion_suppression_in_runtime",
        "no_hardcoded_stable_styling"
      ],
      "properties": {
        "all_modes_conform": { "type": "boolean" },
        "protected_cues_never_hue_only": { "type": "boolean" },
        "captures_share_one_session": { "type": "boolean" },
        "live_apply_no_silent_lag": { "type": "boolean" },
        "motion_suppression_in_runtime": { "type": "boolean" },
        "no_hardcoded_stable_styling": { "type": "boolean" }
      }
    },
    "claimCeiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asserts_all_modes_conform",
        "asserts_protected_cues_non_color",
        "asserts_one_appearance_session",
        "asserts_live_apply_no_silent_lag",
        "asserts_motion_suppression_runtime",
        "asserts_no_hardcoded_styling"
      ],
      "properties": {
        "asserts_all_modes_conform": { "type": "boolean" },
        "asserts_protected_cues_non_color": { "type": "boolean" },
        "asserts_one_appearance_session": { "type": "boolean" },
        "asserts_live_apply_no_silent_lag": { "type": "boolean" },
        "asserts_motion_suppression_runtime": { "type": "boolean" },
        "asserts_no_hardcoded_styling": { "type": "boolean" }
      }
    },
    "stableQualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_class", "qualifies_stable", "narrowing_reasons"],
      "properties": {
        "claim_class": { "$ref": "#/$defs/claimClass" },
        "qualifies_stable": { "type": "boolean" },
        "narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowingReason" }
        }
      }
    },
    "recoveryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_label", "action_role", "keyboard_reachable"],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_label": { "type": "string", "minLength": 1 },
        "action_role": { "$ref": "#/$defs/recoveryRole" },
        "keyboard_reachable": { "const": true }
      }
    },
    "entryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "route_ref", "keyboard_reachable", "activates_same_record"],
      "properties": {
        "surface": { "$ref": "#/$defs/routeSurface" },
        "route_ref": { "$ref": "#/$defs/canonicalRef" },
        "keyboard_reachable": { "const": true },
        "activates_same_record": { "const": true }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_order_index",
        "tab_stop_count",
        "row_narration",
        "action_labels",
        "layout_modes"
      ],
      "properties": {
        "focus_order_index": { "type": "integer", "minimum": 0 },
        "tab_stop_count": { "type": "integer", "minimum": 0 },
        "row_narration": { "type": "string", "minLength": 1 },
        "action_labels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "layout_modes": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["mode", "row_narration_available", "recovery_affordances_reachable"],
            "properties": {
              "mode": { "$ref": "#/$defs/layoutMode" },
              "row_narration_available": { "const": true },
              "recovery_affordances_reachable": { "const": true }
            }
          }
        }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "appearance_contract_ref",
        "component_state_registry_ref",
        "token_registry_refs",
        "contributing_capture_refs"
      ],
      "properties": {
        "appearance_contract_ref": { "$ref": "#/$defs/presentRef" },
        "component_state_registry_ref": { "$ref": "#/$defs/presentRef" },
        "token_registry_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "contributing_capture_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
