{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/start_center_surface.schema.json",
  "title": "Aureline Start Center, workspace-switcher, and open-flow disclosure record",
  "description": "Boundary schema for the Start Center, workspace-switcher, open-flow, restore-card, and recent-work disclosure contract frozen in docs/ux/start_center_contract.md. Freezes six record kinds: start_center_surface_record, start_center_primary_action_record, recent_work_row_disclosure_record, restore_card_record, disclosure_banner_record, and workspace_switcher_view_record. The contract mints no new entry-verb, target-kind, resulting-mode, restore-level, missing-target-state, recovery-class, trust-state, or next-step-decision-hook values; it re-exports those vocabularies from the entry-restore object model and quotes startup-state tokens from the entry-restore truth audit. Five start-center-local vocabularies are introduced and scoped: start_center_surface_family, start_center_zone, account_opt_in_posture, freshness_class / absence_class, and privacy_reduction_mode, plus the closed primary_action_id and restore_card_primary_action_id sets. Adding a new surface family, zone, posture, freshness class, privacy-reduction mode, primary action id, disclosure class, or restore-card action is additive-minor and bumps start_center_surface_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/start_center_surface_record" },
    { "$ref": "#/$defs/start_center_primary_action_record" },
    { "$ref": "#/$defs/recent_work_row_disclosure_record" },
    { "$ref": "#/$defs/restore_card_record" },
    { "$ref": "#/$defs/disclosure_banner_record" },
    { "$ref": "#/$defs/workspace_switcher_view_record" }
  ],
  "$defs": {
    "start_center_surface_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this Start Center / workspace-switcher disclosure vocabulary export. Current value is 1. Bumped only on breaking payload changes; additive-optional fields do not bump this version."
    },

    "record_kind": {
      "type": "string",
      "enum": [
        "start_center_surface_record",
        "start_center_primary_action_record",
        "recent_work_row_disclosure_record",
        "restore_card_record",
        "disclosure_banner_record",
        "workspace_switcher_view_record"
      ],
      "description": "Discriminator for the concrete payload shape. Every record carries exactly one kind."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests, support bundles, and claim manifests. Raw absolute paths, raw credentials, raw remote URLs, and raw competitor-config bodies never appear here."
    },

    "monotonic_timestamp": {
      "type": "string",
      "minLength": 1,
      "description": "Producer-local monotonic timestamp. Opaque to this schema; the exporter does not require any specific clock source."
    },

    "redaction_aware_text": {
      "type": "string",
      "maxLength": 1024,
      "description": "Redaction-aware free text (<= 1024 graphemes). The exporter is responsible for applying the redaction policy before the value crosses the boundary."
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional worked-example prelude carried on fixtures under __fixture__. Schema does not constrain shape beyond being an object."
    },

    "start_center_surface_family": {
      "type": "string",
      "enum": [
        "start_center",
        "workspace_switcher_palette",
        "workspace_switcher_menu",
        "workspace_switcher_dedicated_view",
        "open_flow_sheet",
        "restore_card"
      ],
      "description": "Closed set of startup-wedge surface families. See start_center_contract.md §3.1."
    },

    "start_center_zone": {
      "type": "string",
      "enum": [
        "primary_work_resume",
        "recent_work_list",
        "secondary_entry",
        "profile_selection",
        "disclosure_band",
        "help_and_build_identity_footer"
      ],
      "description": "Closed placement-zone vocabulary. Account nags, release-marketing, and marketplace-first content are forbidden above primary_work_resume on seeded startup states. See §3.2."
    },

    "account_opt_in_posture": {
      "type": "string",
      "enum": [
        "optional_local_path_available",
        "required_for_this_row",
        "deferred_review_pending",
        "unavailable_in_this_envelope"
      ],
      "description": "Account / service opt-in posture a row discloses. See §3.3."
    },

    "freshness_class": {
      "type": "string",
      "enum": [
        "live",
        "cached_with_timestamp",
        "stale_offline",
        "unknown_since",
        "not_installed",
        "fetch_deferred"
      ],
      "description": "Freshness disclosure axis for recent-work rows, cached onboarding / help packs, templates / prebuilds, and not-installed docs content. See §3.4."
    },

    "cached_timestamp_class": {
      "type": "string",
      "enum": [
        "minutes_ago",
        "hours_ago",
        "days_ago",
        "older",
        "unknown"
      ],
      "description": "Required when freshness_class is cached_with_timestamp; coarse bucket rendered on the row."
    },

    "absence_class": {
      "type": "string",
      "enum": [
        "never_acquired",
        "not_yet_materialised",
        "removed_by_user",
        "policy_blocked",
        "unreachable",
        "quarantined",
        "superseded_by_newer"
      ],
      "description": "Absence disclosure axis; only present when the row's target is not materialised. See §3.4."
    },

    "privacy_reduction_mode": {
      "type": "string",
      "enum": [
        "default",
        "hide_paths",
        "hide_recent_work",
        "hide_account_affordances",
        "hide_all_except_open_and_clone",
        "sensitive_environment_clear_on_launch"
      ],
      "description": "Privacy-reduction posture. Any non-default value requires a privacy_reduced_mode_notice disclosure banner in disclosure_band. See §3.5."
    },

    "privacy_redaction_applied": {
      "type": "string",
      "enum": [
        "subtitle_path",
        "account_affordance",
        "last_opened_at",
        "none"
      ],
      "description": "Which field class the active privacy_reduction_mode redacted on this row."
    },

    "primary_action_id": {
      "type": "string",
      "enum": [
        "primary_action.open_folder",
        "primary_action.open_workspace",
        "primary_action.clone_repository",
        "primary_action.restore_last_session",
        "primary_action.import_from",
        "primary_action.add_root",
        "primary_action.start_from_template_or_prebuild"
      ],
      "description": "Closed set of primary-action ids. The first five are the required first-launch primary actions on every non-takeover Start Center state. See §3.7."
    },

    "restore_card_primary_action_id": {
      "type": "string",
      "enum": [
        "restore_card.restore_now",
        "restore_card.skip_once",
        "restore_card.open_clean"
      ],
      "description": "Closed set of restore-card primary actions. A card that renders a generic Reopen / Continue CTA is non-conforming. See §3.8."
    },

    "disclosure_class": {
      "type": "string",
      "enum": [
        "account_state_disclosure",
        "service_state_disclosure",
        "policy_state_disclosure",
        "mirror_state_disclosure",
        "offline_state_disclosure",
        "extension_host_state_disclosure",
        "build_channel_identity",
        "privacy_reduced_mode_notice"
      ],
      "description": "Closed disclosure-banner class vocabulary. See §3.9."
    },

    "entry_verb": {
      "type": "string",
      "enum": [
        "open",
        "clone",
        "import",
        "add_root",
        "restore",
        "resume",
        "start_from_snapshot"
      ],
      "description": "Re-export of entry_verb from entry_and_restore_result.schema.json. Never redefined here. See entry_restore_object_model.md §1.1."
    },

    "target_kind": {
      "type": "string",
      "enum": [
        "local_file",
        "local_folder",
        "local_repo_root",
        "workspace_manifest",
        "workset_manifest",
        "remote_repository",
        "ssh_workspace",
        "container_workspace",
        "devcontainer_workspace",
        "managed_cloud_workspace",
        "portable_state_package",
        "handoff_packet",
        "competitor_config_root",
        "template_or_prebuild_snapshot",
        "review_or_work_item_deep_link",
        "recovery_checkpoint"
      ],
      "description": "Re-export of target_kind from entry_and_restore_result.schema.json. See §1.2."
    },

    "resulting_mode": {
      "type": "string",
      "enum": [
        "single_file",
        "folder",
        "repo_root",
        "workspace_candidate",
        "workspace_with_roots",
        "workset_slice",
        "inspect_only",
        "clone_then_review",
        "clone_then_open",
        "clone_then_add",
        "clone_only",
        "extract_then_review",
        "compare_before_restore",
        "apply_to_active_workspace",
        "open_prebuild_with_setup_actions",
        "open_prebuild_minimal",
        "resume_live_session",
        "restore_last_session",
        "restore_from_checkpoint"
      ],
      "description": "Re-export of resulting_mode from entry_and_restore_result.schema.json. See §1.3."
    },

    "trust_state": {
      "type": "string",
      "enum": ["trusted", "restricted", "pending_evaluation"],
      "description": "ADR-0001 identity-mode trust vocabulary. Re-exported unchanged."
    },

    "admission_class": {
      "type": "string",
      "enum": [
        "admitted",
        "trust_review_required",
        "policy_blocked",
        "needs_repair",
        "needs_reconnect",
        "needs_reauth"
      ],
      "description": "Re-export of admission_class. See entry_restore_object_model.md §1.4."
    },

    "portability_class": {
      "type": "string",
      "enum": [
        "local_only",
        "synced",
        "imported",
        "provider_linked",
        "stale"
      ],
      "description": "Re-export of portability_class. See §2.4."
    },

    "restore_availability": {
      "type": "string",
      "enum": [
        "exact",
        "compatible",
        "layout_only",
        "evidence_only",
        "none"
      ],
      "description": "Re-export of restore_availability. See §2.5."
    },

    "recent_work_target_state": {
      "type": "string",
      "enum": [
        "reachable",
        "stale_metadata",
        "missing_target",
        "moved_target_detected",
        "remote_unreachable",
        "authority_expired",
        "locked_by_other_instance",
        "policy_blocked",
        "quarantined",
        "mode_downgraded",
        "unknown"
      ],
      "description": "Re-export of recent_work_target_state. See §2.3."
    },

    "safe_recovery_action": {
      "type": "string",
      "enum": [
        "open",
        "open_in_new_window",
        "open_restricted",
        "locate_missing_target",
        "reconnect",
        "reauth",
        "open_read_only_cached_view",
        "retry_later",
        "compare_before_restore",
        "open_without_restore",
        "unpin",
        "pin",
        "remove_from_recents",
        "reveal_in_explorer"
      ],
      "description": "Re-export of safe_recovery_action. See §2.6."
    },

    "next_step_decision_hook": {
      "type": "string",
      "enum": [
        "continue_in_restricted_mode",
        "review_trust_and_open",
        "open_minimal",
        "set_up_later",
        "review_archetype_match",
        "compare_before_restore",
        "open_without_restore",
        "safe_mode",
        "reconnect_required",
        "reauth_required",
        "locate_missing_target",
        "remove_from_recents",
        "review_migration_report",
        "roll_back_import",
        "keep_imported_state",
        "adopt_recommended_bundle",
        "review_unsupported_items"
      ],
      "description": "Re-export of next_step_decision_hook. Free-form action labels are non-conforming."
    },

    "restore_level": {
      "type": "string",
      "enum": [
        "exact_restore",
        "compatible_restore",
        "layout_only",
        "recovered_drafts",
        "evidence_only",
        "no_restore"
      ],
      "description": "Re-export of restore_level. See entry_restore_object_model.md §3.1."
    },

    "missing_target_state": {
      "type": "string",
      "enum": [
        "fully_present",
        "missing_extension_host",
        "quarantined_extension",
        "missing_remote_target",
        "authority_expired_for_remote",
        "missing_toolchain",
        "missing_profile",
        "missing_devcontainer",
        "missing_managed_workspace",
        "topology_changed",
        "schema_migrated",
        "binary_or_extension_version_changed",
        "corrupt_restorable_state",
        "policy_blocked_restore"
      ],
      "description": "Re-export of missing_target_state. See §3.2."
    },

    "session_execution_posture": {
      "type": "string",
      "enum": [
        "transcript_restored_not_rerun",
        "session_ended",
        "reconnect_available",
        "rerun_required",
        "context_unavailable",
        "live_session_continued"
      ],
      "description": "Re-export of session-scoped execution posture. See §3.3."
    },

    "checkpoint_linked_recovery_class": {
      "type": "string",
      "enum": [
        "exact_rollback_from_checkpoint",
        "compensating_rollback",
        "regenerate_from_canonical_source",
        "restore_from_session_checkpoint",
        "restore_from_migration_checkpoint",
        "restore_from_settings_backup",
        "restore_from_recovery_journal",
        "restore_from_local_history_snapshot",
        "manual_recovery_required"
      ],
      "description": "Re-export of checkpoint-linked recovery class. See §4."
    },

    "startup_state_token": {
      "type": "string",
      "enum": [
        "startup_state:first_run",
        "startup_state:reopen_with_pending_restore",
        "startup_state:restore_failed",
        "startup_state:restore_skipped",
        "startup_state:open_without_restore",
        "startup_state:warming_startup",
        "startup_state:partial_startup",
        "startup_state:offline_startup",
        "startup_state:unsupported_startup",
        "startup_state:empty_state_or_placeholder_transition"
      ],
      "description": "Startup-state token re-exported from docs/ux/entry_restore_truth_audit.md §6."
    },

    "navigation_route_ref": {
      "type": "string",
      "enum": [
        "route.command_palette",
        "route.quick_open",
        "route.activity_rail",
        "route.sidebar",
        "route.breadcrumbs",
        "route.editor_tabs",
        "route.editor_group",
        "route.status_bar_link",
        "route.inspector_link",
        "route.global_menu",
        "route.context_menu",
        "route.notification_or_banner",
        "route.deep_link_or_protocol",
        "route.cli_invocation",
        "route.ai_tool_invocation",
        "route.open_recent_submenu",
        "route.switch_project",
        "route.dedicated_view"
      ],
      "description": "Re-export of navigation_route_id plus the two advertised later-reach routes later_reach_routes[] cites (route.open_recent_submenu, route.switch_project) and the dedicated-view route the workspace-switcher may host on. See docs/ux/navigation_and_escalation_contract.md §3."
    },

    "keyboard_reachability_posture": {
      "type": "string",
      "enum": [
        "all_primary_focusable",
        "all_primary_focusable_plus_escape_routes",
        "narrowed_keyboard_posture_with_disclosed_reason"
      ],
      "description": "Closed keyboard-reachability posture. Only all_primary_focusable (or the plus-escape-routes variant) is conforming on non-takeover states. The narrowed variant requires a disclosed_narrowing_reason."
    },

    "side_effect_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["setup_actions_class", "time_class", "connectivity_class", "cleanup_class", "bypass_path"],
      "properties": {
        "setup_actions_class": {
          "type": "string",
          "enum": [
            "no_setup_actions",
            "toolchain_detect_only",
            "dependency_install",
            "containerized_bootstrap",
            "devcontainer_bootstrap",
            "remote_attach",
            "browser_auth_handshake",
            "secret_handle_request",
            "mixed_setup"
          ]
        },
        "time_class": {
          "type": "string",
          "enum": ["instant", "fast", "moderate", "long_running", "network_dependent"]
        },
        "connectivity_class": {
          "type": "string",
          "enum": ["local_only", "local_with_registry", "remote_required", "mirror_or_air_gapped", "unknown"]
        },
        "cleanup_class": {
          "type": "string",
          "enum": ["no_cleanup_required", "cleanup_on_failure", "rollback_checkpoint_retained", "manual_cleanup_required"]
        },
        "bypass_path": {
          "type": "string",
          "enum": ["open_prebuild_minimal", "open_plain_folder", "set_up_later", "no_bypass_available"]
        }
      },
      "description": "Re-export of side_effect_envelope. Required on primary_action.start_from_template_or_prebuild and on clone records that attach managed / container / devcontainer runtimes at open time."
    },

    "pane_execution_posture_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pane_id", "session_execution_posture"],
      "properties": {
        "pane_id": { "$ref": "#/$defs/opaque_id" },
        "pane_class": {
          "type": "string",
          "enum": [
            "terminal",
            "task_runner",
            "debug",
            "notebook_kernel",
            "preview_server",
            "remote_tunnel",
            "editor_group",
            "other"
          ]
        },
        "session_execution_posture": { "$ref": "#/$defs/session_execution_posture" }
      },
      "description": "Per-pane session-execution posture row carried on restore cards so live_session_continued is never inferred from absence."
    },

    "start_center_primary_action_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "start_center_surface_schema_version",
        "primary_action_id",
        "entry_verb_candidate",
        "target_kind_candidates",
        "resulting_mode_candidates",
        "account_opt_in_posture",
        "next_step_decision_hooks",
        "disclosed_in_zone",
        "keyboard_reachable"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "start_center_primary_action_record" },
        "start_center_surface_schema_version": { "$ref": "#/$defs/start_center_surface_schema_version" },
        "primary_action_id": { "$ref": "#/$defs/primary_action_id" },
        "entry_verb_candidate": { "$ref": "#/$defs/entry_verb" },
        "target_kind_candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/target_kind" },
          "uniqueItems": true
        },
        "resulting_mode_candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/resulting_mode" },
          "uniqueItems": true
        },
        "account_opt_in_posture": { "$ref": "#/$defs/account_opt_in_posture" },
        "next_step_decision_hooks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/next_step_decision_hook" },
          "uniqueItems": true
        },
        "side_effect_envelope": { "$ref": "#/$defs/side_effect_envelope" },
        "disclosed_in_zone": { "$ref": "#/$defs/start_center_zone" },
        "keyboard_reachable": { "type": "boolean" },
        "disabled_reason_code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Optional disabled-reason code drawn from the command-descriptor disabled_reason_code vocabulary. Required when the action renders visible-but-disabled."
        },
        "restore_card_ref": { "$ref": "#/$defs/opaque_id" },
        "presentation_label": { "$ref": "#/$defs/redaction_aware_text" },
        "presentation_subtitle": { "$ref": "#/$defs/redaction_aware_text" }
      },
      "description": "One primary-action row on a Start Center or workspace-switcher surface. See start_center_contract.md §5."
    },

    "recent_work_row_disclosure_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "start_center_surface_schema_version",
        "recent_work_entry_ref",
        "presentation_label",
        "target_kind",
        "target_state",
        "portability_class",
        "trust_state",
        "restore_availability",
        "freshness_class",
        "account_opt_in_posture",
        "privacy_redaction_applied",
        "row_actions",
        "disclosed_in_zone",
        "pinned",
        "last_opened_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "recent_work_row_disclosure_record" },
        "start_center_surface_schema_version": { "$ref": "#/$defs/start_center_surface_schema_version" },
        "recent_work_entry_ref": { "$ref": "#/$defs/opaque_id" },
        "presentation_label": { "$ref": "#/$defs/redaction_aware_text" },
        "presentation_subtitle": { "$ref": "#/$defs/redaction_aware_text" },
        "target_kind": { "$ref": "#/$defs/target_kind" },
        "target_state": { "$ref": "#/$defs/recent_work_target_state" },
        "portability_class": { "$ref": "#/$defs/portability_class" },
        "trust_state": { "$ref": "#/$defs/trust_state" },
        "restore_availability": { "$ref": "#/$defs/restore_availability" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "cached_timestamp_class": { "$ref": "#/$defs/cached_timestamp_class" },
        "absence_class": { "$ref": "#/$defs/absence_class" },
        "account_opt_in_posture": { "$ref": "#/$defs/account_opt_in_posture" },
        "privacy_redaction_applied": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/privacy_redaction_applied" },
          "uniqueItems": true
        },
        "row_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/safe_recovery_action" },
          "uniqueItems": true
        },
        "disclosed_in_zone": {
          "type": "string",
          "enum": ["recent_work_list"],
          "description": "Recent-work rows render only in the recent_work_list zone."
        },
        "pinned": { "type": "boolean" },
        "last_opened_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "description": "One recent-work row's disclosure wrapping. Wraps the upstream recent_work_entry_record by ref and never contradicts its fields. See start_center_contract.md §6."
    },

    "restore_card_summary_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exact_restore_item_count",
        "dirty_buffer_recovery_item_count",
        "checkpoint_rollback_item_count",
        "evidence_only_item_count"
      ],
      "properties": {
        "exact_restore_item_count": { "type": "integer", "minimum": 0 },
        "dirty_buffer_recovery_item_count": { "type": "integer", "minimum": 0 },
        "checkpoint_rollback_item_count": { "type": "integer", "minimum": 0 },
        "evidence_only_item_count": { "type": "integer", "minimum": 0 }
      },
      "description": "Four separable counts on a restore card. A card that flattens these into a single aggregate is non-conforming. See start_center_contract.md §7.1."
    },

    "restore_card_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "start_center_surface_schema_version",
        "restore_prompt_ref",
        "restore_level",
        "recovery_class_refs",
        "summary_counts",
        "session_execution_posture_by_pane",
        "missing_target_states",
        "primary_actions",
        "disclosed_in_zone",
        "keyboard_reachable"
      ],
      "properties": {
