          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/checkpoint_linked_recovery_class" },
          "uniqueItems": true
        },
        "summary_counts": { "$ref": "#/$defs/restore_card_summary_counts" },
        "session_execution_posture_by_pane": {
          "type": "array",
