    "disclosure_banner_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "start_center_surface_schema_version",
        "disclosure_class",
        "disclosed_in_zone"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "disclosure_banner_record" },
        "start_center_surface_schema_version": { "$ref": "#/$defs/start_center_surface_schema_version" },
        "disclosure_class": { "$ref": "#/$defs/disclosure_class" },
        "disclosed_in_zone": { "$ref": "#/$defs/start_center_zone" },
        "account_opt_in_posture": { "$ref": "#/$defs/account_opt_in_posture" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "resolution_hooks": {
          "type": "array",
          "items": { "$ref": "#/$defs/next_step_decision_hook" },
          "uniqueItems": true
        },
        "build_channel_id": { "$ref": "#/$defs/opaque_id" },
        "channel_name": {
          "type": "string",
          "enum": ["stable", "beta", "nightly", "preview", "lts", "experimental"]
        },
        "presentation_label": { "$ref": "#/$defs/redaction_aware_text" },
        "presentation_subtitle": { "$ref": "#/$defs/redaction_aware_text" }
      },
      "allOf": [
        {
          "if": { "properties": { "disclosure_class": { "const": "build_channel_identity" } }, "required": ["disclosure_class"] },
          "then": {
            "required": ["build_channel_id", "channel_name"],
            "properties": {
              "disclosed_in_zone": { "const": "help_and_build_identity_footer" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "disclosure_class": {
                "enum": [
                  "account_state_disclosure",
                  "service_state_disclosure",
                  "policy_state_disclosure",
                  "mirror_state_disclosure",
                  "offline_state_disclosure",
                  "extension_host_state_disclosure",
                  "privacy_reduced_mode_notice"
                ]
              }
            },
            "required": ["disclosure_class"]
          },
          "then": {
            "required": ["resolution_hooks"],
            "properties": {
              "resolution_hooks": { "minItems": 1 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "disclosure_class": {
                "enum": [
                  "account_state_disclosure",
                  "service_state_disclosure",
                  "policy_state_disclosure"
                ]
              }
            },
            "required": ["disclosure_class"]
          },
          "then": {
            "required": ["account_opt_in_posture"]
          }
        },
        {
          "if": {
            "properties": {
              "disclosure_class": {
                "enum": [
                  "service_state_disclosure",
                  "mirror_state_disclosure",
                  "offline_state_disclosure"
                ]
              }
            },
            "required": ["disclosure_class"]
          },
          "then": {
            "required": ["freshness_class"]
          }
        }
      ],
      "description": "Disclosure banner for account / service / policy / mirror / offline / extension-host / privacy / build-channel state. See start_center_contract.md §8."
    },

