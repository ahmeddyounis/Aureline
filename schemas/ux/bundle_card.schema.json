{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/bundle_card.schema.json",
  "title": "Aureline Start Center bundle card",
  "description": "Boundary schema for the start_center_bundle_card_record frozen in docs/ux/start_center_bundle_surfaces.md. Every Start Center bundle row, gallery / browse-bundles row, workspace-switcher bundle row, update-detail entry, and export-facing bundle summary that lets a user inspect a bundle before install MUST resolve through this record. The card carries bundle identity (id, revision), bundle class, bundle source class, bundle status class, signer source / continuity / signature class, support class, channel relation, mirror or offline packaging posture, persona / stack tag refs, archetype tag refs, compatible Aureline range, evidence-badge ids, freshness overlay, availability narrowing, policy notice ref, local / offline availability class, optional disabled reason, typed card actions, successor recommendation class, lifecycle state class, evidence age class, retest-needed posture, and a ref to the companion bundle detail-page record. Raw signing keys, raw certificate material, raw repository URLs, raw absolute paths, raw secrets, raw extension binaries, and raw user-authored content never cross this boundary; records carry opaque refs, closed vocabulary, timestamps, and short reviewable summaries only. Adding a new bundle_card_surface_family, bundle_evidence_badge_id, bundle_card_action_id, bundle_card_zone, bundle_card_freshness_overlay, or local_offline_availability_class value is additive-minor and bumps bundle_card_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "$ref": "#/$defs/start_center_bundle_card_record",
  "$defs": {
    "bundle_card_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version. Current value is 1. Bumped on additive-minor enum or field additions; repurposing or removal is breaking and requires a decision row."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests, support bundles, and claim manifests. Raw absolute paths, raw URLs, raw credentials, raw key material, and raw user content never appear here."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "redaction_aware_text": {
      "type": "string",
      "maxLength": 1024,
      "description": "Redaction-aware free text (<= 1024 graphemes). The exporter is responsible for applying the redaction policy before the value crosses the boundary."
    },
    "reviewable_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Short reviewer-facing summary already scrubbed by the producer."
    },
    "monotonic_timestamp": {
      "type": "string",
      "minLength": 1,
      "description": "Producer-local monotonic timestamp opaque to this schema."
    },
    "semver_string": {
      "type": "string",
      "minLength": 1
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional worked-example prelude carried on fixtures under __fixture__. Schema does not constrain shape beyond being an object."
    },

    "bundle_class": {
      "type": "string",
      "enum": [
        "launch_bundle",
        "imported_user_bundle",
        "org_approved_bundle",
        "design_partner_bundle",
        "local_draft_bundle"
      ],
      "description": "Re-exported from schemas/workflow/bundle_manifest.schema.json. See docs/workflow/workflow_bundle_object_model.md §3.1."
    },
    "bundle_source_class": {
      "type": "string",
      "enum": [
        "certified",
        "managed_approved",
        "community",
        "imported",
        "local_draft"
      ]
    },
    "bundle_status_class": {
      "type": "string",
      "enum": [
        "certified_current",
        "certified_retest_pending",
        "managed_approved_current",
        "community_reviewed",
        "community_unreviewed",
        "imported_pending_review",
        "local_draft",
        "deprecated_or_archived",
        "retest_needed",
        "status_unknown"
      ]
    },
    "bundle_signer_source_class": {
      "type": "string",
      "enum": [
        "core_signing_root",
        "core_signing_root_via_mirror",
        "org_policy_signing_root",
        "org_mirror_signing_root",
        "community_channel_signature",
        "signed_offline_bundle_root",
        "repo_local_workspace_trust",
        "local_user_trust_only",
        "unsigned_user_review_required",
        "trust_source_unknown_review_required"
      ]
    },
    "signer_continuity_class": {
      "type": "string",
      "enum": [
        "continuous_with_previous_acquisition",
        "first_acquisition_no_prior_signer",
        "signer_changed_review_required",
        "signer_unknown_user_review_required",
        "signer_continuity_not_applicable"
      ]
    },
    "signature_class": {
      "type": "string",
      "enum": [
        "unsigned",
        "author_signature",
        "author_and_organization_signature",
        "organization_signature_only",
        "managed_only_channel_signature",
        "quarantined_no_signature"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "officially_supported",
        "community_supported",
        "experimental",
        "legacy_deprecated",
        "unsupported",
        "support_unknown"
      ]
    },
    "bundle_channel_relation_class": {
      "type": "string",
      "enum": [
        "same_channel_revision",
        "cross_channel_promotion",
        "cross_channel_demotion",
        "branch_or_fork_revision",
        "not_applicable_local_draft"
      ]
    },
    "mirror_or_offline_packaging_posture": {
      "type": "string",
      "enum": [
        "live_origin_only",
        "live_or_mirror",
        "mirror_only",
        "signed_offline_bundle",
        "offline_no_bundle",
        "packaging_posture_unknown"
      ]
    },
    "lifecycle_state_class": {
      "type": "string",
      "enum": [
        "active_supported",
        "soft_deprecated_with_successor",
        "hard_deprecated_remove_recommended",
        "retest_needed",
        "evidence_aged",
        "removed_unavailable",
        "rollback_recommended",
        "lifecycle_unknown"
      ]
    },
    "successor_recommendation_class": {
      "type": "string",
      "enum": [
        "no_successor",
        "successor_recommended_same_class",
        "successor_recommended_different_class",
        "successor_recommended_first_party_native",
        "successor_unknown"
      ]
    },
    "evidence_age_class": {
      "type": "string",
      "enum": [
        "fresh_current",
        "aging_within_window",
        "stale_past_window",
        "age_unknown"
      ]
    },
    "retest_needed_posture": {
      "type": "string",
      "enum": [
        "not_required",
        "retest_recommended",
        "retest_required",
        "retest_blocked"
      ]
    },
    "availability_narrowing_class": {
      "type": "string",
      "enum": [
        "mirror_only_subset",
        "signed_offline_bundle_subset",
        "policy_blocked",
        "signature_review_required",
        "target_runtime_unavailable",
        "fully_available"
      ],
      "description": "Re-exported from docs/ux/template_and_prebuild_contract.md §3.8 (extended with fully_available so a card may render the absence verbatim)."
    },
    "disabled_reason_code": {
      "type": "string",
      "enum": [
        "policy_narrowed_fleet",
        "policy_narrowed_admin",
        "policy_narrowed_workspace_trust",
        "mirror_only_cached_subset",
        "signature_review_required",
        "uncertified_excluded",
        "target_runtime_unavailable",
        "network_unreachable",
        "rebuild_required"
      ]
    },
    "archetype_row_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque archetype row id from artifacts/qe/workflow_bundle_ids.yaml."
    },
    "archetype_revision": {
      "type": "integer",
      "minimum": 1
    },
    "archetype_tag_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["archetype_row_id", "archetype_revision"],
      "properties": {
        "archetype_row_id": { "$ref": "#/$defs/archetype_row_id" },
        "archetype_revision": { "$ref": "#/$defs/archetype_revision" },
        "binding_summary_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },

    "runtime_compatibility_range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_aureline_runtime_version",
        "maximum_aureline_runtime_version_exclusive",
        "compatible_release_channel_refs"
      ],
      "properties": {
        "minimum_aureline_runtime_version": { "$ref": "#/$defs/semver_string" },
        "maximum_aureline_runtime_version_exclusive": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/semver_string" }
          ]
        },
        "compatible_release_channel_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "compatibility_note_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      },
      "description": "Re-exported from schemas/workflow/bundle_manifest.schema.json. See docs/workflow/workflow_bundle_object_model.md §5.1."
    },

    "bundle_card_surface_family": {
      "type": "string",
      "enum": [
        "start_center_bundle_row",
        "gallery_browse_bundles_row",
        "workspace_switcher_bundle_row",
        "update_detail_entry",
        "export_facing_bundle_summary"
      ],
      "description": "Closed surface-family vocabulary. See docs/ux/start_center_bundle_surfaces.md §3.1."
    },
    "bundle_card_zone": {
      "type": "string",
      "enum": [
        "start_center.primary_work_resume",
        "start_center.secondary_entry",
        "gallery.body",
        "update_detail.body",
        "export_summary.body"
      ],
      "description": "Closed zone vocabulary for bundle card placement. See §3.5."
    },
    "bundle_evidence_badge_id": {
      "type": "string",
      "enum": [
        "badge.certified",
        "badge.managed_approved",
        "badge.community",
        "badge.imported",
        "badge.local_draft",
        "badge.retest_pending",
        "badge.deprecated",
        "badge.status_unknown",
        "badge.signed_offline_bundle",
        "badge.mirror_only",
        "badge.live_or_mirror",
        "badge.live_origin_only",
        "badge.offline_no_bundle"
      ],
      "description": "Closed evidence-and-status badge vocabulary. Every badge resolves to a manifest field per §3.2 / §4.3."
    },
    "bundle_card_action_id": {
      "type": "string",
      "enum": [
        "bundle_card.review_bundle",
        "bundle_card.compare_with_installed",
        "bundle_card.view_certification_sheet",
        "bundle_card.view_changelog",
        "bundle_card.view_known_limits",
        "bundle_card.view_successor",
        "bundle_card.export_summary_row",
        "bundle_card.dismiss"
      ],
      "description": "Closed typed-action vocabulary. Free-form action labels are non-conforming. See §3.3."
    },
    "bundle_card_freshness_overlay": {
      "type": "string",
      "enum": [
        "freshness.fresh_current",
        "freshness.aging_within_window",
        "freshness.stale_past_window",
        "freshness.age_unknown"
      ],
      "description": "Freshness overlay rendered on top of the manifest's evidence_age_class. See §3.6."
    },
    "local_offline_availability_class": {
      "type": "string",
      "enum": [
        "available_live",
        "available_via_mirror",
        "available_offline_signed_bundle",
        "unavailable_offline_or_mirror_only",
        "availability_unknown"
      ],
      "description": "Closed local / offline availability vocabulary derived from mirror_or_offline_packaging_posture. See §4.1."
    },

    "bundle_card_action_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "keyboard_reachable"],
      "properties": {
        "action_id": { "$ref": "#/$defs/bundle_card_action_id" },
        "keyboard_reachable": { "type": "boolean" },
        "rendered_state": {
          "type": "string",
          "enum": ["enabled", "visible_disabled", "hidden_not_applicable"],
          "description": "Optional render state. Defaults to enabled. visible_disabled requires a disabled_reason_code; hidden_not_applicable is reserved for actions whose preconditions are not met (e.g. view_successor when there is no successor)."
        },
        "disabled_reason_code": { "$ref": "#/$defs/disabled_reason_code" },
        "presentation_label": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },

    "successor_recommendation_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["successor_recommendation_class"],
      "properties": {
        "successor_recommendation_class": { "$ref": "#/$defs/successor_recommendation_class" },
        "successor_bundle_id": { "$ref": "#/$defs/nullable_opaque_id" },
        "successor_bundle_revision": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 1 }
          ]
        },
        "successor_summary_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "decision_row_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      },
      "description": "Re-exported from the manifest's lifecycle.successor_recommendation block. See workflow_bundle_object_model.md §8.1."
    },

    "start_center_bundle_card_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "bundle_card_schema_version",
        "card_id",
        "bundle_id",
        "bundle_revision",
        "bundle_card_surface_family",
        "bundle_card_zone",
        "bundle_class",
        "bundle_source_class",
        "bundle_status_class",
        "bundle_signer_source_class",
        "signer_continuity_class",
        "signature_class",
        "support_class",
        "bundle_channel_relation_class",
        "mirror_or_offline_packaging_posture",
        "archetype_tag_refs",
        "persona_or_stack_tag_refs",
        "compatible_aureline_range",
        "evidence_badge_ids",
        "freshness_overlay",
        "local_offline_availability_class",
        "card_actions",
        "successor_recommendation",
        "lifecycle_state_class",
        "evidence_age_class",
        "retest_needed_posture",
        "bundle_detail_page_ref",
        "keyboard_reachable",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "start_center_bundle_card_record" },
        "bundle_card_schema_version": { "$ref": "#/$defs/bundle_card_schema_version" },
        "card_id": { "$ref": "#/$defs/opaque_id" },
        "bundle_id": { "$ref": "#/$defs/opaque_id" },
        "bundle_revision": { "type": "integer", "minimum": 1 },
        "bundle_revision_semver": { "$ref": "#/$defs/semver_string" },
        "bundle_card_surface_family": { "$ref": "#/$defs/bundle_card_surface_family" },
        "bundle_card_zone": { "$ref": "#/$defs/bundle_card_zone" },
        "bundle_class": { "$ref": "#/$defs/bundle_class" },
        "bundle_source_class": { "$ref": "#/$defs/bundle_source_class" },
        "bundle_status_class": { "$ref": "#/$defs/bundle_status_class" },
        "bundle_signer_source_class": { "$ref": "#/$defs/bundle_signer_source_class" },
        "signer_continuity_class": { "$ref": "#/$defs/signer_continuity_class" },
        "signature_class": { "$ref": "#/$defs/signature_class" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "bundle_channel_relation_class": { "$ref": "#/$defs/bundle_channel_relation_class" },
        "mirror_or_offline_packaging_posture": { "$ref": "#/$defs/mirror_or_offline_packaging_posture" },
        "archetype_tag_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/archetype_tag_ref" }
        },
        "persona_or_stack_tag_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Opaque tag refs (e.g. persona_tag:typescript_web_app_developer, stack_tag:rust_systems). Free-text persona strings are non-conforming."
        },
        "compatible_aureline_range": { "$ref": "#/$defs/runtime_compatibility_range" },
        "evidence_badge_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bundle_evidence_badge_id" },
          "uniqueItems": true
        },
        "freshness_overlay": { "$ref": "#/$defs/bundle_card_freshness_overlay" },
        "availability_narrowing_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/availability_narrowing_class" }
          ]
        },
        "policy_notice_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "local_offline_availability_class": { "$ref": "#/$defs/local_offline_availability_class" },
        "disabled_reason_code": { "$ref": "#/$defs/disabled_reason_code" },
        "card_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bundle_card_action_record" }
        },
        "successor_recommendation": { "$ref": "#/$defs/successor_recommendation_block" },
        "lifecycle_state_class": { "$ref": "#/$defs/lifecycle_state_class" },
        "evidence_age_class": { "$ref": "#/$defs/evidence_age_class" },
        "retest_needed_posture": { "$ref": "#/$defs/retest_needed_posture" },
        "bundle_detail_page_ref": { "$ref": "#/$defs/opaque_id" },
        "keyboard_reachable": { "const": true },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "presentation_label": { "$ref": "#/$defs/redaction_aware_text" },
        "presentation_subtitle": { "$ref": "#/$defs/redaction_aware_text" },
        "card_summary_ref": { "$ref": "#/$defs/opaque_id" }
      },
      "allOf": [
        {
          "description": "Local-draft bundles MUST resolve through local-only signers; promotion requires a new manifest revision in a new class.",
          "if": {
            "properties": { "bundle_class": { "const": "local_draft_bundle" } },
            "required": ["bundle_class"]
          },
          "then": {
            "properties": {
              "bundle_signer_source_class": {
                "enum": [
                  "local_user_trust_only",
                  "unsigned_user_review_required",
                  "repo_local_workspace_trust"
                ]
              },
              "bundle_status_class": { "const": "local_draft" }
            }
          }
        },
        {
          "description": "Card actions MUST include bundle_card.review_bundle on every non-takeover card.",
          "properties": {
            "card_actions": {
              "contains": {
                "type": "object",
                "properties": { "action_id": { "const": "bundle_card.review_bundle" } },
                "required": ["action_id"]
              }
            }
          },
          "required": ["card_actions"]
        },
        {
          "description": "badge.certified is forbidden when status is not certified_current; downgrade to badge.retest_pending per §4.3 rule 1.",
          "if": {
            "properties": {
              "evidence_badge_ids": {
                "type": "array",
                "contains": { "const": "badge.certified" }
              }
            },
            "required": ["evidence_badge_ids"]
          },
          "then": {
            "properties": {
              "bundle_status_class": { "const": "certified_current" },
              "evidence_age_class": { "const": "fresh_current" },
              "retest_needed_posture": { "const": "not_required" }
            }
          }
        },
        {
          "description": "badge.managed_approved is forbidden when status is not managed_approved_current.",
          "if": {
            "properties": {
              "evidence_badge_ids": {
                "type": "array",
                "contains": { "const": "badge.managed_approved" }
              }
            },
            "required": ["evidence_badge_ids"]
          },
          "then": {
            "properties": {
              "bundle_status_class": { "const": "managed_approved_current" }
            }
          }
        },
        {
          "description": "When bundle_status_class is status_unknown, the card MUST cite a typed disabled_reason_code.",
          "if": {
            "properties": { "bundle_status_class": { "const": "status_unknown" } },
            "required": ["bundle_status_class"]
          },
          "then": {
            "required": ["disabled_reason_code"]
          }
        },
        {
          "description": "Cards in the start_center.primary_work_resume zone MUST resolve to certified_current or managed_approved_current status.",
          "if": {
            "properties": { "bundle_card_zone": { "const": "start_center.primary_work_resume" } },
            "required": ["bundle_card_zone"]
          },
          "then": {
            "properties": {
              "bundle_status_class": {
                "enum": ["certified_current", "managed_approved_current"]
              }
            }
          }
        },
        {
          "description": "Launch-class bundles MUST cite at least one archetype binding tag.",
          "if": {
            "properties": { "bundle_class": { "const": "launch_bundle" } },
            "required": ["bundle_class"]
          },
          "then": {
            "properties": {
              "archetype_tag_refs": { "minItems": 1 }
            }
          }
        },
        {
          "description": "Cards on the update_detail_entry family MUST advertise view_changelog as one of the card_actions.",
          "if": {
            "properties": { "bundle_card_surface_family": { "const": "update_detail_entry" } },
            "required": ["bundle_card_surface_family"]
          },
          "then": {
            "properties": {
              "card_actions": {
                "contains": {
                  "type": "object",
                  "properties": { "action_id": { "const": "bundle_card.view_changelog" } },
                  "required": ["action_id"]
                }
              }
            }
          }
        }
      ],
      "description": "Inspectable Start Center / gallery / browse-bundles / update-detail / export-facing bundle card. See docs/ux/start_center_bundle_surfaces.md §4."
    }
  }
}
