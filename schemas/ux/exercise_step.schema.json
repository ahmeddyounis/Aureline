{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/exercise_step.schema.json",
  "title": "Aureline exercise step authoring artifact",
  "description": "Boundary schema for the exercise step authoring artifact frozen in docs/ux/learning_artifact_object_model.md. One exercise_step_artifact record per authored exercise step. The record is the portable authoring object pack authors ship; the runtime guided_surface_state_record on schemas/ux/guided_surface_state.schema.json carries the render-time state for an exercise_step surface and resolves against this artifact by id. The contract mints no new exercise_mutation_posture, layout_target_class, deployment_profile_id, or redaction_class vocabulary; those re-export verbatim from schemas/ux/guided_surface_state.schema.json, schemas/ux/guided_tour.schema.json, schemas/governance/capability_lifecycle.schema.json, and artifacts/governance/deployment_profiles.yaml. Adding a new sandbox_class, reversibility_class, completion_detector_kind, target_ref_kind, jargon_level_class, privacy_scope_class, or denial_reason is additive-minor and bumps exercise_step_artifact_schema_version; repurposing an existing value is breaking and requires a new decision row. Raw URLs, raw absolute paths, raw screen coordinates, raw step bodies, raw prompt / completion text, and raw credential material never cross this boundary.",
  "type": "object",
  "$ref": "#/$defs/exercise_step_artifact",
  "$defs": {
    "exercise_step_artifact_schema_version": {
      "type": "integer",
      "const": 1
    },

    "record_kind": {
      "type": "string",
      "const": "exercise_step_artifact"
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },

    "body_summary_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },

    "bcp47_locale_tag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": { "type": "object", "additionalProperties": true },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "jargon_level_class": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced", "expert"]
    },

    "privacy_scope_class": {
      "type": "string",
      "enum": [
        "local_only_machine_bound",
        "profile_portable",
        "classroom_managed_pool",
        "facilitator_only",
        "audience_visible"
      ]
    },

    "sandbox_class": {
      "type": "string",
      "enum": [
        "read_only_walkthrough",
        "mutates_workspace_after_ack",
        "mutates_in_isolated_sandbox",
        "blocked_until_trust_granted"
      ],
      "description": "Closed sandbox vocabulary describing whether the exercise mutates the workspace, runs in an isolated sandbox, or is blocked until workspace trust is granted. See learning_artifact_object_model.md §5."
    },

    "reversibility_class": {
      "type": "string",
      "enum": [
        "reversible_via_command",
        "reversible_via_undo_history",
        "irreversible_requires_explicit_ack"
      ],
      "description": "Closed reversibility vocabulary. Required on mutating exercises; a mutating exercise without a reversibility declaration is non-conforming."
    },

    "exercise_mutation_posture": {
      "type": "string",
      "enum": [
        "read_only_walkthrough",
        "mutates_workspace_after_ack",
        "blocked_until_trust_granted"
      ],
      "description": "Re-exported from schemas/ux/guided_surface_state.schema.json without modification. MUST agree with sandbox_class on this artifact."
    },

    "derivation_class": {
      "type": "string",
      "enum": ["primary", "derived", "derived_with_upstream_anchors"]
    },

    "layout_target_class": {
      "type": "string",
      "enum": [
        "start_center",
        "command_palette",
        "workspace_switcher",
        "primary_editor",
        "docs_pane",
        "architecture_map_canvas",
        "review_pane",
        "activity_center",
        "support_center",
        "settings_pane",
        "no_canvas_target_facilitator_only"
      ]
    },

    "deployment_profile_id": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud",
        "air_gapped_mirror_only"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": { "type": "string", "enum": ["trusted", "restricted"] },
        "execution_context_id": { "type": "string", "minLength": 1 }
      }
    },

    "target_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_kind"],
      "oneOf": [
        { "required": ["target_kind", "command_id_ref"] },
        { "required": ["target_kind", "docs_citation_anchor_ref"] },
        { "required": ["target_kind", "symbol_linked_reference_ref"] },
        { "required": ["target_kind", "keymap_bridge_ref"] },
        { "required": ["target_kind", "layout_target_class"] }
      ],
      "properties": {
        "target_kind": {
          "type": "string",
          "enum": [
            "command_id_target",
            "docs_citation_anchor_target",
            "symbol_linked_reference_target",
            "keymap_bridge_target",
            "layout_target"
          ]
        },
        "command_id_ref": { "$ref": "#/$defs/opaque_id" },
        "docs_citation_anchor_ref": { "$ref": "#/$defs/opaque_id" },
        "symbol_linked_reference_ref": { "$ref": "#/$defs/opaque_id" },
        "keymap_bridge_ref": { "$ref": "#/$defs/opaque_id" },
        "layout_target_class": { "$ref": "#/$defs/layout_target_class" }
      }
    },

    "completion_detector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["detector_kind"],
      "properties": {
        "detector_kind": {
          "type": "string",
          "enum": [
            "command_invocation_detector",
            "docs_anchor_seen_detector",
            "layout_focus_detector",
            "time_window_detector",
            "manual_acknowledge_detector"
          ]
        },
        "command_id_ref": { "$ref": "#/$defs/opaque_id" },
        "docs_citation_anchor_ref": { "$ref": "#/$defs/opaque_id" },
        "layout_target_class": { "$ref": "#/$defs/layout_target_class" },
        "max_duration_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 }
      },
      "allOf": [
        {
          "if": { "properties": { "detector_kind": { "const": "command_invocation_detector" } }, "required": ["detector_kind"] },
          "then": { "required": ["command_id_ref"] }
        },
        {
          "if": { "properties": { "detector_kind": { "const": "docs_anchor_seen_detector" } }, "required": ["detector_kind"] },
          "then": { "required": ["docs_citation_anchor_ref"] }
        },
        {
          "if": { "properties": { "detector_kind": { "const": "layout_focus_detector" } }, "required": ["detector_kind"] },
          "then": { "required": ["layout_target_class"] }
        },
        {
          "if": { "properties": { "detector_kind": { "const": "time_window_detector" } }, "required": ["detector_kind"] },
          "then": { "required": ["max_duration_seconds"] }
        }
      ]
    },

    "denial_reason": {
      "type": "string",
      "enum": [
        "learning_artifact_target_ref_not_canonical",
        "learning_artifact_promised_citation_missing",
        "learning_artifact_cites_forbidden_target",
        "learning_artifact_hidden_write_path",
        "learning_artifact_completion_detector_missing",
        "learning_artifact_mutating_exercise_without_reversibility",
        "learning_artifact_mutation_posture_mismatch",
        "learning_artifact_mutating_exercise_completion_detector_mismatch",
        "learning_artifact_privacy_scope_envelope_mismatch",
        "exercise_step_artifact_schema_version_lagging"
      ]
    },

    "exercise_step_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "exercise_step_artifact_schema_version",
        "step_id",
        "pack_revision_ref",
        "position_index",
        "default_locale",
        "title_short_label",
        "body_summary",
        "jargon_level_class",
        "target_ref",
        "completion_detector",
        "allowed_action_refs",
        "sandbox_class",
        "mutation_posture",
        "derivation_class",
        "deployment_profile_refs",
        "privacy_scope_class",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "exercise_step_artifact_schema_version": {
          "$ref": "#/$defs/exercise_step_artifact_schema_version"
        },
        "step_id": { "$ref": "#/$defs/opaque_id" },
        "tour_pack_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Optional opaque pin to a tour pack the exercise ships in. Exercises MAY ship outside a tour bundle."
        },
        "pack_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "position_index": { "type": "integer", "minimum": 0 },
        "default_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "title_short_label": { "$ref": "#/$defs/short_label_text" },
        "body_summary": { "$ref": "#/$defs/body_summary_text" },
        "jargon_level_class": { "$ref": "#/$defs/jargon_level_class" },
        "target_ref": { "$ref": "#/$defs/target_ref" },
        "completion_detector": { "$ref": "#/$defs/completion_detector" },
        "allowed_action_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Opaque pins to canonical command_ids on schemas/commands/command_registry_entry.schema.json. Empty array is admissible only when sandbox_class = blocked_until_trust_granted (no actions are exposed until trust is granted)."
        },
        "sandbox_class": { "$ref": "#/$defs/sandbox_class" },
        "reversibility_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reversibility_class" }
          ],
          "description": "Required (non-null) when sandbox_class is mutates_workspace_after_ack or mutates_in_isolated_sandbox. Null otherwise."
        },
        "mutation_posture": { "$ref": "#/$defs/exercise_mutation_posture" },
        "primary_docs_citation_anchor_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "upstream_citation_anchor_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "derivation_class": { "$ref": "#/$defs/derivation_class" },
        "deployment_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "privacy_scope_class": { "$ref": "#/$defs/privacy_scope_class" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "denial_reason_on_deny": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/denial_reason" }
          ]
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Mutating exercises (mutates_workspace_after_ack or mutates_in_isolated_sandbox) require a non-null reversibility_class.",
          "if": {
            "properties": {
              "sandbox_class": {
                "enum": ["mutates_workspace_after_ack", "mutates_in_isolated_sandbox"]
              }
            },
            "required": ["sandbox_class"]
          },
          "then": {
            "properties": {
              "reversibility_class": { "$ref": "#/$defs/reversibility_class" }
            },
            "required": ["reversibility_class"]
          }
        },
        {
          "description": "Read-only and trust-blocked sandbox classes forbid a non-null reversibility_class (the row has no mutation to reverse).",
          "if": {
            "properties": {
              "sandbox_class": {
                "enum": ["read_only_walkthrough", "blocked_until_trust_granted"]
              }
            },
            "required": ["sandbox_class"]
          },
          "then": {
            "properties": { "reversibility_class": { "type": "null" } }
          }
        },
        {
          "description": "mutation_posture agrees with sandbox_class. read_only_walkthrough <-> read_only_walkthrough, blocked_until_trust_granted <-> blocked_until_trust_granted, mutates_workspace_after_ack covers the workspace-mutation and isolated-sandbox cases.",
          "oneOf": [
            {
              "properties": {
                "sandbox_class": { "const": "read_only_walkthrough" },
                "mutation_posture": { "const": "read_only_walkthrough" }
              }
            },
            {
              "properties": {
                "sandbox_class": { "const": "blocked_until_trust_granted" },
                "mutation_posture": { "const": "blocked_until_trust_granted" }
              }
            },
            {
              "properties": {
                "sandbox_class": {
                  "enum": ["mutates_workspace_after_ack", "mutates_in_isolated_sandbox"]
                },
                "mutation_posture": { "const": "mutates_workspace_after_ack" }
              }
            }
          ]
        },
        {
          "description": "Mutating exercises MUST complete via command_invocation_detector pinning a command_id_ref so completion follows from a governed action.",
          "if": {
            "properties": {
              "sandbox_class": {
                "enum": ["mutates_workspace_after_ack", "mutates_in_isolated_sandbox"]
              }
            },
            "required": ["sandbox_class"]
          },
          "then": {
            "properties": {
              "completion_detector": {
                "properties": {
                  "detector_kind": { "const": "command_invocation_detector" }
                },
                "required": ["detector_kind", "command_id_ref"]
              }
            }
          }
        },
        {
          "description": "blocked_until_trust_granted exercises forbid allowed_action_refs entries; no action is exposed until trust is granted.",
          "if": {
            "properties": { "sandbox_class": { "const": "blocked_until_trust_granted" } },
            "required": ["sandbox_class"]
          },
          "then": {
            "properties": {
              "allowed_action_refs": { "type": "array", "maxItems": 0 }
            }
          }
        },
        {
          "description": "derived_with_upstream_anchors requires at least one upstream anchor; primary forbids them.",
          "if": {
            "properties": { "derivation_class": { "const": "derived_with_upstream_anchors" } },
            "required": ["derivation_class"]
          },
          "then": {
            "properties": {
              "upstream_citation_anchor_refs": { "type": "array", "minItems": 1 }
            }
          }
        },
        {
          "description": "primary derivation forbids upstream anchors.",
          "if": {
            "properties": { "derivation_class": { "const": "primary" } },
            "required": ["derivation_class"]
          },
          "then": {
            "properties": {
              "upstream_citation_anchor_refs": { "type": "array", "maxItems": 0 }
            }
          }
        }
      ],
      "description": "One exercise step authoring artifact. See docs/ux/learning_artifact_object_model.md §1.3."
    }
  }
}
