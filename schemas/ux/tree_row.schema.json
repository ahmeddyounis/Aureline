{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/tree_row.schema.json",
  "title": "Aureline structural tree row and tree-view interaction contract",
  "description": "Boundary schema for the structural tree row and tree-view interaction contracts frozen in docs/ux/tree_row_contract.md and docs/ux/tree_view_contract.md. File trees, outline trees, schema trees, package trees, component/runtime trees, route and dependency trees, write-scope preview trees, and support/export projections use this shared row anatomy, disclosure, lazy-hydration, virtualization, selection, action-exposure, provider-fallback, hidden-scope, and identity/recovery vocabulary. The eventual shell / workspace / graph Rust types are the source of record; this schema is the cross-tool boundary every non-owning surface reads. Adding enum values, optional fields, or additive sub-records is additive-minor and bumps tree_row_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/tree_row_record" },
    { "$ref": "#/$defs/tree_placeholder_record" },
    { "$ref": "#/$defs/tree_surface_snapshot_record" },
    { "$ref": "#/$defs/tree_view_snapshot_record" }
  ],
  "$defs": {
    "tree_row_schema_version": {
      "type": "integer",
      "const": 2,
      "description": "Integer schema version for the structural tree row and tree-view contract export. Current value is 2."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "tree_row_record",
        "tree_placeholder_record",
        "tree_surface_snapshot_record",
        "tree_view_snapshot_record"
      ],
      "description": "Discriminator for the concrete tree-row payload shape."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "description": "Optional worked-example prelude carried by fixtures."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe for logs, RPC, support export, and fixtures. Raw credentials and raw provider payloads never appear here."
    },
    "redaction_aware_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },
    "scope_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "id"],
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "workspace",
            "window",
            "workspace_root",
            "workset",
            "sparse_slice",
            "review_workspace",
            "remote_session",
            "runtime_session",
            "support_export"
          ]
        },
        "id": { "$ref": "#/$defs/opaque_id" }
      },
      "description": "Typed scope the tree row, placeholder, or snapshot belongs to."
    },
    "count_value": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "value"],
          "properties": {
            "status": { "const": "exact" },
            "value": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "value"],
          "properties": {
            "status": { "const": "approximate" },
            "value": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "const": "unknown" }
          }
        }
      ],
      "description": "Exact, approximate, or unknown count truth."
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "file_tree",
        "outline_tree",
        "schema_tree",
        "package_tree",
        "component_tree",
        "runtime_tree",
        "route_tree",
        "dependency_tree",
        "write_scope_preview_tree",
        "support_export_tree"
      ],
      "description": "Structural tree family using this shared row contract."
    },
    "node_kind": {
      "type": "string",
      "enum": [
        "workspace_root",
        "directory",
        "file",
        "generated_artifact",
        "symlink_or_alias",
        "symbol",
        "class",
        "function",
        "method",
        "field",
        "schema",
        "schema_type",
        "schema_field",
        "module",
        "package",
        "dependency",
        "route",
        "component",
        "service",
        "runtime_node",
        "notebook_cell",
        "test",
        "placeholder",
        "missing_target",
        "unsupported_scope",
        "imported_node",
        "cached_node"
      ],
      "description": "What the row represents. This is not an icon name."
    },
    "authority_class": {
      "type": "string",
      "enum": [
        "workspace_vfs",
        "buffer_editor",
        "derived_knowledge",
        "execution",
        "policy_entitlement",
        "provider_overlay"
      ],
      "description": "Canonical-owner classification re-exported from the subscription contract."
    },
    "materialization_class": {
      "type": "string",
      "enum": [
        "ephemeral_projection",
        "durable_local_materialization",
        "exportable_snapshot",
        "managed_replicated_view"
      ],
      "description": "Materialized-view class re-exported from the subscription/materialized-view model."
    },
    "source_state": {
      "type": "string",
      "enum": [
        "live_discovery",
        "imported_state",
        "cached_snapshot",
        "generated_manifest",
        "provider_overlay",
        "runtime_inspection",
        "support_export_snapshot"
      ],
      "description": "How the row was sourced."
    },
    "readiness_state": {
      "type": "string",
      "enum": [
        "discovering",
        "hot_set_ready",
        "full_indexing",
        "fully_indexed",
        "paused",
        "rebuilding",
        "stale",
        "failed_degraded"
      ],
      "description": "Closed placeholder and snapshot readiness vocabulary. fully_indexed is the only state that may claim complete scope without a partial or hidden-scope cue."
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ],
      "description": "Freshness vocabulary re-exported from the capability lifecycle and search-readiness contracts."
    },
    "completeness_class": {
      "type": "string",
      "enum": [
        "complete_for_scope",
        "partial_for_scope",
        "hidden_scope_present",
        "unknown_for_scope",
        "not_applicable"
      ],
      "description": "Claim the tree makes about the requested scope."
    },
    "label_source_class": {
      "type": "string",
      "enum": [
        "canonical_owner",
        "imported_metadata",
        "cached_snapshot",
        "runtime_observation",
        "generated_lineage",
        "redacted_placeholder"
      ],
      "description": "Where the display label came from."
    },
    "row_badge_class": {
      "type": "string",
      "enum": [
        "supported",
        "unsupported",
        "experimental",
        "cached",
        "stale",
        "partial",
        "imported",
        "generated",
        "read_only",
        "policy_limited",
        "remote_limited",
        "runtime_only",
        "approximate_mapping",
        "unknown",
        "none"
      ],
      "description": "Closed support and freshness badge vocabulary."
    },
    "row_badge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["badge_class"],
      "properties": {
        "badge_class": { "$ref": "#/$defs/row_badge_class" },
        "source_ref": { "$ref": "#/$defs/opaque_id" },
        "presentation_label": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "mutability_state": {
      "type": "string",
      "enum": [
        "writable",
        "read_only",
        "locked_by_policy",
        "locked_by_provider",
        "generated_read_only",
        "unsupported_read_only",
        "cached_read_only",
        "unknown"
      ],
      "description": "Closed lock and read-only state vocabulary. Generated and read-only remain distinct."
    },
    "selection_sync_state": {
      "type": "string",
      "enum": [
        "synced_to_active_target",
        "can_sync_on_focus",
        "can_reveal_target",
        "out_of_scope",
        "target_missing",
        "mapping_approximate",
        "disabled_read_only",
        "not_supported",
        "unknown"
      ],
      "description": "Whether the row can track, reveal, or synchronize with the current editor/runtime/source target."
    },
    "selection_sync": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": { "$ref": "#/$defs/selection_sync_state" },
        "active_target_ref": { "$ref": "#/$defs/opaque_id" },
        "reveal_command_ref": { "$ref": "#/$defs/opaque_id" },
        "selection_scope_ref": { "$ref": "#/$defs/opaque_id" },
        "fallback_action_id": { "$ref": "#/$defs/recovery_action_id" },
        "explanation_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "search_match_state": {
      "type": "string",
      "enum": [
        "none",
        "direct_match",
        "descendant_match",
        "hidden_descendant_match",
        "stale_match",
        "approximate_match"
      ],
      "description": "Search or filter highlight state for the row."
    },
    "search_match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": { "$ref": "#/$defs/search_match_state" },
        "query_session_ref": { "$ref": "#/$defs/opaque_id" },
        "direct_match_count": { "$ref": "#/$defs/count_value" },
        "descendant_match_count": { "$ref": "#/$defs/count_value" },
        "hidden_match_count": { "$ref": "#/$defs/count_value" },
        "match_anchor_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },
    "hidden_scope_reason": {
      "type": "string",
      "enum": [
        "trust_state_excludes_surface",
        "policy_narrows_source",
        "sparse_scope_excludes_root",
        "outside_loaded_scope",
        "excluded_by_user_filter",
        "client_scope_excludes_surface",
        "provider_overlay_unauthorised",
        "remote_shard_unreachable",
        "generated_artifact_hidden_by_default",
        "ignored_by_workspace_rules",
        "unsupported_scope",
        "redaction_narrowed"
      ],
      "description": "Closed reasons a subtree, descendant set, or peer scope is omitted from the visible tree."
    },
    "hidden_scope_placement": {
      "type": "string",
      "enum": [
        "inline_badge",
        "child_placeholder_row",
        "ancestor_summary",
        "support_export_only"
      ],
      "description": "Narrowest visible placement for a hidden-scope disclosure."
    },
    "hidden_scope_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "count", "placement"],
      "properties": {
        "reason": { "$ref": "#/$defs/hidden_scope_reason" },
        "count": { "$ref": "#/$defs/count_value" },
        "placement": { "$ref": "#/$defs/hidden_scope_placement" },
        "scope_ref": { "$ref": "#/$defs/scope_ref" },
        "explanation_ref": { "$ref": "#/$defs/opaque_id" },
        "detail_action_id": { "$ref": "#/$defs/recovery_action_id" }
      },
      "description": "Disclosure for omitted scope, hidden children, hidden descendants, or hidden search matches."
    },
    "identity_state": {
      "type": "string",
      "enum": [
        "stable",
        "moved_resolved",
        "moved_ambiguous",
        "missing_target",
        "stale_cached_identity",
        "generated_artifact_lineage",
        "unsupported_scope",
        "imported_cached_state",
        "collision_review_required"
      ],
      "description": "Stable identity and recovery posture for moved, missing, generated, imported, cached, unsupported, or colliding rows."
    },
    "recovery_action_id": {
      "type": "string",
      "enum": [
        "none_required",
        "reveal_current_target",
        "locate_missing_target",
        "review_ambiguous_move",
        "remove_row_from_view",
        "reopen_parent_scope",
        "rebuild_scope",
        "refresh_provider",
        "open_read_only_cache",
        "show_lineage",
        "inspect_support_export",
        "retry_discovery",
        "resume_discovery",
        "widen_scope",
        "view_unsupported_reason",
        "open_generated_source",
        "open_current_file",
        "open_index_status"
      ],
      "description": "Closed recovery and inspect action vocabulary for tree rows and placeholders."
    },
    "action_role": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "recovery",
        "destructive",
        "inspect"
      ]
    },
    "recovery_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_role", "enabled"],
      "properties": {
        "action_id": { "$ref": "#/$defs/recovery_action_id" },
        "action_role": { "$ref": "#/$defs/action_role" },
        "enabled": { "type": "boolean" },
        "requires_target_revalidation": { "type": "boolean" },
        "requires_confirmation": { "type": "boolean" },
        "presentation_label": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "identity_recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity_state", "recovery_actions", "support_export_required"],
      "properties": {
        "identity_state": { "$ref": "#/$defs/identity_state" },
        "predecessor_identity_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "current_target_ref": { "$ref": "#/$defs/opaque_id" },
        "lineage_ref": { "$ref": "#/$defs/opaque_id" },
        "recovery_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/recovery_action" },
          "minItems": 1
        },
        "support_export_required": { "type": "boolean" },
        "explanation_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "indentation_guide_state": {
      "type": "string",
      "enum": [
        "hidden",
        "visible_for_depth",
        "visible_for_focus_path",
        "visible_for_selected_path"
      ],
      "description": "How indentation guides are exposed without changing row identity or focus order."
    },
    "tree_indentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["depth", "indent_unit_ref", "guide_state"],
      "properties": {
        "depth": { "type": "integer", "minimum": 0 },
        "indent_unit_ref": { "$ref": "#/$defs/opaque_id" },
        "guide_state": { "$ref": "#/$defs/indentation_guide_state" },
        "mirrors_parent_row_id": { "$ref": "#/$defs/opaque_id" }
      },
      "description": "Presentation indentation facts. Consumers still use structural identity and parent refs for behavior."
    },
    "tree_disclosure_state": {
      "type": "string",
      "enum": [
        "leaf_no_affordance",
        "collapsed_ready",
        "expanded_ready",
        "collapsed_unhydrated",
        "expanding_hydrating",
        "expanded_partial",
        "blocked_unavailable",
        "provider_unavailable",
        "placeholder_expandable"
      ],
      "description": "Closed disclosure affordance vocabulary. Expansion, hydration, blocked, and provider-unavailable states remain distinct."
    },
    "tree_disclosure_affordance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "keyboard_toggle_allowed",
        "announces_child_count",
        "announces_hidden_count"
      ],
      "properties": {
        "state": { "$ref": "#/$defs/tree_disclosure_state" },
        "keyboard_toggle_allowed": { "type": "boolean" },
        "announces_child_count": { "type": "boolean" },
        "announces_hidden_count": { "type": "boolean" },
        "placeholder_ref": { "$ref": "#/$defs/opaque_id" },
        "child_count": { "$ref": "#/$defs/count_value" },
        "accessible_label_ref": { "$ref": "#/$defs/opaque_id" }
      },
      "description": "Disclosure control facts for rows and placeholders. Visual chevrons, twisties, and disclosure buttons all resolve to this shape."
    },
    "row_hydration_state": {
      "type": "string",
      "enum": [
        "not_hydrated",
        "hydrating",
        "hydrated",
        "partially_hydrated",
        "hydration_paused",
        "hydration_blocked",
        "provider_unavailable",
        "provider_missing"
      ],
      "description": "Lazy-hydration state for a row's children or backing provider."
    },
    "tree_row_focus_state": {
      "type": "string",
      "enum": [
        "not_focusable",
        "focusable",
        "focused",
        "focus_delegated_to_child",
        "focus_return_placeholder"
      ]
    },
    "tree_row_current_item_state": {
      "type": "string",
      "enum": [
        "not_current",
        "current_item",
        "current_item_hidden",
        "current_item_missing",
        "current_item_placeholder"
      ]
    },
    "tree_row_active_state": {
      "type": "string",
      "enum": [
        "inactive",
        "active_target",
        "active_ancestor",
        "active_provider_context",
        "active_target_unavailable"
      ]
    },
    "tree_row_selected_state": {
      "type": "string",
      "enum": [
        "unselected",
        "selected",
        "range_anchor",
        "hidden_selected",
        "selection_blocked"
      ]
    },
    "tree_row_open_state": {
      "type": "string",
      "enum": [
        "not_open",
        "open_primary_editor",
        "open_secondary_editor",
        "open_preview",
        "open_external",
        "open_unavailable"
      ]
    },
    "tree_row_interaction_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_state",
        "current_item_state",
        "active_state",
        "selected_state",
        "open_state"
      ],
      "properties": {
        "focus_state": { "$ref": "#/$defs/tree_row_focus_state" },
        "current_item_state": { "$ref": "#/$defs/tree_row_current_item_state" },
        "active_state": { "$ref": "#/$defs/tree_row_active_state" },
        "selected_state": { "$ref": "#/$defs/tree_row_selected_state" },
        "open_state": { "$ref": "#/$defs/tree_row_open_state" },
        "range_anchor_ref": { "$ref": "#/$defs/opaque_id" },
        "invocation_ref": { "$ref": "#/$defs/opaque_id" }
      },
      "description": "Per-row interaction truth. Focus, current item, active target, selection, and open state are separate axes."
    },
    "tree_action_exposure_class": {
      "type": "string",
      "enum": [
        "none",
        "inline_always",
        "inline_on_focus_or_hover",
        "inline_when_width_allows",
        "deferred_context_menu",
        "deferred_command_palette",
        "blocked_explain_only"
      ],
      "description": "Whether row actions are visible inline or deferred to context routes."
    },
    "tree_action_exposure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exposure_class", "max_inline_actions"],
      "properties": {
        "exposure_class": { "$ref": "#/$defs/tree_action_exposure_class" },
        "max_inline_actions": { "type": "integer", "minimum": 0, "maximum": 3 },
        "inline_action_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "deferred_action_route_ref": { "$ref": "#/$defs/opaque_id" },
        "explanation_ref": { "$ref": "#/$defs/opaque_id" }
      },
      "description": "Inline versus deferred action posture for a tree row or view."
    },
    "tree_drag_move_posture_class": {
      "type": "string",
      "enum": [
        "not_supported",
        "preview_only",
        "local_reorder_allowed",
        "move_requires_review",
        "copy_requires_modifier",
        "external_drop_review_required",
        "blocked_by_policy",
        "blocked_generated_or_read_only",
        "provider_move_unavailable"
      ],
      "description": "Closed drag or move posture vocabulary for tree-backed surfaces."
    },
    "tree_drag_move_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["posture_class", "review_required"],
      "properties": {
        "posture_class": { "$ref": "#/$defs/tree_drag_move_posture_class" },
        "review_required": { "type": "boolean" },
        "drop_target_state": {
          "type": "string",
          "enum": [
            "not_drop_target",
            "drop_target_allowed",
            "drop_target_review_required",
            "drop_target_blocked",
            "drop_target_unknown_until_hydrated"
          ]
        },
        "recovery_action_id": { "$ref": "#/$defs/recovery_action_id" },
        "explanation_ref": { "$ref": "#/$defs/opaque_id" }
      },
      "description": "Drag, drop, reorder, move, and copy posture without overloading row hover state."
    },
    "tree_keyboard_navigation_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "arrow_key_model",
        "left_key_behavior",
        "right_key_behavior",
        "typeahead_behavior",
        "home_end_behavior",
        "activation_behavior"
      ],
      "properties": {
        "arrow_key_model": {
          "type": "string",
          "enum": ["roving_focus", "aria_activedescendant", "platform_native_tree"]
        },
        "left_key_behavior": {
          "type": "string",
          "enum": ["collapse_then_parent", "parent_only", "no_op_on_leaf"]
        },
        "right_key_behavior": {
          "type": "string",
          "enum": ["expand_then_first_child", "first_child_only", "hydrate_then_expand"]
        },
        "typeahead_behavior": {
          "type": "string",
          "enum": ["visible_rows_only", "loaded_rows", "all_matching_with_review", "disabled"]
        },
        "home_end_behavior": {
          "type": "string",
          "enum": ["realized_window", "loaded_tree", "full_tree_with_virtual_scroll"]
        },
        "activation_behavior": {
          "type": "string",
          "enum": ["open_current_item", "toggle_disclosure_on_branch", "route_by_node_kind"]
        },
        "multi_select_modifier": {
          "type": "string",
          "enum": ["platform_default", "ctrl_cmd", "shift_only", "disabled"]
        }
      },
      "description": "Keyboard behavior shared by hierarchy surfaces."
    },
    "tree_virtualization_state": {
      "type": "string",
      "enum": [
        "not_virtualized",
        "virtualized_stable",
        "virtualized_hydrating",
        "virtualized_filtered",
        "virtualized_provider_limited"
      ]
    },
    "tree_accessibility_semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role_model",
        "setsize_truth",
        "posinset_truth",
        "active_descendant_strategy",
        "exposes_hidden_counts"
      ],
      "properties": {
        "role_model": {
          "type": "string",
          "enum": ["tree_treeitem_group", "treegrid", "outline_tree", "native_platform_tree"]
        },
        "setsize_truth": {
          "type": "string",
          "enum": ["exact", "approximate", "unknown_until_hydrated"]
        },
