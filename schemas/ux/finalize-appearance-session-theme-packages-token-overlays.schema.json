{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/finalize-appearance-session-theme-packages-token-overlays.schema.json",
  "title": "Appearance-session finalization certification record",
  "description": "Boundary schema for the appearance_session_finalization_certification_record that governs versioned theme packages, inspectable appearance-session summaries, token-overlay validation, imported-theme mapping honesty, extension appearance descriptors, live-appearance change disclosure, and provenance preservation. The schema mints no parallel vocabulary; it re-uses appearance_session, theme_package_manifest, token_registry, theme_import_mapping_report, and extension_appearance_conformance types by reference. Adding a new row class or pillar is additive-minor and bumps schema_version; repurposing an existing value is breaking and requires a new record kind.",
  "type": "object",
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "posture_id",
    "posture_label",
    "title",
    "summary",
    "appearance_session",
    "surface_lifecycle_marker",
    "theme_packages",
    "session_summaries",
    "token_overlays",
    "import_reports",
    "extension_descriptors",
    "live_changes",
    "provenance",
    "pillars",
    "claim_ceiling",
    "stable_qualification",
    "recovery_routes",
    "routes",
    "accessibility",
    "available_without_account",
    "available_without_managed_services",
    "honesty_marker_present",
    "upstream",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": {
      "type": "string",
      "const": "appearance_session_finalization_certification_record"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "notice": {
      "type": "string",
      "minLength": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "settings:appearance_session_finalization:v1"
    },
    "record_id": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "format": "date-time" },
    "posture_id": { "type": "string", "minLength": 1 },
    "posture_label": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "title": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "appearance_session": {
      "type": "object",
      "required": [
        "appearance_session_id",
        "session_revision",
        "active_theme_package_ref",
        "active_theme_revision_ref",
        "mode_theme_class",
        "contrast_mode",
        "accent_source",
        "density_class",
        "text_scale_percent",
        "reduced_motion_posture",
        "follow_system_posture",
        "live_follow_system_policy_ref",
        "value_ref"
      ],
      "properties": {
        "appearance_session_id": { "type": "string", "minLength": 1 },
        "session_revision": { "type": "integer", "minimum": 0 },
        "active_theme_package_ref": { "type": "string", "minLength": 1 },
        "active_theme_revision_ref": { "type": "string", "minLength": 1 },
        "mode_theme_class": {
          "type": "string",
          "enum": ["dark_reference", "light_parity", "high_contrast_dark", "high_contrast_light"]
        },
        "contrast_mode": {
          "type": "string",
          "enum": ["contrast_standard", "contrast_high", "contrast_forced_colors"]
        },
        "accent_source": {
          "type": "string",
          "enum": ["system_accent", "theme_package_accent", "user_selected_accent", "policy_locked_accent", "not_applicable"]
        },
        "density_class": {
          "type": "string",
          "enum": ["compact", "standard", "comfortable"]
        },
        "text_scale_percent": { "type": "integer", "minimum": 0 },
        "reduced_motion_posture": {
          "type": "string",
          "enum": ["motion_standard", "motion_reduced", "motion_low_motion", "motion_power_saver", "motion_critical_hot_path"]
        },
        "follow_system_posture": {
          "type": "string",
          "enum": ["follow_system", "manual_override", "managed_policy_override", "unavailable_platform_signal"]
        },
        "live_follow_system_policy_ref": { "type": "string", "minLength": 1 },
        "value_ref": { "type": "string", "minLength": 1 }
      }
    },
    "surface_lifecycle_marker": {
      "type": "string",
      "enum": ["preview", "beta", "stable"]
    },
    "theme_packages": {
      "type": "array",
      "items": { "$ref": "#/$defs/theme_package_manifest_row" }
    },
    "session_summaries": {
      "type": "array",
      "items": { "$ref": "#/$defs/appearance_session_summary_row" }
    },
    "token_overlays": {
      "type": "array",
      "items": { "$ref": "#/$defs/token_overlay_validation_row" }
    },
    "import_reports": {
      "type": "array",
      "items": { "$ref": "#/$defs/imported_theme_mapping_report_row" }
    },
    "extension_descriptors": {
      "type": "array",
      "items": { "$ref": "#/$defs/extension_appearance_descriptor_row" }
    },
    "live_changes": {
      "type": "array",
      "items": { "$ref": "#/$defs/live_appearance_change_row" }
    },
    "provenance": {
      "type": "array",
      "items": { "$ref": "#/$defs/provenance_preservation_row" }
    },
    "pillars": {
      "type": "object",
      "required": [
        "theme_packages_versioned",
        "appearance_sessions_inspectable",
        "token_overlays_validated",
        "import_reports_honest",
        "extension_gaps_visible",
        "live_changes_disclosed",
        "provenance_intact"
      ],
      "properties": {
        "theme_packages_versioned": { "type": "boolean" },
        "appearance_sessions_inspectable": { "type": "boolean" },
        "token_overlays_validated": { "type": "boolean" },
        "import_reports_honest": { "type": "boolean" },
        "extension_gaps_visible": { "type": "boolean" },
        "live_changes_disclosed": { "type": "boolean" },
        "provenance_intact": { "type": "boolean" }
      }
    },
    "claim_ceiling": {
      "type": "object",
      "required": [
        "asserts_theme_packages_versioned",
        "asserts_sessions_inspectable",
        "asserts_token_overlays_validated",
        "asserts_import_reports_honest",
        "asserts_extension_gaps_visible",
        "asserts_live_changes_disclosed",
        "asserts_provenance_intact"
      ],
      "properties": {
        "asserts_theme_packages_versioned": { "type": "boolean" },
        "asserts_sessions_inspectable": { "type": "boolean" },
        "asserts_token_overlays_validated": { "type": "boolean" },
        "asserts_import_reports_honest": { "type": "boolean" },
        "asserts_extension_gaps_visible": { "type": "boolean" },
        "asserts_live_changes_disclosed": { "type": "boolean" },
        "asserts_provenance_intact": { "type": "boolean" }
      }
    },
    "stable_qualification": {
      "type": "object",
      "required": ["claim_class", "qualifies_stable", "narrowing_reasons"],
      "properties": {
        "claim_class": {
          "type": "string",
          "enum": ["stable", "beta", "preview", "not_claimed"]
        },
        "qualifies_stable": { "type": "boolean" },
        "narrowing_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "theme_package_unversioned",
              "appearance_session_not_inspectable",
              "token_overlay_silently_dropped",
              "import_report_missing_visible_gaps",
              "extension_gap_undisclosed",
              "live_change_silent_lag",
              "provenance_flattened",
              "surface_not_yet_stable"
            ]
          }
        }
      }
    },
    "recovery_routes": {
      "type": "array",
      "items": { "$ref": "#/$defs/recovery_route_record" }
    },
    "routes": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry_route_record" }
    },
    "accessibility": {
      "type": "object",
      "required": ["focus_order_index", "tab_stop_count", "row_narration", "action_labels", "layout_modes"],
      "properties": {
        "focus_order_index": { "type": "integer", "minimum": 0 },
        "tab_stop_count": { "type": "integer", "minimum": 0 },
        "row_narration": { "type": "string", "minLength": 1 },
        "action_labels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "layout_modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/layout_mode_disclosure" }
        }
      }
    },
    "available_without_account": { "type": "boolean" },
    "available_without_managed_services": { "type": "boolean" },
    "honesty_marker_present": { "type": "boolean" },
    "upstream": {
      "type": "object",
      "required": [
        "appearance_contract_ref",
        "component_state_registry_ref",
        "token_registry_refs",
        "appearance_conformance_packet_ref",
        "contributing_capture_refs"
      ],
      "properties": {
        "appearance_contract_ref": { "type": "string", "minLength": 1 },
        "component_state_registry_ref": { "type": "string", "minLength": 1 },
        "token_registry_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "appearance_conformance_packet_ref": { "type": "string", "minLength": 1 },
        "contributing_capture_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "diagnostics_export_ref": { "type": "string", "minLength": 1 },
    "support_export_ref": { "type": "string", "minLength": 1 },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "narrative_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "theme_package_manifest_row": {
      "type": "object",
      "required": [
        "package_ref",
        "package_revision_ref",
        "package_version_label",
        "supported_theme_classes",
        "supported_density_classes",
        "supported_motion_postures",
        "default_density_class",
        "default_motion_posture",
        "minimum_text_contrast_target",
        "minimum_ui_contrast_target",
        "manifest_versioned",
        "provenance_declared",
        "trust_severity_semantics_preserved",
        "surface_marker",
        "conforms"
      ],
      "properties": {
        "package_ref": { "type": "string", "minLength": 1 },
        "package_revision_ref": { "type": "string", "minLength": 1 },
        "package_version_label": { "type": "string", "minLength": 1 },
        "supported_theme_classes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "supported_density_classes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "supported_motion_postures": {
          "type": "array",
          "items": { "type": "string" }
        },
        "default_density_class": { "type": "string" },
        "default_motion_posture": { "type": "string" },
        "minimum_text_contrast_target": { "type": "number" },
        "minimum_ui_contrast_target": { "type": "number" },
        "manifest_versioned": { "type": "boolean" },
        "provenance_declared": { "type": "boolean" },
        "trust_severity_semantics_preserved": { "type": "boolean" },
        "surface_marker": { "type": "string", "enum": ["preview", "beta", "stable"] },
        "waiver_ref": { "type": "string" },
        "conforms": { "type": "boolean" }
      }
    },
    "appearance_session_summary_row": {
      "type": "object",
      "required": [
        "appearance_session_id",
        "session_revision",
        "active_theme_package_ref",
        "active_theme_revision_ref",
        "mode_theme_class",
        "contrast_mode",
        "accent_source",
        "density_class",
        "text_scale_percent",
        "reduced_motion_posture",
        "follow_system_posture",
        "checkpoint_active",
        "summary_exportable",
        "cites_one_package_source",
        "conforms"
      ],
      "properties": {
        "appearance_session_id": { "type": "string", "minLength": 1 },
        "session_revision": { "type": "integer", "minimum": 0 },
        "active_theme_package_ref": { "type": "string", "minLength": 1 },
        "active_theme_revision_ref": { "type": "string", "minLength": 1 },
        "mode_theme_class": { "type": "string" },
        "contrast_mode": { "type": "string" },
        "accent_source": { "type": "string" },
        "density_class": { "type": "string" },
        "text_scale_percent": { "type": "integer", "minimum": 0 },
        "reduced_motion_posture": { "type": "string" },
        "follow_system_posture": { "type": "string" },
        "checkpoint_active": { "type": "boolean" },
        "current_checkpoint_ref": { "type": "string" },
        "rollback_ref": { "type": "string" },
        "summary_exportable": { "type": "boolean" },
        "cites_one_package_source": { "type": "boolean" },
        "conforms": { "type": "boolean" }
      }
    },
    "token_overlay_validation_row": {
      "type": "object",
      "required": [
        "scope",
        "overlay_ref",
        "supported_token_count",
        "inert_token_count",
        "downgraded_token_count",
        "silently_dropped_token_count",
        "unknown_tokens_preserved",
        "unsupported_tokens_preserved",
        "scope_lineage_recorded",
        "conforms"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": ["user", "profile", "workspace", "policy"]
        },
        "overlay_ref": { "type": "string", "minLength": 1 },
        "supported_token_count": { "type": "integer", "minimum": 0 },
        "inert_token_count": { "type": "integer", "minimum": 0 },
        "downgraded_token_count": { "type": "integer", "minimum": 0 },
        "silently_dropped_token_count": { "type": "integer", "minimum": 0 },
        "unknown_tokens_preserved": { "type": "boolean" },
        "unsupported_tokens_preserved": { "type": "boolean" },
        "scope_lineage_recorded": { "type": "boolean" },
        "conforms": { "type": "boolean" }
      }
    },
    "imported_theme_mapping_report_row": {
      "type": "object",
      "required": [
        "report_ref",
        "source_format",
        "translated_slot_count",
        "unsupported_slot_count",
        "unresolved_slot_count",
        "fallback_substituted_count",
        "syntax_coverage_reported",
        "parity_notes_visible",
        "fallback_behavior_documented",
        "rollback_path_present",
        "full_fidelity_claim_blocked_when_unsupported",
        "conforms"
      ],
      "properties": {
        "report_ref": { "type": "string", "minLength": 1 },
        "source_format": { "type": "string", "minLength": 1 },
        "translated_slot_count": { "type": "integer", "minimum": 0 },
        "unsupported_slot_count": { "type": "integer", "minimum": 0 },
        "unresolved_slot_count": { "type": "integer", "minimum": 0 },
        "fallback_substituted_count": { "type": "integer", "minimum": 0 },
        "syntax_coverage_reported": { "type": "boolean" },
        "parity_notes_visible": { "type": "boolean" },
        "fallback_behavior_documented": { "type": "boolean" },
        "rollback_path_present": { "type": "boolean" },
        "full_fidelity_claim_blocked_when_unsupported": { "type": "boolean" },
        "conforms": { "type": "boolean" }
      }
    },
    "extension_appearance_descriptor_row": {
      "type": "object",
      "required": [
        "surface_id",
        "surface_label",
        "theme_inheritance",
        "density_inheritance",
        "high_contrast_inheritance",
        "focus_inheritance",
        "reduced_motion_inheritance",
        "gap_visible_in_product",
        "gap_visible_in_export",
        "gap_visible_in_diagnostics",
        "prevents_quiet_stable_claim",
        "conforms"
      ],
      "properties": {
        "surface_id": { "type": "string", "minLength": 1 },
        "surface_label": { "type": "string", "minLength": 1 },
        "theme_inheritance": {
          "type": "string",
          "enum": ["inherits", "partial", "does_not_inherit"]
        },
        "density_inheritance": {
          "type": "string",
          "enum": ["inherits", "partial", "does_not_inherit"]
        },
        "high_contrast_inheritance": {
          "type": "string",
          "enum": ["inherits", "partial", "does_not_inherit"]
        },
        "focus_inheritance": {
          "type": "string",
          "enum": ["inherits", "partial", "does_not_inherit"]
        },
        "reduced_motion_inheritance": {
          "type": "string",
          "enum": ["inherits", "partial", "does_not_inherit"]
        },
        "gap_visible_in_product": { "type": "boolean" },
        "gap_visible_in_export": { "type": "boolean" },
        "gap_visible_in_diagnostics": { "type": "boolean" },
        "prevents_quiet_stable_claim": { "type": "boolean" },
        "conforms": { "type": "boolean" }
      }
    },
    "live_appearance_change_row": {
      "type": "object",
      "required": [
        "axis",
        "live_apply_class",
        "disclosure_required",
        "silently_lags_system",
        "applies_coherently_or_discloses",
        "note",
        "conforms"
      ],
      "properties": {
        "axis": {
          "type": "string",
          "enum": ["os_theme", "os_contrast", "os_accent", "os_density", "os_text_scale", "os_reduced_motion"]
        },
        "live_apply_class": {
          "type": "string",
          "enum": ["apply_live", "apply_live_checkpointed", "confirm_required", "reload_required", "restart_required", "policy_blocked"]
        },
        "disclosure_required": { "type": "boolean" },
        "silently_lags_system": { "type": "boolean" },
        "applies_coherently_or_discloses": { "type": "boolean" },
        "note": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "conforms": { "type": "boolean" }
      }
    },
    "provenance_preservation_row": {
      "type": "object",
      "required": [
        "dimension",
        "package_identity_survives_export",
        "unresolved_slots_survive_export",
        "overlay_lineage_survives_export",
        "inheritance_gaps_survive_export",
        "survives_sync_without_flattening",
        "conforms"
      ],
      "properties": {
        "dimension": {
          "type": "string",
          "enum": ["theme_package_identity", "overlay_scope_lineage", "unresolved_import_slots", "extension_inheritance_gaps"]
        },
        "package_identity_survives_export": { "type": "boolean" },
        "unresolved_slots_survive_export": { "type": "boolean" },
        "overlay_lineage_survives_export": { "type": "boolean" },
        "inheritance_gaps_survive_export": { "type": "boolean" },
        "survives_sync_without_flattening": { "type": "boolean" },
        "conforms": { "type": "boolean" }
      }
    },
    "recovery_route_record": {
      "type": "object",
      "required": ["action_id", "action_label", "action_role", "keyboard_reachable"],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_label": { "type": "string", "minLength": 1 },
        "action_role": {
          "type": "string",
          "enum": ["primary", "recovery", "secondary"]
        },
        "keyboard_reachable": { "type": "boolean" }
      }
    },
    "entry_route_record": {
      "type": "object",
      "required": ["surface", "route_ref", "keyboard_reachable", "activates_same_record"],
      "properties": {
        "surface": {
          "type": "string",
          "enum": ["settings_appearance", "command_palette", "status_bar", "menu_command"]
        },
        "route_ref": { "type": "string", "minLength": 1 },
        "keyboard_reachable": { "type": "boolean" },
        "activates_same_record": { "type": "boolean" }
      }
    },
    "layout_mode_disclosure": {
      "type": "object",
      "required": ["mode", "row_narration_available", "recovery_affordances_reachable"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["normal", "high_contrast", "zoomed"]
        },
        "row_narration_available": { "type": "boolean" },
        "recovery_affordances_reachable": { "type": "boolean" }
      }
    }
  }
}
