{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/stable_affordance_row.schema.json",
  "title": "Aureline stable affordance mapping row contract",
  "description": "Boundary schema for stable_affordance_row_record frozen in docs/ux/stable_affordance_mapping_contract.md. A stable affordance row enumerates the contract-grade follow-up actions (copy command id, copy CLI equivalent, open schema/docs, run migration check, open support packet, copy stable issue/advisory ref) a surface exposes so desktop UI, CLI/headless output, docs/help, migration reports, diagnostics, and support exports can pivot on stable identifiers rather than prose. The row carries stable ids, repo-relative refs, controlled vocabulary, and short redaction-aware summaries only. Raw paths, raw URLs, raw command lines, raw policy bodies, raw payloads, and secret material never cross this boundary. Adding a new surface class, affordance class, availability class, fallback behavior, or target-ref kind is additive-minor and requires a stable_affordance_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [{ "$ref": "#/$defs/stable_affordance_row_record" }],
  "$defs": {
    "stable_affordance_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the stable affordance mapping export."
    },
    "instance_schema_hint": {
      "type": "string",
      "format": "uri-reference",
      "description": "Optional schema hint carried on worked fixtures."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": { "type": "object", "additionalProperties": true },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9]+(?:[A-Za-z0-9_.:/-]*[A-Za-z0-9])?$",
      "description": "Stable opaque id safe for logs, fixtures, and support exports. Raw paths, raw URLs, raw command lines, and raw policy bodies are forbidden."
    },
    "stable_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/#-]*[A-Za-z0-9]$",
      "description": "Stable ref string safe for logs, fixtures, docs, and support exports (repo-relative path, docs anchor id, schema id, advisory id, etc.)."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 900,
      "description": "Bounded redaction-aware sentence suitable for UI and support export."
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ],
      "description": "Re-exported from the common redaction class vocabulary used across UX boundary schemas."
    },
    "record_kind": {
      "type": "string",
      "const": "stable_affordance_row_record",
      "description": "Discriminator for this payload shape."
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "command_result",
        "settings_row",
        "deprecation_notice",
        "migration_report",
        "diagnostic_finding",
        "policy_denial",
        "docs_help_surface",
        "support_center_card",
        "cli_headless_output",
        "support_export_packet"
      ],
      "description": "Closed surface-class vocabulary for stable affordance mapping rows."
    },
    "projection_surface_class": {
      "type": "string",
      "enum": [
        "desktop_ui",
        "cli_headless",
        "docs_help",
        "migration_report",
        "diagnostics",
        "support_center",
        "support_export"
      ],
      "description": "Cross-surface projections where the same stable ids should be reusable."
    },
    "subject_kind": {
      "type": "string",
      "enum": [
        "command",
        "setting_or_manifest",
        "schema_or_packet",
        "deprecation_or_lifecycle_notice",
        "migration_scope",
        "diagnostic_scope",
        "policy_scope",
        "support_scope",
        "issue_or_advisory"
      ],
      "description": "High-level subject kind this row attaches affordances to."
    },
    "command_id_ref": {
      "type": "string",
      "pattern": "^cmd:[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "Canonical command id."
    },
    "canonical_verb": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$",
      "description": "Dotted snake_case canonical verb."
    },
    "affordance_slot_class": {
      "type": "string",
      "enum": [
        "copy_command_id",
        "copy_cli_equivalent",
        "open_schema_docs",
        "run_migration_check",
        "open_support_packet",
        "copy_issue_or_advisory_ref"
      ]
    },
    "affordance_availability_class": {
      "type": "string",
      "enum": [
        "available",
        "disabled_missing_mapping",
        "disabled_not_applicable",
        "disabled_policy_blocked",
        "disabled_client_scope_blocked",
        "disabled_offline_or_degraded",
        "disabled_support_only"
      ],
      "description": "Availability states for a stable affordance slot. Slots are present even when disabled so the surface degrades explicitly."
    },
    "fallback_behavior_class": {
      "type": "string",
      "enum": [
        "show_disabled_with_reason",
        "show_disabled_with_reason_and_contract_link",
        "replace_with_open_contract_surface",
        "render_placeholder_row_with_contract_link"
      ],
      "description": "Required explicit degradation behavior when an affordance is unavailable."
    },
    "target_ref_kind": {
      "type": "string",
      "enum": [
        "command_id",
        "canonical_verb",
        "docs_ref",
        "schema_ref",
        "migration_check_ref",
        "support_packet_ref",
        "issue_ref",
        "advisory_ref",
        "contract_ref"
      ],
      "description": "Typed ref kinds a stable affordance may point at."
    },
    "stable_affordance_target_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_kind", "ref_id"],
      "properties": {
        "ref_kind": { "$ref": "#/$defs/target_ref_kind" },
        "ref_id": { "$ref": "#/$defs/stable_ref" }
      },
      "allOf": [
        {
          "if": { "properties": { "ref_kind": { "const": "command_id" } } },
          "then": { "properties": { "ref_id": { "$ref": "#/$defs/command_id_ref" } } }
        },
        {
          "if": {
            "properties": { "ref_kind": { "const": "canonical_verb" } }
          },
          "then": { "properties": { "ref_id": { "$ref": "#/$defs/canonical_verb" } } }
        }
      ]
    },
    "stable_affordance_slot_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_class",
        "availability_class",
        "fallback_behavior",
        "target_refs",
        "disabled_reason_summary"
      ],
      "properties": {
        "slot_class": { "$ref": "#/$defs/affordance_slot_class" },
        "availability_class": { "$ref": "#/$defs/affordance_availability_class" },
        "fallback_behavior": { "$ref": "#/$defs/fallback_behavior_class" },
        "target_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_affordance_target_ref" },
          "uniqueItems": true,
          "description": "Typed stable refs the affordance resolves to (command id, docs anchor, schema path, migration check ref, support packet ref, issue/advisory ref)."
        },
        "disabled_reason_summary": {
          "oneOf": [{ "$ref": "#/$defs/reviewable_sentence" }, { "type": "null" }],
          "description": "Non-null whenever availability_class != available so the UI can degrade explicitly."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "availability_class": { "const": "available" } }
          },
          "then": { "properties": { "disabled_reason_summary": { "const": null } } }
        }
      ]
    },
    "stable_affordance_inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "copy_command_id",
        "copy_cli_equivalent",
        "open_schema_docs",
        "run_migration_check",
        "open_support_packet",
        "copy_issue_or_advisory_ref"
      ],
      "properties": {
        "copy_command_id": { "$ref": "#/$defs/stable_affordance_slot_record" },
        "copy_cli_equivalent": {
          "$ref": "#/$defs/stable_affordance_slot_record"
        },
        "open_schema_docs": { "$ref": "#/$defs/stable_affordance_slot_record" },
        "run_migration_check": {
          "$ref": "#/$defs/stable_affordance_slot_record"
        },
        "open_support_packet": {
          "$ref": "#/$defs/stable_affordance_slot_record"
        },
        "copy_issue_or_advisory_ref": {
          "$ref": "#/$defs/stable_affordance_slot_record"
        }
      }
    },
    "stable_affordance_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "$schema",
        "record_kind",
        "stable_affordance_schema_version",
        "row_id",
        "surface_class",
        "subject_kind",
        "subject_ref",
        "projection_surfaces",
        "fallback_contract_ref",
        "affordances",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "$ref": "#/$defs/instance_schema_hint" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "stable_affordance_schema_version": {
          "$ref": "#/$defs/stable_affordance_schema_version"
        },
        "row_id": { "$ref": "#/$defs/opaque_id" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "subject_kind": { "$ref": "#/$defs/subject_kind" },
        "subject_ref": {
          "$ref": "#/$defs/stable_ref",
          "description": "Stable subject identifier (command id, schema id, packet id, policy id, migration scope id, advisory id, etc.)."
        },
        "projection_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/projection_surface_class" },
          "uniqueItems": true,
          "minItems": 1
        },
        "fallback_contract_ref": {
          "$ref": "#/$defs/stable_ref",
          "description": "Repo-relative ref to the stable affordance mapping contract section that defines fallback behavior."
        },
        "affordances": { "$ref": "#/$defs/stable_affordance_inventory" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "notes": {
          "oneOf": [{ "$ref": "#/$defs/reviewable_sentence" }, { "type": "null" }]
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    }
  }
}
