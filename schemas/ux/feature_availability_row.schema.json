{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/feature_availability_row.schema.json",
  "title": "Aureline feature-availability row, support-scope badge, and current-readiness contract",
  "description": "Boundary schema for feature_availability_row_record and support_scope_badge_record frozen in docs/ux/feature_availability_contract.md. The schema gives entry points, help, compatibility reports, claim manifests, marketplace listings, migration guides, issue templates, empty states, command results, and support exports one vocabulary for workflow-capability availability and one support-scope badge that re-exports the seven-axis capability matrix without inventing parallel vocabularies. Raw command lines, raw URLs, raw absolute paths, raw policy bodies, raw secret values, raw stdout/stderr, raw provider payloads, raw clipboard bytes, raw notebook output bytes, raw OAuth tokens, raw CA bundle bytes, and raw certificate chain PEM never cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/feature_availability_row_record" },
    { "$ref": "#/$defs/support_scope_badge_record" }
  ],
  "$defs": {
    "feature_availability_row_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for feature-availability row, support-scope badge, and current-readiness payloads."
    },
    "feature_availability_row_kind": {
      "type": "string",
      "const": "feature_availability_row_record"
    },
    "support_scope_badge_kind": {
      "type": "string",
      "const": "support_scope_badge_record"
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9]+(?:[A-Za-z0-9_.:/-]*[A-Za-z0-9])?$",
      "description": "Stable opaque id safe for logs, RPC, support bundles, screenshots, and fixtures. Raw absolute paths, raw URLs, raw command lines, raw secrets, and raw policy bodies never appear here."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_id" },
        { "type": "null" }
      ]
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 900,
      "not": {
        "anyOf": [
          { "pattern": "^\\s*Available\\s*$" },
          { "pattern": "^\\s*Unavailable\\s*$" },
          { "pattern": "^\\s*Supported\\s*$" },
          { "pattern": "^\\s*Coming soon\\s*$" },
          { "pattern": "^\\s*Sometimes\\s*$" },
          { "pattern": "^\\s*Maybe\\s*$" },
          { "pattern": "^\\s*In progress\\s*$" },
          { "pattern": "^\\s*Try again later\\s*$" },
          { "pattern": "^\\s*See docs\\s*$" },
          { "pattern": "^\\s*Generic error\\s*$" }
        ]
      },
      "description": "Bounded redaction-aware sentence suitable for review, screenshots, and support export. Generic chip words (Available, Unavailable, Supported, Coming soon, Sometimes, Maybe, In progress, Try again later, See docs, Generic error) are forbidden as the entire sentence."
    },
    "short_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "consumer_surface_class": {
      "type": "string",
      "enum": [
        "entry_point_start_center",
        "entry_point_project_entry",
        "entry_point_command_palette",
        "entry_point_run_or_debug_or_test_picker",
        "entry_point_search_row",
        "entry_point_marketplace_card",
        "entry_point_restore_card",
        "help_contextual_trigger",
        "help_docs_pane",
        "help_about_pane",
        "compatibility_report_row",
        "claim_manifest_row",
        "migration_guide_row",
        "issue_template_row",
        "empty_state_row",
        "command_result_message",
        "support_export_row"
      ]
    },
    "workflow_capability_class": {
      "type": "string",
      "enum": [
        "edit_language_aware",
        "navigate_find_references",
        "navigate_workspace_search",
        "navigate_symbol_index",
        "run_tests",
        "run_debug_session",
        "run_build",
        "run_task",
        "format_or_lint",
        "refactor_apply",
        "ai_assist_inline",
        "ai_assist_chat",
        "ai_assist_apply",
        "vcs_commit_or_review",
        "container_or_devcontainer_attach",
        "remote_session_attach",
        "managed_workspace_session",
        "extension_install_or_manage",
        "marketplace_browse",
        "package_manager_action",
        "notebook_kernel_action",
        "preview_render_or_export",
        "data_query_or_compute",
        "diagnostics_or_doctor",
        "settings_or_profile_action",
        "migration_action"
      ]
    },
    "environment_mode_class": {
      "type": "string",
      "enum": [
        "local_only",
        "remote_attach",
        "devcontainer_or_container",
        "managed_workspace",
        "air_gapped",
        "mixed_local_plus_remote",
        "notebook_kernel_local",
        "notebook_kernel_remote",
        "companion_surface",
        "cli_or_headless"
      ]
    },
    "environment_mode_set": {
      "type": "array",
      "items": { "$ref": "#/$defs/environment_mode_class" },
      "uniqueItems": true,
      "minItems": 1,
      "description": "Non-empty ordered set of environment modes the row is currently considered ready in. Empty is forbidden; rows that are not ready in any mode render the not_supported availability state."
    },
    "availability_state_class": {
      "type": "string",
      "enum": [
        "ready",
        "ready_with_caveats",
        "partial_index",
        "missing_toolchain",
        "not_configured",
        "policy_blocked",
        "not_certified_in_this_mode",
        "not_supported",
        "unknown_repair_required"
      ]
    },
    "availability_state_label_text": {
      "type": "string",
      "enum": [
        "Ready",
        "Ready with caveats",
        "Partial index",
        "Missing toolchain",
        "Not configured",
        "Policy blocked",
        "Not certified in this mode",
        "Not supported",
        "Unknown repair required"
      ]
    },
    "why_unavailable_handoff_class": {
      "type": "string",
      "enum": [
        "none_state_is_ready",
        "open_capability_axis_inspector",
        "open_index_status_repair",
        "install_or_locate_toolchain",
        "open_configuration_setup",
        "open_policy_explainer",
        "open_compatibility_report_for_mode",
        "open_archetype_status_or_request_support",
        "open_diagnostics_repair"
      ]
    },
    "configuration_kind": {
      "type": "string",
      "enum": [
        "test_runner_pin",
        "debug_target_pin",
        "build_target_pin",
        "provider_link",
        "archetype_declaration",
        "environment_pin",
        "credential_link",
        "workspace_trust_grant",
        "extension_link"
      ]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "labs",
        "preview",
        "beta",
        "stable",
        "lts_facing",
        "deprecated",
        "disabled_by_policy",
        "retired",
        "unresolved_axis_lifecycle_state"
      ]
    },
    "support_class": {
      "type": "string",
      "enum": [
        "best_effort",
        "community_supported",
        "standard_support",
        "extended_support",
        "operator_only_support",
        "no_support",
        "unresolved_axis_support_class"
      ]
    },
    "release_channel": {
      "type": "string",
      "enum": [
        "nightly_channel",
        "experimental_channel",
        "preview_channel",
        "stable_channel",
        "lts_channel",
        "managed_only_channel",
        "unresolved_axis_release_channel"
      ]
    },
    "client_scope_class": {
      "type": "string",
      "enum": [
        "desktop_product",
        "cli",
        "companion_surface",
        "remote_agent",
        "sdk_or_api",
        "managed_admin_surface"
      ]
    },
    "client_scope_set": {
      "type": "array",
      "items": { "$ref": "#/$defs/client_scope_class" },
      "uniqueItems": true
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified",
        "unresolved_axis_freshness_class"
      ]
    },
    "certified_archetype_state": {
      "type": "string",
      "enum": [
        "not_applicable",
        "supported",
        "best_effort",
        "untested",
        "degraded",
        "unsupported",
        "unresolved_axis_certified_archetype_state"
      ]
    },
    "marker_kind": {
      "type": "string",
      "enum": [
        "no_live_markers",
        "non_stable_capability_dependency",
        "disabled_by_policy_dependency",
        "deprecated_dependency",
        "retired_dependency",
        "provider_linked_dependency",
        "client_scope_restricted_dependency",
        "freshness_floor_dependency",
        "kill_switch_dependency",
        "managed_only_dependency",
        "toolchain_or_sdk_or_runtime_dependency",
        "language_pack_dependency",
        "index_warming_dependency",
        "credential_dependency",
        "extension_dependency",
        "archetype_row_dependency"
      ]
    },
    "effect_on_parent": {
      "type": "string",
      "enum": [
        "no_effect",
        "narrows_effective_lifecycle_state",
        "narrows_effective_support_class",
        "narrows_effective_release_channel",
        "narrows_effective_client_scopes",
        "narrows_effective_freshness_class",
        "narrows_effective_environment_mode_set",
        "gates_entire_capability"
      ]
    },
    "marker_state": {
      "type": "string",
      "enum": [
        "present",
        "not_required",
        "absent",
        "below_required_version",
        "warming",
        "partial",
        "stale",
        "blocked",
        "unknown"
      ]
    },
    "dependency_marker_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "marker_kind",
        "marker_state",
        "effect_on_parent",
        "marker_label",
        "dependency_ref",
        "repair_hook_ref"
      ],
      "properties": {
        "marker_kind": { "$ref": "#/$defs/marker_kind" },
        "marker_state": { "$ref": "#/$defs/marker_state" },
        "effect_on_parent": { "$ref": "#/$defs/effect_on_parent" },
        "marker_label": { "$ref": "#/$defs/short_label" },
        "dependency_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "repair_hook_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      },
      "allOf": [
        {
          "if": { "properties": { "marker_kind": { "const": "no_live_markers" } }, "required": ["marker_kind"] },
          "then": {
            "properties": {
              "marker_state": { "const": "not_required" },
              "effect_on_parent": { "const": "no_effect" }
            }
          }
        }
      ]
    },
    "dependency_marker_state_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entries", "no_dependencies_required"],
      "properties": {
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependency_marker_entry" },
          "minItems": 1,
          "uniqueItems": false
        },
        "no_dependencies_required": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "no_dependencies_required": { "const": true } }, "required": ["no_dependencies_required"] },
          "then": {
            "properties": {
              "entries": {
                "type": "array",
                "minItems": 1,
                "maxItems": 1,
                "items": {
                  "properties": { "marker_kind": { "const": "no_live_markers" } }
                }
              }
            }
          }
        }
      ]
    },
    "why_unavailable_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff_class",
        "handoff_label_text",
        "handoff_command_ref",
        "handoff_evidence_refs",
        "handoff_summary"
      ],
      "properties": {
        "handoff_class": { "$ref": "#/$defs/why_unavailable_handoff_class" },
        "handoff_label_text": { "$ref": "#/$defs/short_label" },
        "handoff_command_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "handoff_evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "handoff_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "active_policy_bundle_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "policy_rule_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "certified_archetype_report_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "active_environment_mode": {
          "oneOf": [
            { "$ref": "#/$defs/environment_mode_class" },
            { "type": "null" }
          ]
        },
        "reference_workspace_row_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "archetype_rubric_row_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "doctor_finding_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "diagnostics_card_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "setup_target_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "configuration_kind": {
          "oneOf": [
            { "$ref": "#/$defs/configuration_kind" },
            { "type": "null" }
          ]
        },
        "capability_lifecycle_row_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      },
      "allOf": [
        {
          "if": { "properties": { "handoff_class": { "const": "none_state_is_ready" } }, "required": ["handoff_class"] },
          "then": {
            "properties": {
              "handoff_command_ref": { "type": "null" },
              "active_policy_bundle_ref": { "type": "null" },
              "policy_rule_ref": { "type": "null" },
              "certified_archetype_report_ref": { "type": "null" },
              "active_environment_mode": { "type": "null" },
              "reference_workspace_row_ref": { "type": "null" },
              "archetype_rubric_row_ref": { "type": "null" },
              "doctor_finding_ref": { "type": "null" },
              "diagnostics_card_ref": { "type": "null" },
              "setup_target_ref": { "type": "null" },
              "configuration_kind": { "type": "null" },
              "capability_lifecycle_row_ref": { "type": "null" }
            }
          }
        },
        {
          "if": { "properties": { "handoff_class": { "const": "open_capability_axis_inspector" } }, "required": ["handoff_class"] },
          "then": {
            "required": ["capability_lifecycle_row_ref"],
            "properties": {
              "capability_lifecycle_row_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        },
        {
          "if": { "properties": { "handoff_class": { "const": "open_policy_explainer" } }, "required": ["handoff_class"] },
          "then": {
            "required": ["active_policy_bundle_ref", "policy_rule_ref"],
            "properties": {
              "active_policy_bundle_ref": { "$ref": "#/$defs/opaque_id" },
              "policy_rule_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        },
        {
          "if": { "properties": { "handoff_class": { "const": "open_compatibility_report_for_mode" } }, "required": ["handoff_class"] },
          "then": {
            "required": ["certified_archetype_report_ref", "active_environment_mode"],
            "properties": {
              "certified_archetype_report_ref": { "$ref": "#/$defs/opaque_id" },
              "active_environment_mode": { "$ref": "#/$defs/environment_mode_class" }
            }
          }
        },
        {
          "if": { "properties": { "handoff_class": { "const": "open_archetype_status_or_request_support" } }, "required": ["handoff_class"] },
          "then": {
            "anyOf": [
              { "required": ["reference_workspace_row_ref"], "properties": { "reference_workspace_row_ref": { "$ref": "#/$defs/opaque_id" } } },
              { "required": ["archetype_rubric_row_ref"], "properties": { "archetype_rubric_row_ref": { "$ref": "#/$defs/opaque_id" } } }
            ]
          }
        },
        {
          "if": { "properties": { "handoff_class": { "const": "open_diagnostics_repair" } }, "required": ["handoff_class"] },
          "then": {
            "anyOf": [
              { "required": ["doctor_finding_ref"], "properties": { "doctor_finding_ref": { "$ref": "#/$defs/opaque_id" } } },
              { "required": ["diagnostics_card_ref"], "properties": { "diagnostics_card_ref": { "$ref": "#/$defs/opaque_id" } } }
            ]
          }
        },
        {
          "if": { "properties": { "handoff_class": { "const": "open_configuration_setup" } }, "required": ["handoff_class"] },
          "then": {
            "required": ["setup_target_ref", "configuration_kind"],
            "properties": {
              "setup_target_ref": { "$ref": "#/$defs/opaque_id" },
              "configuration_kind": { "$ref": "#/$defs/configuration_kind" }
            }
          }
        }
      ]
    },
    "current_readiness_object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "availability_state",
        "availability_state_label_text",
        "availability_explanation_sentence",
        "workflow_capability_id",
        "workflow_capability_class",
        "workflow_capability_label",
        "effective_environment_mode",
        "effective_environment_mode_set",
        "dependency_marker_state",
        "support_scope_badge_ref",
        "why_unavailable_handoff",
        "evidence_links",
        "captured_at"
      ],
      "properties": {
        "availability_state": { "$ref": "#/$defs/availability_state_class" },
        "availability_state_label_text": { "$ref": "#/$defs/availability_state_label_text" },
        "availability_explanation_sentence": { "$ref": "#/$defs/reviewable_sentence" },
        "workflow_capability_id": { "$ref": "#/$defs/opaque_id" },
        "workflow_capability_class": { "$ref": "#/$defs/workflow_capability_class" },
        "workflow_capability_label": { "$ref": "#/$defs/short_label" },
        "effective_environment_mode": { "$ref": "#/$defs/environment_mode_class" },
        "effective_environment_mode_set": { "$ref": "#/$defs/environment_mode_set" },
        "dependency_marker_state": { "$ref": "#/$defs/dependency_marker_state_block" },
        "support_scope_badge_ref": { "$ref": "#/$defs/opaque_id" },
        "why_unavailable_handoff": {
          "oneOf": [
            { "$ref": "#/$defs/why_unavailable_handoff" },
            { "type": "null" }
          ]
        },
        "evidence_links": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "minItems": 1
        },
        "captured_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "if": { "properties": { "availability_state": { "const": "ready" } }, "required": ["availability_state"] },
          "then": {
            "properties": {
              "availability_state_label_text": { "const": "Ready" },
              "why_unavailable_handoff": { "type": "null" }
            }
          }
        },
        {
          "if": { "not": { "properties": { "availability_state": { "const": "ready" } }, "required": ["availability_state"] } },
          "then": {
            "properties": {
              "why_unavailable_handoff": { "$ref": "#/$defs/why_unavailable_handoff" }
            }
          }
        },
        {
          "if": { "properties": { "availability_state": { "const": "ready_with_caveats" } }, "required": ["availability_state"] },
          "then": {
            "properties": {
              "availability_state_label_text": { "const": "Ready with caveats" },
              "why_unavailable_handoff": {
                "properties": { "handoff_class": { "const": "open_capability_axis_inspector" } }
              }
            }
          }
        },
        {
          "if": { "properties": { "availability_state": { "const": "partial_index" } }, "required": ["availability_state"] },
          "then": {
            "properties": {
              "availability_state_label_text": { "const": "Partial index" },
              "why_unavailable_handoff": {
                "properties": { "handoff_class": { "const": "open_index_status_repair" } }
              },
              "dependency_marker_state": {
                "properties": {
                  "entries": {
                    "contains": {
                      "properties": {
                        "marker_kind": {
                          "enum": ["index_warming_dependency", "freshness_floor_dependency"]
                        }
                      },
                      "required": ["marker_kind"]
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "availability_state": { "const": "missing_toolchain" } }, "required": ["availability_state"] },
          "then": {
            "properties": {
              "availability_state_label_text": { "const": "Missing toolchain" },
              "why_unavailable_handoff": {
                "properties": { "handoff_class": { "const": "install_or_locate_toolchain" } }
              },
              "dependency_marker_state": {
                "properties": {
                  "entries": {
                    "contains": {
                      "allOf": [
                        { "properties": { "marker_kind": { "const": "toolchain_or_sdk_or_runtime_dependency" } }, "required": ["marker_kind"] },
                        { "properties": { "marker_state": { "enum": ["absent", "below_required_version", "blocked", "unknown"] } }, "required": ["marker_state"] }
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "availability_state": { "const": "not_configured" } }, "required": ["availability_state"] },
          "then": {
            "properties": {
              "availability_state_label_text": { "const": "Not configured" },
              "why_unavailable_handoff": {
                "properties": { "handoff_class": { "const": "open_configuration_setup" } }
              }
            }
          }
        },
        {
          "if": { "properties": { "availability_state": { "const": "policy_blocked" } }, "required": ["availability_state"] },
          "then": {
            "properties": {
              "availability_state_label_text": { "const": "Policy blocked" },
              "why_unavailable_handoff": {
                "properties": { "handoff_class": { "const": "open_policy_explainer" } }
              }
            }
          }
        },
        {
          "if": { "properties": { "availability_state": { "const": "not_certified_in_this_mode" } }, "required": ["availability_state"] },
          "then": {
            "properties": {
              "availability_state_label_text": { "const": "Not certified in this mode" },
              "why_unavailable_handoff": {
                "properties": { "handoff_class": { "const": "open_compatibility_report_for_mode" } }
              },
              "effective_environment_mode_set": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        },
        {
          "if": { "properties": { "availability_state": { "const": "not_supported" } }, "required": ["availability_state"] },
          "then": {
            "properties": {
              "availability_state_label_text": { "const": "Not supported" },
              "why_unavailable_handoff": {
                "properties": { "handoff_class": { "const": "open_archetype_status_or_request_support" } }
              }
            }
          }
        },
        {
          "if": { "properties": { "availability_state": { "const": "unknown_repair_required" } }, "required": ["availability_state"] },
          "then": {
            "properties": {
              "availability_state_label_text": { "const": "Unknown repair required" },
              "why_unavailable_handoff": {
                "properties": { "handoff_class": { "const": "open_diagnostics_repair" } }
              }
            }
          }
        }
      ]
    },
    "support_scope_badge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lifecycle_state",
        "support_class",
        "release_channel",
        "client_scopes",
        "freshness_class",
        "certified_archetype_state",
        "dependency_markers",
        "archetype_row_ref",
        "support_window_ref",
        "known_limit_refs"
      ],
      "properties": {
        "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
        "support_class": { "$ref": "#/$defs/support_class" },
        "release_channel": { "$ref": "#/$defs/release_channel" },
        "client_scopes": {
          "$ref": "#/$defs/client_scope_set",
          "minItems": 1
        },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "certified_archetype_state": { "$ref": "#/$defs/certified_archetype_state" },
        "dependency_markers": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependency_marker_entry" },
          "minItems": 1,
          "uniqueItems": false
        },
        "archetype_row_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "support_window_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "known_limit_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "support_class": { "enum": ["standard_support", "extended_support"] }
            },
            "required": ["support_class"]
          },
          "then": {
            "required": ["archetype_row_ref", "support_window_ref"],
            "properties": {
              "archetype_row_ref": { "$ref": "#/$defs/opaque_id" },
              "support_window_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "certified_archetype_state": { "const": "supported" }
            },
            "required": ["certified_archetype_state"]
          },
          "then": {
            "required": ["archetype_row_ref"],
            "properties": {
              "archetype_row_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        }
      ]
    },
    "feature_availability_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "feature_availability_row_schema_version",
        "feature_availability_row_id",
        "current_readiness",
        "support_scope_badge",
        "consumer_surfaces",
        "redaction_class",
        "export_safe",
        "narrative_refs"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/feature_availability_row_kind" },
        "feature_availability_row_schema_version": { "$ref": "#/$defs/feature_availability_row_schema_version" },
        "feature_availability_row_id": { "$ref": "#/$defs/opaque_id" },
        "current_readiness": { "$ref": "#/$defs/current_readiness_object" },
        "support_scope_badge": { "$ref": "#/$defs/support_scope_badge" },
        "consumer_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/consumer_surface_class" },
          "minItems": 1,
          "uniqueItems": true
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "export_safe": { "type": "boolean" },
        "narrative_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "current_readiness": {
                "properties": { "availability_state": { "const": "not_certified_in_this_mode" } },
                "required": ["availability_state"]
              }
            },
            "required": ["current_readiness"]
          },
          "then": {
            "properties": {
              "support_scope_badge": {
                "properties": {
                  "certified_archetype_state": {
                    "enum": ["supported", "best_effort", "untested", "degraded", "unsupported"]
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "support_scope_badge": {
                "properties": { "certified_archetype_state": { "const": "supported" } },
                "required": ["certified_archetype_state"]
              }
            },
            "required": ["support_scope_badge"]
          },
          "then": {
            "properties": {
              "current_readiness": {
                "properties": {
                  "effective_environment_mode_set": {
                    "type": "array",
                    "minItems": 1
                  }
                }
              }
            }
          }
        }
      ]
    },
    "support_scope_badge_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "feature_availability_row_schema_version",
        "support_scope_badge_id",
        "workflow_capability_id",
        "workflow_capability_class",
        "support_scope_badge",
        "redaction_class",
        "export_safe",
        "narrative_refs"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/support_scope_badge_kind" },
        "feature_availability_row_schema_version": { "$ref": "#/$defs/feature_availability_row_schema_version" },
        "support_scope_badge_id": { "$ref": "#/$defs/opaque_id" },
        "workflow_capability_id": { "$ref": "#/$defs/opaque_id" },
        "workflow_capability_class": { "$ref": "#/$defs/workflow_capability_class" },
        "support_scope_badge": { "$ref": "#/$defs/support_scope_badge" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "export_safe": { "type": "boolean" },
        "narrative_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  }
}
