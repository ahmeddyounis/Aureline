{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/clipboard_payload_class.schema.json",
  "title": "Aureline clipboard-payload-class contract",
  "description": "Boundary schema for clipboard_payload_class_record. Every covered editor, diff, review, result-grid, and provider-linked surface declares one payload class per source object. The class names the default representation (always plain text), any non-default rich/context variants that diverge from raw/source truth, the clipboard route posture, and the sensitive-copy review when applicable. Raw clipboard bodies, raw file contents, raw private paths, raw provider tokens, and raw URLs never cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/clipboard_payload_class_record" }
  ],
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version. Current value is 1."
    },
    "record_kind": {
      "type": "string",
      "const": "clipboard_payload_class_record"
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "shell:interaction_transfer_beta:v1"
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 720,
      "description": "Opaque, stable id safe to log, on RPC, and in support bundles."
    },
    "short_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Short, privacy-safe label safe for direct rendering."
    },
    "safe_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1600,
      "description": "Bounded redaction-aware text safe for fixtures and support export."
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "editor",
        "diff",
        "review",
        "result_grid",
        "provider_linked"
      ]
    },
    "representation_class": {
      "type": "string",
      "enum": [
        "plain_text",
        "raw_safe",
        "rendered",
        "with_context",
        "escaped",
        "sanitized",
        "redacted",
        "metadata_only"
      ]
    },
    "clipboard_route": {
      "type": "string",
      "enum": [
        "local_system",
        "remote_bridge",
        "named_register",
        "policy_blocked"
      ]
    },
    "sensitive_posture": {
      "type": "string",
      "enum": [
        "not_sensitive",
        "label_first_preview",
        "write_blocked"
      ]
    },
    "copy_variant_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "variant_id_ref",
        "variant_label",
        "representation_class",
        "representation_class_token",
        "diverges_from_source_truth"
      ],
      "properties": {
        "variant_id_ref": { "$ref": "#/$defs/opaque_id" },
        "variant_label": { "$ref": "#/$defs/short_label" },
        "representation_class": { "$ref": "#/$defs/representation_class" },
        "representation_class_token": { "$ref": "#/$defs/representation_class" },
        "diverges_from_source_truth": { "type": "boolean" }
      }
    },
    "clipboard_payload_class_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "payload_class_id",
        "surface_class",
        "surface_class_token",
        "source_ref",
        "source_label",
        "default_representation_class",
        "default_representation_class_token",
        "default_representation_label",
        "variant_disclosures",
        "clipboard_route",
        "clipboard_route_token",
        "route_disclosure_material",
        "sensitive_posture",
        "sensitive_posture_token",
        "sensitive_value_class_tokens",
        "label_first_path",
        "clipboard_write_deferred_until_review",
        "paste_targets_neutral"
      ],
      "properties": {
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "payload_class_id": { "$ref": "#/$defs/opaque_id" },
        "surface_class": { "$ref": "#/$defs/surface_class" },
        "surface_class_token": { "$ref": "#/$defs/surface_class" },
        "source_ref": { "$ref": "#/$defs/opaque_id" },
        "source_label": { "$ref": "#/$defs/short_label" },
        "default_representation_class": {
          "$ref": "#/$defs/representation_class",
          "const": "plain_text",
          "description": "Default copy must be the plain-text-safe representation."
        },
        "default_representation_class_token": {
          "$ref": "#/$defs/representation_class",
          "const": "plain_text"
        },
        "default_representation_label": { "$ref": "#/$defs/safe_text" },
        "variant_disclosures": {
          "type": "array",
          "items": { "$ref": "#/$defs/copy_variant_disclosure" }
        },
        "clipboard_route": { "$ref": "#/$defs/clipboard_route" },
        "clipboard_route_token": { "$ref": "#/$defs/clipboard_route" },
        "route_disclosure_material": { "type": "boolean" },
        "sensitive_posture": { "$ref": "#/$defs/sensitive_posture" },
        "sensitive_posture_token": { "$ref": "#/$defs/sensitive_posture" },
        "sensitive_value_class_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/short_label" }
        },
        "sensitive_preview_action_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "label_first_path": { "type": "boolean" },
        "clipboard_write_deferred_until_review": { "type": "boolean" },
        "paste_targets_neutral": {
          "type": "boolean",
          "const": true,
          "description": "True when the default copy pastes safely into terminals, reviews, issue trackers, and support flows without hidden formatting traps."
        }
      }
    }
  }
}
