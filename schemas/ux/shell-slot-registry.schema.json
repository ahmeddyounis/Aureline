{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/shell-slot-registry.schema.json",
  "title": "Aureline stable shell slot registry and responsive fallback packet",
  "description": "Boundary schema for the stable shell-slot registry packet emitted by aureline-shell. Core shell, diagnostics, support export, docs/help, and extension admission consume this packet to share declared slots, permitted surface kinds, fallback ladders, stable-surface ownership, and placeholder-preserving hydration fixtures. Records carry closed vocabulary, command ids, owner refs, and review-safe summaries only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "shell_zoning_schema_version",
    "contract_ref",
    "declared_slots",
    "responsive_ladders",
    "stable_surface_claims",
    "placeholder_hydration_cases",
    "audit"
  ],
  "properties": {
    "record_kind": { "const": "shell_zoning_responsive_fallback_packet" },
    "shell_zoning_schema_version": { "type": "integer", "const": 1 },
    "contract_ref": { "type": "string", "minLength": 1 },
    "declared_slots": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/declared_slot" }
    },
    "responsive_ladders": {
      "type": "array",
      "minItems": 24,
      "items": { "$ref": "#/$defs/responsive_ladder" }
    },
    "stable_surface_claims": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/stable_surface_claim" }
    },
    "placeholder_hydration_cases": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/slot_hydration_case" }
    },
    "audit": { "$ref": "#/$defs/audit" }
  },
  "$defs": {
    "zone_id": {
      "type": "string",
      "enum": [
        "title_context_bar",
        "activity_rail",
        "left_sidebar",
        "main_workspace",
        "right_inspector",
        "bottom_panel",
        "status_bar",
        "transient_overlay"
      ]
    },
    "slot_id": {
      "type": "string",
      "enum": [
        "title_context_bar_identity",
        "activity_rail_primary_routes",
        "left_sidebar_section_surface",
        "main_workspace_working_set",
        "main_workspace_review_surface",
        "right_inspector_contextual_detail",
        "bottom_panel_tool_panels",
        "status_bar_recovery_primary",
        "status_bar_extension_scoped",
        "transient_overlay_command_palette",
        "transient_overlay_dialog_or_sheet"
      ]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "host_chrome",
        "first_party",
        "provider_backed",
        "extension_contributed"
      ]
    },
    "adaptive_class": {
      "type": "string",
      "enum": ["compact_desktop", "standard_desktop", "expanded_desktop"]
    },
    "fallback_placement": {
      "type": "string",
      "enum": ["docked", "sheet", "overflow", "placeholder"]
    },
    "placeholder_class": {
      "type": "string",
      "enum": [
        "required_chrome",
        "missing_extension",
        "missing_remote",
        "missing_provider",
        "capability_loss",
        "topology_drift"
      ]
    },
    "dependency_loss_class": {
      "type": "string",
      "enum": [
        "warm_restore_pending_rebind",
        "extension_removed",
        "remote_unavailable",
        "provider_capability_lost",
        "display_topology_changed"
      ]
    },
    "non_empty": { "type": "string", "minLength": 1 },
    "command_id": {
      "type": "string",
      "pattern": "^cmd:[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
    },
    "declared_slot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "shell_zone",
        "slot_label",
        "permitted_surface_kinds",
        "fallback_order",
        "close_command_id",
        "reopen_command_id",
        "placeholder_class",
        "stable_required",
        "owner_ref",
        "private_top_level_chrome_forbidden"
      ],
      "properties": {
        "slot_id": { "$ref": "#/$defs/slot_id" },
        "shell_zone": { "$ref": "#/$defs/zone_id" },
        "slot_label": { "$ref": "#/$defs/non_empty" },
        "permitted_surface_kinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/surface_kind" }
        },
        "fallback_order": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "contains": { "const": "placeholder" },
          "items": { "$ref": "#/$defs/fallback_placement" }
        },
        "close_command_id": { "$ref": "#/$defs/command_id" },
        "reopen_command_id": { "$ref": "#/$defs/command_id" },
        "placeholder_class": { "$ref": "#/$defs/placeholder_class" },
        "stable_required": { "type": "boolean" },
        "owner_ref": { "$ref": "#/$defs/non_empty" },
        "private_top_level_chrome_forbidden": { "const": true }
      }
    },
    "responsive_ladder": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "adaptive_class",
        "minimum_editor_width_px",
        "placements_in_order",
        "preserves_slot_identity",
        "preserves_breadcrumb_truth",
        "preserves_trust_truth",
        "preserves_execution_target_truth",
        "keyboard_reachable_recovery"
      ],
      "properties": {
        "slot_id": { "$ref": "#/$defs/slot_id" },
        "adaptive_class": { "$ref": "#/$defs/adaptive_class" },
        "minimum_editor_width_px": { "type": "integer", "minimum": 420 },
        "placements_in_order": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fallback_placement" }
        },
        "preserves_slot_identity": { "const": true },
        "preserves_breadcrumb_truth": { "const": true },
        "preserves_trust_truth": { "const": true },
        "preserves_execution_target_truth": { "const": true },
        "keyboard_reachable_recovery": { "const": true }
      }
    },
    "stable_surface_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "owned_by",
        "declared_slot_id",
        "surface_kind",
        "stable_claim",
        "has_private_top_level_chrome",
        "creates_duplicate_sidebar",
        "creates_floating_global_button",
        "occupancy_reason"
      ],
      "properties": {
        "surface_id": { "$ref": "#/$defs/non_empty" },
        "owned_by": { "$ref": "#/$defs/non_empty" },
        "declared_slot_id": { "$ref": "#/$defs/slot_id" },
        "surface_kind": { "$ref": "#/$defs/surface_kind" },
        "stable_claim": { "const": true },
        "has_private_top_level_chrome": { "const": false },
        "creates_duplicate_sidebar": { "const": false },
        "creates_floating_global_button": { "const": false },
        "occupancy_reason": { "$ref": "#/$defs/non_empty" }
      }
    },
    "slot_hydration_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "surface_id",
        "slot_id",
        "shell_zone",
        "dependency_loss",
        "placeholder_class",
        "preserves_breadcrumb_truth",
        "preserves_trust_truth",
        "preserves_target_truth",
        "preserves_reopen_path",
        "adjacent_layout_collapsed",
        "topology_identity_preserved"
      ],
      "properties": {
        "scenario_id": { "$ref": "#/$defs/non_empty" },
        "surface_id": { "$ref": "#/$defs/non_empty" },
        "slot_id": { "$ref": "#/$defs/slot_id" },
        "shell_zone": { "$ref": "#/$defs/zone_id" },
        "dependency_loss": { "$ref": "#/$defs/dependency_loss_class" },
        "placeholder_class": { "$ref": "#/$defs/placeholder_class" },
        "preserves_breadcrumb_truth": { "const": true },
        "preserves_trust_truth": { "const": true },
        "preserves_target_truth": { "const": true },
        "preserves_reopen_path": { "const": true },
        "adjacent_layout_collapsed": { "const": false },
        "topology_identity_preserved": { "const": true }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "every_stable_surface_declared",
        "every_slot_valid",
        "no_private_top_level_chrome",
        "no_duplicate_sidebars",
        "no_floating_global_buttons",
        "responsive_ladders_preserve_truth",
        "placeholders_preserve_declared_slot"
      ],
      "properties": {
        "every_stable_surface_declared": { "const": true },
        "every_slot_valid": { "const": true },
        "no_private_top_level_chrome": { "const": true },
        "no_duplicate_sidebars": { "const": true },
        "no_floating_global_buttons": { "const": true },
        "responsive_ladders_preserve_truth": { "const": true },
        "placeholders_preserve_declared_slot": { "const": true }
      }
    }
  }
}
