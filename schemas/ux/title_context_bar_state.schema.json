{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/title_context_bar_state.schema.json",
  "title": "Aureline title/context bar identity state contract",
  "description": "Boundary schema for the canonical shell identity tuple frozen in docs/ux/title_context_bar_contract.md. A title_context_bar_state_record names workspace/root identity, repo or branch context when applicable, trust state, host class, profile, route state, degraded/recovery state, field visibility, and surface projections so title/context bar chrome, native window title, workspace status item, and support/export representations quote one state object without surface-local fields. Raw paths, raw URLs, raw hostnames, raw user identifiers, raw tokens, raw command lines, and raw support payload bodies never cross this boundary; records carry opaque refs, controlled tokens, and privacy-safe labels.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "title_context_bar_state_schema_version",
    "state_id",
    "workspace_identity",
    "repo_identity",
    "trust_identity",
    "host_identity",
    "profile_identity",
    "route_state",
    "degraded_or_recovery_state",
    "field_visibility",
    "surface_projections",
    "updated_at",
    "narrative_refs"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "__fixture__": {
      "$ref": "#/$defs/fixture_metadata"
    },
    "record_kind": {
      "type": "string",
      "const": "title_context_bar_state_record",
      "description": "Discriminator for this record family."
    },
    "title_context_bar_state_schema_version": {
      "$ref": "#/$defs/title_context_bar_state_schema_version"
    },
    "state_id": {
      "$ref": "#/$defs/opaque_id"
    },
    "workspace_identity": {
      "$ref": "#/$defs/workspace_identity"
    },
    "repo_identity": {
      "$ref": "#/$defs/repo_identity"
    },
    "trust_identity": {
      "$ref": "#/$defs/trust_identity"
    },
    "host_identity": {
      "$ref": "#/$defs/host_identity"
    },
    "profile_identity": {
      "$ref": "#/$defs/profile_identity"
    },
    "route_state": {
      "$ref": "#/$defs/route_state"
    },
    "degraded_or_recovery_state": {
      "$ref": "#/$defs/degraded_or_recovery_state"
    },
    "field_visibility": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/field_visibility_rule"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "surface_projections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/surface_projection"
      },
      "minItems": 4,
      "uniqueItems": true
    },
    "updated_at": {
      "$ref": "#/$defs/monotonic_timestamp"
    },
    "narrative_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "properties": {
        "surface_projections": {
          "contains": {
            "properties": {
              "surface": { "const": "title_context_bar" }
            },
            "required": ["surface"]
          }
        }
      }
    },
    {
      "properties": {
        "surface_projections": {
          "contains": {
            "properties": {
              "surface": { "const": "native_window_title" }
            },
            "required": ["surface"]
          }
        }
      }
    },
    {
      "properties": {
        "surface_projections": {
          "contains": {
            "properties": {
              "surface": { "const": "workspace_status_item" }
            },
            "required": ["surface"]
          }
        }
      }
    },
    {
      "properties": {
        "surface_projections": {
          "contains": {
            "properties": {
              "surface": { "const": "support_export" }
            },
            "required": ["surface"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "repo_identity": {
            "properties": {
              "repo_state_class": {
                "enum": ["not_applicable", "metadata_missing", "detached_metadata"]
              }
            },
            "required": ["repo_state_class"]
          }
        },
        "required": ["repo_identity"]
      },
      "then": {
        "properties": {
          "repo_identity": {
            "properties": {
              "branch_label": { "type": "null" },
              "branch_ref": { "type": "null" }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "title_context_bar_state_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this identity tuple. Additive optional fields or enum values bump this const; repurposing a value is breaking."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "linked_docs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$",
      "description": "Opaque stable id safe for logs, support bundles, status records, and schema fixtures. Raw paths, URLs, hostnames, user identifiers, tokens, and payload bodies never appear here."
    },
    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 140,
      "description": "Privacy-safe short label intended for title/context bar, native window title, status item, or support summary rendering."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280,
      "description": "Short privacy-safe explanatory sentence. Raw paths, URLs, hostnames, user identifiers, tokens, command lines, and secret material MUST NOT appear."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 UTC timestamp produced from the shell's monotonic event timeline."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "nullable_short_label": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/short_label_text" }
      ]
    },
    "workspace_kind": {
      "type": "string",
      "enum": [
        "empty_shell",
        "local_folder",
        "local_repo_root",
        "workspace_with_roots",
        "workset_slice",
        "remote_workspace",
        "managed_cloud_workspace",
        "restored_checkpoint"
      ]
    },
    "workspace_lifecycle_state": {
      "type": "string",
      "enum": [
        "workspace.discovered",
        "workspace.trust_evaluating",
        "workspace.opening",
        "workspace.partially_ready",
        "workspace.ready",
        "workspace.degraded",
        "workspace.read_only_degraded",
        "workspace.recovering",
        "workspace.closing",
        "workspace.closed"
      ]
    },
    "root_readiness_class": {
      "type": "string",
      "enum": [
        "single_root_ready",
        "multi_root_all_ready",
        "multi_root_partial",
        "multi_root_mixed_trust",
        "root_missing",
        "root_policy_hidden",
        "not_applicable"
      ]
    },
    "repo_state_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "attached_single_repo",
        "detached_head",
        "metadata_missing",
        "detached_metadata",
        "mixed_multi_repo",
        "provider_overlay_stale"
      ]
    },
    "trust_state": {
      "type": "string",
      "enum": [
        "untrusted_unknown",
        "restricted",
        "trusted",
        "trusted_time_bounded",
        "trusted_policy_degraded",
        "restricted_recovery_fallback",
        "restricted_extension_quarantine",
        "trust_revoked",
        "trust_unavailable_identity_gate"
      ]
    },
    "trust_source_class": {
      "type": "string",
      "enum": [
        "first_open_default",
        "user_grant",
        "remembered_user_grant",
        "admin_policy_prebinding",
        "policy_narrowed",
        "recovery_ladder",
        "extension_quarantine",
        "identity_gate",
        "user_or_admin_revoked"
      ]
    },
    "host_class": {
      "type": "string",
      "enum": [
        "local",
        "remote_host",
        "container_devcontainer",
        "managed_workspace",
        "browser_runtime_bridge",
        "service_plane",
        "mixed_local_plus_remote",
        "unknown_missing_details"
      ]
    },
    "host_state_class": {
      "type": "string",
      "enum": [
        "ready",
        "probing",
        "sync_warming",
        "reconnecting",
        "read_only_degraded",
        "offline",
        "policy_blocked",
        "missing_details",
        "mixed"
      ]
    },
    "deployment_profile_class": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud"
      ]
    },
    "identity_mode": {
      "type": "string",
      "enum": [
        "account_free_local",
        "self_hosted_org",
        "managed_workspace"
      ]
    },
    "profile_mode_class": {
      "type": "string",
      "enum": [
        "standard",
        "temporary_session",
        "safe_mode",
        "imported_profile",
        "managed_policy_profile",
        "support_recovery"
      ]
    },
    "route_kind": {
      "type": "string",
      "enum": [
        "ordinary_editing",
        "entry_route",
        "restore_route",
        "review_route",
        "run_debug_route",
        "remote_attach_route",
        "deep_link_review",
        "support_export",
        "recovery_route"
      ]
    },
    "authority_delta_class": {
      "type": "string",
      "enum": [
        "none",
        "trust_boundary_crossing",
        "policy_boundary_crossing",
        "remote_authority_rebind",
        "auth_scope_widening",
        "mutation_or_execution_pending_review",
        "unknown_requires_review"
      ]
    },
    "route_freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "warming",
        "partial",
        "stale",
        "offline",
        "unknown_requires_review"
      ]
    },
    "degraded_state_token": {
      "type": "string",
      "enum": [
        "Warming",
        "Cached",
        "Partial",
        "Stale",
        "Offline",
        "PolicyBlocked",
        "Limited",
        "Unsupported",
        "Experimental",
        "RetestPending"
      ]
    },
    "recovery_mode_class": {
      "type": "string",
      "enum": [
        "none",
        "restricted_mode",
        "safe_mode",
        "open_without_restore",
        "partial_open",
        "reconnecting",
        "read_only_degraded",
        "policy_blocked",
        "missing_metadata",
        "mixed_state_review"
      ]
    },
    "field_path": {
      "type": "string",
      "enum": [
        "workspace_identity.display_label",
        "workspace_identity.workspace_kind",
        "workspace_identity.lifecycle_state",
        "workspace_identity.root_summary",
        "repo_identity.repo_state_class",
        "repo_identity.repo_label",
        "repo_identity.branch_label",
        "repo_identity.revision_ref",
        "trust_identity.trust_state",
        "trust_identity.trust_source",
        "host_identity.host_class",
        "host_identity.host_state",
        "host_identity.target_label",
        "profile_identity.profile_label",
        "profile_identity.profile_mode",
        "profile_identity.deployment_profile",
        "profile_identity.identity_mode",
        "route_state.route_kind",
        "route_state.route_label",
        "route_state.authority_delta",
        "route_state.route_freshness",
        "degraded_or_recovery_state.degraded_tokens",
        "degraded_or_recovery_state.recovery_mode",
        "degraded_or_recovery_state.last_failure_summary"
      ]
    },
    "visibility_class": {
      "type": "string",
      "enum": [
        "primary_visible",
        "condensed_visible",
        "inspector_only",
        "native_title_only",
        "support_export_only",
        "hidden_redacted",
        "omitted_not_applicable"
      ]
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "title_context_bar",
        "native_window_title",
        "workspace_status_item",
        "support_export"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "root_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root_count",
        "ready_root_count",
        "primary_root_label",
        "root_readiness",
        "root_detail_refs"
      ],
      "properties": {
        "root_count": {
          "type": "integer",
          "minimum": 0
        },
        "ready_root_count": {
          "type": "integer",
          "minimum": 0
        },
        "primary_root_label": {
          "$ref": "#/$defs/nullable_short_label"
        },
        "root_readiness": {
          "$ref": "#/$defs/root_readiness_class"
        },
        "root_detail_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },
    "workspace_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_ref",
        "display_label",
        "workspace_kind",
        "lifecycle_state",
        "root_summary"
      ],
      "properties": {
        "workspace_ref": { "$ref": "#/$defs/opaque_id" },
        "display_label": { "$ref": "#/$defs/short_label_text" },
        "workspace_kind": { "$ref": "#/$defs/workspace_kind" },
        "lifecycle_state": { "$ref": "#/$defs/workspace_lifecycle_state" },
        "root_summary": { "$ref": "#/$defs/root_summary" }
      }
    },
    "repo_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_state_class",
        "repo_ref",
        "repo_label",
        "branch_label",
        "branch_ref",
        "revision_ref",
        "repo_detail_refs"
      ],
      "properties": {
        "repo_state_class": { "$ref": "#/$defs/repo_state_class" },
        "repo_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "repo_label": { "$ref": "#/$defs/nullable_short_label" },
        "branch_label": { "$ref": "#/$defs/nullable_short_label" },
        "branch_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "revision_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "repo_detail_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        }
      }
    },
    "trust_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust_state",
        "trust_source",
        "trust_review_action_ref",
        "last_changed_at"
      ],
      "properties": {
        "trust_state": { "$ref": "#/$defs/trust_state" },
        "trust_source": { "$ref": "#/$defs/trust_source_class" },
        "trust_review_action_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "last_changed_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    },
    "host_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "host_class",
        "host_state",
        "target_ref",
        "target_label",
        "boundary_note"
      ],
      "properties": {
        "host_class": { "$ref": "#/$defs/host_class" },
        "host_state": { "$ref": "#/$defs/host_state_class" },
        "target_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "target_label": { "$ref": "#/$defs/nullable_short_label" },
        "boundary_note": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "profile_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_ref",
        "profile_label",
        "profile_mode",
        "deployment_profile",
        "identity_mode"
      ],
      "properties": {
        "profile_ref": { "$ref": "#/$defs/opaque_id" },
        "profile_label": { "$ref": "#/$defs/short_label_text" },
        "profile_mode": { "$ref": "#/$defs/profile_mode_class" },
        "deployment_profile": { "$ref": "#/$defs/deployment_profile_class" },
        "identity_mode": { "$ref": "#/$defs/identity_mode" }
      }
    },
    "route_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_kind",
        "route_ref",
        "route_label",
        "authority_delta",
        "route_freshness",
        "active_surface_ref"
      ],
      "properties": {
        "route_kind": { "$ref": "#/$defs/route_kind" },
        "route_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "route_label": { "$ref": "#/$defs/short_label_text" },
        "authority_delta": { "$ref": "#/$defs/authority_delta_class" },
        "route_freshness": { "$ref": "#/$defs/route_freshness_class" },
        "active_surface_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "degraded_or_recovery_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "degraded_tokens",
        "recovery_mode",
        "last_failure_ref",
        "last_failure_summary",
        "primary_recovery_action_ref",
        "support_status_ref"
      ],
      "properties": {
        "degraded_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/degraded_state_token" },
          "uniqueItems": true
        },
        "recovery_mode": { "$ref": "#/$defs/recovery_mode_class" },
        "last_failure_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "last_failure_summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        },
        "primary_recovery_action_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "support_status_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "field_visibility_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_path",
        "visibility",
        "visible_in_surfaces",
        "overflow_target_surface",
        "reason"
      ],
      "properties": {
        "field_path": { "$ref": "#/$defs/field_path" },
        "visibility": { "$ref": "#/$defs/visibility_class" },
        "visible_in_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_kind" },
          "uniqueItems": true
        },
        "overflow_target_surface": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/surface_kind" }
          ]
        },
        "reason": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "surface_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "projection_ref",
        "field_paths",
        "render_label",
        "opens_detail_surface_ref",
        "redaction_class",
        "forbids_surface_local_fields"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/surface_kind" },
        "projection_ref": { "$ref": "#/$defs/opaque_id" },
        "field_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/field_path" },
          "minItems": 1,
          "uniqueItems": true
        },
        "render_label": { "$ref": "#/$defs/short_label_text" },
        "opens_detail_surface_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "forbids_surface_local_fields": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
