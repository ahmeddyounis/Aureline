{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/fanout_receipt.schema.json",
  "title": "Aureline notification fanout receipt contract",
  "description": "Boundary schema for fanout_receipt_record frozen in docs/ux/notification_envelope_contract.md. A fanout receipt is a typed, joinable record of a delivery attempt (or deliberate non-delivery) to a specific surface and client scope. Receipts exist so suppressed, deduped, stale, or dropped fanout remains visible truth instead of disappearing into best-effort transport behavior. Raw bodies, raw paths, raw URLs, raw provider payloads, raw prompt or completion text, raw command bodies, secret material, and customer-owned identifiers never cross this boundary; receipts carry stable ids, stable enums, privacy/export posture, and reopen linkage only. Adding a new fanout_surface_class, fanout_receipt_state, stale_or_undelivered_reason_class, or client_scope value is additive-minor and requires a fanout_receipt_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [{ "$ref": "#/$defs/fanout_receipt_record" }],
  "$defs": {
    "fanout_receipt_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this fanout-receipt vocabulary export. Current value is 1."
    },
    "instance_schema_hint": {
      "type": "string",
      "format": "uri-reference",
      "description": "Optional schema hint carried on worked fixtures."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe on RPC, safe in manifests / journal entries / support bundles / OS payloads. Raw bodies, raw paths, raw URLs, and secret material never appear here."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },
    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Short privacy-safe label text. Must not contain raw paths, raw URLs, raw secret material, raw customer-owned identifiers, or raw AI prompt / completion text."
    },
    "client_scope": {
      "type": "string",
      "enum": [
        "desktop_product",
        "cli",
        "companion_surface",
        "remote_agent",
        "sdk_or_api",
        "managed_admin_surface"
      ]
    },
    "dedupe_key_scheme": {
      "type": "string",
      "enum": [
        "canonical_event_id",
        "canonical_object_target_plus_event_class",
        "grouped_burst_id",
        "subsystem_plus_object_plus_phase",
        "cross_client_canonical_event_id"
      ]
    },
    "fanout_surface_class": {
      "type": "string",
      "enum": [
        "durable_job_row",
        "status_strip",
        "status_item",
        "activity_center_digest_card",
        "toast",
        "contextual_banner",
        "os_notification",
        "lock_screen_summary",
        "companion_push",
        "digest_group_row",
        "not_delivered_held"
      ],
      "description": "Frozen fanout surface vocabulary aligned with the delivery-surface class set."
    },
    "fanout_receipt_state": {
      "type": "string",
      "enum": [
        "delivered",
        "held_quiet_hours",
        "suppressed_policy",
        "deduped_canonical_event",
        "deduped_grouped_burst",
        "released_from_hold",
        "not_attempted_no_route"
      ]
    },
    "stale_or_undelivered_reason_class": {
      "type": "string",
      "enum": [
        "none",
        "held_by_quiet_hours",
        "suppressed_by_policy",
        "deduped_on_canonical_event",
        "deduped_on_grouped_burst",
        "no_route_for_surface_or_tier",
        "stale_before_delivery",
        "expired_before_delivery",
        "transport_failed",
        "unknown"
      ],
      "description": "Typed reason class for stale or undelivered fanout. The receipt_state remains the primary outcome; this field captures the reviewable reason when the outcome is not delivered or when a delivery is stale."
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ],
      "description": "Export / retention redaction posture applied to any durable sink that records this receipt."
    },
    "suppression_reason": {
      "type": "string",
      "enum": [
        "quiet_hours_user_policy",
        "do_not_disturb_user_policy",
        "focus_mode_user_policy",
        "presentation_mode_active",
        "screen_share_active",
        "privacy_mode_active",
        "admin_policy_suppression",
        "reduced_attention_posture",
        "power_saver_background_pause",
        "dedupe_same_canonical_event",
        "dedupe_same_grouped_burst",
        "class_muted_by_user",
        "class_snoozed_by_user",
        "release_pending_next_unsuppressed_surface"
      ]
    },
    "fanout_receipt_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "fanout_receipt_schema_version",
        "fanout_receipt_id",
        "source_notification_envelope_id_ref",
        "canonical_event_id",
        "event_lineage_id_ref",
        "fanout_surface_class",
        "client_scope",
        "receipt_state",
        "stale_or_undelivered_reason",
        "dedupe_key_scheme",
        "delivery_envelope_ref",
        "reopen_target_ref",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "$ref": "#/$defs/instance_schema_hint" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "type": "string", "const": "fanout_receipt_record" },
        "fanout_receipt_schema_version": { "$ref": "#/$defs/fanout_receipt_schema_version" },
        "fanout_receipt_id": { "$ref": "#/$defs/opaque_id" },
        "source_notification_envelope_id_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque reference to the originating notification_envelope_record."
        },
        "canonical_event_id": { "$ref": "#/$defs/opaque_id" },
        "event_lineage_id_ref": { "$ref": "#/$defs/opaque_id" },
        "fanout_surface_class": { "$ref": "#/$defs/fanout_surface_class" },
        "client_scope": { "$ref": "#/$defs/client_scope" },
        "receipt_state": { "$ref": "#/$defs/fanout_receipt_state" },
        "stale_or_undelivered_reason": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reason_class", "reason_label"],
          "properties": {
            "reason_class": { "$ref": "#/$defs/stale_or_undelivered_reason_class" },
            "reason_label": {
              "oneOf": [
                { "type": "null" },
                { "$ref": "#/$defs/short_label_text" }
              ],
              "description": "Optional privacy-safe label clarifying the reason (e.g. 'Held during presentation mode')."
            }
          }
        },
        "dedupe_key_scheme": { "$ref": "#/$defs/dedupe_key_scheme" },
        "delivery_envelope_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque reference to the per-surface delivery envelope (or a hold envelope when fanout_surface_class = not_delivered_held)."
        },
        "reopen_target_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque reference to the canonical reopen target used on activation."
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "suppression_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/suppression_reason" },
          "uniqueItems": true
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Delivered receipts MUST declare reason_class = none.",
          "if": {
            "properties": { "receipt_state": { "const": "delivered" } },
            "required": ["receipt_state"]
          },
          "then": {
            "properties": {
              "stale_or_undelivered_reason": {
                "properties": { "reason_class": { "const": "none" } },
                "required": ["reason_class"]
              }
            }
          }
        }
      ]
    }
  }
}

