{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/guided_tour.schema.json",
  "title": "Aureline guided-tour, architecture-map, walkthrough, and command-tip object model",
  "description": "Boundary schema for the multi-step guided-tour, architecture-map, walkthrough, and command-tip definitions frozen in docs/ux/learning_and_presentation_contract.md. Every multi-step tour resolves through one guided_tour_record naming the sequenced waypoints and the audience the tour is admissible for; every waypoint resolves through one tour_waypoint_record citing exactly one canonical anchor (a command_id, a docs citation anchor, or a symbol-linked reference); every architecture map resolves through one architecture_map_record naming the symbol-anchored canvas nodes and their derived-explanation upstream anchors; every command-tip pack resolves through one command_tip_pack_record bundling tip rows that surface from canonical command_ids. The contract mints no new command_id, docs_citation_anchor, symbol_linked_reference, freshness_class, locale, or deployment_profile vocabulary; those re-export verbatim from schemas/commands/command_registry_entry.schema.json, schemas/docs/citation_anchor.schema.json, schemas/docs/symbol_linked_reference.schema.json, schemas/ux/guided_surface_state.schema.json, and artifacts/governance/deployment_profiles.yaml. Adding a new tour_audience_class, indexing_readiness_class, waypoint_anchor_kind, layout_target_class, partial_indexing_disclosure_class, evidence_hook_class, source_language_fallback_class, or denial_reason is additive-minor and bumps guided_tour_schema_version; repurposing an existing value is breaking and requires a new decision row. Raw paths, raw URLs, raw prompt / completion text, raw credential material, raw graph node payloads, and raw provider payloads never cross this boundary.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/guided_tour_record" },
    { "$ref": "#/$defs/tour_waypoint_record" },
    { "$ref": "#/$defs/architecture_map_record" },
    { "$ref": "#/$defs/command_tip_pack_record" }
  ],
  "$defs": {
    "guided_tour_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this guided-tour vocabulary export. Current value is 1. Bumped only on breaking payload changes; additive-optional fields do not bump this version."
    },

    "record_kind": {
      "type": "string",
      "enum": [
        "guided_tour_record",
        "tour_waypoint_record",
        "architecture_map_record",
        "command_tip_pack_record"
      ],
      "description": "Discriminator for the concrete payload shape. Every record carries exactly one kind."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests / portable profile packages / support bundles. Raw URLs, raw absolute paths, raw graph node payloads, and raw credential material never appear here."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Short privacy-safe label text. MUST NOT embed raw paths, raw URLs, raw secret material, or raw AI prompt / completion text."
    },

    "bcp47_locale_tag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": { "type": "object", "additionalProperties": true },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "tour_audience_class": {
      "type": "string",
      "enum": [
        "first_run_no_account",
        "first_run_after_opt_in",
        "learning_mode_individual",
        "learning_mode_classroom_managed",
        "facilitator_led_walkthrough",
        "architecture_map_walkthrough",
        "post_migration_review",
        "policy_disabled"
      ],
      "description": "Closed audience-class vocabulary. first_run_no_account MUST resolve under the no-account local-entry contract without requiring an account opt-in (M00-211)."
    },

    "indexing_readiness_class": {
      "type": "string",
      "enum": [
        "live_authoritative_full_index",
        "partial_index_disclosed",
        "stale_index_disclosed",
        "cached_mirror_only_index",
        "index_unavailable_suppressed"
      ],
      "description": "Closed indexing-readiness vocabulary the tour MUST resolve under so a tour that runs over partial or cached indexing discloses that fact rather than presenting itself as live."
    },

    "waypoint_anchor_kind": {
      "type": "string",
      "enum": [
        "command_id_anchor",
        "docs_citation_anchor",
        "symbol_linked_reference_anchor",
        "graph_node_anchor"
      ],
      "description": "Discriminator naming which typed waypoint anchor is populated. graph_node_anchor MUST resolve to a symbol_linked_reference id rather than a private graph node so an architecture-map waypoint has the same citation chain as the rest of the product."
    },

    "layout_target_class": {
      "type": "string",
      "enum": [
        "start_center",
        "command_palette",
        "workspace_switcher",
        "primary_editor",
        "docs_pane",
        "architecture_map_canvas",
        "review_pane",
        "activity_center",
        "support_center",
        "settings_pane",
        "no_canvas_target_facilitator_only"
      ],
      "description": "Closed layout-target vocabulary the waypoint spotlights. Each value names a canonical workspace surface; presentation-mode layout anchors land on these targets rather than on private surfaces (see learning_and_presentation_contract.md §7)."
    },

    "partial_indexing_disclosure_class": {
      "type": "string",
      "enum": [
        "no_disclosure_required_full_index",
        "partial_index_disclosed_inline",
        "partial_index_disclosed_in_freshness_chip",
        "partial_index_disclosed_in_freshness_chip_and_route",
        "partial_index_suppressed_active_false"
      ],
      "description": "Closed partial-indexing disclosure vocabulary. A waypoint over a partial index MUST disclose at least once before it can render."
    },

    "source_language_fallback_class": {
      "type": "string",
      "enum": [
        "no_fallback_locale_native",
        "fallback_to_source_language_disclosed",
        "fallback_blocked_locale_unavailable",
        "fallback_blocked_pack_missing"
      ],
      "description": "Closed locale source-language fallback vocabulary. fallback_to_source_language_disclosed binds the locale_pack_manifest source-language fallback (M00-251); a waypoint that falls back without disclosure is non-conforming."
    },

    "evidence_hook_class": {
      "type": "string",
      "enum": [
        "tour_citation_audit",
        "cached_pack_continuity",
        "presentation_role_review",
        "layout_restore_proof",
        "privacy_bounded_classroom_artifact"
      ],
      "description": "Reserved evidence-hook vocabulary tour, waypoint, architecture-map, and command-tip records may attach without redefining object shape."
    },

    "freshness_class": {
      "type": "string",
      "enum": [
        "live_authoritative",
        "cached_current",
        "stale_past_ttl",
        "cached_mirror_only",
        "unverified_upstream"
      ],
      "description": "Re-exported from schemas/ux/guided_surface_state.schema.json without modification."
    },

    "version_match_state": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ],
      "description": "Re-exported from schemas/docs/citation_anchor.schema.json."
    },

    "deployment_profile_id": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud",
        "air_gapped_mirror_only"
      ]
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": { "type": "string", "enum": ["trusted", "restricted"] },
        "execution_context_id": { "type": "string", "minLength": 1 }
      }
    },

    "denial_reason": {
      "type": "string",
      "enum": [
        "guided_tour_waypoint_without_canonical_anchor",
        "guided_tour_partial_index_not_disclosed",
        "guided_tour_locale_fallback_not_disclosed",
        "guided_tour_layout_target_not_canonical_surface",
        "guided_tour_audience_envelope_mismatch",
        "guided_tour_action_opens_private_mutation_path",
        "guided_tour_imported_pack_unverified",
        "guided_tour_schema_version_lagging"
      ],
      "description": "Closed denial-reason vocabulary publishers MUST emit when a tour, waypoint, architecture-map, or command-tip pack would otherwise render non-conforming state."
    },

    "tour_waypoint_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anchor_kind"],
      "oneOf": [
        { "required": ["anchor_kind", "command_id_ref"] },
        { "required": ["anchor_kind", "docs_citation_anchor_ref"] },
        { "required": ["anchor_kind", "symbol_linked_reference_ref"] }
      ],
      "properties": {
        "anchor_kind": { "$ref": "#/$defs/waypoint_anchor_kind" },
        "command_id_ref": { "$ref": "#/$defs/opaque_id" },
        "docs_citation_anchor_ref": { "$ref": "#/$defs/opaque_id" },
        "symbol_linked_reference_ref": { "$ref": "#/$defs/opaque_id" }
      },
      "description": "Typed primary anchor for a waypoint. graph_node_anchor MUST populate symbol_linked_reference_ref; private graph payloads are not admissible as a primary anchor."
    },

    "guided_tour_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "guided_tour_schema_version",
        "tour_id",
        "tour_audience_class",
        "indexing_readiness_class",
        "waypoint_refs",
        "default_locale",
        "docs_pack_ref",
        "docs_pack_revision_ref",
        "deployment_profile_refs",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "guided_tour_record" },
        "guided_tour_schema_version": { "$ref": "#/$defs/guided_tour_schema_version" },
        "tour_id": { "$ref": "#/$defs/opaque_id" },
        "tour_audience_class": { "$ref": "#/$defs/tour_audience_class" },
        "indexing_readiness_class": { "$ref": "#/$defs/indexing_readiness_class" },
        "waypoint_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Sequenced opaque ids of tour_waypoint_records. Order in this array is the canonical waypoint order; each waypoint's position_index MUST agree with this order."
        },
        "agenda_label": { "$ref": "#/$defs/short_label_text" },
        "command_tip_pack_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Optional opaque pin to a command_tip_pack_record providing inline tips for waypoints in this tour."
        },
        "default_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "source_language_fallback_class": { "$ref": "#/$defs/source_language_fallback_class" },
        "docs_pack_ref": { "$ref": "#/$defs/opaque_id" },
        "docs_pack_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "deployment_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "evidence_hooks_reserved": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_hook_class" },
          "uniqueItems": true
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "presentation_subtitle": { "$ref": "#/$defs/short_label_text" },
        "denial_reason_on_deny": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/denial_reason" }
          ]
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "first_run_no_account audiences MUST be admissible on individual_local or self_hosted profiles so the no-account first-run path runs without requiring an account opt-in.",
          "if": {
            "properties": { "tour_audience_class": { "const": "first_run_no_account" } },
            "required": ["tour_audience_class"]
          },
          "then": {
            "properties": {
              "deployment_profile_refs": {
                "type": "array",
                "contains": {
                  "enum": ["individual_local", "self_hosted"]
                }
              }
            }
          }
        },
        {
          "description": "policy_disabled audiences MUST resolve under the policy bundle and never carry a portable evidence hook.",
          "if": {
            "properties": { "tour_audience_class": { "const": "policy_disabled" } },
            "required": ["tour_audience_class"]
          },
          "then": {
            "properties": {
              "indexing_readiness_class": { "const": "index_unavailable_suppressed" }
            }
          }
        }
      ],
      "description": "One sequenced multi-step guided-tour definition. See learning_and_presentation_contract.md §3."
    },

    "tour_waypoint_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "guided_tour_schema_version",
        "waypoint_id",
        "tour_ref",
        "position_index",
        "anchor",
        "layout_target_class",
        "partial_indexing_disclosure_class",
        "source_language_fallback_class",
        "freshness_class",
        "version_match_state_at_mint",
        "locale",
        "locale_fallback_disclosed",
        "docs_pack_ref",
        "docs_pack_revision_ref",
        "active",
        "deployment_profile_refs",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "tour_waypoint_record" },
        "guided_tour_schema_version": { "$ref": "#/$defs/guided_tour_schema_version" },
        "waypoint_id": { "$ref": "#/$defs/opaque_id" },
        "tour_ref": { "$ref": "#/$defs/opaque_id" },
        "position_index": { "type": "integer", "minimum": 0 },
        "anchor": { "$ref": "#/$defs/tour_waypoint_anchor" },
        "upstream_citation_anchor_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Required (non-empty) when the waypoint paraphrases or summarizes a docs/source anchor; the citation contract requires upstream anchors on derived explanations."
        },
        "guided_surface_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Optional opaque pin to the guided_surface_state_record this waypoint emits at mint time. Lets a reviewer cross-reference §3 authority class on guided_surface_state.schema.json."
        },
        "layout_target_class": { "$ref": "#/$defs/layout_target_class" },
        "partial_indexing_disclosure_class": { "$ref": "#/$defs/partial_indexing_disclosure_class" },
        "source_language_fallback_class": { "$ref": "#/$defs/source_language_fallback_class" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "version_match_state_at_mint": { "$ref": "#/$defs/version_match_state" },
        "locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "locale_fallback_disclosed": { "type": "boolean" },
        "docs_pack_ref": { "$ref": "#/$defs/opaque_id" },
        "docs_pack_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "active": { "type": "boolean" },
        "deployment_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "evidence_hooks_reserved": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_hook_class" },
          "uniqueItems": true
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "presentation_subtitle": { "$ref": "#/$defs/short_label_text" },
        "denial_reason_on_deny": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/denial_reason" }
          ]
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "graph_node_anchor MUST resolve through a symbol_linked_reference_ref so architecture-map waypoints share the symbol-anchored citation lane.",
          "if": {
            "properties": {
              "anchor": {
                "properties": { "anchor_kind": { "const": "graph_node_anchor" } }
              }
            },
            "required": ["anchor"]
          },
          "then": {
            "properties": {
              "anchor": {
                "required": ["symbol_linked_reference_ref"]
              },
              "layout_target_class": { "const": "architecture_map_canvas" }
            }
          }
        },
        {
          "description": "Locale fallbacks are disclosed.",
          "if": {
            "properties": {
              "source_language_fallback_class": { "const": "fallback_to_source_language_disclosed" }
            },
            "required": ["source_language_fallback_class"]
          },
          "then": {
            "properties": { "locale_fallback_disclosed": { "const": true } }
          }
        },
        {
          "description": "partial_index_suppressed_active_false forces active = false; partial-index disclosure values force active = true.",
          "if": {
            "properties": {
              "partial_indexing_disclosure_class": { "const": "partial_index_suppressed_active_false" }
            },
            "required": ["partial_indexing_disclosure_class"]
          },
          "then": {
            "properties": { "active": { "const": false } }
          }
        }
      ],
      "description": "One waypoint on a guided tour. See learning_and_presentation_contract.md §3."
    },

    "architecture_map_node_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "symbol_linked_reference_ref", "layout_target_class"],
      "properties": {
        "node_id": { "$ref": "#/$defs/opaque_id" },
        "symbol_linked_reference_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque pin to a symbol_linked_reference_record id. Architecture-map nodes ride the symbol-linked-reference lane rather than minting a private graph-node anchor."
        },
        "upstream_citation_anchor_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "layout_target_class": { "$ref": "#/$defs/layout_target_class" },
        "presentation_label": { "$ref": "#/$defs/short_label_text" }
      }
    },

    "architecture_map_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "guided_tour_schema_version",
        "map_id",
        "tour_ref",
        "node_records",
        "default_locale",
        "freshness_class",
        "version_match_state_at_mint",
        "deployment_profile_refs",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "architecture_map_record" },
        "guided_tour_schema_version": { "$ref": "#/$defs/guided_tour_schema_version" },
        "map_id": { "$ref": "#/$defs/opaque_id" },
        "tour_ref": { "$ref": "#/$defs/opaque_id" },
        "node_records": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/architecture_map_node_record" },
          "uniqueItems": true
        },
        "default_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "version_match_state_at_mint": { "$ref": "#/$defs/version_match_state" },
        "deployment_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "evidence_hooks_reserved": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_hook_class" },
          "uniqueItems": true
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "description": "One architecture-map definition. See learning_and_presentation_contract.md §3."
    },

    "command_tip_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tip_id", "command_id_ref", "presentation_label"],
      "properties": {
        "tip_id": { "$ref": "#/$defs/opaque_id" },
        "command_id_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque pin to a canonical command_id on schemas/commands/command_registry_entry.schema.json. Tips that cannot resolve to a canonical command MUST suppress."
        },
        "docs_citation_anchor_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Optional companion docs anchor backing the tip narrative."
        },
        "keymap_bridge_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Optional keymap-bridge resolver this tip composes with so a 'you pressed X' bridge tip stays on the canonical command."
        },
        "layout_target_class": { "$ref": "#/$defs/layout_target_class" },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "presentation_subtitle": { "$ref": "#/$defs/short_label_text" }
      }
    },

    "command_tip_pack_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "guided_tour_schema_version",
        "pack_id",
        "tip_records",
        "default_locale",
        "deployment_profile_refs",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "command_tip_pack_record" },
        "guided_tour_schema_version": { "$ref": "#/$defs/guided_tour_schema_version" },
        "pack_id": { "$ref": "#/$defs/opaque_id" },
        "tour_ref": { "$ref": "#/$defs/opaque_id" },
        "tip_records": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/command_tip_record" },
          "uniqueItems": true
        },
        "default_locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "source_language_fallback_class": { "$ref": "#/$defs/source_language_fallback_class" },
        "deployment_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "evidence_hooks_reserved": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_hook_class" },
          "uniqueItems": true
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "description": "Bundle of command tips referenced by waypoints. See learning_and_presentation_contract.md §3."
    }
  }
}
