{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/ship-sync-device-registry-conflict-review-and-support.schema.json",
  "title": "Aureline sync / device-registry certification record",
  "description": "Boundary schema for sync_device_registry_certification_record, the single governed record the desktop device-and-sync surface, command palette, status bar, support export, Help/About, admin device-registry view, dashboards, and docs all read for one sync posture. It is minted by crates/aureline-settings/src/sync_device_registry_stable as a genuine projection of the live settings runtime (crate::schema::SchemaRegistry, crate::resolver::EffectiveSettingsResolver, and the beta crate::sync conflict path over crate::inspector::conflict) and binds, for one posture: (1) device participation truth — each device exposes a stable identity, participation state, profile durability, last successful sync, selected scope set, conflict class, retained rollback checkpoint, and local-authoritative fallback, inspectable without a mutating action; (2) field-aware conflict review distinguishing exact-match, translated, partial, stale-remote, policy-locked, and local-authoritative outcomes, naming the REL-SYNC-009 merge class, and protecting any overwrite with a change preview and a rollback checkpoint before apply; (3) snapshot-class provenance for the local rollback checkpoint, portable profile export, managed sync snapshot, and support recovery manifest, each with included/excluded state classes, producer version, integrity hash, source provenance, and local-authoritative fallback; (4) a secret boundary excluding dirty-buffer journals and secret material from the sync and export lanes; (5) profile-roaming/offboarding truth keeping local launch/edit authority even when managed sync is unavailable, with temporary profiles excluded by default; (6) cross-surface parity across the desktop UI, CLI inspect, Help/About, support export, and admin device-registry view; (7) a public claim ceiling no posture may exceed; and (8) a derived stable-claim verdict that narrows a posture which cannot prove a pillar, or whose lowest surface marker is below Stable, below Stable with a named reason. Minted refs are opaque aureline://<class>/<id> object refs; upstream projection refs keep their source scheme.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "posture_id",
    "posture_label",
    "title",
    "summary",
    "surface_lifecycle_marker",
    "device_participation",
    "conflict_review",
    "snapshots",
    "secret_boundary",
    "surface_parity",
    "profile_roaming",
    "outcome_coverage",
    "pillars",
    "claim_ceiling",
    "stable_qualification",
    "recovery_routes",
    "routes",
    "accessibility",
    "available_without_account",
    "available_without_managed_services",
    "honesty_marker_present",
    "upstream",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": { "const": "sync_device_registry_certification_record" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "notice": { "type": "string", "minLength": 1 },
    "shared_contract_ref": { "const": "settings:sync_device_registry_stable:v1" },
    "record_id": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "minLength": 1 },
    "posture_id": { "type": "string", "minLength": 1 },
    "posture_label": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "surface_lifecycle_marker": { "$ref": "#/$defs/lifecycleMarker" },
    "device_participation": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/deviceParticipationRow" }
    },
    "conflict_review": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/conflictReviewRow" }
    },
    "snapshots": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/snapshotRow" }
    },
    "secret_boundary": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/secretBoundaryRow" }
    },
    "surface_parity": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/surfaceParityRow" }
    },
    "profile_roaming": { "$ref": "#/$defs/profileRoaming" },
    "outcome_coverage": {
      "type": "array",
      "items": { "$ref": "#/$defs/outcomeClass" }
    },
    "pillars": { "$ref": "#/$defs/pillars" },
    "claim_ceiling": { "$ref": "#/$defs/claimCeiling" },
    "stable_qualification": { "$ref": "#/$defs/stableQualification" },
    "recovery_routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/recoveryRoute" }
    },
    "routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/entryRoute" }
    },
    "accessibility": { "$ref": "#/$defs/accessibility" },
    "available_without_account": { "type": "boolean" },
    "available_without_managed_services": { "type": "boolean" },
    "honesty_marker_present": { "type": "boolean" },
    "upstream": { "$ref": "#/$defs/upstream" },
    "diagnostics_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "support_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } },
    "narrative_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } }
  },
  "$defs": {
    "canonicalRef": {
      "type": "string",
      "pattern": "^aureline://(?!home/|landing/|root/)[^/]+/.+",
      "maxLength": 200
    },
    "presentRef": { "type": "string", "minLength": 1, "maxLength": 200 },
    "token": { "type": "string", "minLength": 1 },
    "lifecycleMarker": { "enum": ["preview", "beta", "stable"] },
    "claimClass": { "enum": ["stable", "beta", "preview", "not_claimed"] },
    "identityMode": { "enum": ["account_free_local", "self_hosted_org", "managed_convenience"] },
    "participationState": { "enum": ["active", "paused", "revoked", "forgotten"] },
    "profileDurability": { "enum": ["durable", "session_only", "promoted", "discarded_on_exit"] },
    "outcomeClass": {
      "enum": [
        "exact_match",
        "translated",
        "partial",
        "stale_remote",
        "policy_locked",
        "local_authoritative"
      ]
    },
    "mergeClass": {
      "enum": [
        "fieldwise_merge",
        "additive_merge",
        "explicit_conflict_review",
        "local_precedence"
      ]
    },
    "settingCategory": { "enum": ["scalar", "additive_asset", "structured_definition"] },
    "snapshotClass": {
      "enum": [
        "local_rollback_checkpoint",
        "portable_profile_export",
        "managed_sync_snapshot",
        "support_recovery_manifest"
      ]
    },
    "stateClass": {
      "enum": [
        "scalar_settings",
        "keybindings",
        "tasks",
        "launch_configs",
        "workset_definitions",
        "extension_inventory_refs",
        "machine_local_topology",
        "dirty_buffer_journals",
        "secret_material",
        "reference_only_metadata"
      ]
    },
    "surfaceClass": {
      "enum": [
        "desktop_ui",
        "cli_inspect",
        "help_about",
        "support_export",
        "admin_device_registry"
      ]
    },
    "routeSurface": {
      "enum": ["device_registry", "command_palette", "status_bar", "menu_command"]
    },
    "recoveryRole": { "enum": ["primary", "recovery", "secondary"] },
    "layoutMode": { "enum": ["normal", "high_contrast", "zoomed"] },
    "narrowingReason": {
      "enum": [
        "device_participation_incomplete",
        "conflict_review_not_field_aware",
        "snapshot_provenance_missing",
        "local_fallback_unproven",
        "secret_boundary_unproven",
        "merge_rule_unenforced",
        "profile_roaming_incomplete",
        "surface_clones_prose",
        "surface_not_yet_stable"
      ]
    },
    "deviceParticipationRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "device_id",
        "device_class",
        "os_family_class",
        "identity_mode",
        "participation_state",
        "is_local_device",
        "profile_durability",
        "sync_freshness",
        "selected_scope_set",
        "conflict_class",
        "local_authoritative_fallback",
        "inspectable_without_mutation",
        "conforms"
      ],
      "properties": {
        "device_id": { "type": "string", "minLength": 1 },
        "device_label": { "type": "string", "minLength": 1 },
        "device_class": { "$ref": "#/$defs/token" },
        "os_family_class": { "$ref": "#/$defs/token" },
        "identity_mode": { "$ref": "#/$defs/identityMode" },
        "participation_state": { "$ref": "#/$defs/participationState" },
        "is_local_device": { "type": "boolean" },
        "profile_durability": { "$ref": "#/$defs/profileDurability" },
        "last_successful_sync": { "type": "string", "minLength": 1 },
        "sync_freshness": { "$ref": "#/$defs/token" },
        "selected_scope_set": { "type": "array", "items": { "$ref": "#/$defs/token" } },
        "conflict_class": { "$ref": "#/$defs/token" },
        "rollback_checkpoint_ref": { "$ref": "#/$defs/canonicalRef" },
        "local_authoritative_fallback": { "type": "boolean" },
        "inspectable_without_mutation": { "type": "boolean" },
        "revocation_reason": { "type": "string", "minLength": 1 },
        "waiver_ref": { "$ref": "#/$defs/presentRef" },
        "conforms": { "type": "boolean" }
      }
    },
    "conflictReviewRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "setting_id",
        "conflicting_scope",
        "setting_category",
        "outcome_class",
        "merge_class",
        "remote_device_id",
        "remote_participation_state",
        "recommended_path",
        "overwrites_local",
        "local_authoritative",
        "inspectable_before_apply",
        "widens_authority",
        "redaction_class",
        "lock_state",
        "diagnostics_entry_ref",
        "merge_rule_satisfied",
        "protected_before_overwrite",
        "conforms"
      ],
      "properties": {
        "setting_id": { "type": "string", "minLength": 1 },
        "conflicting_scope": { "$ref": "#/$defs/token" },
        "setting_category": { "$ref": "#/$defs/settingCategory" },
        "outcome_class": { "$ref": "#/$defs/outcomeClass" },
        "merge_class": { "$ref": "#/$defs/mergeClass" },
        "remote_device_id": { "type": "string", "minLength": 1 },
        "remote_participation_state": { "$ref": "#/$defs/participationState" },
        "recommended_path": { "$ref": "#/$defs/token" },
        "overwrites_local": { "type": "boolean" },
        "local_authoritative": { "type": "boolean" },
        "change_preview_ref": { "$ref": "#/$defs/canonicalRef" },
        "rollback_checkpoint_ref": { "$ref": "#/$defs/canonicalRef" },
        "inspectable_before_apply": { "type": "boolean" },
        "widens_authority": { "type": "boolean" },
        "redaction_class": { "$ref": "#/$defs/token" },
        "lock_state": { "$ref": "#/$defs/token" },
        "source_packet_ref": { "type": "string", "minLength": 1 },
        "diagnostics_entry_ref": { "$ref": "#/$defs/canonicalRef" },
        "merge_rule_satisfied": { "type": "boolean" },
        "protected_before_overwrite": { "type": "boolean" },
        "waiver_ref": { "$ref": "#/$defs/presentRef" },
        "conforms": { "type": "boolean" }
      }
    },
    "snapshotRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_class",
        "snapshot_ref",
        "producer_aureline_version",
        "producer_schema_version",
        "integrity_hash",
        "source_provenance",
        "included_state_classes",
        "excluded_state_classes",
        "local_authoritative_fallback",
        "carries_forbidden_state_class",
        "conforms"
      ],
      "properties": {
        "snapshot_class": { "$ref": "#/$defs/snapshotClass" },
        "snapshot_ref": { "$ref": "#/$defs/canonicalRef" },
        "producer_aureline_version": { "type": "string", "minLength": 1 },
        "producer_schema_version": { "type": "string", "minLength": 1 },
        "integrity_hash": { "type": "string", "minLength": 1 },
        "source_provenance": { "type": "string", "minLength": 1 },
        "included_state_classes": { "type": "array", "items": { "$ref": "#/$defs/stateClass" } },
        "excluded_state_classes": { "type": "array", "items": { "$ref": "#/$defs/stateClass" } },
        "local_authoritative_fallback": { "type": "boolean" },
        "carries_forbidden_state_class": { "type": "boolean" },
        "waiver_ref": { "$ref": "#/$defs/presentRef" },
        "conforms": { "type": "boolean" }
      }
    },
    "secretBoundaryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state_class", "lane", "excluded", "reference_only_allowed", "reason", "conforms"],
      "properties": {
        "state_class": { "$ref": "#/$defs/stateClass" },
        "lane": { "$ref": "#/$defs/token" },
        "excluded": { "type": "boolean" },
        "reference_only_allowed": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1 },
        "conforms": { "type": "boolean" }
      }
    },
    "surfaceParityRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "consumes_shared_record",
        "clones_prose",
        "surface_marker",
        "shared_contract_ref",
        "record_ref",
        "conforms"
      ],
      "properties": {
        "surface_class": { "$ref": "#/$defs/surfaceClass" },
        "consumes_shared_record": { "type": "boolean" },
        "clones_prose": { "type": "boolean" },
        "surface_marker": { "$ref": "#/$defs/lifecycleMarker" },
        "shared_contract_ref": { "$ref": "#/$defs/token" },
        "record_ref": { "$ref": "#/$defs/canonicalRef" },
        "waiver_ref": { "$ref": "#/$defs/presentRef" },
        "conforms": { "type": "boolean" }
      }
    },
    "profileRoaming": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "managed_sync_available",
        "local_launch_edit_authority_retained",
        "temporary_profiles_excluded",
        "active_profile_durability",
        "originating_profile_revision",
        "summary",
        "conforms"
      ],
      "properties": {
        "latest_successful_sync_ref": { "$ref": "#/$defs/canonicalRef" },
        "extension_inventory_ref": { "$ref": "#/$defs/canonicalRef" },
        "remaining_retention_days": { "type": "integer", "minimum": 0 },
        "managed_sync_available": { "type": "boolean" },
        "local_launch_edit_authority_retained": { "type": "boolean" },
        "temporary_profiles_excluded": { "type": "boolean" },
        "active_profile_durability": { "$ref": "#/$defs/profileDurability" },
        "originating_profile_revision": { "$ref": "#/$defs/presentRef" },
        "summary": { "type": "string", "minLength": 1 },
        "conforms": { "type": "boolean" }
      }
    },
    "pillars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "device_participation_truth",
        "conflict_review_field_aware",
        "snapshot_provenance_complete",
        "local_fallback_proven",
        "secret_boundary_held",
        "merge_rules_enforced",
        "profile_roaming_truth",
        "surfaces_share_one_truth"
      ],
      "properties": {
        "device_participation_truth": { "type": "boolean" },
        "conflict_review_field_aware": { "type": "boolean" },
        "snapshot_provenance_complete": { "type": "boolean" },
        "local_fallback_proven": { "type": "boolean" },
        "secret_boundary_held": { "type": "boolean" },
        "merge_rules_enforced": { "type": "boolean" },
        "profile_roaming_truth": { "type": "boolean" },
        "surfaces_share_one_truth": { "type": "boolean" }
      }
    },
    "claimCeiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asserts_device_participation_truth",
        "asserts_conflict_review_field_aware",
        "asserts_snapshot_provenance_complete",
        "asserts_local_fallback_proven",
        "asserts_secret_boundary_held",
        "asserts_merge_rules_enforced",
        "asserts_profile_roaming_truth",
        "asserts_surfaces_share_one_truth"
      ],
      "properties": {
        "asserts_device_participation_truth": { "type": "boolean" },
        "asserts_conflict_review_field_aware": { "type": "boolean" },
        "asserts_snapshot_provenance_complete": { "type": "boolean" },
        "asserts_local_fallback_proven": { "type": "boolean" },
        "asserts_secret_boundary_held": { "type": "boolean" },
        "asserts_merge_rules_enforced": { "type": "boolean" },
        "asserts_profile_roaming_truth": { "type": "boolean" },
        "asserts_surfaces_share_one_truth": { "type": "boolean" }
      }
    },
    "stableQualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_class", "qualifies_stable", "narrowing_reasons"],
      "properties": {
        "claim_class": { "$ref": "#/$defs/claimClass" },
        "qualifies_stable": { "type": "boolean" },
        "narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowingReason" }
        }
      }
    },
    "recoveryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_label", "action_role", "keyboard_reachable"],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_label": { "type": "string", "minLength": 1 },
        "action_role": { "$ref": "#/$defs/recoveryRole" },
        "keyboard_reachable": { "const": true }
      }
    },
    "entryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "route_ref", "keyboard_reachable", "activates_same_record"],
      "properties": {
        "surface": { "$ref": "#/$defs/routeSurface" },
        "route_ref": { "$ref": "#/$defs/canonicalRef" },
        "keyboard_reachable": { "const": true },
        "activates_same_record": { "const": true }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_order_index",
        "tab_stop_count",
        "row_narration",
        "action_labels",
        "layout_modes"
      ],
      "properties": {
        "focus_order_index": { "type": "integer", "minimum": 0 },
        "tab_stop_count": { "type": "integer", "minimum": 0 },
        "row_narration": { "type": "string", "minLength": 1 },
        "action_labels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "layout_modes": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["mode", "row_narration_available", "recovery_affordances_reachable"],
            "properties": {
              "mode": { "$ref": "#/$defs/layoutMode" },
              "row_narration_available": { "const": true },
              "recovery_affordances_reachable": { "const": true }
            }
          }
        }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_ref",
        "resolver_state_ref",
        "sync_contract_ref",
        "participating_device_ids",
        "reviewed_setting_ids"
      ],
      "properties": {
        "registry_ref": { "$ref": "#/$defs/presentRef" },
        "resolver_state_ref": { "$ref": "#/$defs/presentRef" },
        "sync_contract_ref": { "$ref": "#/$defs/presentRef" },
        "participating_device_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "reviewed_setting_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
