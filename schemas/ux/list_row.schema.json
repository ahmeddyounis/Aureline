{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/list_row.schema.json",
  "title": "Aureline list-row, result-row, and card-row identity and quick-action contract",
  "description": "Boundary schema for shared row anatomy frozen in docs/ux/list_and_card_row_contract.md. List-backed support, review, provider, run, incident, search, activity, sidebar, start-surface, dense-table, and companion surfaces use this schema to keep canonical object identity, display title, source/provider, freshness, owner/actor, state, quick actions, open-details behavior, duplicate merge, density, peek metadata, and card-promotion rules consistent. Raw provider payloads, raw URLs, raw absolute paths, raw log bodies, raw comments, raw prompts, raw credentials, and secret material never cross this boundary; rows carry opaque refs, controlled vocabulary, bounded reviewable labels, and explicit disclosure booleans. Adding enum values or optional fields is additive-minor and bumps list_row_schema_version; repurposing an existing value is breaking.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/list_row_record" },
    { "$ref": "#/$defs/result_row_record" },
    { "$ref": "#/$defs/card_row_record" }
  ],
  "$defs": {
    "list_row_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this shared row contract."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "list_row_record",
        "result_row_record",
        "card_row_record"
      ]
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable identifier safe for manifests, RPC, logs, support export, and fixtures."
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Bounded, redaction-aware display label. It may contain user-facing names but not raw credentials, raw provider payloads, raw absolute paths, or secret material."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "support_triage",
        "review_queue",
        "provider_inventory",
        "run_history",
        "incident_queue",
        "search_results",
        "activity_feed",
        "start_surface",
        "sidebar",
        "dense_table",
        "companion_summary",
        "admin_queue",
        "work_item_queue"
      ]
    },
    "row_presentation_class": {
      "type": "string",
      "enum": [
        "list_row",
        "result_row",
        "card_row",
        "tile_row"
      ]
    },
    "layout_density_class": {
      "type": "string",
      "enum": [
        "compact",
        "standard",
        "expanded",
        "mobile_summary",
        "companion_summary"
      ]
    },
    "surface_slot": {
      "type": "string",
      "enum": [
        "dense_table",
        "standard_list",
        "expanded_queue",
        "sidebar",
        "start_surface",
        "mobile_summary",
        "companion_summary"
      ]
    },
    "canonical_object_kind": {
      "type": "string",
      "enum": [
        "support_case",
        "review_thread",
        "review_workspace",
        "provider_resource",
        "provider_grant",
        "run",
        "job",
        "incident",
        "work_item",
        "search_result",
        "activity_event",
        "workspace_resource",
        "local_artifact",
        "draft",
        "policy_decision",
        "restore_entry"
      ]
    },
    "source_kind": {
      "type": "string",
      "enum": [
        "local",
        "provider",
        "remote_runtime",
        "generated",
        "imported",
        "mirrored",
        "mixed_merged"
      ]
    },
    "authority_class": {
      "type": "string",
      "enum": [
        "local_authoritative",
        "provider_authoritative",
        "local_draft",
        "remote_runtime_authoritative",
        "policy_authoritative",
        "imported_snapshot",
        "mixed_authority",
        "unknown_authority"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "live",
        "fresh",
        "recently_stale",
        "materially_stale",
        "cached_snapshot",
        "imported_snapshot",
        "local_only_unsynced",
        "unknown"
      ]
    },
    "state_class": {
      "type": "string",
      "enum": [
        "healthy",
        "unread",
        "draft",
        "blocked",
        "stale",
        "failed"
      ],
      "description": "Frozen row-state vocabulary. These values are not synonyms and must not collapse into one highlight treatment."
    },
    "status_intent": {
      "type": "string",
      "enum": [
        "neutral",
        "info",
        "warning",
        "danger",
        "blocked",
        "success"
      ]
    },
    "reason_chip_class": {
      "type": "string",
      "enum": [
        "unread",
        "draft",
        "blocked",
        "stale",
        "failed",
        "healthy",
        "partial",
        "provider_backed",
        "local_only",
        "merged_duplicate",
        "authority_required",
        "approval_required",
        "read_only",
        "queued",
        "policy_limited",
        "freshness_required",
        "peek_available"
      ]
    },
    "reason_chip_placement": {
      "type": "string",
      "enum": [
        "after_primary_label",
        "secondary_metadata_line",
        "before_quick_actions",
        "right_status_area",
        "peek_only"
      ]
    },
    "action_kind": {
      "type": "string",
      "enum": [
        "open_details",
        "open",
        "peek",
        "copy",
        "acknowledge",
        "mark_read",
        "retry",
        "resume",
        "publish",
        "blocker_details",
        "external_handoff",
        "remove",
        "rerun",
        "export",
        "assign",
        "approve",
        "dismiss",
        "overflow_menu"
      ]
    },
    "effect_class": {
      "type": "string",
      "enum": [
        "read_only",
        "local_state_change",
        "provider_mutation",
        "remote_execution",
        "destructive_metadata",
        "export_or_share"
      ]
    },
    "scope_class": {
      "type": "string",
      "enum": [
        "this_row",
        "selected_rows",
        "visible_rows",
        "loaded_rows",
        "all_matching",
        "canonical_object",
        "provider_object",
        "workspace_scope",
        "incident_scope",
        "run_scope"
      ]
    },
    "stale_action_policy": {
      "type": "string",
      "enum": [
        "allowed_read_only",
        "requires_refresh_before_mutation",
        "requires_review_before_mutation",
        "blocked_until_fresh",
        "not_applicable"
      ]
    },
    "activation_model": {
      "type": "string",
      "enum": [
        "enter_or_click_opens_details",
        "enter_opens_peek_click_opens_details",
        "enter_opens_review_sheet",
        "enter_requires_repair_or_reauth"
      ]
    },
    "missing_target_fallback": {
      "type": "string",
      "enum": [
        "open_cached_detail",
        "open_repair_sheet",
        "open_read_only_evidence",
        "show_vanished_target",
        "deny_with_reason"
      ]
    },
    "card_promotion_class": {
      "type": "string",
      "enum": [
        "stays_row",
        "promotes_to_expanded_row",
        "promotes_to_card",
        "promotes_to_tile",
        "card_only"
      ]
    },
    "card_promotion_reason": {
      "type": "string",
      "enum": [
        "none",
        "needs_multi_line_evidence",
        "has_preview_media",
        "contains_multiple_targets",
        "requires_step_review",
        "has_partial_or_blocked_detail",
        "needs_comparison_layout",
        "mobile_summary_expansion"
      ]
    },
    "metadata_slot": {
      "type": "string",
      "enum": [
        "canonical_identity",
        "title",
        "secondary_label",
        "source_provider",
        "freshness_state",
        "owner_actor",
        "row_state",
        "reason_chips",
        "quick_actions",
        "duplicate_members",
        "rank_reason",
        "preview_snippet",
        "audit_refs",
        "history_refs",
        "authority_state",
        "counts"
      ]
    },
    "merge_state": {
      "type": "string",
      "enum": [
        "not_applicable",
        "single_source",
        "merged_duplicate",
        "merge_disclosure",
        "not_mergeable"
      ]
    },
    "merge_role": {
      "type": "string",
      "enum": [
        "primary",
        "supporting",
        "conflicting",
        "hidden_disclosure"
      ]
    },
    "left_edge_anchor_class": {
      "type": "string",
      "enum": [
        "object_kind_icon",
        "state_marker",
        "selection_control",
        "avatar_or_actor",
        "provider_logo",
        "severity_marker",
        "card_thumbnail"
      ]
    },
    "visible_slot": {
      "type": "string",
      "enum": [
        "left_edge_anchor",
        "title",
        "secondary_label",
        "source_provider",
        "freshness_age",
        "owner_actor",
        "row_state",
        "reason_chips",
        "primary_action",
        "overflow_action",
        "selection_control",
        "counts",
        "preview_summary"
      ]
    },
    "canonical_object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_kind",
        "canonical_object_id",
        "object_revision_ref"
      ],
      "properties": {
        "object_kind": { "$ref": "#/$defs/canonical_object_kind" },
        "canonical_object_id": { "$ref": "#/$defs/opaque_id" },
        "object_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "route_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "display_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "primary_label",
        "left_edge_anchor"
      ],
      "properties": {
        "title": { "$ref": "#/$defs/reviewable_label" },
        "primary_label": { "$ref": "#/$defs/reviewable_label" },
        "secondary_label": { "$ref": "#/$defs/reviewable_label" },
        "canonical_id_display": { "$ref": "#/$defs/reviewable_label" },
        "left_edge_anchor": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "anchor_class",
            "label",
            "stable_left_edge"
          ],
          "properties": {
            "anchor_class": { "$ref": "#/$defs/left_edge_anchor_class" },
            "label": { "$ref": "#/$defs/reviewable_label" },
            "stable_left_edge": { "type": "boolean", "const": true }
          }
        }
      }
    },
    "source_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_kind",
        "source_label",
        "source_ref",
        "authority_class"
      ],
      "properties": {
        "source_kind": { "$ref": "#/$defs/source_kind" },
        "source_label": { "$ref": "#/$defs/reviewable_label" },
        "source_ref": { "$ref": "#/$defs/opaque_id" },
        "authority_class": { "$ref": "#/$defs/authority_class" },
        "provider_account_label": { "$ref": "#/$defs/reviewable_label" },
        "provider_host_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "freshness_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness_class",
        "observed_at",
        "age_label"
      ],
      "properties": {
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "observed_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "age_label": { "$ref": "#/$defs/reviewable_label" },
        "stale_reason": { "$ref": "#/$defs/reviewable_label" },
        "freshness_source_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "actor_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_kind",
        "label",
        "actor_ref"
      ],
      "properties": {
        "actor_kind": {
          "type": "string",
          "enum": [
            "user",
            "team",
            "system",
            "provider",
            "remote_service",
            "ai_agent",
            "unknown"
          ]
        },
        "label": { "$ref": "#/$defs/reviewable_label" },
        "actor_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "reason_chip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chip_class",
        "label",
        "placement"
      ],
      "properties": {
        "chip_class": { "$ref": "#/$defs/reason_chip_class" },
        "label": { "$ref": "#/$defs/reviewable_label" },
        "placement": { "$ref": "#/$defs/reason_chip_placement" },
        "detail_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "row_state_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_class",
        "status_intent",
        "user_label",
        "reason_chips"
      ],
      "properties": {
        "state_class": { "$ref": "#/$defs/state_class" },
        "status_intent": { "$ref": "#/$defs/status_intent" },
        "user_label": { "$ref": "#/$defs/reviewable_label" },
        "reason_chips": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reason_chip" }
        },
        "status_detail_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "quick_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "label",
        "action_kind",
        "enabled",
        "target_identity",
        "scope",
        "authority",
        "freshness_gate",
        "effect_class",
        "disclosure"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "label": { "$ref": "#/$defs/reviewable_label" },
        "action_kind": { "$ref": "#/$defs/action_kind" },
        "enabled": { "type": "boolean" },
        "disabled_reason": { "$ref": "#/$defs/reviewable_label" },
        "target_identity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "target_object_id",
            "target_label",
            "target_kind"
          ],
          "properties": {
            "target_object_id": { "$ref": "#/$defs/opaque_id" },
            "target_label": { "$ref": "#/$defs/reviewable_label" },
            "target_kind": { "$ref": "#/$defs/canonical_object_kind" }
          }
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scope_class",
            "scope_label",
            "object_count"
          ],
          "properties": {
            "scope_class": { "$ref": "#/$defs/scope_class" },
            "scope_label": { "$ref": "#/$defs/reviewable_label" },
            "object_count": { "type": "integer", "minimum": 1 }
          }
        },
        "authority": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "authority_class",
            "authority_label",
            "approval_required",
            "revalidates_on_invoke"
          ],
          "properties": {
            "authority_class": { "$ref": "#/$defs/authority_class" },
            "authority_label": { "$ref": "#/$defs/reviewable_label" },
            "approval_required": { "type": "boolean" },
            "revalidates_on_invoke": { "type": "boolean" },
            "acting_identity_ref": { "$ref": "#/$defs/opaque_id" },
            "policy_context_ref": { "$ref": "#/$defs/opaque_id" }
          }
        },
        "freshness_gate": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "freshness_class",
            "freshness_required_before_invoke",
            "stale_action_policy"
          ],
          "properties": {
            "freshness_class": { "$ref": "#/$defs/freshness_class" },
            "freshness_required_before_invoke": { "type": "boolean" },
            "stale_action_policy": { "$ref": "#/$defs/stale_action_policy" }
          }
        },
        "effect_class": { "$ref": "#/$defs/effect_class" },
        "disclosure": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "target_identity_visible",
            "authority_visible",
            "freshness_visible",
            "scope_visible"
          ],
          "properties": {
            "target_identity_visible": { "type": "boolean", "const": true },
            "authority_visible": { "type": "boolean", "const": true },
            "freshness_visible": { "type": "boolean", "const": true },
            "scope_visible": { "type": "boolean", "const": true }
          }
        },
        "review_surface_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "open_details_behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_action_id",
        "detail_route_ref",
        "activation_model",
        "preserves_list_context",
        "revalidates_freshness_on_open",
        "missing_target_fallback"
      ],
      "properties": {
        "default_action_id": { "$ref": "#/$defs/opaque_id" },
        "detail_route_ref": { "$ref": "#/$defs/opaque_id" },
        "activation_model": { "$ref": "#/$defs/activation_model" },
        "preserves_list_context": { "type": "boolean", "const": true },
        "revalidates_freshness_on_open": { "type": "boolean" },
        "missing_target_fallback": { "$ref": "#/$defs/missing_target_fallback" }
      }
    },
    "card_promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_class",
        "trigger_reasons",
        "metadata_policy"
      ],
      "properties": {
        "promotion_class": { "$ref": "#/$defs/card_promotion_class" },
        "trigger_reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/card_promotion_reason" },
          "uniqueItems": true
        },
        "metadata_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "hover_may_hide",
            "peek_required_for",
            "never_hide"
          ],
          "properties": {
            "hover_may_hide": {
              "type": "array",
              "items": { "$ref": "#/$defs/metadata_slot" },
              "uniqueItems": true
            },
            "peek_required_for": {
              "type": "array",
              "items": { "$ref": "#/$defs/metadata_slot" },
              "uniqueItems": true
            },
            "never_hide": {
              "type": "array",
              "minItems": 3,
              "items": { "$ref": "#/$defs/metadata_slot" },
              "uniqueItems": true,
              "allOf": [
                { "contains": { "const": "canonical_identity" } },
                { "contains": { "const": "freshness_state" } },
                { "contains": { "const": "authority_state" } }
              ]
            }
          }
        }
      }
    },
    "right_utility_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_visible_quick_actions",
        "max_visible_status_chips",
        "overflow_required_when_exceeded"
      ],
      "properties": {
        "max_visible_quick_actions": { "type": "integer", "minimum": 1, "maximum": 3 },
        "max_visible_status_chips": { "type": "integer", "minimum": 1, "maximum": 3 },
        "overflow_required_when_exceeded": { "type": "boolean", "const": true }
      }
    },
    "density_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "density_class",
        "surface_slot",
        "visible_slots",
        "hidden_until_peek_slots",
        "right_utility_budget"
      ],
      "properties": {
        "density_class": { "$ref": "#/$defs/layout_density_class" },
        "surface_slot": { "$ref": "#/$defs/surface_slot" },
        "visible_slots": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/visible_slot" },
          "uniqueItems": true
        },
        "hidden_until_peek_slots": {
          "type": "array",
          "items": { "$ref": "#/$defs/metadata_slot" },
          "uniqueItems": true
        },
        "right_utility_budget": { "$ref": "#/$defs/right_utility_budget" }
      }
    },
    "scan_layout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_left_scan_edge",
        "reason_chip_placement",
        "right_utility_budget"
      ],
      "properties": {
        "stable_left_scan_edge": { "type": "boolean", "const": true },
        "reason_chip_placement": { "$ref": "#/$defs/reason_chip_placement" },
        "right_utility_budget": { "$ref": "#/$defs/right_utility_budget" }
      }
    },
    "duplicate_merge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "merge_state",
        "canonical_merge_key",
        "member_count",
        "provenance_visible",
        "members"
      ],
      "properties": {
        "merge_state": { "$ref": "#/$defs/merge_state" },
        "canonical_merge_key": { "$ref": "#/$defs/opaque_id" },
        "member_count": { "type": "integer", "minimum": 1 },
        "provenance_visible": { "type": "boolean", "const": true },
        "conflict_summary": { "$ref": "#/$defs/reviewable_label" },
        "members": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "member_ref",
              "source_label",
              "freshness_class",
              "merge_role"
            ],
            "properties": {
              "member_ref": { "$ref": "#/$defs/opaque_id" },
              "source_label": { "$ref": "#/$defs/reviewable_label" },
              "freshness_class": { "$ref": "#/$defs/freshness_class" },
              "merge_role": { "$ref": "#/$defs/merge_role" }
            }
          }
        }
      }
    },
    "peek_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tooltip_fields",
        "hovercard_fields",
        "peek_fields",
        "hover_must_not_hide_identity",
        "hover_must_not_hide_freshness",
        "hover_must_not_hide_authority"
      ],
      "properties": {
        "tooltip_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/metadata_slot" },
          "uniqueItems": true
        },
        "hovercard_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/metadata_slot" },
          "uniqueItems": true
        },
        "peek_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/metadata_slot" },
          "uniqueItems": true
        },
        "hover_must_not_hide_identity": { "type": "boolean", "const": true },
        "hover_must_not_hide_freshness": { "type": "boolean", "const": true },
        "hover_must_not_hide_authority": { "type": "boolean", "const": true }
      }
    },
    "accessibility_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_model",
        "keyboard_default_action",
        "selection_role",
        "announcement_fields"
      ],
      "properties": {
        "focus_model": {
          "type": "string",
          "enum": [
            "row_focus_separate_from_selection",
            "cell_focus_inside_row",
            "card_focus_with_inner_actions"
          ]
        },
        "keyboard_default_action": { "$ref": "#/$defs/action_kind" },
        "selection_role": {
          "type": "string",
          "enum": [
            "not_selectable",
            "single_select",
            "multi_select",
            "current_item_only"
          ]
        },
        "announcement_fields": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/metadata_slot" },
          "uniqueItems": true
        }
      }
    },
    "result_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_set_ref",
        "rank_reason_label",
        "rank_reason_visible"
      ],
      "properties": {
        "result_set_ref": { "$ref": "#/$defs/opaque_id" },
        "rank_reason_label": { "$ref": "#/$defs/reviewable_label" },
        "rank_reason_visible": { "type": "boolean" },
        "snippet_basis_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "card_layout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_layout_class",
        "required_card_slots",
        "summary_count_separation_preserved"
      ],
      "properties": {
        "card_layout_class": {
          "type": "string",
          "enum": [
            "summary_card",
            "evidence_card",
            "incident_card",
            "run_card",
            "provider_card",
            "tile"
          ]
        },
        "required_card_slots": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/metadata_slot" },
          "uniqueItems": true
        },
        "summary_count_separation_preserved": { "type": "boolean", "const": true }
      }
    },
    "row_record_common": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "list_row_schema_version",
        "row_id",
        "surface_family",
        "row_presentation_class",
        "minted_at",
        "canonical_object",
        "display_identity",
        "source",
        "freshness",
        "owner_or_actor",
        "row_state",
        "quick_actions",
        "open_details_behavior",
        "card_promotion",
        "density_rules",
        "scan_layout",
        "duplicate_merge",
        "peek_policy",
        "accessibility"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "list_row_schema_version": { "$ref": "#/$defs/list_row_schema_version" },
        "row_id": { "$ref": "#/$defs/opaque_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "row_presentation_class": { "$ref": "#/$defs/row_presentation_class" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "canonical_object": { "$ref": "#/$defs/canonical_object" },
        "display_identity": { "$ref": "#/$defs/display_identity" },
        "source": { "$ref": "#/$defs/source_summary" },
        "freshness": { "$ref": "#/$defs/freshness_summary" },
        "owner_or_actor": { "$ref": "#/$defs/actor_summary" },
        "row_state": { "$ref": "#/$defs/row_state_summary" },
        "quick_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/quick_action" }
        },
        "open_details_behavior": { "$ref": "#/$defs/open_details_behavior" },
        "card_promotion": { "$ref": "#/$defs/card_promotion" },
        "density_rules": { "$ref": "#/$defs/density_rules" },
        "scan_layout": { "$ref": "#/$defs/scan_layout" },
        "duplicate_merge": { "$ref": "#/$defs/duplicate_merge" },
        "peek_policy": { "$ref": "#/$defs/peek_policy" },
        "accessibility": { "$ref": "#/$defs/accessibility_summary" },
        "result_context": { "$ref": "#/$defs/result_context" },
        "card_layout": { "$ref": "#/$defs/card_layout" }
      }
    },
    "list_row_record": {
      "allOf": [
        { "$ref": "#/$defs/row_record_common" },
        {
          "type": "object",
          "properties": {
            "record_kind": { "const": "list_row_record" },
            "row_presentation_class": { "const": "list_row" }
          },
          "not": {
            "anyOf": [
              { "required": ["result_context"] },
              { "required": ["card_layout"] }
            ]
          }
        }
      ]
    },
    "result_row_record": {
      "allOf": [
        { "$ref": "#/$defs/row_record_common" },
        {
          "type": "object",
          "required": ["result_context"],
          "properties": {
            "record_kind": { "const": "result_row_record" },
            "row_presentation_class": { "const": "result_row" }
          },
          "not": {
            "required": ["card_layout"]
          }
        }
      ]
    },
    "card_row_record": {
      "allOf": [
        { "$ref": "#/$defs/row_record_common" },
        {
          "type": "object",
          "required": ["card_layout"],
          "properties": {
            "record_kind": { "const": "card_row_record" },
            "row_presentation_class": {
              "enum": ["card_row", "tile_row"]
            },
            "card_promotion": {
              "type": "object",
              "properties": {
                "promotion_class": {
                  "enum": [
                    "promotes_to_card",
                    "promotes_to_tile",
                    "card_only"
                  ]
                }
              }
            }
          }
        }
      ]
    }
  }
}
