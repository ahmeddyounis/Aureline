{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/embedded_boundary_audit_beta.schema.json",
  "title": "Aureline embedded-surface boundary audit (beta) schema",
  "description": "Boundary schema for the beta embedded-surface boundary audit projection produced by aureline-shell. Each record carries the shared contract ref `shell:embedded_boundary_audit_beta:v1`. Adding a value to any closed vocabulary (surface_family_token, boundary_state_token, permission_class_token, browser_fallback_posture_token, fallback_target_class_token, audit axis, defect kind) is additive-minor; repurposing or weakening any host-owned chrome rule is breaking.",
  "type": "object",
  "$ref": "#/$defs/page",
  "$defs": {
    "iso_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp."
    },
    "stable_id": {
      "type": "string",
      "minLength": 1
    },
    "shared_contract_ref": {
      "type": "string",
      "const": "shell:embedded_boundary_audit_beta:v1"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "embedded_docs_help",
        "embedded_marketplace_or_account",
        "embedded_service_dashboard",
        "embedded_auth_confirmation",
        "extension_hosted_surface"
      ]
    },
    "owner_class_token": {
      "type": "string",
      "enum": [
        "host_product",
        "first_party_project",
        "extension_bundle",
        "connected_provider",
        "enterprise_admin",
        "customer_service_owner",
        "unknown_owner"
      ]
    },
    "publisher_or_service_class_token": {
      "type": "string",
      "enum": [
        "first_party_project",
        "marketplace_service",
        "connected_provider_service",
        "customer_service",
        "extension_publisher",
        "identity_provider",
        "unknown_publisher_or_service"
      ]
    },
    "origin_class_token": {
      "type": "string",
      "enum": [
        "local_pack_or_artifact",
        "first_party_hosted_web",
        "connected_provider_hosted_web",
        "customer_or_enterprise_hosted_web",
        "extension_publisher_hosted_web",
        "cross_origin_subframe",
        "system_browser_return",
        "unknown_origin_class"
      ]
    },
    "origin_verification_token": {
      "type": "string",
      "enum": [
        "verified",
        "unverified",
        "certificate_failed",
        "policy_blocked",
        "cross_origin_limited",
        "offline_cached"
      ]
    },
    "data_boundary_class_token": {
      "type": "string",
      "enum": [
        "local_product_boundary",
        "first_party_hosted_service_boundary",
        "connected_provider_boundary",
        "customer_control_plane_boundary",
        "extension_publisher_boundary",
        "cross_origin_limited_boundary"
      ]
    },
    "boundary_state_token": {
      "type": "string",
      "enum": [
        "live_verified",
        "stale_snapshot",
        "policy_blocked",
        "certificate_failed",
        "cross_origin_limited",
        "offline_snapshot",
        "external_open_only"
      ]
    },
    "permission_class_token": {
      "type": "string",
      "enum": [
        "host_owned_full_authority",
        "host_owned_inspect_only",
        "host_owned_browser_only",
        "host_owned_copy_export_only",
        "host_owned_with_native_step_up_required",
        "embedded_lower_trust_session_refresh",
        "embedded_lower_trust_password_exception",
        "no_permission_within_product"
      ]
    },
    "browser_fallback_posture_token": {
      "type": "string",
      "enum": [
        "system_browser_first",
        "device_code_fallback_offered",
        "external_open_blocked_by_policy",
        "external_open_unavailable_offline",
        "browser_fallback_not_applicable"
      ]
    },
    "fallback_target_class_token": {
      "type": "string",
      "enum": [
        "system_browser_handoff_packet",
        "device_code_companion_card",
        "platform_authenticator_native",
        "host_native_review_or_approval",
        "local_inspect_or_export",
        "no_fallback_available"
      ]
    },
    "identity_mode_token": {
      "type": "string",
      "enum": ["account_free_local", "self_hosted_org", "managed_workspace"]
    },
    "trust_state_token": {
      "type": "string",
      "enum": ["trusted", "restricted"]
    },
    "auth_flow_class_token": {
      "type": "string",
      "enum": [
        "not_applicable",
        "system_browser",
        "device_code",
        "platform_authenticator_native",
        "embedded_session_refresh",
        "embedded_password_exception"
      ]
    },
    "provider_health_token": {
      "type": "string",
      "enum": ["healthy", "degraded", "unavailable", "revoked", "suspended", "expired"]
    },
    "redaction_class_token": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "audit_axis": {
      "type": "string",
      "enum": [
        "owner_origin_publisher_disclosed",
        "trust_class_disclosed",
        "handoff_rules_disclosed",
        "system_browser_baseline_for_identity_or_risky_web",
        "host_owned_high_risk_approval",
        "support_export_vocabulary_parity"
      ]
    },
    "defect_kind": {
      "type": "string",
      "enum": [
        "missing_owner_label",
        "missing_publisher_or_service_label",
        "missing_origin_host_label",
        "missing_boundary_state_token",
        "missing_permission_class_token",
        "missing_browser_fallback_posture_token",
        "missing_browser_handoff_packet_ref",
        "system_browser_not_baseline_on_identity_or_risky_web",
        "embedded_minted_native_reserved_surface",
        "support_row_vocabulary_drift",
        "boundary_state_inconsistent_with_origin_verification",
        "auth_confirmation_missing_flow_class",
        "embedded_auth_exception_missing_exception_ref"
      ]
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "case_id",
        "row_id",
        "source_card_id",
        "surface_family",
        "surface_family_token",
        "owner_label",
        "owner_class_token",
        "publisher_or_service_label",
        "publisher_or_service_class_token",
        "origin_label",
        "host_or_domain_label",
        "origin_class_token",
        "origin_verification_token",
        "data_boundary_class_token",
        "data_boundary_label",
        "boundary_state_token",
        "boundary_state_label",
        "permission_class_token",
        "permission_label",
        "identity_mode_token",
        "trust_state_token",
        "browser_fallback_posture_token",
        "fallback_target_class_token",
        "native_reserved_surface_tokens",
        "capability_limitation_tokens",
        "layout_constraint_tokens",
        "chrome_inheritance_tokens",
        "promised_audit_axes",
        "plain_language_summary",
        "redaction_class_token"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "shell_embedded_boundary_audit_beta_row_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "case_id": { "$ref": "#/$defs/stable_id" },
        "row_id": { "$ref": "#/$defs/stable_id" },
        "source_card_id": { "$ref": "#/$defs/stable_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "surface_family_token": { "$ref": "#/$defs/surface_family" },
        "owner_label": { "type": "string", "minLength": 1 },
        "owner_class_token": { "$ref": "#/$defs/owner_class_token" },
        "publisher_or_service_label": { "type": "string", "minLength": 1 },
        "publisher_or_service_class_token": {
          "$ref": "#/$defs/publisher_or_service_class_token"
        },
        "origin_label": { "type": "string", "minLength": 1 },
        "host_or_domain_label": { "type": "string", "minLength": 1 },
        "origin_class_token": { "$ref": "#/$defs/origin_class_token" },
        "origin_verification_token": { "$ref": "#/$defs/origin_verification_token" },
        "data_boundary_class_token": { "$ref": "#/$defs/data_boundary_class_token" },
        "data_boundary_label": { "type": "string", "minLength": 1 },
        "boundary_state_token": { "$ref": "#/$defs/boundary_state_token" },
        "boundary_state_label": { "type": "string", "minLength": 1 },
        "permission_class_token": { "$ref": "#/$defs/permission_class_token" },
        "permission_label": { "type": "string", "minLength": 1 },
        "identity_mode_token": { "$ref": "#/$defs/identity_mode_token" },
        "trust_state_token": { "$ref": "#/$defs/trust_state_token" },
        "browser_fallback_posture_token": {
          "$ref": "#/$defs/browser_fallback_posture_token"
        },
        "fallback_target_class_token": { "$ref": "#/$defs/fallback_target_class_token" },
        "browser_handoff_packet_ref": { "type": "string", "minLength": 1 },
        "return_target_label": { "type": "string", "minLength": 1 },
        "auth_flow_class_token": { "$ref": "#/$defs/auth_flow_class_token" },
        "auth_provider_domain_label": { "type": "string", "minLength": 1 },
        "auth_exception_id_ref": { "type": "string", "minLength": 1 },
        "provider_class_token": { "type": "string", "minLength": 1 },
        "provider_health_token": { "$ref": "#/$defs/provider_health_token" },
        "provider_scope_label": { "type": "string", "minLength": 1 },
        "native_reserved_surface_tokens": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "capability_limitation_tokens": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "layout_constraint_tokens": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "chrome_inheritance_tokens": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "promised_audit_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/audit_axis" },
          "uniqueItems": true
        },
        "plain_language_summary": { "type": "string", "minLength": 1 },
        "redaction_class_token": { "$ref": "#/$defs/redaction_class_token" }
      }
    },
    "support_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "case_id",
        "row_id",
        "surface_family_token",
        "owner_label",
        "host_or_domain_label",
        "data_boundary_class_token",
        "boundary_state_token",
        "permission_class_token",
        "browser_fallback_posture_token",
        "fallback_target_class_token",
        "identity_mode_token",
        "trust_state_token",
        "native_reserved_surface_tokens",
        "redaction_class_token"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "shell_embedded_boundary_audit_beta_support_row_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "case_id": { "$ref": "#/$defs/stable_id" },
        "row_id": { "$ref": "#/$defs/stable_id" },
        "surface_family_token": { "$ref": "#/$defs/surface_family" },
        "owner_label": { "type": "string", "minLength": 1 },
        "host_or_domain_label": { "type": "string", "minLength": 1 },
        "data_boundary_class_token": { "$ref": "#/$defs/data_boundary_class_token" },
        "boundary_state_token": { "$ref": "#/$defs/boundary_state_token" },
        "permission_class_token": { "$ref": "#/$defs/permission_class_token" },
        "browser_fallback_posture_token": {
          "$ref": "#/$defs/browser_fallback_posture_token"
        },
        "fallback_target_class_token": { "$ref": "#/$defs/fallback_target_class_token" },
        "browser_handoff_packet_ref": { "type": "string", "minLength": 1 },
        "identity_mode_token": { "$ref": "#/$defs/identity_mode_token" },
        "trust_state_token": { "$ref": "#/$defs/trust_state_token" },
        "auth_flow_class_token": { "$ref": "#/$defs/auth_flow_class_token" },
        "provider_health_token": { "$ref": "#/$defs/provider_health_token" },
        "native_reserved_surface_tokens": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "redaction_class_token": { "$ref": "#/$defs/redaction_class_token" }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "defect_id",
        "defect_kind",
        "defect_kind_token",
        "surface_family",
        "surface_family_token",
        "row_id",
        "field",
        "note"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "shell_embedded_boundary_audit_beta_defect_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "defect_id": { "$ref": "#/$defs/stable_id" },
        "defect_kind": { "$ref": "#/$defs/defect_kind" },
        "defect_kind_token": { "$ref": "#/$defs/defect_kind" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "surface_family_token": { "$ref": "#/$defs/surface_family" },
        "row_id": { "$ref": "#/$defs/stable_id" },
        "field": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_count",
        "support_row_count",
        "surface_family_count",
        "defect_count",
        "identity_or_risky_row_count",
        "system_browser_first_row_count",
        "host_owned_high_risk_approval_row_count",
        "surface_families_present",
        "boundary_states_present",
        "permission_classes_present",
        "fallback_postures_present"
      ],
      "properties": {
        "row_count": { "type": "integer", "minimum": 0 },
        "support_row_count": { "type": "integer", "minimum": 0 },
        "surface_family_count": { "type": "integer", "minimum": 0 },
        "defect_count": { "type": "integer", "minimum": 0 },
        "identity_or_risky_row_count": { "type": "integer", "minimum": 0 },
        "system_browser_first_row_count": { "type": "integer", "minimum": 0 },
        "host_owned_high_risk_approval_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "surface_families_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_family" }
        },
        "boundary_states_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/boundary_state_token" }
        },
        "permission_classes_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/permission_class_token" }
        },
        "fallback_postures_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/browser_fallback_posture_token" }
        }
      }
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "page_id",
        "page_label",
        "generated_at",
        "summary",
        "rows",
        "support_rows",
        "defects"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "shell_embedded_boundary_audit_beta_page_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "page_id": { "$ref": "#/$defs/stable_id" },
        "page_label": { "type": "string", "minLength": 1 },
        "generated_at": { "$ref": "#/$defs/iso_timestamp" },
        "summary": { "$ref": "#/$defs/summary" },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/row" }
        },
        "support_rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/support_row" }
        },
        "defects": {
          "type": "array",
          "items": { "$ref": "#/$defs/defect" }
        }
      }
    },
    "support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "export_id",
        "generated_at",
        "page",
        "defect_kinds_present",
        "defect_counts_by_kind",
        "raw_private_material_excluded"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "shell_embedded_boundary_audit_beta_support_export_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/shared_contract_ref" },
        "export_id": { "$ref": "#/$defs/stable_id" },
        "generated_at": { "$ref": "#/$defs/iso_timestamp" },
        "page": { "$ref": "#/$defs/page" },
        "defect_kinds_present": {
          "type": "array",
          "items": { "$ref": "#/$defs/defect_kind" }
        },
        "defect_counts_by_kind": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "raw_private_material_excluded": { "type": "boolean", "const": true }
      }
    }
  }
}
