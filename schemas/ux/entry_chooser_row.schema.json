{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/entry_chooser_row.schema.json",
  "title": "Aureline entry-chooser row record",
  "description": "Boundary schema for one entry_chooser_row_record as frozen in docs/ux/project_entry_contract.md. Every chooser surface that lets the user pick a project entry — Start Center, command palette, Open Recent submenu, workspace switcher, drag-drop preview, system-open handoff sheet, CLI / headless preview, and deep-link intent review — emits one record per visible row. The row carries the entry verb, the closed entry_chooser_row_kind (file, folder, workspace, remote, template, archive_or_handoff, recent, restore, deep_link_intent_review), source surface, candidate target kinds, candidate resulting modes, trust posture class, profile-default class, command-id linkage, entry-route-id family, account-opt-in posture, and the typed next-step decision hooks. The contract mints no new entry-verb, target-kind, resulting-mode, trust-state, admission-class, restore-level, missing-target-state, recovery-class, or next-step-decision-hook value; those re-export from /schemas/workspace/entry_and_restore_result.schema.json. Adding a new entry_chooser_row_kind, entry_chooser_surface_class, trust_posture_class, profile_default_class, or entry_route_id_family is additive-minor and bumps entry_chooser_row_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "$ref": "#/$defs/entry_chooser_row_record",
  "$defs": {
    "entry_chooser_row_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this entry-chooser row vocabulary export. Current value is 1. Bumped only on breaking payload changes; additive-optional fields do not bump this version."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests, support bundles, and claim manifests. Raw absolute paths, raw credentials, raw remote URLs, and raw competitor-config bodies never appear here."
    },

    "monotonic_timestamp": {
      "type": "string",
      "minLength": 1,
      "description": "Producer-local monotonic timestamp. Opaque to this schema; the exporter does not require any specific clock source."
    },

    "redaction_aware_text": {
      "type": "string",
      "maxLength": 1024,
      "description": "Redaction-aware free text (<= 1024 graphemes). The exporter is responsible for applying the redaction policy before the value crosses the boundary."
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional worked-example prelude carried on fixtures under __fixture__. Schema does not constrain shape beyond being an object."
    },

    "entry_verb": {
      "type": "string",
      "enum": [
        "open",
        "clone",
        "import",
        "add_root",
        "restore",
        "resume",
        "start_from_snapshot"
      ],
      "description": "Re-export of entry_verb from /schemas/workspace/entry_and_restore_result.schema.json. Never redefined here."
    },

    "target_kind": {
      "type": "string",
      "enum": [
        "local_file",
        "local_folder",
        "local_repo_root",
        "workspace_manifest",
        "workset_manifest",
        "remote_repository",
        "ssh_workspace",
        "container_workspace",
        "devcontainer_workspace",
        "managed_cloud_workspace",
        "portable_state_package",
        "handoff_packet",
        "competitor_config_root",
        "template_or_prebuild_snapshot",
        "review_or_work_item_deep_link",
        "recovery_checkpoint"
      ],
      "description": "Re-export of target_kind."
    },

    "resulting_mode": {
      "type": "string",
      "enum": [
        "single_file",
        "folder",
        "repo_root",
        "workspace_candidate",
        "workspace_with_roots",
        "workset_slice",
        "inspect_only",
        "clone_then_review",
        "clone_then_open",
        "clone_then_add",
        "clone_only",
        "extract_then_review",
        "compare_before_restore",
        "apply_to_active_workspace",
        "open_prebuild_with_setup_actions",
        "open_prebuild_minimal",
        "resume_live_session",
        "restore_last_session",
        "restore_from_checkpoint"
      ],
      "description": "Re-export of resulting_mode."
    },

    "source_surface": {
      "type": "string",
      "enum": [
        "start_center",
        "command_palette",
        "quick_open",
        "os_file_association",
        "drag_and_drop",
        "deep_link",
        "cli",
        "headless_automation",
        "workspace_switcher",
        "recent_work_activation",
        "template_or_prebuild_card",
        "migration_center",
        "crash_recovery_screen",
        "companion_handoff_return"
      ],
      "description": "Re-export of source_surface. Names which entry surface originated the activation."
    },

    "account_opt_in_posture": {
      "type": "string",
      "enum": [
        "optional_local_path_available",
        "required_for_this_row",
        "deferred_review_pending",
        "unavailable_in_this_envelope"
      ],
      "description": "Re-export from start_center_contract §3.3."
    },

    "next_step_decision_hook": {
      "type": "string",
      "enum": [
        "continue_in_restricted_mode",
        "review_trust_and_open",
        "open_minimal",
        "set_up_later",
        "review_archetype_match",
        "compare_before_restore",
        "open_without_restore",
        "safe_mode",
        "reconnect_required",
        "reauth_required",
        "locate_missing_target",
        "remove_from_recents",
        "review_migration_report",
        "roll_back_import",
        "keep_imported_state",
        "adopt_recommended_bundle",
        "review_unsupported_items"
      ],
      "description": "Re-export of next_step_decision_hook."
    },

    "entry_chooser_row_kind": {
      "type": "string",
      "enum": [
        "file",
        "folder",
        "workspace",
        "remote",
        "template",
        "archive_or_handoff",
        "recent",
        "restore",
        "deep_link_intent_review"
      ],
      "description": "Closed set of entry-chooser row classes. See project_entry_contract.md §4.2."
    },

    "entry_chooser_surface_class": {
      "type": "string",
      "enum": [
        "start_center",
        "workspace_switcher_palette",
        "workspace_switcher_menu",
        "workspace_switcher_dedicated_view",
        "command_palette",
        "open_recent_submenu",
        "drag_drop_preview",
        "system_open_handoff_sheet",
        "cli_headless_preview",
        "deep_link_intent_review"
      ],
      "description": "Closed set of chooser surface classes. See project_entry_contract.md §4.3."
    },

    "trust_posture_class": {
      "type": "string",
      "enum": [
        "trust_pending_until_admission",
        "trust_never_implied_by_clone",
        "trust_unchanged_until_admit",
        "trust_per_root_admission",
        "trust_inherited_from_target",
        "trust_revalidated_at_resume"
      ],
      "description": "Closed pre-commit trust posture set. Each verb's allowed value is fixed by project_entry_contract.md §3."
    },

    "profile_default_class": {
      "type": "string",
      "enum": [
        "default_profile",
        "last_active_profile",
        "sticky_for_target",
        "sticky_for_target_or_default",
        "unchanged",
        "depends_on_artifact_class",
        "default_or_template_default",
        "locked_profile_required"
      ],
      "description": "Closed profile-default posture set. Each verb's allowed value is fixed by project_entry_contract.md §3 / §4.6."
    },

    "entry_route_id_family": {
      "type": "string",
      "enum": [
        "workspace_entry.open_folder",
        "workspace_entry.open_workspace",
        "workspace_entry.clone_repository",
        "workspace_entry.import",
        "workspace_entry.resume_snapshot",
        "workspace_entry.restore_last_session",
        "workspace_entry.deep_link",
        "workspace_entry.open_in_safe_mode",
        "workspace_entry.continue_in_restricted_mode"
      ],
      "description": "Re-export of the workspace_entry_route_id family from docs/ux/workspace_entry_route_matrix.md. The row's entry_route_id_family MUST match its verb per §3."
    },

    "command_id_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Opaque ref to the command-descriptor row the chooser will invoke. MUST resolve into the command_id family for the row's verb (command.workspace.open_*, command.workspace.clone_*, command.workspace.import_*, command.workspace.add_root_*, command.workspace.restore_*, command.workspace.resume_*, command.workspace.start_from_snapshot_*)."
    },

    "disclosed_in_zone": {
      "type": "string",
      "enum": [
        "primary_work_resume",
        "recent_work_list",
        "secondary_entry",
        "profile_selection",
        "disclosure_band",
        "help_and_build_identity_footer",
        "palette_results",
        "drag_drop_overlay",
        "system_handoff_sheet_body",
        "cli_text_block",
        "deep_link_review_body"
      ],
      "description": "The chooser zone the row renders in. Start Center / workspace-switcher rows use the start_center_zone vocabulary; palette / drag-drop / system-open / CLI / deep-link surfaces add their own surface-local zone ids."
    },

    "entry_chooser_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "entry_chooser_row_schema_version",
        "row_id",
        "entry_chooser_row_kind",
        "entry_chooser_surface_class",
        "source_surface",
        "entry_verb_candidate",
        "target_kind_candidates",
        "resulting_mode_candidates",
        "trust_posture_class",
        "profile_default_class",
        "command_id_ref",
        "entry_route_id_family",
        "account_opt_in_posture",
        "next_step_decision_hooks",
        "disclosed_in_zone",
        "keyboard_reachable",
        "presentation_label"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "entry_chooser_row_record" },
        "entry_chooser_row_schema_version": { "$ref": "#/$defs/entry_chooser_row_schema_version" },
        "row_id": { "$ref": "#/$defs/opaque_id" },
        "entry_chooser_row_kind": { "$ref": "#/$defs/entry_chooser_row_kind" },
        "entry_chooser_surface_class": { "$ref": "#/$defs/entry_chooser_surface_class" },
        "source_surface": { "$ref": "#/$defs/source_surface" },
        "entry_verb_candidate": { "$ref": "#/$defs/entry_verb" },
        "target_kind_candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/target_kind" },
          "uniqueItems": true,
          "description": "Non-empty subset of the verb's allowed target-kind set per project_entry_contract.md §3."
        },
        "resulting_mode_candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/resulting_mode" },
          "uniqueItems": true,
          "description": "Non-empty subset of the verb's allowed resulting-mode set per project_entry_contract.md §3."
        },
        "trust_posture_class": { "$ref": "#/$defs/trust_posture_class" },
        "profile_default_class": { "$ref": "#/$defs/profile_default_class" },
        "command_id_ref": { "$ref": "#/$defs/command_id_ref" },
        "entry_route_id_family": { "$ref": "#/$defs/entry_route_id_family" },
        "account_opt_in_posture": { "$ref": "#/$defs/account_opt_in_posture" },
        "next_step_decision_hooks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/next_step_decision_hook" },
          "uniqueItems": true
        },
        "disclosed_in_zone": { "$ref": "#/$defs/disclosed_in_zone" },
        "keyboard_reachable": { "type": "boolean" },
        "presentation_label": { "$ref": "#/$defs/redaction_aware_text" },
        "presentation_subtitle": { "$ref": "#/$defs/redaction_aware_text" },
        "disabled_reason_code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Required when the row renders visible-but-disabled. Free-form 'Not available' copy is non-conforming."
        },
        "recent_work_entry_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Required when entry_chooser_row_kind is recent."
        },
        "restore_prompt_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Required when entry_chooser_row_kind is restore."
        },
        "artifact_descriptor_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Required when entry_chooser_row_kind is archive_or_handoff or template."
        },
        "remote_target_descriptor_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Required when entry_chooser_row_kind is remote (and when a remote variant of recent / template is rendered)."
        },
        "deep_link_descriptor_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Required when source_surface is deep_link or entry_chooser_row_kind is deep_link_intent_review."
        },
        "filesystem_identity_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Required when at least one target_kind_candidate is a local kind (local_file / local_folder / local_repo_root / workspace_manifest / workset_manifest)."
        },
        "open_flow_sheet_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Optional ref to the open_flow_sheet_record the chooser will render on activation. Required for every committing activation that may write bytes, change trust, attach a runtime, retarget a profile, or rehydrate a session — i.e. every row except a pure no-op open per project_entry_contract.md §5 rule 2."
        },
        "reroute_to_verb": {
          "$ref": "#/$defs/entry_verb",
          "description": "Optional. Set when the chooser detects a reroute (e.g. dropping a tar.zst archive on a folder row reroutes from open to import). When set, next_step_decision_hooks[] MUST include exactly one of review_trust_and_open, review_migration_report, compare_before_restore, review_archetype_match, or review_unsupported_items per §4.5."
        },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "entry_route_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Optional onboarding-measurement entry_route_id (e.g. er.start_center, er.warm_start, er.recent_work_reopen, er.restore_prompt). Distinct from entry_route_id_family; this is the analytics row id, the family is the product route family."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "entry_verb_candidate": { "const": "open" } }, "required": ["entry_verb_candidate"] },
          "then": {
            "properties": {
              "target_kind_candidates": {
                "items": {
                  "enum": [
                    "local_file",
                    "local_folder",
                    "local_repo_root",
                    "workspace_manifest",
                    "workset_manifest"
                  ]
                }
              },
              "resulting_mode_candidates": {
                "items": {
                  "enum": [
                    "single_file",
                    "folder",
                    "repo_root",
                    "workspace_candidate",
                    "workspace_with_roots",
                    "workset_slice"
                  ]
                }
              },
              "trust_posture_class": { "const": "trust_pending_until_admission" }
            }
          }
        },
        {
          "if": { "properties": { "entry_verb_candidate": { "const": "clone" } }, "required": ["entry_verb_candidate"] },
          "then": {
            "properties": {
              "target_kind_candidates": {
                "items": { "enum": ["remote_repository"] }
              },
              "resulting_mode_candidates": {
                "items": {
                  "enum": [
                    "clone_then_review",
                    "clone_then_open",
                    "clone_then_add",
                    "clone_only"
                  ]
                }
              },
              "trust_posture_class": { "const": "trust_never_implied_by_clone" },
              "profile_default_class": { "const": "default_profile" }
            },
            "required": ["remote_target_descriptor_ref"]
          }
        },
        {
          "if": { "properties": { "entry_verb_candidate": { "const": "import" } }, "required": ["entry_verb_candidate"] },
          "then": {
            "properties": {
              "target_kind_candidates": {
                "items": {
                  "enum": [
                    "portable_state_package",
                    "handoff_packet",
                    "competitor_config_root",
                    "template_or_prebuild_snapshot"
                  ]
                }
              },
              "resulting_mode_candidates": {
                "items": {
                  "enum": [
                    "extract_then_review",
                    "compare_before_restore",
                    "apply_to_active_workspace"
                  ]
                }
              },
              "trust_posture_class": { "const": "trust_unchanged_until_admit" },
              "profile_default_class": { "const": "depends_on_artifact_class" }
            },
            "required": ["artifact_descriptor_ref"]
          }
        },
        {
          "if": { "properties": { "entry_verb_candidate": { "const": "add_root" } }, "required": ["entry_verb_candidate"] },
          "then": {
            "properties": {
              "target_kind_candidates": {
                "items": {
                  "enum": [
                    "local_folder",
                    "local_repo_root",
                    "remote_repository",
                    "ssh_workspace",
                    "container_workspace",
                    "devcontainer_workspace",
                    "managed_cloud_workspace"
                  ]
                }
              },
              "resulting_mode_candidates": {
                "items": { "enum": ["workspace_with_roots", "workset_slice"] }
              },
              "trust_posture_class": { "const": "trust_per_root_admission" },
              "profile_default_class": { "const": "unchanged" },
              "entry_chooser_surface_class": {
                "enum": [
                  "workspace_switcher_palette",
                  "workspace_switcher_menu",
                  "workspace_switcher_dedicated_view",
                  "command_palette",
                  "drag_drop_preview",
                  "system_open_handoff_sheet",
                  "cli_headless_preview",
                  "deep_link_intent_review"
                ]
              }
            }
          }
        },
        {
          "if": { "properties": { "entry_verb_candidate": { "const": "restore" } }, "required": ["entry_verb_candidate"] },
          "then": {
            "properties": {
              "target_kind_candidates": {
                "items": {
                  "enum": [
                    "recovery_checkpoint",
                    "local_folder",
                    "local_repo_root",
                    "workspace_manifest",
                    "workset_manifest",
                    "managed_cloud_workspace"
                  ]
                }
              },
              "resulting_mode_candidates": {
                "items": { "enum": ["restore_last_session", "restore_from_checkpoint"] }
              },
              "trust_posture_class": { "const": "trust_inherited_from_target" },
              "profile_default_class": { "const": "sticky_for_target" }
            },
            "required": ["restore_prompt_ref"]
          }
        },
        {
          "if": { "properties": { "entry_verb_candidate": { "const": "resume" } }, "required": ["entry_verb_candidate"] },
          "then": {
            "properties": {
              "target_kind_candidates": {
                "items": {
                  "enum": [
                    "managed_cloud_workspace",
                    "ssh_workspace",
                    "container_workspace",
                    "devcontainer_workspace",
                    "template_or_prebuild_snapshot"
                  ]
                }
              },
              "resulting_mode_candidates": {
                "items": { "enum": ["resume_live_session", "open_prebuild_minimal"] }
              },
              "trust_posture_class": { "const": "trust_revalidated_at_resume" },
              "profile_default_class": { "const": "sticky_for_target" }
            }
          }
        },
        {
          "if": { "properties": { "entry_verb_candidate": { "const": "start_from_snapshot" } }, "required": ["entry_verb_candidate"] },
          "then": {
            "properties": {
              "target_kind_candidates": {
                "items": { "enum": ["template_or_prebuild_snapshot"] }
              },
              "resulting_mode_candidates": {
                "items": {
                  "enum": ["open_prebuild_with_setup_actions", "open_prebuild_minimal"]
                }
              },
              "trust_posture_class": { "const": "trust_pending_until_admission" },
              "profile_default_class": { "const": "default_or_template_default" }
            },
            "required": ["artifact_descriptor_ref"]
          }
        },
        {
          "if": { "properties": { "entry_chooser_row_kind": { "const": "recent" } }, "required": ["entry_chooser_row_kind"] },
          "then": { "required": ["recent_work_entry_ref"] }
        },
        {
          "if": { "properties": { "entry_chooser_row_kind": { "const": "restore" } }, "required": ["entry_chooser_row_kind"] },
          "then": {
            "required": ["restore_prompt_ref"],
            "properties": {
              "entry_verb_candidate": { "const": "restore" }
            }
          }
        },
        {
          "if": { "properties": { "entry_chooser_row_kind": { "const": "archive_or_handoff" } }, "required": ["entry_chooser_row_kind"] },
          "then": {
            "required": ["artifact_descriptor_ref"],
            "properties": {
              "entry_verb_candidate": { "const": "import" }
            }
          }
        },
        {
          "if": { "properties": { "entry_chooser_row_kind": { "const": "template" } }, "required": ["entry_chooser_row_kind"] },
          "then": {
            "required": ["artifact_descriptor_ref"],
            "properties": {
              "entry_verb_candidate": { "enum": ["start_from_snapshot", "resume"] }
            }
          }
        },
        {
          "if": { "properties": { "entry_chooser_row_kind": { "const": "remote" } }, "required": ["entry_chooser_row_kind"] },
          "then": {
            "required": ["remote_target_descriptor_ref"],
            "properties": {
              "entry_verb_candidate": { "enum": ["clone", "add_root", "resume", "open"] }
            }
          }
        },
        {
          "if": { "properties": { "entry_chooser_row_kind": { "const": "file" } }, "required": ["entry_chooser_row_kind"] },
          "then": {
            "properties": {
              "entry_verb_candidate": { "const": "open" },
              "target_kind_candidates": {
                "items": { "enum": ["local_file"] }
              }
            },
            "required": ["filesystem_identity_ref"]
          }
        },
        {
          "if": { "properties": { "entry_chooser_row_kind": { "const": "workspace" } }, "required": ["entry_chooser_row_kind"] },
          "then": {
            "properties": {
              "entry_verb_candidate": { "const": "open" },
              "target_kind_candidates": {
                "items": { "enum": ["workspace_manifest", "workset_manifest"] }
              }
            },
            "required": ["filesystem_identity_ref"]
          }
        },
        {
          "if": { "properties": { "entry_chooser_row_kind": { "const": "deep_link_intent_review" } }, "required": ["entry_chooser_row_kind"] },
          "then": {
            "required": ["deep_link_descriptor_ref"],
            "properties": {
              "source_surface": { "const": "deep_link" },
              "entry_chooser_surface_class": { "const": "deep_link_intent_review" }
            }
          }
        }
      ],
      "description": "One entry-chooser row record. See docs/ux/project_entry_contract.md §4."
    }
  }
}
