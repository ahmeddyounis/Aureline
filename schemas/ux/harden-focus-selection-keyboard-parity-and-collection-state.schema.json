{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/harden-focus-selection-keyboard-parity-and-collection-state.schema.json",
  "title": "Aureline interaction-parity record",
  "description": "Boundary schema for interaction_parity_record, the single governed record the shell collection surface, the keyboard-help reference, the CLI interaction inspector, Help/About, the diagnostics support export, and docs all read for one dense-surface interaction posture on the claimed-stable desktop matrix. It is minted by crates/aureline-shell/src/interaction_integrity_stable as a genuine projection of the live interaction-integrity packet (crates/aureline-shell/src/interaction_integrity). It binds, for one dense-surface identity: (1) distinct coordination states (focus, current item, selection, anchor, activation) keyed by stable object identity rather than row index or position; (2) identity preserved across streaming inserts, sort/filter/pagination refresh, background indexing, and extension-view replacement; (3) complete focus return for every transient surface that returns to the invoker, its row, or a safe ancestor/sibling and never the document body, an off-screen surface, or a different window; (4) a single-tab-stop or roving-tabindex keyboard model with Arrow moving the current item, Space toggling selection where supported, Enter triggering a discoverable default, and Home/End/Page preserving anchor semantics without silently firing destructive actions; (5) asynchronous updates that never steal focus, with the focused object resolving to the nearest safe sibling or parent and announcing the reason when it disappears; (6) selected-count narration, position-in-set cues, and blocked/read-only row cues across normal, high-contrast, and zoomed layouts; (7) per-OS conformance for macOS, Windows, and Linux; (8) a public claim ceiling no posture may exceed; and (9) a derived stable-claim verdict that narrows a posture which cannot prove a pillar, or whose lowest binding surface marker is below Stable, below Stable with a named reason. Minted refs are opaque aureline://<class>/<id> object refs; upstream refs keep their source scheme.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "posture_id",
    "posture_label",
    "title",
    "summary",
    "surface_class",
    "surface_id_ref",
    "surface_lifecycle_marker",
    "coordination",
    "async_updates",
    "focus_returns",
    "keyboard_model",
    "a11y_cues",
    "platform_conformance",
    "surface_projections",
    "pillars",
    "claim_ceiling",
    "stable_qualification",
    "recovery_routes",
    "routes",
    "accessibility",
    "available_without_account",
    "available_without_managed_services",
    "honesty_marker_present",
    "upstream",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": { "const": "interaction_parity_record" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "notice": { "type": "string", "minLength": 1 },
    "shared_contract_ref": { "const": "shell:interaction_parity_stable:v1" },
    "record_id": { "$ref": "#/$defs/presentRef" },
    "as_of": { "type": "string", "minLength": 1 },
    "posture_id": { "$ref": "#/$defs/presentRef" },
    "posture_label": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "surface_class": { "$ref": "#/$defs/surfaceClass" },
    "surface_id_ref": { "$ref": "#/$defs/presentRef" },
    "surface_lifecycle_marker": { "$ref": "#/$defs/lifecycleMarker" },
    "coordination": { "$ref": "#/$defs/coordination" },
    "async_updates": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/asyncUpdateRow" }
    },
    "focus_returns": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/focusReturnRow" }
    },
    "keyboard_model": { "$ref": "#/$defs/keyboardModel" },
    "a11y_cues": { "$ref": "#/$defs/a11yCues" },
    "platform_conformance": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/platformConformanceRow" }
    },
    "surface_projections": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/surfaceProjection" }
    },
    "pillars": { "$ref": "#/$defs/pillars" },
    "claim_ceiling": { "$ref": "#/$defs/claimCeiling" },
    "stable_qualification": { "$ref": "#/$defs/qualification" },
    "recovery_routes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/recoveryRoute" }
    },
    "routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/entryRoute" }
    },
    "accessibility": { "$ref": "#/$defs/accessibility" },
    "available_without_account": { "type": "boolean" },
    "available_without_managed_services": { "type": "boolean" },
    "honesty_marker_present": { "type": "boolean" },
    "upstream": { "$ref": "#/$defs/upstream" },
    "diagnostics_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "support_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } },
    "narrative_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } }
  },
  "$defs": {
    "canonicalRef": {
      "type": "string",
      "pattern": "^aureline://(?!home/|dashboard/|landing/|index/|overview/|start/|root/)[^/]+/.+$"
    },
    "presentRef": { "type": "string", "minLength": 1 },
    "lifecycleMarker": { "type": "string", "enum": ["preview", "beta", "stable"] },
    "claimClass": { "type": "string", "enum": ["stable", "beta", "preview", "not_claimed"] },
    "surfaceClass": {
      "type": "string",
      "enum": ["tree", "virtualized_list", "grid", "palette_like", "inspector_detail"]
    },
    "asyncUpdateClass": {
      "type": "string",
      "enum": [
        "streaming_insert",
        "sort_filter_refresh",
        "background_indexing",
        "extension_view_replacement",
        "notification_banner",
        "multi_window_update"
      ]
    },
    "disappearanceResolution": {
      "type": "string",
      "enum": ["not_applicable", "nearest_safe_sibling", "parent_node", "document_body"]
    },
    "focusReturnTrigger": {
      "type": "string",
      "enum": [
        "dialog_confirm_cancel",
        "sheet_dismiss",
        "palette_dismiss",
        "popover_dismiss",
        "inline_rename_commit_cancel",
        "inspector_dismiss",
        "pane_close",
        "split_reflow",
        "extension_view_removal",
        "missing_dependency_placeholder_replacement"
      ]
    },
    "keyboardModelClass": {
      "type": "string",
      "enum": ["single_tab_stop", "roving_tabindex"]
    },
    "profileClass": { "type": "string", "enum": ["macos", "windows", "linux"] },
    "truthSurface": {
      "type": "string",
      "enum": [
        "shell_collection_surface",
        "keyboard_help",
        "cli_inspect",
        "help_about",
        "support_export"
      ]
    },
    "narrowingReason": {
      "type": "string",
      "enum": [
        "coordination_states_collapsed",
        "identity_lost_under_async_update",
        "focus_return_incomplete",
        "keyboard_model_incomplete",
        "async_update_steals_focus",
        "accessibility_cues_incomplete",
        "platform_conformance_incomplete",
        "surface_not_yet_stable"
      ]
    },
    "recoveryRole": { "type": "string", "enum": ["primary", "recovery", "secondary"] },
    "routeSurface": {
      "type": "string",
      "enum": ["activity_center", "command_palette", "status_bar", "menu_command"]
    },
    "layoutMode": { "type": "string", "enum": ["normal", "high_contrast", "zoomed"] },
    "coordination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selection_object_id_refs",
        "states_modeled_distinctly",
        "activation_preserves_selection",
        "identity_by_stable_id_not_index"
      ],
      "properties": {
        "focus_object_id_ref": { "type": "string", "minLength": 1 },
        "current_item_id_ref": { "type": "string", "minLength": 1 },
        "selection_object_id_refs": { "type": "array", "items": { "type": "string" } },
        "anchor_object_id_ref": { "type": "string", "minLength": 1 },
        "last_activated_object_id_ref": { "type": "string", "minLength": 1 },
        "states_modeled_distinctly": { "type": "boolean" },
        "activation_preserves_selection": { "type": "boolean" },
        "identity_by_stable_id_not_index": { "type": "boolean" }
      }
    },
    "asyncUpdateRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "update_class",
        "preserves_focus_by_stable_id",
        "preserves_selection_by_stable_id",
        "preserves_anchor",
        "steals_focus_from_active_task",
        "focused_object_can_disappear",
        "disappearance_resolution",
        "announces_focus_move_reason",
        "user_impact_label"
      ],
      "properties": {
        "update_class": { "$ref": "#/$defs/asyncUpdateClass" },
        "preserves_focus_by_stable_id": { "type": "boolean" },
        "preserves_selection_by_stable_id": { "type": "boolean" },
        "preserves_anchor": { "type": "boolean" },
        "steals_focus_from_active_task": { "type": "boolean" },
        "focused_object_can_disappear": { "type": "boolean" },
        "disappearance_resolution": { "$ref": "#/$defs/disappearanceResolution" },
        "announces_focus_move_reason": { "type": "boolean" },
        "user_impact_label": { "type": "string", "minLength": 1 }
      }
    },
    "focusReturnRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger",
        "rule_id",
        "origin_object_id_ref",
        "invoking_control_id_ref",
        "expected_return_target_id_ref",
        "fallback_return_target_id_ref",
        "returns_to_invoker_or_safe_ancestor",
        "never_returns_to_document_body",
        "never_returns_to_offscreen_surface",
        "never_warps_across_windows",
        "preserves_selection_or_cursor_state",
        "screen_reader_announcement"
      ],
      "properties": {
        "trigger": { "$ref": "#/$defs/focusReturnTrigger" },
        "rule_id": { "type": "string", "minLength": 1 },
        "origin_object_id_ref": { "type": "string", "minLength": 1 },
        "invoking_control_id_ref": { "type": "string", "minLength": 1 },
        "expected_return_target_id_ref": { "type": "string", "minLength": 1 },
        "fallback_return_target_id_ref": { "type": "string", "minLength": 1 },
        "returns_to_invoker_or_safe_ancestor": { "type": "boolean" },
        "never_returns_to_document_body": { "type": "boolean" },
        "never_returns_to_offscreen_surface": { "type": "boolean" },
        "never_warps_across_windows": { "type": "boolean" },
        "preserves_selection_or_cursor_state": { "type": "boolean" },
        "screen_reader_announcement": { "type": "string", "minLength": 1 }
      }
    },
    "keyboardModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_class",
        "single_tab_stop",
        "arrow_moves_current_item",
        "selection_supported",
        "space_toggles_selection",
        "enter_triggers_default_action",
        "default_action_discoverable",
        "home_end_page_preserves_anchor",
        "no_silent_destructive_activation"
      ],
      "properties": {
        "model_class": { "$ref": "#/$defs/keyboardModelClass" },
        "single_tab_stop": { "type": "boolean" },
        "arrow_moves_current_item": { "type": "boolean" },
        "selection_supported": { "type": "boolean" },
        "space_toggles_selection": { "type": "boolean" },
        "enter_triggers_default_action": { "type": "boolean" },
        "default_action_discoverable": { "type": "boolean" },
        "home_end_page_preserves_anchor": { "type": "boolean" },
        "no_silent_destructive_activation": { "type": "boolean" }
      }
    },
    "a11yCues": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_count_narrated",
        "selected_count_label",
        "position_in_set_narrated",
        "position_in_set",
        "set_size",
        "position_in_set_label",
        "blocked_row_cue_present",
        "read_only_row_cue_present",
        "roving_tabindex_narrated"
      ],
      "properties": {
        "selected_count_narrated": { "type": "boolean" },
        "selected_count_label": { "type": "string", "minLength": 1 },
        "position_in_set_narrated": { "type": "boolean" },
        "position_in_set": { "type": "integer", "minimum": 0 },
        "set_size": { "type": "integer", "minimum": 0 },
        "position_in_set_label": { "type": "string", "minLength": 1 },
        "blocked_row_cue_present": { "type": "boolean" },
        "read_only_row_cue_present": { "type": "boolean" },
        "roving_tabindex_narrated": { "type": "boolean" }
      }
    },
    "platformConformanceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "profile_id", "covered", "proof_ref", "named_behaviors"],
      "properties": {
        "profile": { "$ref": "#/$defs/profileClass" },
        "profile_id": { "type": "string", "minLength": 1 },
        "covered": { "type": "boolean" },
        "proof_ref": { "type": "string", "minLength": 1 },
        "named_behaviors": { "type": "array", "items": { "type": "string" } }
      }
    },
    "surfaceProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "surface_marker", "reads_shared_record", "summary_line"],
      "properties": {
        "surface": { "$ref": "#/$defs/truthSurface" },
        "surface_marker": { "$ref": "#/$defs/lifecycleMarker" },
        "reads_shared_record": { "type": "boolean" },
        "summary_line": { "type": "string", "minLength": 1 }
      }
    },
    "pillars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coordination_states_distinct",
        "identity_survives_async_updates",
        "focus_return_complete",
        "keyboard_model_complete",
        "async_never_steals_focus",
        "accessibility_cues_complete",
        "platform_conformance_complete"
      ],
      "properties": {
        "coordination_states_distinct": { "type": "boolean" },
        "identity_survives_async_updates": { "type": "boolean" },
        "focus_return_complete": { "type": "boolean" },
        "keyboard_model_complete": { "type": "boolean" },
        "async_never_steals_focus": { "type": "boolean" },
        "accessibility_cues_complete": { "type": "boolean" },
        "platform_conformance_complete": { "type": "boolean" }
      }
    },
    "claimCeiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asserts_coordination_states_distinct",
        "asserts_identity_survives_async_updates",
        "asserts_focus_return_complete",
        "asserts_keyboard_model_complete",
        "asserts_async_never_steals_focus",
        "asserts_accessibility_cues_complete",
        "asserts_platform_conformance_complete"
      ],
      "properties": {
        "asserts_coordination_states_distinct": { "type": "boolean" },
        "asserts_identity_survives_async_updates": { "type": "boolean" },
        "asserts_focus_return_complete": { "type": "boolean" },
        "asserts_keyboard_model_complete": { "type": "boolean" },
        "asserts_async_never_steals_focus": { "type": "boolean" },
        "asserts_accessibility_cues_complete": { "type": "boolean" },
        "asserts_platform_conformance_complete": { "type": "boolean" }
      }
    },
    "qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_class", "qualifies_stable", "narrowing_reasons"],
      "properties": {
        "claim_class": { "$ref": "#/$defs/claimClass" },
        "qualifies_stable": { "type": "boolean" },
        "narrowing_reasons": { "type": "array", "items": { "$ref": "#/$defs/narrowingReason" } }
      }
    },
    "recoveryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_label", "action_role", "keyboard_reachable"],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_label": { "type": "string", "minLength": 1 },
        "action_role": { "$ref": "#/$defs/recoveryRole" },
        "keyboard_reachable": { "type": "boolean" }
      }
    },
    "entryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "route_ref", "keyboard_reachable", "activates_same_item"],
      "properties": {
        "surface": { "$ref": "#/$defs/routeSurface" },
        "route_ref": { "$ref": "#/$defs/canonicalRef" },
        "keyboard_reachable": { "type": "boolean" },
        "activates_same_item": { "type": "boolean" }
      }
    },
    "layoutModeDisclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "row_narration_available", "recovery_affordances_reachable"],
      "properties": {
        "mode": { "$ref": "#/$defs/layoutMode" },
        "row_narration_available": { "type": "boolean" },
        "recovery_affordances_reachable": { "type": "boolean" }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_order_index",
        "tab_stop_count",
        "row_narration",
        "action_labels",
        "layout_modes"
      ],
      "properties": {
        "focus_order_index": { "type": "integer", "minimum": 0 },
        "tab_stop_count": { "type": "integer", "minimum": 0 },
        "row_narration": { "type": "string", "minLength": 1 },
        "action_labels": { "type": "array", "items": { "type": "string" } },
        "layout_modes": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/layoutModeDisclosure" }
        }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interaction_packet_ref",
        "interaction_contract_ref",
        "contributing_object_refs"
      ],
      "properties": {
        "interaction_packet_ref": { "$ref": "#/$defs/presentRef" },
        "interaction_contract_ref": { "$ref": "#/$defs/presentRef" },
        "contributing_object_refs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
