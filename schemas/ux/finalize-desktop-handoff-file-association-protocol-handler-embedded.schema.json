{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/finalize-desktop-handoff-file-association-protocol-handler-embedded.schema.json",
  "title": "Aureline desktop handoff-conformance record",
  "description": "Boundary schema for desktop_handoff_conformance_record, the single governed record the desktop handoff-review surface, the CLI handoff inspector, Help/About, the diagnostics support export, and docs all read for one OS-originated entry-path posture on the claimed-stable desktop matrix. It is minted by crates/aureline-shell/src/desktop_handoff_conformance_stable as a genuine projection of the live native desktop contract packet (crates/aureline-shell/src/platform_integration), the native-handoff vocabulary (crates/aureline-shell/src/deeplink/native_handoff), and the system-browser return-paths page (crates/aureline-shell/src/system_browser_return_paths). It binds, for one entry-path identity: (1) typed target intent \u2014 literal target, source-locator/deep-link intent, requested action, resulting mode, and canonical object identity preserved end to end instead of reopening a generic shell or the wrong install; (2) handler ownership \u2014 explicit owning channel and build, every side-by-side Stable/Preview/Beta/portable/admin-managed channel enumerated, no last-writer-wins, and spoof-resistant; (3) system-browser default conformance \u2014 claimed identity and auth rows default to system-browser handoff or surface an explicit exception with scope, return path, and recovery; (4) trust/profile/tenant review ahead of any widened authority; (5) truthful recovery \u2014 moved/removable/network/missing targets render a recoverable placeholder with last-seen identity, unsaved-local-state posture, and explicit Locate/Open cached context/Close placeholder actions; (6) per-OS conformance for macOS, Windows, and Linux; (7) a public claim ceiling no posture may exceed; and (8) a derived stable-claim verdict that narrows a posture which cannot prove a pillar, or whose lowest binding surface marker is below Stable, below Stable with a named reason. Minted refs are opaque aureline://<class>/<id> object refs; upstream and literal projection refs keep their source scheme.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "posture_id",
    "posture_label",
    "title",
    "summary",
    "entry_path",
    "surface_lifecycle_marker",
    "intent",
    "handler_ownership",
    "auth_default",
    "trust_review",
    "recovery",
    "platform_conformance",
    "surface_projections",
    "pillars",
    "claim_ceiling",
    "stable_qualification",
    "recovery_routes",
    "routes",
    "accessibility",
    "available_without_account",
    "available_without_managed_services",
    "honesty_marker_present",
    "upstream",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": {
      "const": "desktop_handoff_conformance_record"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "notice": {
      "type": "string",
      "minLength": 1
    },
    "shared_contract_ref": {
      "const": "shell:desktop_handoff_conformance_stable:v1"
    },
    "record_id": {
      "$ref": "#/$defs/presentRef"
    },
    "as_of": {
      "type": "string",
      "minLength": 1
    },
    "posture_id": {
      "type": "string",
      "minLength": 1
    },
    "posture_label": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "entry_path": {
      "$ref": "#/$defs/entryPathClass"
    },
    "surface_lifecycle_marker": {
      "$ref": "#/$defs/lifecycleMarker"
    },
    "intent": {
      "$ref": "#/$defs/typedTargetIntent"
    },
    "handler_ownership": {
      "$ref": "#/$defs/handlerOwnership"
    },
    "auth_default": {
      "$ref": "#/$defs/authDefault"
    },
    "trust_review": {
      "$ref": "#/$defs/trustReview"
    },
    "recovery": {
      "$ref": "#/$defs/targetRecovery"
    },
    "platform_conformance": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/platformConformanceRow"
      }
    },
    "surface_projections": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/surfaceProjection"
      }
    },
    "pillars": {
      "$ref": "#/$defs/pillars"
    },
    "claim_ceiling": {
      "$ref": "#/$defs/claimCeiling"
    },
    "stable_qualification": {
      "$ref": "#/$defs/qualification"
    },
    "recovery_routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/recoveryRoute"
      }
    },
    "routes": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/entryRoute"
      }
    },
    "accessibility": {
      "$ref": "#/$defs/accessibility"
    },
    "available_without_account": {
      "type": "boolean"
    },
    "available_without_managed_services": {
      "type": "boolean"
    },
    "honesty_marker_present": {
      "type": "boolean"
    },
    "upstream": {
      "$ref": "#/$defs/upstream"
    },
    "diagnostics_export_ref": {
      "$ref": "#/$defs/canonicalRef"
    },
    "support_export_ref": {
      "$ref": "#/$defs/canonicalRef"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/canonicalRef"
      }
    },
    "narrative_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/canonicalRef"
      }
    }
  },
  "$defs": {
    "canonicalRef": {
      "type": "string",
      "pattern": "^aureline://(?!home/|dashboard/|landing/|index/|overview/|start/|root/)[^/]+/.+$"
    },
    "presentRef": {
      "type": "string",
      "minLength": 1
    },
    "lifecycleMarker": {
      "enum": [
        "preview",
        "beta",
        "stable"
      ]
    },
    "claimClass": {
      "enum": [
        "stable",
        "beta",
        "preview",
        "not_claimed"
      ]
    },
    "entryPathClass": {
      "enum": [
        "file_association",
        "protocol_handler",
        "system_open",
        "default_browser_auth_callback",
        "reveal_in_system_shell",
        "recent_item_reopen",
        "jump_list_action",
        "removable_volume_reopen",
        "network_share_reopen",
        "native_open_save"
      ]
    },
    "channelClass": {
      "enum": [
        "stable",
        "preview",
        "beta",
        "portable",
        "admin_managed"
      ]
    },
    "platformProfileClass": {
      "enum": [
        "macos",
        "windows",
        "linux"
      ]
    },
    "availabilityClass": {
      "enum": [
        "exact_available",
        "available_read_only",
        "stale_available",
        "moved_or_alias_changed",
        "missing_or_unmounted",
        "blocked_by_policy",
        "auth_required",
        "remote_unreachable",
        "expired",
        "ambiguous",
        "unknown"
      ]
    },
    "exceptionClass": {
      "enum": [
        "system_browser_default_no_exception",
        "admin_policy_device_code_required",
        "admin_policy_manual_resume_required",
        "browser_launch_unavailable_use_device_code",
        "browser_launch_offline_use_stay_local",
        "account_free_local_no_auth_required"
      ]
    },
    "truthSurface": {
      "enum": [
        "desktop_handoff_review",
        "cli_inspect",
        "help_about",
        "support_export"
      ]
    },
    "narrowingReason": {
      "enum": [
        "typed_intent_not_preserved",
        "handler_ownership_not_explicit",
        "auth_not_system_browser_default",
        "trust_review_not_enforced",
        "recovery_not_truthful",
        "platform_conformance_incomplete",
        "surface_not_yet_stable"
      ]
    },
    "recoveryRole": {
      "enum": [
        "primary",
        "recovery",
        "secondary"
      ]
    },
    "routeSurface": {
      "enum": [
        "activity_center",
        "command_palette",
        "status_bar",
        "menu_command"
      ]
    },
    "layoutMode": {
      "enum": [
        "normal",
        "high_contrast",
        "zoomed"
      ]
    },
    "recoveryActionId": {
      "enum": [
        "open_bound_target",
        "locate_target",
        "open_cached_context",
        "close_placeholder",
        "reconnect_session",
        "reauthenticate",
        "review_handler_ownership",
        "export_handoff_support"
      ]
    },
    "typedTargetIntent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_surface_token",
        "origin_class_token",
        "requested_action_class_token",
        "literal_target_label",
        "literal_target_ref",
        "canonical_target_ref",
        "target_kind_token",
        "resulting_mode_token",
        "availability",
        "freshness_class_token",
        "preserves_literal_target",
        "preserves_typed_intent",
        "preserves_resulting_mode",
        "no_generic_shell_reopen"
      ],
      "properties": {
        "source_surface_token": {
          "type": "string",
          "minLength": 1
        },
        "origin_class_token": {
          "type": "string",
          "minLength": 1
        },
        "requested_action_class_token": {
          "type": "string",
          "minLength": 1
        },
        "literal_target_label": {
          "type": "string",
          "minLength": 1
        },
        "literal_target_ref": {
          "$ref": "#/$defs/presentRef"
        },
        "canonical_target_ref": {
          "$ref": "#/$defs/canonicalRef"
        },
        "target_kind_token": {
          "type": "string",
          "minLength": 1
        },
        "resulting_mode_token": {
          "type": "string",
          "minLength": 1
        },
        "availability": {
          "$ref": "#/$defs/availabilityClass"
        },
        "freshness_class_token": {
          "type": "string",
          "minLength": 1
        },
        "deep_link_intent_ref": {
          "$ref": "#/$defs/presentRef"
        },
        "preserves_literal_target": {
          "type": "boolean"
        },
        "preserves_typed_intent": {
          "type": "boolean"
        },
        "preserves_resulting_mode": {
          "type": "boolean"
        },
        "no_generic_shell_reopen": {
          "type": "boolean"
        }
      }
    },
    "handlerOwnership": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owning_channel_ref",
        "owner_build_ref",
        "owning_channel_class",
        "handler_ownership_token",
        "ownership_review_state_token",
        "side_by_side_channels",
        "ownership_explicit",
        "no_last_writer_wins",
        "spoof_resistant"
      ],
      "properties": {
        "owning_channel_ref": {
          "$ref": "#/$defs/canonicalRef"
        },
        "owner_build_ref": {
          "$ref": "#/$defs/presentRef"
        },
        "owning_channel_class": {
          "$ref": "#/$defs/channelClass"
        },
        "handler_ownership_token": {
          "type": "string",
          "minLength": 1
        },
        "ownership_review_state_token": {
          "type": "string",
          "minLength": 1
        },
        "side_by_side_channels": {
          "type": "array",
          "minItems": 5,
          "items": {
            "$ref": "#/$defs/channelClass"
          }
        },
        "ownership_explicit": {
          "type": "boolean"
        },
        "no_last_writer_wins": {
          "type": "boolean"
        },
        "spoof_resistant": {
          "type": "boolean"
        }
      }
    },
    "authDefault": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applies",
        "default_to_system_browser",
        "system_browser_default",
        "exception_class",
        "return_mode_token",
        "embedded_browser_used"
      ],
      "properties": {
        "applies": {
          "type": "boolean"
        },
        "default_to_system_browser": {
          "type": "boolean"
        },
        "system_browser_default": {
          "type": "boolean"
        },
        "exception_class": {
          "$ref": "#/$defs/exceptionClass"
        },
        "exception_scope_ref": {
          "$ref": "#/$defs/presentRef"
        },
        "return_path_ref": {
          "$ref": "#/$defs/presentRef"
        },
        "return_mode_token": {
          "type": "string",
          "minLength": 1
        },
        "recovery_on_exception_ref": {
          "$ref": "#/$defs/presentRef"
        },
        "embedded_browser_used": {
          "type": "boolean"
        }
      }
    },
    "trustReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust_state_token",
        "profile_or_tenant_scope_ref",
        "policy_epoch_ref",
        "requested_authority_scope_token",
        "granted_authority_scope_token",
        "review_required_before_widening",
        "trust_profile_tenant_checked",
        "no_silent_authority_widening"
      ],
      "properties": {
        "trust_state_token": {
          "type": "string",
          "minLength": 1
        },
        "profile_or_tenant_scope_ref": {
          "$ref": "#/$defs/presentRef"
        },
        "policy_epoch_ref": {
          "$ref": "#/$defs/presentRef"
        },
        "requested_authority_scope_token": {
          "type": "string",
          "minLength": 1
        },
        "granted_authority_scope_token": {
          "type": "string",
          "minLength": 1
        },
        "review_required_before_widening": {
          "type": "boolean"
        },
        "trust_profile_tenant_checked": {
          "type": "boolean"
        },
        "no_silent_authority_widening": {
          "type": "boolean"
        }
      }
    },
    "targetRecovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "availability",
        "placeholder_required",
        "unsaved_local_state_posture_token",
        "local_work_preserved",
        "recovery_actions",
        "no_silent_replay_or_authority_reuse",
        "write_posture_token"
      ],
      "properties": {
        "availability": {
          "$ref": "#/$defs/availabilityClass"
        },
        "placeholder_required": {
          "type": "boolean"
        },
        "last_seen_identity_ref": {
          "$ref": "#/$defs/presentRef"
        },
        "unsaved_local_state_posture_token": {
          "type": "string",
          "minLength": 1
        },
        "local_work_preserved": {
          "type": "boolean"
        },
        "recovery_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/recoveryActionId"
          }
        },
        "no_silent_replay_or_authority_reuse": {
          "type": "boolean"
        },
        "canonical_target_path_label": {
          "type": "string",
          "minLength": 1
        },
        "write_posture_token": {
          "type": "string",
          "minLength": 1
        },
        "profile_remote_boundary_note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "platformConformanceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "profile_id",
        "covered",
        "proof_ref",
        "drill_class_tokens"
      ],
      "properties": {
        "profile": {
          "$ref": "#/$defs/platformProfileClass"
        },
        "profile_id": {
          "type": "string",
          "minLength": 1
        },
        "covered": {
          "type": "boolean"
        },
        "proof_ref": {
          "$ref": "#/$defs/presentRef"
        },
        "drill_class_tokens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "surfaceProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "surface_marker",
        "reads_shared_record",
        "summary_line"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/truthSurface"
        },
        "surface_marker": {
          "$ref": "#/$defs/lifecycleMarker"
        },
        "reads_shared_record": {
          "type": "boolean"
        },
        "summary_line": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "pillars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "typed_intent_preserved",
        "handler_ownership_explicit",
        "system_browser_default_or_explicit_exception",
        "trust_review_enforced",
        "recovery_truthful",
        "platform_conformance_complete"
      ],
      "properties": {
        "typed_intent_preserved": {
          "type": "boolean"
        },
        "handler_ownership_explicit": {
          "type": "boolean"
        },
        "system_browser_default_or_explicit_exception": {
          "type": "boolean"
        },
        "trust_review_enforced": {
          "type": "boolean"
        },
        "recovery_truthful": {
          "type": "boolean"
        },
        "platform_conformance_complete": {
          "type": "boolean"
        }
      }
    },
    "claimCeiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asserts_typed_intent_preserved",
        "asserts_handler_ownership_explicit",
        "asserts_system_browser_default",
        "asserts_trust_review_enforced",
        "asserts_recovery_truthful",
        "asserts_platform_conformance_complete"
      ],
      "properties": {
        "asserts_typed_intent_preserved": {
          "type": "boolean"
        },
        "asserts_handler_ownership_explicit": {
          "type": "boolean"
        },
        "asserts_system_browser_default": {
          "type": "boolean"
        },
        "asserts_trust_review_enforced": {
          "type": "boolean"
        },
        "asserts_recovery_truthful": {
          "type": "boolean"
        },
        "asserts_platform_conformance_complete": {
          "type": "boolean"
        }
      }
    },
    "qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_class",
        "qualifies_stable",
        "narrowing_reasons"
      ],
      "properties": {
        "claim_class": {
          "$ref": "#/$defs/claimClass"
        },
        "qualifies_stable": {
          "type": "boolean"
        },
        "narrowing_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/narrowingReason"
          }
        }
      }
    },
    "recoveryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "action_label",
        "action_role",
        "keyboard_reachable"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "minLength": 1
        },
        "action_label": {
          "type": "string",
          "minLength": 1
        },
        "action_role": {
          "$ref": "#/$defs/recoveryRole"
        },
        "keyboard_reachable": {
          "type": "boolean"
        }
      }
    },
    "entryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "route_ref",
        "keyboard_reachable",
        "activates_same_item"
      ],
      "properties": {
        "surface": {
          "$ref": "#/$defs/routeSurface"
        },
        "route_ref": {
          "$ref": "#/$defs/canonicalRef"
        },
        "keyboard_reachable": {
          "type": "boolean"
        },
        "activates_same_item": {
          "type": "boolean"
        }
      }
    },
    "layoutModeDisclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "row_narration_available",
        "recovery_affordances_reachable"
      ],
      "properties": {
        "mode": {
          "$ref": "#/$defs/layoutMode"
        },
        "row_narration_available": {
          "type": "boolean"
        },
        "recovery_affordances_reachable": {
          "type": "boolean"
        }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_order_index",
        "tab_stop_count",
        "row_narration",
        "action_labels",
        "layout_modes"
      ],
      "properties": {
        "focus_order_index": {
          "type": "integer",
          "minimum": 0
        },
        "tab_stop_count": {
          "type": "integer",
          "minimum": 0
        },
        "row_narration": {
          "type": "string",
          "minLength": 1
        },
        "action_labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "layout_modes": {
          "type": "array",
          "minItems": 3,
          "items": {
            "$ref": "#/$defs/layoutModeDisclosure"
          }
        }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "native_contract_packet_ref",
        "system_browser_page_ref",
        "ownership_audit_ref",
        "contributing_event_refs"
      ],
      "properties": {
        "native_contract_packet_ref": {
          "$ref": "#/$defs/presentRef"
        },
        "system_browser_page_ref": {
          "$ref": "#/$defs/presentRef"
        },
        "ownership_audit_ref": {
          "$ref": "#/$defs/presentRef"
        },
        "contributing_event_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/presentRef"
          }
        }
      }
    }
  }
}
