{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/guided_surface_state.schema.json",
  "title": "Aureline learnability, guided-surface, and citation-backed explainer contract",
  "description": "Boundary schema for the learnability surfaces frozen in docs/ux/learnability_contract.md. Every onboarding card, glossary card, guided-tour step, architecture explainer, contextual tip, keymap-bridge hint, exercise step, learning-mode profile entry, speaker-note adjunct, and teaching-session adjunct resolves through one guided_surface_state_record plus one guided_surface_rule_record for its surface kind, and every learning-mode profile aggregates through one learning_mode_profile_record declaring the twelve const-true invariants. The contract mints no new command id, docs citation anchor, symbol-linked reference, source_class, derivation, reuse_surface, policy_context, redaction_class, deployment_profile_id, or freshness vocabulary; those are re-exported by reference from schemas/commands/command_registry_entry.schema.json, schemas/commands/command_descriptor.schema.json, schemas/docs/citation_anchor.schema.json, schemas/docs/symbol_linked_reference.schema.json, schemas/commands/keybinding_resolver.schema.json, schemas/ux/onboarding_portability_state.schema.json, and artifacts/governance/deployment_profiles.yaml. Adding a new guided_surface_kind, guidance_authority_class, dismissal_class, reset_class, progress_export_class, freshness_class, suppression_cause_class, citation_posture, teaching_session_adjunct_class, learning_mode_profile_class, exercise_mutation_posture, or denial_reason is additive-minor and bumps guided_surface_schema_version; repurposing an existing value is breaking and requires a new decision row. Raw pack bodies, raw URLs, raw absolute paths, raw prompt / completion text, and raw credential material never cross this boundary; this schema carries opaque ids, typed vocabulary, short privacy-safe labels, and typed policy / redaction metadata only.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/guided_surface_state_record" },
    { "$ref": "#/$defs/guided_surface_rule_record" },
    { "$ref": "#/$defs/learning_mode_profile_record" }
  ],
  "$defs": {
    "guided_surface_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this learnability / guided-surface vocabulary export. Current value is 1. Bumped only on breaking payload changes; additive-optional fields do not bump this version."
    },

    "record_kind": {
      "type": "string",
      "enum": [
        "guided_surface_state_record",
        "guided_surface_rule_record",
        "learning_mode_profile_record"
      ],
      "description": "Discriminator for the concrete payload shape. Every record carries exactly one kind."
    },

    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests / support bundles / portable profile packages. Raw URLs, raw absolute paths, raw docs bodies, and raw prompt text never appear here."
    },

    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },

    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Short privacy-safe label text. MUST NOT embed raw paths, raw URLs, raw secret material, or raw AI prompt / completion text."
    },

    "bcp47_locale_tag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$",
      "description": "BCP-47 language tag re-exported from schemas/docs/citation_anchor.schema.json without modification."
    },

    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "guided_surface_kind": {
      "type": "string",
      "enum": [
        "onboarding_card",
        "glossary_card",
        "guided_tour_step",
        "architecture_explainer",
        "contextual_tip",
        "keymap_bridge_hint",
        "exercise_step",
        "learning_mode_profile_entry",
        "speaker_note_adjunct",
        "teaching_session_adjunct"
      ],
      "description": "Closed guided-surface kind vocabulary. See docs/ux/learnability_contract.md §2."
    },

    "guidance_authority_class": {
      "type": "string",
      "enum": [
        "command_id_anchored",
        "docs_anchor_anchored",
        "symbol_reference_anchored",
        "keymap_bridge_anchored",
        "derived_with_upstream_anchors",
        "aggregate_learning_mode_entry"
      ],
      "description": "Closed authority-class vocabulary. See §3. unanchored is not a value; a surface that cannot declare an authority MUST suppress rather than render."
    },

    "dismissal_class": {
      "type": "string",
      "enum": [
        "per_session_one_shot",
        "per_profile_dismissable",
        "per_device_dismissable",
        "policy_locked",
        "not_dismissable"
      ],
      "description": "Closed dismissal vocabulary. See §4."
    },

    "reset_class": {
      "type": "string",
      "enum": [
        "resettable_per_profile",
        "resettable_per_device",
        "resettable_per_account",
        "resettable_by_policy",
        "not_resettable_locally"
      ],
      "description": "Re-exported from schemas/ux/onboarding_portability_state.schema.json without modification."
    },

    "progress_export_class": {
      "type": "string",
      "enum": [
        "in_portable_profile_package",
        "in_portable_profile_package_redacted",
        "in_support_bundle_redacted",
        "not_exported_machine_local",
        "blocked_by_policy"
      ],
      "description": "Re-exported from schemas/ux/onboarding_portability_state.schema.json export_class without modification; omits in_handoff_packet which is not admissible for learnability progress state."
    },

    "freshness_class": {
      "type": "string",
      "enum": [
        "live_authoritative",
        "cached_current",
        "stale_past_ttl",
        "cached_mirror_only",
        "unverified_upstream"
      ],
      "description": "Closed freshness vocabulary for guided surfaces. See §5. Narrower than the citation-anchor freshness_class because learnability surfaces project into teaching contexts where unverified_upstream is a suppression-only state."
    },

    "version_match_state": {
      "type": "string",
      "enum": [
        "exact_build_match",
        "compatible_minor_drift",
        "incompatible_drift_detected",
        "pre_release_unverified",
        "unknown_target_build"
      ],
      "description": "Re-exported from schemas/docs/citation_anchor.schema.json version_match_state without modification (ADR-0013)."
    },

    "suppression_cause_class": {
      "type": "string",
      "enum": [
        "stale_citation_superseded",
        "docs_pack_missing",
        "locale_unavailable",
        "policy_disabled_learning_surface",
        "imported_teaching_pack_unavailable",
        "incompatible_build_drift",
        "exercise_step_blocked_by_workspace_trust",
        "keymap_bridge_unresolved",
        "command_id_missing",
        "command_id_deprecated_without_replacement",
        "command_id_disabled_in_current_policy",
        "teaching_session_expired"
      ],
      "description": "Closed suppression-cause vocabulary. Required when active = false. See §5."
    },

    "citation_posture": {
      "type": "string",
      "enum": [
        "required_primary_anchor",
        "required_primary_plus_upstream",
        "optional_supplementary",
        "forbidden"
      ],
      "description": "Closed citation-posture vocabulary used on guided_surface_rule_record rows. A rule that sets required_primary_plus_upstream on a kind forces every record of that kind to carry at least one upstream_citation_anchor_ref."
    },

    "teaching_session_adjunct_class": {
      "type": "string",
      "enum": [
        "speaker_note_for_architecture_map",
        "speaker_note_for_guided_tour",
        "presentation_mode_caption",
        "audience_visible_exercise_cue",
        "handoff_note_for_facilitator"
      ],
      "description": "Closed teaching-session adjunct class. Required when surface_kind is speaker_note_adjunct or teaching_session_adjunct. See §6."
    },

    "learning_mode_profile_class": {
      "type": "string",
      "enum": [
        "default_individual_learner",
        "classroom_managed_pool",
        "facilitator_led_session",
        "air_gapped_offline_pack",
        "privacy_reduced_local_only",
        "policy_disabled"
      ],
      "description": "Closed learning-mode profile-class vocabulary. See §1.3."
    },

    "exercise_mutation_posture": {
      "type": "string",
      "enum": [
        "read_only_walkthrough",
        "mutates_workspace_after_ack",
        "blocked_until_trust_granted"
      ],
      "description": "Closed exercise mutation-posture vocabulary. Required when surface_kind = exercise_step."
    },

    "denial_reason": {
      "type": "string",
      "enum": [
        "learnability_surface_without_command_or_docs_anchor",
        "learnability_surface_derived_without_upstream",
        "learnability_surface_cites_forbidden_target",
        "learnability_surface_opens_private_mutation_path",
        "learnability_surface_citation_stale_presented_as_live",
        "learnability_surface_locale_fallback_not_disclosed",
        "learnability_surface_docs_pack_missing_not_disclosed",
        "learnability_surface_dismissed_state_collapsed",
        "learnability_surface_progress_export_class_mismatch",
        "learnability_surface_policy_disabled_still_rendered",
        "learnability_surface_imported_teaching_pack_unverified",
        "learnability_surface_presentation_step_loses_command_link",
        "learnability_surface_schema_version_lagging"
      ],
      "description": "Closed denial-reason set publishers MUST emit on non-conformance. See §8."
    },

    "deployment_profile_id": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud",
        "air_gapped_mirror_only"
      ],
      "description": "Re-exported from artifacts/governance/deployment_profiles.yaml without modification."
    },

    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ],
      "description": "Re-exported from schemas/governance/capability_lifecycle.schema.json without modification (ADR-0011)."
    },

    "measurement_surface_ref": {
      "type": "string",
      "enum": [
        "surface_first_run",
        "surface_first_open",
        "surface_first_useful_edit",
        "surface_migration_review",
        "surface_restore_success",
        "surface_opt_in_boundary"
      ],
      "description": "Re-exported from docs/product/onboarding_measurement_plan.md §3 without modification."
    },

    "reuse_surface": {
      "type": "string",
      "enum": [
        "docs_pane",
        "docs_browser",
        "help_about",
        "service_health",
        "support_summary",
        "onboarding",
        "ai_explanation_overlay",
        "glossary_card",
        "hosted_review_evidence",
        "repair_packet_evidence",
        "portability_export",
        "offboarding_export"
      ],
      "description": "Re-exported from schemas/docs/citation_anchor.schema.json reuse_surface without modification. The docs citation contract requires that anchors this surface cites list one of onboarding, glossary_card, ai_explanation_overlay, docs_pane, or hosted_review_evidence; surfaces MUST not flatten a support-bundle-only or signing-evidence-only anchor into a teaching card."
    },

    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted"]
        },
        "execution_context_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "description": "Policy context this surface was minted under. Re-exported from schemas/docs/citation_anchor.schema.json without modification."
    },

    "primary_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anchor_kind"],
      "oneOf": [
        { "required": ["anchor_kind", "command_id_ref"] },
        { "required": ["anchor_kind", "docs_citation_anchor_ref"] },
        { "required": ["anchor_kind", "symbol_linked_reference_ref"] },
        { "required": ["anchor_kind", "keymap_bridge_ref"] },
        { "required": ["anchor_kind", "aggregated_entry_refs"] }
      ],
      "properties": {
        "anchor_kind": {
          "type": "string",
          "enum": [
            "command_id_anchor",
            "docs_citation_anchor",
            "symbol_linked_reference_anchor",
            "keymap_bridge_anchor",
            "aggregate_learning_mode_entry_anchor"
          ],
          "description": "Discriminator naming which typed primary-anchor field is populated. MUST agree with guidance_authority_class on the parent record."
        },
        "command_id_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque pin to a canonical command_id on schemas/commands/command_registry_entry.schema.json. Required for anchor_kind = command_id_anchor."
        },
        "docs_citation_anchor_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque pin to a docs_citation_anchor_record.anchor_id from schemas/docs/citation_anchor.schema.json. Required for anchor_kind = docs_citation_anchor."
        },
        "symbol_linked_reference_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque pin to a symbol_linked_reference_record id from schemas/docs/symbol_linked_reference.schema.json. Required for anchor_kind = symbol_linked_reference_anchor."
        },
        "keymap_bridge_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque pin to a keybinding_resolver record (legacy-keymap bridge) from schemas/commands/keybinding_resolver.schema.json that resolves to a canonical command_id. Required for anchor_kind = keymap_bridge_anchor."
        },
        "aggregated_entry_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Opaque ids of the guided_surface_state_records this learning_mode_profile_entry aggregates. Required for anchor_kind = aggregate_learning_mode_entry_anchor; forbidden otherwise."
        }
      }
    },

    "guided_surface_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "guided_surface_schema_version",
        "surface_id",
        "surface_kind",
        "rule_ref",
        "authority_class",
        "primary_anchor",
        "upstream_citation_anchor_refs",
        "dismissal_class",
        "reset_class",
        "progress_export_class",
        "freshness_class",
        "version_match_state_at_mint",
        "locale",
        "locale_fallback_disclosed",
        "docs_pack_ref",
        "docs_pack_revision_ref",
        "target_build_identity_ref",
        "active",
        "deployment_profile_refs",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "guided_surface_state_record" },
        "guided_surface_schema_version": { "$ref": "#/$defs/guided_surface_schema_version" },
        "surface_id": { "$ref": "#/$defs/opaque_id" },
        "surface_kind": { "$ref": "#/$defs/guided_surface_kind" },
        "rule_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque id of the guided_surface_rule_record this surface resolves against. Every emitted state record names the rule row for its surface kind."
        },
        "authority_class": { "$ref": "#/$defs/guidance_authority_class" },
        "primary_anchor": { "$ref": "#/$defs/primary_anchor" },
        "upstream_citation_anchor_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Upstream docs_citation_anchor ids this surface derives from. Empty for non-derived surfaces. Non-empty for authority_class = derived_with_upstream_anchors; the docs citation contract requires at least one upstream anchor of an authoritative source_class."
        },
        "dismissal_class": { "$ref": "#/$defs/dismissal_class" },
        "reset_class": { "$ref": "#/$defs/reset_class" },
        "progress_export_class": { "$ref": "#/$defs/progress_export_class" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "version_match_state_at_mint": { "$ref": "#/$defs/version_match_state" },
        "locale": { "$ref": "#/$defs/bcp47_locale_tag" },
        "locale_fallback_disclosed": { "type": "boolean" },
        "docs_pack_ref": { "$ref": "#/$defs/opaque_id" },
        "docs_pack_revision_ref": { "$ref": "#/$defs/opaque_id" },
        "target_build_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "active": { "type": "boolean" },
        "suppression_cause_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/suppression_cause_class" }
          ],
          "description": "Required (non-null) when active = false. Null otherwise."
        },
        "teaching_session_adjunct_class": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/teaching_session_adjunct_class" }
          ]
        },
        "preserves_command_identity_on_handoff": {
          "type": "boolean",
          "description": "When surface_kind is speaker_note_adjunct or teaching_session_adjunct, MUST be true so the presentation step carries the same command id or docs anchor as its audience-visible step."
        },
        "exercise_mutation_posture": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/exercise_mutation_posture" }
          ]
        },
        "measurement_surface_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/measurement_surface_ref" }
          ]
        },
        "reuse_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/reuse_surface" },
          "uniqueItems": true,
          "description": "Reuse surfaces this surface is admissible on. When non-empty, every cited docs anchor MUST allow at least one of onboarding, glossary_card, ai_explanation_overlay, docs_pane, or hosted_review_evidence."
        },
        "deployment_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "denial_reason_on_deny": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/denial_reason" }
          ],
          "description": "Reserved for suppressed rows whose cause is not admissible as a plain suppression_cause_class (e.g. a schema-version lag)."
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "presentation_subtitle": { "$ref": "#/$defs/short_label_text" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "authority_class agrees with primary_anchor.anchor_kind.",
          "oneOf": [
            {
              "properties": {
                "authority_class": { "const": "command_id_anchored" },
                "primary_anchor": {
                  "properties": { "anchor_kind": { "const": "command_id_anchor" } }
                }
              }
            },
            {
              "properties": {
                "authority_class": { "const": "docs_anchor_anchored" },
                "primary_anchor": {
                  "properties": { "anchor_kind": { "const": "docs_citation_anchor" } }
                }
              }
            },
            {
              "properties": {
                "authority_class": { "const": "symbol_reference_anchored" },
                "primary_anchor": {
                  "properties": { "anchor_kind": { "const": "symbol_linked_reference_anchor" } }
                }
              }
            },
            {
              "properties": {
                "authority_class": { "const": "keymap_bridge_anchored" },
                "primary_anchor": {
                  "properties": { "anchor_kind": { "const": "keymap_bridge_anchor" } }
                }
              }
            },
            {
              "properties": {
                "authority_class": { "const": "derived_with_upstream_anchors" },
                "primary_anchor": {
                  "properties": {
                    "anchor_kind": {
                      "enum": [
                        "docs_citation_anchor",
                        "symbol_linked_reference_anchor"
                      ]
                    }
                  }
                }
              }
            },
            {
              "properties": {
                "authority_class": { "const": "aggregate_learning_mode_entry" },
                "primary_anchor": {
                  "properties": { "anchor_kind": { "const": "aggregate_learning_mode_entry_anchor" } }
                }
              }
            }
          ]
        },
        {
          "description": "authority_class = derived_with_upstream_anchors requires a non-empty upstream_citation_anchor_refs; all other classes require it empty.",
          "if": {
            "properties": { "authority_class": { "const": "derived_with_upstream_anchors" } },
            "required": ["authority_class"]
          },
          "then": {
            "properties": {
              "upstream_citation_anchor_refs": {
                "type": "array",
                "minItems": 1
              }
            }
          },
          "else": {
            "properties": {
              "upstream_citation_anchor_refs": {
                "type": "array",
                "maxItems": 0
              }
            }
          }
        },
        {
          "description": "active = false requires suppression_cause_class; active = true forbids it.",
          "if": {
            "properties": { "active": { "const": false } },
            "required": ["active"]
          },
          "then": {
            "properties": {
              "suppression_cause_class": { "$ref": "#/$defs/suppression_cause_class" }
            },
            "required": ["suppression_cause_class"]
          },
          "else": {
            "properties": {
              "suppression_cause_class": { "type": "null" }
            }
          }
        },
        {
          "description": "per_profile_dismissable requires a portable progress_export_class.",
          "if": {
            "properties": { "dismissal_class": { "const": "per_profile_dismissable" } },
            "required": ["dismissal_class"]
          },
          "then": {
            "properties": {
              "progress_export_class": {
                "enum": [
                  "in_portable_profile_package",
                  "in_portable_profile_package_redacted"
                ]
              }
            }
          }
        },
        {
          "description": "per_device_dismissable forbids portable profile export.",
          "if": {
            "properties": { "dismissal_class": { "const": "per_device_dismissable" } },
            "required": ["dismissal_class"]
          },
          "then": {
            "properties": {
              "progress_export_class": {
                "enum": [
                  "not_exported_machine_local",
                  "in_support_bundle_redacted"
                ]
              }
            }
          }
        },
        {
          "description": "policy_locked surfaces carry a populated policy_context.policy_epoch (always required) and MUST NOT export as portable.",
          "if": {
            "properties": { "dismissal_class": { "const": "policy_locked" } },
            "required": ["dismissal_class"]
          },
          "then": {
            "properties": {
              "progress_export_class": {
                "enum": [
                  "blocked_by_policy",
                  "in_support_bundle_redacted"
                ]
              }
            }
          }
        },
        {
          "description": "surface_kind = exercise_step requires a non-null exercise_mutation_posture.",
          "if": {
            "properties": { "surface_kind": { "const": "exercise_step" } },
            "required": ["surface_kind"]
          },
          "then": {
            "properties": {
              "exercise_mutation_posture": { "$ref": "#/$defs/exercise_mutation_posture" }
            },
            "required": ["exercise_mutation_posture"]
          }
        },
        {
          "description": "Speaker-note and teaching-session adjuncts require a non-null teaching_session_adjunct_class and preserves_command_identity_on_handoff = true.",
          "if": {
            "properties": {
              "surface_kind": {
                "enum": ["speaker_note_adjunct", "teaching_session_adjunct"]
              }
            },
            "required": ["surface_kind"]
          },
          "then": {
            "properties": {
              "teaching_session_adjunct_class": { "$ref": "#/$defs/teaching_session_adjunct_class" },
              "preserves_command_identity_on_handoff": { "const": true }
            },
            "required": [
              "teaching_session_adjunct_class",
              "preserves_command_identity_on_handoff"
            ]
          }
        },
        {
          "description": "keymap_bridge_hint surfaces MUST declare authority_class = keymap_bridge_anchored and cite a keymap_bridge_ref.",
          "if": {
            "properties": { "surface_kind": { "const": "keymap_bridge_hint" } },
            "required": ["surface_kind"]
          },
          "then": {
            "properties": {
              "authority_class": { "const": "keymap_bridge_anchored" }
            }
          }
        },
        {
          "description": "onboarding_card surfaces MUST declare authority_class = command_id_anchored so the card teaches a canonical action.",
          "if": {
            "properties": { "surface_kind": { "const": "onboarding_card" } },
            "required": ["surface_kind"]
          },
          "then": {
            "properties": {
              "authority_class": {
                "enum": ["command_id_anchored", "derived_with_upstream_anchors"]
              }
            }
          }
        },
        {
          "description": "glossary_card surfaces MUST declare authority_class = docs_anchor_anchored or derived_with_upstream_anchors (for paraphrased glossary cards).",
          "if": {
            "properties": { "surface_kind": { "const": "glossary_card" } },
            "required": ["surface_kind"]
          },
          "then": {
            "properties": {
              "authority_class": {
                "enum": ["docs_anchor_anchored", "derived_with_upstream_anchors"]
              }
            }
          }
        },
        {
          "description": "architecture_explainer surfaces MUST declare authority_class = symbol_reference_anchored or derived_with_upstream_anchors.",
          "if": {
            "properties": { "surface_kind": { "const": "architecture_explainer" } },
            "required": ["surface_kind"]
          },
          "then": {
            "properties": {
              "authority_class": {
                "enum": ["symbol_reference_anchored", "derived_with_upstream_anchors"]
              }
            }
          }
        },
        {
          "description": "learning_mode_profile_entry surfaces declare authority_class = aggregate_learning_mode_entry and pin aggregated_entry_refs.",
          "if": {
            "properties": { "surface_kind": { "const": "learning_mode_profile_entry" } },
            "required": ["surface_kind"]
          },
          "then": {
            "properties": {
              "authority_class": { "const": "aggregate_learning_mode_entry" }
            }
          }
        },
        {
          "description": "freshness_class = unverified_upstream forces active = false with a typed suppression cause.",
          "if": {
            "properties": { "freshness_class": { "const": "unverified_upstream" } },
            "required": ["freshness_class"]
          },
          "then": {
            "properties": {
              "active": { "const": false },
              "suppression_cause_class": {
                "enum": [
                  "imported_teaching_pack_unavailable",
                  "incompatible_build_drift",
                  "docs_pack_missing"
                ]
              }
            }
          }
        },
        {
          "description": "version_match_state_at_mint = incompatible_drift_detected forces active = false with suppression_cause_class = incompatible_build_drift.",
          "if": {
            "properties": { "version_match_state_at_mint": { "const": "incompatible_drift_detected" } },
            "required": ["version_match_state_at_mint"]
          },
          "then": {
            "properties": {
              "active": { "const": false },
              "suppression_cause_class": { "const": "incompatible_build_drift" }
            }
          }
        }
      ],
      "description": "One structured guided-surface record. See docs/ux/learnability_contract.md §1.1."
    },

    "guided_surface_rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "guided_surface_schema_version",
        "rule_id",
        "surface_kind",
        "citation_posture",
        "allowed_authority_classes",
        "allowed_dismissal_classes",
        "allowed_reset_classes",
        "allowed_progress_export_classes",
        "maximum_freshness_class",
        "requires_preserves_command_identity",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "guided_surface_rule_record" },
        "guided_surface_schema_version": { "$ref": "#/$defs/guided_surface_schema_version" },
        "rule_id": { "$ref": "#/$defs/opaque_id" },
        "surface_kind": { "$ref": "#/$defs/guided_surface_kind" },
        "citation_posture": { "$ref": "#/$defs/citation_posture" },
        "allowed_authority_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/guidance_authority_class" },
          "uniqueItems": true
        },
        "allowed_dismissal_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/dismissal_class" },
          "uniqueItems": true
        },
        "allowed_reset_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reset_class" },
          "uniqueItems": true
        },
        "allowed_progress_export_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/progress_export_class" },
          "uniqueItems": true
        },
        "allowed_teaching_adjunct_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/teaching_session_adjunct_class" },
          "uniqueItems": true
        },
        "maximum_freshness_class": { "$ref": "#/$defs/freshness_class" },
        "requires_preserves_command_identity": { "type": "boolean" },
        "denial_reasons_reserved": {
          "type": "array",
          "items": { "$ref": "#/$defs/denial_reason" },
          "uniqueItems": true
        },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "Speaker-note and teaching-session adjunct rules MUST require command-identity preservation and MUST name at least one teaching_session_adjunct_class.",
          "if": {
            "properties": {
              "surface_kind": {
                "enum": ["speaker_note_adjunct", "teaching_session_adjunct"]
              }
            },
            "required": ["surface_kind"]
          },
          "then": {
            "properties": {
              "requires_preserves_command_identity": { "const": true },
              "allowed_teaching_adjunct_classes": {
                "type": "array",
                "minItems": 1
              }
            },
            "required": ["allowed_teaching_adjunct_classes"]
          }
        },
        {
          "description": "required_primary_plus_upstream citation posture forces derived_with_upstream_anchors into allowed_authority_classes.",
          "if": {
            "properties": { "citation_posture": { "const": "required_primary_plus_upstream" } },
            "required": ["citation_posture"]
          },
          "then": {
            "properties": {
              "allowed_authority_classes": {
                "type": "array",
                "contains": { "const": "derived_with_upstream_anchors" }
              }
            }
          }
        }
      ],
      "description": "One guided-surface rule row per surface_kind. See §1.2."
    },

    "invariant_assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["invariant_id", "asserted_true"],
      "properties": {
        "invariant_id": {
          "type": "string",
          "enum": [
            "every_guided_surface_cites_command_or_docs_anchor",
            "derived_guided_surface_retains_upstream",
            "no_private_mutation_path_outside_command_registry",
            "stale_or_unverified_surface_suppresses_or_discloses",
            "portable_dismissal_never_leaks_account_or_policy_state",
            "policy_disabled_learning_surface_never_renders",
            "locale_fallback_is_disclosed",
            "exercise_steps_respect_workspace_trust",
            "imported_teaching_pack_is_verified_before_render",
            "presentation_adjunct_preserves_command_identity",
            "learning_mode_profile_exports_match_portability_lanes",
            "every_guided_surface_resolves_against_rule_record"
          ]
        },
        "asserted_true": { "type": "boolean", "const": true },
        "notes": { "$ref": "#/$defs/short_label_text" }
      }
    },

    "learning_mode_profile_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "guided_surface_schema_version",
        "profile_id",
        "profile_class",
        "active_surface_kinds",
        "disabled_surface_kinds",
        "allowed_progress_export_classes",
        "dismissal_scope_class",
        "deployment_profile_refs",
        "rule_refs",
        "invariants",
        "minted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "learning_mode_profile_record" },
        "guided_surface_schema_version": { "$ref": "#/$defs/guided_surface_schema_version" },
        "profile_id": { "$ref": "#/$defs/opaque_id" },
        "profile_class": { "$ref": "#/$defs/learning_mode_profile_class" },
        "active_surface_kinds": {
          "type": "array",
          "items": { "$ref": "#/$defs/guided_surface_kind" },
          "uniqueItems": true
        },
        "disabled_surface_kinds": {
          "type": "array",
          "items": { "$ref": "#/$defs/guided_surface_kind" },
          "uniqueItems": true
        },
        "allowed_progress_export_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/progress_export_class" },
          "uniqueItems": true
        },
        "dismissal_scope_class": { "$ref": "#/$defs/dismissal_class" },
        "deployment_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deployment_profile_id" },
          "uniqueItems": true
        },
        "rule_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true,
          "description": "Ids of every guided_surface_rule_record this profile binds."
        },
        "docs_pack_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "suppressed_causes": {
          "type": "array",
          "items": { "$ref": "#/$defs/suppression_cause_class" },
          "uniqueItems": true
        },
        "invariants": {
          "type": "array",
          "minItems": 12,
          "items": { "$ref": "#/$defs/invariant_assertion" },
          "uniqueItems": true,
          "description": "Every profile declares all twelve const-true invariants. See §7."
        },
        "presentation_label": { "$ref": "#/$defs/short_label_text" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "policy_disabled profiles forbid portable progress exports.",
          "if": {
            "properties": { "profile_class": { "const": "policy_disabled" } },
            "required": ["profile_class"]
          },
          "then": {
            "properties": {
              "allowed_progress_export_classes": {
                "type": "array",
                "items": {
                  "enum": ["blocked_by_policy", "in_support_bundle_redacted"]
                }
              }
            }
          }
        },
        {
          "description": "air_gapped_offline_pack and privacy_reduced_local_only profiles forbid portable profile export.",
          "if": {
            "properties": {
              "profile_class": {
                "enum": ["air_gapped_offline_pack", "privacy_reduced_local_only"]
              }
            },
            "required": ["profile_class"]
          },
          "then": {
            "properties": {
              "allowed_progress_export_classes": {
                "type": "array",
                "items": {
                  "enum": [
                    "not_exported_machine_local",
                    "in_support_bundle_redacted",
                    "blocked_by_policy"
                  ]
                }
              }
            }
          }
        }
      ],
      "description": "One learning-mode profile aggregator. See §1.3 and §7."
    }
  }
}
