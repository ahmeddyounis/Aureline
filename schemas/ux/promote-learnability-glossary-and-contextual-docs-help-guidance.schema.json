{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/promote-learnability-glossary-and-contextual-docs-help-guidance.schema.json",
  "title": "Aureline learnability-glossary disclosure record",
  "description": "Boundary schema for learnability_glossary_disclosure_record, the single governed record the switching row, docs/help browser, command palette, diagnostics, support exports, Help/About, and docs all read for one claimed-stable switching cohort. It is minted by crates/aureline-shell/src/learnability_glossary_stable and binds, for one canonical switching identity: (1) an opt-in, dismissible why-now card grounded in command/file/symbol truth; (2) glossary chips that each cite a stable command/file/symbol/docs anchor; (3) contextual docs/help reachable in place; (4) a posture that never forces a tutorial funnel before first useful work and preserves exact focus return; (5) guided tour/learning/teaching affordances that each carry their own Preview/Beta/Stable marker and support boundary rather than implying stable coverage by adjacency; (6) a learning-state privacy posture keeping dismissals, resume entries, and the learning digest user-owned and local-first; (7) a public claim ceiling no row may exceed; (8) a derived stable-claim verdict that narrows a row missing any pillar below Stable with a named reason; (9) recovery/route/accessibility parity across the switching row, docs/help browser, command palette, and a menu command in normal/high-contrast/zoomed layouts; and (10) availability without an account or managed services. Top-level refs are opaque aureline://<class>/<id> durable-object refs; docs/help node refs are repo-relative source paths.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "source_ecosystem",
    "source_ecosystem_label",
    "title",
    "summary",
    "why_now_card",
    "glossary_chips",
    "contextual_docs",
    "posture",
    "guided_affordances",
    "privacy",
    "claim_ceiling",
    "stable_qualification",
    "recovery_routes",
    "surfaces",
    "routes",
    "accessibility",
    "available_without_account",
    "available_without_managed_services",
    "honesty_marker_present",
    "upstream",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": { "type": "string", "const": "learnability_glossary_disclosure_record" },
    "schema_version": { "type": "integer", "const": 1 },
    "notice": { "$ref": "#/$defs/reviewable_sentence" },
    "shared_contract_ref": {
      "type": "string",
      "const": "shell:learnability_glossary_disclosure_stable:v1"
    },
    "record_id": { "$ref": "#/$defs/stable_token" },
    "as_of": { "$ref": "#/$defs/utc_date_time" },
    "source_ecosystem": { "$ref": "#/$defs/source_ecosystem" },
    "source_ecosystem_label": { "$ref": "#/$defs/non_empty_string" },
    "title": { "$ref": "#/$defs/reviewable_sentence" },
    "summary": { "$ref": "#/$defs/reviewable_sentence" },
    "why_now_card": { "$ref": "#/$defs/why_now_card" },
    "glossary_chips": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/glossary_chip" }
    },
    "contextual_docs": { "$ref": "#/$defs/contextual_docs" },
    "posture": { "$ref": "#/$defs/posture" },
    "guided_affordances": {
      "type": "array",
      "items": { "$ref": "#/$defs/guided_affordance" }
    },
    "privacy": { "$ref": "#/$defs/privacy_posture" },
    "claim_ceiling": { "$ref": "#/$defs/claim_ceiling" },
    "stable_qualification": { "$ref": "#/$defs/stable_qualification" },
    "recovery_routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/recovery_route" }
    },
    "surfaces": { "$ref": "#/$defs/surface_parity" },
    "routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/entry_route" }
    },
    "accessibility": { "$ref": "#/$defs/accessibility" },
    "available_without_account": { "type": "boolean", "const": true },
    "available_without_managed_services": { "type": "boolean", "const": true },
    "honesty_marker_present": { "type": "boolean" },
    "upstream": { "$ref": "#/$defs/upstream_refs" },
    "diagnostics_export_ref": { "$ref": "#/$defs/canonical_ref" },
    "support_export_ref": { "$ref": "#/$defs/canonical_ref" },
    "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/canonical_ref" } },
    "narrative_refs": { "type": "array", "items": { "$ref": "#/$defs/canonical_ref" } }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1, "maxLength": 200 },
    "reviewable_sentence": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "stable_token": { "type": "string", "minLength": 1, "maxLength": 200 },
    "source_path": { "type": "string", "minLength": 1, "maxLength": 300 },
    "utc_date_time": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "canonical_ref": {
      "type": "string",
      "description": "Opaque durable-object ref of the form aureline://<class>/<id>; <class> is not a generic landing page.",
      "pattern": "^aureline://(?!(home|dashboard|landing|index|overview|start|root)/)[^/]+/.+$",
      "maxLength": 200
    },
    "source_ecosystem": {
      "type": "string",
      "description": "Serde snake_case rendering of the incumbent ecosystem (note jet_brains_family).",
      "enum": ["vs_code_code_oss", "jet_brains_family", "vim_neovim", "emacs"]
    },
    "claim_class": {
      "type": "string",
      "enum": ["stable", "beta", "preview", "not_claimed"]
    },
    "lifecycle_marker": {
      "type": "string",
      "enum": ["preview", "beta", "stable"]
    },
    "narrowing_reason": {
      "type": "string",
      "enum": [
        "glossary_anchors_not_stable",
        "why_now_card_not_grounded_in_truth",
        "contextual_docs_uncited",
        "focus_return_not_preserved",
        "blocks_first_useful_work"
      ]
    },
    "guided_affordance_kind": {
      "type": "string",
      "enum": ["guided_tour", "learning_mode", "teaching_session", "presentation_mode"]
    },
    "recovery_action_role": {
      "type": "string",
      "enum": ["primary", "recovery", "secondary"]
    },
    "route_surface": {
      "type": "string",
      "enum": ["switching_row", "docs_help_browser", "command_palette", "menu_command"]
    },
    "layout_mode": {
      "type": "string",
      "enum": ["normal", "high_contrast", "zoomed"]
    },
    "learning_target": {
      "type": "object",
      "additionalProperties": false,
      "description": "Stable command/file/symbol/docs/graph/surface anchor; exactly the populated kind matches target_kind.",
      "required": ["target_kind"],
      "properties": {
        "target_kind": {
          "type": "string",
          "enum": [
            "command_id",
            "file_object_id",
            "symbol_object_id",
            "docs_node_id",
            "graph_node_id",
            "surface_object_id"
          ]
        },
        "command_id": { "type": ["string", "null"] },
        "file_object_id": { "type": ["string", "null"] },
        "symbol_object_id": { "type": ["string", "null"] },
        "docs_node_id": { "type": ["string", "null"] },
        "graph_node_id": { "type": ["string", "null"] },
        "surface_object_id": { "type": ["string", "null"] }
      }
    },
    "why_now_card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_id",
        "headline",
        "body",
        "cited_target",
        "dismissible",
        "blocks_first_useful_work"
      ],
      "properties": {
        "card_id": { "$ref": "#/$defs/stable_token" },
        "headline": { "$ref": "#/$defs/reviewable_sentence" },
        "body": { "$ref": "#/$defs/reviewable_sentence" },
        "cited_target": { "$ref": "#/$defs/learning_target" },
        "dismissible": { "type": "boolean" },
        "blocks_first_useful_work": { "type": "boolean" }
      }
    },
    "glossary_chip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chip_id",
        "incumbent_term",
        "aureline_term",
        "explanation",
        "anchor",
        "docs_help_ref"
      ],
      "properties": {
        "chip_id": { "$ref": "#/$defs/stable_token" },
        "incumbent_term": { "$ref": "#/$defs/non_empty_string" },
        "aureline_term": { "$ref": "#/$defs/non_empty_string" },
        "explanation": { "$ref": "#/$defs/reviewable_sentence" },
        "anchor": { "$ref": "#/$defs/learning_target" },
        "docs_help_ref": { "$ref": "#/$defs/source_path" }
      }
    },
    "contextual_docs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["docs_browser_ref", "help_node_refs", "opens_in_place"],
      "properties": {
        "docs_browser_ref": { "$ref": "#/$defs/canonical_ref" },
        "help_node_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_path" }
        },
        "opens_in_place": { "type": "boolean" }
      }
    },
    "posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opt_in",
        "blocks_first_useful_work",
        "preserves_exact_focus_return",
        "focus_return_anchor_ref"
      ],
      "properties": {
        "opt_in": { "type": "boolean" },
        "blocks_first_useful_work": { "type": "boolean" },
        "preserves_exact_focus_return": { "type": "boolean" },
        "focus_return_anchor_ref": { "$ref": "#/$defs/canonical_ref" }
      }
    },
    "guided_affordance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "affordance_id",
        "affordance_kind",
        "lifecycle_marker",
        "support_boundary",
        "marker_visible_in_product",
        "marker_visible_in_docs_help",
        "marker_visible_in_support_export"
      ],
      "properties": {
        "affordance_id": { "$ref": "#/$defs/stable_token" },
        "affordance_kind": { "$ref": "#/$defs/guided_affordance_kind" },
        "lifecycle_marker": { "$ref": "#/$defs/lifecycle_marker" },
        "support_boundary": { "$ref": "#/$defs/reviewable_sentence" },
        "marker_visible_in_product": { "type": "boolean", "const": true },
        "marker_visible_in_docs_help": { "type": "boolean", "const": true },
        "marker_visible_in_support_export": { "type": "boolean", "const": true }
      }
    },
    "privacy_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_store_ref",
        "dismissals_user_owned",
        "resume_entries_user_owned",
        "learning_digest_user_owned",
        "repo_visible",
        "telemetry_grade"
      ],
      "properties": {
        "state_store_ref": { "$ref": "#/$defs/canonical_ref" },
        "dismissals_user_owned": { "type": "boolean", "const": true },
        "resume_entries_user_owned": { "type": "boolean", "const": true },
        "learning_digest_user_owned": { "type": "boolean", "const": true },
        "repo_visible": { "type": "boolean", "const": false },
        "telemetry_grade": { "type": "boolean", "const": false }
      }
    },
    "claim_ceiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asserts_glossary_anchors_stable",
        "asserts_why_now_grounded",
        "asserts_contextual_docs_cited",
        "asserts_focus_return_preserved",
        "asserts_non_blocking"
      ],
      "properties": {
        "asserts_glossary_anchors_stable": { "type": "boolean" },
        "asserts_why_now_grounded": { "type": "boolean" },
        "asserts_contextual_docs_cited": { "type": "boolean" },
        "asserts_focus_return_preserved": { "type": "boolean" },
        "asserts_non_blocking": { "type": "boolean" }
      }
    },
    "stable_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_class", "qualifies_stable", "narrowing_reasons"],
      "properties": {
        "claim_class": { "$ref": "#/$defs/claim_class" },
        "qualifies_stable": { "type": "boolean" },
        "narrowing_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/narrowing_reason" }
        }
      }
    },
    "recovery_route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_label", "action_role", "keyboard_reachable"],
      "properties": {
        "action_id": { "$ref": "#/$defs/stable_token" },
        "action_label": { "$ref": "#/$defs/non_empty_string" },
        "action_role": { "$ref": "#/$defs/recovery_action_role" },
        "keyboard_reachable": { "type": "boolean", "const": true }
      }
    },
    "surface_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "switching_row_id",
        "docs_help_row_id",
        "command_palette_command_id",
        "recovery_action_ids",
        "reopen_surfaces",
        "parity_holds"
      ],
      "properties": {
        "switching_row_id": { "$ref": "#/$defs/non_empty_string" },
        "docs_help_row_id": { "$ref": "#/$defs/non_empty_string" },
        "command_palette_command_id": { "$ref": "#/$defs/non_empty_string" },
        "recovery_action_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_token" }
        },
        "reopen_surfaces": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3
        },
        "parity_holds": { "type": "boolean", "const": true }
      }
    },
    "entry_route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "route_ref", "keyboard_reachable", "activates_same_row"],
      "properties": {
        "surface": { "$ref": "#/$defs/route_surface" },
        "route_ref": { "$ref": "#/$defs/canonical_ref" },
        "keyboard_reachable": { "type": "boolean", "const": true },
        "activates_same_row": { "type": "boolean", "const": true }
      }
    },
    "layout_mode_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "row_narration_available", "recovery_affordances_reachable"],
      "properties": {
        "mode": { "$ref": "#/$defs/layout_mode" },
        "row_narration_available": { "type": "boolean", "const": true },
        "recovery_affordances_reachable": { "type": "boolean", "const": true }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_order_index",
        "tab_stop_count",
        "row_narration",
        "action_labels",
        "layout_modes"
      ],
      "properties": {
        "focus_order_index": { "type": "integer", "minimum": 0 },
        "tab_stop_count": { "type": "integer", "minimum": 1 },
        "row_narration": { "$ref": "#/$defs/reviewable_sentence" },
        "action_labels": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        },
        "layout_modes": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/layout_mode_disclosure" }
        }
      }
    },
    "upstream_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "migration_scoreboard_ref",
        "corpus_section_ref",
        "learning_manifest_ref",
        "learning_surface_projection_ref"
      ],
      "properties": {
        "migration_scoreboard_ref": { "$ref": "#/$defs/non_empty_string" },
        "corpus_section_ref": { "$ref": "#/$defs/non_empty_string" },
        "learning_manifest_ref": { "$ref": "#/$defs/non_empty_string" },
        "learning_surface_projection_ref": { "$ref": "#/$defs/non_empty_string" }
      }
    }
  }
}
