{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/batch_action_review.schema.json",
  "title": "Aureline UX batch-action review boundary vocabulary",
  "description": "UX-side boundary schema for the batch_action_review_record every dense collection surface (search, problems / diagnostics, review queues, pipeline logs, package inventories, work-item lists, admin grids) emits before a destructive, remote, provider-owned, export, or share batch action. Each record pairs to the surface's live selection_state_record (schemas/ux/selection_state.schema.json), the durable batch_review_packet_record (schemas/collections/batch_review_packet.schema.json), and (when the action commits) exactly one interaction_safety_packet_record (schemas/ux/interaction_safety.schema.json). The record carries the action class, review requirement class, included / excluded / blocked / hidden-selected / not-loaded / server-side count summaries, the per-reason blocked breakdown, recovery class, focus-return target, and cancel route. Raw row text, raw query bodies, raw provider URLs, raw absolute paths, raw secret-bearing literals, raw prompt text, and raw clipboard bytes MUST NOT appear on any record emitted against this schema; records carry opaque ids, typed vocabulary, redaction-aware reviewable labels (<= 1024 graphemes), and count truth only. Adding a new action class, review requirement class, blocked reason, unavailable reason, recovery class, count term, count status, denial reason, or audit-event id is additive-minor and bumps batch_action_review_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/batch_action_review_record" },
    { "$ref": "#/$defs/batch_action_review_audit_event_record" }
  ],
  "$defs": {
    "batch_action_review_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version. Current value is 1."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "batch_action_review_record",
        "batch_action_review_audit_event_record"
      ]
    },
    "instance_schema_hint": {
      "type": "string",
      "format": "uri-reference"
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": { "type": "object", "additionalProperties": true },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests, journal entries, support bundles, claim manifests, and portability exports."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Redaction-aware reviewable label. Carries presentation summary copy; never carries raw row bodies, raw query text, raw URLs, or raw absolute paths."
    },
    "running_build_identity_ref": {
      "type": "string",
      "minLength": 1
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "client_scope": {
      "type": "string",
      "enum": [
        "desktop_product",
        "cli",
        "companion_surface",
        "remote_agent",
        "sdk_or_api",
        "managed_admin_surface"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "authoritative_live",
        "warm_cached",
        "degraded_cached",
        "stale",
        "unverified"
      ]
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted"]
        },
        "execution_context_id": { "type": "string", "minLength": 1 }
      }
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "search_collection",
        "problems_or_diagnostics_collection",
        "review_collection",
        "log_or_event_collection",
        "package_or_inventory_grid",
        "work_item_collection",
        "admin_or_settings_grid"
      ]
    },
    "selection_scope_class": {
      "type": "string",
      "enum": [
        "current_item_only",
        "visible_range",
        "loaded_set",
        "all_matching_query",
        "explicit_custom_set"
      ]
    },
    "batch_action_class": {
      "type": "string",
      "enum": [
        "routine_non_mutating",
        "local_reversible",
        "remote_mutation",
        "destructive_mutation",
        "export_or_share",
        "provider_owned_mutation"
      ],
      "description": "Closed batch-action class vocabulary."
    },
    "review_requirement_class": {
      "type": "string",
      "enum": [
        "no_review_required",
        "inline_preview_required",
        "review_sheet_required"
      ]
    },
    "review_state": {
      "type": "string",
      "enum": [
        "preview_only",
        "review_sheet_open",
        "review_sheet_accepted",
        "review_sheet_cancelled",
        "review_sheet_basis_drifted_re_review_required"
      ]
    },
    "execution_origin_class": {
      "type": "string",
      "enum": [
        "client_local_execution",
        "provider_authoritative_execution",
        "mixed_client_then_provider"
      ]
    },
    "scope_truth_class": {
      "type": "string",
      "enum": [
        "client_local_truth",
        "provider_authoritative_truth",
        "mixed_truth_resolved_by_provider"
      ]
    },
    "blocked_reason_class": {
      "type": "string",
      "enum": [
        "blocked_by_policy",
        "blocked_by_ownership",
        "blocked_by_protected_path",
        "blocked_by_provider_unsupported",
        "blocked_by_freshness_required",
        "blocked_by_grant_missing",
        "blocked_by_concurrent_edit"
      ]
    },
    "unavailable_reason_class": {
      "type": "string",
      "enum": [
        "unavailable_provider_offline",
        "unavailable_filter_unsupported_by_provider",
        "unavailable_column_redacted",
        "unavailable_authority_class_lower_than_required"
      ]
    },
    "recovery_guidance_class": {
      "type": "string",
      "enum": [
        "inline_undo_revert_available",
        "compensating_action_only",
        "regenerate_from_source",
        "evidence_only_no_rerun",
        "restore_from_checkpoint",
        "no_recovery_available"
      ]
    },
    "collection_count_term": {
      "type": "string",
      "enum": [
        "visible",
        "loaded",
        "matching",
        "selected",
        "included",
        "excluded",
        "blocked",
        "unavailable",
        "skipped",
        "hidden_selected",
        "not_loaded",
        "server_side"
      ]
    },
    "collection_count_status": {
      "type": "string",
      "enum": [
        "exact",
        "approximate",
        "provider_limited",
        "stale",
        "cached",
        "partial",
        "unknown"
      ]
    },
    "collection_count_value": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["term", "status", "value"],
          "properties": {
            "term": { "$ref": "#/$defs/collection_count_term" },
            "status": {
              "type": "string",
              "enum": [
                "exact",
                "approximate",
                "provider_limited",
                "stale",
                "cached",
                "partial"
              ]
            },
            "value": { "type": "integer", "minimum": 0 },
            "tolerance_label": { "$ref": "#/$defs/reviewable_label" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["term", "status"],
          "properties": {
            "term": { "$ref": "#/$defs/collection_count_term" },
            "status": { "const": "unknown" },
            "value": { "type": "null" },
            "tolerance_label": { "$ref": "#/$defs/reviewable_label" }
          }
        }
      ]
    },
    "blocked_summary_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason_class", "count"],
      "properties": {
        "reason_class": { "$ref": "#/$defs/blocked_reason_class" },
        "count": { "type": "integer", "minimum": 0 },
        "count_status": { "$ref": "#/$defs/collection_count_status" },
        "item_id_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "unavailable_summary_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason_class", "count"],
      "properties": {
        "reason_class": { "$ref": "#/$defs/unavailable_reason_class" },
        "count": { "type": "integer", "minimum": 0 },
        "count_status": { "$ref": "#/$defs/collection_count_status" },
        "item_id_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "summary_label": { "$ref": "#/$defs/reviewable_label" }
      }
    },
    "server_side_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_authoritative_basis_label",
        "server_side_count"
      ],
      "properties": {
        "provider_authoritative_basis_label": { "$ref": "#/$defs/reviewable_label" },
        "server_side_count": { "$ref": "#/$defs/collection_count_value" },
        "provider_filter_ast_id_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "provider_authority_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      },
      "description": "Required block when execution_origin_class is provider_authoritative_execution or mixed_client_then_provider. server_side_count.term MUST be server_side."
    },
    "batch_action_review_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "batch_action_review_schema_version",
        "batch_action_review_id",
        "surface_family",
        "selection_state_record_ref",
        "paired_collection_batch_review_packet_record_ref",
        "selection_scope_class",
        "action_class",
        "review_requirement_class",
        "review_state",
        "execution_origin_class",
        "scope_truth_class",
        "included_item_id_refs",
        "excluded_item_id_refs",
        "count_truth",
        "blocked_summary",
        "unavailable_summary",
        "recovery_guidance_class",
        "focus_target_id_ref",
        "cancel_action_id_ref",
        "running_build_identity_ref",
        "policy_context",
        "client_scopes",
        "redaction_class",
        "freshness_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "$ref": "#/$defs/instance_schema_hint" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "batch_action_review_record" },
        "batch_action_review_schema_version": { "$ref": "#/$defs/batch_action_review_schema_version" },
        "batch_action_review_id": { "$ref": "#/$defs/opaque_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "selection_state_record_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque ref to the schemas/ux/selection_state.schema.json record this review pairs to."
        },
        "paired_collection_batch_review_packet_record_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque ref to the durable schemas/collections/batch_review_packet.schema.json record. Required so the durable boundary owns identity, included id refs, and apply-time drift labelling."
        },
        "paired_interaction_safety_packet_record_ref": {
          "$ref": "#/$defs/nullable_opaque_id",
          "description": "Opaque ref to the schemas/ux/interaction_safety.schema.json packet the apply commits against. Required (non-null) for review_sheet_required actions at commit."
        },
        "selection_scope_class": { "$ref": "#/$defs/selection_scope_class" },
        "action_class": { "$ref": "#/$defs/batch_action_class" },
        "review_requirement_class": { "$ref": "#/$defs/review_requirement_class" },
        "review_state": { "$ref": "#/$defs/review_state" },
        "execution_origin_class": { "$ref": "#/$defs/execution_origin_class" },
        "scope_truth_class": { "$ref": "#/$defs/scope_truth_class" },
        "included_item_id_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "excluded_item_id_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "hidden_selected_item_id_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "not_loaded_item_id_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "count_truth": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/collection_count_value" },
          "description": "Per-term count truth. MUST contain visible, loaded, selected, included, and excluded terms. all_matching_query also requires matching. Provider-authoritative or mixed execution also requires server_side."
        },
        "blocked_summary": {
          "type": "array",
          "items": { "$ref": "#/$defs/blocked_summary_entry" },
          "description": "Per-reason blocked summary. Empty when no blocked rows exist."
        },
        "unavailable_summary": {
          "type": "array",
          "items": { "$ref": "#/$defs/unavailable_summary_entry" }
        },
        "server_side_scope": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/server_side_scope" }
          ]
        },
        "recovery_guidance_class": { "$ref": "#/$defs/recovery_guidance_class" },
        "focus_target_id_ref": { "$ref": "#/$defs/opaque_id" },
        "cancel_action_id_ref": { "$ref": "#/$defs/opaque_id" },
        "review_summary_label": { "$ref": "#/$defs/reviewable_label" },
        "summary_label": { "$ref": "#/$defs/reviewable_label" },
        "running_build_identity_ref": { "$ref": "#/$defs/running_build_identity_ref" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "client_scopes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/client_scope" }
        },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "remote_mutation, destructive_mutation, export_or_share, and provider_owned_mutation MUST require a review sheet.",
          "if": {
            "properties": {
              "action_class": {
                "enum": [
                  "remote_mutation",
                  "destructive_mutation",
                  "export_or_share",
                  "provider_owned_mutation"
                ]
              }
            },
            "required": ["action_class"]
          },
          "then": {
            "properties": {
              "review_requirement_class": { "const": "review_sheet_required" }
            }
          }
        },
        {
          "description": "routine_non_mutating MUST NOT require a review sheet.",
          "if": {
            "properties": { "action_class": { "const": "routine_non_mutating" } },
            "required": ["action_class"]
          },
          "then": {
            "properties": {
              "review_requirement_class": { "const": "no_review_required" }
            }
          }
        },
        {
          "description": "count_truth MUST contain visible, loaded, selected, included, and excluded terms.",
          "properties": {
            "count_truth": {
              "type": "array",
              "allOf": [
                { "contains": { "type": "object", "properties": { "term": { "const": "visible" } }, "required": ["term"] } },
                { "contains": { "type": "object", "properties": { "term": { "const": "loaded" } }, "required": ["term"] } },
                { "contains": { "type": "object", "properties": { "term": { "const": "selected" } }, "required": ["term"] } },
                { "contains": { "type": "object", "properties": { "term": { "const": "included" } }, "required": ["term"] } },
                { "contains": { "type": "object", "properties": { "term": { "const": "excluded" } }, "required": ["term"] } }
              ]
            }
          }
        },
        {
          "description": "all_matching_query selection scope MUST emit a matching count term.",
          "if": {
            "properties": { "selection_scope_class": { "const": "all_matching_query" } },
            "required": ["selection_scope_class"]
          },
          "then": {
            "properties": {
              "count_truth": {
                "type": "array",
                "contains": {
                  "type": "object",
                  "properties": { "term": { "const": "matching" } },
                  "required": ["term"]
                }
              }
            }
          }
        },
        {
          "description": "provider_authoritative_execution and mixed_client_then_provider MUST carry server_side_scope and a server_side count term.",
          "if": {
            "properties": {
              "execution_origin_class": {
                "enum": [
                  "provider_authoritative_execution",
                  "mixed_client_then_provider"
                ]
              }
            },
            "required": ["execution_origin_class"]
          },
          "then": {
            "required": ["server_side_scope"],
            "properties": {
              "server_side_scope": { "type": "object" },
              "count_truth": {
                "type": "array",
                "contains": {
                  "type": "object",
                  "properties": { "term": { "const": "server_side" } },
                  "required": ["term"]
                }
              }
            }
          }
        },
        {
          "description": "client_local_execution MUST NOT carry server_side_scope.",
          "if": {
            "properties": { "execution_origin_class": { "const": "client_local_execution" } },
            "required": ["execution_origin_class"]
          },
          "then": {
            "properties": {
              "server_side_scope": { "type": "null" }
            }
          }
        },
        {
          "description": "review_sheet_required actions MUST pin a paired_interaction_safety_packet_record_ref when review_state is review_sheet_accepted.",
          "if": {
            "properties": {
              "review_requirement_class": { "const": "review_sheet_required" },
              "review_state": { "const": "review_sheet_accepted" }
            },
            "required": ["review_requirement_class", "review_state"]
          },
          "then": {
            "properties": {
              "paired_interaction_safety_packet_record_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        },
        {
          "description": "no_recovery_available recovery class MUST pair to an interaction-safety packet ref so reviewers can audit the irreversible_high_blast posture.",
          "if": {
            "properties": { "recovery_guidance_class": { "const": "no_recovery_available" } },
            "required": ["recovery_guidance_class"]
          },
          "then": {
            "properties": {
              "paired_interaction_safety_packet_record_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        }
      ],
      "description": "Durable batch-action review record. Raw row text, raw query bodies, raw URLs, and raw absolute paths never appear here."
    },
    "batch_action_review_audit_event_id": {
      "type": "string",
      "enum": [
        "batch_action_review_minted",
        "batch_action_review_sheet_opened",
        "batch_action_review_sheet_accepted",
        "batch_action_review_sheet_cancelled",
        "batch_action_review_basis_drifted",
        "batch_action_review_audit_denial_emitted",
        "batch_action_review_schema_version_bumped"
      ]
    },
    "batch_action_review_denial_reason": {
      "type": "string",
      "enum": [
        "batch_action_review_unknown",
        "review_sheet_required_for_action_class",
        "selection_scope_widened_without_review",
        "batch_count_term_collapsed",
        "count_status_missing",
        "blocked_reason_unlabelled",
        "unavailable_reason_unlabelled",
        "recovery_guidance_missing",
        "server_side_count_missing_for_remote_action",
        "scope_truth_class_unlabelled",
        "execution_origin_class_unlabelled",
        "raw_body_forbidden_on_boundary",
        "raw_url_forbidden_on_boundary",
        "batch_action_review_schema_version_lagging",
        "policy_epoch_expired",
        "policy_blocked"
      ]
    },
    "batch_action_review_audit_event_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "batch_action_review_schema_version",
        "audit_event_id",
        "audit_event_class",
        "batch_action_review_id_ref",
        "running_build_identity_ref",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "$schema": { "$ref": "#/$defs/instance_schema_hint" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "batch_action_review_audit_event_record" },
        "batch_action_review_schema_version": { "$ref": "#/$defs/batch_action_review_schema_version" },
        "audit_event_id": { "$ref": "#/$defs/opaque_id" },
        "audit_event_class": { "$ref": "#/$defs/batch_action_review_audit_event_id" },
        "batch_action_review_id_ref": { "$ref": "#/$defs/opaque_id" },
        "denial_reason": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/batch_action_review_denial_reason" }
          ]
        },
        "summary_label": { "$ref": "#/$defs/reviewable_label" },
        "running_build_identity_ref": { "$ref": "#/$defs/running_build_identity_ref" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      }
    }
  }
}
