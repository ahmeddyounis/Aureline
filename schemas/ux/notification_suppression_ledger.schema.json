{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/notification_suppression_ledger.schema.json",
  "title": "Aureline notification suppression-history ledger: delayed, coalesced, muted, and withheld deliveries",
  "description": "Boundary schema for the notification_suppression_ledger_entry_record and notification_suppression_ledger_manifest_record frozen in docs/ux/notification_action_grammar.md. The suppression ledger records why a notification delivery was delayed, coalesced (deduped), muted, or withheld on a given surface without implying that the underlying canonical event or durable object identity disappeared. The ledger is explicitly separate from chronology/audit history: it captures delivery-suppression truth (quiet-hours hold, focus/presentation/privacy holds, admin suppression, dedupe collapse, user mute/snooze) while the audit trail and history rows record object mutations and consequential actions. Records compose with schemas/ux/event_lineage.schema.json and schemas/ux/notification_suppression_record.schema.json without re-minting canonical_event_id, suppression_reason, delivery_surface_class, or durable linkback vocabulary. Raw bodies, raw paths, raw URLs, raw provider payloads, raw prompt/completion text, raw command bodies, secret material, and customer-owned identifiers never cross this boundary; the schema carries opaque ids, typed vocabulary, and short privacy-safe labels only. Adding a new suppression_disposition_class, invariant_id, or denial_reason is additive-minor and bumps notification_suppression_ledger_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/notification_suppression_ledger_entry_record" },
    { "$ref": "#/$defs/notification_suppression_ledger_manifest_record" }
  ],
  "$defs": {
    "notification_suppression_ledger_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this notification suppression-ledger vocabulary export. Current value is 1. Bumped only on breaking payload changes; additive-optional fields do not bump this version."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "notification_suppression_ledger_entry_record",
        "notification_suppression_ledger_manifest_record"
      ],
      "description": "Discriminator for the concrete payload shape. Every record carries exactly one kind."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque stable id safe for RPC, manifests, journals, support bundles, OS notification payloads, lock-screen summaries, and companion push payloads."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced from a monotonic clock source."
    },
    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Short privacy-safe label text. Must not contain raw paths, raw URLs, raw provider payloads, raw secret material, raw customer-owned identifiers, or raw prompt/completion text."
    },
    "instance_schema_hint": {
      "type": "string",
      "format": "uri-reference",
      "description": "Optional schema hint carried on worked fixtures."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": { "type": "object", "additionalProperties": true },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "source_subsystem": {
      "type": "string",
      "enum": [
        "editor",
        "terminal",
        "review_and_diff",
        "palette_and_search",
        "install_update_attach",
        "ai_apply",
        "collaboration",
        "provider_bearing",
        "docs_help_service_health",
        "support_export",
        "build_system",
        "test_runner",
        "debug_session",
        "task_runner",
        "indexer",
        "vfs_save",
        "sync_mirror",
        "notebook_kernel",
        "remote_agent",
        "extension_host",
        "workspace_trust",
        "policy_resolver",
        "admin_policy",
        "secret_broker",
        "runtime_power_manager",
        "shell"
      ],
      "description": "Re-exported from schemas/ux/activity_event_envelope.schema.json without modification."
    },
    "client_scope": {
      "type": "string",
      "enum": [
        "desktop_product",
        "cli",
        "companion_surface",
        "remote_agent",
        "sdk_or_api",
        "managed_admin_surface"
      ]
    },
    "delivery_surface_class": {
      "type": "string",
      "enum": [
        "toast",
        "contextual_banner",
        "status_item",
        "durable_job_row",
        "attention_item",
        "activity_center_digest_card",
        "digest_group_row",
        "os_notification",
        "os_badge_app_icon",
        "lock_screen_summary",
        "companion_push",
        "not_delivered_held"
      ],
      "description": "Re-exported from schemas/ux/activity_event_envelope.schema.json without modification."
    },
    "quiet_hours_mode": {
      "type": "string",
      "enum": [
        "mode_none",
        "mode_quiet_hours_user",
        "mode_do_not_disturb_user",
        "mode_focus_mode_user",
        "mode_presentation",
        "mode_screen_share",
        "mode_privacy_mode",
        "mode_reduced_attention_policy",
        "mode_power_saver_runtime",
        "mode_admin_suppression"
      ]
    },
    "suppression_reason": {
      "type": "string",
      "enum": [
        "quiet_hours_user_policy",
        "do_not_disturb_user_policy",
        "focus_mode_user_policy",
        "presentation_mode_active",
        "screen_share_active",
        "privacy_mode_active",
        "admin_policy_suppression",
        "reduced_attention_posture",
        "power_saver_background_pause",
        "dedupe_same_canonical_event",
        "dedupe_same_grouped_burst",
        "class_muted_by_user",
        "class_snoozed_by_user",
        "release_pending_next_unsuppressed_surface"
      ],
      "description": "Re-exported from schemas/ux/notification_event.schema.json without modification."
    },
    "badge_class": {
      "type": "string",
      "enum": [
        "needs_review",
        "failed_runs",
        "mentions",
        "security_notices",
        "session_requests",
        "offline_publish_pending",
        "durable_running_count",
        "held_or_suppressed_count",
        "completion_unread"
      ]
    },
    "delay_until_condition_class": {
      "type": "string",
      "enum": [
        "next_unsuppressed_surface",
        "mode_exit",
        "user_explicit_show_held",
        "lock_screen_unlock",
        "policy_epoch_advance",
        "trust_state_restored",
        "no_delay_collapsed_or_denied"
      ],
      "description": "Names when a delayed delivery may resume. Re-exported from schemas/ux/notification_suppression_record.schema.json."
    },
    "linkback_target_kind": {
      "type": "string",
      "enum": [
        "durable_job_row_exact",
        "attention_item_exact",
        "activity_center_item",
        "history_lane_row",
        "evidence_packet_row",
        "review_sheet",
        "diff_view",
        "canonical_object_target_exact",
        "export_preview_row",
        "audit_trail_only"
      ],
      "description": "Re-exported from schemas/ux/event_lineage.schema.json without modification."
    },
    "preserved_durable_linkback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "target_identity_ref",
        "announcement_label",
        "preserves_canonical_event_id",
        "suppression_is_not_deletion"
      ],
      "properties": {
        "kind": { "$ref": "#/$defs/linkback_target_kind" },
        "target_identity_ref": { "$ref": "#/$defs/opaque_id" },
        "announcement_label": { "$ref": "#/$defs/short_label_text" },
        "preserves_canonical_event_id": { "type": "boolean", "const": true },
        "suppression_is_not_deletion": {
          "type": "boolean",
          "const": true,
          "description": "Const-true marker: this ledger records delivery suppression and never implies that the canonical event or durable object identity was deleted."
        }
      }
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted"]
        },
        "execution_context_id": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "suppression_disposition_class": {
      "type": "string",
      "enum": [
        "delayed",
        "coalesced",
        "muted",
        "withheld",
        "released"
      ],
      "description": "High-level suppression disposition for this ledger entry. delayed holds delivery until a later condition; coalesced merges a delivery into an existing canonical object or grouped burst; muted suppresses delivery by user choice; withheld denies a surface delivery while preserving a durable/audit linkback; released records that a previously delayed/muted/withheld item became eligible for delivery."
    },
    "denial_reason": {
      "type": "string",
      "enum": [
        "suppression_ledger_missing_linkback",
        "suppression_ledger_implied_deletion",
        "suppression_ledger_schema_version_lagging"
      ],
      "description": "Closed denial-reason vocabulary for suppression-ledger conformance failures."
    },
    "invariant_assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["invariant_id", "asserted_true"],
      "properties": {
        "invariant_id": {
          "type": "string",
          "enum": [
            "suppression_is_not_deletion",
            "canonical_event_id_preserved_under_suppression",
            "durable_linkback_preserved_under_suppression",
            "coalesced_deliveries_do_not_mint_surface_local_duplicates",
            "suppression_history_separate_from_audit_history",
            "reopen_from_summary_surfaces_forbids_shortcut_replay"
          ]
        },
        "asserted_true": { "type": "boolean", "const": true }
      }
    },
    "notification_suppression_ledger_entry_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "notification_suppression_ledger_schema_version",
        "ledger_entry_id",
        "canonical_event_id",
        "event_lineage_id_ref",
        "canonical_object_target_ref",
        "source_subsystem",
        "intended_delivery_surface_class",
        "client_scope",
        "suppression_disposition_class",
        "suppression_reasons",
        "active_quiet_hours_modes_at_decision",
        "delay_until_condition_class",
        "coalesced_into_grouped_burst_id_ref",
        "coalesced_into_canonical_event_id_ref",
        "snooze_resume_condition_label",
        "muted_class_ref",
        "preserved_durable_linkback",
        "decision_summary_label",
        "policy_context",
        "decided_at"
      ],
      "properties": {
        "$schema": { "$ref": "#/$defs/instance_schema_hint" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "notification_suppression_ledger_entry_record" },
        "notification_suppression_ledger_schema_version": { "$ref": "#/$defs/notification_suppression_ledger_schema_version" },
        "ledger_entry_id": { "$ref": "#/$defs/opaque_id" },
        "canonical_event_id": { "$ref": "#/$defs/opaque_id" },
        "event_lineage_id_ref": { "$ref": "#/$defs/opaque_id" },
        "canonical_object_target_ref": { "$ref": "#/$defs/opaque_id" },
        "source_subsystem": { "$ref": "#/$defs/source_subsystem" },
        "intended_delivery_surface_class": { "$ref": "#/$defs/delivery_surface_class" },
        "client_scope": { "$ref": "#/$defs/client_scope" },
        "suppression_disposition_class": { "$ref": "#/$defs/suppression_disposition_class" },
        "suppression_reasons": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/suppression_reason" }
        },
        "active_quiet_hours_modes_at_decision": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/quiet_hours_mode" }
        },
        "delay_until_condition_class": { "$ref": "#/$defs/delay_until_condition_class" },
        "coalesced_into_grouped_burst_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Non-null only when suppression_disposition_class = coalesced and the delivery merged into a grouped burst."
        },
        "coalesced_into_canonical_event_id_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Non-null only when suppression_disposition_class = coalesced and the delivery merged into an existing canonical event."
        },
        "snooze_resume_condition_label": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/short_label_text" }
          ],
          "description": "Non-null only when suppression_disposition_class = delayed and suppression_reasons includes class_snoozed_by_user."
        },
        "muted_class_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/badge_class" }
          ],
          "description": "Non-null only when suppression_disposition_class = muted."
        },
        "preserved_durable_linkback": { "$ref": "#/$defs/preserved_durable_linkback" },
        "decision_summary_label": { "$ref": "#/$defs/short_label_text" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "decided_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "suppression_disposition_class = coalesced requires at least one non-null coalesced-into ref.",
          "if": {
            "properties": { "suppression_disposition_class": { "const": "coalesced" } },
            "required": ["suppression_disposition_class"]
          },
          "then": {
            "anyOf": [
              {
                "properties": {
                  "coalesced_into_grouped_burst_id_ref": { "$ref": "#/$defs/opaque_id" }
                }
              },
              {
                "properties": {
                  "coalesced_into_canonical_event_id_ref": { "$ref": "#/$defs/opaque_id" }
                }
              }
            ]
          }
        },
        {
          "description": "suppression_disposition_class != coalesced should leave coalesced-into refs null.",
          "if": {
            "properties": {
              "suppression_disposition_class": {
                "enum": ["delayed", "muted", "withheld", "released"]
              }
            },
            "required": ["suppression_disposition_class"]
          },
          "then": {
            "properties": {
              "coalesced_into_grouped_burst_id_ref": { "type": "null" },
              "coalesced_into_canonical_event_id_ref": { "type": "null" }
            }
          }
        }
        ,
        {
          "description": "suppression_disposition_class = muted MUST carry a non-null muted_class_ref.",
          "if": {
            "properties": { "suppression_disposition_class": { "const": "muted" } },
            "required": ["suppression_disposition_class"]
          },
          "then": {
            "properties": { "muted_class_ref": { "$ref": "#/$defs/badge_class" } }
          }
        },
        {
          "description": "suppression_disposition_class != muted should leave muted_class_ref null.",
          "if": {
            "properties": {
              "suppression_disposition_class": {
                "enum": ["delayed", "coalesced", "withheld", "released"]
              }
            },
            "required": ["suppression_disposition_class"]
          },
          "then": {
            "properties": { "muted_class_ref": { "type": "null" } }
          }
        },
        {
          "description": "class_muted_by_user implies suppression_disposition_class = muted and requires muted_class_ref.",
          "if": {
            "properties": {
              "suppression_reasons": {
                "contains": { "const": "class_muted_by_user" }
              }
            },
            "required": ["suppression_reasons"]
          },
          "then": {
            "properties": {
              "suppression_disposition_class": { "const": "muted" },
              "muted_class_ref": { "$ref": "#/$defs/badge_class" }
            }
          }
        },
        {
          "description": "class_snoozed_by_user implies suppression_disposition_class = delayed and requires snooze_resume_condition_label.",
          "if": {
            "properties": {
              "suppression_reasons": {
                "contains": { "const": "class_snoozed_by_user" }
              }
            },
            "required": ["suppression_reasons"]
          },
          "then": {
            "properties": {
              "suppression_disposition_class": { "const": "delayed" },
              "snooze_resume_condition_label": { "$ref": "#/$defs/short_label_text" }
            }
          }
        },
        {
          "description": "dedupe_same_grouped_burst implies suppression_disposition_class = coalesced and requires coalesced_into_grouped_burst_id_ref.",
          "if": {
            "properties": {
              "suppression_reasons": {
                "contains": { "const": "dedupe_same_grouped_burst" }
              }
            },
            "required": ["suppression_reasons"]
          },
          "then": {
            "properties": {
              "suppression_disposition_class": { "const": "coalesced" },
              "coalesced_into_grouped_burst_id_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        },
        {
          "description": "dedupe_same_canonical_event implies suppression_disposition_class = coalesced and requires coalesced_into_canonical_event_id_ref.",
          "if": {
            "properties": {
              "suppression_reasons": {
                "contains": { "const": "dedupe_same_canonical_event" }
              }
            },
            "required": ["suppression_reasons"]
          },
          "then": {
            "properties": {
              "suppression_disposition_class": { "const": "coalesced" },
              "coalesced_into_canonical_event_id_ref": { "$ref": "#/$defs/opaque_id" }
            }
          }
        }
      ]
    },
    "notification_suppression_ledger_manifest_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "notification_suppression_ledger_schema_version",
        "manifest_id",
        "generated_at",
        "invariants",
        "policy_context"
      ],
      "properties": {
        "$schema": { "$ref": "#/$defs/instance_schema_hint" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "notification_suppression_ledger_manifest_record" },
        "notification_suppression_ledger_schema_version": { "$ref": "#/$defs/notification_suppression_ledger_schema_version" },
        "manifest_id": { "$ref": "#/$defs/opaque_id" },
        "generated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "invariants": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/invariant_assertion" },
          "description": "Manifest invariants that must remain const-true for every suppression ledger entry."
        },
        "policy_context": { "$ref": "#/$defs/policy_context" }
      }
    }
  }
}
