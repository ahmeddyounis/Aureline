{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/editor_layer.schema.json",
  "title": "Aureline editor anatomy, layer-classification, and stable-text-column contract",
  "description": "Boundary schema for the editor anatomy contract frozen in docs/ux/editor_anatomy_contract.md. The schema exports editor_layer_catalog_record and editor_stack_case_record so shell, renderer, language, review, generated-artifact, live-preview, restore, support/export, and accessibility tooling share one vocabulary for canonical editor layers, accessory role classification, stable text-column behavior, state placement, and large-file/degraded layer downgrades. Raw file bodies, raw absolute paths, raw URLs, raw terminal output, raw provider payloads, raw preview DOM, and credential material never cross this boundary; records carry opaque refs, bounded labels, typed state, and measured layout facts only. Adding a new layer-adjacent accessory, state class, downgrade reason, or permitted reflow trigger is additive-minor and requires an editor_layer_schema_version bump; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/editor_layer_catalog_record" },
    { "$ref": "#/$defs/editor_stack_case_record" }
  ],
  "$defs": {
    "editor_layer_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for editor anatomy payloads. Current value is 1."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "record_kinds_exercised": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "description": "Optional worked-example prelude carried on fixtures."
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "description": "Opaque, stable id safe to log, safe on RPC, safe in manifests, and safe in support bundles. Raw paths, raw payloads, and capability tickets never appear here."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/opaque_id" }
      ]
    },
    "redaction_aware_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Bounded, redaction-aware display text. Raw absolute paths, raw logs, raw preview DOM, raw provider payloads, and secret material must not appear."
    },
    "short_label_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "description": "Short redaction-aware label suitable for compact editor chrome."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp produced by the emitting subsystem."
    },
    "record_kind": {
      "type": "string",
      "enum": ["editor_layer_catalog_record", "editor_stack_case_record"],
      "description": "Discriminator for the concrete payload shape."
    },
    "canonical_layer_class": {
      "type": "string",
      "enum": [
        "document_header",
        "context_layer",
        "gutter",
        "text_viewport",
        "inline_assist_layer",
        "transient_knowledge_layer",
        "status_layer"
      ],
      "description": "Canonical editor layer. Adding another layer is a breaking anatomy decision, not a fixture-local choice."
    },
    "accessory_role_class": {
      "type": "string",
      "enum": ["content", "annotation", "action_affordance"],
      "description": "Whether an accessory is source/content, explanatory annotation, or an invokable affordance."
    },
    "accessory_class": {
      "type": "string",
      "enum": [
        "tab_label",
        "dirty_state_marker",
        "pin_marker",
        "compare_role_marker",
        "restored_recovered_marker",
        "header_close_unpin_control",
        "breadcrumb_path",
        "root_identity_badge",
        "symbol_ancestry",
        "generated_source_relation_strip",
        "read_only_degraded_reason_strip",
        "line_number",
        "current_line_cue",
        "breakpoint_debug_marker",
        "fold_control",
        "diagnostic_marker",
        "change_marker",
        "supplemental_gutter_marker",
        "overview_ruler_minimap_marker",
        "source_text",
        "selection_range",
        "caret",
        "multi_cursor_column_indicator",
        "ime_marked_text_composition",
        "code_lens",
        "inlay_hint",
        "inline_quick_action",
        "ghost_text",
        "hover_card",
        "peek_panel",
        "docs_popup",
        "signature_help",
        "encoding_indicator",
        "line_ending_indicator",
        "language_mode_indicator",
        "selection_cursor_stats",
        "semantic_execution_mode_item",
        "degraded_large_file_status_item"
      ],
      "description": "Frozen launch-bearing editor accessory vocabulary."
    },
    "surface_state_class": {
      "type": "string",
      "enum": ["compare", "restored", "generated", "read_only", "live_preview", "degraded", "large_file"],
      "description": "Editor-visible state whose placement is governed by this contract."
    },
    "disclosure_surface": {
      "type": "string",
      "enum": [
        "document_header",
        "context_layer",
        "gutter",
        "text_viewport",
        "inline_assist_layer",
        "transient_knowledge_layer",
        "status_layer",
        "command_palette",
        "support_export"
      ],
      "description": "Surface where state, downgrade, or detail disclosure is visible or exportable."
    },
    "layer_visibility_class": {
      "type": "string",
      "enum": ["visible", "unchanged", "narrowed", "downgraded", "hidden_with_replacement", "not_applicable"],
      "description": "How a layer behaves in a concrete editor-stack case."
    },
    "downgrade_reason_class": {
      "type": "string",
      "enum": [
        "none",
        "large_file_budget",
        "degraded_runtime",
        "read_only_or_generated",
        "stale_or_partial_semantics",
        "policy_or_trust_boundary",
        "high_zoom_or_compact_density",
        "low_resource_or_power_state",
        "missing_provider_or_dependency",
        "higher_priority_decoration",
        "typing_budget_protection"
      ],
      "description": "Reason a layer or accessory narrowed, downgraded, suppressed, or hid."
    },
    "column_shift_trigger": {
      "type": "string",
      "enum": [
        "none",
        "typing_or_cursoring",
        "transient_diagnostic",
        "transient_hint",
        "hover_or_peek",
        "status_change",
        "compare_state_change",
        "restored_state_change",
        "generated_state_change",
        "read_only_state_change",
        "live_preview_state_change",
        "degraded_state_change",
        "large_file_entry",
        "font_or_zoom_change",
        "density_change",
        "explicit_user_layout_change",
        "line_count_digit_reserve_crossed",
        "viewport_resize"
      ],
      "description": "Trigger associated with a text-column measurement."
    },
    "permitted_reflow_reason": {
      "type": "string",
      "enum": [
        "none",
        "font_or_zoom_change",
        "density_change",
        "explicit_user_layout_change",
        "line_count_digit_reserve_crossed",
        "viewport_resize"
      ],
      "description": "Closed set of reasons that may intentionally recompute the stable text column."
    },
    "layer_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer", "owns_summary", "must_never_own", "allowed_role_classes"],
      "properties": {
        "layer": { "$ref": "#/$defs/canonical_layer_class" },
        "owns_summary": { "$ref": "#/$defs/redaction_aware_text" },
        "must_never_own": { "$ref": "#/$defs/redaction_aware_text" },
        "allowed_role_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/accessory_role_class" }
        }
      },
      "description": "One canonical layer definition."
    },
    "accessory_assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accessory_class",
        "assigned_layer",
        "role_class",
        "owns_summary",
        "must_never_own",
        "must_not_impersonate_content",
        "keyboard_reachable_when_actionable"
      ],
      "properties": {
        "accessory_class": { "$ref": "#/$defs/accessory_class" },
        "assigned_layer": { "$ref": "#/$defs/canonical_layer_class" },
        "role_class": { "$ref": "#/$defs/accessory_role_class" },
        "owns_summary": { "$ref": "#/$defs/redaction_aware_text" },
        "must_never_own": { "$ref": "#/$defs/redaction_aware_text" },
        "must_not_impersonate_content": { "type": "boolean" },
        "keyboard_reachable_when_actionable": { "type": "boolean" },
        "action_command_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" },
          "description": "Command refs when the accessory role is action_affordance."
        },
        "source_authority_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" },
          "description": "Opaque refs to buffer, language, review, generated lineage, preview, or policy sources behind the accessory."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "role_class": { "const": "action_affordance" } },
            "required": ["role_class"]
          },
          "then": {
            "properties": { "keyboard_reachable_when_actionable": { "const": true } }
          }
        },
        {
          "if": {
            "properties": {
              "role_class": { "enum": ["annotation", "action_affordance"] }
            },
            "required": ["role_class"]
          },
          "then": {
            "properties": { "must_not_impersonate_content": { "const": true } }
          }
        }
      ],
      "description": "One accessory assigned to exactly one layer and one role class."
    },
    "state_placement_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_class",
        "required_layers",
        "allowed_additional_layers",
        "visible_text_required",
        "icon_only_forbidden",
        "minimum_disclosure"
      ],
      "properties": {
        "state_class": { "$ref": "#/$defs/surface_state_class" },
        "required_layers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/canonical_layer_class" }
        },
        "allowed_additional_layers": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/canonical_layer_class" }
        },
        "visible_text_required": { "type": "boolean", "const": true },
        "icon_only_forbidden": { "type": "boolean", "const": true },
        "minimum_disclosure": { "$ref": "#/$defs/redaction_aware_text" },
        "state_authority_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      },
      "description": "Required layer placement for one editor-visible state."
    },
    "stable_text_column_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "measurement_id",
        "text_column_x_px_before",
        "text_column_x_px_after",
        "column_shift_px",
        "column_shift_trigger",
        "permitted_reflow_reason",
        "jitter_forbidden",
        "source_text_column_preserved",
        "gutter_width_reserved_at_viewport_level",
        "per_line_text_start_changes_forbidden"
      ],
      "properties": {
        "measurement_id": { "$ref": "#/$defs/opaque_id" },
        "text_column_x_px_before": { "type": "integer", "minimum": 0 },
        "text_column_x_px_after": { "type": "integer", "minimum": 0 },
        "column_shift_px": { "type": "integer", "minimum": 0 },
        "column_shift_trigger": { "$ref": "#/$defs/column_shift_trigger" },
        "permitted_reflow_reason": { "$ref": "#/$defs/permitted_reflow_reason" },
        "jitter_forbidden": { "type": "boolean", "const": true },
        "source_text_column_preserved": { "type": "boolean" },
        "gutter_width_reserved_at_viewport_level": { "type": "boolean", "const": true },
        "per_line_text_start_changes_forbidden": { "type": "boolean", "const": true },
        "measured_accessory_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "notes": { "$ref": "#/$defs/redaction_aware_text" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "column_shift_trigger": {
                "enum": [
                  "typing_or_cursoring",
                  "transient_diagnostic",
                  "transient_hint",
                  "hover_or_peek",
                  "status_change",
                  "compare_state_change",
                  "restored_state_change",
                  "generated_state_change",
                  "read_only_state_change",
                  "live_preview_state_change",
                  "degraded_state_change",
                  "large_file_entry"
                ]
              }
            },
            "required": ["column_shift_trigger"]
          },
          "then": {
            "properties": {
              "column_shift_px": { "const": 0 },
              "permitted_reflow_reason": { "const": "none" },
              "source_text_column_preserved": { "const": true }
            }
          }
        },
        {
          "if": {
            "properties": {
              "permitted_reflow_reason": {
                "enum": [
                  "font_or_zoom_change",
                  "density_change",
                  "explicit_user_layout_change",
                  "line_count_digit_reserve_crossed",
                  "viewport_resize"
                ]
              }
            },
            "required": ["permitted_reflow_reason"]
          },
          "then": {
            "properties": {
              "column_shift_trigger": {
                "enum": [
                  "font_or_zoom_change",
                  "density_change",
                  "explicit_user_layout_change",
                  "line_count_digit_reserve_crossed",
                  "viewport_resize"
                ]
              }
            }
          }
        }
      ],
      "description": "Measured stable-text-column policy for a concrete editor stack."
    },
    "layer_adjustment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer",
        "visibility",
        "downgrade_reason",
        "what_still_works",
        "what_is_reduced_or_removed",
        "disclosure_surfaces"
      ],
      "properties": {
        "layer": { "$ref": "#/$defs/canonical_layer_class" },
        "visibility": { "$ref": "#/$defs/layer_visibility_class" },
        "downgrade_reason": { "$ref": "#/$defs/downgrade_reason_class" },
        "what_still_works": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/short_label_text" }
        },
        "what_is_reduced_or_removed": {
          "type": "array",
          "items": { "$ref": "#/$defs/short_label_text" }
        },
        "disclosure_surfaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/disclosure_surface" }
        },
        "replacement_route_ref": { "$ref": "#/$defs/nullable_opaque_id" }
      },
      "description": "How one layer narrows, downgrades, hides with replacement, or remains unchanged in a concrete case."
    },
    "editor_stack_assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "single_layer_assignment_verified",
        "all_accessories_classified",
        "source_text_column_stable",
        "transient_state_does_not_move_text",
        "critical_state_not_icon_only",
        "large_file_or_degraded_downgrades_disclosed",
        "keyboard_detail_routes_present"
      ],
      "properties": {
        "single_layer_assignment_verified": { "type": "boolean", "const": true },
        "all_accessories_classified": { "type": "boolean", "const": true },
        "source_text_column_stable": { "type": "boolean", "const": true },
        "transient_state_does_not_move_text": { "type": "boolean", "const": true },
        "critical_state_not_icon_only": { "type": "boolean", "const": true },
        "large_file_or_degraded_downgrades_disclosed": { "type": "boolean", "const": true },
        "keyboard_detail_routes_present": { "type": "boolean", "const": true }
      },
      "description": "Boolean acceptance assertions for worked fixtures."
    },
    "editor_layer_catalog_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "editor_layer_schema_version",
        "catalog_id",
        "layer_definitions",
        "accessory_assignments",
        "state_placement_rules",
        "stable_text_column_rules",
        "forbidden_outcomes_verified_absent",
        "emitted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "editor_layer_catalog_record" },
        "editor_layer_schema_version": { "$ref": "#/$defs/editor_layer_schema_version" },
        "catalog_id": { "$ref": "#/$defs/opaque_id" },
        "layer_definitions": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/layer_definition" }
        },
        "accessory_assignments": {
          "type": "array",
          "minItems": 30,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/accessory_assignment" }
        },
        "state_placement_rules": {
          "type": "array",
          "minItems": 7,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/state_placement_rule" }
        },
        "stable_text_column_rules": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/redaction_aware_text" }
        },
        "forbidden_outcomes_verified_absent": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/short_label_text" }
        },
        "emitted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "description": "Canonical catalog record for editor layers, accessories, and state placement."
    },
    "editor_stack_case_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "editor_layer_schema_version",
        "case_id",
        "scenario",
        "active_state_classes",
        "accessory_assignments",
        "stable_text_column",
        "state_placements",
        "layer_adjustments",
        "assertions",
        "forbidden_outcomes_verified_absent",
        "emitted_at"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "editor_stack_case_record" },
        "editor_layer_schema_version": { "$ref": "#/$defs/editor_layer_schema_version" },
        "case_id": { "$ref": "#/$defs/opaque_id" },
        "scenario": { "$ref": "#/$defs/redaction_aware_text" },
        "workspace_authority_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "buffer_authority_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "active_state_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/surface_state_class" }
        },
        "accessory_assignments": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/accessory_assignment" }
        },
        "stable_text_column": { "$ref": "#/$defs/stable_text_column_policy" },
        "state_placements": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/state_placement_rule" }
        },
        "layer_adjustments": {
          "type": "array",
          "minItems": 7,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/layer_adjustment" }
        },
        "assertions": { "$ref": "#/$defs/editor_stack_assertions" },
        "support_export_ref": { "$ref": "#/$defs/nullable_opaque_id" },
        "forbidden_outcomes_verified_absent": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/short_label_text" }
        },
        "emitted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "description": "Concrete editor-stack case used by renderer, accessibility, support/export, and contract tests."
    }
  }
}
