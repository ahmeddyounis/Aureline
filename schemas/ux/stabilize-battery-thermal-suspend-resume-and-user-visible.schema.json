{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/stabilize-battery-thermal-suspend-resume-and-user-visible.schema.json",
  "title": "Aureline runtime-efficiency adaptation record",
  "description": "Boundary schema for runtime_efficiency_adaptation_record, the single governed record the shell status strip, the in-product diagnostics review, the CLI efficiency inspector, Help/About, the diagnostics support export, and docs all read for one efficiency posture on the claimed-stable desktop matrix. It is minted by crates/aureline-shell/src/runtime_efficiency_stable as a genuine projection of the live efficiency runtime (crates/aureline-shell/src/efficiency) and the suspend-resume / power-posture page (crates/aureline-shell/src/runtime_adaptation). It binds, for one efficiency-state identity: (1) a materialized runtime-efficiency state (Nominal, EfficiencyAware, ThermalConstrained, ProtectCore, Recovery) bound to named shed-work classes, protected foreground paths, resume conditions, and export-safe diagnostics; (2) background work shed before any foreground regression; (3) protected foreground paths within published latency bands; (4) hidden-pane quiescence (no off-screen paint, animation, or speculative poll); (5) a surfaced queue-governor reason, paused lanes, and resume owner so battery saver, thermal clamp, low-disk, suspend, and resume transitions never masquerade as generic slowness or stale data; (6) preserved save durability and local durable state; (7) per-OS conformance for macOS, Windows, and Linux; (8) a public claim ceiling no posture may exceed; and (9) a derived stable-claim verdict that narrows a posture which cannot prove a pillar, or whose lowest binding surface marker is below Stable, below Stable with a named reason. Minted refs are opaque aureline://<class>/<id> object refs; upstream refs keep their source scheme.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "schema_version",
    "notice",
    "shared_contract_ref",
    "record_id",
    "as_of",
    "posture_id",
    "posture_label",
    "title",
    "summary",
    "efficiency_state",
    "surface_lifecycle_marker",
    "governor",
    "shed_work",
    "protected_paths",
    "hidden_pane_audit",
    "durability",
    "platform_conformance",
    "surface_projections",
    "pillars",
    "claim_ceiling",
    "stable_qualification",
    "recovery_routes",
    "routes",
    "accessibility",
    "available_without_account",
    "available_without_managed_services",
    "honesty_marker_present",
    "upstream",
    "diagnostics_export_ref",
    "support_export_ref",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "record_kind": { "const": "runtime_efficiency_adaptation_record" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "notice": { "type": "string", "minLength": 1 },
    "shared_contract_ref": { "const": "shell:runtime_efficiency_adaptation_stable:v1" },
    "record_id": { "$ref": "#/$defs/presentRef" },
    "as_of": { "type": "string", "minLength": 1 },
    "posture_id": { "$ref": "#/$defs/presentRef" },
    "posture_label": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "efficiency_state": { "$ref": "#/$defs/efficiencyState" },
    "surface_lifecycle_marker": { "$ref": "#/$defs/lifecycleMarker" },
    "governor": { "$ref": "#/$defs/governor" },
    "shed_work": { "type": "array", "items": { "$ref": "#/$defs/shedWorkRow" } },
    "protected_paths": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/protectedPathRow" }
    },
    "hidden_pane_audit": { "$ref": "#/$defs/hiddenPaneAudit" },
    "durability": { "$ref": "#/$defs/durability" },
    "suspend_resume": { "$ref": "#/$defs/suspendResume" },
    "platform_conformance": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/platformConformanceRow" }
    },
    "surface_projections": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/surfaceProjection" }
    },
    "pillars": { "$ref": "#/$defs/pillars" },
    "claim_ceiling": { "$ref": "#/$defs/claimCeiling" },
    "stable_qualification": { "$ref": "#/$defs/qualification" },
    "recovery_routes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/recoveryRoute" }
    },
    "routes": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/entryRoute" }
    },
    "accessibility": { "$ref": "#/$defs/accessibility" },
    "available_without_account": { "type": "boolean" },
    "available_without_managed_services": { "type": "boolean" },
    "honesty_marker_present": { "type": "boolean" },
    "upstream": { "$ref": "#/$defs/upstream" },
    "diagnostics_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "support_export_ref": { "$ref": "#/$defs/canonicalRef" },
    "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } },
    "narrative_refs": { "type": "array", "items": { "$ref": "#/$defs/canonicalRef" } }
  },
  "$defs": {
    "canonicalRef": {
      "type": "string",
      "pattern": "^aureline://(?!home/|dashboard/|landing/|index/|overview/|start/|root/)[^/]+/.+$"
    },
    "presentRef": { "type": "string", "minLength": 1 },
    "efficiencyState": {
      "type": "string",
      "enum": ["Nominal", "EfficiencyAware", "ThermalConstrained", "ProtectCore", "Recovery"]
    },
    "lifecycleMarker": { "type": "string", "enum": ["preview", "beta", "stable"] },
    "claimClass": { "type": "string", "enum": ["stable", "beta", "preview", "not_claimed"] },
    "governorReason": {
      "type": "string",
      "enum": [
        "none_nominal",
        "battery_saver",
        "low_battery",
        "critical_battery",
        "thermal_clamp",
        "low_disk",
        "suspend_resume",
        "pressure_cleared"
      ]
    },
    "resumeOwner": {
      "type": "string",
      "enum": [
        "automatic_on_pressure_clear",
        "user_restore_power",
        "user_resume",
        "admin_policy",
        "remote_reconnect"
      ]
    },
    "protectedPath": {
      "type": "string",
      "enum": ["edit_typing", "save_document", "direct_navigation", "quick_open", "command_palette"]
    },
    "profileClass": { "type": "string", "enum": ["macos", "windows", "linux"] },
    "truthSurface": {
      "type": "string",
      "enum": [
        "shell_status_strip",
        "diagnostics_review",
        "cli_inspect",
        "help_about",
        "support_export"
      ]
    },
    "narrowingReason": {
      "type": "string",
      "enum": [
        "efficiency_state_not_materialized",
        "background_not_shed_before_foreground",
        "foreground_exceeds_latency_band",
        "hidden_panes_not_quiescent",
        "governor_reason_not_surfaced",
        "durable_state_not_preserved",
        "platform_conformance_incomplete",
        "surface_not_yet_stable"
      ]
    },
    "recoveryRole": { "type": "string", "enum": ["primary", "recovery", "secondary"] },
    "routeSurface": {
      "type": "string",
      "enum": ["activity_center", "command_palette", "status_bar", "menu_command"]
    },
    "layoutMode": { "type": "string", "enum": ["normal", "high_contrast", "zoomed"] },
    "governor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "reason_label",
        "paused_lane_tokens",
        "resume_owner",
        "resume_owner_label",
        "surfaced_in_status_strip",
        "surfaced_in_diagnostics",
        "not_generic_slowness",
        "not_stale_masquerade"
      ],
      "properties": {
        "reason": { "$ref": "#/$defs/governorReason" },
        "reason_label": { "type": "string", "minLength": 1 },
        "paused_lane_tokens": { "type": "array", "items": { "type": "string" } },
        "resume_owner": { "$ref": "#/$defs/resumeOwner" },
        "resume_owner_label": { "type": "string", "minLength": 1 },
        "surfaced_in_status_strip": { "type": "boolean" },
        "surfaced_in_diagnostics": { "type": "boolean" },
        "not_generic_slowness": { "type": "boolean" },
        "not_stale_masquerade": { "type": "boolean" }
      }
    },
    "shedWorkRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workload_id",
        "work_class",
        "queue_lane",
        "action",
        "changes_behavior",
        "shed_before_foreground",
        "user_impact_label",
        "resume_owner",
        "resume_condition"
      ],
      "properties": {
        "workload_id": { "type": "string", "minLength": 1 },
        "work_class": { "type": "string", "minLength": 1 },
        "queue_lane": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "changes_behavior": { "type": "boolean" },
        "shed_before_foreground": { "type": "boolean" },
        "user_impact_label": { "type": "string", "minLength": 1 },
        "resume_owner": { "$ref": "#/$defs/resumeOwner" },
        "resume_condition": { "type": "string", "minLength": 1 }
      }
    },
    "protectedPathRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "published_band_ms",
        "observed_p99_ms",
        "within_band",
        "preserved_under_posture"
      ],
      "properties": {
        "path": { "$ref": "#/$defs/protectedPath" },
        "published_band_ms": { "type": "integer", "minimum": 0 },
        "observed_p99_ms": { "type": "integer", "minimum": 0 },
        "within_band": { "type": "boolean" },
        "preserved_under_posture": { "type": "boolean" }
      }
    },
    "renderSample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "surface_class",
        "visibility_state",
        "committed_paint_count",
        "hidden_pane_work",
        "offscreen_suppression_eligible"
      ],
      "properties": {
        "surface_id": { "type": "string", "minLength": 1 },
        "surface_class": { "type": "string", "minLength": 1 },
        "visibility_state": { "type": "string", "minLength": 1 },
        "committed_paint_count": { "type": "integer", "minimum": 0 },
        "hidden_pane_work": { "type": "integer", "minimum": 0 },
        "offscreen_suppression_eligible": { "type": "integer", "minimum": 0 }
      }
    },
    "hiddenPaneAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "audited_surface_count",
        "hidden_surface_count",
        "visible_pane_work",
        "hidden_pane_work",
        "offscreen_suppression_eligible",
        "hidden_pane_render_violation_count",
        "passes_hidden_pane_policy",
        "samples"
      ],
      "properties": {
        "record_kind": { "const": "hidden_pane_render_audit" },
        "schema_version": { "type": "integer", "minimum": 1 },
        "audited_surface_count": { "type": "integer", "minimum": 0 },
        "hidden_surface_count": { "type": "integer", "minimum": 0 },
        "visible_pane_work": { "type": "integer", "minimum": 0 },
        "hidden_pane_work": { "type": "integer", "minimum": 0 },
        "offscreen_suppression_eligible": { "type": "integer", "minimum": 0 },
        "hidden_pane_render_violation_count": { "type": "integer", "minimum": 0 },
        "passes_hidden_pane_policy": { "type": "boolean" },
        "samples": { "type": "array", "items": { "$ref": "#/$defs/renderSample" } }
      }
    },
    "durability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "save_durability_preserved",
        "dirty_buffers_preserved",
        "user_owned_artifacts_preserved",
        "invariant_summary"
      ],
      "properties": {
        "save_durability_preserved": { "type": "boolean" },
        "dirty_buffers_preserved": { "type": "boolean" },
        "user_owned_artifacts_preserved": { "type": "boolean" },
        "invariant_summary": { "type": "string", "minLength": 1 }
      }
    },
    "suspendResume": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id_ref",
        "event_token",
        "continuity_summary_tokens",
        "local_work_continues",
        "privileged_or_mutating_work_paused",
        "no_silent_rerun_or_authority_reuse",
        "user_visible_resume_summary_required",
        "recovery_action_tokens"
      ],
      "properties": {
        "case_id_ref": { "$ref": "#/$defs/presentRef" },
        "event_token": { "type": "string", "minLength": 1 },
        "continuity_summary_tokens": { "type": "array", "items": { "type": "string" } },
        "local_work_continues": { "type": "boolean" },
        "privileged_or_mutating_work_paused": { "type": "boolean" },
        "no_silent_rerun_or_authority_reuse": { "type": "boolean" },
        "user_visible_resume_summary_required": { "type": "boolean" },
        "recovery_action_tokens": { "type": "array", "items": { "type": "string" } }
      }
    },
    "platformConformanceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "profile_id", "covered", "proof_ref", "named_downgrade_behaviors"],
      "properties": {
        "profile": { "$ref": "#/$defs/profileClass" },
        "profile_id": { "type": "string", "minLength": 1 },
        "covered": { "type": "boolean" },
        "proof_ref": { "type": "string", "minLength": 1 },
        "named_downgrade_behaviors": { "type": "array", "items": { "type": "string" } }
      }
    },
    "surfaceProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "surface_marker", "reads_shared_record", "summary_line"],
      "properties": {
        "surface": { "$ref": "#/$defs/truthSurface" },
        "surface_marker": { "$ref": "#/$defs/lifecycleMarker" },
        "reads_shared_record": { "type": "boolean" },
        "summary_line": { "type": "string", "minLength": 1 }
      }
    },
    "pillars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "efficiency_state_materialized",
        "background_shed_before_foreground",
        "foreground_within_latency_bands",
        "hidden_panes_quiescent",
        "governor_reason_surfaced",
        "durable_state_preserved",
        "platform_conformance_complete"
      ],
      "properties": {
        "efficiency_state_materialized": { "type": "boolean" },
        "background_shed_before_foreground": { "type": "boolean" },
        "foreground_within_latency_bands": { "type": "boolean" },
        "hidden_panes_quiescent": { "type": "boolean" },
        "governor_reason_surfaced": { "type": "boolean" },
        "durable_state_preserved": { "type": "boolean" },
        "platform_conformance_complete": { "type": "boolean" }
      }
    },
    "claimCeiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asserts_efficiency_state_materialized",
        "asserts_background_shed_before_foreground",
        "asserts_foreground_within_latency_bands",
        "asserts_hidden_panes_quiescent",
        "asserts_governor_reason_surfaced",
        "asserts_durable_state_preserved",
        "asserts_platform_conformance_complete"
      ],
      "properties": {
        "asserts_efficiency_state_materialized": { "type": "boolean" },
        "asserts_background_shed_before_foreground": { "type": "boolean" },
        "asserts_foreground_within_latency_bands": { "type": "boolean" },
        "asserts_hidden_panes_quiescent": { "type": "boolean" },
        "asserts_governor_reason_surfaced": { "type": "boolean" },
        "asserts_durable_state_preserved": { "type": "boolean" },
        "asserts_platform_conformance_complete": { "type": "boolean" }
      }
    },
    "qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_class", "qualifies_stable", "narrowing_reasons"],
      "properties": {
        "claim_class": { "$ref": "#/$defs/claimClass" },
        "qualifies_stable": { "type": "boolean" },
        "narrowing_reasons": { "type": "array", "items": { "$ref": "#/$defs/narrowingReason" } }
      }
    },
    "recoveryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_label", "action_role", "keyboard_reachable"],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_label": { "type": "string", "minLength": 1 },
        "action_role": { "$ref": "#/$defs/recoveryRole" },
        "keyboard_reachable": { "type": "boolean" }
      }
    },
    "entryRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "route_ref", "keyboard_reachable", "activates_same_item"],
      "properties": {
        "surface": { "$ref": "#/$defs/routeSurface" },
        "route_ref": { "$ref": "#/$defs/canonicalRef" },
        "keyboard_reachable": { "type": "boolean" },
        "activates_same_item": { "type": "boolean" }
      }
    },
    "layoutModeDisclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "row_narration_available", "recovery_affordances_reachable"],
      "properties": {
        "mode": { "$ref": "#/$defs/layoutMode" },
        "row_narration_available": { "type": "boolean" },
        "recovery_affordances_reachable": { "type": "boolean" }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus_order_index",
        "tab_stop_count",
        "row_narration",
        "action_labels",
        "layout_modes"
      ],
      "properties": {
        "focus_order_index": { "type": "integer", "minimum": 0 },
        "tab_stop_count": { "type": "integer", "minimum": 0 },
        "row_narration": { "type": "string", "minLength": 1 },
        "action_labels": { "type": "array", "items": { "type": "string" } },
        "layout_modes": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/layoutModeDisclosure" }
        }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "efficiency_snapshot_ref",
        "runtime_adaptation_page_ref",
        "contributing_decision_refs"
      ],
      "properties": {
        "efficiency_snapshot_ref": { "$ref": "#/$defs/presentRef" },
        "runtime_adaptation_page_ref": { "$ref": "#/$defs/presentRef" },
        "contributing_decision_refs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
