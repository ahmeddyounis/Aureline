{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/lifecycle_status_card.schema.json",
  "title": "Aureline lifecycle-status card degraded-mode contract",
  "description": "Boundary schema for lifecycle_status_card_record instances frozen in docs/ux/degraded_mode_pattern.md. The record is the reusable degraded-mode card family for workspaces, extensions, remote sessions, collaboration sessions, AI actions, and update or rollback flows. Every card states what still works, what is reduced or paused, whether data or certainty is affected, where the last-failure reason is visible, which keyboard-reachable inspect path opens details, and which recovery action preserves current work through safe review. Raw credentials, raw logs, raw prompts, raw absolute paths, raw URLs, raw hostnames, raw tokens, and raw external payload bodies never cross this boundary; records carry opaque refs, controlled labels, typed cause classes, and reviewable sentences only. Adding a status label, lifecycle state, cause class, recovery action kind, or delivery surface is additive-minor and bumps lifecycle_status_card_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_kind",
    "lifecycle_status_card_schema_version",
    "card_id",
    "lifecycle_object_class",
    "lifecycle_state",
    "status_label",
    "status_label_token",
    "failure_tier",
    "delivery_surfaces",
    "truth_classes",
    "degraded_state_tokens",
    "what_still_works",
    "what_is_reduced_or_paused",
    "data_or_certainty_effect",
    "local_editing_contract",
    "last_failure",
    "primary_recovery_action",
    "recovery_actions",
    "inspect_path",
    "support_export",
    "collapse_policy",
    "accessibility",
    "narrative_refs"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "__fixture__": {
      "$ref": "#/$defs/fixture_metadata"
    },
    "record_kind": {
      "type": "string",
      "const": "lifecycle_status_card_record",
      "description": "Discriminator for this card family."
    },
    "lifecycle_status_card_schema_version": {
      "$ref": "#/$defs/lifecycle_status_card_schema_version"
    },
    "card_id": {
      "$ref": "#/$defs/opaque_id"
    },
    "lifecycle_object_class": {
      "$ref": "#/$defs/lifecycle_object_class"
    },
    "lifecycle_state": {
      "$ref": "#/$defs/lifecycle_state"
    },
    "status_label": {
      "$ref": "#/$defs/status_label"
    },
    "status_label_token": {
      "$ref": "#/$defs/status_label_token"
    },
    "failure_tier": {
      "$ref": "#/$defs/failure_tier"
    },
    "delivery_surfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/delivery_surface"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "truth_classes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/truth_class"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "degraded_state_tokens": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/degraded_state_token"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "what_still_works": {
      "$ref": "#/$defs/capability_preservation_block"
    },
    "what_is_reduced_or_paused": {
      "$ref": "#/$defs/reduced_capability_block"
    },
    "data_or_certainty_effect": {
      "$ref": "#/$defs/data_or_certainty_effect"
    },
    "local_editing_contract": {
      "$ref": "#/$defs/local_editing_contract"
    },
    "last_failure": {
      "$ref": "#/$defs/last_failure"
    },
    "primary_recovery_action": {
      "$ref": "#/$defs/recovery_action"
    },
    "recovery_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recovery_action"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "inspect_path": {
      "$ref": "#/$defs/inspect_path"
    },
    "support_export": {
      "$ref": "#/$defs/support_export"
    },
    "collapse_policy": {
      "$ref": "#/$defs/collapse_policy"
    },
    "accessibility": {
      "$ref": "#/$defs/accessibility"
    },
    "narrative_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lifecycle_object_class": {
            "const": "workspace"
          }
        },
        "required": ["lifecycle_object_class"]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "workspace.starting",
              "workspace.ready",
              "workspace.partially_ready",
              "workspace.degraded",
              "workspace.read_only_degraded",
              "workspace.recovering",
              "workspace.quarantined",
              "workspace.stopped"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_object_class": {
            "const": "extension"
          }
        },
        "required": ["lifecycle_object_class"]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "extension.loading",
              "extension.activated",
              "extension.partially_activated",
              "extension.degraded",
              "extension.read_only_degraded",
              "extension.quarantined",
              "extension.unactivated_by_policy",
              "extension.uninstalled"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_object_class": {
            "const": "remote_session"
          }
        },
        "required": ["lifecycle_object_class"]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "remote.reachable",
              "remote.reconnecting",
              "remote.reauth_pending",
              "remote.read_only_degraded",
              "remote.offline",
              "remote.policy_blocked"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_object_class": {
            "const": "collaboration_session"
          }
        },
        "required": ["lifecycle_object_class"]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "collaboration.solo",
              "collaboration.publish_pending",
              "collaboration.shared_active",
              "collaboration.participant_degraded",
              "collaboration.shared_degraded",
              "collaboration.no_recording",
              "collaboration.ended",
              "collaboration.archived"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_object_class": {
            "const": "ai_action"
          }
        },
        "required": ["lifecycle_object_class"]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "ai.drafting",
              "ai.context_resolving",
              "ai.awaiting_review",
              "ai.partial_results",
              "ai.retest_pending",
              "ai.degraded",
              "ai.patch_proposed",
              "ai.applied",
              "ai.rolled_back",
              "ai.blocked_by_policy"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_object_class": {
            "const": "update_rollback_flow"
          }
        },
        "required": ["lifecycle_object_class"]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "update.checking",
              "update.available",
              "update.downloading",
              "update.ready_to_restart",
              "update.applying",
              "update.rolled_back",
              "update.partial_apply",
              "update.failed",
              "update.blocked_by_policy"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status_label_token": {
            "const": "partially_ready"
          }
        },
        "required": ["status_label_token"]
      },
      "then": {
        "properties": {
          "status_label": {
            "const": "Partially ready"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status_label_token": {
            "const": "degraded"
          }
        },
        "required": ["status_label_token"]
      },
      "then": {
        "properties": {
          "status_label": {
            "const": "Degraded"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status_label_token": {
            "const": "read_only_degraded"
          }
        },
        "required": ["status_label_token"]
      },
      "then": {
        "properties": {
          "status_label": {
            "const": "Read-only degraded"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status_label_token": {
            "const": "warming"
          }
        },
        "required": ["status_label_token"]
      },
      "then": {
        "properties": {
          "status_label": {
            "const": "Warming"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status_label_token": {
            "const": "reconnecting"
          }
        },
        "required": ["status_label_token"]
      },
      "then": {
        "properties": {
          "status_label": {
            "const": "Reconnecting"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status_label_token": {
            "const": "policy_blocked"
          }
        },
        "required": ["status_label_token"]
      },
      "then": {
        "properties": {
          "status_label": {
            "const": "Policy blocked"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status_label_token": {
            "const": "no_recording"
          }
        },
        "required": ["status_label_token"]
      },
      "then": {
        "properties": {
          "status_label": {
            "const": "No recording"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status_label_token": {
            "const": "stale_evidence"
          }
        },
        "required": ["status_label_token"]
      },
      "then": {
        "properties": {
          "status_label": {
            "const": "Stale evidence"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "workspace.partially_ready",
              "workspace.degraded",
              "workspace.read_only_degraded",
              "remote.reconnecting",
              "remote.read_only_degraded",
              "remote.offline",
              "collaboration.participant_degraded",
              "collaboration.shared_degraded",
              "collaboration.no_recording",
              "ai.partial_results",
              "ai.retest_pending",
              "ai.degraded",
              "ai.blocked_by_policy",
              "update.rolled_back",
              "update.partial_apply",
              "update.failed"
            ]
          }
        },
        "required": ["lifecycle_state"]
      },
      "then": {
        "properties": {
          "local_editing_contract": {
            "properties": {
              "local_editing_available": {
                "const": true
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "lifecycle_status_card_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for this lifecycle-status card vocabulary export. Additive-optional fields do not bump this value; breaking meaning changes do."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "scenario"],
      "properties": {
        "name": {
          "$ref": "#/$defs/opaque_id"
        },
        "scenario": {
          "type": "string",
          "minLength": 1
        },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "linked_docs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$",
      "description": "Opaque id safe for logs, support exports, admin audit, and fixtures. Raw paths, hostnames, URLs, tokens, prompts, and secret material never appear."
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 320,
      "description": "Short, privacy-safe sentence intended for direct rendering or export. Raw paths, raw URLs, credentials, raw prompts, and raw logs MUST NOT appear."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 UTC timestamp from the monotonic timestamp envelope."
    },
    "wall_clock_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 UTC wall-clock timestamp paired with the monotonic timestamp where available."
    },
    "lifecycle_object_class": {
      "type": "string",
      "enum": [
        "workspace",
        "extension",
        "remote_session",
        "collaboration_session",
        "ai_action",
        "update_rollback_flow"
      ]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "workspace.starting",
        "workspace.ready",
        "workspace.partially_ready",
        "workspace.degraded",
        "workspace.read_only_degraded",
        "workspace.recovering",
        "workspace.quarantined",
        "workspace.stopped",
        "extension.loading",
        "extension.activated",
        "extension.partially_activated",
        "extension.degraded",
        "extension.read_only_degraded",
        "extension.quarantined",
        "extension.unactivated_by_policy",
        "extension.uninstalled",
        "remote.reachable",
        "remote.reconnecting",
        "remote.reauth_pending",
        "remote.read_only_degraded",
        "remote.offline",
        "remote.policy_blocked",
        "collaboration.solo",
        "collaboration.publish_pending",
        "collaboration.shared_active",
        "collaboration.participant_degraded",
        "collaboration.shared_degraded",
        "collaboration.no_recording",
        "collaboration.ended",
        "collaboration.archived",
        "ai.drafting",
        "ai.context_resolving",
        "ai.awaiting_review",
        "ai.partial_results",
        "ai.retest_pending",
        "ai.degraded",
        "ai.patch_proposed",
        "ai.applied",
        "ai.rolled_back",
        "ai.blocked_by_policy",
        "update.checking",
        "update.available",
        "update.downloading",
        "update.ready_to_restart",
        "update.applying",
        "update.rolled_back",
        "update.partial_apply",
        "update.failed",
        "update.blocked_by_policy"
      ]
    },
    "status_label": {
      "type": "string",
      "enum": [
        "Partially ready",
        "Degraded",
        "Read-only degraded",
        "Warming",
        "Reconnecting",
        "Policy blocked",
        "No recording",
        "Stale evidence"
      ]
    },
    "status_label_token": {
      "type": "string",
      "enum": [
        "partially_ready",
        "degraded",
        "read_only_degraded",
        "warming",
        "reconnecting",
        "policy_blocked",
        "no_recording",
        "stale_evidence"
      ]
    },
    "failure_tier": {
      "type": "string",
      "enum": [
        "tier.inline_issue",
        "tier.contextual_degraded",
        "tier.workflow_block",
        "tier.session_recovery",
        "tier.escalation_surface"
      ]
    },
    "delivery_surface": {
      "type": "string",
      "enum": [
        "contextual_banner",
        "status_item",
        "durable_job_row",
        "activity_center_digest_card",
        "window_attached_sheet",
        "panel",
        "dialog_modal",
        "full_surface_takeover",
        "support_center",
        "object_handoff_packet_surface"
      ]
    },
    "truth_class": {
      "type": "string",
      "enum": [
        "user_authored_durable_truth",
        "workspace_vcs_truth",
        "runtime_observed_truth",
        "derived_indexed_truth",
        "session_collaboration_truth",
        "ai_inferred_truth"
      ]
    },
    "degraded_state_token": {
      "type": "string",
      "enum": [
        "Warming",
        "Cached",
        "Partial",
        "Stale",
        "Offline",
        "PolicyBlocked",
        "Limited",
        "Unsupported",
        "Experimental",
        "RetestPending"
      ]
    },
    "cause_class": {
      "type": "string",
      "enum": [
        "no_previous_failure",
        "owner_not_ready",
        "background_index_incomplete",
        "cache_or_index_degraded",
        "transport_reconnect_in_progress",
        "authority_expired_for_remote",
        "remote_transport_unreachable",
        "relay_outage_detected",
        "relay_recording_disabled",
        "extension_quarantined",
        "extension_permission_revoked",
        "policy_denied_operation",
        "admin_policy_blocked",
        "managed_control_plane_unreachable",
        "evidence_stale",
        "context_stale",
        "ai_provider_unavailable",
        "update_apply_failed",
        "rollback_checkpoint_selected",
        "unresolved_axis"
      ]
    },
    "blocked_mutation_class": {
      "type": "string",
      "enum": [
        "none",
        "remote_authoritative_writes",
        "collaboration_recording_capture",
        "ai_apply_without_review",
        "extension_privileged_activation",
        "update_forward_apply",
        "policy_protected_operation",
        "managed_workspace_mutation",
        "index_claim_promotion",
        "local_file_writes"
      ]
    },
    "capability_preservation_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capabilities",
        "local_work_preserved",
        "authoritative_source_refs",
        "summary_sentence"
      ],
      "properties": {
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reviewable_sentence"
          },
          "minItems": 1
        },
        "local_work_preserved": {
          "type": "boolean",
          "description": "True when buffers, drafts, recovery journal, current binary, or other local work survive the degraded state."
        },
        "authoritative_source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_id"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "summary_sentence": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "reduced_capability_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capabilities",
        "cause_classes",
        "blocked_mutation_classes",
        "summary_sentence"
      ],
      "properties": {
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reviewable_sentence"
          },
          "minItems": 1
        },
        "cause_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cause_class"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "blocked_mutation_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/blocked_mutation_class"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "summary_sentence": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "data_or_certainty_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "data_affected",
        "certainty_affected",
        "effect_scope",
        "disclosure_sentence"
      ],
      "properties": {
        "data_affected": {
          "type": "boolean"
        },
        "certainty_affected": {
          "type": "boolean"
        },
        "effect_scope": {
          "type": "string",
          "enum": [
            "none",
            "cached_data",
            "partial_scope",
            "stale_evidence",
            "inferred_or_uncited_evidence",
            "read_only_authority",
            "recording_gap",
            "policy_withheld"
          ]
        },
        "disclosure_sentence": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "local_editing_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_editing_available",
        "save_pipeline_available",
        "survival_basis",
        "blocked_local_editing_reason"
      ],
      "properties": {
        "local_editing_available": {
          "type": "boolean"
        },
        "save_pipeline_available": {
          "type": "boolean"
        },
        "survival_basis": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "blocked_local_editing_reason": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/reviewable_sentence"
            }
          ]
        }
      }
    },
    "last_failure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "has_last_failure",
        "reason_class",
        "reason_code_ref",
        "occurred_at_monotonic",
        "occurred_at_wall_clock",
        "visibility",
        "summary_sentence",
        "recovery_history_refs"
      ],
      "properties": {
        "has_last_failure": {
          "type": "boolean"
        },
        "reason_class": {
          "$ref": "#/$defs/cause_class"
        },
        "reason_code_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "occurred_at_monotonic": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/monotonic_timestamp"
            }
          ]
        },
        "occurred_at_wall_clock": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/wall_clock_timestamp"
            }
          ]
        },
        "visibility": {
          "type": "string",
          "enum": [
            "primary_status_surface",
            "keyboard_reachable_detail_surface",
            "primary_and_detail_surface"
          ]
        },
        "summary_sentence": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "recovery_history_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_id"
          },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "has_last_failure": {
                "const": true
              }
            },
            "required": ["has_last_failure"]
          },
          "then": {
            "properties": {
              "reason_class": {
                "not": {
                  "const": "no_previous_failure"
                }
              },
              "reason_code_ref": {
                "$ref": "#/$defs/opaque_id"
              },
              "occurred_at_monotonic": {
                "$ref": "#/$defs/monotonic_timestamp"
              },
              "occurred_at_wall_clock": {
                "$ref": "#/$defs/wall_clock_timestamp"
              }
            }
          }
        }
      ]
    },
    "recovery_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "label_text",
        "action_kind",
        "next_safe_action_hook",
        "review_surface_class",
        "preserves_current_work",
        "routes_through_safe_review",
        "discards_session_state",
        "summary_sentence"
      ],
      "properties": {
        "action_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "label_text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "action_kind": {
          "type": "string",
          "enum": [
            "inspect_status",
            "reveal_last_failure",
            "retry",
            "reconnect",
            "reauthenticate",
            "continue_locally",
            "continue_without_recording",
            "retry_warming",
            "rebuild_index_reviewed",
            "reload_extension_reviewed",
            "quarantine_extension_reviewed",
            "request_admin_policy_review",
            "retry_with_narrower_scope",
            "refresh_evidence",
            "review_patch",
            "rollback_to_checkpoint",
            "boot_previous_version",
            "export_diagnostics",
            "open_without_restore"
          ]
        },
        "next_safe_action_hook": {
          "type": "string",
          "enum": [
            "reveal_last_failure",
            "reconnect_required",
            "reauth_required",
            "continue_in_restricted_mode",
            "open_without_restore",
            "safe_mode",
            "retry_later",
            "request_policy_review",
            "refresh_evidence",
            "retry_with_narrower_scope",
            "compare_before_restore",
            "continue_without_recording"
          ]
        },
        "review_surface_class": {
          "type": "string",
          "enum": [
            "status_item_drawer",
            "repair_card",
            "window_attached_sheet",
            "collaboration_session_panel",
            "ai_review_surface",
            "update_review_sheet",
            "support_center",
            "policy_explainer"
          ]
        },
        "preserves_current_work": {
          "type": "boolean",
          "const": true
        },
        "routes_through_safe_review": {
          "type": "boolean",
          "const": true
        },
        "discards_session_state": {
          "type": "boolean",
          "const": false
        },
        "summary_sentence": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "inspect_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_class",
        "activation_command_id",
        "focus_target_id",
        "accessible_name",
        "keyboard_shortcut_ref",
        "opens_without_pointer",
        "detail_surface_ref"
      ],
      "properties": {
        "surface_class": {
          "type": "string",
          "enum": [
            "status_item_drawer",
            "contextual_banner_detail",
            "activity_center_detail",
            "repair_card",
            "window_attached_sheet",
            "support_center_detail"
          ]
        },
        "activation_command_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "focus_target_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "accessible_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "keyboard_shortcut_ref": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/opaque_id"
            }
          ]
        },
        "opens_without_pointer": {
          "type": "boolean",
          "const": true
        },
        "detail_surface_ref": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },
    "support_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_field_refs",
        "redaction_class",
        "last_failure_preserved",
        "raw_secret_material_excluded",
        "status_token_preserved"
      ],
      "properties": {
        "export_field_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_id"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "redaction_class": {
          "type": "string",
          "enum": [
            "metadata_safe_default",
            "operator_only_restricted",
            "internal_support_restricted"
          ]
        },
        "last_failure_preserved": {
          "type": "boolean",
          "const": true
        },
        "raw_secret_material_excluded": {
          "type": "boolean",
          "const": true
        },
        "status_token_preserved": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "collapse_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "may_collapse_to_generic",
        "collapse_denial_reasons",
        "allowed_collapse_contexts"
      ],
      "properties": {
        "may_collapse_to_generic": {
          "type": "boolean",
          "const": false,
          "description": "Lifecycle-status cards using controlled degraded labels do not collapse to generic error/degraded/unavailable copy."
        },
        "collapse_denial_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "label_semantics_differ",
              "local_editing_contract_differs",
              "write_safety_differs",
              "policy_source_differs",
              "data_or_certainty_differs",
              "recording_or_audit_gap_differs",
              "last_failure_actionable"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "allowed_collapse_contexts": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "none"
            ]
          },
          "minItems": 1,
          "maxItems": 1
        }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status_announced",
        "inspect_path_keyboard_reachable",
        "focus_return_target_ref"
      ],
      "properties": {
        "status_announced": {
          "type": "boolean",
          "const": true
        },
        "inspect_path_keyboard_reachable": {
          "type": "boolean",
          "const": true
        },
        "focus_return_target_ref": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    }
  }
}
