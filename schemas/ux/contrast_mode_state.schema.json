{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/contrast_mode_state.schema.json",
  "title": "Aureline visual adaptation and contrast-mode state",
  "description": "Boundary schema for visual adaptation records frozen in docs/accessibility/visual_adaptation_contract.md. The schema keeps theme, contrast, saturation, motion, and resource posture explicit so high-contrast, low-saturation, forced-colors, reduced-motion, screenshots, support packets, docs captures, diagnostics, diffs, charts, status items, badges, settings locks, and inline severity cues preserve semantic state without relying on hue or animation alone.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/visual_adaptation_state_record" },
    { "$ref": "#/$defs/visual_adaptation_case_record" }
  ],
  "$defs": {
    "contrast_mode_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for visual adaptation records."
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "visual_adaptation_state_record",
        "visual_adaptation_case_record"
      ]
    },
    "nonempty_string": {
      "type": "string",
      "minLength": 1
    },
    "short_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "safe_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1400,
      "description": "Bounded prose safe for docs, support packets, and fixtures. Raw source text, raw file paths, raw URLs, raw terminal bytes, secrets, raw provider payloads, and private user identifiers must not appear."
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "description": "Opaque stable ref, schema ref, document ref, or fixture-local id. Raw paths, source text, URLs, payloads, terminal bytes, and secret material must not appear."
    },
    "ref_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/opaque_ref" },
      "uniqueItems": true
    },
    "nonempty_ref_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/opaque_ref" },
      "uniqueItems": true
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "theme_class": {
      "type": "string",
      "enum": [
        "dark_reference",
        "light_parity",
        "high_contrast_dark",
        "high_contrast_light"
      ],
      "description": "Re-exported from the design-token vocabulary without modification."
    },
    "saturation_class": {
      "type": "string",
      "enum": [
        "standard",
        "low_saturation"
      ]
    },
    "contrast_strategy_class": {
      "type": "string",
      "enum": [
        "standard",
        "high_contrast",
        "forced_colors"
      ]
    },
    "motion_posture_class": {
      "type": "string",
      "enum": [
        "motion_standard",
        "motion_reduced",
        "motion_low_motion",
        "motion_power_saver",
        "motion_critical_hot_path"
      ],
      "description": "Re-exported from the design-token vocabulary without modification."
    },
    "resource_posture_class": {
      "type": "string",
      "enum": [
        "standard",
        "low_resource",
        "power_saver",
        "thermal_pressure",
        "critical_hot_path"
      ]
    },
    "capture_surface_class": {
      "type": "string",
      "enum": [
        "interactive_surface",
        "docs_help_capture",
        "exported_evidence",
        "support_packet",
        "screenshot",
        "public_proof",
        "release_evidence"
      ]
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "editor_gutter",
        "editor_inline",
        "diff_view",
        "diagnostic_list",
        "status_item",
        "badge_or_pill",
        "settings_row",
        "chart",
        "toast",
        "overlay",
        "docs_capture",
        "support_export",
        "screenshot",
        "durable_job_row",
        "terminal",
        "ai_working_state",
        "notification",
        "command_palette",
        "problems_panel",
        "other"
      ]
    },
    "semantic_state_class": {
      "type": "string",
      "enum": [
        "diff_added",
        "diff_removed",
        "diff_modified",
        "breakpoint_enabled",
        "breakpoint_disabled",
        "breakpoint_conditional",
        "folded_range",
        "diagnostic_error",
        "diagnostic_warning",
        "diagnostic_info",
        "diagnostic_hint",
        "trust_restricted",
        "trust_policy_locked",
        "blocked",
        "degraded",
        "stale",
        "read_only",
        "current_execution",
        "running",
        "waiting",
        "completed",
        "failed",
        "ai_draft_pending",
        "ai_applied",
        "chart_threshold",
        "focus_visible",
        "settings_locked",
        "other"
      ]
    },
    "semantic_status_class": {
      "type": "string",
      "enum": [
        "success",
        "warning",
        "danger",
        "info",
        "insight",
        "none"
      ]
    },
    "trust_visual_state_class": {
      "type": "string",
      "enum": [
        "trusted_full",
        "restricted_workspace",
        "remote_target_active",
        "collaboration_active",
        "ai_draft_pending",
        "ai_applied",
        "index_warming",
        "debugging_active",
        "quiet_hours_active",
        "policy_locked",
        "none"
      ]
    },
    "non_color_cue_class": {
      "type": "string",
      "enum": [
        "text_label",
        "icon_glyph",
        "shape",
        "border",
        "stroke_pattern",
        "underline_pattern",
        "fill_pattern",
        "position",
        "count_label",
        "focus_ring",
        "accessible_name",
        "progress_text",
        "static_progress_bar",
        "static_frame",
        "lock_or_shield_glyph",
        "plus_minus_marker",
        "disclosure_glyph",
        "keyboard_detail_route"
      ]
    },
    "motion_family_class": {
      "type": "string",
      "enum": [
        "cursor_blink",
        "terminal_idle_animation",
        "ai_working_indicator",
        "chart_transition",
        "toast_entry_exit",
        "overlay_entry_exit",
        "progress_indicator_loop",
        "skeleton_shimmer",
        "panel_motion",
        "dense_list_reflow",
        "minimap_animation",
        "none"
      ]
    },
    "token_remap_reason_class": {
      "type": "string",
      "enum": [
        "contrast_raise",
        "low_saturation_review",
        "forced_colors_platform_override",
        "semantic_state_preservation",
        "syntax_deemphasis",
        "diff_pattern_required",
        "chart_pattern_required",
        "trust_boundary_preservation",
        "motion_suppressed_static_marker"
      ]
    },
    "denial_reason": {
      "type": "string",
      "enum": [
        "color_alone_conveys_required_meaning",
        "motion_only_conveys_required_meaning",
        "semantic_cue_removed_by_visual_mode",
        "trust_cue_removed_by_visual_mode",
        "settings_lock_rendered_as_plain_disabled",
        "compact_surface_hidden_required_state",
        "forced_colors_drops_shape_or_label",
        "low_saturation_collapses_distinct_states",
        "contrast_target_missing",
        "evidence_visual_mode_metadata_missing",
        "reduced_motion_fallback_missing",
        "resource_simplification_hides_recovery_action",
        "contrast_mode_schema_version_lagging"
      ]
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_epoch",
        "trust_state"
      ],
      "properties": {
        "policy_epoch": { "$ref": "#/$defs/opaque_ref" },
        "trust_state": {
          "type": "string",
          "enum": [
            "trusted",
            "restricted"
          ]
        },
        "execution_context_id": { "$ref": "#/$defs/opaque_ref" }
      }
    },
    "contrast_guarantees": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_text_contrast",
        "minimum_ui_contrast",
        "minimum_focus_contrast",
        "color_alone_prohibited",
        "motion_alone_prohibited"
      ],
      "properties": {
        "minimum_text_contrast": {
          "type": "number",
          "minimum": 1
        },
        "minimum_ui_contrast": {
          "type": "number",
          "minimum": 1
        },
        "minimum_focus_contrast": {
          "type": "number",
          "minimum": 1
        },
        "color_alone_prohibited": { "type": "boolean" },
        "motion_alone_prohibited": { "type": "boolean" },
        "contrast_measurement_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_ref" }
          ]
        },
        "notes": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/safe_summary" }
          ]
        }
      }
    },
    "token_remap_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "source_token_refs",
        "target_token_refs",
        "reason_class",
        "preserves_semantic_state",
        "non_color_cues",
        "denial_reasons"
      ],
      "properties": {
        "rule_id": { "$ref": "#/$defs/opaque_ref" },
        "source_token_refs": { "$ref": "#/$defs/nonempty_ref_array" },
        "target_token_refs": { "$ref": "#/$defs/ref_array" },
        "reason_class": { "$ref": "#/$defs/token_remap_reason_class" },
        "preserves_semantic_state": { "type": "boolean" },
        "non_color_cues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_color_cue_class" },
          "uniqueItems": true
        },
        "forced_colors_safe": { "type": "boolean" },
        "grayscale_safe": { "type": "boolean" },
        "denial_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/denial_reason" },
          "uniqueItems": true
        },
        "notes": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/safe_summary" }
          ]
        }
      }
    },
    "semantic_cue_assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantic_state_class",
        "surface_family",
        "visible_label",
        "semantic_status_class",
        "trust_visual_state_class",
        "token_refs",
        "non_color_cues",
        "high_contrast_preserved",
        "low_saturation_preserved",
        "grayscale_preserved",
        "reduced_motion_preserved",
        "forced_colors_preserved",
        "accessible_name_parts",
        "detail_route_ref",
        "denial_reasons"
      ],
      "properties": {
        "semantic_state_class": { "$ref": "#/$defs/semantic_state_class" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "visible_label": { "$ref": "#/$defs/short_label" },
        "semantic_status_class": { "$ref": "#/$defs/semantic_status_class" },
        "trust_visual_state_class": { "$ref": "#/$defs/trust_visual_state_class" },
        "token_refs": { "$ref": "#/$defs/ref_array" },
        "non_color_cues": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/non_color_cue_class" },
          "uniqueItems": true
        },
        "high_contrast_preserved": { "type": "boolean" },
        "low_saturation_preserved": { "type": "boolean" },
        "grayscale_preserved": { "type": "boolean" },
        "reduced_motion_preserved": { "type": "boolean" },
        "forced_colors_preserved": { "type": "boolean" },
        "accessible_name_parts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/short_label" }
        },
        "detail_route_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_ref" }
          ]
        },
        "denial_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/denial_reason" },
          "uniqueItems": true
        },
        "notes": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/safe_summary" }
          ]
        }
      }
    },
    "reduced_motion_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_family",
        "suppressed_motion_families",
        "replacement_cues",
        "preserves_state_conveyance",
        "allowed_in_power_saver",
        "durable_fallback_ref",
        "denial_reasons"
      ],
      "properties": {
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "suppressed_motion_families": {
          "type": "array",
          "items": { "$ref": "#/$defs/motion_family_class" },
          "uniqueItems": true
        },
        "replacement_cues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_color_cue_class" },
          "uniqueItems": true
        },
        "preserves_state_conveyance": { "type": "boolean" },
        "allowed_in_power_saver": { "type": "boolean" },
        "durable_fallback_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_ref" }
          ]
        },
        "denial_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/denial_reason" },
          "uniqueItems": true
        },
        "notes": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/safe_summary" }
          ]
        }
      }
    },
    "compact_surface_assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_family",
        "compact_label",
        "required_visible_states",
        "non_color_cues",
        "keyboard_detail_route_ref",
        "accessible_name_parts",
        "high_contrast_preserved",
        "grayscale_preserved",
        "reduced_motion_preserved",
        "denial_reasons"
      ],
      "properties": {
        "surface_family": {
          "type": "string",
          "enum": [
            "status_item",
            "badge_or_pill",
            "settings_row",
            "editor_inline",
            "editor_gutter",
            "command_palette"
          ]
        },
        "compact_label": { "$ref": "#/$defs/short_label" },
        "required_visible_states": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/semantic_state_class" },
          "uniqueItems": true
        },
        "non_color_cues": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/non_color_cue_class" },
          "uniqueItems": true
        },
        "keyboard_detail_route_ref": { "$ref": "#/$defs/opaque_ref" },
        "accessible_name_parts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/short_label" }
        },
        "high_contrast_preserved": { "type": "boolean" },
        "grayscale_preserved": { "type": "boolean" },
        "reduced_motion_preserved": { "type": "boolean" },
        "denial_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/denial_reason" },
          "uniqueItems": true
        }
      }
    },
    "evidence_propagation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "visual_adaptation_state_ref",
        "capture_surface_class",
        "docs_help_capture",
        "exported_evidence",
        "support_packet",
        "screenshot",
        "raw_private_material_excluded",
        "metadata_fields"
      ],
      "properties": {
        "visual_adaptation_state_ref": { "$ref": "#/$defs/opaque_ref" },
        "capture_surface_class": { "$ref": "#/$defs/capture_surface_class" },
        "docs_help_capture": { "type": "boolean" },
        "exported_evidence": { "type": "boolean" },
        "support_packet": { "type": "boolean" },
        "screenshot": { "type": "boolean" },
        "raw_private_material_excluded": { "type": "boolean" },
        "metadata_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "visual_adaptation_state_ref",
              "theme_class",
              "saturation_class",
              "contrast_strategy_class",
              "motion_posture_class",
              "resource_posture_class",
              "forced_colors_active",
              "adaptation_row_refs",
              "contrast_mode_schema_version",
              "capture_surface_class",
              "rendered_at",
              "semantic_cue_assertions"
            ]
          },
          "uniqueItems": true
        },
        "review_label": { "$ref": "#/$defs/short_label" },
        "notes": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/safe_summary" }
          ]
        }
      }
    },
    "visual_adaptation_state_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "contrast_mode_schema_version",
        "visual_adaptation_state_id",
        "theme_class",
        "saturation_class",
        "contrast_strategy_class",
        "motion_posture_class",
        "resource_posture_class",
        "forced_colors_active",
        "adaptation_row_refs",
        "contrast_guarantees",
        "token_remap_rules",
        "semantic_cue_assertions",
        "reduced_motion_rules",
        "compact_surface_assertions",
        "evidence_propagation",
        "policy_context",
        "redaction_class",
        "minted_at"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "visual_adaptation_state_record"
        },
        "contrast_mode_schema_version": { "$ref": "#/$defs/contrast_mode_schema_version" },
        "visual_adaptation_state_id": { "$ref": "#/$defs/opaque_ref" },
        "theme_class": { "$ref": "#/$defs/theme_class" },
        "saturation_class": { "$ref": "#/$defs/saturation_class" },
        "contrast_strategy_class": { "$ref": "#/$defs/contrast_strategy_class" },
        "motion_posture_class": { "$ref": "#/$defs/motion_posture_class" },
        "resource_posture_class": { "$ref": "#/$defs/resource_posture_class" },
        "forced_colors_active": { "type": "boolean" },
        "adaptation_row_refs": { "$ref": "#/$defs/nonempty_ref_array" },
        "contrast_guarantees": { "$ref": "#/$defs/contrast_guarantees" },
        "token_remap_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/token_remap_rule" }
        },
        "semantic_cue_assertions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/semantic_cue_assertion" }
        },
        "reduced_motion_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/reduced_motion_rule" }
        },
        "compact_surface_assertions": {
          "type": "array",
          "items": { "$ref": "#/$defs/compact_surface_assertion" }
        },
        "evidence_propagation": { "$ref": "#/$defs/evidence_propagation" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": {
          "type": "string",
          "enum": [
            "metadata_safe_default",
            "metadata_safe",
            "operator_only_restricted",
            "internal_support_restricted"
          ]
        },
        "minted_at": { "$ref": "#/$defs/timestamp" },
        "notes": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/safe_summary" }
          ]
        }
      }
    },
    "visual_adaptation_case_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "contrast_mode_schema_version",
        "case_id",
        "scenario",
        "active_state",
        "surfaces_under_review",
        "semantic_cue_assertions",
        "reduced_motion_rules",
        "compact_surface_assertions",
        "evidence_propagation",
        "assertions",
        "policy_context",
        "redaction_class",
        "minted_at",
        "narrative_refs"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "name",
            "scenario"
          ],
          "properties": {
            "name": { "$ref": "#/$defs/nonempty_string" },
            "scenario": { "$ref": "#/$defs/nonempty_string" },
            "exercised_axes": {
              "type": "object",
              "additionalProperties": true
            },
            "contract_sections": {
              "type": "array",
              "items": { "$ref": "#/$defs/nonempty_string" },
              "uniqueItems": true
            }
          }
        },
        "record_kind": {
          "type": "string",
          "const": "visual_adaptation_case_record"
        },
        "contrast_mode_schema_version": { "$ref": "#/$defs/contrast_mode_schema_version" },
        "case_id": { "$ref": "#/$defs/opaque_ref" },
        "scenario": { "$ref": "#/$defs/safe_summary" },
        "active_state": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "visual_adaptation_state_ref",
            "theme_class",
            "saturation_class",
            "contrast_strategy_class",
            "motion_posture_class",
            "resource_posture_class",
            "forced_colors_active",
            "adaptation_row_refs",
            "contrast_guarantees"
          ],
          "properties": {
            "visual_adaptation_state_ref": { "$ref": "#/$defs/opaque_ref" },
            "theme_class": { "$ref": "#/$defs/theme_class" },
            "saturation_class": { "$ref": "#/$defs/saturation_class" },
            "contrast_strategy_class": { "$ref": "#/$defs/contrast_strategy_class" },
            "motion_posture_class": { "$ref": "#/$defs/motion_posture_class" },
            "resource_posture_class": { "$ref": "#/$defs/resource_posture_class" },
            "forced_colors_active": { "type": "boolean" },
            "adaptation_row_refs": { "$ref": "#/$defs/nonempty_ref_array" },
            "contrast_guarantees": { "$ref": "#/$defs/contrast_guarantees" }
          }
        },
        "surfaces_under_review": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_family" },
          "uniqueItems": true
        },
        "semantic_cue_assertions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/semantic_cue_assertion" }
        },
        "reduced_motion_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/reduced_motion_rule" }
        },
        "compact_surface_assertions": {
          "type": "array",
          "items": { "$ref": "#/$defs/compact_surface_assertion" }
        },
        "evidence_propagation": { "$ref": "#/$defs/evidence_propagation" },
        "assertions": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "visual_mode_switch_preserves_semantic_cues",
            "no_hue_only_state",
            "no_motion_only_state",
            "critical_states_remain_perceivable",
            "compact_surfaces_remain_distinguishable",
            "evidence_carries_visual_mode"
          ],
          "properties": {
            "visual_mode_switch_preserves_semantic_cues": { "type": "boolean" },
            "no_hue_only_state": { "type": "boolean" },
            "no_motion_only_state": { "type": "boolean" },
            "critical_states_remain_perceivable": { "type": "boolean" },
            "compact_surfaces_remain_distinguishable": { "type": "boolean" },
            "evidence_carries_visual_mode": { "type": "boolean" },
            "notes": {
              "oneOf": [
                { "type": "null" },
                { "$ref": "#/$defs/safe_summary" }
              ]
            }
          }
        },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "redaction_class": {
          "type": "string",
          "enum": [
            "metadata_safe_default",
            "metadata_safe",
            "operator_only_restricted",
            "internal_support_restricted"
          ]
        },
        "minted_at": { "$ref": "#/$defs/timestamp" },
        "narrative_refs": { "$ref": "#/$defs/nonempty_ref_array" }
      }
    }
  }
}
