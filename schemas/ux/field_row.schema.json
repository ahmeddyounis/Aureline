{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/field_row.schema.json",
  "title": "Aureline field-row and value-source boundary",
  "description": "Boundary schema for one field_row_record frozen in docs/ux/field_row_and_value_source_contract.md. A field-row record captures the reusable row anatomy for high-impact forms and inspectors: visible label, redaction-aware value projection, source pill, effective-value inspector, validation and apply posture, help, action affordances, exact-row deep-link targets, search-hit highlighting, object-reference picker state, and optional extension slots for path basis, structured diff/preview, and multi-value overflow or duplicate rules. It composes with the staged-review, field-rule, settings effective-value, and policy-explainability contracts. Raw secret bytes, raw policy bodies, raw provider payloads, raw URLs with sensitive components, and sensitive raw filesystem paths never cross this boundary; records carry refs, stable id paths, class labels, summaries, and redaction-aware projections only. Adding an enum value is additive-minor and bumps field_row_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "$ref": "#/$defs/field_row_record",
  "$defs": {
    "field_row_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "field_row_record"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:-][a-z0-9]+)*$",
      "description": "Stable opaque id safe for logs, RPC, support bundles, CLI JSON, and issue handoff."
    },
    "stable_id_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[a-z0-9]+(?:[a-z0-9_.:/-]*[a-z0-9])?$",
      "description": "Stable path-like identity for a referenced object. This is not a display label."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 760
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "settings_form",
        "request_runtime_form",
        "network_transport_form",
        "package_action_form",
        "policy_edit_form",
        "repair_action_form",
        "data_connection_form",
        "support_export",
        "profile_import_form",
        "generic_high_impact_form"
      ]
    },
    "required_class": {
      "type": "string",
      "enum": [
        "required",
        "optional",
        "inherited_when_blank",
        "computed_only"
      ]
    },
    "field_value_kind": {
      "type": "string",
      "enum": [
        "scalar_value",
        "secret_reference",
        "path_reference",
        "object_reference",
        "code_or_structured_value",
        "multi_value",
        "generated_value"
      ]
    },
    "value_redaction_class": {
      "type": "string",
      "enum": [
        "none",
        "redacted_shape",
        "class_label_only",
        "secret_handle_only",
        "metadata_only",
        "omitted"
      ]
    },
    "value_source_class": {
      "type": "string",
      "enum": [
        "policy",
        "user",
        "workspace",
        "profile",
        "imported",
        "external_vault",
        "default",
        "machine",
        "runtime_probe",
        "managed_provider"
      ]
    },
    "source_role_class": {
      "type": "string",
      "enum": [
        "winner",
        "contributing_override",
        "constrained_by_policy",
        "shadowed",
        "fallback_default",
        "external_resolution",
        "imported_basis"
      ]
    },
    "source_freshness_class": {
      "type": "string",
      "enum": [
        "current",
        "pending",
        "stale",
        "inaccessible",
        "unavailable",
        "not_applicable"
      ]
    },
    "source_inspection_class": {
      "type": "string",
      "enum": [
        "inspectable",
        "current_user_cannot_inspect",
        "stale_or_missing",
        "redacted_by_policy",
        "external_only"
      ]
    },
    "source_pill_tone": {
      "type": "string",
      "enum": [
        "neutral",
        "user",
        "workspace",
        "profile",
        "policy",
        "external",
        "imported",
        "default",
        "warning",
        "blocked"
      ]
    },
    "field_validation_state": {
      "type": "string",
      "enum": [
        "pristine",
        "incomplete",
        "invalid",
        "warning",
        "blocked",
        "ready",
        "pending",
        "stale",
        "policy_blocked",
        "inspect_only"
      ]
    },
    "apply_posture_class": {
      "type": "string",
      "enum": [
        "immediate_live_apply",
        "staged_until_apply",
        "preview_first_apply",
        "policy_locked_no_apply",
        "external_source_inspect_only",
        "observe_only_no_apply"
      ]
    },
    "editability_class": {
      "type": "string",
      "enum": [
        "editable_now",
        "editable_staged",
        "editable_with_preview",
        "policy_locked",
        "external_source_read_only",
        "inspect_only",
        "unavailable"
      ]
    },
    "lock_state": {
      "type": "string",
      "enum": [
        "unlocked",
        "read_only",
        "policy_locked",
        "policy_constrained",
        "external_source_locked",
        "stale_authority_locked",
        "capability_locked",
        "managed_admin_only"
      ]
    },
    "dirty_state": {
      "type": "string",
      "enum": [
        "not_dirty",
        "dirty_unapplied",
        "staged_pending_validation",
        "staged_review_ready",
        "applied",
        "discarded"
      ]
    },
    "currentness_class": {
      "type": "string",
      "enum": [
        "current",
        "pending",
        "stale",
        "permission_limited",
        "source_unavailable",
        "not_applicable"
      ]
    },
    "help_visibility_class": {
      "type": "string",
      "enum": [
        "inline",
        "tooltip",
        "hovercard",
        "peek",
        "sheet",
        "docs_route"
      ]
    },
    "action_kind": {
      "type": "string",
      "enum": [
        "edit_value",
        "apply_now",
        "stage_change",
        "open_preview",
        "open_policy_details",
        "open_source",
        "open_effective_value_inspector",
        "open_target",
        "clear_value",
        "reset_value",
        "copy_stable_id",
        "show_help",
        "revalidate",
        "no_action"
      ]
    },
    "action_availability_class": {
      "type": "string",
      "enum": [
        "enabled",
        "disabled",
        "disabled_policy_blocked",
        "disabled_permission_denied",
        "disabled_stale_reference",
        "inspect_only",
        "hidden_by_policy"
      ]
    },
    "object_reference_state": {
      "type": "string",
      "enum": [
        "current",
        "stale_label_drifted",
        "stale_target_missing",
        "permission_lost",
        "provider_unreachable",
        "deleted_or_revoked",
        "unresolved"
      ]
    },
    "permission_state": {
      "type": "string",
      "enum": [
        "can_inspect",
        "cannot_inspect_missing_scope",
        "cannot_inspect_policy",
        "cannot_inspect_provider",
        "unknown",
        "not_applicable"
      ]
    },
    "stale_warning_class": {
      "type": "string",
      "enum": [
        "label_changed",
        "target_missing",
        "permission_narrowed",
        "provider_unreachable",
        "deleted_or_revoked",
        "source_stale",
        "none"
      ]
    },
    "path_basis_class": {
      "type": "string",
      "enum": [
        "workspace_root",
        "containing_file",
        "selected_target",
        "current_working_directory",
        "remote_target",
        "container_root",
        "user_chosen_basis",
        "not_applicable"
      ]
    },
    "duplicate_rule_class": {
      "type": "string",
      "enum": [
        "reject_duplicates",
        "preserve_with_warning",
        "merge_by_stable_id",
        "allow_after_review",
        "not_applicable"
      ]
    },
    "overflow_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "visible_all",
        "hidden_with_count",
        "summarized_with_inspect_path"
      ]
    },
    "search_highlight_field": {
      "type": "string",
      "enum": [
        "label",
        "value_preview",
        "source_label",
        "help_text",
        "stable_id_path",
        "lock_explanation",
        "action_label"
      ]
    },
    "field_label": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text",
        "required_class",
        "description"
      ],
      "properties": {
        "text": { "$ref": "#/$defs/non_empty_string" },
        "required_class": { "$ref": "#/$defs/required_class" },
        "description": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "value_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value_kind",
        "value_redaction_class",
        "current_value_ref",
        "effective_value_ref",
        "value_preview",
        "changed_from_live"
      ],
      "properties": {
        "value_kind": { "$ref": "#/$defs/field_value_kind" },
        "value_redaction_class": { "$ref": "#/$defs/value_redaction_class" },
        "current_value_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "effective_value_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "value_preview": { "$ref": "#/$defs/reviewable_sentence" },
        "changed_from_live": { "type": "boolean" }
      }
    },
    "source_pill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_class",
        "label",
        "tone",
        "explanation_action_ref",
        "inspector_action_ref"
      ],
      "properties": {
        "source_class": { "$ref": "#/$defs/value_source_class" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "tone": { "$ref": "#/$defs/source_pill_tone" },
        "explanation_action_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "inspector_action_ref": { "$ref": "#/$defs/opaque_id" }
      }
    },
    "source_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "source_class",
        "source_label",
        "precedence_rank",
        "role_class",
        "freshness_class",
        "inspection_class",
        "stable_source_id_path",
        "explanation",
        "open_source_action_ref",
        "warning"
      ],
      "properties": {
        "source_ref": { "$ref": "#/$defs/opaque_id" },
        "source_class": { "$ref": "#/$defs/value_source_class" },
        "source_label": { "$ref": "#/$defs/non_empty_string" },
        "precedence_rank": {
          "type": "integer",
          "minimum": 1
        },
        "role_class": { "$ref": "#/$defs/source_role_class" },
        "freshness_class": { "$ref": "#/$defs/source_freshness_class" },
        "inspection_class": { "$ref": "#/$defs/source_inspection_class" },
        "stable_source_id_path": { "$ref": "#/$defs/stable_id_path" },
        "explanation": { "$ref": "#/$defs/reviewable_sentence" },
        "open_source_action_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "warning": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      }
    },
    "effective_value_inspector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inspector_ref",
        "precedence_order",
        "source_entries",
        "winning_source_ref",
        "effective_value_ref",
        "explanation",
        "one_interaction_available"
      ],
      "properties": {
        "inspector_ref": { "$ref": "#/$defs/opaque_id" },
        "precedence_order": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/value_source_class" }
        },
        "source_entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source_entry" }
        },
        "winning_source_ref": { "$ref": "#/$defs/opaque_id" },
        "effective_value_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "explanation": { "$ref": "#/$defs/reviewable_sentence" },
        "one_interaction_available": { "type": "boolean" }
      }
    },
    "row_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_validation_state",
        "apply_posture_class",
        "editability_class",
        "lock_state",
        "dirty_state",
        "currentness_class",
        "state_summary",
        "policy_or_external_explanation_ref"
      ],
      "properties": {
        "field_validation_state": { "$ref": "#/$defs/field_validation_state" },
        "apply_posture_class": { "$ref": "#/$defs/apply_posture_class" },
        "editability_class": { "$ref": "#/$defs/editability_class" },
        "lock_state": { "$ref": "#/$defs/lock_state" },
        "dirty_state": { "$ref": "#/$defs/dirty_state" },
        "currentness_class": { "$ref": "#/$defs/currentness_class" },
        "state_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "policy_or_external_explanation_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "row_help": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "help_text",
        "help_visibility_class",
        "help_action_ref",
        "explanation_refs",
        "one_interaction_inspectable"
      ],
      "properties": {
        "help_text": { "$ref": "#/$defs/reviewable_sentence" },
        "help_visibility_class": { "$ref": "#/$defs/help_visibility_class" },
        "help_action_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "explanation_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "one_interaction_inspectable": { "type": "boolean" }
      }
    },
    "row_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "action_kind",
        "label",
        "availability_class",
        "target_ref"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/opaque_id" },
        "action_kind": { "$ref": "#/$defs/action_kind" },
        "label": { "$ref": "#/$defs/non_empty_string" },
        "availability_class": { "$ref": "#/$defs/action_availability_class" },
        "target_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "action_summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/reviewable_sentence" }
          ]
        }
      }
    },
    "stale_reference_warning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "warning_class",
        "summary",
        "blocks_apply"
      ],
      "properties": {
        "warning_class": { "$ref": "#/$defs/stale_warning_class" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" },
        "blocks_apply": { "type": "boolean" }
      }
    },
    "permission_note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "permission_state",
        "summary"
      ],
      "properties": {
        "permission_state": { "$ref": "#/$defs/permission_state" },
        "summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "object_reference_picker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference_kind",
        "display_label",
        "stable_id_path",
        "stable_id_ref",
        "reference_state",
        "display_label_changed",
        "previous_display_label",
        "stale_reference_warning",
        "permission_note",
        "open_target_action_ref",
        "copy_stable_id_action_ref",
        "identity_survives_label_change"
      ],
      "properties": {
        "reference_kind": { "$ref": "#/$defs/non_empty_string" },
        "display_label": { "$ref": "#/$defs/non_empty_string" },
        "stable_id_path": { "$ref": "#/$defs/stable_id_path" },
        "stable_id_ref": { "$ref": "#/$defs/opaque_id" },
        "reference_state": { "$ref": "#/$defs/object_reference_state" },
        "display_label_changed": { "type": "boolean" },
        "previous_display_label": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/non_empty_string" }
          ]
        },
        "stale_reference_warning": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/stale_reference_warning" }
          ]
        },
        "permission_note": { "$ref": "#/$defs/permission_note" },
        "open_target_action_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "copy_stable_id_action_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "identity_survives_label_change": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "display_label_changed": { "const": true }
            }
          },
          "then": {
            "properties": {
              "previous_display_label": { "$ref": "#/$defs/non_empty_string" },
              "identity_survives_label_change": { "const": true }
            }
          }
        },
        {
          "if": {
            "properties": {
              "reference_state": { "const": "permission_lost" }
            }
          },
          "then": {
            "properties": {
              "permission_note": {
                "properties": {
                  "permission_state": {
                    "enum": [
                      "cannot_inspect_missing_scope",
                      "cannot_inspect_policy",
                      "cannot_inspect_provider",
                      "unknown"
                    ]
                  }
                }
              }
            }
          }
        }
      ]
    },
    "exact_row_deep_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_ref",
        "anchor_ref",
        "focus_target_ref",
        "reveals_source",
        "reveals_effective_value",
        "reveals_lock_or_override"
      ],
      "properties": {
        "route_ref": { "$ref": "#/$defs/non_empty_string" },
        "anchor_ref": { "$ref": "#/$defs/opaque_id" },
        "focus_target_ref": { "$ref": "#/$defs/opaque_id" },
        "reveals_source": { "type": "boolean" },
        "reveals_effective_value": { "type": "boolean" },
        "reveals_lock_or_override": { "type": "boolean" }
      }
    },
    "search_hit_highlight": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "highlight_field",
        "matched_text",
        "highlight_summary"
      ],
      "properties": {
        "highlight_field": { "$ref": "#/$defs/search_highlight_field" },
        "matched_text": { "$ref": "#/$defs/non_empty_string" },
        "highlight_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "search_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "search_document_ref",
        "hit_highlights",
        "opens_exact_row"
      ],
      "properties": {
        "search_document_ref": { "$ref": "#/$defs/opaque_id" },
        "hit_highlights": {
          "type": "array",
          "items": { "$ref": "#/$defs/search_hit_highlight" }
        },
        "opens_exact_row": { "type": "boolean" }
      }
    },
    "path_basis_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_basis_class",
        "basis_ref",
        "basis_summary"
      ],
      "properties": {
        "path_basis_class": { "$ref": "#/$defs/path_basis_class" },
        "basis_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        },
        "basis_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "structured_diff_preview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_ref",
        "preview_summary",
        "opens_before_apply"
      ],
      "properties": {
        "preview_ref": { "$ref": "#/$defs/opaque_id" },
        "preview_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "opens_before_apply": { "type": "boolean" }
      }
    },
    "multi_value_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_count",
        "visible_item_count",
        "overflow_class",
        "duplicate_rule_class",
        "order_is_meaningful",
        "inspect_overflow_action_ref"
      ],
      "properties": {
        "item_count": {
          "type": "integer",
          "minimum": 0
        },
        "visible_item_count": {
          "type": "integer",
          "minimum": 0
        },
        "overflow_class": { "$ref": "#/$defs/overflow_class" },
        "duplicate_rule_class": { "$ref": "#/$defs/duplicate_rule_class" },
        "order_is_meaningful": { "type": "boolean" },
        "inspect_overflow_action_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ]
        }
      }
    },
    "extension_slots": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_basis",
        "structured_diff_preview",
        "multi_value_rules"
      ],
      "properties": {
        "path_basis": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/path_basis_disclosure" }
          ]
        },
        "structured_diff_preview": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/structured_diff_preview" }
          ]
        },
        "multi_value_rules": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/multi_value_rules" }
          ]
        }
      }
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name",
        "scenario"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/reviewable_sentence" },
        "exercised_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        }
      }
    },
    "field_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "field_row_id",
        "surface_family",
        "canonical_field_path",
        "exact_row_deep_link",
        "label",
        "value",
        "source_pill",
        "effective_value_inspector",
        "state",
        "help",
        "primary_action",
        "secondary_actions",
        "extension_slots",
        "emitted_at",
        "narrative_refs"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/field_row_schema_version" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "field_row_id": { "$ref": "#/$defs/opaque_id" },
        "surface_family": { "$ref": "#/$defs/surface_family" },
        "canonical_field_path": { "$ref": "#/$defs/non_empty_string" },
        "exact_row_deep_link": { "$ref": "#/$defs/exact_row_deep_link" },
        "label": { "$ref": "#/$defs/field_label" },
        "value": { "$ref": "#/$defs/value_projection" },
        "source_pill": { "$ref": "#/$defs/source_pill" },
        "effective_value_inspector": { "$ref": "#/$defs/effective_value_inspector" },
        "state": { "$ref": "#/$defs/row_state" },
        "help": { "$ref": "#/$defs/row_help" },
        "primary_action": { "$ref": "#/$defs/row_action" },
        "secondary_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/row_action" }
        },
        "object_reference_picker": { "$ref": "#/$defs/object_reference_picker" },
        "search_projection": { "$ref": "#/$defs/search_projection" },
        "extension_slots": { "$ref": "#/$defs/extension_slots" },
        "emitted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "narrative_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "properties": {
                  "apply_posture_class": { "const": "policy_locked_no_apply" }
                }
              }
            }
          },
          "then": {
            "properties": {
              "state": {
                "properties": {
                  "lock_state": {
                    "enum": [
                      "policy_locked",
                      "policy_constrained",
                      "managed_admin_only"
                    ]
                  },
                  "editability_class": { "const": "policy_locked" }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "properties": {
                  "apply_posture_class": { "const": "external_source_inspect_only" }
                }
              }
            }
          },
          "then": {
            "properties": {
              "state": {
                "properties": {
                  "editability_class": {
                    "enum": [
                      "external_source_read_only",
                      "inspect_only"
                    ]
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
