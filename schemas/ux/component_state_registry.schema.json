{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/component_state_registry.schema.json",
  "title": "Aureline beta component-state registry",
  "description": "Boundary schema for the beta component-state registry consumed by launch-critical shell surfaces. The registry publishes canonical Empty, Loading, Pending, Degraded, Blocked, Error, and Completed state families; badge and notice cue families for lifecycle, route, readiness, and policy semantics; launch-surface consumer rows; and invariants that reject hue-only state meaning, spinner-only blocked states, hover-only critical actions, and missing focus visibility. Raw screenshots, raw private paths, raw provider payloads, raw URLs, raw policy bodies, and raw secret material never cross this boundary.",
  "type": "object",
  "$ref": "#/$defs/component_state_registry_record",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "component_state_registry_beta_record"
    },
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "short_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 760
    },
    "canonical_state_class": {
      "type": "string",
      "enum": [
        "empty",
        "loading",
        "pending",
        "degraded",
        "blocked",
        "error",
        "completed"
      ]
    },
    "component_taxonomy_state_class": {
      "type": "string",
      "enum": [
        "idle",
        "hover",
        "focus",
        "focus_visible",
        "pressed",
        "selected",
        "current",
        "disabled",
        "read_only",
        "loading",
        "pending",
        "degraded",
        "stale",
        "restricted",
        "policy_blocked",
        "locked",
        "warning",
        "destructive",
        "reconnecting",
        "completed",
        "restored",
        "quiet_hours_held"
      ]
    },
    "cue_family_class": {
      "type": "string",
      "enum": ["lifecycle", "route", "readiness", "policy"]
    },
    "cue_kind": {
      "type": "string",
      "enum": ["badge", "notice"]
    },
    "non_color_cue_class": {
      "type": "string",
      "enum": [
        "label_text",
        "icon",
        "border",
        "shape",
        "progress_indicator",
        "lock_or_shield_glyph",
        "check_or_selection_marker"
      ]
    },
    "theme_class": {
      "type": "string",
      "enum": [
        "dark_reference",
        "light_parity",
        "high_contrast_dark",
        "high_contrast_light"
      ]
    },
    "density_class": {
      "type": "string",
      "enum": ["compact", "standard", "comfortable"]
    },
    "motion_posture": {
      "type": "string",
      "enum": [
        "motion_standard",
        "motion_reduced",
        "motion_low_motion",
        "motion_power_saver",
        "motion_critical_hot_path"
      ]
    },
    "launch_surface_class": {
      "type": "string",
      "enum": [
        "shell_chrome",
        "start_center",
        "command_palette",
        "search_surface",
        "dialog_sheet",
        "trust_prompt",
        "notification_envelope",
        "help_about_row",
        "settings_root",
        "activity_center_row"
      ]
    },
    "launch_priority": {
      "type": "string",
      "enum": ["launch_critical", "supporting", "out_of_scope"]
    },
    "token_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["foreground", "border", "fill"],
      "properties": {
        "foreground": { "$ref": "#/$defs/ref" },
        "border": { "$ref": "#/$defs/ref" },
        "fill": { "$ref": "#/$defs/ref" }
      }
    },
    "component_state_family_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "state_class",
        "display_label",
        "taxonomy_state_refs",
        "token_refs",
        "required_non_color_cues",
        "hue_only_allowed",
        "spinner_only_allowed",
        "hover_only_critical_action_allowed",
        "persistent_disclosure_required",
        "screen_reader_label",
        "copy_rule"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "component_state_family_beta_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "state_class": { "$ref": "#/$defs/canonical_state_class" },
        "display_label": { "$ref": "#/$defs/short_text" },
        "taxonomy_state_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/component_taxonomy_state_class" },
          "uniqueItems": true
        },
        "token_refs": { "$ref": "#/$defs/token_refs" },
        "required_non_color_cues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_color_cue_class" },
          "uniqueItems": true
        },
        "hue_only_allowed": { "type": "boolean", "const": false },
        "spinner_only_allowed": { "type": "boolean", "const": false },
        "hover_only_critical_action_allowed": {
          "type": "boolean",
          "const": false
        },
        "persistent_disclosure_required": { "type": "boolean", "const": true },
        "screen_reader_label": { "$ref": "#/$defs/short_text" },
        "copy_rule": { "$ref": "#/$defs/short_text" }
      }
    },
    "cue_vocabulary_token": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "token",
        "label",
        "state_class_ref",
        "token_refs",
        "required_non_color_cues"
      ],
      "properties": {
        "token": { "$ref": "#/$defs/ref" },
        "label": { "$ref": "#/$defs/short_text" },
        "state_class_ref": { "$ref": "#/$defs/canonical_state_class" },
        "token_refs": { "$ref": "#/$defs/token_refs" },
        "required_non_color_cues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_color_cue_class" },
          "uniqueItems": true
        }
      }
    },
    "cue_family_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "family_class",
        "cue_kind",
        "honesty_fallback_token",
        "requires_text_shape_fallback",
        "required_non_color_cues",
        "vocabulary_tokens"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "component_cue_family_beta_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "family_class": { "$ref": "#/$defs/cue_family_class" },
        "cue_kind": { "$ref": "#/$defs/cue_kind" },
        "honesty_fallback_token": { "$ref": "#/$defs/ref" },
        "requires_text_shape_fallback": { "type": "boolean", "const": true },
        "required_non_color_cues": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/non_color_cue_class" },
          "uniqueItems": true
        },
        "vocabulary_tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/cue_vocabulary_token" }
        }
      }
    },
    "launch_surface_consumer_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "surface_class",
        "launch_priority",
        "consumer_refs",
        "consumes_component_states",
        "consumes_cue_families",
        "required_theme_classes",
        "required_density_classes",
        "required_motion_postures",
        "critical_actions_keyboard_reachable",
        "focus_visibility_preserved",
        "no_color_only_state_meaning",
        "waiver_ref"
      ],
      "properties": {
        "record_kind": {
          "type": "string",
          "const": "launch_surface_consumer_beta_record"
        },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "surface_class": { "$ref": "#/$defs/launch_surface_class" },
        "launch_priority": { "$ref": "#/$defs/launch_priority" },
        "consumer_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ref" },
          "uniqueItems": true
        },
        "consumes_component_states": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/canonical_state_class" },
          "uniqueItems": true
        },
        "consumes_cue_families": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/cue_family_class" },
          "uniqueItems": true
        },
        "required_theme_classes": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/theme_class" },
          "uniqueItems": true
        },
        "required_density_classes": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/density_class" },
          "uniqueItems": true
        },
        "required_motion_postures": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/motion_posture" },
          "uniqueItems": true
        },
        "critical_actions_keyboard_reachable": { "type": "boolean" },
        "focus_visibility_preserved": { "type": "boolean" },
        "no_color_only_state_meaning": { "type": "boolean" },
        "waiver_ref": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/ref" }]
        }
      }
    },
    "component_state_registry_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "schema_version",
        "shared_contract_ref",
        "registry_id",
        "source_refs",
        "runtime_consumer_refs",
        "component_state_families",
        "cue_families",
        "launch_surface_consumers"
      ],
      "properties": {
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "shared_contract_ref": { "$ref": "#/$defs/ref" },
        "registry_id": { "$ref": "#/$defs/ref" },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ref" },
          "uniqueItems": true
        },
        "runtime_consumer_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ref" },
          "uniqueItems": true
        },
        "component_state_families": {
          "type": "array",
          "minItems": 7,
          "items": { "$ref": "#/$defs/component_state_family_row" }
        },
        "cue_families": {
          "type": "array",
          "minItems": 8,
          "items": { "$ref": "#/$defs/cue_family_row" }
        },
        "launch_surface_consumers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/launch_surface_consumer_row" }
        }
      }
    }
  }
}
