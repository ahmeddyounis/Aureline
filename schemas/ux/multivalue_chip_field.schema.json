{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/multivalue_chip_field.schema.json",
  "title": "Aureline multi-value list / chip field boundary",
  "description": "Boundary schema for one multivalue_chip_field_record frozen in docs/ux/path_code_and_multivalue_field_contract.md. The record covers add/remove/reorder semantics, duplicate handling, overflow visibility, bulk-paste behavior, and export/serialization truth for any field whose value is a list of chips/tags. It composes with the field_rule_record (typically a multi_value_list or key_value_map field_display_class) for redaction, validation, copy/export posture, and unsafe-value warnings, and with the field_row_record for label, source pill, and apply posture. Raw chip payloads (raw secrets, raw URLs with sensitive components, raw provider payloads, raw absolute paths, raw stdout/stderr, raw clipboard bytes, raw OAuth tokens) never cross this boundary; the record carries chip handle refs, counts, duplicate reports, normalization summaries, and serialization-class chips only. Adding an enum value is additive-minor and bumps multivalue_chip_field_schema_version; repurposing an existing value is breaking and requires a new decision row.",
  "type": "object",
  "$ref": "#/$defs/multivalue_chip_field_record",
  "$defs": {
    "multivalue_chip_field_schema_version": {
      "type": "integer",
      "const": 1
    },
    "record_kind": {
      "type": "string",
      "const": "multivalue_chip_field_record"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[_.:/-][a-z0-9]+)*$",
      "description": "Stable opaque id safe for logs, RPC, support bundles, screenshots, and fixtures."
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 760
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "surface_family": {
      "type": "string",
      "enum": [
        "settings_form",
        "scaffolding_form",
        "request_workspace_form",
        "package_action_form",
        "repair_action_form",
        "data_connection_form",
        "transport_form",
        "support_export",
        "generic_high_impact_form"
      ]
    },
    "chip_value_shape_class": {
      "type": "string",
      "enum": [
        "scalar_chip",
        "key_value_chip",
        "path_chip",
        "endpoint_chip",
        "secret_handle_chip",
        "provider_resource_chip",
        "object_reference_chip",
        "tag_chip",
        "glob_chip",
        "header_or_param_chip",
        "env_key_chip"
      ]
    },
    "add_method_class": {
      "type": "string",
      "enum": [
        "keyboard_separator",
        "picker_only",
        "paste_with_review_required",
        "drag_drop_with_disclosure",
        "scan_from_referenced_object",
        "blocked_read_only"
      ]
    },
    "remove_semantics_class": {
      "type": "string",
      "enum": [
        "direct_remove_with_undo",
        "remove_requires_review",
        "remove_blocked_by_policy",
        "remove_blocked_required_value",
        "remove_only_in_bulk_review"
      ]
    },
    "reorder_semantics_class": {
      "type": "string",
      "enum": [
        "reorder_with_drag",
        "reorder_with_keyboard",
        "reorder_only_in_review",
        "order_meaningful_no_reorder",
        "order_irrelevant",
        "order_canonicalized_on_save_with_warning"
      ]
    },
    "duplicate_policy_class": {
      "type": "string",
      "enum": [
        "reject_duplicates",
        "merge_by_stable_id",
        "preserve_with_warning",
        "last_value_wins_requires_review",
        "case_insensitive_dedupe_with_warning",
        "not_applicable_unique_by_construction"
      ]
    },
    "overflow_visibility_class": {
      "type": "string",
      "enum": [
        "all_inline",
        "virtualized_window",
        "n_more_chip_with_expand",
        "summary_count_only_inspect_required",
        "hidden_count_blocks_apply"
      ]
    },
    "bulk_paste_policy_class": {
      "type": "string",
      "enum": [
        "bulk_paste_blocked",
        "bulk_paste_inline_with_split_rule",
        "bulk_paste_promotes_to_review",
        "bulk_paste_requires_field_rule_review"
      ]
    },
    "bulk_paste_split_rule_class": {
      "type": "string",
      "enum": [
        "newline_split",
        "comma_split",
        "whitespace_split",
        "custom_delimiter_split",
        "structured_array_paste",
        "not_applicable"
      ]
    },
    "serialization_truth_class": {
      "type": "string",
      "enum": [
        "order_preserving_array",
        "set_canonical_unordered",
        "ordered_key_value_pair_list",
        "unordered_key_value_map",
        "delimited_string_with_declared_separator",
        "chip_handle_list_refs_only"
      ]
    },
    "export_truth_class": {
      "type": "string",
      "enum": [
        "export_matches_visible_order",
        "export_canonicalizes_order_with_warning",
        "export_redacts_chip_payload_to_handle_only",
        "export_excluded_class_change_required"
      ]
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "$ref": "#/$defs/non_empty_string" },
        "scenario": { "$ref": "#/$defs/reviewable_sentence" },
        "exercised_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        }
      }
    },
    "list_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_value_count",
        "visible_chip_count",
        "hidden_chip_count",
        "duplicate_count"
      ],
      "properties": {
        "total_value_count": { "$ref": "#/$defs/non_negative_integer" },
        "visible_chip_count": { "$ref": "#/$defs/non_negative_integer" },
        "hidden_chip_count": { "$ref": "#/$defs/non_negative_integer" },
        "duplicate_count": { "$ref": "#/$defs/non_negative_integer" }
      }
    },
    "bulk_paste_behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bulk_paste_policy_class",
        "split_rule_class",
        "trims_each_value",
        "applies_duplicate_policy_to_paste",
        "bulk_paste_summary"
      ],
      "properties": {
        "bulk_paste_policy_class": { "$ref": "#/$defs/bulk_paste_policy_class" },
        "split_rule_class": { "$ref": "#/$defs/bulk_paste_split_rule_class" },
        "trims_each_value": { "type": "boolean" },
        "applies_duplicate_policy_to_paste": { "type": "boolean" },
        "preview_required_before_apply": { "type": "boolean" },
        "bulk_paste_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "serialization_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "serialization_truth_class",
        "export_truth_class",
        "serialization_summary"
      ],
      "properties": {
        "serialization_truth_class": { "$ref": "#/$defs/serialization_truth_class" },
        "export_truth_class": { "$ref": "#/$defs/export_truth_class" },
        "delimiter_summary": {
          "oneOf": [
            { "$ref": "#/$defs/reviewable_sentence" },
            { "type": "null" }
          ],
          "description": "Required when serialization_truth_class is delimited_string_with_declared_separator. Names the declared separator class without embedding raw separator bytes."
        },
        "serialization_summary": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "multivalue_chip_field_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_kind",
        "multivalue_chip_field_id",
        "field_rule_record_ref",
        "field_row_record_ref",
        "surface_families",
        "field_label",
        "chip_value_shape_class",
        "add_method_class",
        "remove_semantics_class",
        "reorder_semantics_class",
        "duplicate_policy_class",
        "overflow_visibility_class",
        "list_counts",
        "bulk_paste_behavior",
        "serialization_report",
        "narrative_refs",
        "emitted_at"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/multivalue_chip_field_schema_version" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "multivalue_chip_field_id": { "$ref": "#/$defs/opaque_id" },
        "field_rule_record_ref": { "$ref": "#/$defs/opaque_id" },
        "field_row_record_ref": { "$ref": "#/$defs/opaque_id" },
        "surface_families": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_family" },
          "uniqueItems": true
        },
        "field_label": { "$ref": "#/$defs/non_empty_string" },
        "chip_value_shape_class": { "$ref": "#/$defs/chip_value_shape_class" },
        "add_method_class": { "$ref": "#/$defs/add_method_class" },
        "remove_semantics_class": { "$ref": "#/$defs/remove_semantics_class" },
        "reorder_semantics_class": { "$ref": "#/$defs/reorder_semantics_class" },
        "duplicate_policy_class": { "$ref": "#/$defs/duplicate_policy_class" },
        "overflow_visibility_class": { "$ref": "#/$defs/overflow_visibility_class" },
        "list_counts": { "$ref": "#/$defs/list_counts" },
        "bulk_paste_behavior": { "$ref": "#/$defs/bulk_paste_behavior" },
        "serialization_report": { "$ref": "#/$defs/serialization_report" },
        "narrative_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/non_empty_string" },
          "uniqueItems": true
        },
        "emitted_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" }
      },
      "allOf": [
        {
          "description": "Visible + hidden chip counts must equal total value count so silent truncation is impossible.",
          "properties": {
            "list_counts": {
              "type": "object"
            }
          }
        },
        {
          "description": "When overflow class is all_inline or virtualized_window, hidden chips must be zero so the visible projection accounts for every value.",
          "if": {
            "properties": {
              "overflow_visibility_class": {
                "enum": ["all_inline", "virtualized_window"]
              }
            },
            "required": ["overflow_visibility_class"]
          },
          "then": {
            "properties": {
              "list_counts": {
                "properties": {
                  "hidden_chip_count": { "const": 0 }
                },
                "required": ["hidden_chip_count"]
              }
            }
          }
        },
        {
          "description": "When overflow class is n_more_chip_with_expand or summary_count_only_inspect_required, hidden chip count must be greater than zero so the projected disclosure has a real overflow to expand.",
          "if": {
            "properties": {
              "overflow_visibility_class": {
                "enum": [
                  "n_more_chip_with_expand",
                  "summary_count_only_inspect_required"
                ]
              }
            },
            "required": ["overflow_visibility_class"]
          },
          "then": {
            "properties": {
              "list_counts": {
                "properties": {
                  "hidden_chip_count": { "type": "integer", "minimum": 1 }
                },
                "required": ["hidden_chip_count"]
              }
            }
          }
        },
        {
          "description": "Hidden-count overflow that blocks apply must publish hidden count > 0 and route through review before apply.",
          "if": {
            "properties": {
              "overflow_visibility_class": { "const": "hidden_count_blocks_apply" }
            },
            "required": ["overflow_visibility_class"]
          },
          "then": {
            "properties": {
              "list_counts": {
                "properties": {
                  "hidden_chip_count": { "type": "integer", "minimum": 1 }
                },
                "required": ["hidden_chip_count"]
              }
            }
          }
        },
        {
          "description": "Reject-duplicates and merge-by-stable-id policies leave duplicate_count at zero by construction.",
          "if": {
            "properties": {
              "duplicate_policy_class": {
                "enum": ["reject_duplicates", "merge_by_stable_id", "not_applicable_unique_by_construction"]
              }
            },
            "required": ["duplicate_policy_class"]
          },
          "then": {
            "properties": {
              "list_counts": {
                "properties": { "duplicate_count": { "const": 0 } },
                "required": ["duplicate_count"]
              }
            }
          }
        },
        {
          "description": "When the duplicate policy preserves duplicates with warning or last-value-wins requires review, duplicate_count may be non-zero, and apply must route through a review surface before serialization.",
          "if": {
            "properties": {
              "duplicate_policy_class": {
                "enum": [
                  "preserve_with_warning",
                  "last_value_wins_requires_review",
                  "case_insensitive_dedupe_with_warning"
                ]
              }
            },
            "required": ["duplicate_policy_class"]
          },
          "then": {
            "properties": {
              "list_counts": {
                "properties": {
                  "duplicate_count": { "type": "integer", "minimum": 0 }
                },
                "required": ["duplicate_count"]
              }
            }
          }
        },
        {
          "description": "Bulk paste blocked must pair with split_rule_class not_applicable so no implicit split is implied.",
          "if": {
            "properties": {
              "bulk_paste_behavior": {
                "properties": {
                  "bulk_paste_policy_class": { "const": "bulk_paste_blocked" }
                },
                "required": ["bulk_paste_policy_class"]
              }
            },
            "required": ["bulk_paste_behavior"]
          },
          "then": {
            "properties": {
              "bulk_paste_behavior": {
                "properties": {
                  "split_rule_class": { "const": "not_applicable" }
                },
                "required": ["split_rule_class"]
              }
            }
          }
        },
        {
          "description": "Bulk paste promoted to review or to field-rule review must require preview_required_before_apply true.",
          "if": {
            "properties": {
              "bulk_paste_behavior": {
                "properties": {
                  "bulk_paste_policy_class": {
                    "enum": [
                      "bulk_paste_promotes_to_review",
                      "bulk_paste_requires_field_rule_review"
                    ]
                  }
                },
                "required": ["bulk_paste_policy_class"]
              }
            },
            "required": ["bulk_paste_behavior"]
          },
          "then": {
            "properties": {
              "bulk_paste_behavior": {
                "properties": {
                  "preview_required_before_apply": { "const": true }
                },
                "required": ["preview_required_before_apply"]
              }
            }
          }
        },
        {
          "description": "Delimited-string serialization must publish a delimiter_summary so the declared separator is reviewable.",
          "if": {
            "properties": {
              "serialization_report": {
                "properties": {
                  "serialization_truth_class": { "const": "delimited_string_with_declared_separator" }
                },
                "required": ["serialization_truth_class"]
              }
            },
            "required": ["serialization_report"]
          },
          "then": {
            "properties": {
              "serialization_report": {
                "properties": {
                  "delimiter_summary": { "$ref": "#/$defs/reviewable_sentence" }
                },
                "required": ["delimiter_summary"]
              }
            }
          }
        },
        {
          "description": "Set-canonical-unordered serialization must pair with order_irrelevant or order_canonicalized_on_save_with_warning so the visible reorder semantics match the persisted shape.",
          "if": {
            "properties": {
              "serialization_report": {
                "properties": {
                  "serialization_truth_class": { "const": "set_canonical_unordered" }
                },
                "required": ["serialization_truth_class"]
              }
            },
            "required": ["serialization_report"]
          },
          "then": {
            "properties": {
              "reorder_semantics_class": {
                "enum": [
                  "order_irrelevant",
                  "order_canonicalized_on_save_with_warning"
                ]
              }
            }
          }
        },
        {
          "description": "Secret-handle chip shapes must export only handle refs, never raw payloads.",
          "if": {
            "properties": {
              "chip_value_shape_class": { "const": "secret_handle_chip" }
            },
            "required": ["chip_value_shape_class"]
          },
          "then": {
            "properties": {
              "serialization_report": {
                "properties": {
                  "export_truth_class": {
                    "enum": [
                      "export_redacts_chip_payload_to_handle_only",
                      "export_excluded_class_change_required"
                    ]
                  },
                  "serialization_truth_class": {
                    "const": "chip_handle_list_refs_only"
                  }
                },
                "required": [
                  "export_truth_class",
                  "serialization_truth_class"
                ]
              }
            }
          }
        }
      ]
    }
  }
}
