{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/review_decision.schema.json",
  "title": "Aureline preview/apply/revert review-decision packet",
  "description": "Boundary schema for one review_decision_record frozen in docs/ux/preview_apply_revert_contract.md. The record is emitted when a user (or a policy-managed actor) admits, cancels, defers, re-reviews, keeps, or reverts a proposed consequential change. It binds consequence summary, diff-scope identity, blocked/hidden truth, checkpoint expectation, the honest revert_class claim, and post-apply evidence links to the same preview/apply lineage ids used by interaction safety, mutation journal, and local history. Raw bodies, raw paths, raw URLs, raw prompts, raw credentials, and raw provider payloads never cross this boundary.",
  "type": "object",
  "$ref": "#/$defs/review_decision_record",
  "$defs": {
    "review_decision_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the review-decision payload shape. Current value is 1."
    },
    "record_kind": {
      "type": "string",
      "const": "review_decision_record"
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenario"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "exercised_axes": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9]+(?:[A-Za-z0-9_.:/-]*[A-Za-z0-9])?$",
      "description": "Opaque, stable id safe for RPC boundaries, manifests, logs, and support exports. Raw bodies, paths, URLs, and credentials never appear here."
    },
    "nullable_opaque_id": {
      "oneOf": [
        { "$ref": "#/$defs/opaque_id" },
        { "type": "null" }
      ]
    },
    "monotonic_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 900
    },
    "short_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 220
    },
    "client_scope": {
      "type": "string",
      "enum": [
        "desktop_product",
        "cli",
        "companion_surface",
        "remote_agent",
        "sdk_or_api",
        "managed_admin_surface"
      ]
    },
    "redaction_class": {
      "type": "string",
      "enum": [
        "metadata_safe_default",
        "operator_only_restricted",
        "internal_support_restricted",
        "signing_evidence_only"
      ]
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_epoch", "trust_state"],
      "properties": {
        "policy_epoch": { "type": "string", "minLength": 1 },
        "trust_state": {
          "type": "string",
          "enum": ["trusted", "restricted"]
        },
        "execution_context_id": { "type": "string", "minLength": 1 }
      }
    },
    "review_flow_class": {
      "type": "string",
      "enum": [
        "ai_patch_review",
        "bulk_replace_review",
        "package_action_review",
        "scaffold_generation_review",
        "rename_or_refactor_review",
        "migration_or_import_review",
        "restore_or_reset_review",
        "generic_preview_apply_review"
      ],
      "description": "Closed flow class naming which family of review surface emitted this record."
    },
    "apply_timing_class": {
      "type": "string",
      "enum": [
        "immediate_live_apply",
        "staged_apply_required",
        "preview_first_apply_required",
        "policy_locked_no_apply",
        "dry_run_then_apply",
        "observe_only_no_apply"
      ],
      "description": "Apply timing posture. Mirrors the apply_timing_class used on staged review surfaces."
    },
    "decision_point": {
      "type": "string",
      "enum": [
        "propose",
        "preview",
        "apply",
        "validate",
        "keep_or_revert"
      ],
      "description": "Preview/apply lifecycle point at which the decision is recorded."
    },
    "decision_outcome": {
      "type": "string",
      "enum": [
        "apply_admitted",
        "cancelled_no_change",
        "deferred_draft_saved",
        "kept_after_apply",
        "revert_requested",
        "evidence_only",
        "re_review_required_basis_drifted",
        "blocked_by_policy",
        "blocked_missing_checkpoint"
      ]
    },
    "consequence_class": {
      "type": "string",
      "enum": [
        "reversible_local",
        "recoverable_durable",
        "external_shared",
        "irreversible_high_blast"
      ]
    },
    "revert_class": {
      "type": "string",
      "enum": [
        "exact_undo",
        "compensating_action",
        "regenerate_from_source",
        "restore_from_checkpoint",
        "evidence_only_no_rerun",
        "no_recovery_available"
      ]
    },
    "blocked_reason_class": {
      "type": "string",
      "enum": [
        "blocked_by_policy",
        "blocked_by_ownership",
        "blocked_by_protected_path",
        "blocked_by_provider_unsupported",
        "blocked_by_freshness_required",
        "blocked_by_grant_missing",
        "blocked_by_concurrent_edit"
      ]
    },
    "blocked_summary_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason_class", "count"],
      "properties": {
        "reason_class": { "$ref": "#/$defs/blocked_reason_class" },
        "count": { "type": "integer", "minimum": 0 },
        "item_id_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "summary_label": { "$ref": "#/$defs/reviewable_sentence" }
      }
    },
    "diff_scope_class": {
      "type": "string",
      "enum": [
        "textual_diff",
        "file_tree_diff",
        "structured_edit_preview",
        "package_delta_list",
        "scaffold_file_plan",
        "migration_plan_summary",
        "restore_reset_scope_summary",
        "evidence_only_summary"
      ]
    },
    "diff_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["diff_scope_class", "diff_scope_label"],
      "properties": {
        "diff_scope_class": { "$ref": "#/$defs/diff_scope_class" },
        "diff_scope_label": { "$ref": "#/$defs/reviewable_sentence" },
        "diff_object_identity_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" },
          "description": "Opaque object identities the diff is about (files, packages, providers, settings scopes)."
        },
        "diff_artifact_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Optional opaque reference to a rendered diff artifact, preview surface, or review pack."
        }
      }
    },
    "evidence_link_class": {
      "type": "string",
      "enum": [
        "mutation_journal_entry",
        "mutation_group",
        "local_history_checkpoint",
        "local_history_group",
        "durable_job",
        "history_row",
        "evidence_packet",
        "vcs_commit",
        "provider_audit_record"
      ]
    },
    "evidence_link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["link_class", "id_ref", "label"],
      "properties": {
        "link_class": { "$ref": "#/$defs/evidence_link_class" },
        "id_ref": { "$ref": "#/$defs/opaque_id" },
        "label": { "$ref": "#/$defs/short_label" }
      }
    },
    "review_decision_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "review_decision_schema_version",
        "review_decision_id",
        "review_flow_class",
        "apply_timing_class",
        "decision_point",
        "decision_outcome",
        "consequence_class",
        "revert_class",
        "consequence_summary",
        "diff_identity",
        "basis_snapshot_ref",
        "target_identities_ref",
        "included_member_count",
        "blocked_member_count",
        "hidden_member_count",
        "blocked_summary",
        "preview_phase_ref",
        "checkpoint_ref",
        "post_apply_evidence_links",
        "client_scope",
        "redaction_class",
        "policy_context",
        "running_build_identity_ref",
        "minted_at"
      ],
      "properties": {
        "$schema": {
          "type": "string",
          "format": "uri-reference"
        },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "$ref": "#/$defs/record_kind" },
        "review_decision_schema_version": { "$ref": "#/$defs/review_decision_schema_version" },
        "review_decision_id": { "$ref": "#/$defs/opaque_id" },
        "review_flow_class": { "$ref": "#/$defs/review_flow_class" },
        "apply_timing_class": { "$ref": "#/$defs/apply_timing_class" },
        "decision_point": { "$ref": "#/$defs/decision_point" },
        "decision_outcome": { "$ref": "#/$defs/decision_outcome" },
        "consequence_class": { "$ref": "#/$defs/consequence_class" },
        "revert_class": { "$ref": "#/$defs/revert_class" },
        "consequence_summary": { "$ref": "#/$defs/reviewable_sentence" },
        "diff_identity": { "$ref": "#/$defs/diff_identity" },
        "basis_snapshot_ref": { "$ref": "#/$defs/opaque_id" },
        "scope_identity_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Opaque stable scope identity that preview/apply/revert MUST preserve. Typically the mutation group id or provider-side selection id."
        },
        "target_identities_ref": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "included_member_count": { "type": "integer", "minimum": 0 },
        "blocked_member_count": { "type": "integer", "minimum": 0 },
        "hidden_member_count": { "type": "integer", "minimum": 0 },
        "blocked_summary": {
          "type": "array",
          "items": { "$ref": "#/$defs/blocked_summary_entry" },
          "uniqueItems": true,
          "description": "Per-reason breakdown for blocked members. MUST be empty when blocked_member_count is 0."
        },
        "preview_phase_ref": {
          "$ref": "#/$defs/opaque_id",
          "description": "Opaque reference to the approved preview_apply_revert_record (interaction safety) that the decision is based on."
        },
        "apply_phase_ref": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/opaque_id" }
          ],
          "description": "Opaque reference to the apply-phase preview_apply_revert_record (interaction safety) when apply has committed."
        },
        "checkpoint_ref": {
          "$ref": "#/$defs/nullable_opaque_id",
          "description": "Opaque reference to the checkpoint or snapshot group used for restore_from_checkpoint recovery claims. Null when no checkpoint is required or available."
        },
        "post_apply_evidence_links": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_link" },
          "uniqueItems": true,
          "description": "Evidence links that make the apply outcome inspectable after navigation/restart."
        },
        "client_scope": { "$ref": "#/$defs/client_scope" },
        "redaction_class": { "$ref": "#/$defs/redaction_class" },
        "policy_context": { "$ref": "#/$defs/policy_context" },
        "running_build_identity_ref": { "type": "string", "minLength": 1 },
        "minted_at": { "$ref": "#/$defs/monotonic_timestamp" }
      },
      "allOf": [
        {
          "description": "no_recovery_available is admitted only when consequence_class is irreversible_high_blast.",
          "if": {
            "properties": { "revert_class": { "const": "no_recovery_available" } },
            "required": ["revert_class"]
          },
          "then": {
            "properties": { "consequence_class": { "const": "irreversible_high_blast" } },
            "required": ["consequence_class"]
          }
        },
        {
          "description": "restore_from_checkpoint MUST carry a non-null checkpoint_ref.",
          "if": {
            "properties": { "revert_class": { "const": "restore_from_checkpoint" } },
            "required": ["revert_class"]
          },
          "then": {
            "properties": { "checkpoint_ref": { "$ref": "#/$defs/opaque_id" } },
            "required": ["checkpoint_ref"]
          }
        },
        {
          "description": "decision_outcome = apply_admitted MUST carry apply_phase_ref and at least one post-apply evidence link.",
          "if": {
            "properties": { "decision_outcome": { "const": "apply_admitted" } },
            "required": ["decision_outcome"]
          },
          "then": {
            "properties": {
              "apply_phase_ref": { "$ref": "#/$defs/opaque_id" },
              "post_apply_evidence_links": { "minItems": 1 }
            },
            "required": ["apply_phase_ref"]
          }
        },
        {
          "description": "decision_outcome = cancelled_no_change MUST carry apply_phase_ref = null and no post-apply evidence links.",
          "if": {
            "properties": { "decision_outcome": { "const": "cancelled_no_change" } },
            "required": ["decision_outcome"]
          },
          "then": {
            "properties": {
              "apply_phase_ref": { "type": "null" },
              "post_apply_evidence_links": { "maxItems": 0 }
            },
            "required": ["apply_phase_ref"]
          }
        },
        {
          "description": "blocked_member_count = 0 MUST have an empty blocked_summary array.",
          "if": {
            "properties": { "blocked_member_count": { "const": 0 } },
            "required": ["blocked_member_count"]
          },
          "then": {
            "properties": { "blocked_summary": { "maxItems": 0 } },
            "required": ["blocked_summary"]
          }
        }
      ]
    }
  }
}

