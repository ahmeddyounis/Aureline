{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ux/recent_work_row.schema.json",
  "title": "Aureline recent-work row, restore-card, and workspace-switcher row contract",
  "description": "Boundary schema for concrete row anatomy on recent-work lists, restore cards, and workspace switchers. The records wrap the workspace entry / restore object model and force unavailable targets, cached-only views, remote entries, and partial restore states to carry one shared recovery vocabulary and write-safety badge.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/recent_work_row_record" },
    { "$ref": "#/$defs/restore_card_summary_record" },
    { "$ref": "#/$defs/workspace_switcher_row_record" }
  ],
  "$defs": {
    "recent_work_row_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer schema version for the row-level recent-work / restore-card / switcher anatomy contract."
    },
    "fixture_metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "opaque_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque id safe for logs, support bundles, and manifests. Raw paths, raw URLs with credentials, and secrets never appear here."
    },
    "redaction_aware_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "monotonic_timestamp": {
      "type": "string",
      "minLength": 1
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "local_file",
        "local_folder",
        "local_repo_root",
        "workspace_manifest",
        "workset_manifest",
        "remote_repository",
        "ssh_workspace",
        "container_workspace",
        "devcontainer_workspace",
        "managed_cloud_workspace",
        "portable_state_package",
        "handoff_packet",
        "competitor_config_root",
        "template_or_prebuild_snapshot",
        "review_or_work_item_deep_link",
        "recovery_checkpoint"
      ],
      "description": "Re-exported target kind from the workspace entry / restore object model."
    },
    "root_kind": {
      "type": "string",
      "enum": [
        "local_file",
        "local_folder",
        "local_repo_root",
        "workspace_manifest",
        "multi_root_workspace",
        "workset",
        "remote_repository",
        "ssh_remote_root",
        "container_root",
        "devcontainer_root",
        "managed_cloud_workspace",
        "template_snapshot",
        "imported_or_handoff_root",
        "recovery_checkpoint",
        "recent_session"
      ]
    },
    "target_state": {
      "type": "string",
      "enum": [
        "reachable",
        "stale_metadata",
        "missing_target",
        "moved_target_detected",
        "missing_mount",
        "remote_unreachable",
        "authority_expired",
        "suspended_managed_workspace",
        "locked_by_other_instance",
        "policy_blocked",
        "quarantined",
        "mode_downgraded",
        "cached_only",
        "unknown"
      ]
    },
    "availability_class": {
      "type": "string",
      "enum": [
        "available",
        "degraded",
        "unavailable",
        "cached_only",
        "blocked",
        "unknown"
      ]
    },
    "trust_state": {
      "type": "string",
      "enum": ["trusted", "restricted", "pending_evaluation"]
    },
    "restore_availability": {
      "type": "string",
      "enum": ["exact", "compatible", "layout_only", "evidence_only", "none"]
    },
    "restore_class": {
      "type": "string",
      "enum": [
        "exact_restore",
        "compatible_restore",
        "layout_only",
        "recovered_drafts",
        "evidence_only",
        "no_restore"
      ]
    },
    "freshness_class": {
      "type": "string",
      "enum": [
        "live",
        "cached_with_timestamp",
        "stale_offline",
        "unknown_since",
        "not_installed",
        "fetch_deferred"
      ]
    },
    "cached_timestamp_class": {
      "type": "string",
      "enum": ["minutes_ago", "hours_ago", "days_ago", "older", "unknown"]
    },
    "privacy_reduction_mode": {
      "type": "string",
      "enum": [
        "default",
        "hide_paths",
        "hide_recent_work",
        "hide_account_affordances",
        "hide_all_except_open_and_clone",
        "sensitive_environment_clear_on_launch"
      ]
    },
    "privacy_redaction_applied": {
      "type": "string",
      "enum": [
        "primary_label",
        "location_or_target_subtitle",
        "account_affordance",
        "last_opened_at",
        "last_validated_at",
        "row_hidden",
        "none"
      ]
    },
    "unavailable_reason": {
      "type": "string",
      "enum": [
        "missing_path",
        "missing_mount",
        "moved_root",
        "remote_disconnected",
        "authority_expired",
        "managed_workspace_suspended",
        "policy_blocked",
        "quarantined",
        "stale_cache",
        "locked_elsewhere",
        "unknown_owner",
        "write_unsafe_stale_or_disconnected"
      ]
    },
    "recovery_action_id": {
      "type": "string",
      "enum": [
        "open",
        "open_in_new_window",
        "open_restricted",
        "open_read_only_cached_view",
        "locate_missing_target",
        "reconnect",
        "reauth",
        "retry_later",
        "compare_before_restore",
        "open_without_restore",
        "restore_now",
        "skip_once",
        "open_clean",
        "recover_draft",
        "export_evidence",
        "pin",
        "unpin",
        "remove_from_recents",
        "reveal_in_explorer",
        "resume",
        "rebuild",
        "cancel_switch",
        "reopen_previous_workspace",
        "close_other_window",
        "transfer_window",
        "clear_recent_work",
        "exit_privacy_reduced_mode"
      ],
      "description": "Shared unavailable-target and recovery action vocabulary. Surface-specific synonyms are non-conforming."
    },
    "action_role": {
      "type": "string",
      "enum": ["primary", "secondary", "recovery", "destructive", "privacy_control"]
    },
    "recovery_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_role", "enabled"],
      "properties": {
        "action_id": { "$ref": "#/$defs/recovery_action_id" },
        "action_role": { "$ref": "#/$defs/action_role" },
        "enabled": { "type": "boolean" },
        "requires_confirmation": { "type": "boolean" },
        "requires_target_revalidation": { "type": "boolean" },
        "presentation_label": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "write_safety_badge": {
      "type": "string",
      "enum": [
        "writes_allowed",
        "writes_require_revalidation",
        "writes_blocked_cached_view_only",
        "writes_blocked_target_unavailable",
        "writes_blocked_policy",
        "writes_unsafe_stale_or_disconnected"
      ]
    },
    "activation_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_object_model_ref",
        "project_entry_action_record_required",
        "error_handling_path_ref",
        "source_surface"
      ],
      "properties": {
        "workspace_object_model_ref": {
          "type": "string",
          "const": "docs/workspace/entry_restore_object_model.md"
        },
        "project_entry_action_record_required": { "type": "boolean", "const": true },
        "project_entry_action_ref": { "$ref": "#/$defs/opaque_id" },
        "error_handling_path_ref": {
          "type": "string",
          "enum": [
            "entry_restore_error_path",
            "unavailable_target_recovery_path",
            "restore_prompt_error_path"
          ]
        },
        "source_surface": {
          "type": "string",
          "enum": [
            "start_center",
            "workspace_switcher",
            "open_recent_submenu",
            "command_palette",
            "restore_card"
          ]
        },
        "failure_recovery_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/recovery_action_id" },
          "uniqueItems": true
        }
      }
    },
    "unavailable_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "user_explanation_required",
        "destructive_cleanup_requires_confirmation",
        "cache_view_available",
        "recovery_actions"
      ],
      "properties": {
        "reason": { "$ref": "#/$defs/unavailable_reason" },
        "last_successful_validation_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "user_explanation_required": { "type": "boolean", "const": true },
        "destructive_cleanup_requires_confirmation": { "type": "boolean" },
        "cache_view_available": { "type": "boolean" },
        "write_safety_badge": { "$ref": "#/$defs/write_safety_badge" },
        "recovery_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/recovery_action_id" },
          "uniqueItems": true
        },
        "explanation_summary": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "remote_session_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["remote_session_ref", "target_state", "posture", "recovery_actions"],
      "properties": {
        "remote_session_ref": { "$ref": "#/$defs/opaque_id" },
        "target_state": { "$ref": "#/$defs/target_state" },
        "posture": {
          "type": "string",
          "enum": [
            "reattach_available",
            "reconnect_available",
            "reauth_required",
            "evidence_only",
            "session_ended",
            "blocked_by_policy"
          ]
        },
        "recovery_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/recovery_action_id" },
          "uniqueItems": true
        }
      }
    },
    "missing_dependency_warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dependency_class", "target_state", "severity", "recovery_actions"],
      "properties": {
        "dependency_class": {
          "type": "string",
          "enum": [
            "extension_host",
            "remote_target",
            "toolchain",
            "profile",
            "devcontainer",
            "managed_workspace",
            "display_topology",
            "version_or_schema",
            "policy"
          ]
        },
        "target_state": { "$ref": "#/$defs/target_state" },
        "severity": { "type": "string", "enum": ["info", "warning", "blocking"] },
        "recovery_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/recovery_action_id" },
          "uniqueItems": true
        },
        "presentation_label": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "dirty_buffer_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dirty_buffer_count",
        "recovery_journal_refs",
        "compare_available",
        "discard_available"
      ],
      "properties": {
        "dirty_buffer_count": { "type": "integer", "minimum": 0 },
        "recovery_journal_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "compare_available": { "type": "boolean" },
        "discard_available": { "type": "boolean" },
        "open_journal_available": { "type": "boolean" }
      }
    },
    "restorable_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "windows",
        "editors",
        "terminals",
        "remote_sessions",
        "dirty_buffers",
        "notebooks",
        "tasks",
        "evidence_packets"
      ],
      "properties": {
        "windows": { "type": "integer", "minimum": 0 },
        "editors": { "type": "integer", "minimum": 0 },
        "terminals": { "type": "integer", "minimum": 0 },
        "remote_sessions": { "type": "integer", "minimum": 0 },
        "dirty_buffers": { "type": "integer", "minimum": 0 },
        "notebooks": { "type": "integer", "minimum": 0 },
        "tasks": { "type": "integer", "minimum": 0 },
        "evidence_packets": { "type": "integer", "minimum": 0 }
      }
    },
    "cross_window_consequence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consequence_class",
        "dirty_buffer_count",
        "requires_confirmation",
        "failure_recovery_actions"
      ],
      "properties": {
        "consequence_class": {
          "type": "string",
          "enum": [
            "no_open_windows",
            "focus_existing_window",
            "open_in_new_window",
            "replace_current_workspace",
            "add_root_to_current_workspace",
            "close_or_suspend_previous_workspace",
            "transfer_dirty_buffers_blocked"
          ]
        },
        "affected_window_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/opaque_id" },
          "uniqueItems": true
        },
        "dirty_buffer_count": { "type": "integer", "minimum": 0 },
        "requires_confirmation": { "type": "boolean" },
        "failure_recovery_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/recovery_action_id" },
          "uniqueItems": true
        },
        "presentation_summary": { "$ref": "#/$defs/redaction_aware_text" }
      }
    },
    "switcher_entry_class": {
      "type": "string",
      "enum": [
        "local",
        "remote",
        "managed",
        "pinned",
        "recent",
        "recently_restored",
        "open_window",
        "template",
        "imported"
      ]
    },
    "recent_work_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "recent_work_row_schema_version",
        "row_id",
        "recent_work_entry_ref",
        "primary_label",
        "location_or_target_subtitle",
        "target_kind",
        "root_kind",
        "target_state",
        "availability_class",
        "trust_state",
        "restore_availability",
        "freshness_class",
        "privacy_reduction_mode",
        "privacy_redaction_applied",
        "pinned",
        "write_safety_badge",
        "row_actions",
        "activation_contract"
      ],
      "anyOf": [
        { "required": ["last_opened_at"] },
        { "required": ["last_validated_at"] }
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "recent_work_row_record" },
        "recent_work_row_schema_version": { "$ref": "#/$defs/recent_work_row_schema_version" },
        "row_id": { "$ref": "#/$defs/opaque_id" },
        "recent_work_entry_ref": { "$ref": "#/$defs/opaque_id" },
        "primary_label": { "$ref": "#/$defs/redaction_aware_text" },
        "location_or_target_subtitle": { "$ref": "#/$defs/redaction_aware_text" },
        "target_kind": { "$ref": "#/$defs/target_kind" },
        "root_kind": { "$ref": "#/$defs/root_kind" },
        "target_state": { "$ref": "#/$defs/target_state" },
        "availability_class": { "$ref": "#/$defs/availability_class" },
        "trust_state": { "$ref": "#/$defs/trust_state" },
        "restore_availability": { "$ref": "#/$defs/restore_availability" },
        "freshness_class": { "$ref": "#/$defs/freshness_class" },
        "cached_timestamp_class": { "$ref": "#/$defs/cached_timestamp_class" },
        "privacy_reduction_mode": { "$ref": "#/$defs/privacy_reduction_mode" },
        "privacy_redaction_applied": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/privacy_redaction_applied" },
          "uniqueItems": true
        },
        "pinned": { "type": "boolean" },
        "last_opened_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "last_validated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "write_safety_badge": { "$ref": "#/$defs/write_safety_badge" },
        "unavailable_target": { "$ref": "#/$defs/unavailable_target" },
        "row_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/recovery_action" }
        },
        "activation_contract": { "$ref": "#/$defs/activation_contract" }
      }
    },
    "restore_card_summary_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "recent_work_row_schema_version",
        "card_id",
        "restore_prompt_ref",
        "primary_label",
        "restore_class",
        "restorable_counts",
        "remote_session_summaries",
        "dirty_buffer_summary",
        "missing_dependency_warnings",
        "write_safety_badge",
        "card_actions",
        "activation_contract"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "restore_card_summary_record" },
        "recent_work_row_schema_version": { "$ref": "#/$defs/recent_work_row_schema_version" },
        "card_id": { "$ref": "#/$defs/opaque_id" },
        "restore_prompt_ref": { "$ref": "#/$defs/opaque_id" },
        "primary_label": { "$ref": "#/$defs/redaction_aware_text" },
        "location_or_target_subtitle": { "$ref": "#/$defs/redaction_aware_text" },
        "restore_class": { "$ref": "#/$defs/restore_class" },
        "restorable_counts": { "$ref": "#/$defs/restorable_counts" },
        "remote_session_summaries": {
          "type": "array",
          "items": { "$ref": "#/$defs/remote_session_summary" }
        },
        "dirty_buffer_summary": { "$ref": "#/$defs/dirty_buffer_summary" },
        "missing_dependency_warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/missing_dependency_warning" }
        },
        "write_safety_badge": { "$ref": "#/$defs/write_safety_badge" },
        "card_actions": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/recovery_action" }
        },
        "activation_contract": { "$ref": "#/$defs/activation_contract" }
      }
    },
    "workspace_switcher_row_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_kind",
        "recent_work_row_schema_version",
        "row_id",
        "switcher_entry_ref",
        "primary_label",
        "location_or_target_subtitle",
        "searchable_terms",
        "switcher_entry_classes",
        "target_kind",
        "root_kind",
        "target_state",
        "availability_class",
        "trust_state",
        "restore_availability",
        "pinned",
        "write_safety_badge",
        "cross_window_consequence",
        "row_actions",
        "activation_contract"
      ],
      "anyOf": [
        { "required": ["last_opened_at"] },
        { "required": ["last_validated_at"] }
      ],
      "properties": {
        "$schema": { "type": "string" },
        "__fixture__": { "$ref": "#/$defs/fixture_metadata" },
        "record_kind": { "const": "workspace_switcher_row_record" },
        "recent_work_row_schema_version": { "$ref": "#/$defs/recent_work_row_schema_version" },
        "row_id": { "$ref": "#/$defs/opaque_id" },
        "switcher_entry_ref": { "$ref": "#/$defs/opaque_id" },
        "recent_work_entry_ref": { "$ref": "#/$defs/opaque_id" },
        "primary_label": { "$ref": "#/$defs/redaction_aware_text" },
        "location_or_target_subtitle": { "$ref": "#/$defs/redaction_aware_text" },
        "searchable_terms": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/redaction_aware_text" },
          "uniqueItems": true
        },
        "switcher_entry_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/switcher_entry_class" },
          "uniqueItems": true
        },
        "target_kind": { "$ref": "#/$defs/target_kind" },
        "root_kind": { "$ref": "#/$defs/root_kind" },
        "target_state": { "$ref": "#/$defs/target_state" },
        "availability_class": { "$ref": "#/$defs/availability_class" },
        "trust_state": { "$ref": "#/$defs/trust_state" },
        "restore_availability": { "$ref": "#/$defs/restore_availability" },
        "pinned": { "type": "boolean" },
        "last_opened_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "last_validated_at": { "$ref": "#/$defs/monotonic_timestamp" },
        "write_safety_badge": { "$ref": "#/$defs/write_safety_badge" },
        "unavailable_target": { "$ref": "#/$defs/unavailable_target" },
        "cross_window_consequence": { "$ref": "#/$defs/cross_window_consequence" },
        "row_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/recovery_action" }
        },
        "activation_contract": { "$ref": "#/$defs/activation_contract" }
      }
    }
  }
}
