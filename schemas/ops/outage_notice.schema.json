{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aureline.dev/schemas/ops/outage_notice.schema.json",
  "title": "Aureline outage and maintenance notice",
  "description": "Boundary schema for outage_notice_record, the cross-surface notice contract frozen in docs/ux/control_data_plane_status_contract.md. A notice names whether the event is planned maintenance, tenant migration, or unplanned degradation; resolves to one state in scheduled/read_only/drain/migration/failover/reconciling/resolved; carries exact UTC times plus the display timezone and UTC offset; separates control-plane effects from data-plane effects; names retained local-safe capabilities, blocked managed-only capabilities, blocked write classes, and deferral paths; and preserves boundary-change, stale-notice, and historical-retention truth so migration/failover recovery cannot hide tenant, region, residency, key-ownership, or endpoint-identity changes behind generic all-clear copy. The schema is a contract artifact only; backend incident management and tenant orchestration are out of scope.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "notice_id",
    "notice_kind_class",
    "notice_state_class",
    "title",
    "summary",
    "created_at",
    "updated_at",
    "schedule",
    "affected_scope",
    "plane_effects",
    "local_continuity",
    "blocked_write_classes",
    "guidance_actions",
    "boundary_change_summary",
    "notice_lifecycle",
    "display_copy",
    "evidence_refs",
    "narrative_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for this notice record. Additive-minor changes bump this integer."
    },
    "record_kind": {
      "type": "string",
      "const": "outage_notice_record"
    },
    "notice_id": {
      "$ref": "#/$defs/stable_token"
    },
    "notice_kind_class": {
      "$ref": "#/$defs/notice_kind_class"
    },
    "notice_state_class": {
      "$ref": "#/$defs/notice_state_class"
    },
    "title": {
      "$ref": "#/$defs/reviewable_sentence"
    },
    "summary": {
      "$ref": "#/$defs/reviewable_sentence"
    },
    "created_at": {
      "$ref": "#/$defs/utc_date_time"
    },
    "updated_at": {
      "$ref": "#/$defs/utc_date_time"
    },
    "schedule": {
      "$ref": "#/$defs/notice_schedule"
    },
    "affected_scope": {
      "$ref": "#/$defs/affected_scope"
    },
    "plane_effects": {
      "$ref": "#/$defs/plane_effects"
    },
    "local_continuity": {
      "$ref": "#/$defs/local_continuity"
    },
    "blocked_write_classes": {
      "type": "array",
      "description": "Every managed write class blocked by the notice. Read-only and drain notices MUST list at least one blocked write class.",
      "items": {
        "$ref": "#/$defs/blocked_write_class"
      }
    },
    "guidance_actions": {
      "type": "array",
      "minItems": 1,
      "description": "Explicit next actions. Continue-local, publish-later, reconnect-later, export-before-maintenance, and review-new-boundary guidance is represented here rather than inferred from prose.",
      "items": {
        "$ref": "#/$defs/guidance_action"
      }
    },
    "boundary_change_summary": {
      "$ref": "#/$defs/boundary_change_summary"
    },
    "notice_lifecycle": {
      "$ref": "#/$defs/notice_lifecycle"
    },
    "display_copy": {
      "$ref": "#/$defs/display_copy"
    },
    "evidence_refs": {
      "type": "array",
      "description": "Opaque evidence, incident, drill, support-bundle, or continuity-packet refs that justify the notice.",
      "items": {
        "$ref": "#/$defs/stable_token"
      }
    },
    "narrative_refs": {
      "type": "array",
      "minItems": 1,
      "description": "Repo-relative pointers into companion narrative contracts.",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "__fixture__": {
      "type": "object",
      "description": "Optional fixture annotation block. Never part of the runtime record."
    }
  },
  "allOf": [
    {
      "description": "Read-only and drain notices must disclose blocked write classes and at least one explicit deferral path.",
      "if": {
        "properties": {
          "notice_state_class": {
            "enum": [
              "read_only",
              "drain"
            ]
          }
        },
        "required": [
          "notice_state_class"
        ]
      },
      "then": {
        "properties": {
          "blocked_write_classes": {
            "minItems": 1
          },
          "guidance_actions": {
            "contains": {
              "properties": {
                "action_class": {
                  "enum": [
                    "publish_later",
                    "reconnect_later",
                    "export_before_maintenance"
                  ]
                }
              },
              "required": [
                "action_class"
              ]
            }
          }
        }
      }
    },
    {
      "description": "Migration and failover notices must require a boundary review action before prior approvals, replay queues, or reconnect tokens are trusted under the new route.",
      "if": {
        "properties": {
          "notice_state_class": {
            "enum": [
              "migration",
              "failover"
            ]
          }
        },
        "required": [
          "notice_state_class"
        ]
      },
      "then": {
        "properties": {
          "guidance_actions": {
            "contains": {
              "properties": {
                "action_class": {
                  "const": "review_new_boundary"
                }
              },
              "required": [
                "action_class"
              ]
            }
          }
        }
      }
    },
    {
      "description": "When boundary_change_required is true, at least one boundary axis must be present and review status cannot claim not_required.",
      "if": {
        "properties": {
          "boundary_change_summary": {
            "properties": {
              "boundary_change_required": {
                "const": true
              }
            },
            "required": [
              "boundary_change_required"
            ]
          }
        },
        "required": [
          "boundary_change_summary"
        ]
      },
      "then": {
        "properties": {
          "boundary_change_summary": {
            "properties": {
              "boundary_axes": {
                "minItems": 1
              },
              "review_status_class": {
                "not": {
                  "const": "not_required"
                }
              }
            }
          },
          "guidance_actions": {
            "contains": {
              "properties": {
                "action_class": {
                  "const": "review_new_boundary"
                }
              },
              "required": [
                "action_class"
              ]
            }
          }
        }
      }
    },
    {
      "description": "Stale, superseded, expired, retained, or imported notices must carry a visible stale label.",
      "if": {
        "properties": {
          "notice_lifecycle": {
            "properties": {
              "notice_freshness_class": {
                "not": {
                  "const": "active_current"
                }
              }
            },
            "required": [
              "notice_freshness_class"
            ]
          }
        },
        "required": [
          "notice_lifecycle"
        ]
      },
      "then": {
        "properties": {
          "display_copy": {
            "properties": {
              "stale_label": {
                "$ref": "#/$defs/reviewable_sentence"
              }
            },
            "required": [
              "stale_label"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "stable_token": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "description": "Opaque stable token. Raw URLs, raw hostnames, raw tenant names, raw account ids, raw endpoint credentials, raw policy bodies, and raw secret material never appear here."
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "reviewable_sentence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Short redaction-aware sentence safe for UI, support export, and admin review surfaces."
    },
    "utc_date_time": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$",
      "description": "RFC 3339 / ISO 8601 UTC timestamp."
    },
    "nullable_utc_date_time": {
      "anyOf": [
        {
          "$ref": "#/$defs/utc_date_time"
        },
        {
          "type": "null"
        }
      ]
    },
    "timezone_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(UTC|[A-Za-z_]+/[A-Za-z0-9_+.-]+(?:/[A-Za-z0-9_+.-]+)*)$",
      "description": "IANA timezone id or UTC."
    },
    "utc_offset": {
      "type": "string",
      "pattern": "^(Z|[+-](?:0[0-9]|1[0-4]):[0-5][0-9])$",
      "description": "UTC offset in force at the window start."
    },
    "notice_kind_class": {
      "type": "string",
      "enum": [
        "planned_maintenance",
        "tenant_migration",
        "unplanned_degradation"
      ]
    },
    "notice_state_class": {
      "type": "string",
      "enum": [
        "scheduled",
        "read_only",
        "drain",
        "migration",
        "failover",
        "reconciling",
        "resolved"
      ]
    },
    "time_basis_class": {
      "type": "string",
      "enum": [
        "scheduled_exact",
        "detected_exact",
        "updated_exact",
        "resolved_exact",
        "historical_exact"
      ]
    },
    "notice_schedule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "time_basis_class",
        "observed_or_announced_at",
        "starts_at",
        "expected_or_actual_ends_at",
        "resolved_at",
        "timezone_id",
        "utc_offset_at_start",
        "export_deadline_at"
      ],
      "properties": {
        "time_basis_class": {
          "$ref": "#/$defs/time_basis_class"
        },
        "observed_or_announced_at": {
          "$ref": "#/$defs/utc_date_time"
        },
        "starts_at": {
          "$ref": "#/$defs/utc_date_time"
        },
        "expected_or_actual_ends_at": {
          "$ref": "#/$defs/nullable_utc_date_time"
        },
        "resolved_at": {
          "$ref": "#/$defs/nullable_utc_date_time"
        },
        "timezone_id": {
          "$ref": "#/$defs/timezone_id"
        },
        "utc_offset_at_start": {
          "$ref": "#/$defs/utc_offset"
        },
        "export_deadline_at": {
          "$ref": "#/$defs/nullable_utc_date_time"
        }
      }
    },
    "deployment_profile_class": {
      "type": "string",
      "enum": [
        "individual_local",
        "self_hosted",
        "enterprise_online",
        "air_gapped",
        "managed_cloud"
      ]
    },
    "residency_scope_class": {
      "type": "string",
      "enum": [
        "not_applicable",
        "customer_region_pinned",
        "vendor_region_default",
        "sovereign_region_pinned",
        "tenant_residency_recheck_required",
        "residency_changed_review_required"
      ]
    },
    "control_plane_service_class": {
      "type": "string",
      "enum": [
        "sync_service",
        "registry_service",
        "relay_service",
        "ai_broker_service",
        "auth_identity_service",
        "policy_service",
        "docs_pack_service",
        "catalog_service",
        "telemetry_sink_service",
        "workspace_control_plane_service",
        "provider_review_service",
        "merge_queue_service",
        "support_ingest_service"
      ]
    },
    "data_plane_capability_class": {
      "type": "string",
      "enum": [
        "local_editing",
        "local_save",
        "local_search",
        "local_git",
        "local_tasks",
        "local_docs_inspect",
        "local_export",
        "local_diagnostics",
        "remote_attach",
        "managed_runtime",
        "collaboration_session",
        "hosted_review_publish",
        "merge_queue",
        "ai_gateway_prompt",
        "extension_install_update",
        "settings_profile_sync",
        "support_bundle_upload"
      ]
    },
    "affected_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deployment_profiles",
        "tenant_refs",
        "org_refs",
        "workspace_refs",
        "region_refs",
        "residency_scope_classes",
        "service_classes",
        "endpoint_refs",
        "scope_summary"
      ],
      "properties": {
        "deployment_profiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/deployment_profile_class"
          }
        },
        "tenant_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stable_token"
          }
        },
        "org_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stable_token"
          }
        },
        "workspace_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stable_token"
          }
        },
        "region_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stable_token"
          }
        },
        "residency_scope_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/residency_scope_class"
          }
        },
        "service_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/control_plane_service_class"
          }
        },
        "endpoint_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stable_token"
          }
        },
        "scope_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "control_plane_effect_state": {
      "type": "string",
      "enum": [
        "unaffected",
        "scheduled_impact",
        "read_only",
        "drain",
        "migration_in_progress",
        "failover_in_progress",
        "reconciling",
        "unavailable",
        "mirror_only",
        "boundary_recheck_required",
        "resolved",
        "unknown_requires_review"
      ]
    },
    "data_plane_effect_state": {
      "type": "string",
      "enum": [
        "unaffected_local_safe",
        "available_local_safe",
        "available_mirror_backed",
        "reduced_read_only",
        "blocked_pending_reconnect",
        "blocked_pending_boundary_recheck",
        "blocked_by_policy",
        "unavailable_managed_only",
        "resolved",
        "unknown_requires_review"
      ]
    },
    "recovery_trigger_class": {
      "type": "string",
      "enum": [
        "window_starts",
        "window_ends",
        "service_returns_healthy",
        "operator_marks_reconciled",
        "boundary_review_completed",
        "manual_reconnect_required",
        "manual_export_required",
        "not_applicable"
      ]
    },
    "control_plane_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service_class",
        "effect_state",
        "recovery_trigger_class",
        "note"
      ],
      "properties": {
        "service_class": {
          "$ref": "#/$defs/control_plane_service_class"
        },
        "effect_state": {
          "$ref": "#/$defs/control_plane_effect_state"
        },
        "recovery_trigger_class": {
          "$ref": "#/$defs/recovery_trigger_class"
        },
        "note": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "data_plane_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_class",
        "effect_state",
        "recovery_trigger_class",
        "note"
      ],
      "properties": {
        "capability_class": {
          "$ref": "#/$defs/data_plane_capability_class"
        },
        "effect_state": {
          "$ref": "#/$defs/data_plane_effect_state"
        },
        "recovery_trigger_class": {
          "$ref": "#/$defs/recovery_trigger_class"
        },
        "note": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "plane_effects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_plane",
        "data_plane"
      ],
      "properties": {
        "control_plane": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/control_plane_effect"
          }
        },
        "data_plane": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/data_plane_effect"
          }
        }
      }
    },
    "local_core_status_class": {
      "type": "string",
      "enum": [
        "local_core_unaffected",
        "meaningful_safe_subset_available",
        "local_only_available",
        "no_safe_local_subset",
        "unknown_requires_review"
      ]
    },
    "local_continuity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_core_status_class",
        "continue_local_guidance_required",
        "retained_local_safe_capabilities",
        "blocked_managed_only_capabilities",
        "continuity_summary"
      ],
      "properties": {
        "local_core_status_class": {
          "$ref": "#/$defs/local_core_status_class"
        },
        "continue_local_guidance_required": {
          "type": "boolean"
        },
        "retained_local_safe_capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/reviewable_sentence"
          }
        },
        "blocked_managed_only_capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reviewable_sentence"
          }
        },
        "continuity_summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "write_class": {
      "type": "string",
      "enum": [
        "managed_review_comment_publish",
        "managed_review_approval",
        "merge_queue_enqueue",
        "collaboration_presence_write",
        "profile_settings_sync_write",
        "policy_admin_write",
        "extension_registry_publish_or_install",
        "managed_workspace_lifecycle_write",
        "remote_control_session_join",
        "ai_gateway_prompt_submit",
        "support_bundle_upload",
        "telemetry_upload"
      ]
    },
    "write_block_state_class": {
      "type": "string",
      "enum": [
        "not_blocked",
        "scheduled_to_block",
        "blocked_read_only",
        "blocked_drain_new_actions",
        "blocked_pending_reconnect",
        "blocked_pending_boundary_recheck",
        "blocked_by_policy",
        "unknown_requires_review"
      ]
    },
    "deferral_path_class": {
      "type": "string",
      "enum": [
        "publish_later",
        "reconnect_later",
        "export_before_maintenance",
        "no_deferral_requires_export",
        "blocked_no_safe_retry",
        "not_applicable"
      ]
    },
    "local_capture_class": {
      "type": "string",
      "enum": [
        "capture_allowed_local_queue",
        "capture_allowed_export_only",
        "capture_blocked_boundary_unknown",
        "capture_not_applicable"
      ]
    },
    "blocked_write_class": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "write_class",
        "block_state_class",
        "deferral_path_class",
        "local_capture_class",
        "resume_trigger_class",
        "note"
      ],
      "properties": {
        "write_class": {
          "$ref": "#/$defs/write_class"
        },
        "block_state_class": {
          "$ref": "#/$defs/write_block_state_class"
        },
        "deferral_path_class": {
          "$ref": "#/$defs/deferral_path_class"
        },
        "local_capture_class": {
          "$ref": "#/$defs/local_capture_class"
        },
        "resume_trigger_class": {
          "$ref": "#/$defs/recovery_trigger_class"
        },
        "affected_queue_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/stable_token"
            },
            {
              "type": "null"
            }
          ]
        },
        "note": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "guidance_action_class": {
      "type": "string",
      "enum": [
        "continue_local",
        "publish_later",
        "reconnect_later",
        "export_before_maintenance",
        "review_new_boundary",
        "retry_after_window",
        "open_boundary_details",
        "export_diagnostics",
        "no_action_required"
      ]
    },
    "action_requirement_class": {
      "type": "string",
      "enum": [
        "required",
        "recommended",
        "available",
        "not_applicable"
      ]
    },
    "guidance_trigger_class": {
      "type": "string",
      "enum": [
        "safe_local_subset_available",
        "control_plane_write_blocked",
        "data_plane_reconnect_needed",
        "maintenance_window_pending",
        "boundary_change_detected",
        "reconciliation_pending",
        "resolved_no_boundary_change",
        "stale_notice_review",
        "user_export_requested"
      ]
    },
    "guidance_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_class",
        "requirement_class",
        "trigger_class",
        "target_write_classes",
        "due_before_at",
        "message"
      ],
      "properties": {
        "action_class": {
          "$ref": "#/$defs/guidance_action_class"
        },
        "requirement_class": {
          "$ref": "#/$defs/action_requirement_class"
        },
        "trigger_class": {
          "$ref": "#/$defs/guidance_trigger_class"
        },
        "target_write_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/write_class"
          }
        },
        "due_before_at": {
          "$ref": "#/$defs/nullable_utc_date_time"
        },
        "message": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "boundary_axis_class": {
      "type": "string",
      "enum": [
        "tenant",
        "region",
        "residency",
        "key_ownership",
        "endpoint_identity"
      ]
    },
    "boundary_axis_state_class": {
      "type": "string",
      "enum": [
        "unchanged",
        "changed",
        "unknown_recheck_required",
        "not_applicable"
      ]
    },
    "boundary_review_status_class": {
      "type": "string",
      "enum": [
        "not_required",
        "required_pending",
        "reviewed_accepted",
        "stale_notice_requires_review",
        "unknown_requires_review"
      ]
    },
    "boundary_axis_change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "axis_class",
        "axis_state_class",
        "previous_ref",
        "current_ref",
        "required_follow_up_action",
        "summary"
      ],
      "properties": {
        "axis_class": {
          "$ref": "#/$defs/boundary_axis_class"
        },
        "axis_state_class": {
          "$ref": "#/$defs/boundary_axis_state_class"
        },
        "previous_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/stable_token"
            },
            {
              "type": "null"
            }
          ]
        },
        "current_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/stable_token"
            },
            {
              "type": "null"
            }
          ]
        },
        "required_follow_up_action": {
          "$ref": "#/$defs/guidance_action_class"
        },
        "summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "boundary_change_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "boundary_change_required",
        "boundary_effective_at",
        "review_status_class",
        "boundary_axes",
        "summary"
      ],
      "properties": {
        "boundary_change_required": {
          "type": "boolean"
        },
        "boundary_effective_at": {
          "$ref": "#/$defs/nullable_utc_date_time"
        },
        "review_status_class": {
          "$ref": "#/$defs/boundary_review_status_class"
        },
        "boundary_axes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/boundary_axis_change"
          }
        },
        "summary": {
          "$ref": "#/$defs/reviewable_sentence"
        }
      }
    },
    "notice_freshness_class": {
      "type": "string",
      "enum": [
        "active_current",
        "superseded_stale",
        "expired_stale",
        "historical_retained",
        "imported_historical"
      ]
    },
    "retention_reason_class": {
      "type": "string",
      "enum": [
        "active_window",
        "audit_history",
        "boundary_change_history",
        "support_export_history",
        "imported_offline_history"
      ]
    },
    "notice_lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "notice_freshness_class",
        "supersedes_notice_id",
        "superseded_by_notice_id",
        "retained_until_at",
        "retention_reason_class",
        "history_notice_refs"
      ],
      "properties": {
        "notice_freshness_class": {
          "$ref": "#/$defs/notice_freshness_class"
        },
        "supersedes_notice_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/stable_token"
            },
            {
              "type": "null"
            }
          ]
        },
        "superseded_by_notice_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/stable_token"
            },
            {
              "type": "null"
            }
          ]
        },
        "retained_until_at": {
          "$ref": "#/$defs/nullable_utc_date_time"
        },
        "retention_reason_class": {
          "$ref": "#/$defs/retention_reason_class"
        },
        "history_notice_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stable_token"
          }
        }
      }
    },
    "display_copy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_status_line",
        "local_continuity_line",
        "blocked_writes_line",
        "boundary_change_line",
        "stale_label",
        "all_work_broken_implied",
        "generic_all_clear_used"
      ],
      "properties": {
        "primary_status_line": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "local_continuity_line": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "blocked_writes_line": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "boundary_change_line": {
          "$ref": "#/$defs/reviewable_sentence"
        },
        "stale_label": {
          "anyOf": [
            {
              "$ref": "#/$defs/reviewable_sentence"
            },
            {
              "type": "null"
            }
          ]
        },
        "all_work_broken_implied": {
          "type": "boolean",
          "const": false,
          "description": "Must remain false. Notices cannot imply all work is broken when local continuity is available."
        },
        "generic_all_clear_used": {
          "type": "boolean",
          "const": false,
          "description": "Must remain false. Resolved notices with changed boundaries cannot use a generic all-clear."
        }
      }
    }
  }
}
