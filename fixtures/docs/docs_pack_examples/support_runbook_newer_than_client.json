  "__fixture__": {
    "name": "support_runbook_newer_than_client",
    "scenario": "The support_runbook_registry publishes a runbook pack that targets a build newer than the running client (compat_window min 1.1.0, max 1.1.99; running build is pinned at 1.0.x). Signature verifies and the pack is internally publishable from the publisher's point of view, but every rendering surface computes version_match_state=incompatible_drift_detected against the running build and renders a typed version_mismatch chip with an upgrade_release_channel repair hook. The manifest itself declares publishable_state=blocked with version_mismatch-like blocking because the registry refuses to surface a runbook whose compat window excludes the running build.",
    "exercised_axes": {
      "source_class": "support_runbook",
      "publisher_class": "support_pipeline",
      "signature_status": "signed_and_verified",
      "declared_freshness_class": "warm_cached",
      "citation_posture": "citation_required",
      "backlink_posture": "backlink_resolvable",
      "publishable_state": "blocked",
      "exercised_blocking_reasons": [
        "missing_target_build_identity"
      ],
      "repair_hook_kind": "upgrade_release_channel"
    },
    "contract_sections": [
      "Pack newer than the local client",
      "When a pack is not publishable"
    ],
    "note": "The blocking_reasons list carries missing_target_build_identity to mean 'the running build is outside the declared compat window and the registry cannot pin a target for this client'; rendering surfaces would additionally project version_match_state=incompatible_drift_detected on any help_status_badge_record they emit."
  },
