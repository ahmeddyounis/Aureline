{
  "record_kind": "terminal_pane_session_case",
  "schema_version": 1,
  "case_name": "restricted_trust_renders_policy_blocked",
  "scenario": "A workspace in restricted trust opens a local shell. The pane row MUST render a PolicyBlocked degraded chip even before any lifecycle drift, so the chrome never implies the session is freely interactive.",
  "workspace_id": "ws-test",
  "active_workspace_id": "ws-test",
  "steps": [
    {
      "action": "open_session",
      "host_class": "host_desktop",
      "display_title": "zsh",
      "cwd_hint": null,
      "execution_context_ref": "execution_context.local_desktop.workspace_root",
      "trust_state": "restricted",
      "observed_at": "mono:0"
    },
    { "action": "mark_starting", "session_index": 0, "observed_at": "mono:1" },
    { "action": "mark_active", "session_index": 0, "observed_at": "mono:2" }
  ],
  "expect": {
    "tabs": [
      {
        "session_id": "pty:ws-test|host_desktop|0",
        "host_class": "host_desktop",
        "target_badge": "Local",
        "boundary_cue_token": "boundary_cue_local_session",
        "boundary_cue_visible": false,
        "display_title": "zsh",
        "cwd_hint": null,
        "execution_context_ref": "execution_context.local_desktop.workspace_root",
        "trust_state_token": "restricted",
        "lifecycle_state_token": "session_active",
        "is_interactive": true,
        "degraded_token": "PolicyBlocked"
      }
    ],
    "active_tab_id": "pty:ws-test|host_desktop|0",
    "required_transitions": [
      { "from": "session_starting", "to": "session_active" }
    ]
  }
