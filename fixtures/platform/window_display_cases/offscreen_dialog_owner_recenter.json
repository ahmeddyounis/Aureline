{
  "$schema": "../../../schemas/platform/window_state.schema.json",
  "record_kind": "window_display_verification_case",
  "window_state_schema_version": 1,
  "case_id": "platform:window-display:offscreen-dialog-owner-recenter:01",
  "__fixture__": {
    "scenario_id": "offscreen_dialog_owner_recenter",
    "summary": "A dialog, sheet, or child window would reopen off-screen because its prior monitor or safe bounds no longer exist. Aureline recenters it on the owning window and returns focus there on dismiss.",
    "matrix_ref": "artifacts/qa/window_display_matrix.yaml",
    "contract_sections": [
      "docs/ux/window_display_contract.md#6-focus-active-window-and-owned-prompts",
      "docs/ux/window_display_contract.md#5-restore-history",
      "docs/qa/multi_window_verification.md#required-drills"
    ]
  },
  "scenario_classes": ["offscreen_recovery", "detached_window"],
  "claimed_profile_scope": "all_claimed_desktop_profiles",
  "topology": {
    "starting_arrangement": "owner window on primary display with a modal or sheet last shown on a removed display",
    "change_event": "dialog_reopen_after_safe_bounds_shrink",
    "display_context": "owner_window_reachable_dialog_not_reachable",
    "topology_change_classes": [
      "display_removed",
      "safe_bounds_changed"
    ],
    "starting_window_modes": ["normal"],
    "resulting_window_modes": ["normal"]
  },
  "native_affordance_contract": {
    "titlebar_mode": "custom_titlebar_native_controls",
    "required_controls": [
      "close",
      "minimize",
      "maximize_or_zoom",
      "fullscreen_toggle",
      "system_menu",
      "window_drag_region",
      "resize_border"
    ],
    "control_projection_rule": "native_controls_project_canonical_commands",
    "must_not_happen": [
      "native dialog chrome appears without an owning window route",
      "titlebar controls dismiss a destructive prompt without focus return"
    ]
  },
  "layout_intent_contract": {
    "preserve": [
      "dialog ownership",
      "owning pane context",
      "keyboard-visible recovery path"
    ],
    "raw_coordinate_policy": "safe_bounds_and_focus_visibility_over_pixels",
    "continuity_level_expectation": "no_restore",
    "restore_provenance_expectation": "topology_adjustment_note_required"
  },
  "focus_and_dialog_contract": {
    "focus_visibility_rule": "return_to_dialog_owner_visible",
    "active_window_identity_rule": "activate_owner_window_for_prompt",
    "dialog_ownership_rule": "owned_prompt_recentered_with_owner",
    "focus_return_order": [
      "owning_surface",
      "recorded_focus_target",
      "adjacent_visible_pane",
      "main_workspace",
      "visible_recovery_card"
    ],
    "must_not_happen": [
      "dialog is orphaned on a background or unreachable window",
      "focus becomes trapped on an off-screen control",
      "dismiss returns focus to document body instead of the owner"
    ]
  },
  "restore_history_contract": {
    "must_record_when": [
      "dialog_owner_recentered",
      "window_moved_to_safe_bounds",
      "focus_target_fallback_applied"
    ],
    "adjustment_classes": [
      "dialog_recentered_to_owner",
      "snapped_to_safe_bounds",
      "stacking_repaired"
    ],
    "history_visibility_rule": "visible_in_restore_provenance_and_support_export"
  },
  "continuity_cues_contract": {
    "preserved_cues": [
      "workspace_identity",
      "trust_state",
      "host_remote_state",
      "profile_identity",
      "recovery_cues",
      "window_role_badge"
    ],
    "cross_window_transfer_rule": "no_cross_window_transfer_in_case",
    "secondary_window_rule": "primary_window_remains_visible_owner"
  },
  "live_surface_contract": {
    "restorable_context": [
      "owner window and pane",
      "dialog purpose and safe action set"
    ],
    "live_authority_requires_reauthorization": [],
    "must_not_happen": [
      "a destructive confirmation is hidden off-screen",
      "dialog recenter changes ownership silently"
    ]
  },
  "safe_recovery_actions": [
    "Recenter dialog",
    "Move owner window to primary display",
    "Cancel or dismiss"
  ],
  "required_drills": [
    "focus_routing_visible_return",
    "dialog_ownership_window_local",
    "restore_provenance_visible_after_reopen"
  ],
  "evidence_hooks": [
    "docs/ux/window_display_contract.md#6-focus-active-window-and-owned-prompts",
    "docs/ux/window_display_contract.md#5-restore-history",
    "artifacts/qa/window_display_matrix.yaml#offscreen_dialog_owner_recenter"
  ]
}
