{
  "$schema": "../../../schemas/platform/window_state.schema.json",
  "record_kind": "window_display_verification_case",
  "window_state_schema_version": 1,
  "case_id": "platform:window-display:suspend-resume-remote-rebind:01",
  "__fixture__": {
    "scenario_id": "suspend_resume_remote_rebind",
    "summary": "A battery-backed machine sleeps and wakes while remote, debug, task, and preview surfaces are present. Local context survives wake and any display reconnect, but live authority rebinding remains explicit.",
    "matrix_ref": "artifacts/qa/window_display_matrix.yaml",
    "contract_sections": [
      "docs/ux/window_display_contract.md#4-topology-change-handling",
      "docs/ux/window_display_contract.md#5-restore-history",
      "docs/workspace/layout_serialization_contract.md#6-live-surface-no-rerun-rules"
    ]
  },
  "scenario_classes": ["suspend_resume", "display_topology_change"],
  "claimed_profile_scope": "all_claimed_desktop_profiles",
  "topology": {
    "starting_arrangement": "dual-display workspace with editor, remote terminal, task output, and debug panes",
    "change_event": "sleep_wake_with_possible_display_reconnect",
    "display_context": "battery_backed_laptop_or_mobile_desktop",
    "topology_change_classes": [
      "wake_display_reconnect",
      "display_removed",
      "display_added",
      "scale_changed"
    ],
    "starting_window_modes": ["normal"],
    "resulting_window_modes": ["normal"]
  },
  "native_affordance_contract": {
    "titlebar_mode": "custom_titlebar_native_controls",
    "required_controls": [
      "close",
      "minimize",
      "maximize_or_zoom",
      "fullscreen_toggle",
      "system_menu",
      "window_drag_region",
      "resize_border"
    ],
    "control_projection_rule": "native_controls_project_canonical_commands",
    "must_not_happen": [
      "wake resumes native controls before safe bounds and scale are refreshed",
      "system menu offers reconnect or rerun without product review state"
    ]
  },
  "layout_intent_contract": {
    "preserve": [
      "pane tree and detached-window roles",
      "dirty-buffer visibility and local context",
      "recent focus chain if the target remains visible"
    ],
    "raw_coordinate_policy": "safe_bounds_and_focus_visibility_over_pixels",
    "continuity_level_expectation": "compatible_restore",
    "restore_provenance_expectation": "visible_after_reopen"
  },
  "focus_and_dialog_contract": {
    "focus_visibility_rule": "preserve_primary_focus_visible",
    "active_window_identity_rule": "restore_last_active_visible_window",
    "dialog_ownership_rule": "owned_prompt_recentered_with_owner",
    "focus_return_order": [
      "recorded_focus_target",
      "owning_surface",
      "adjacent_visible_pane",
      "main_workspace",
      "visible_recovery_card"
    ],
    "must_not_happen": [
      "wake restores focus to a hidden or disconnected surface",
      "display reconnect strands the active pane off-screen",
      "a dialog remains attached to a window that is no longer reachable"
    ]
  },
  "restore_history_contract": {
    "must_record_when": [
      "display_topology_changed",
      "scale_bucket_changed",
      "authority_rebind_required",
      "live_surface_no_rerun_enforced",
      "focus_target_fallback_applied"
    ],
    "adjustment_classes": [
      "moved_to_primary_display",
      "scale_normalized",
      "authority_rebind_deferred",
      "stacking_repaired"
    ],
    "history_visibility_rule": "visible_in_restore_provenance_and_support_export"
  },
  "continuity_cues_contract": {
    "preserved_cues": [
      "workspace_identity",
      "trust_state",
      "host_remote_state",
      "profile_identity",
      "recovery_cues",
      "window_role_badge"
    ],
    "cross_window_transfer_rule": "no_cross_window_transfer_in_case",
    "secondary_window_rule": "secondary_window_can_collapse_to_primary_with_history"
  },
  "live_surface_contract": {
    "restorable_context": [
      "editor tabs and dirty markers",
      "terminal transcript, title, and cwd hints",
      "task output and preview provenance"
    ],
    "live_authority_requires_reauthorization": [
      "remote attach or forwarded-service grants",
      "debug control channel",
      "browser callback or approval ticket state"
    ],
    "expected_missing_target_states": [
      "authority_expired_for_remote",
      "topology_changed"
    ],
    "session_execution_postures": [
      { "surface_class": "terminal_pane", "posture": "reconnect_available" },
      { "surface_class": "task_runner", "posture": "rerun_required" },
      { "surface_class": "debug_session", "posture": "reconnect_available" },
      { "surface_class": "preview_route", "posture": "context_unavailable" }
    ],
    "must_not_happen": [
      "wake silently replays a remote command",
      "a privileged callback resumes without revalidation",
      "support export hides whether the pane reconnected or stayed unavailable"
    ]
  },
  "safe_recovery_actions": [
    "Continue local",
    "Reconnect",
    "Reauthenticate",
    "Export restore details"
  ],
  "required_drills": [
    "focus_routing_visible_return",
    "placeholder_hydration_preserves_topology",
    "restore_provenance_visible_after_reopen",
    "no_hidden_rerun_live_surfaces"
  ],
  "evidence_hooks": [
    "docs/ux/window_display_contract.md#4-topology-change-handling",
    "docs/ux/window_display_contract.md#5-restore-history",
    "artifacts/qa/window_display_matrix.yaml#suspend_resume_remote_rebind"
  ]
}
