      "initial_source_lines": [
        "export function greet(name: string): string {",
        "  return `Hello, ${name}`;",
        "}",
        "",
        "export class Greeter {",
        "  message(name: string): string {",
        "    return greet(name);",
        "  }",
        "}",
        ""
