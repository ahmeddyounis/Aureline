    {
      "label": "python_large_region_symbol_snapshot",
      "language_id": "language:python",
      "workspace_relative_path": "service/example.py",
      "initial_source_lines": [
        "def alpha():",
        "    return 1",
        "",
        "def beta():",
        "    return 2",
        "",
        "class Service:",
        "    def handle(self):",
        "        return beta()",
        ""
      ],
      "edit": {
        "edit_id": "edit:large:replace-service-region",
        "find_text": "def beta():\n    return 2\n\nclass Service:\n    def handle(self):\n        return beta()",
        "replacement_text": "def gamma(value):\n    total = value + 1\n    if total > 3:\n        return total\n    return alpha()\n\nclass Service:\n    def handle(self, value):\n        result = gamma(value)\n        return result\n\n    def helper(self):\n        return gamma(2)"
      },
      "expected_workload": "large_changed_region",
      "expected_symbols_after": ["alpha", "gamma", "Service", "handle", "helper"]
    }
  ],
  "benchmark_expectations": {
    "required_workloads": ["ordinary_typing", "large_changed_region"]
  }
