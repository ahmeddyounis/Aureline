{
  "record_kind": "workspace_lifecycle_case",
  "schema_version": 1,
  "workspace_id": "ws-test",
  "initial_observed_at": "mono:0",
  "steps": [
    { "action": "open_workspace", "observed_at": "mono:1" },
    { "action": "resolve_trust", "trust_state": "trusted", "observed_at": "mono:2" },
    { "action": "mark_shell_interactive", "observed_at": "mono:3" },
    {
      "action": "update_readiness_gates",
      "watcher_health": "healthy",
      "hot_index_ready": true,
      "command_graph_ready": true,
      "observed_at": "mono:4"
    },
    {
      "action": "update_readiness_gates",
      "watcher_health": "fallback_polling",
      "observed_at": "mono:5",
      "reason_code": "watcher_fault"
    },
    { "action": "update_readiness_gates", "watcher_health": "healthy", "observed_at": "mono:6" }
  ],
  "expect": {
    "final_state": "ready",
    "final_trust_state": "trusted",
    "final_watcher_health": "healthy",
    "final_hot_index_ready": true,
    "final_command_graph_ready": true,
    "required_transitions": [
      { "from": "discovered", "to": "trust_evaluating" },
      { "from": "trust_evaluating", "to": "opening" },
      { "from": "opening", "to": "partially_ready" },
      { "from": "partially_ready", "to": "ready" },
      { "from": "ready", "to": "degraded" },
      { "from": "degraded", "to": "partially_ready" },
      { "from": "partially_ready", "to": "ready" }
    ]
  }
}
