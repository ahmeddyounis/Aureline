{
  "$schema": "../../../schemas/workspace/generated_artifact_lineage.schema.json",
  "__fixture__": "fixtures.workspace.generated_artifacts.build_output_no_canonical_sibling",
  "case_id": "fixtures.workspace.generated_artifacts.build_output_no_canonical_sibling",
  "title": "Build outputs report a generated class but no source-canonical sibling, so explorer/search keep them visible without implying a single canonical edit target.",
  "scenario": "Cargo's `target/` and an arbitrary `dist/` bundle output are detected as build outputs. The lineage record carries `generated_class=build_output` and a `null` source-canonical pointer because there is no single canonical edit target.",
  "input": {
    "relative_paths": [
      "target/debug/build/foo/out/codegen.rs",
      "dist/main.bundle.js",
      "node_modules/lodash/index.js"
    ]
  },
  "expected_lineage_records": [
    {
      "generated_relative_path": "target/debug/build/foo/out/codegen.rs",
      "generated_class": "build_output",
      "source_canonical_relative_path": null,
      "producer_id": "producer:cargo_target",
      "producer_label": "Cargo build output",
      "freshness_class": "possibly_stale",
      "rule_id": "build_output.cargo_target"
    },
    {
      "generated_relative_path": "dist/main.bundle.js",
      "generated_class": "build_output",
      "source_canonical_relative_path": null,
      "producer_id": "producer:dist_bundle",
      "producer_label": "Distribution bundle",
      "freshness_class": "possibly_stale",
      "rule_id": "build_output.dist"
    },
    {
      "generated_relative_path": "node_modules/lodash/index.js",
      "generated_class": "vendored_snapshot",
      "source_canonical_relative_path": null,
      "producer_id": "producer:npm_install",
      "producer_label": "Vendored node_modules",
      "freshness_class": "snapshot_only",
      "rule_id": "vendored.node_modules"
    }
  ]
}
