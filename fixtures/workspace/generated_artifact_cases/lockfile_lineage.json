{
  "$schema": "../../../schemas/workspace/generated_artifact_lineage.schema.json",
  "__fixture__": "fixtures.workspace.generated_artifacts.lockfile_lineage",
  "case_id": "fixtures.workspace.generated_artifacts.lockfile_lineage",
  "title": "Cargo lockfile points back to its manifest sibling, and the explorer/search rows label the row distinctly from a hand-authored source.",
  "scenario": "A workspace contains the canonical Cargo.toml and the resolver-generated Cargo.lock side-by-side. The explorer must label Cargo.lock as a lockfile pointing at Cargo.toml; the lexical search shell must label the same row distinctly when the user searches for it.",
  "input": {
    "relative_paths": [
      "Cargo.lock",
      "Cargo.toml",
      "crates/aureline-shell/Cargo.lock",
      "crates/aureline-shell/Cargo.toml"
    ]
  },
  "expected_lineage_records": [
    {
      "generated_relative_path": "Cargo.lock",
      "generated_class": "lockfile",
      "source_canonical_relative_path": "Cargo.toml",
      "producer_id": "producer:cargo_lockfile",
      "producer_label": "Cargo lockfile",
      "freshness_class": "derived_from_canonical",
      "rule_id": "lockfile.cargo"
    },
    {
      "generated_relative_path": "Cargo.toml",
      "expect_match": false
    },
    {
      "generated_relative_path": "crates/aureline-shell/Cargo.lock",
      "generated_class": "lockfile",
      "source_canonical_relative_path": "crates/aureline-shell/Cargo.toml",
      "producer_id": "producer:cargo_lockfile",
      "producer_label": "Cargo lockfile",
      "freshness_class": "derived_from_canonical",
      "rule_id": "lockfile.cargo"
    },
    {
      "generated_relative_path": "crates/aureline-shell/Cargo.toml",
      "expect_match": false
    }
  ]
}
