{
  "$schema": "../../../schemas/ux/notification_suppression_record.schema.json",
  "__fixture__": {
    "name": "lock_screen_safe_generic_payload_rule",
    "scenario": "Per-class rule for the lock_screen_safe_generic privacy payload class. Lock-screen, companion, and system-notification surfaces may carry the payload. Allowed labels are restricted to category-class, severity-class, lifecycle-phase, member-count, audit-only-marker, and privacy-redacted placeholders — no workspace, session, actor, object identity, or next-action labels. Allowed actions cover read-only opens (in product, canonical object, durable row, digest group, attention item), snooze-until-unlock, acknowledge-clears-badge, dismiss-transient, and show-held-in-product. Forbidden shortcut classes cover every mutation, secret-reveal, irreversible, review-bypass, and trust / policy / provider-grant change.",
    "exercised_axes": {
      "privacy_payload_class": "lock_screen_safe_generic",
      "applies_to_surface_classes": ["lock_screen_summary", "companion_push", "os_notification"],
      "lock_screen_safe": true
    },
    "contract_sections": [
      "Privacy-safe payload classes",
      "No-bypass on high-risk shortcuts"
    ]
  },
  "record_kind": "privacy_safe_payload_rule_record",
  "notification_suppression_schema_version": 1,
  "rule_id": "ux:privacy-payload-rule:lock_screen_safe_generic",
  "privacy_payload_class": "lock_screen_safe_generic",
  "applies_to_surface_classes": [
    "lock_screen_summary",
    "companion_push",
    "os_notification"
  ],
  "allowed_label_kinds": [
    "category_label_only",
    "summary_member_count_label",
    "severity_class_label",
    "lifecycle_phase_label",
    "audit_only_marker",
    "privacy_redacted_placeholder"
  ],
  "forbidden_label_kinds": [
    "raw_path",
    "raw_url",
    "raw_email",
    "raw_provider_payload",
    "raw_secret_material",
    "raw_prompt_text",
    "raw_completion_text",
    "raw_command_body",
    "customer_owned_identifier",
    "destructive_intent_phrase",
    "object_identity_on_lock_screen",
    "actor_real_name_on_lock_screen",
    "review_diff_excerpt_on_lock_screen"
  ],
  "allowed_action_kinds": [
    "open_in_product",
