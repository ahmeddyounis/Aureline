{
  "$schema": "../../../schemas/ux/notification_suppression_record.schema.json",
  "__fixture__": {
    "name": "in_product_only_payload_rule",
    "scenario": "Per-class rule for the in_product_only privacy payload class. The class never reaches lock-screen surfaces and never reaches companion or system-notification surfaces. The rule's applies_to_surface_classes is restricted to in-product render surfaces — toast, contextual_banner, status_item, durable_job_row, attention_item, activity_center_digest_card, digest_group_row. Allowed labels widen to scoped workspace / session / next-action / actor-role labels. Allowed actions cover open-in-product variants only. Forbidden shortcut classes still apply: even an in-product surface MAY NOT bypass the review sheet or approval workflow for high-risk actions.",
    "exercised_axes": {
      "privacy_payload_class": "in_product_only",
      "lock_screen_safe": false,
      "companion_safe": false,
      "system_notification_safe": false
    },
    "contract_sections": [
      "Privacy-safe payload classes"
    ]
  },
  "record_kind": "privacy_safe_payload_rule_record",
  "notification_suppression_schema_version": 1,
  "rule_id": "ux:privacy-payload-rule:in_product_only",
  "privacy_payload_class": "in_product_only",
  "applies_to_surface_classes": [
    "toast",
    "contextual_banner",
    "status_item",
    "durable_job_row",
    "attention_item",
    "activity_center_digest_card",
    "digest_group_row"
  ],
  "allowed_label_kinds": [
    "category_label_only",
    "scoped_workspace_label",
    "scoped_session_label",
    "next_action_label",
    "summary_member_count_label",
    "actor_role_label",
    "severity_class_label",
    "lifecycle_phase_label"
  ],
  "forbidden_label_kinds": [
    "raw_path",
    "raw_url",
    "raw_email",
    "raw_provider_payload",
    "raw_secret_material",
    "raw_prompt_text",
    "raw_completion_text",
    "raw_command_body",
    "customer_owned_identifier"
  ],
  "allowed_action_kinds": [
    "open_in_product",
    "open_review_context_in_product",
    "open_canonical_object_in_product",
    "open_durable_row_in_product",
    "open_digest_group_in_product",
    "open_attention_item_in_product",
    "show_held_in_product",
    "acknowledge_clears_badge_only",
    "dismiss_transient_only"
  ],
  "forbidden_shortcut_action_classes": [
    "bypass_review_sheet",
    "bypass_approval_workflow",
    "direct_mutation_from_lock_screen",
    "direct_mutation_from_companion_push",
    "direct_mutation_from_dock_or_taskbar",
    "direct_mutation_from_system_tray"
  ],
  "redacted_summary_template_label": "{category} in {workspace_label}",
  "redaction_template_tokens": [
    "{category}",
    "{workspace_label}",
    "{session_label}",
    "{actor_role}",
    "{severity_class}",
    "{lifecycle_phase}"
  ],
  "max_label_text_length": 160,
  "requires_in_product_open_for_actions": true,
  "must_resolve_through_in_product_surface_for_high_risk": true,
  "lock_screen_safe": false,
  "companion_safe": false,
  "system_notification_safe": false
}
