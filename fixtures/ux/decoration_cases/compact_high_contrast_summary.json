{
  "__fixture__": {
    "name": "compact_high_contrast_summary",
    "scenario": "A compact high-contrast tab cannot fit every badge. It must keep blocked/trust text visible and summarize generated, stale, imported, and lifecycle state without relying on hue.",
    "exercised_axes": {
      "surface_family": "tab",
      "adaptive_class": "compact_desktop",
      "high_contrast": true,
      "summary_accessible": true
    },
    "contract_sections": [
      "Surface Projection Rules",
      "No-Hue-Only and Accessibility Rules",
      "Collapse and Summary Rules"
    ],
    "linked_docs": [
      "docs/ux/decoration_precedence_contract.md",
      "docs/design/design_token_component_state_vocabulary.md",
      "docs/ux/tabs_editor_groups_contract.md"
    ]
  },
  "record_kind": "decoration_conflict_case",
  "decoration_case_schema_version": 1,
  "case_id": "decor.case.compact.high_contrast.summary",
  "object_ref": "object:tab.generated.report.snapshot",
  "surface_family": "tab",
  "input_states": [
    {
      "family": "blocked_degraded",
      "state": "blocked",
      "precedence_band": "blocked_or_high_severity",
      "source_ref": "review:apply.blocked",
      "label": "Blocked",
      "consequence": "Apply is blocked until the report source is refreshed."
    },
    {
      "family": "trust",
      "state": "restricted_workspace",
      "precedence_band": "trust_or_policy_critical",
      "source_ref": "trust:workspace.restricted",
      "label": "Restricted workspace",
      "consequence": "The tab cannot elevate active content."
    },
    {
      "family": "generated",
      "state": "generated_read_only",
      "precedence_band": "generated_derived",
      "source_ref": "lineage:report.generator",
      "label": "Generated",
      "consequence": "The report is read-only generated output."
    },
    {
      "family": "freshness",
      "state": "stale",
      "precedence_band": "freshness_import_snapshot",
      "source_ref": "snapshot:report.2026-04-18",
      "label": "Stale",
      "consequence": "The visible report is below freshness floor."
    },
    {
      "family": "imported_snapshot",
      "state": "captured_snapshot",
      "precedence_band": "freshness_import_snapshot",
      "source_ref": "capture:report.snapshot",
      "label": "Captured snapshot",
      "consequence": "The tab is showing captured evidence, not live source."
    },
    {
      "family": "lifecycle",
      "state": "preview",
      "precedence_band": "lifecycle_support",
      "source_ref": "capability:report_viewer",
      "label": "Preview",
      "consequence": "The report viewer is preview."
    }
  ],
  "expected_resolution": {
    "primary_visual_state": {
      "family": "trust",
      "state": "restricted_workspace",
      "precedence_band": "trust_or_policy_critical",
      "label": "Restricted",
      "required_channels": [
        "text",
        "icon",
        "shape_or_border"
      ],
      "reason": "Trust restriction is the highest band. The blocked state remains a required secondary text cue because it changes apply behavior."
    },
    "secondary_visible_states": [
      {
        "family": "blocked_degraded",
        "state": "blocked",
        "label": "Blocked"
      }
    ],
    "collapsed_summary": {
      "label": "4 more states",
      "families": [
        "generated",
        "freshness",
        "imported_snapshot",
        "lifecycle"
      ],
      "must_be_keyboard_reachable": true,
      "must_not_use_hue_only": true
    },
    "accessible_name_must_include": [
      "Restricted workspace",
      "Blocked",
      "Generated",
      "Stale",
      "Captured snapshot",
      "Preview"
    ],
    "detail_sections": [
      "primary_state_reason",
      "trust_and_policy",
      "blockers_and_degradation",
      "lifecycle_and_support",
      "freshness_and_snapshot",
      "generated_and_lineage",
      "hidden_by_precedence"
    ],
    "forbidden_renderings": [
      "red_or_green_only_tab_state",
      "blocked_hidden_behind_more_menu",
      "summary_count_without_family_names",
      "hover_only_state_recovery"
    ]
  },
  "surface_projection": {
    "tab": {
      "visible_label": "report.html",
      "primary_cue": "Restricted",
      "secondary_cue": "Blocked",
      "summary_affordance": "4 more states",
      "overflow_row_states": [
        "Restricted workspace",
        "Blocked",
        "Generated",
        "Stale",
        "Captured snapshot",
        "Preview"
      ],
      "focus_popover_command_id": "cmd:tab.decoration.inspect_state"
    }
  },
  "assertions": {
    "high_contrast_preserves_state_without_hue": true,
    "compact_layout_has_keyboard_reachable_summary": true,
    "trust_and_blocked_text_visible": true,
    "lower_priority_states_preserved_in_accessible_name": true
  },
  "narrative_refs": [
    "docs/ux/decoration_precedence_contract.md",
    "docs/design/design_token_component_state_vocabulary.md",
    "docs/ux/tabs_editor_groups_contract.md"
  ]
}
