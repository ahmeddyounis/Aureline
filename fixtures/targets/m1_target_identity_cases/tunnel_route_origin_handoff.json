{
  "__fixture__": {
    "name": "tunnel_route_origin_handoff",
    "scenario": "Open a trusted local-desktop terminal, then hand off to an SSH remote reached through a declared tunnel route. The wedge keeps the target class as remote_host while the route-origin label renders Tunnel and preserves the tunnel session and target identity refs.",
    "owning_lane": "host_boundary_cues_seed"
  },
  "workspace_id": "ws-host-boundary",
  "steps": [
    {
      "kind": "initial_open",
      "host_class": "host_desktop",
      "target_class": "local_host",
      "working_directory": "/workspace",
      "execution_context_ref": "execution_context.local_desktop.workspace_root",
      "display_title": "zsh",
      "cwd_hint": "~/code/aureline",
      "observed_at": "mono:1"
    },
    {
      "kind": "target_handoff",
      "host_class": "remote_agent_primary",
      "target_class": "ssh_remote",
      "working_directory": "/srv/code",
      "execution_context_ref": "execution_context.ssh_remote.tunnel.prod_host",
      "route_origin": {
        "route_class": "tunnel_exposed_route",
        "transport_label": "SSH tunnel",
        "tunnel_session_ref": "tunnel.session.prod.0001",
        "target_identity_ref": "target.ssh_remote.prod_host"
      },
      "display_title": "ssh tunnel prod",
      "cwd_hint": "/srv/code",
      "observed_at": "mono:2"
    }
  ],
  "expect": {
    "current_boundary_cue": "local_to_remote",
    "current_boundary_cue_visible": true,
    "has_honesty_marker": false,
    "has_invariant_violations": false,
    "steps": [
      {
        "kind": "initial_open",
        "boundary_cue": "hidden",
        "boundary_cue_visible": false,
        "degraded_token": null,
        "honesty_marker_present": false,
        "current_target_class": "local_desktop",
        "source_target_class": null,
        "current_route_origin_class": "local_only"
      },
      {
        "kind": "target_handoff",
        "boundary_cue": "local_to_remote",
        "boundary_cue_visible": true,
        "degraded_token": null,
        "honesty_marker_present": false,
        "current_target_class": "remote_host",
        "source_target_class": "local_desktop",
        "current_route_origin_class": "tunnel_exposed_route"
      }
    ]
  }
}
