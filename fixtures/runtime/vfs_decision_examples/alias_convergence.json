{
  "$schema": "../../../schemas/runtime/vfs_save_envelope.schema.json",
  "__fixture__": {
    "name": "alias_convergence",
    "scenario": "User opens README.md through a symlink named docs/current-readme.md. The VFS canonicalises both paths, detects they resolve to the same device+inode+generation token, converges them onto one dirty-buffer authority, and discloses the alias relationship in the identity record. A subsequent save against either presentation path targets the same canonical object.",
    "hooks_exercised": [
      "vfs_canonicalize",
      "vfs_alias_converge"
    ],
    "adr_sections": [
      "Filesystem-identity layers: alias_set",
      "Identity rules: convergence onto one dirty-buffer authority",
      "Alias handling"
    ]
  },
  "record_kind": "identity_record",
  "vfs_save_envelope_schema_version": 1,
  "presentation_path": {
    "uri": "file:///Users/example/projects/aureline/docs/current-readme.md",
    "display_label": "current-readme.md",
    "root_badge": "local"
  },
  "logical_workspace_identity": {
    "workspace_id": "ws-aureline-primary",
    "root_id": "root-1",
    "logical_uri": "aureline-ws://ws-aureline-primary/root-1/README.md",
    "trust_state": "trusted"
  },
  "canonical_filesystem_object": {
    "canonical_uri": "file:///Users/example/projects/aureline/README.md",
    "normalization_form": "mixed_observed",
    "strongest_identity_token": {
      "kind": "device_inode_generation",
      "value": "dev:16777232/ino:48215119/gen:5"
    },
    "fallback_identity_tokens": [
      { "kind": "inode_mtime_size", "value": "48215119/1745074102/2041" }
    ]
  },
  "alias_set": {
    "aliases": [
      {
        "alias_uri": "file:///Users/example/projects/aureline/docs/current-readme.md",
        "alias_kind": "symlink",
        "resolution_chain": [
          "file:///Users/example/projects/aureline/docs/current-readme.md",
          "-> symlink target",
          "file:///Users/example/projects/aureline/README.md"
        ]
      },
      {
        "alias_uri": "file:///Users/example/projects/aureline/README.md",
        "alias_kind": "symlink",
        "resolution_chain": [
          "file:///Users/example/projects/aureline/README.md",
          "-> canonical"
        ]
      }
    ]
  }
