{
  "$schema": "../../../schemas/runtime/vfs_save_envelope.schema.json",
  "__fixture__": {
    "name": "case_only_rename_preview",
    "scenario": "User requests to rename README.md to Readme.md on a case-insensitive but case-preserving root (APFS with case-insensitive policy, or NTFS). The VFS reads supports_case_only_rename from the root envelope, produces a previewable rename plan, and does not commit the rename until the user accepts the plan. A rename collision with a sibling Readme.md (the opposite case) is surfaced rather than silently coerced.",
    "hooks_exercised": [
      "vfs_rename_plan_previewed",
      "vfs_canonicalize"
    ],
    "adr_sections": [
      "Filesystem-identity layers: rules for case-only rename",
      "Root-capability envelope: supports_case_only_rename",
      "Failure cases: wrong_target_prevention"
    ]
  },
  "record_kind": "root_capability_envelope",
  "vfs_save_envelope_schema_version": 1,
  "root_id": "root-1",
  "root_class": "local_posix_like",
  "capability_flags": {
    "supports_atomic_replace": true,
    "supports_in_place_write": true,
    "supports_conditional_remote_write": false,
    "case_sensitivity": "insensitive_preserving",
    "unicode_normalization": "mixed_observed",
    "supports_case_only_rename": true,
    "supports_unicode_normalization_rename": false,
    "symlink_escape_policy": "warn",
    "read_only": false,
    "policy_constrained": false,
    "review_required_before_save": false,
    "review_required_before_rename": false,
    "remote_container_adaptation": false
  },
  "strongest_identity_token_kind": "device_inode_generation",
  "fallback_identity_token_kinds": [
    "device_inode",
    "inode_mtime_size",
    "content_hash"
  ],
  "preferred_save_mode": "atomic_replace",
  "permitted_save_modes": [
    "atomic_replace",
    "in_place_write",
    "blocked"
  ],
  "watcher_source": "os_native_watcher"
}
