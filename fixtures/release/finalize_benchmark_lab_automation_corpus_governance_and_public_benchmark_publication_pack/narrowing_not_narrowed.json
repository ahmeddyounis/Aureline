    "below_cutline_levels": [
      "beta",
      "preview",
      "withdrawn"
    ],
    "description": "A benchmark-lab governance asset carries a Stable (or LTS) public claim only when its proof packet is within its freshness SLO, any waiver it relies on is unexpired, its benchmark corpus metadata and lab trace are present where it makes a performance claim, its evidence is complete, an owner has signed off, and the public claim it backs is itself at or above the cutline. An asset that loses any of those carries a label below the cutline (beta, preview, withdrawn) and never inherits an adjacent backed asset's published label."
  },
  "release_blocking_surface_refs": [
    "surface:nightly_benchmark_ci_lane",
