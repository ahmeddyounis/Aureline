  "rules": [
    {
      "rule_id": "gov_rule:claim_label_narrowed",
      "title": "Backing public claim narrowed below cutline",
      "trigger_reason": "claim_label_narrowed",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_label",
      "blocks_qualification": false,
      "rationale": "An asset whose backing public claim is already below the stable cutline inherits that ceiling; the stable claim manifest already holds the claim upstream, so this is expected inheritance rather than a governance defect and does not hold qualification on its own."
    },
    {
      "rule_id": "gov_rule:surface_capability_absent",
      "title": "Asset names an unimplemented surface capability",
      "trigger_reason": "surface_capability_absent",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_evidence",
      "blocks_qualification": true,
      "rationale": "An asset that names a surface capability the build does not yet implement cannot carry a Stable public claim; the asset narrows and qualification holds until the capability lands and is re-evidenced."
    },
    {
      "rule_id": "gov_rule:evidence_incomplete",
      "title": "Asset evidence incomplete",
      "trigger_reason": "evidence_incomplete",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_evidence",
      "blocks_qualification": true,
      "rationale": "An asset whose proof packet does not cover the required evidence scope narrows until the evidence is recaptured; the asset cannot carry Stable on partial evidence."
    },
    {
      "rule_id": "gov_rule:corpus_metadata_missing",
      "title": "Benchmark corpus metadata or lab trace missing",
      "trigger_reason": "corpus_metadata_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_proof_packet",
      "blocks_qualification": true,
      "rationale": "An asset whose published benchmark numbers cannot be traced to a corpus manifest and a benchmark-lab trace narrows until both are attached; an untraceable benchmark cannot carry a Stable public claim."
    },
    {
      "rule_id": "gov_rule:proof_packet_freshness_breached",
      "title": "Proof packet breached its freshness SLO",
      "trigger_reason": "proof_packet_freshness_breached",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_proof_packet",
      "blocks_qualification": true,
      "rationale": "An asset whose proof packet aged past its freshness SLO narrows until the packet is refreshed; a stale packet cannot carry a Stable public claim even when the claim it backs is still published Stable upstream."
    },
    {
      "rule_id": "gov_rule:proof_packet_missing",
      "title": "Proof packet missing",
      "trigger_reason": "proof_packet_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_proof_packet",
      "blocks_qualification": true,
      "rationale": "An asset with no captured proof packet narrows until one is captured; an unproven asset cannot carry a Stable public claim."
    },
    {
      "rule_id": "gov_rule:waiver_expired",
      "title": "Asset waiver expired",
      "trigger_reason": "waiver_expired",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_label",
      "blocks_qualification": true,
      "rationale": "An asset that carried a Stable public claim only under a waiver narrows the moment that waiver expires; qualification holds until the underlying gap is closed or a fresh waiver is granted."
    },
    {
      "rule_id": "gov_rule:owner_signoff_missing",
      "title": "Owner sign-off missing",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "request_owner_signoff",
      "blocks_qualification": true,
      "rationale": "An asset carrying a Stable public claim requires an owner sign-off; without it the asset narrows and qualification holds until the owner signs off."
    }
  ],
