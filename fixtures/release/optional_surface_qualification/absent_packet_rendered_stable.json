  "stop_rules": [
    {
      "rule_id": "surface_rule:claim_label_narrowed",
      "title": "Backing public claim narrowed below cutline",
      "trigger_reason": "claim_label_narrowed",
      "applies_to_labels": [
        "beta",
        "preview",
        "withdrawn"
      ],
      "default_action": "narrow_surface_label",
      "blocks_promotion": false,
      "rationale": "An optional surface whose backing public claim is already below the stable cutline inherits that ceiling; the stable claim manifest already holds the claim upstream, so this is expected inheritance rather than a register defect and does not hold publication on its own."
    },
    {
      "rule_id": "surface_rule:qualification_packet_absent",
      "title": "Optional surface lacks a stable qualification packet",
      "trigger_reason": "qualification_packet_absent",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "author_qualification_packet",
      "blocks_promotion": true,
      "rationale": "An optional surface with no stable qualification packet at all cannot back a Stable public claim by riding on an adjacent qualified surface; it narrows below the cutline and publication holds until a qualification packet is authored, captured, and signed off."
    },
    {
      "rule_id": "surface_rule:surface_capability_absent",
      "title": "Optional surface names an unimplemented capability",
      "trigger_reason": "surface_capability_absent",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_surface_evidence",
      "blocks_promotion": true,
      "rationale": "An optional surface that names a capability the build does not yet implement cannot back a Stable public claim; the surface narrows and publication holds until the capability lands and is re-qualified."
    },
    {
      "rule_id": "surface_rule:surface_evidence_incomplete",
      "title": "Optional surface evidence incomplete",
      "trigger_reason": "surface_evidence_incomplete",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_surface_evidence",
      "blocks_promotion": true,
      "rationale": "An optional surface whose qualification evidence is incomplete cannot back a Stable public claim; it narrows and publication holds until the evidence is recaptured."
    },
    {
      "rule_id": "surface_rule:qualification_packet_breached",
      "title": "Qualification packet breached its freshness SLO",
      "trigger_reason": "qualification_packet_breached",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_qualification_packet",
      "blocks_promotion": true,
      "rationale": "An optional surface whose qualification packet has aged past its freshness SLO no longer carries current proof; it narrows and publication holds until the packet is refreshed within its SLO."
    },
    {
      "rule_id": "surface_rule:waiver_expired",
      "title": "Relied-on waiver expired",
      "trigger_reason": "waiver_expired",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "hold_promotion",
      "blocks_promotion": true,
      "rationale": "An optional surface that rendered qualified only because of a waiver loses that authorization once the waiver expires; it narrows and publication holds until the underlying gap is closed or a fresh waiver is granted."
    },
    {
      "rule_id": "surface_rule:owner_signoff_missing",
      "title": "Owner sign-off missing",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "request_owner_signoff",
      "blocks_promotion": true,
      "rationale": "An optional surface cannot back a Stable public claim without an owner sign-off; it narrows and publication holds until the owner signs off."
    }
