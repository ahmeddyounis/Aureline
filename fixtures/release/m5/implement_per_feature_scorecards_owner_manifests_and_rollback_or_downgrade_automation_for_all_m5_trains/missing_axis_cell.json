        "stable"
      ],
      "default_action": "remediate_scorecard",
      "blocks_promotion": true,
      "rationale": "An M5 train scorecard whose posture reports 'scorecard_axis_failed' cannot keep a Stable or LTS claim and must narrow before publication."
