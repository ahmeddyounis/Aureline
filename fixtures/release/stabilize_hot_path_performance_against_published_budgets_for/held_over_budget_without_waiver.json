        "stable"
      ],
      "default_action": "refresh_proof_packet",
      "blocks_promotion": true,
      "rationale": "A hot-path budget without a captured proof packet cannot carry a Stable public claim."
    },
    {
      "rule_id": "hotpath_rule:corpus_metadata_missing",
      "title": "Corpus metadata or benchmark-lab trace missing",
      "trigger_reason": "corpus_metadata_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_proof_packet",
      "blocks_promotion": true,
      "rationale": "An untraceable benchmark cannot carry a Stable public claim; corpus metadata and lab trace must both be present."
    },
    {
      "rule_id": "hotpath_rule:owner_signoff_missing",
      "title": "Required owner sign-off missing",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "request_owner_signoff",
      "blocks_promotion": true,
      "rationale": "A hot-path budget without owner sign-off cannot carry a Stable public claim."
    },
