    "surface:search_results_latency"
  ],
  "rules": [
    {
      "rule_id": "hotpath_rule:claim_label_narrowed",
      "title": "Backing public claim narrowed below cutline",
      "trigger_reason": "claim_label_narrowed",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_label",
      "blocks_promotion": false,
      "rationale": "A hot-path budget whose backing public claim is already below the stable cutline inherits that ceiling; this is expected inheritance rather than a performance defect."
    },
    {
      "rule_id": "hotpath_rule:budget_regressed",
      "title": "Measured p50/p95 regressed beyond published budget",
      "trigger_reason": "budget_regressed",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "retune_or_waive_budget",
      "blocks_promotion": true,
      "rationale": "A hot-path budget whose measured p50/p95 exceeds the published ceiling narrows until the implementation re-meets the budget, the numbers are re-published, or a waiver covers an intentionally tightened threshold."
    },
    {
      "rule_id": "hotpath_rule:proof_packet_freshness_breached",
      "title": "Proof packet breached freshness SLO",
      "trigger_reason": "proof_packet_freshness_breached",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_proof_packet",
      "blocks_promotion": true,
      "rationale": "A hot-path budget whose proof packet is stale cannot carry a Stable public claim; the trace must be re-run and the packet refreshed."
    },
    {
      "rule_id": "hotpath_rule:proof_packet_missing",
      "title": "Proof packet missing",
      "trigger_reason": "proof_packet_missing",
      "applies_to_labels": [
