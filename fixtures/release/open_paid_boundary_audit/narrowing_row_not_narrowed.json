  "rules": [
    {
      "rule_id": "audit_rule:claim_label_narrowed",
      "title": "Backing public claim narrowed below cutline",
      "trigger_reason": "claim_label_narrowed",
      "applies_to_labels": [
        "beta",
        "preview",
        "withdrawn"
      ],
      "default_action": "narrow_audit_label",
      "blocks_publication": false,
      "rationale": "An audit row whose backing public claim is already below the stable cutline inherits that ceiling; the stable claim manifest holds the claim upstream, so this is expected inheritance rather than an audit defect and does not hold publication on its own."
    },
    {
      "rule_id": "audit_rule:audit_evidence_incomplete",
      "title": "Audit evidence incomplete",
      "trigger_reason": "audit_evidence_incomplete",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_audit_evidence",
      "blocks_publication": true,
      "rationale": "An audit row whose boundary, licensing, provenance, or contribution evidence is incomplete cannot back a Stable public claim; it narrows and publication holds until the evidence is recaptured."
    },
    {
      "rule_id": "audit_rule:attestation_packet_freshness_breached",
      "title": "Attestation packet breached its freshness SLO",
      "trigger_reason": "attestation_packet_freshness_breached",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_attestation_packet",
      "blocks_publication": true,
      "rationale": "An audit row whose attestation packet has aged past its freshness SLO no longer carries current proof of the boundary, license, provenance, or contribution control; it narrows and publication holds until the packet is refreshed within its SLO."
    },
    {
      "rule_id": "audit_rule:attestation_packet_missing",
      "title": "Attestation packet missing",
      "trigger_reason": "attestation_packet_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_attestation_packet",
      "blocks_publication": true,
      "rationale": "An audit row with no captured attestation packet cannot back a Stable public claim by riding an adjacent attested row; it narrows and publication holds until a packet is captured and signed off."
    },
    {
      "rule_id": "audit_rule:waiver_expired",
      "title": "Relied-on waiver expired",
      "trigger_reason": "waiver_expired",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "hold_publication",
      "blocks_publication": true,
      "rationale": "An audit row that attested only because of a waiver loses that authorization once the waiver expires; it narrows and publication holds until the underlying gap is closed or a fresh waiver is granted."
    },
    {
      "rule_id": "audit_rule:owner_signoff_missing",
      "title": "Row owner signoff missing",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "request_owner_signoff",
      "blocks_publication": true,
      "rationale": "An audit row cannot back a Stable public claim without the row owner's signoff; it narrows and publication holds until the owner signs."
    },
    {
      "rule_id": "audit_rule:audit_control_unsatisfied",
      "title": "Required audit control unsatisfied",
      "trigger_reason": "audit_control_unsatisfied",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "satisfy_audit_control",
      "blocks_publication": true,
      "rationale": "An audit row with a required boundary, licensing, provenance, or contribution-policy control that is not satisfied cannot back a Stable public claim; it narrows and publication holds until the control is satisfied."
    }
  ],
