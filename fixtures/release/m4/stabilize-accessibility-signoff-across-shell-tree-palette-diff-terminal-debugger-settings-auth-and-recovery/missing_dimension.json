    "description": "An accessibility surface signoff carries a Stable (or LTS) public claim only when all dimensions pass or degrade gracefully, the proof packet is current within its freshness SLO, any waiver is unexpired, and the public claim it backs is itself at or above the cutline. A surface that loses any of those carries a label below the cutline and never inherits an adjacent qualified surface."
  },
  "release_blocking_surface_refs": [
    "surface:shell",
    "surface:tree",
    "surface:palette",
    "surface:diff",
    "surface:terminal",
    "surface:debugger",
