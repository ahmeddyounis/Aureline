    "surface:auth",
    "surface:recovery"
  ],
  "rules": [
    {
      "rule_id": "a11y_rule:claim_label_narrowed",
      "title": "Backing public claim narrowed below cutline",
      "trigger_reason": "claim_label_narrowed",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_claim",
      "blocks_promotion": false,
      "rationale": "An accessibility signoff whose backing public claim is already below the stable cutline inherits that ceiling; this is expected inheritance rather than an accessibility defect."
    },
    {
      "rule_id": "a11y_rule:dimension_blocked",
      "title": "At least one accessibility dimension is blocked or pending evidence",
      "trigger_reason": "dimension_blocked",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_claim",
      "blocks_promotion": true,
      "rationale": "A surface with a blocked or pending-evidence dimension cannot carry a Stable accessibility claim until the gap is closed or waived."
    },
    {
      "rule_id": "a11y_rule:evidence_stale",
      "title": "Proof packet breached freshness SLO",
      "trigger_reason": "evidence_stale",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_evidence_packet",
      "blocks_promotion": true,
      "rationale": "An accessibility signoff whose proof packet is stale must refresh evidence before it can hold a Stable claim."
    },
    {
      "rule_id": "a11y_rule:evidence_missing",
      "title": "Proof packet missing or incomplete",
      "trigger_reason": "evidence_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_evidence_packet",
      "blocks_promotion": true,
      "rationale": "An accessibility signoff without a captured proof packet cannot hold a Stable claim."
    },
    {
      "rule_id": "a11y_rule:owner_signoff_missing",
      "title": "Required owner sign-off is missing",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "request_owner_signoff",
      "blocks_promotion": true,
      "rationale": "An accessibility signoff must be owner-signed before it can hold a Stable claim."
    },
    {
      "rule_id": "a11y_rule:waiver_expired",
      "title": "Waiver covering a provisional signoff has expired",
      "trigger_reason": "waiver_expired",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_claim",
      "blocks_promotion": true,
      "rationale": "A provisional signoff held on a waiver narrows automatically when the waiver expires."
    }
  ],
