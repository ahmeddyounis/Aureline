{
  "description": "Validation fixture cases for the ring promotion control register.",
  "artifact_source": "artifacts/release/stabilize_the_release_center_promotion_evidence_canary_pilot.json",
  "schema": "schemas/release/stabilize_the_release_center_promotion_evidence_canary_pilot.schema.json",
  "cases": [
    {
      "file": "valid_artifact.json",
      "expected": "passes",
      "description": "Baseline valid artifact"
    },
    {
      "file": "missing_subject_kind.json",
      "expected": "fails",
      "violation": "SubjectKindMissing",
      "description": "All ai_tool_pack rows removed"
    },
    {
      "file": "held_with_active_gap.json",
      "expected": "fails",
      "violation": "HeldRowWithActiveGap",
      "description": "Qualified row carries an active gap reason"
    },
    {
      "file": "narrowing_row_not_narrowed.json",
      "expected": "fails",
      "violation": "EffectiveLabelNotNarrowed",
      "description": "NarrowedStale row retains claim label"
    },
    {
      "file": "stale_packet_not_narrowed.json",
      "expected": "fails",
      "violation": "EffectiveLabelNotNarrowed",
      "description": "Stale row did not drop effective label"
    },
    {
      "file": "target_narrower_than_current.json",
      "expected": "fails",
      "violation": "TargetRingNarrowerThanCurrent",
      "description": "Target ring is narrower than current ring"
    },
    {
      "file": "missing_rule_for_reason.json",
      "expected": "fails",
      "violation": "GapReasonWithoutRule",
      "description": "No rule watches for waiver_expired"
    },
    {
      "file": "rollback_target_wider.json",
      "expected": "fails",
      "violation": "RollbackTargetWiderThanCurrent",
      "description": "Rollback target is wider than current ring"
    }
  ]
}