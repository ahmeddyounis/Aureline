  "rules": [
    {
      "rule_id": "response_rule:claim_label_narrowed",
      "title": "Backing public claim narrowed below cutline",
      "trigger_reason": "claim_label_narrowed",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "narrow_response_label",
      "blocks_publication": false,
      "rationale": "A lane whose backing public claim is already below the stable cutline inherits that ceiling; the stable claim manifest already holds the claim upstream, so this is expected inheritance rather than a response defect and does not hold publication on its own."
    },
    {
      "rule_id": "response_rule:response_evidence_incomplete",
      "title": "Response evidence incomplete",
      "trigger_reason": "response_evidence_incomplete",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_response_evidence",
      "blocks_publication": true,
      "rationale": "A lane whose response packet does not cover the lane's drill, staffing, or rollback-target evidence narrows until the evidence is recaptured; the lane cannot claim Stable readiness on partial evidence."
    },
    {
      "rule_id": "response_rule:response_packet_freshness_breached",
      "title": "Response packet breached its freshness SLO",
      "trigger_reason": "response_packet_freshness_breached",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_response_packet",
      "blocks_publication": true,
      "rationale": "A lane cannot claim Stable readiness on a response packet that has aged past its freshness SLO; the lane narrows and the packet must be refreshed before it backs the lane again."
    },
    {
      "rule_id": "response_rule:response_packet_missing",
      "title": "No response packet captured",
      "trigger_reason": "response_packet_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_response_packet",
      "blocks_publication": true,
      "rationale": "A lane with no captured response packet has nothing to govern against and narrows until a packet lands."
    },
    {
      "rule_id": "response_rule:waiver_expired",
      "title": "Provisional waiver expired",
      "trigger_reason": "waiver_expired",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "hold_publication",
      "blocks_publication": true,
      "rationale": "A lane that only claimed Stable readiness because of a waiver narrows the moment the waiver expires; publication holds rather than silently keeping the promise."
    },
    {
      "rule_id": "response_rule:owner_signoff_missing",
      "title": "Ready lane lacks owner sign-off",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "request_owner_signoff",
      "blocks_publication": true,
      "rationale": "No lane claims Stable or LTS readiness without a named owner sign-off; an unsigned lane holds publication until the owner signs."
    },
    {
      "rule_id": "response_rule:emergency_control_unsatisfied",
      "title": "Required emergency control unsatisfied",
      "trigger_reason": "emergency_control_unsatisfied",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "satisfy_emergency_control",
      "blocks_publication": true,
      "rationale": "An emergency-disable lane cannot claim Stable readiness while a required emergency control is unsatisfied; the lane narrows until the control is satisfied."
    },
    {
      "rule_id": "response_rule:mirror_drill_unverified",
      "title": "Required mirror drill checkpoint unverified",
      "trigger_reason": "mirror_drill_unverified",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "verify_mirror_drill",
      "blocks_publication": true,
      "rationale": "A mirror/offline-drill lane cannot claim Stable readiness while a required drill checkpoint is unverified; the lane narrows until the checkpoint is verified."
    }
  ],
