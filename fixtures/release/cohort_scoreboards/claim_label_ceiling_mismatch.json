  "launch_cutline": {
    "cutline_level": "stable",
    "above_cutline_levels": [
      "lts",
      "stable"
    ],
    "below_cutline_levels": [
      "beta",
      "preview",
      "withdrawn"
    ],
    "description": "A cohort scoreboard row renders at a Stable (or LTS) public claim only when it carries a captured, within-freshness-SLO scoreboard packet, every scoreboard metric clears its threshold, the row owner has signed, every required signoff in the row's signoff loop is complete, any waiver it relies on is unexpired, and the public claim it backs is itself at or above the cutline. A row whose packet breached its freshness SLO or is missing, whose metric fails its threshold, whose required signoff loop is incomplete, whose waiver expired, or whose backing public claim is below the cutline narrows to a label below the cutline (beta, preview, withdrawn) and never inherits an adjacent signed-off row's label."
  },
  "release_blocking_scoreboard_refs": [
    "cohort_scoreboard:design_partner_managed_pilot",
    "cohort_scoreboard:design_partner_alpha_evidence",
    "cohort_scoreboard:certified_archetype_rust_workspace",
