    "cohort_scoreboard:stable_cohort_extension_author"
  ],
  "rules": [
    {
      "rule_id": "cohort_rule:claim_label_narrowed",
      "title": "Backing public claim narrowed below cutline",
      "trigger_reason": "claim_label_narrowed",
      "applies_to_labels": [
        "beta",
        "preview",
        "withdrawn"
      ],
      "default_action": "narrow_scoreboard_label",
      "blocks_publication": false,
      "rationale": "A scoreboard row whose backing public claim is already below the stable cutline inherits that ceiling; the stable claim manifest holds the claim upstream, so this is expected inheritance rather than a scoreboard defect and does not hold publication on its own."
    },
    {
      "rule_id": "cohort_rule:scoreboard_evidence_incomplete",
      "title": "Scoreboard evidence incomplete",
      "trigger_reason": "scoreboard_evidence_incomplete",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "recapture_scoreboard_evidence",
      "blocks_publication": true,
      "rationale": "A scoreboard row whose qualification evidence is incomplete cannot back a Stable public claim; it narrows and publication holds until the evidence is recaptured."
    },
    {
      "rule_id": "cohort_rule:scoreboard_packet_freshness_breached",
      "title": "Scoreboard packet breached its freshness SLO",
      "trigger_reason": "scoreboard_packet_freshness_breached",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_scoreboard_packet",
      "blocks_publication": true,
      "rationale": "A scoreboard row whose packet has aged past its freshness SLO no longer carries current proof; it narrows and publication holds until the packet is refreshed within its SLO."
    },
    {
      "rule_id": "cohort_rule:scoreboard_packet_missing",
      "title": "Scoreboard packet missing",
      "trigger_reason": "scoreboard_packet_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "refresh_scoreboard_packet",
      "blocks_publication": true,
      "rationale": "A scoreboard row with no captured packet cannot back a Stable public claim by riding an adjacent signed-off row; it narrows and publication holds until a packet is captured and signed off."
    },
    {
      "rule_id": "cohort_rule:waiver_expired",
      "title": "Relied-on waiver expired",
      "trigger_reason": "waiver_expired",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "hold_publication",
      "blocks_publication": true,
      "rationale": "A scoreboard row that signed off only because of a waiver loses that authorization once the waiver expires; it narrows and publication holds until the underlying gap is closed or a fresh waiver is granted."
    },
    {
      "rule_id": "cohort_rule:owner_signoff_missing",
      "title": "Row owner signoff missing",
      "trigger_reason": "owner_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "complete_signoff_loop",
      "blocks_publication": true,
      "rationale": "A scoreboard row cannot back a Stable public claim without the row owner's signoff; it narrows and publication holds until the owner signs."
    },
    {
      "rule_id": "cohort_rule:required_signoff_missing",
      "title": "Required signoff loop incomplete",
      "trigger_reason": "required_signoff_missing",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "complete_signoff_loop",
      "blocks_publication": true,
      "rationale": "A scoreboard row cannot back a Stable public claim until every required role in its signoff loop has signed; an incomplete loop narrows the row and holds publication until the loop closes."
    },
    {
      "rule_id": "cohort_rule:score_below_threshold",
      "title": "Scoreboard metric below threshold",
      "trigger_reason": "score_below_threshold",
      "applies_to_labels": [
        "lts",
        "stable"
      ],
      "default_action": "hold_publication",
      "blocks_publication": true,
      "rationale": "A scoreboard row with a metric that fails its threshold or is unmeasured cannot back a Stable public claim; it narrows and publication holds until the metric clears its threshold."
    }
  ],
