{
  "manifest_version": 1,
  "package_id": "dev.aureline.samples.prompt-gap",
  "publisher_id": "dev.aureline.samples",
  "version": "1.0.0-beta.1",
  "runtime_origin": "wasm",
  "host_contract_family": "wasm_component_model",
  "sdk": {
    "line_id": "aureline.sdk.beta",
    "line_semver": "1.0.0-beta.1",
    "host_abi_window": "component_model_abi_window_beta_1",
    "wit_world_refs": [
      "aureline:workspace-read@1.0.0",
      "aureline:network-egress@1.0.0"
    ],
    "lifecycle_metadata_refs": [
      "lifecycle_row:sdk_api_surface.wasm_component_model_host_api",
      "lifecycle_row:manifest_schema.extension_manifest_beta_v1",
      "lifecycle_row:permission_vocabulary.extension_permissions_v1"
    ]
  },
  "compatibility": {
    "aureline_versions": {
      "min": "0.3.0-beta.1",
      "max": "0.3.x"
    },
    "platforms": [
      "macos-aarch64"
    ],
    "support_class": "supported",
    "bridge_state": "native"
  },
  "permissions": [
    {
      "scope": "network_egress",
      "targets": [
        "https://api.aureline.example/prompt-gap"
      ],
      "purpose": "",
      "trust_mode": "explicit_approval_required",
      "review_required": true,
      "network": {
        "endpoint_class": "metadata_fetch"
      },
      "prompt": {
        "summary": "Allow metadata requests for this extension.",
        "deniable": true
      }
    }
  ],
  "lifecycle": {
    "state": "verified",
    "activation": {
      "triggers": [
        "on_command:dev.aureline.samples.prompt-gap.open"
      ],
      "lazy": true,
      "startup": false,
      "budget_ms": 120
    },
    "degraded_path": {
      "behavior_class": "read_only_degrade",
      "preserves_core_editing": true,
      "user_message_ref": "docs/extensions/m3/conformance_kit_beta.md#degraded-paths"
    },
    "disable": {
      "supported": true,
      "preserves_user_state": true,
      "evidence_ref": "evidence:prompt-gap:disable"
    },
    "rollback": {
      "supported": true,
      "last_known_good_ref": "extension:dev.aureline.samples.prompt-gap@1.0.0-beta.0"
    }
  },
  "conformance": {
    "fixtures": [
      {
        "scenario_class": "install",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/permission_prompt_missing_purpose_fail.json#install"
      },
      {
        "scenario_class": "activation",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/permission_prompt_missing_purpose_fail.json#activation"
      },
      {
        "scenario_class": "permission_prompt",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/permission_prompt_missing_purpose_fail.json#permission_prompt"
      },
      {
        "scenario_class": "degraded_path",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/permission_prompt_missing_purpose_fail.json#degraded_path"
      },
      {
        "scenario_class": "disable_rollback",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/permission_prompt_missing_purpose_fail.json#disable_rollback"
      }
    ]
  }
}
