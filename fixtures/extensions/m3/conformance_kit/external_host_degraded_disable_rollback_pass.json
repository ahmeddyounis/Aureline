{
  "manifest_version": 1,
  "package_id": "dev.aureline.samples.external-lsp",
  "publisher_id": "dev.aureline.samples",
  "version": "1.0.0-beta.1",
  "runtime_origin": "external_host",
  "host_contract_family": "external_host_process",
  "sdk": {
    "line_id": "aureline.sdk.beta",
    "line_semver": "1.0.0-beta.1",
    "host_abi_window": "external_host_process_window_documented",
    "wit_world_refs": [],
    "lifecycle_metadata_refs": [
      "lifecycle_row:sdk_api_surface.external_host_supervised_api",
      "lifecycle_row:manifest_schema.extension_manifest_beta_v1",
      "lifecycle_row:permission_vocabulary.extension_permissions_v1"
    ],
    "external_host_contract_ref": "external_host_contract:dev.aureline.samples.external-lsp@1.0.0"
  },
  "compatibility": {
    "aureline_versions": {
      "min": "0.3.0-beta.1",
      "max": "0.3.x"
    },
    "platforms": [
      "macos-aarch64",
      "linux-x86_64",
      "windows-x86_64"
    ],
    "support_class": "supported",
    "bridge_state": "native"
  },
  "permissions": [
    {
      "scope": "filesystem_read",
      "targets": [
        "workspace://trusted-roots"
      ],
      "purpose": "Read source files passed to the supervised language host.",
      "trust_mode": "read_only_degrade",
      "review_required": false
    },
    {
      "scope": "shell_execute",
      "targets": [
        "helper://dev.aureline.samples.external-lsp/server"
      ],
      "purpose": "Launch the supervised language host process under the extension runtime.",
      "trust_mode": "disabled_in_restricted_mode",
      "review_required": true,
      "prompt": {
        "summary": "Allow the supervised language host process for this workspace.",
        "deniable": true
      }
    },
    {
      "scope": "network_egress",
      "targets": [
        "https://registry.aureline.example/external-lsp"
      ],
      "purpose": "Check signed extension-owned metadata through the configured registry.",
      "trust_mode": "explicit_approval_required",
      "review_required": true,
      "network": {
        "endpoint_class": "package_registry"
      },
      "prompt": {
        "summary": "Allow signed registry metadata checks for the language host.",
        "deniable": true
      }
    }
  ],
  "lifecycle": {
    "state": "resolved",
    "activation": {
      "triggers": [
        "on_language:sample"
      ],
      "lazy": true,
      "startup": false,
      "budget_ms": 180
    },
    "degraded_path": {
      "behavior_class": "disable_background_work",
      "preserves_core_editing": true,
      "user_message_ref": "docs/extensions/m3/conformance_kit_beta.md#degraded-paths"
    },
    "disable": {
      "supported": true,
      "preserves_user_state": true,
      "evidence_ref": "evidence:external-lsp:disable"
    },
    "rollback": {
      "supported": true,
      "last_known_good_ref": "extension:dev.aureline.samples.external-lsp@1.0.0-beta.0"
    }
  },
  "conformance": {
    "fixtures": [
      {
        "scenario_class": "install",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/external_host_degraded_disable_rollback_pass.json#install"
      },
      {
        "scenario_class": "activation",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/external_host_degraded_disable_rollback_pass.json#activation"
      },
      {
        "scenario_class": "permission_prompt",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/external_host_degraded_disable_rollback_pass.json#permission_prompt"
      },
      {
        "scenario_class": "degraded_path",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/external_host_degraded_disable_rollback_pass.json#degraded_path"
      },
      {
        "scenario_class": "disable_rollback",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/external_host_degraded_disable_rollback_pass.json#disable_rollback"
      }
    ]
  }
}
