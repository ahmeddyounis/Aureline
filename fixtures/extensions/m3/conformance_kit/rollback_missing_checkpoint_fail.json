{
  "manifest_version": 1,
  "package_id": "dev.aureline.samples.rollback-gap",
  "publisher_id": "dev.aureline.samples",
  "version": "1.0.0-beta.1",
  "runtime_origin": "external_host",
  "host_contract_family": "external_host_process",
  "sdk": {
    "line_id": "aureline.sdk.beta",
    "line_semver": "1.0.0-beta.1",
    "host_abi_window": "external_host_process_window_documented",
    "wit_world_refs": [],
    "lifecycle_metadata_refs": [
      "lifecycle_row:sdk_api_surface.external_host_supervised_api",
      "lifecycle_row:manifest_schema.extension_manifest_beta_v1"
    ],
    "external_host_contract_ref": "external_host_contract:dev.aureline.samples.rollback-gap@1.0.0"
  },
  "compatibility": {
    "aureline_versions": {
      "min": "0.3.0-beta.1",
      "max": "0.3.x"
    },
    "platforms": [
      "macos-aarch64"
    ],
    "support_class": "supported",
    "bridge_state": "native"
  },
  "permissions": [
    {
      "scope": "shell_execute",
      "targets": [
        "helper://dev.aureline.samples.rollback-gap/server"
      ],
      "purpose": "Launch the supervised test host for rollback validation.",
      "trust_mode": "disabled_in_restricted_mode",
      "review_required": true,
      "prompt": {
        "summary": "Allow the supervised rollback test host.",
        "deniable": true
      }
    }
  ],
  "lifecycle": {
    "state": "resolved",
    "activation": {
      "triggers": [
        "on_language:rollback-gap"
      ],
      "lazy": true,
      "startup": false,
      "budget_ms": 180
    },
    "degraded_path": {
      "behavior_class": "disable_background_work",
      "preserves_core_editing": true,
      "user_message_ref": "docs/extensions/m3/conformance_kit_beta.md#degraded-paths"
    },
    "disable": {
      "supported": true,
      "preserves_user_state": true,
      "evidence_ref": "evidence:rollback-gap:disable"
    },
    "rollback": {
      "supported": true
    }
  },
  "conformance": {
    "fixtures": [
      {
        "scenario_class": "install",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/rollback_missing_checkpoint_fail.json#install"
      },
      {
        "scenario_class": "activation",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/rollback_missing_checkpoint_fail.json#activation"
      },
      {
        "scenario_class": "permission_prompt",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/rollback_missing_checkpoint_fail.json#permission_prompt"
      },
      {
        "scenario_class": "degraded_path",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/rollback_missing_checkpoint_fail.json#degraded_path"
      },
      {
        "scenario_class": "disable_rollback",
        "fixture_ref": "fixtures/extensions/m3/conformance_kit/rollback_missing_checkpoint_fail.json#disable_rollback"
      }
    ]
  }
}
